fx/thebes/gfxMacFont.cpp", "gfx/thebes/gfxMacFont.h", "layout/generic/TextDrawTarget.h"], "git_node": null, "git_parents": [null], "node": "b01be3d4095f1aa565ce619f67f7476438543fdc", "parents": ["d075d05bea936f5272912ac0b47eb7d6b1e0205c"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1414154 - Remove gfxContext::Set/GetFontSmoothingBackgroundColor and TextRunDrawParams::fontSmoothingBGColor. r=lsalzman\n\nMozReview-Commit-ID: BXZP3maOJRi", "files": ["gfx/thebes/gfxContext.cpp", "gfx/thebes/gfxContext.h", "gfx/thebes/gfxFont.h", "gfx/thebes/gfxTextRun.cpp", "layout/generic/nsTextFrame.cpp", "layout/xul/nsTextBoxFrame.cpp", "layout/xul/tree/nsTreeBodyFrame.cpp"], "git_node": null, "git_parents": [null], "node": "71651421a36f04f7a2aed614abc7b539e4e7ef6e", "parents": ["b01be3d4095f1aa565ce619f67f7476438543fdc"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1414157 - Supply the font smoothing background color in the webrender FontInstanceOptions. r=lsalzman\n\nMozReview-Commit-ID: CaI4FH7GoI8", "files": ["gfx/2d/ScaledFontMac.cpp"], "git_node": null, "git_parents": [null], "node": "a80606dac3934ba1219506c8fc6c79a31f43f4d9", "parents": ["71651421a36f04f7a2aed614abc7b539e4e7ef6e"], "tags": []}, {"author": "ffxbld", "branch": "default", "desc": "No bug, Automated HSTS preload list update from host bld-linux64-spot-030 - a=hsts-update", "files": ["security/manager/ssl/nsSTSPreloadList.errors", "security/manager/ssl/nsSTSPreloadList.inc"], "git_node": null, "git_parents": [null], "node": "44845ed77d8d5ff558e07a5fb5384e9bb4973a4a", "parents": ["849017ffe2976f7721c20c3625d8fafeb3cce8dd"], "tags": []}, {"author": "ffxbld", "branch": "default", "desc": "No bug, Automated HPKP preload list update from host bld-linux64-spot-030 - a=hpkp-update", "files": ["security/manager/ssl/StaticHPKPins.h"], "git_node": null, "git_parents": [null], "node": "cc9ba74427d3c7cae8da70964db8aa45f0d5e4b2", "parents": ["44845ed77d8d5ff558e07a5fb5384e9bb4973a4a"], "tags": []}, {"author": "ffxbld", "branch": "default", "desc": "No bug, Automated HSTS preload list update from host bld-linux64-spot-035 - a=hsts-update", "files": ["security/manager/ssl/nsSTSPreloadList.errors", "security/manager/ssl/nsSTSPreloadList.inc"], "git_node": null, "git_parents": [null], "node": "66d07f7ef35f15490874b5156224523b90812550", "parents": ["cc9ba74427d3c7cae8da70964db8aa45f0d5e4b2"], "tags": []}, {"author": "ffxbld", "branch": "default", "desc": "No bug, Automated HPKP preload list update from host bld-linux64-spot-035 - a=hpkp-update", "files": ["security/manager/ssl/StaticHPKPins.h"], "git_node": null, "git_parents": [null], "node": "e64846245b002c204144ac412fbd874e32e47edf", "parents": ["66d07f7ef35f15490874b5156224523b90812550"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "merge autoland to mozilla-central. r=merge a=merge", "files": [], "git_node": null, "git_parents": [null, null], "node": "4e43d3919c51deab933fabe451900504078c3ec6", "parents": ["e64846245b002c204144ac412fbd874e32e47edf", "a80606dac3934ba1219506c8fc6c79a31f43f4d9"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "merge mozilla-inbound to mozilla-central. r=merge a=merge", "files": ["js/src/vm/StopIterationObject.h", "layout/generic/nsTextFrame.cpp", "layout/xul/nsTextBoxFrame.cpp", "layout/xul/tree/nsTreeBodyFrame.cpp"], "git_node": null, "git_parents": [null, null], "node": "179dae92e4d794e7f45ad080ff01908c80691f31", "parents": ["4e43d3919c51deab933fabe451900504078c3ec6", "73a48b92351a1c615108c36324c4900cb8ad41a6"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1413811 (part 1) - Avoid PrefCallback for pref callbacks registered with Preferences::RegisterCallback(). r=glandium.\n\nPref callbacks registered via Preferences::Add*VarCache() are wrapped in a\nValueObserver -- which groups all callback requests that have the same prefname\nand callback function -- and the ValueObserver is put into gObserverTable. This\nis reasonable.\n\nObservers registered via nsPrefBranch::Add{Weak,Strong}Observer() are wrapped\nin a PrefCallback, and the PrefCallback is put into sRootBranch-\u003emObservers.\nThis is also reasonable.\n\nPref callbacks registered via Preferences::RegisterCallback() are conceptually\nsimilar to those registered via Preferences::Add*VarCache(). However, they are\nimplemented by using *both* of the above mechanisms: they are wrapped in a\nValueObserver which is put into gObserverTable, *and* that ValueObserver is then\nwrapped in a PrefCallback which is put into sRootBranch-\u003emObservers.\n\nUsing both mechanisms isn't necessary, so this patch removes the\nPrefCallback/mObservers part. This makes Preferences::RegisterCallback() work\nin much the same way as Preferences::Add*VarCache().\n\nSpecifically:\n\n- Preferences::RegisterCallback() now calls PREF_RegisterCallback() instead of\n  Preferences::AddStrongObserver(). This makes it more similar to\n  RegisterPriorityCallback().\n\n- Preferences::UnregisterCallback() now explicitly calls\n  PREF_UnregisterCallback() instead of Preferences::RemoveObserver (which\n  previously happened via ~ValueObserver() when the ValueObserver was removed\n  from gObserverTable and its refcount dropped to zerod).\n\nMozReview-Commit-ID: 1tEQNeYrBUU", "files": ["modules/libpref/Preferences.cpp"], "git_node": null, "git_parents": [null], "node": "b7ade96f752be032b1de492c2520c68d242d04ec", "parents": ["179dae92e4d794e7f45ad080ff01908c80691f31"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1413811 (part 2) - Factor out similarities between RegisterPriorityCallback() and Preferences::RegisterCallback(). r=glandium.\n\nMozReview-Commit-ID: 8K3RNjZTSc3", "files": ["modules/libpref/Preferences.cpp"], "git_node": null, "git_parents": [null], "node": "044253938e1c21d20026e88be2ff9a4f4f3beb27", "parents": ["b7ade96f752be032b1de492c2520c68d242d04ec"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1413811 (part 3) - Rename RegisterPriorityCallback(). r=glandium.\n\nMozReview-Commit-ID: 5Ov1cHgfB5Y", "files": ["modules/libpref/Preferences.cpp"], "git_node": null, "git_parents": [null], "node": "3d4a51bb3b210376c58239968e37d930d76f51fc", "parents": ["044253938e1c21d20026e88be2ff9a4f4f3beb27"], "tags": []}, {"author": "Junior Hsu \u003cjuhsu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412218 - Add telemetry probe for how many users with legacy cookie files. r=jdm, data-r=francois", "files": ["netwerk/cookie/nsCookieService.cpp", "toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "8110a775c106a10810123208b86d9781b111647d", "parents": ["3d4a51bb3b210376c58239968e37d930d76f51fc"], "tags": []}, {"author": "Bob Clary \u003cbclary@bclary.com\u003e", "branch": "default", "desc": "Bug 1408241 - disable Mdm1 dom/media/test/test_mediarecorder_record_addtracked_stream, r=jmaher.", "files": ["dom/media/test/mochitest.ini"], "git_node": null, "git_parents": [null], "node": "8172eea4088e8ea74149b4151814ac4201e4fac1", "parents": ["8110a775c106a10810123208b86d9781b111647d"], "tags": []}, {"author": "Bob Clary \u003cbclary@bclary.com\u003e", "branch": "default", "desc": "Bug 1365451 - disable Cdm1 dom/media/test/crashtests/691096-1.html, r=jmaher.", "files": ["dom/media/test/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "c0d3f0b323a3478e0c4ef39fdb3ba039f8dba95c", "parents": ["8172eea4088e8ea74149b4151814ac4201e4fac1"], "tags": []}, {"author": "Paul Bone \u003cpbone@mozilla.com\u003e", "branch": "default", "desc": "Bug 1298018 - Part 1: Clarify emptyChunks_ comment. r=jonco", "files": ["js/src/gc/GCRuntime.h"], "git_node": null, "git_parents": [null], "node": "7baa6f43d16abac72422c725453650c520b4c395", "parents": ["c0d3f0b323a3478e0c4ef39fdb3ba039f8dba95c"], "tags": []}, {"author": "Paul Bone \u003cpbone@mozilla.com\u003e", "branch": "default", "desc": "Bug 1298018 - Part 2: Remove some unused methods. r=jonco", "files": ["js/src/gc/Nursery.h"], "git_node": null, "git_parents": [null], "node": "7434bbd4eee44b52e7bc43926c8444400391ee9c", "parents": ["7baa6f43d16abac72422c725453650c520b4c395"], "tags": []}, {"author": "Paul Bone \u003cpbone@mozilla.com\u003e", "branch": "default", "desc": "Bug 1298018 - Part 3: Replace updateNumChunks(). r=jonco\n\nThis method both shrinks and grows the nursery.  This change replaces it\nwith specialised code to either shrink or grow the nursery.", "files": ["js/src/gc/Nursery.cpp", "js/src/gc/Nursery.h"], "git_node": null, "git_parents": [null], "node": "bf065ffab5f7649ec7724ad226e97a853715497a", "parents": ["7434bbd4eee44b52e7bc43926c8444400391ee9c"], "tags": []}, {"author": "Paul Bone \u003cpbone@mozilla.com\u003e", "branch": "default", "desc": "Bug 1298018 - Part 4: Lazily allocate nursery chunks. r=jonco", "files": ["js/src/gc/Nursery.cpp", "js/src/gc/Nursery.h"], "git_node": null, "git_parents": [null], "node": "d8dbac587181077425996af8a29fb3df03765614", "parents": ["bf065ffab5f7649ec7724ad226e97a853715497a"], "tags": []}, {"author": "Paul Bone \u003cpbone@mozilla.com\u003e", "branch": "default", "desc": "Bug 1298018 - Part 5: Remove allocateFirstChunk(). r=jonco", "files": ["js/src/gc/Nursery.cpp", "js/src/gc/Nursery.h"], "git_node": null, "git_parents": [null], "node": "7bd9208b8c7c92521abfc8e4cae34bfbf419547a", "parents": ["d8dbac587181077425996af8a29fb3df03765614"], "tags": []}, {"author": "JerryShih \u003chshih@mozilla.com\u003e", "branch": "default", "desc": "Bug 1409176 - make SyncObjectD3D11Client become fallible. r=dvander\n\nCurrently, the device-reset flow doesn't notify the decoder for device change\nimmediately. The decoder might use an invalid sync-object for synchronization.\nThen, we will hit some assertions.\nThis patch try to make the synchronization flow become fallible, then we could\npass the error to the media framework for error handling.\n\nMozReview-Commit-ID: BFY32MmOdt0", "files": ["gfx/layers/SyncObject.h", "gfx/layers/d3d11/TextureD3D11.cpp", "gfx/layers/d3d11/TextureD3D11.h"], "git_node": null, "git_parents": [null], "node": "00b5d1cc54d3f45a0c2064b7530f131b9ad9c919", "parents": ["7bd9208b8c7c92521abfc8e4cae34bfbf419547a"], "tags": []}, {"author": "JerryShih \u003chshih@mozilla.com\u003e", "branch": "default", "desc": "Bug 1409176 - handle decoder error in WMFMediaDataDecoder::ProcessDecode(). r=jya,mattwoodrow\n\nThe DXVA decoder might hit some error because of the hardware device status.\nThis patch try to pass the error code to the decoder promise object to\ndeal with the error.\n\nMozReview-Commit-ID: IAj8gzKGF3j", "files": ["dom/media/platforms/wmf/DXVA2Manager.cpp", "dom/media/platforms/wmf/WMFMediaDataDecoder.cpp"], "git_node": null, "git_parents": [null], "node": "382939cc1ff5dc276d7c7d70d14fece9fbd59e77", "parents": ["00b5d1cc54d3f45a0c2064b7530f131b9ad9c919"], "tags": []}, {"author": "Csoregi Natalia \u003cncsoregi@mozilla.com\u003e", "branch": "default", "desc": "Backed out 5 changesets (bug 1411688) for failing Android single-locale repacks. r=backout a=backout\n\nBacked out changeset 65d5d13b4ea0 (bug 1411688)\nBacked out changeset 8ba514bd8ed6 (bug 1411688)\nBacked out changeset 866854a996b8 (bug 1411688)\nBacked out changeset 34f83aab44e6 (bug 1411688)\nBacked out changeset 2e4e139bb5d7 (bug 1411688)", "files": ["build.gradle", "mobile/android/config/mozconfigs/android-aarch64/l10n-nightly", "mobile/android/config/mozconfigs/android-api-16/l10n-nightly", "mobile/android/config/mozconfigs/android-x86/l10n-nightly", "mobile/android/geckoview/build.gradle", "mobile/android/gradle/with_gecko_binaries.gradle", "taskcluster/ci/l10n/kind.yml", "taskcluster/ci/nightly-l10n/kind.yml", "taskcluster/taskgraph/transforms/l10n.py", "testing/mozharness/configs/single_locale/tc_android-api-16.py", "testing/mozharness/scripts/mobile_l10n.py", "toolkit/mozapps/installer/upload-files-APK.mk"], "git_node": null, "git_parents": [null], "node": "a73e202ca31d30bc2b96418fa81d1096f8dc731e", "parents": ["179dae92e4d794e7f45ad080ff01908c80691f31"], "tags": []}, {"author": "Csoregi Natalia \u003cncsoregi@mozilla.com\u003e", "branch": "default", "desc": "Backed out 6 changesets (bug 1395922) for failing Media tests test_eme_sample_groups_playback.html and test_eme_sample_groups_playback.html r=backout a=backout\n\nBacked out changeset f856af63682e (bug 1395922)\nBacked out changeset f59a7e727f39 (bug 1395922)\nBacked out changeset 9cd31c6a8e2c (bug 1395922)\nBacked out changeset d46f952f94f8 (bug 1395922)\nBacked out changeset f786d928b1e0 (bug 1395922)\nBacked out changeset bacda0f99f71 (bug 1395922)", "files": ["dom/html/HTMLMediaElement.cpp", "dom/html/HTMLMediaElement.h", "dom/media/MediaDecoder.cpp", "dom/media/MediaDecoder.h", "dom/media/MediaFormatReader.cpp", "dom/media/MediaFormatReader.h", "dom/media/MediaPromiseDefs.h", "dom/media/moz.build", "dom/media/test/bipbop_225w_175kbps.mp4^headers^", "dom/media/test/mochitest.ini", "dom/media/test/test_eme_detach_reattach_same_mediakeys_during_playback.html", "dom/media/test/test_eme_unsetMediaKeys_then_capture.html"], "git_node": null, "git_parents": [null], "node": "8b9167b8a937e09f6673d4d7d693c6ac1c25a3d7", "parents": ["a73e202ca31d30bc2b96418fa81d1096f8dc731e"], "tags": []}, {"author": "J.C. Jones \u003cjjones@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414627 - Remove mention of Firefox from Symantec distrust message r=flod\n\nThis is a string change to a string introduced to Nightly on 3 November.\n\nMozReview-Commit-ID: BlfJhmcwgOT", "files": ["browser/locales/en-US/chrome/browser/browser.properties"], "git_node": null, "git_parents": [null], "node": "c9ed5bfc1e34ed57be8cae7b0ccc3e6cac55b7ab", "parents": ["179dae92e4d794e7f45ad080ff01908c80691f31"], "tags": []}, {"author": "Fischer.json \u003cfischer.json@gmail.com\u003e", "branch": "default", "desc": "Bug 1410416 - Part 1: Have SiteDateManager.jsm call `propagateUnregister` to remove service workers, r=baku\n\nMozReview-Commit-ID: BNUhm6a2x1b", "files": ["browser/components/preferences/SiteDataManager.jsm"], "git_node": null, "git_parents": [null], "node": "8ef662f3fa226a9661e3744600bef42bef98258e", "parents": ["c9ed5bfc1e34ed57be8cae7b0ccc3e6cac55b7ab"], "tags": []}, {"author": "Fischer.json \u003cfischer.json@gmail.com\u003e", "branch": "default", "desc": "Bug 1410416 - Part 2 - Add test cases about removing service workers, r=baku\n\nMozReview-Commit-ID: 6MeilGCkomc", "files": ["browser/components/preferences/in-content/tests/browser.ini", "browser/components/preferences/in-content/tests/browser_siteData.js", "browser/components/preferences/in-content/tests/browser_siteData3.js", "browser/components/preferences/in-content/tests/head.js", "browser/components/preferences/in-content/tests/service_worker_test.html", "browser/components/preferences/in-content/tests/service_worker_test.js"], "git_node": null, "git_parents": [null], "node": "f89f5660e3d74421398997e947938245069e97a5", "parents": ["8ef662f3fa226a9661e3744600bef42bef98258e"], "tags": []}, {"author": "Prathiksha \u003cprathikshaprasadsuman@gmail.com\u003e", "branch": "default", "desc": "Bug 1400660 - Create a new pref to determine the initial state of the 'See details' panel in about:blocked pages. r=francois,johannh\n\nMozReview-Commit-ID: CxZmvc34ULB", "files": ["browser/app/profile/firefox.js", "browser/base/content/content.js"], "git_node": null, "git_parents": [null], "node": "f1f109730a9bddf15bd1febcb5a08a6796415f0b", "parents": ["f89f5660e3d74421398997e947938245069e97a5"], "tags": []}, {"author": "Prathiksha \u003cprathikshaprasadsuman@gmail.com\u003e", "branch": "default", "desc": "Bug 1363969 - Remove prompt action that asks to restart the browser when we change TP blocklists. r=francois\n\nMozReview-Commit-ID: 3PEIcyJ8zWV", "files": ["browser/components/preferences/blocklists.js", "browser/locales/en-US/chrome/browser/preferences/preferences.properties"], "git_node": null, "git_parents": [null], "node": "68850c2bf7bb8b6832ea63c428b86706f3b2af97", "parents": ["f1f109730a9bddf15bd1febcb5a08a6796415f0b"], "tags": []}, {"author": "Glenn Watson \u003cgithub@intuitionlibrary.com\u003e", "branch": "default", "desc": "servo: Merge #19123 - Update WR (border artifact fix, native font support on Linux) (from glennw:update-wr-border); r=emilio\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 644e574e1b95a46f8fde77af5a24fe41d97d829f", "files": ["servo/Cargo.lock"], "git_node": null, "git_parents": [null], "node": "fa0f66eaa81fa9663de8e1d73f1299c585ef53f8", "parents": ["68850c2bf7bb8b6832ea63c428b86706f3b2af97"], "tags": []}, {"author": "Mantaroh Yoshinaga \u003cmantaroh@gmail.com\u003e", "branch": "default", "desc": "Bug 1411121 - Part 1: Return NS_ERROR_FAILURE if nsIPrintDialogService doesn't exist on GTK when showing print dialog. r=karlt\n\nA printingui uses the xul print dialog(i.e. printdialog.xul) if there\nare not nsIPrintDialogService. But this code is unreachable code since\ncurrent gtk widget has nsIPrintDialogService always.\nSo this patch will remove this code.\n\nMozReview-Commit-ID: EeM6YytEfdW", "files": ["toolkit/components/printingui/unixshared/nsPrintingPromptService.cpp", "toolkit/components/printingui/unixshared/nsPrintingPromptService.h"], "git_node": null, "git_parents": [null], "node": "b503682a7c6eb3ff80382980e6a60675c29f873b", "parents": ["fa0f66eaa81fa9663de8e1d73f1299c585ef53f8"], "tags": []}, {"author": "Mantaroh Yoshinaga \u003cmantaroh@gmail.com\u003e", "branch": "default", "desc": "Bug 1411121 - Part 2: Remove printdialog.xul and printjoboptions.xul. r=mconley\n\nThis patch will remove printing xul dialog and related files since a caller of\nthis xul dialog doesn't exist.\nThe printjoboptions.xul is only used by printdialog.xul.\n\nMozReview-Commit-ID: B6VZuj3Lg1b", "files": ["browser/base/content/test/static/browser_all_files_referenced.js", "toolkit/components/printing/content/printdialog.js", "toolkit/components/printing/content/printdialog.xul", "toolkit/components/printing/content/printjoboptions.js", "toolkit/components/printing/content/printjoboptions.xul", "toolkit/components/printing/jar.mn", "toolkit/locales/en-US/chrome/global/printdialog.dtd", "toolkit/locales/en-US/chrome/global/printjoboptions.dtd", "toolkit/locales/jar.mn"], "git_node": null, "git_parents": [null], "node": "1ca360e198808af99ed35305d1a6a37fe87452f6", "parents": ["b503682a7c6eb3ff80382980e6a60675c29f873b"], "tags": []}, {"author": "Mantaroh Yoshinaga \u003cmantaroh@gmail.com\u003e", "branch": "default", "desc": "Bug 1411121 - Part 3: Remove the nsIPrintingPromptService::showPrinterProperties() r=mconley\n\nWe can remove nsIPrintingPromptService::showPrinterProperties() since this\ncaller doesn't exist and this implementation of each platform returns\nNS_ERROR_NOT_IMPLEMENTED.\n\nMozReview-Commit-ID: 4s4ncv9U5Od", "files": ["toolkit/components/browser/nsIPrintingPromptService.idl", "toolkit/components/printingui/ipc/nsPrintingProxy.cpp", "toolkit/components/printingui/mac/nsPrintingPromptService.cpp", "toolkit/components/printingui/unixshared/nsPrintingPromptService.cpp", "toolkit/components/printingui/win/nsPrintingPromptService.cpp"], "git_node": null, "git_parents": [null], "node": "db6983d22fd31179be27602dd1b66138f6f8fc87", "parents": ["1ca360e198808af99ed35305d1a6a37fe87452f6"], "tags": []}, {"author": "Mantaroh Yoshinaga \u003cmantaroh@gmail.com\u003e", "branch": "default", "desc": "Bug 1411121 - Part 4. Remove printPageSetup resources from linux package since Linux will display native dialog. r=mconley\n\nThis patch will remove printPageSetup resources from Linux package. This xul is\n'PageSetup' dialog, but gecko doesn't use this dialog since gecko will display\na native page setup dialog.\n(For Detail, See nsPrintDialogServiceGTK::ShowPageSetup)\n\nMozReview-Commit-ID: 4AFjaM3cB35", "files": ["toolkit/components/printing/jar.mn", "toolkit/locales/jar.mn", "toolkit/themes/linux/global/jar.mn"], "git_node": null, "git_parents": [null], "node": "110873e70443c09818ac49a8000097d22316a92f", "parents": ["db6983d22fd31179be27602dd1b66138f6f8fc87"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414121. P1 - let mozDumpDebugInfo() return a promise. r=bz\n\nMozReview-Commit-ID: Klfr3AYdSCG", "files": ["dom/html/HTMLMediaElement.cpp", "dom/html/HTMLMediaElement.h", "dom/webidl/HTMLMediaElement.webidl"], "git_node": null, "git_parents": [null], "node": "5dc63b15b7e29659a21b9d63563272045117b03d", "parents": ["110873e70443c09818ac49a8000097d22316a92f"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414121. P2 - let MediaDecoder::DumpDebugInfo() return a MozPromise. r=jya\n\nMozReview-Commit-ID: Fau4ysdlwwa", "files": ["dom/html/HTMLMediaElement.cpp", "dom/media/MediaDecoder.cpp", "dom/media/MediaDecoder.h"], "git_node": null, "git_parents": [null], "node": "694d4dc74495c0453fc63d15f6cbf9a77c6604e3", "parents": ["5dc63b15b7e29659a21b9d63563272045117b03d"], "tags": []}, {"author": "steveck-chung \u003cschung@mozilla.com\u003e", "branch": "default", "desc": "Bug 1413491 - [Form Autofill] Provide 2 different option for address merge for form manual/autofill submission. r=lchang\n\nMozReview-Commit-ID: FqbpOKzWGcb", "files": ["browser/extensions/formautofill/FormAutofillParent.jsm", "browser/extensions/formautofill/ProfileStorage.jsm", "browser/extensions/formautofill/test/mochitest/test_on_address_submission.html", "browser/extensions/formautofill/test/unit/test_addressRecords.js"], "git_node": null, "git_parents": [null], "node": "bf2259850d28be7dff3a0150381bc1085164d632", "parents": ["694d4dc74495c0453fc63d15f6cbf9a77c6604e3"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1375772 - don't evict the block which is in the current cached range. r=cpearce\n\nEvicting the block will result in a gap in the current cached range starting\nfrom mStreamOffset to mChannelOffset. Then we have\n|GetCachedDataEndInternal(mStreamOffset) \u003c mChannelOffset| and MediaCache\nwill open a new channel to fill the gap which is bad.\n\nThis is exactly the issue described in bug 1347174 where we limit the readahead\nsize to prevent the problem above from happening.\n\nHowever bug 1347174 is indeed a workaround instead of a fix. It works around\nthe issue by suspending the download before the cache is full and has to evict\nsome blocks to allow new data to come in.\n\nWe should let MediaCache suspend the channel if it is full or evict played\nblocks if possible.\n\nMozReview-Commit-ID: HuUsZLdHGuh", "files": ["dom/media/MediaCache.cpp"], "git_node": null, "git_parents": [null], "node": "3fcb7efd900132296ab90c8f46d18add2532e6f6", "parents": ["bf2259850d28be7dff3a0150381bc1085164d632"], "tags": []}, {"author": "Glenn Watson \u003cgithub@intuitionlibrary.com\u003e", "branch": "default", "desc": "servo: Merge #19124 - Update WR (removal of clip-scroll groups and packed layers) (from glennw:update-wr-csg); r=jdm\n\nThis shouldn't have any visual effect on Servo - it's an\nimportant internal optimization and simplification though.\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 88505dc2ffc31efa614e1a5070a9bc23feded30a", "files": ["servo/Cargo.lock"], "git_node": null, "git_parents": [null], "node": "4a6748b997e052a996f34ae49ba1929394c0d753", "parents": ["3fcb7efd900132296ab90c8f46d18add2532e6f6"], "tags": []}, {"author": "Fred Lin \u003cgasolin@gmail.com\u003e", "branch": "default", "desc": "Bug 1413938 - remove setScalingStyles and set css variables in component;r=Honza\n\nMozReview-Commit-ID: Emfb2w2Z7cN", "files": ["devtools/client/netmonitor/src/components/RequestListContent.js"], "git_node": null, "git_parents": [null], "node": "f21886b3741e7562f97f7d5fc6d9816e6c5a4ce6", "parents": ["4a6748b997e052a996f34ae49ba1929394c0d753"], "tags": []}, {"author": "Chris Pearce \u003ccpearce@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414680 - Remove IsActive() and IsHidden() from MediaDecoderOwner as they're unused by MediaDecoder. r=jwwang\n\nMozReview-Commit-ID: 7NaPBmQJVQC", "files": ["dom/html/HTMLMediaElement.h", "dom/media/MediaDecoderOwner.h", "dom/media/gtest/MockMediaDecoderOwner.h"], "git_node": null, "git_parents": [null], "node": "c38e1f292403b5d5f692ff83961116fa68f4f483", "parents": ["f21886b3741e7562f97f7d5fc6d9816e6c5a4ce6"], "tags": []}, {"author": "Chris Pearce \u003ccpearce@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414680 - Make MediaDecoderOwner::DispatchAsyncEvent() return void. r=jwwang\n\nThe return value is unchecked in MediaDecoder, and we only ever returned\nNS_OK anyway. And we if the dispatch fails, we can't really do anything;\ndispatching an \"error\" event probably won't work.\n\nMozReview-Commit-ID: 67K6Mjft6tY", "files": ["dom/html/HTMLMediaElement.cpp", "dom/html/HTMLMediaElement.h", "dom/media/MediaDecoderOwner.h", "dom/media/gtest/MockMediaDecoderOwner.h"], "git_node": null, "git_parents": [null], "node": "408257c94413fe9376d282edcb53097764be1491", "parents": ["c38e1f292403b5d5f692ff83961116fa68f4f483"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414213. P1 - H264::NumSPS() should return 0 if aExtraData is empty. r=jya\n\nMozReview-Commit-ID: JTzEqYt9mQr", "files": ["media/libstagefright/binding/H264.cpp"], "git_node": null, "git_parents": [null], "node": "fe1d819e6cca883629d37b7cf055894ded17658f", "parents": ["408257c94413fe9376d282edcb53097764be1491"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414213. P2 - don't continue reading if reader.Read(5) failed. r=jya\n\nMozReview-Commit-ID: 1vNbACa9Vpv", "files": ["media/libstagefright/binding/H264.cpp"], "git_node": null, "git_parents": [null], "node": "bbe8f621038333bea5eb4f6cbf157d1030166700", "parents": ["fe1d819e6cca883629d37b7cf055894ded17658f"], "tags": []}, {"author": "Lee Bousfield \u003cljbousfield@gmail.com\u003e", "branch": "default", "desc": "Bug 1398539: Inhibit screensaver with XScreenSaverSuspend r=karlt\n\nMozReview-Commit-ID: LhhpaDaPdaO", "files": ["widget/gtk/WakeLockListener.cpp"], "git_node": null, "git_parents": [null], "node": "baff3e8129149cd9667ffd9b827ee16006892b0c", "parents": ["bbe8f621038333bea5eb4f6cbf157d1030166700"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414118: Update handler's AccessibleTextTearoff for IAccessibleHypertext2. r=MarcoZ\n\nBug 873444 implemented support for IAccessibleHypertext2.\nAccessibleHandler's AccessibleTextTearoff needs to be updated accordingly, thus eliminating an additional cross-process QueryInterface for IAHypertext2 when the client also wants IAText.\n\nMozReview-Commit-ID: EGqYX7jY9Cp", "files": ["accessible/ipc/win/handler/AccessibleHandler.cpp", "accessible/ipc/win/handler/AccessibleTextTearoff.cpp", "accessible/ipc/win/handler/AccessibleTextTearoff.h"], "git_node": null, "git_parents": [null], "node": "1de3d5f589b3529f24d69aaa76662d1022ca80d9", "parents": ["baff3e8129149cd9667ffd9b827ee16006892b0c"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414706 - dump debug info immediately when a test times out. r=jya\n\nFor now we dump debug info when the whole test case finishes. However, it\nwould be harder to relate the debug info to the timed out test when there\nare multiple test timeouts.\n\nNote we don't call |this.finished(token)| until v.mozDumpDebugInfo() is done\nbecause |this.finished(token)| might finish the whole test case and clean up\nthe page which might change the output of v.mozDumpDebugInfo().\n\nMozReview-Commit-ID: BrdZ0EVpaBQ", "files": ["dom/media/test/manifest.js"], "git_node": null, "git_parents": [null], "node": "046aa4f8f7583671dc3c682e544a20e84eaf5478", "parents": ["1de3d5f589b3529f24d69aaa76662d1022ca80d9"], "tags": []}, {"author": "KuoE0 \u003ckuoe0.tw@gmail.com\u003e", "branch": "default", "desc": "Bug 1399310 - (Part 1) Make `nsTextFrame::DrawTextRunAndDecorations` draw only in the range of the text. r=jfkthame\n\nWe create a clip region with the text length to make the decoration line\nwould be only drawn in the area. This allows the decoration line would\nnot be drawn multiple times when the text is being selected.\n\nMozReview-Commit-ID: 4gjawk71eSu", "files": ["layout/generic/nsTextFrame.cpp"], "git_node": null, "git_parents": [null], "node": "0564a1d6d2d6ae8bbb00afcfb4fa289211854d64", "parents": ["046aa4f8f7583671dc3c682e544a20e84eaf5478"], "tags": []}, {"author": "KuoE0 \u003ckuoe0.tw@gmail.com\u003e", "branch": "default", "desc": "Bug 1399310 - (Part 2) Add a bunch of test cases for text selection. r=jfkthame\n\nMozReview-Commit-ID: 5e43Sc6vPB7", "files": ["layout/reftests/selection/reftest.list", "layout/reftests/selection/rtl-selection-with-decoration-ref.html", "layout/reftests/selection/rtl-selection-with-decoration.html", "layout/reftests/selection/semitransparent-decoration-line-ref.html", "layout/reftests/selection/semitransparent-decoration-line.html", "layout/reftests/selection/writing-mode-ref.html", "layout/reftests/selection/writing-mode.html", "layout/reftests/text-shadow/reftest.list"], "git_node": null, "git_parents": [null], "node": "fb90190ba5b1d880c743f90b7634397c8c3abe9b", "parents": ["0564a1d6d2d6ae8bbb00afcfb4fa289211854d64"], "tags": []}, {"author": "Csoregi Natalia \u003cncsoregi@mozilla.com\u003e", "branch": "default", "desc": "Merge autoland to mozilla-central r=merge a=merge", "