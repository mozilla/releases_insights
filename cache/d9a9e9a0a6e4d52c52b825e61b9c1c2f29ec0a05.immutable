ents": [null], "node": "dba231450e1ead2ac8760573f385848f706f39a8", "parents": ["486620c2345ab558d0507c14a19e49f631b8347f"], "tags": []}, {"author": "Franziskus Kiefer \u003cfranziskuskiefer@gmail.com\u003e", "branch": "default", "desc": "Bug 1415795 - revert name change of NSS API, r=ttaubert\n\nMozReview-Commit-ID: Jj72zkfaRh", "files": ["security/manager/ssl/nsNSSIOLayer.cpp"], "git_node": null, "git_parents": [null], "node": "af86f905265d01c9b908f3095a985dbf220f00e6", "parents": ["dba231450e1ead2ac8760573f385848f706f39a8"], "tags": []}, {"author": "Franziskus Kiefer \u003cfranziskuskiefer@gmail.com\u003e", "branch": "default", "desc": "Bug 1401594 - land NSS NSS_3_34_BETA5 UPGRADE_NSS_RELEASE, r=ttaubert\n\nMozReview-Commit-ID: HdFnjDGJDcJ", "files": ["security/nss/TAG-INFO", "security/nss/cmd/tstclnt/tstclnt.c", "security/nss/coreconf/coreconf.dep", "security/nss/gtests/ssl_gtest/tls_agent.cc", "security/nss/lib/ssl/sslexp.h", "security/nss/lib/ssl/sslsock.c", "security/nss/lib/ssl/tls13con.c", "security/nss/lib/ssl/tls13con.h"], "git_node": null, "git_parents": [null], "node": "40444386933a58ff76502f11863784a87ea0996a", "parents": ["af86f905265d01c9b908f3095a985dbf220f00e6"], "tags": []}, {"author": "Jason Laster \u003cjason.laster.11@gmail.com\u003e", "branch": "default", "desc": "Bug 1415300 - Update Debugger frontend (11-7). r=jdescottes\n\nMozReview-Commit-ID: HdGGdN5Efw8", "files": ["devtools/client/debugger/new/README.mozilla", "devtools/client/debugger/new/debugger.css", "devtools/client/debugger/new/debugger.js", "devtools/client/debugger/new/parser-worker.js", "devtools/client/debugger/new/pretty-print-worker.js", "devtools/client/debugger/new/search-worker.js", "devtools/client/debugger/new/test/mochitest/browser.ini", "devtools/client/debugger/new/test/mochitest/browser_dbg-breaking.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-debugger-buttons.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-editor-select.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-expressions-error.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-navigation.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-pause-exceptions.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-preview.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-quick-open.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-returnvalues.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-scopes-mutations.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-sourcemaps.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-sourcemaps2.js", "devtools/client/debugger/new/test/mochitest/examples/doc-scripts.html", "devtools/client/debugger/new/test/mochitest/examples/simple1.js", "devtools/client/debugger/new/test/mochitest/examples/simple3.js", "devtools/client/debugger/new/test/mochitest/head.js"], "git_node": null, "git_parents": [null], "node": "9e2acadbdad8d0121330123e165404ba61a77ad0", "parents": ["40444386933a58ff76502f11863784a87ea0996a"], "tags": []}, {"author": "David Major \u003cdmajor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401250 - Change firefox.exe description metadata to evade the Windows 10 appcompat engine. r=ted\n\nThis patch changes our Windows file-description metadata from \"Firefox\" to \"Mozilla Firefox\" in order to work around an issue on Windows 10.\n\nTo be clear: This patch does NOT change any branding normally presented to a typical user. Short of attaching a debugger, the only way to see this change is to right-click firefox.exe and choose Properties then Details.\n\nWe're doing this because Windows 10 ships with an appcompat fix called DamThrottleControl that applies to any firefox.exe with product name and description equal to the string \"Firefox\". I have no idea what that fix was intended to do, but Nightly and DevEdition appear to be doing fine without it. In any case, the appcompat fix comes with the side effect of loading user32.dll very early in our process, which allows AppInit_DLLs to sneak in before our blocklist initializes. That's bad (and it fails a mochitest). This patch evades the Windows appcompat engine by making us no longer match the string that it's testing for.", "files": ["browser/app/module.ver"], "git_node": null, "git_parents": [null], "node": "0b07ff291caab66f3941443c5e52ae645fd1aa40", "parents": ["9e2acadbdad8d0121330123e165404ba61a77ad0"], "tags": []}, {"author": "qiaopengcheng \u003cqiaopengcheng-hf@loongson.cn\u003e", "branch": "default", "desc": "Bug 1403421 - Support mips64-linux performance. r=njn", "files": ["toolkit/moz.configure", "tools/profiler/core/PlatformMacros.h", "tools/profiler/core/platform-linux-android.cpp"], "git_node": null, "git_parents": [null], "node": "9bbac53ac79278f3cd4eac584fb30aad38987490", "parents": ["0b07ff291caab66f3941443c5e52ae645fd1aa40"], "tags": []}, {"author": "Eugen Sawin \u003cesawin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415690 - [1.0] Resolve canonical data path to avoid permission issues. r=snorp\n", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoSession.java"], "git_node": null, "git_parents": [null], "node": "3ea95e09f4b360f74ceeaeaea66535f02b977fe6", "parents": ["9bbac53ac79278f3cd4eac584fb30aad38987490"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414310 - Assert that JS threading APIs are only used between JS_Initialize and JS_Shutdown r=luke", "files": ["js/public/Initialization.h", "js/src/jsutil.h", "js/src/threading/Mutex.cpp", "js/src/threading/Thread.h", "js/src/vm/Initialization.cpp"], "git_node": null, "git_parents": [null], "node": "b86c252b68fac5f673d8c6fb44640a5d376fcc8c", "parents": ["3ea95e09f4b360f74ceeaeaea66535f02b977fe6"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414310 - Destroy mach exception handl