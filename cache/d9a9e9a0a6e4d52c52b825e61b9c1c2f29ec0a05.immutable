git_parents": [null], "node": "3f6382962d9764c65e5bfac415f42799e8f2ee71", "parents": ["da97d80851c4b8f424a4af36db2bda5004980854"], "tags": []}], "date": 1515606099, "git_changesets": [null], "user": "ncsoregi@mozilla.com"}, "8518": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nid -\u003e 0f0141ed9bb6", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "8b628206e629ee6729bd27024399acd855ff1c97", "parents": ["3f6382962d9764c65e5bfac415f42799e8f2ee71"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\ncy -\u003e cd528119b1f0\nid -\u003e 0f0141ed9bb6", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "c815231fbfbcc8410f0e1d4b9461ec493236f4b0", "parents": ["8b628206e629ee6729bd27024399acd855ff1c97"], "tags": []}], "date": 1515608466, "git_changesets": [null, null], "user": "ffxbld"}, "8519": {"changesets": [{"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1403923 - Safely shutdown Firefox from in delete_session. r=jgraham, a=test-only\n\nWith the request to shutdown the browser, a given amount of time\nhas to be waited to allow the process to shutdown itself. Only\nif the process is still running afterward it has to be killed.\n\nFirefox has an integrated background monitor which observes\nlong running threads during shutdown, and kills those after\n65s. To allow Firefox to shutdown on its own, geckodriver\nhas to wait that time, and some additional seconds.\n\nMozReview-Commit-ID: 4LRLQE0jZzw", "files": ["testing/geckodriver/CHANGES.md", "testing/geckodriver/src/marionette.rs", "testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/webdriver/tests/state/get_element_attribute.py", "testing/web-platform/tests/webdriver/tests/state/get_element_property.py", "testing/web-platform/tests/webdriver/tests/state/get_element_tag_name.py", "testing/web-platform/tests/webdriver/tests/state/is_element_selected.py", "testing/webdriver/src/server.rs"], "git_node": null, "git_parents": [null], "node": "218cfb44a3f44cb3e5b72a5c7c4032817becd664", "parents": ["c815231fbfbcc8410f0e1d4b9461ec493236f4b0"], "tags": []}, {"author": "Yoshi Huang \u003callstars.chh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403365 - Fix intermittent in browser_pageinfo_firstPartyIsolation.js. r=baku, a=test-only\n\nWhen we try to load https://example.com/browser/browser/base/content/test/pageinfo/image.html,\nsometimes BrowserTestUtils will return early even the page doesn't load\nyet, for example, the browser.currentURI is still about:blank.\nAnd loading about:blank will cause error in pageInfo.js, hence caused\nthe timeout.\n\nSo I add more parameters to browserLoaded to make sure browwserLoaded is\nreturned with the correct url.", "files": ["browser/base/content/test/pageinfo/browser_pageinfo_firstPartyIsolation.js"], "git_node": null, "git_parents": [null], "node": "41f57230d558923a843e825da94e0146f3888b13", "parents": ["218cfb44a3f44cb3e5b72a5c7c4032817becd664"], "tags": []}, {"author": "Peter Van der Beken \u003cpeterv@propagandism.org\u003e", "branch": "default", "desc": "Bug 1387427 - Don't insert source content into the document for XSLT transforms. r=smaug, a=gchang", "files": ["dom/xml/nsXMLContentSink.cpp", "dom/xml/nsXMLContentSink.h", "dom/xslt/base/txURIUtils.cpp", "dom/xslt/base/txURIUtils.h", "dom/xslt/nsIDocumentTransformer.h", "dom/xslt/xslt/txExecutionState.cpp", "dom/xslt/xslt/txExecutionState.h", "dom/xslt/xslt/txMozillaTextOutput.cpp", "dom/xslt/xslt/txMozillaXMLOutput.cpp", "dom/xslt/xslt/txMozillaXSLTProcessor.cpp", "dom/xslt/xslt/txMozillaXSLTProcessor.h"], "git_node": null, "git_parents": [null], "node": "c77dd415d31f115d24335e3573fd087a3f3705cd", "parents": ["41f57230d558923a843e825da94e0146f3888b13"], "tags": []}, {"author": "Mantaroh Yoshinaga \u003cmantaroh@gmail.com\u003e", "branch": "default", "desc": "Bug 1246883 - Load UA Stylesheet when printing the SVG document. r=jwatt, a=gchang\n\nCurrently, Gecko load only minimal-xul.css if the document is the SVG[1].\nIn the case of printing SVG document, gecko should load ua.css for using style\nwhich related to print.\n\nThis patch will load ua.css when printing the SVG document.\n\n[1] http://searchfox.org/mozilla-central/rev/67f38de2443e6b613d874fcf4d2cd1f2fc3d5e97/layout/base/nsDocumentViewer.cpp#2472\n\nMozReview-Commit-ID: JtdaEvX8QTw", "files": ["layout/printing/nsPrintEngine.cpp"], "git_node": null, "git_parents": [null], "node": "d73b02db0bfc988682b6b5c176ae4f1df85459e2", "parents": ["c77dd415d31f115d24335e3573fd087a3f3705cd"], "tags": []}, {"author": "Haik Aftandilian \u003chaftandilian@mozilla.com\u003e", "branch": "default", "desc": "Bug 1421262 - [Mac] Add access to hw.cachelinesize sysctl, /Library/GPUBundles to content sandbox rules. r=Alex_Gaynor, a=gchang\n\nMozReview-Commit-ID: LBWA8XD64h", "files": ["security/sandbox/mac/SandboxPolicies.h"], "git_node": null, "git_parents": [null], "node": "d5eaaf2bbd80515c1570d3dcc612b69326c4b6c0", "parents": ["d73b02db0bfc988682b6b5c176ae4f1df85459e2"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Bug 1427089 - Only queue a ContentClient buffer state if it has operations. r=dvander, a=gchang", "files": ["gfx/layers/PaintThread.h", "gfx/layers/client/ClientPaintedLayer.cpp"], "git_node": null, "git_parents": [null], "node": "aaea46054159fabc3b045ed11e6efb6e808c4031", "parents": ["d5eaaf2bbd80515c1570d3dcc612b69326c4b6c0"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Bug 1427089 - Wait for a previous empty transaction to complete before doing another empty transaction. r=dvander, a=gchang", "files": ["gfx/layers/client/ClientLayerManager.cpp"], "git_node": null, "git_parents": [null], "node": "ed60f2c05c4ae44d1385176764dafe9b9c0321fa", "parents": ["aaea46054159fabc3b045ed11e6efb6e808c4031"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1426042 - Reftest for bidi reordering where line has an empty trailing ::after pseudo-element. r=dholbert, a=gchang", "files": ["layout/reftests/bidi/1426042-1-ref.html", "layout/reftests/bidi/1426042-1.html", "layout/reftests/bidi/reftest.list"], "git_node": null, "git_parents": [null], "node": "b5147bc4e38410b1c5b66368f9e0d67f02e98738", "parents": ["ed60f2c05c4ae44d1385176764dafe9b9c0321fa"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1426042 - Ensure we don't forget to set bidi data when required on a zero-length trailing frame. r=dholbert, a=gchang", "files": ["layout/base/nsBidiPresUtils.cpp", "layout/reftests/bidi/reftest.list"], "git_node": null, "git_parents": [null], "node": "5b67ac2c216bef0bcf3a3cf7577eade0ffb5e0e2", "parents": ["b5147bc4e38410b1c5b66368f9e0d67f02e98738"], "tags": []}, {"author": "Grigory Kruglov \u003cgkruglov@mozilla.com\u003e", "branch": "default", "desc": "Bug 1428165 - Part 1: Ensure that 'modified' and 'created' timestamps are set when inserting history from sync. r=nalexander, a=gchang\n\nThis fixes a regression introduced in Bug 1291821. History records would be bulk-inserted from sync, and our ContentProvider\nwould erroneously forget to set these two timestamp fields.\n\nMozReview-Commit-ID: 2k0afijN62H", "files": ["mobile/android/base/java/org/mozilla/gecko/db/BrowserProvider.java", "mobile/android/services/src/main/java/org/mozilla/gecko/sync/repositories/android/HistoryDataAccessor.java", "mobile/android/services/src/test/java/org/mozilla/gecko/db/BrowserProviderHistoryTest.java"], "git_node": null, "git_parents": [null], "node": "916cbb15381ea0571c81e33ef37514855f152203", "parents": ["5b67ac2c216bef0bcf3a3cf7577eade0ffb5e0e2"], "tags": []}, {"author": "Grigory Kruglov \u003cgkruglov@mozilla.com\u003e", "branch": "default", "desc": "Bug 1428165 - Part 2: Fix history expiration query. r=nalexander, a=gchang\n\n'modified' value might be missing; in SQLite, max(123, null) is null, and so we must\ncoalesce fields which might be missing values.\n\nMozReview-Commit-ID: Bn1P0kdaHHT", "files": ["mobile/android/base/java/org/mozilla/gecko/db/BrowserProvider.java"], "git_node": null, "git_parents": [null], "node": "38fd987182186720bc0b252a1dc94444f6db39f5", "parents": ["916cbb15381ea0571c81e33ef37514855f152203"], "tags": []}, {"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 1426801 - Clear gFirstIdleTask if we fail to dispatch the runnable. r=mrbkap, a=gchang\n\nMozReview-Commit-ID: 23f9VDTyyqg", "files": ["dom/ipc/ContentChild.cpp"], "git_node": null, "git_parents": [null], "node": "a1d9a99f12a544df996ebdf833cf3e65357a7361", "parents": ["38fd987182186720bc0b252a1dc94444f6db39f5"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1427126 - Use setElementWithType instead of setElement in AppendToList. r=bhackett, a=gchang", "files": ["js/src/vm/List-inl.h"], "git_node": null, "git_parents": [null], "node": "3e7bec52b1431c8dfd56c86ec5062514434fa788", "parents": ["a1d9a99f12a544df996ebdf833cf3e65357a7361"], "tags": []}], "date": 1515638868, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8520": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset 41f57230d558 (bug 1403365) for browser_pageinfo_firstPartyIsolation.js failures.", "files": ["browser/base/content/test/pageinfo/browser_pageinfo_firstPartyIsolation.js"], "git_node": null, "git_parents": [null], "node": "ab58ba2c32b801fdf46eb753b889412e2ddab71a", "parents": ["3e7bec52b1431c8dfd56c86ec5062514434fa788"], "tags": []}], "date": 1515643504, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "8521": {"changesets": [{"author": "Alphan Chen \u003calchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1421214 - Try GoToAnchor() with unescaped string before using document's charset. r=smaug a=gchang", "files": ["docshell/base/nsDocShell.cpp", "dom/base/nsDocument.cpp", "testing/web-platform/tests/html/browsers/browsing-the-web/scroll-to-fragid/scroll-to-anchor-name.html"], "git_node": null, "git_parents": [null], "node": "7047976f6bec7c8e611009b74456986e0045cfc9", "parents": ["ab58ba2c32b801fdf46eb753b889412e2ddab71a"], "tags": []}, {"author": "Ted Mielczarek \u003cted@mielczarek.org\u003e", "branch": "default", "desc": "bug 1422735 - Change symbol upload URL from Socorro to Tecken. r=nalexander a=gchang\n\nMozReview-Commit-ID: BBs6G8dFfPz", "files": ["toolkit/crashreporter/tools/upload_symbols.py"], "git_node": null, "git_parents": [null], "node": "3a94f3140a144491cde0c1805afcd13ae9922b7f", "parents": ["7047976f6bec7c8e611009b74456986e0045cfc9"], "tags": []}], "date": 1515666157, "git_changesets": [null, null], "user": "aciure@mozilla.com"}, "8522": {"changesets": [{"author": "Kearwood \"Kip\" Gilbert \u003ckgilbert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1426500 - Disable WebVR for macOS on Beta and Release r=daoshengmu a=gchang\n- WebVR will continue to be enabled on macOS for Nightly\n  and Dev Edition\n\nMozReview-Commit-ID: LpEX13yZVbb", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "76192bc7ded10f07dd8eb314af1b268d2b0af248", "parents": ["3a94f3140a144491cde0c1805afcd13ae9922b7f"], "tags": []}], "date": 1515667032, "git_changesets": [null], "user": "btara@mozilla.com"}, "8523": {"changesets": [{"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1429542 Make HttpChannelChild::OverrideRunnable check for nullptr before using mNewChannel. r=asuth a=gchang", "files": ["netwerk/protocol/http/HttpChannelChild.cpp"], "git_node": null, "git_parents": [null], "node": "398360c9d5c6fcc80d7ced94afe65ee7f672b0bf", "parents": ["76192bc7ded10f07dd8eb314af1b268d2b0af248"], "tags": []}], "date": 1515669056, "git_changesets": [null], "user": "apavel@mozilla.com"}, "8524": {"changesets": [{"author": "Randell Jesup \u003crjesup@jesup.org\u003e", "branch": "default", "desc": "Bug 1426449: set the correct number of temporal layers for screencasts r=drno a=gchang", "files": ["media/webrtc/signaling/src/media-conduit/VideoConduit.cpp", "media/webrtc/trunk/webrtc/video/vie_encoder.cc"], "git_node": null, "git_parents": [null], "node": "3f7a950871b4587af63fae0e82f601e0f4f10ba6", "parents": ["398360c9d5c6fcc80d7ced94afe65ee7f672b0bf"], "tags": []}, {"author": "Andrew Swan \u003caswan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1396399 - Clarify rules for applying activeTab permission to content scripts. r=kmag, r=bz a=gchang\n\nMozReview-Commit-ID: 9xPDX8Qk2iR", "files": ["docshell/base/nsDocShell.cpp", "docshell/base/nsDocShell.h", "docshell/base/nsDocShellLoadInfo.cpp", "docshell/base/nsDocShellLoadInfo.h", "docshell/base/nsIDocShell.idl", "docshell/base/nsIDocShellLoadInfo.idl", "dom/base/nsFrameLoader.cpp", "dom/base/nsFrameLoader.h", "dom/base/nsIFrameLoader.idl", "dom/base/nsObjectLoadingContent.cpp", "dom/html/nsGenericHTMLFrameElement.cpp", "dom/html/nsGenericHTMLFrameElement.h", "dom/webidl/FrameLoader.webidl", "dom/webidl/WebExtensionContentScript.webidl", "dom/xul/nsXULElement.cpp", "netwerk/base/LoadInfo.cpp", "netwerk/base/LoadInfo.h", "netwerk/base/nsILoadInfo.idl", "toolkit/components/extensions/WebExtensionContentScript.h", "toolkit/components/extensions/WebExtensionPolicy.cpp", "toolkit/components/extensions/ext-tabs-base.js", "toolkit/components/extensions/extension-process-script.js"], "git_node": null, "git_parents": [null], "node": "e57848b337fcaeec8a8e23f45354603df11c2b5b", "parents": ["3f7a950871b4587af63fae0e82f601e0f4f10ba6"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1428589: Don't read a destroyed cookie list if the last cookie in the entry expired. r=jdm a=gchang\nConsider the following situation, which is what causes the failure:\n\n * `cookies` is an array of length 1 (either from the beginning, or because\n   other cookies have been expired while in this loop).\n * the only cookie that remains is expired.\n\nWe append the cookie to removedList, and then we call\ngCookieService-\u003eRemoveCookieFromList, which has the following code:\n\n  if (aIter.entry-\u003eGetCookies().Length() == 1) {\n    mDBState-\u003ehostTable.RawRemoveEntry(aIter.entry);\n  } else {\n    aIter.entry-\u003eGetCookies().RemoveElementAt(aIter.index);\n  }\n\nIf we enter the first branch, as it's the case, that will destroy the array.\n\nWe're effectively removing stuff from the array while mutating it, which is\nscary. It's fine if we don't delete the array, since we iterate through it using\nindices, but still it's dangerous as heck.\n\nIf we're the last element in the array though, we're doomed, because `cookies`\nis now destroyed. We not only try to access the array length again, but also we\ntry to index on it the next time because we never stopped the loop (`i` is still\nzero, and the length may very well be garbage).\n\nFix it by keeping the length in sync from the stack and breaking out from the\nloop if appropriately.\n\nMozReview-Commit-ID: 6qaC9yclvP2", "files": ["netwerk/cookie/nsCookieService.cpp"], "git_node": null, "git_parents": [null], "node": "000398f8c373407ba621d56cbd3b370cf43469a8", "parents": ["e57848b337fcaeec8a8e23f45354603df11c2b5b"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset a34fb2beb5f3 (bug 1419166) on request from gchang. a=backout", "files": ["dom/workers/RuntimeService.cpp", "dom/workers/RuntimeService.h"], "git_node": null, "git_parents": [null], "node": "15c6742655c07b097d9b8dd3529eea0d62388645", "parents": ["000398f8c373407ba621d56cbd3b370cf43469a8"], "tags": []}], "date": 1515674049, "git_changesets": [null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "8525": {"changesets": [{"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 76192bc7ded1 (bug 1426500) for failing mochitest dom/tests/mochitest/general/test_interfaces.html | VRDisplay should be defined on the global scope, at least on OS X. a=backout", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "8bb8f895a740ba60d587337e920f30ec3000c4ca", "parents": ["15c6742655c07b097d9b8dd3529eea0d62388645"], "tags": ["DEVEDITION_58_0b16_RELEASE", "FIREFOX_58_0b16_BUILD1", "FIREFOX_58_0b16_RELEASE", "FIREFOX_RELEASE_58_BASE"]}], "date": 1515674479, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "8526": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging mozilla-beta 8bb8f895a740ba60d587337e920f30ec3000c4ca with FIREFOX_RELEASE_58_BASE a=release DONTBUILD CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "d863896fcb56221128756286f22e41f9c698d598", "parents": ["8bb8f895a740ba60d587337e920f30ec3000c4ca"], "tags": ["FIREFOX_BETA_58_END"]}], "date": 1515686704, "git_changesets": [null], "user": "Callek@gmail.com"}}
}";