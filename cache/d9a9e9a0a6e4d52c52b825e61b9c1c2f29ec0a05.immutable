ntent/test/general/browser_sanitize-timespans.js", "browser/components/search/test/browser_426329.js", "toolkit/components/satchel/FormHistory.jsm", "toolkit/components/satchel/test/unit/head_satchel.js", "toolkit/components/satchel/test/unit/test_notify.js"], "git_node": null, "git_parents": [null], "node": "9c83fd7c7c7a12fedd669af3eda5b679936d15b8", "parents": ["4d7c0110f849a28f5cee9a98291c0c5c4a2eb176"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1320738 - export MOZ_PGO for js/src subconfigure; r=gps\n\nEnvironment variables for configure don't get automatically propagated\ndown to js/src on Windows because mingw. So we have to take extra steps.", "files": ["old-configure.in"], "git_node": null, "git_parents": [null], "node": "6a412222f22e64ccda1361f9edc9a838460b673a", "parents": ["9c83fd7c7c7a12fedd669af3eda5b679936d15b8"], "tags": []}, {"author": "Mats Palmgren \u003cmats@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415185 - Make nsBlockFrame::DoRemoveFrame handle anon/generated content from all the continuations it destroys.  r=emilio\n\nnsBlockFrame::DoRemoveFrame destroys the continuations in first-to-last\norder. Unfortunatley, this means that frames for anon/generated content\nthat were pushed to a later continuation may already be unbound by\nthe time we destroy its frame.  This patch fixes that by collecting\nanon/generated content from all the continuations, rather than from\neach continuation separately.\n\n\nMozReview-Commit-ID: LPBSoqjfjnA", "files": ["layout/generic/nsBlockFrame.cpp", "layout/generic/nsBlockFrame.h", "layout/generic/nsIFrame.h"], "git_node": null, "git_parents": [null], "node": "69d0e8d0a165d6348b7c8f370b02af51523fcd7c", "parents": ["5bee2596ae4d3f0169039953182b792c2eba0c35"], "tags": []}, {"author": "Jason Kratzer\u003cjkratzer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415185 - Crashtest.\n\nMozReview-Commit-ID: EoXgceDULsF", "files": ["layout/ge