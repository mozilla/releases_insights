nch": "default", "desc": "Bug 1376546 - Set up browser instrumentation as a new taskcluster job;r=jmaher\n\nMozReview-Commit-ID: 423Y58ULPPA", "files": ["taskcluster/ci/test/mochitest.yml", "taskcluster/ci/test/test-platforms.yml", "taskcluster/ci/test/test-sets.yml", "testing/mozharness/configs/unittests/linux_unittest.py", "testing/mozharness/configs/unittests/mac_unittest.py", "testing/mozharness/configs/unittests/win_taskcluster_unittest.py", "testing/mozharness/configs/unittests/win_unittest.py", "testing/mozharness/scripts/desktop_unittest.py"], "git_node": null, "git_parents": [null], "node": "088804dba0059036979e7aa28344bc318b7238b4", "parents": ["2d1bca2413eb88d1cdee6a5350ea1bd8410c0fd4"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412558 - P1. Don't export some unused symbols. r=gerald\n\nMozReview-Commit-ID: 8ckJEYseCaS", "files": ["media/ffvpx/libavcodec/avcodec.symbols", "media/ffvpx/libavutil/avutil.symbols"], "git_node": null, "git_parents": [null], "node": "41848d513f53d148ce2fb12675c7bddcb3fdc46f", "parents": ["088804dba0059036979e7aa28344bc318b7238b4"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412558 - P2. Disable ffvp8 and ffvp9 decoders on Unixes 32 bits. r=mshal\n\nThe system ffmpeg will be used instead or libvpx if not found.\n\nMozReview-Commit-ID: GX5WWPOhPq9", "files": ["media/ffvpx/config.h", "old-configure.in"], "git_node": null, "git_parents": [null], "node": "0754603ee7b055980f52bf1b26978df222ec96b4", "parents": ["41848d513f53d148ce2fb12675c7bddcb3fdc46f"], "tags": []}, {"author": "Marco Castelluccio \u003cmcastelluccio@mozilla.com\u003e", "branch": "default", "desc": "Bug 1317041 - Calculate crc32 incrementally; r=gps", "files": ["python/mozbuild/mozpack/mozjar.py", "python/mozbuild/mozpack/test/test_mozjar.py"], "git_node": null, "git_parents": [null], "node": "f47cb574c96e39ecda7bdcdac10ed97afb651f02", "parents": ["0754603ee7b055980f52bf1b26978df222ec96b4"], "tags": []}, {"author": "Keith Yeung \u003ckungfukeith11@gmail.com\u003e", "branch": "default", "desc": "servo: Merge #19133 - Import sequence inner types if it appears in dictionary members (from KiChjang:import-sequence-inner-types); r=jdm\n\nFixes #19107.\n\nr? nox\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 7ae852b6731f7405a101e01881c7fa70cfb83826", "files": ["servo/components/script/dom/bindings/codegen/Configuration.py", "servo/components/script/dom/testbinding.rs", "servo/components/script/dom/webidls/TestBinding.webidl"], "git_node": null, "git_parents": [null], "node": "dd834d38eaabe22f056d3eb37304f43f37edeb35", "parents": ["f47cb574c96e39ecda7bdcdac10ed97afb651f02"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412932 - Don't go through client.mk for maybe_clobber_profiledbuild; r=ted\n\nThis target is simply proxied. We don't need to go through client.mk to\nevaluate it.\n\nMozReview-Commit-ID: 3LF7e8LN8p0", "files": ["client.mk"], "git_node": null, "git_parents": [null], "node": "076a93ecab1087287245d658d3d227c2ff6fcabf", "parents": ["dd834d38eaabe22f056d3eb37304f43f37edeb35"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412932 - Move PGO logic from client.mk into root Makefile.in; r=ted\n\nclient.mk is going away. This commit moves the PGO build target out of\nit.\n\nWe move the code to Makefile.in. This likely isn't its final\nhome, as we'll want to eliminate Makefile.in at some point. However,\nit is easier to move things to the root Makefile.in than other\nalternatives. Keep in mind that the logic needs access to primitives\nlike BUILDSTATUS and variables from mk_add_options, which the\nMakefile.in mechanism has easy access to.\n\nMozReview-Commit-ID: 4C43lBhZz4l", "files": ["Makefile.in", "client.mk"], "git_node": null, "git_parents": [null], "node": "818df7ceccbf42fdebb7ab05853d1f7351430832", "parents": ["076a93ecab1087287245d658d3d227c2ff6fcabf"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412932 - Remove realbuild target from client.mk; r=ted\n\nBefore, the default \"build\" target either invoked \"realbuild\" or\n\"profiledbuild\" depending on whether MOZ_PGO was set. Now that\nPGO is handled by Makefile.in, we only have \"realbuild\" and there\nis no need to have a recursive invocation of client.mk. So we\nmerge \"realbuild\" into \"build.\"\n\nMozReview-Commit-ID: IIX8iAXlsD1", "files": ["client.mk"], "git_node": null, "git_parents": [null], "node": "8c8777aae67f5f6eba7686d73bc195e155c017f6", "parents": ["818df7ceccbf42fdebb7ab05853d1f7351430832"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412932 - Switch to PGO build in Makefile.in; r=ted\n\nPreviously, client.mk made the decision of whether to perform a PGO\nbuild. This required passing around MOZ_PGO and invoking a separate\nmake target if this variable was set.\n\nIn this commit, we move this logic to Makefile.in. We employ a special\nmechanism in rules.mk to override the default make target so\n`make` evaluates \"profiledbuild\" if MOZ_PGO is set. This also\nrequired using an explicit target for $(MAKE) invocations inside\nthe \"profiledbuild\" rule to avoid infinite recursion.\n\nMozReview-Commit-ID: 8sHiVspMisM", "files": ["Makefile.in", "client.mk", "python/mozbuild/mozbuild/test/backend/test_build.py"], "git_node": null, "git_parents": [null], "node": "b5f79b0f2a3586faf692c715b443264478e921c3", "parents": ["8c8777aae67f5f6eba7686d73bc195e155c017f6"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412932 - Inline pgo-profile-run target; r=ted\n\nIt is a one-liner and doesn't need to exist in a separate make file.\n\nMozReview-Commit-ID: 5w3eLWD0CuB", "files": ["Makefile.in", "testing/testsuite-targets.mk"], "git_node": null, "git_parents": [null], "node": "5ce23bfbb79837ab7bf1fda44cf6fac076dcfe92", "parents": ["b5f79b0f2a3586faf692c715b443264478e921c3"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412932 - Set MOZ_PGO for configure; r=ted\n\nThe mechanism by which PGO builds are kicked off is kinda wonky.\n\nThe MOZ_PGO environment variable is recognized by configure and setting\nit will result in MOZ_PGO being defined in substs. In addition, the\nbuild backend (previously client.mk, now Makefile.in) also recognizes\nMOZ_PGO (from mozconfig or environment) and takes appropriate action.\n\nIn-tree mozconfigs set MOZ_PGO via mk_add_options. mk_add_options\nis intended as a mechanism to inject state into client.mk and the\nmake-based build system.\n\nIn addition, there is code in mozharness (unchanged by this commit)\nthat sets MOZ_PGO if appropriate.\n\nA PGO build configuration is different from a non-PGO build\nconfiguration. Therefore a make-centric environment variable to\ncontrol PGO is not ideal. Instead, this should be defined as a\nconfigure-time flag and the build invocation should key off that.\n\nThis commit normalizes in-tree mozconfigs to set MOZ_PGO via\nac_add_options and updates the PGO documentation to recommend\nthis method.\n\nMozReview-Commit-ID: k6AZyJuXjs", "files": ["browser/config/mozconfigs/linux32/beta", "browser/config/mozconfigs/linux32/devedition", "browser/config/mozconfigs/linux32/release", "browser/config/mozconfigs/linux64/beta", "browser/config/mozconfigs/linux64/devedition", "browser/config/mozconfigs/linux64/release", "browser/config/mozconfigs/whitelist", "browser/config/mozconfigs/win32/beta", "browser/config/mozconfigs/win32/devedition", "browser/config/mozconfigs/win32/release", "browser/config/mozconfigs/win64/beta", "browser/config/mozconfigs/win64/devedition", "browser/config/mozconfigs/win64/release", "build/docs/pgo.rst"], "git_node": null, "git_parents": [null], "node": "2013c8dd182429accca0dbdc734b100ff38becd0", "parents": ["5ce23bfbb79837ab7bf1fda44cf6fac076dcfe92"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415365 - Remove unused imports; r=mshal\n\nMozReview-Commit-ID: B8zGAsZvk2H", "files": ["build/compare-mozconfig/compare-mozconfigs-wrapper.py", "build/compare-mozconfig/compare-mozconfigs.py"], "git_node": null, "git_parents": [null], "node": "b4a5ab45942f9b63175701d1265670faebc14f32", "parents": ["2013c8dd182429accca0dbdc734b100ff38becd0"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415365 - Add whitelist entry for MOZ_UPDATE_CHANNEL testing; r=mshal\n\nThis line was added to the nightly macosx64 mozconfig in 9312a1903bf4\n(bug 1391643). But we didn't catch it because compare-mozconfigs\nonly analyzes the current platform and we cross compile for MacOS\nfrom Linux.\n\nMozReview-Commit-ID: 35Q2c0mybPi", "files": ["browser/config/mozconfigs/whitelist"], "git_node": null, "git_parents": [null], "node": "3d7619511fe8270fb5d4bf533129e1df414a2c36", "parents": ["b4a5ab45942f9b63175701d1265670faebc14f32"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415365 - Run compare-mozconfigs for all platforms; r=mshal\n\ncompare-mozconfigs is platform agnostic AFAICT. And it runs fast.\nLet's run tests for all the platforms all the time.\n\nMozReview-Commit-ID: GqsFCp3XdZG", "files": ["build/compare-mozconfig/compare-mozconfigs-wrapper.py"], "git_node": null, "git_parents": [null], "node": "457cdbb01def6f2417ed66f1a7157191b7b54602", "parents": ["3d7619511fe8270fb5d4bf533129e1df414a2c36"], "tags": []}, {"author": "Andrew Swan \u003caswan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415017 Remove AddonRepository sqlite migration code r=kmag\n\nMozReview-Commit-ID: 2F64Um931sy", "files": ["toolkit/mozapps/extensions/internal/AddonRepository.jsm", "toolkit/mozapps/extensions/internal/AddonRepository_SQLiteMigrator.jsm", "toolkit/mozapps/extensions/internal/moz.build"], "git_node": null, "git_parents": [null], "node": "1360d35b11dc2760a28f68d29d600a098e4b6624", "parents": ["457cdbb01def6f2417ed66f1a7157191b7b54602"], "tags": []}, {"author": "Chris Manchester \u003ccmanchester@mozilla.com\u003e", "branch": "default", "desc": "Bug 1407388 - Remove build/unix/elfhack/inject/Makefile.in and replace with generated files. r=mshal\n\nMozReview-Commit-ID: Cr2RUlksKBJ", "files": ["build/unix/elfhack/inject/Makefile.in", "build/unix/elfhack/inject/copy_source.py", "build/unix/elfhack/inject/moz.build"], "git_node": null, "git_parents": [null], "node": "98d83d839fee3cbb2cd3dc043311f75e46b029a8", "parents": ["1360d35b11dc2760a28f68d29d600a098e4b6624"], "tags": []}, {"author": "Fred Lin \u003cgasolin@gmail.com\u003e", "branch": "default", "desc": "Bug 1412761 - remove dup test case;r=Fischer\n\nMozReview-Commit-ID: 9MLGQI3SiIf", "files": ["browser/extensions/onboarding/test/browser/browser_onboarding_uitour.js"], "git_node": null, "git_parents": [null], "node": "a8c72ed6284859fd0617ff09c3ad99b33e2f2ca8", "parents": ["98d83d839fee3cbb2cd3dc043311f75e46b029a8"], "tags": []}, {"author": "Fred Lin \u003cgasolin@gmail.com\u003e", "branch": "default", "desc": "Bug 1412761 - copy editing;r=Fischer\n\nMozReview-Commit-ID: LDZFo94cMNZ", "files": ["browser/extensions/onboarding/bootstrap.js", "browser/extensions/onboarding/content/onboarding.js", "browser/extensions/onboarding/data_events.md"], "git_node": null, "git_parents": [null], "node": "a17c2be449037a40006e9d9041cb20fca4317fcc", "parents": ["a8c72ed6284859fd0617ff09c3ad99b33e2f2ca8"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset dd834d38eaab for Windows debug build bustage", "files": ["servo/components/script/dom/bindings/codegen/Configuration.py", "servo/components/script/dom/testbinding.rs", "servo/components/script/dom/webidls/TestBinding.webidl"], "git_node": null, "git_parents": [null], "node": "b72eaedcdfaa1154fb33e1638e4bd090375789ad", "parents": ["a17c2be449037a40006e9d9041cb20fca4317fcc"], "tags": []}, {"author": "James Cheng \u003cjacheng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415083 - Rearrange the declaration of objects to avoid stack-use-after-scope. r=froydnj\n\nMozReview-Commit-ID: 7nMw1i10b7e", "files": ["xpcom/tests/gtest/TestTArray.cpp"], "git_node": null, "git_parents": [null], "node": "1528ff0ed838f7079c3572e2dadc83dda6acbf8d", "parents": ["b72eaedcdfaa1154fb33e1638e4bd090375789ad"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415335 - Remove build_all and clobber_all targets; r=nalexander\n\nI suspect these were related to MOZ_BUILD_PROJECTS, which has been\nremoved.\n\nMozReview-Commit-ID: DvwwTrczQWv", "files": ["client.mk"], "git_node": null, "git_parents": [null], "node": "1557f5e4e889f4f8cec8f598e42dd3e8c6d94cf6", "parents": ["1528ff0ed838f7079c3572e2dadc83dda6acbf8d"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415335 - Move spaces in path check to configure; r=nalexander\n\nChecks like this are what configure is for.\n\nIn addition to moving the check, we also validate topobjdir as well.\n\nMozReview-Commit-ID: 9sVNQJsAnjO", "files": ["build/moz.configure/init.configure", "client.mk"], "git_node": null, "git_parents": [null], "node": "9fd30a79e468d8fffe922ace03a8533b17c0978b", "parents": ["1557f5e4e889f4f8cec8f598e42dd3e8c6d94cf6"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415335 - Move Windows line endings detection to configure; r=nalexander\n\nThis doesn't need to be in client.mk.\n\nAlso, we inline the info to help people correct the failure, as this\nresults in a better user experience.\n\nMozReview-Commit-ID: KURL3RIGzKf", "files": ["build/moz.configure/init.configure", "client.mk"], "git_node": null, "git_parents": [null], "node": "3894f3262cbcbf35bed76f691a3ab764f2b9cce3", "parents": ["9fd30a79e468d8fffe922ace03a8533b17c0978b"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415335 - Remove clobber target; r=nalexander\n\nIt was just an alias for \"clean,\" which is proxied to the root\nMakefile. `mach clobber` should be used instead.\n\nMozReview-Commit-ID: A8tHaNb7H1z", "files": ["client.mk"], "git_node": null, "git_parents": [null], "node": "270e0b97ec67b236515a1487fdab7a153f15d65f", "parents": ["3894f3262cbcbf35bed76f691a3ab764f2b9cce3"], "tags": []}, {"author": "Kilik Kuo \u003ckikuo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1395922 - [P1] Refactor code and move them into specific functions. r=cpearce\n\nMozReview-Commit-ID: 9lwRH66Wllp", "files": ["dom/html/HTMLMediaElement.cpp", "dom/html/HTMLMediaElement.h"], "git_node": null, "git_parents": [null], "node": "8c1397fea2dd3f56fd17338ea147e2ecc0c514ae", "parents": ["270e0b97ec67b236515a1487fdab7a153f15d65f"], "tags": []}, {"author": "Kilik Kuo \u003ckikuo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1395922 - [P2] Make MediaFormatReader::SetCDMProxy asynchronously with a promise. r=cpearce,jya\n\nMozReview-Commit-ID: 7RarmmlA0lo", "files": ["dom/media/MediaFormatReader.cpp", "dom/media/MediaFormatReader.h", "dom/media/MediaPromiseDefs.h", "dom/media/moz.build"], "git_node": null, "git_parents": [null], "node": "2849269a64be100c949b4917fab599979d224f2e", "parents": ["8c1397fea2dd3f56fd17338ea147e2ecc0c514ae"], "tags": []}, {"author": "Kilik Kuo \u003ckikuo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1395922 - [P3] Make HTMLMediaElement::SetMediaKeys asynchronously. r=cpearce\n\nMozReview-Commit-ID: 5M8CTHMsmIh", "files": ["dom/html/HTMLMediaElement.cpp", "dom/html/HTMLMediaElement.h", "dom/media/MediaDecoder.cpp", "dom/media/MediaDecoder.h"], "git_node": null, "git_parents": [null], "node": "d013a75c11c802e11feade059f611167f46c7273", "parents": ["2849269a64be100c949b4917fab599979d224f2e"], "tags": []}, {"author": "Kilik Kuo \u003ckikuo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1395922 - [P4] Make MDSM enter buffering state when MediaKeys is removed and resume the playback if setting same MediaKeys back. r=cpearce,jya\n\nMozReview-Commit-ID: KdmeGqoVgak", "files": ["dom/media/MediaFormatReader.cpp", "dom/media/MediaFormatReader.h"], "git_node": null, "git_parents": [null], "node": "cf1f507a4dcc47d64f775eca197b670f3dd24c3a", "parents": ["d013a75c11c802e11feade059f611167f46c7273"], "tags": []}, {"author": "Kilik Kuo \u003ckikuo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1395922 - [P5][Test] Capture clear content with canvas 2d after remove MediaKeys from the same HTMLMediaElement. r=cpearce\n\nMozReview-Commit-ID: CUnblsNOmcm", "files": ["dom/media/test/bipbop_225w_175kbps.mp4^headers^", "dom/media/test/mochitest.ini", "dom/media/test/test_eme_unsetMediaKeys_then_capture.html"], "git_node": null, "git_parents": [null], "node": "3adbfd979a270a2a3f2af2530b41794878b74b3d", "parents": ["cf1f507a4dcc47d64f775eca197b670f3dd24c3a"], "tags": []}, {"author": "Kilik Kuo \u003ckikuo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1395922 - [P6][Test] Playback should resume after reattaching same MediaKeys with valid sessions. r=cpearce\n\nMozReview-Commit-ID: CASXy2SN4fh", "files": ["dom/media/test/mochitest.ini", "dom/media/test/test_eme_detach_reattach_same_mediakeys_during_playback.html"], "git_node": null, "git_parents": [null], "node": "c432ab6709bc170b6b083e46f92647387b01336a", "parents": ["3adbfd979a270a2a3f2af2530b41794878b74b3d"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412737. P1 - improve error handling. r=bechen,gerald\n\nMozReview-Commit-ID: 776P80x63y8", "files": ["dom/media/MediaCache.cpp"], "git_node": null, "git_parents": [null], "node": "29e511fbcd627fecb2c3f5b4b99d0a747223bfd6", "parents": ["c432ab6709bc170b6b083e46f92647387b01336a"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412737. P2 - Read() should return only when enough bytes are read or EOS/error is encountered. r=bechen,gerald\n\nThis will remove the need to retry reading for the callers.\n\nNote since data is usually downloaded faster than being consumed, we don't\nbenefit much in reading data from a partial block in the memory. Chances are\nwe still need to wait for the block to commit to the cache so the reader can\ncontinue. So we change the code to always read data from the cache or from\nthe last block when it is completed (reaching EOS).\n\nThis change allows up to somewhat optimize NotifyDataReceived() which won't\nhave to wake up readers if no blocks are committed to the cache.\n\nMozReview-Commit-ID: KwgNSOawuAE", "files": ["dom/media/MediaCache.cpp"], "git_node": null, "git_parents": [null], "node": "dd35b8813ca1e7ad8cbafcde88435b1ddc62ce9a", "parents": ["29e511fbcd627fecb2c3f5b4b99d0a747223bfd6"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412737. P3 - remove the while loops in the callers of MediaCacheStream::Read(). r=bechen,gerald\n\nMozReview-Commit-ID: 7UvmenWQ0Ah", "files": ["dom/media/MediaResource.cpp"], "git_node": null, "git_parents": [null], "node": "b8ae4f1e89c92e7f3b0a5f0335497d54fc848e27", "parents": ["dd35b8813ca1e7ad8cbafcde88435b1ddc62ce9a"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412737. P4 - wake up readers only when we have blocks committed to the cache. r=bechen,gerald\n\nPer P2 changes, a reader will always read data from the cache or from the last\nblock in the memory. NotifyDataReceived() will be slightly more efficient\nif we don't wake up readers unnecessarily when there are no new blocks committed\nto the cache.\n\nMozReview-Commit-ID: 3UWHbvtEUmu", "files": ["dom/media/MediaCache.cpp"], "git_node": null, "git_parents": [null], "node": "13b3569d56c4788967266f8f33a1e8860a92d8a5", "parents": ["b8ae4f1e89c92e7f3b0a5f0335497d54fc848e27"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415346 - Use arrow function in file_event-dispatch.html. r=birtles\n\nMozReview-Commit-ID: 7bYYDIOLqv6", "files": ["dom/animation/test/css-animations/file_event-dispatch.html", "dom/animation/test/css-transitions/file_event-dispatch.html"], "git_node": null, "git_parents": [null], "node": "d3ff2908ecb076e87410fa3dd0880eec0b4f9c0e", "parents": ["13b3569d56c4788967266f8f33a1e8860a92d8a5"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415346 - Use single quote in script in file_event-dispatch.html. r=birtles\n\nMozReview-Commit-ID: H7coY2gzxOE", "files": ["dom/animation/test/css-animations/file_event-dispatch.html"], "git_node": null, "git_parents": [null], "node": "8809ffe82076749ae306c8e934bf03a04b05a233", "parents": ["d3ff2908ecb076e87410fa3dd0880eec0b4f9c0e"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415346 - Remove unused AnimationEventHandler. r=birtles\n\nMozReview-Commit-ID: CKkaow9NNa8", "files": ["dom/animation/test/css-animations/file_event-dispatch.html"], "git_node": null, "git_parents": [null], "node": "dfb4033f96956395d8fa6fbc18386026adc0bca2", "parents": ["8809ffe82076749ae306c8e934bf03a04b05a233"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415346 - Use const instead of var in file_event-dispatch.html. r=birtles\n\nMozReview-Commit-ID: Al9lYAMDVNZ", "files": ["dom/animation/test/css-animations/file_event-dispatch.html", "dom/animation/test/css-transitions/file_event-dispatch.html"], "git_node": null, "git_parents": [null], "node": "8e875e2383ee22c33e52897447ca8d08fec1db64", "parents": ["dfb4033f96956395d8fa6fbc18386026adc0bca2"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415346 - Bind onxx event handler before creating EventWatcher. r=birtles\n\nMozReview-Commit-ID: 83KwkxBq7pK", "files": ["dom/animation/test/css-animations/file_event-dispatch.html", "dom/animation/test/css-transitions/file_event-dispatch.html"], "git_node": null, "git_parents": [null], "node": "587320f427abdf56204e53baf84810464ea2ec47", "parents": ["8e875e2383ee22c33e52897447ca8d08fec1db64"], "tags": []}, {"author": "fantasai \u003cfantasai.cvs@inkedblade.net\u003e", "branch": "default", "desc": "Bug 1411765 - Part1:Convert an Incomplete reflow status to OverflowIncomplete also when our size is exactly the available size, not just less.  r=mats\n\nMozReview-Commit-ID: JikD7p70pJy", "files": ["layout/generic/nsBlockFrame.cpp", "layout/reftests/w3c-css/submitted/break3/moz-block-fragmentation-001-ref.html", "layout/reftests/w3c-css/submitted/break3/moz-block-fragmentation-001.html", "layout/reftests/w3c-css/submitted/break3/reftest.list", "layout/reftests/w3c-css/submitted/reftest.list"], "git_node": null, "git_parents": [null], "node": "0590cfeeeaa383909234ec08837e9faa6f9ef43f", "parents": ["587320f427abdf56204e53baf84810464ea2ec47"], "tags": []}, {"author": "Neerja Pancholi \u003cnpancholi@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411765 - Part2:Remove extra border fragment from ref file to match it with new expected output of grid fragmentation tests and change assertion count for crashtests. r=mats\n\nMozReview-Commit-ID: A6gPAuBI13X", "files": ["layout/generic/crashtests/crashtests.list", "layout/reftests/css-grid/grid-fragmentation-019-ref.html"], "git_node": null, "git_parents": [null], "node": "4288a7814f71e22de13f90a58961da76b482f9af", "parents": ["0590cfeeeaa383909234ec08837e9faa6f9ef43f"], "tags": []}, {"author": "Mats Palmgren \u003cmats@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411765 - Part3:Disable part of failing test grid-fragmentation-dyn1-006.html. r=mats\n\nMozReview-Commit-ID: Id6hGHuTuTr", "files": ["layout/reftests/css-grid/grid-fragmentation-006-ref.html", "layout/reftests/css-grid/grid-fragmentation-006.html"], "git_node": null, "git_parents": [null], "node": "a22464e2572f83d2313bfc3537034b92edd75bd0", "parents": ["4288a7814f71e22de13f90a58961da76b482f9af"], "tags": []}, {"author": "steveck-chung \u003cschung@mozilla.com\u003e", "branch": "default", "desc": "Bug 1402963 - Part 1: Deduplicate credit card by checking credit card storage and untouched fields. r=lchang\n\nMozReview-Commit-ID: tuw36eyQnl", "files": ["browser/extensions/formautofill/FormAutofillParent.jsm", "browser/extensions/formautofill/ProfileStorage.jsm", "browser/extensions/formautofill/test/browser/browser_creditCard_doorhanger.js", "browser/extensions/formautofill/test/browser/head.js"], "git_node": null, "git_parents": [null], "node": "3eef0753a078b9de3ad6d0cd98c96e5f345edc5a", "parents": ["a22464e2572f83d2313bfc3537034b92edd75bd0"], "tags": []}, {"author": "steveck-chung \u003cschung@mozilla.com\u003e", "branch": "default", "desc": "Bug 1402963 - Part 2: Merge the credit card record into existing data. r=lchang\n\nMozReview-Commit-ID: 3Hkqvo2rK9R", "files": ["browser/extensions/formautofill/FormAutofillParent.jsm", "browser/extensions/formautofill/ProfileStorage.jsm", "browser/extensions/formautofill/test/browser/browser_creditCard_doorhanger.js", "browser/extensions/formautofill/test/browser/head.js", "browser/extensions/formautofill/test/unit/test_creditCardRecords.js"], "git_node": null, "git_parents": [null], "node": "8dbc7c83b48762894fd1e02fa1032bfc1a3fdb73", "parents": ["3eef0753a078b9de3ad6d0cd98c96e5f345edc5a"], "tags": []}, {"author": "Alfredo.Yang \u003cayang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1393045 - support QT AudioSampleEntry v2. r=kinetik\n\nMozReview-Commit-ID: GchJJBrdKYm", "files": ["media/libstagefright/binding/mp4parse/src/boxes.rs", "media/libstagefright/binding/mp4parse/src/lib.rs", "media/libstagefright/binding/mp4parse/src/tests.rs", "media/libstagefright/binding/mp4parse/tests/public.rs", "media/libstagefright/binding/mp4parse_capi/src/lib.rs", "media/libstagefright/binding/update-rust.sh"], "git_node": null, "git_parents": [null], "node": "78f97c364749691c184361eef850a59198cf011f", "parents": ["8dbc7c83b48762894fd1e02fa1032bfc1a3fdb73"], "tags": []}, {"author": "Sylvestre Ledru \u003csledru@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414631 - Remove the Chromium Process class r=jld\n\nMozReview-Commit-ID: B5NmJPQhGYm", "files": ["ipc/chromium/moz.build", "ipc/chromium/src/base/process.h", "ipc/chromium/src/base/process_posix.cc", "ipc/chromium/src/base/process_win.cc", "ipc/glue/GeckoChildProcessHost.cpp"], "git_node": null, "git_parents": [null], "node": "901652a2298bb1e2a436dfbeba959899eb84adf8", "parents": ["78f97c364749691c184361eef850a59198cf011f"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1414581 - Part 1. Require more nullptr check of parent node. r=masayuki\n\nBug 1402904 added nullptr check for parent node, but I forgot to add this\nnullptr check of selected node for outdent command.\nSo I need to add more nullptr check.\n\nMozReview-Commit-ID: Au9wrG6htk8", "files": ["editor/libeditor/HTMLEditRules.cpp"], "git_node": null, "git_parents": [null], "node": "c95fd22b6a4f4741e38aa1a1a68e944ccf31400d", "parents": ["901652a2298bb1e2a436dfbeba959899eb84adf8"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1414581 - Part 2. Add crashtest. r=masayuki\n\nMozReview-Commit-ID: 3H4DSubkt0q", "files": ["editor/libeditor/crashtests/1414581.html", "editor/libeditor/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "9903b9dbd27f2b5183c2a4c3bf6b9ed7b4d34fbd", "parents": ["c95fd22b6a4f4741e38aa1a1a68e944ccf31400d"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "servo: Merge #19139 - style: Get rid of parse_specified (from emilio:bye-parse-specified); r=jdm\n\nIt has a single use, and I don't think we should use it in the future.\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 4a2103b9e600a3b372d2770669b3f9f597d1e4b3", "files": ["servo/components/style/properties/helpers.mako.rs", "servo/components/style/properties/longhand/position.mako.rs", "servo/components/style/properties/shorthand/position.mako.rs"], "git_node": null, "git_parents": [null], "node": "20d4b128753bf57a03d56e4b73e7c96049e875b5", "parents": ["9903b9dbd27f2b5183c2a4c3bf6b9ed7b4d34fbd"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415397 - use Span\u003c\u003e to replace low level pointer arithmetic in ReadFromCache(). r=bechen,gerald\n\nMozReview-Commit-ID: HH6KXtMfSIJ", "files": ["dom/media/MediaCache.cpp", "dom/media/MediaCache.h"], "git_node": null, "git_parents": [null], "node": "3e95c596ad5bc0c0b99608ed26380994973e7665", "parents": ["20d4b128753bf57a03d56e4b73e7c96049e875b5"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414188 - Remove ValueObserver. r=glandium.\n\nlibpref has callbacks. You can register a callback function against a\nparticular pref (or pref prefix), and it'll be called when any matching pref\nchanges.\n\nThis is implemented in two layers. The lower layer is the list of CallbackNode\nobjects, pointed to by gFirstCallback.\n\nThe upper layer involves gObserverTable, which is a hash table of ValueObserver\nobjects. It is used for callbacks registered via\nPreferences::RegisterCallback() and Preferences::Add*VarCache(), but not for\nobservers registered with Preferences::Add{Weak,Strong}Observer(). If multiple\ncallbacks with identical prefnames, callback functions and MatchKinds occur,\nthey are commoned up into a single ValueObserver, which is then wrapped by a\nsingle CallbackNode. (The callbacks within a single ValueObserver can have\ndifferent void* aClosure args; ValueObserver keeps those in an nsTArray.)\n\nNote also that gObserverTable is very inelegant, with duplication of data\nbetween the keys and the values due it being a\nnsRefPtrHashtable\u003cValueObserverHashKey, ValueObserver\u003e and ValueObserver being\na subclass of ValueObserverHashKey(!)\n\nThis extra layer might make sense if there were a lot of commoning up\nhappening, but there's not. Across all process kinds there is an average of\nbetween 1.2 and 1.7 closures per ValueObserver. The vast majority have 1\nclosure, and there are a handful that have multiple; the highest number I've\nseen is 71.\n\n(Note that this two-layer design probably seemed more natural back when libpref\nwas spread across multiple files.)\n\nThis patch removes the ValueObserver layer. The only tricky part is that there\nis a notion of a MatchKind -- ExactMatch or PrefixMatch -- which exists in the\nValueObserverLayer but not in the CallbackNode layer. So the patch moves the\nMatchKind into the CallbackNode layer, which is straightforward.\n\nOn Linux64 this reduces memory usage by about 40 KiB in the parent process and\nabout 30 KiB in each content processes.\n\nThe performance implications are minor.\n\n- The list of CallbackNodes is a bit longer, so when a pref is changed we must\n  check more nodes. But we avoid possibly doing prefname matching twice.\n\n- Callback registration is much faster, just a simple list prepend, without any\n  hash table insertion required.\n\n- Callback unregistration is probably not much different. There is a longer\n  list to traverse, but no hash table removal.\n\n- Pref lookup is by far the hottest libpref operation, and it's unchanged.\n\nFor perf to be genuinely affected would require (a) a *lot* more\nalmost-duplicate callbacks that would have been commoned up, and (b) frequent\nchanging of the pref those callbacks are observing. This seems highly unlikely.\n\nMozReview-Commit-ID: 6xo4xmytOf3", "files": ["modules/libpref/Preferences.cpp"], "git_node": null, "git_parents": [null], "node": "891b6831d29bdfc80fc14434185bfd7c975e45dd", "parents": ["90a7bc300af375c80574266857e3ce46c30c6697"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1413833 - Cap the number of modified frames that we track to avoid the overhead getting too large. r=miko", "files": ["layout/base/nsLayoutUtils.cpp", "layout/base/nsLayoutUtils.h", "layout/generic/nsFrame.cpp"], "git_node": null, "git_parents": [null], "node": "e05d3e232865dbb2533966879f50db54daa7340e", "parents": ["891b6831d29bdfc80fc14434185bfd7c975e45dd"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1413833 - Don't use WeakFrame for the modified frame list since get slow with large numbers of frames. r=miko", "files": ["layout/generic/nsFrame.cpp", "layout/generic/nsIFrame.h", "layout/painting/RetainedDisplayListBuilder.cpp"], "git_node": null, "git_parents": [null], "node": "8bd69298b447dc9c5cb11a77f0d14afdb8f9a990", "parents": ["e05d3e232865dbb2533966879f50db54daa7340e"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412110 - Make sure we build a wrap list for the caret frame, since it will have multiple display items. r=miko", "files": ["layout/generic/nsFrame.cpp", "layout/painting/nsDisplayList.h"], "git_node": null, "git_parents": [null], "node": "7c87b438511359c8792273d261d3bed546c9b530", "parents": ["8bd69298b447dc9c5cb11a77f0d14afdb8f9a990"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414397 - Make sure we properly invalidate the entire frame subtree when detecting a caret frame change. r=miko", "files": ["layout/generic/nsFrame.cpp", "layout/generic/nsSubDocumentFrame.cpp", "layout/painting/nsDisplayList.h"], "git_node": null, "git_parents": [null], "node": "574db20bdf3e8b013b3575fc154621213a6aa8a6", "parents": ["7c87b438511359c8792273d261d3bed546c9b530"], "tags": []}, {"author": "Matthew Gregan \u003ckinetik@flim.org\u003e", "branch": "default", "desc": "Bug 1409904 - Convert error! logging to warn! to avoid spurious stderr spamming from audioipc.  r=kamidphish", "files": ["media/audioipc/server/src/lib.rs"], "git_node": null, "git_parents": [null], "node": "c0e806b7a992dc9e8f608df3e6380bce574eb791", "parents": ["574db20bdf3e8b013b3575fc154621213a6aa8a6"], "tags": []}, {"author": "Cervantes Yu \u003ccyu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415103 - Remove dead code in crash reporting. r=gsvelto\n\nThis removes dead code using headlessClient and lastRunCrashID in crash\nreporting. headlessClient is unconditional now. nsIXULRuntime.lastRunCrashID\nis not used anymore so remove code for implementing it.\n\n\nMozReview-Commit-ID: AU4bUeIx3O0", "files": ["toolkit/crashreporter/nsExceptionHandler.cpp", "toolkit/crashreporter/nsExceptionHandler.h", "toolkit/xre/nsAppRunner.cpp", "xpcom/system/nsIXULRuntime.idl"], "git_node": null, "git_parents": [null], "node": "13ec107f211922aec40d4993eef12690c54a0c36", "parents": ["c0e806b7a992dc9e8f608df3e6380bce574eb791"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414150 - Remove the \"memory.free_dirty_pages\" pref. r=glandium.\n\nThis was originally added for b2g, where the pref had a different value.\nBug 1398033 enabled it everywhere.", "files": ["dom/ipc/ContentPrefs.cpp", "modules/libpref/init/all.js", "xpcom/base/AvailableMemoryTracker.cpp"], "git_node": null, "git_parents": [null], "node": "b84d87e9fa100abe4f3aa073d2e169d3392d9b4c", "parents": ["13ec107f211922aec40d4993eef12690c54a0c36"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414150 - Remove the \"memory.low_*\" prefs. r=erahm,dmajor.\n\nThere's no good reason why these should't just be constants. The patch also\nappends \"MiB\" to some of the C++ values to make their meaning clearer.\n\nThis patch fixes one outright bug, and one inconsistency.\n\nThe bug is due to a prefname mismatch:\n\n- ContentPrefs.cpp and AvailableMemoryTracker.cpp use\n  \"memory.low_virtual_mem_threshold_mb\".\n\n- all.js uses \"memory.low_virtual_memory_threshold_mb\".\n\nWhich means that \"memory.low_virtual_memory_threshold_mb\" showed up in\nabout:config, but if you changed it nothing would happen because the callback\nlistened for changes to to \"memory.low_virtual_mem_threshold_mb\"!\n\nNow for the inconsistency. The above means we actually use a value of 256 for\nthe virtual memory threshold, even though all.js says 128. But we *do* use a\nvalue of 128 for the commit space threshold, because that's what all.js says\nand that prefname is used correctly everywhere. The patch changes the commit\nspace threshold to 256 for consistency with the virtual memory threshold.\n\nWhat a mess!", "files": ["dom/ipc/ContentPrefs.cpp", "modules/libpref/init/all.js", "xpcom/base/AvailableMemoryTracker.cpp"], "git_node": null, "git_parents": [null], "node": "99a32740c0588f68bc391a3ae24fe478782134ac", "parents": ["b84d87e9fa100abe4f3aa073d2e169d3392d9b4c"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414150 - Remove the \"consoleservice.{logging,enabled}\" prefs. r=jchen.\n\nIt seems fine to specify these as code constants.", "files": ["xpcom/base/nsConsoleService.cpp"], "git_node": null, "git_parents": [null], "node": "242b1157a36a8fbe769179a630c8457562d9568f", "parents": ["99a32740c0588f68bc391a3ae24fe478782134ac"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414150 - Remove the \"idle_queue.*\" prefs. r=farre.\n\nThere's no good reason why these can't be code constants.\n\nEspecially given that, due to a bug, changes to the\n\"idle_queue.{min,long}_period\" constants were not being passed onto the C++\ncode!\n\nHere's why: those two prefs were specified as integers in all.js. But we used\nAddFloatVarCache() to set up the reading of those prefs. libpref fakes floats\nby storing them as strings and then converting them to floats when they are\nread.\n\nWhich means that AddFloatVarCache() used to fail to get the value from all.js\n-- because there's a type mismatch, int vs. string -- and instead use the\nfallback default. That value is the same as the one in all.js, which is lucky.\nBut if someone changed the value in about:config to 100 (an integer), a similar\nfailure would have occured and the value used by the C++ code wouldn't be\nupdated!\n\nAlso note that idle_queue.max_timer_thread_bound did not have a value in\nall.js.\n\nWhat a mess!", "files": ["modules/libpref/init/all.js", "xpcom/threads/MainThreadIdlePeriod.cpp", "xpcom/threads/MainThreadIdlePeriod.h"], "git_node": null, "git_parents": [null], "node": "dd6063357ae629ffb82e2087ac58431c07548a82", "parents": ["242b1157a36a8fbe769179a630c8457562d9568f"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1415115 - forcing test window focus on dialog close. r=surkov\n\nMozReview-Commit-ID: B71ChCA8Uzm\n", "files": ["accessible/tests/mochitest/events/docload/test_docload_root.html", "accessible/tests/mochitest/events/docload/test_docload_shutdown.html"], "git_node": null, "git_parents": [null], "node": "35a375648ee0224743657c67edfebf0cbe81b719", "parents": ["dd6063357ae629ffb82e2087ac58431c07548a82"], "tags": []}, {"author": "Liam \u003ccanada8715@gmail.com\u003e", "branch": "default", "desc": "Bug 1408790 - The non-selected elements with ids should be lightened to the same color as the non-selected classes r=gl\n\nMozReview-Commit-ID: AjcnYsxxqAs", "files": ["devtools/client/themes/breadcrumbs.css"], "git_node": null, "git_parents": [null], "node": "ac9d12e5587fe2486a2a8c95ef911768841195e2", "parents": ["35a375648ee0224743657c67edfebf0cbe81b719"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1415389.  Make ChromeUtils a WebIDL namespace.  Remove ThreadSafeChromeUtils.  r=kmag\n\nMozReview-Commit-ID: 9ysAeaBMNVt", "files": ["devtools/client/debugger/test/mochitest/browser_dbg_variables-view-04.js", "devtools/client/memory/test/unit/head.js", "devtools/docs/tools/memory-panel.md", "devtools/server/actors/object.js", "devtools/server/performance/memory.js", "devtools/server/tests/unit/test_MemoryActor_saveHeapSnapshot_01.js", "devtools/server/tests/unit/test_MemoryActor_saveHeapSnapshot_02.js", "devtools/server/tests/unit/test_MemoryActor_saveHeapSnapshot_03.js", "devtools/shared/builtin-modules.js", "devtools/shared/fronts/memory.js", "devtools/shared/heapsnapshot/HeapAnalysesWorker.js", "devtools/shared/heapsnapshot/HeapSnapshot.cpp", "devtools/shared/heapsnapshot/tests/unit/dominator-tree-worker.js", "devtools/shared/heapsnapshot/tests/unit/heap-snapshot-worker.js", "dom/base/ChromeUtils.cpp", "dom/base/ChromeUtils.h", "dom/bindings/Bindings.conf", "dom/bindings/parser/WebIDL.py", "dom/browser-element/BrowserElementParent.js", "dom/webidl/ChromeUtils.webidl", "dom/webidl/ThreadSafeChromeUtils.webidl", "dom/webidl/moz.build", "js/xpconnect/tests/chrome/test_getweakmapkeys.xul", "js/xpconnect/tests/chrome/test_paris_weakmap_keys.xul", "js/xpconnect/tests/chrome/test_weakmap_keys_preserved2.xul", "js/xpconnect/tests/chrome/test_weakmaps.xul", "js/xpconnect/tests/unit/test_weak_keys.js", "testing/talos/talos/tests/devtools/addon/content/damp.js", "toolkit/components/ctypes/tests/unit/head.js"], "git_node": null, "git_parents": [null], "node": "73352624f35c23e6000cd50d095708d69249f35d", "parents": ["ac9d12e5587fe2486a2a8c95ef911768841195e2"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1415182.  Make the External interface [NoInterfaceObject], per spec.  r=qdot\n\nMozReview-Commit-ID: DCX4uxAFPAu", "files": ["dom/tests/mochitest/general/test_interfaces.js", "dom/webidl/External.webidl"], "git_node": null, "git_parents": [null], "node": "7e7144bcdcb5b8ea1a7ff362b4ebe9953b8a16a6", "parents": ["73352624f35c23e6000cd50d095708d69249f35d"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1410106 - Better check about privateBrowsing for IDB, r=asuth", "files": ["dom/indexedDB/ActorsParent.cpp", "dom/indexedDB/IDBFactory.cpp", "dom/indexedDB/PBackgroundIDBFactory.ipdl"], "git_node": null, "git_parents": [null], "node": "8a46aeb0b562dd2ac240657a53f489046deb9acb", "parents": ["7e7144bcdcb5b8ea1a7ff362b4ebe9953b8a16a6"], "tags": []}, {"author": "Cervantes Yu \u003ccyu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414714 - Part 1: Remove unused telemetry environment pref \"gfx.direct2d.use1_1\". r=chutten\n\nMozReview-Commit-ID: 5zbW8UTm8Wa", "files": ["toolkit/components/telemetry/TelemetryEnvironment.jsm"], "git_node": null, "git_parents": [null], "node": "a4cc9b54397e5411bc6eff5812fa314201441b7e", "parents": ["8a46aeb0b562dd2ac240657a53f489046deb9acb"], "tags": []}, {"author": "Cervantes Yu \u003ccyu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414714 - Part 2: Remove unused gfx.* prefs. r=nical\n\nThe following prefs are removed because they are defined in gfxPrefs, but the\nresulting gfxPrefs property is used at all.\n* gfx.SurfaceTexture.detach.enabled\n* gfx.touch.resample.*\n* gfx.screen-mirroring.enabled\n\nMozReview-Commit-ID: CyI3JN4TTu5", "files": ["gfx/thebes/gfxPrefs.h", "mobile/android/app/mobile.js"], "git_node": null, "git_parents": [null], "node": "06e41f47f05d0572d77fccfa6fdb87eb2c938d4b", "parents": ["a4cc9b54397e5411bc6eff5812fa314201441b7e"], "tags": []}, {"author": "Cervantes Yu \u003ccyu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414714 - Part 3: Remove more unused prefs defined in gfxPrefs. r=nical\n\nThis removes non-\"gfx.*\" prefs defined in gfxPrefs.h, but the generated gfxPrefs\nproperties are not accessed anywhere in the code base:\n* apz.overscroll.spring_friction\n* apz.overscroll.stop_velocity_threshold\n* apz.overscroll.stretch_factor\n* dom.w3c_touch_events.enabled - this pref is accessed in other places, but not through\ngfxPrefs::TouchEventsEnabled().\n* general.smoothScroll.lines\n* general.smoothScroll.pixels\n* layers.composer2d.enabled\n* layers.stereo-video.enabled\n\nMozReview-Commit-ID: 5OByjpnFthJ", "files": ["gfx/thebes/gfxPrefs.h"], "git_node": null, "git_parents": [null], "node": "71662dbd44ed3f88412168ee0adb044dcee03966", "parents": ["06e41f47f05d0572d77fccfa6fdb87eb2c938d4b"], "tags": []}, {"author": "Bob Owen \u003cbobowencode@gmail.com\u003e", "branch": "default", "desc": "Bug 1415250 Part 1: Block prntm64.dll and guard32.dll in sandboxed child processes. r=jimm", "files": ["security/sandbox/win/src/sandboxbroker/sandboxBroker.cpp"], "git_node": null, "git_parents": [null], "node": "da41769f7553cec255fbb34352020d90328aeadf", "parents": ["71662dbd44ed3f88412168ee0adb044dcee03966"], "tags": []}, {"author": "Bob Owen \u003cbobowencode@gmail.com\u003e", "branch": "default", "desc": "Bug 1415250 Part 2: Make level 4 the default for the Windows content process sandbox. r=jimm", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "c376bb034ca65153a99e06ddd5dd9e69885823a1", "parents": ["da41769f7553cec255fbb34352020d90328aeadf"], "tags": []}, {"author": "Narcis Beleuzu \u003cnbeleuzu@mozilla.com\u003e", "branch": "default", "desc": "Merge inbound to mozilla-central r=merge a=merge", "files": ["dom/webidl/ThreadSafeChromeUtils.webidl", "testing/web-platform/meta/html/browsers/origin/cross-origin-objects/cross-origin-objects.html.ini", "tools/lint/eslint/eslint-plugin-mozilla/lib/rules/avoid-nsISupportsString-preferences.js", "tools/lint/eslint/eslint-plugin-mozilla/tests/avoid-nsISupportsString-preferences.js"], "git_node": null, "git_parents": [null, null], "node": "f63559d7e6a570e4e73ba367964099394248e18d", "parents": ["3e95c596ad5bc0c0b99608ed26380994973e7665", "c376bb034ca65153a99e06ddd5dd9e69885823a1"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415119 - Support out-of-bounds indexes in PostWriteElementBarrier. r=jonco", "files": ["js/src/jit/MCallOptimize.cpp", "js/src/jit/VMFunctions.cpp"], "git_node": null, "git_parents": [null], "node": "8b64b1c8347b77450b44135ab1fe713caf79a4d6", "parents": ["c376bb034ca65153a99e06ddd5dd9e69885823a1"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1292486 - Get rid of nsIUnicodeNormalizer interface. r=jfkthame\n\nm-c and c-c don't use nsIUnicodeNormalizer interface now.\n\nMozReview-Commit-ID: DGK7wBrcrob", "files": ["browser/installer/package-manifest.in", "intl/build/nsI18nModule.cpp", "intl/unicharutil/moz.build", "intl/unicharutil/nsIUnicodeNormalizer.idl", "intl/unicharutil/nsUnicodeNormalizer.cpp", "intl/unicharutil/nsUnicodeNormalizer.h", "intl/unicharutil/tests/NormalizationData.h", "intl/unicharutil/tests/NormalizationTest.cpp", "intl/unicharutil/tests/genNormalizationData.pl", "intl/unicharutil/tests/moz.build", "intl/unicharutil/tests/unit/xpcshell.ini", "mobile/android/installer/package-manifest.in"], "git_node": null, "git_parents": [null], "node": "dcf5bf004564e60942528edb3d1017d04cea479a", "parents": ["8b64b1c8347b77450b44135ab1fe713caf79a4d6"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1415013: Devirtualize PresShell::IsSafeToFlush. r=bz\n\nMozReview-Commit-ID: BL5qcSFE6Hc\n", "files": ["layout/base/PresShell.cpp", "layout/base/PresShell.h", "layout/base/nsIPresShell.h"], "git_node": null, "git_parents": [null], "node": "adcb5a4c7591c970b7ac75071f4c5ce1ecbabcd4", "parents": ["dcf5bf004564e60942528edb3d1017d04cea479a"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1410132 - Skip mutex ordering checks when JS engine is not initialized r=sfink", "files": ["js/src/threading/Mutex.cpp"], "git_node": null, "git_parents": [null], "node": "69aedd61b682f6086a6a47b5616bbc9e1bbf1487", "parents": ["adcb5a4c7591c970b7ac75071f4c5ce1ecbabcd4"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1410132 - Use a separate jemalloc arena for all SpiderMonkey malloc allocations r=njn r=nbp", "files": ["config/check_spidermonkey_style.py", "js/public/Utility.h", "js/src/jsapi-tests/testHashTable.cpp", "js/src/jsapi-tests/tests.cpp", "js/src/jsapi-tests/tests.h", "js/src/jsstr.cpp", "js/src/jsutil.cpp", "js/src/shell/js.cpp", "js/src/vm/Initialization.cpp", "js/src/wasm/WasmProcess.cpp", "js/src/wasm/WasmProcess.h"], "git_node": null, "git_parents": [null], "node": "cdabc4808a0fc6bc99475a7011b07d0f2df22727", "parents": ["69aedd61b682f6086a6a47b5616bbc9e1bbf1487"], "tags": []}, {"author": "Tom Schuster \u003cevilpies@gmail.com\u003e", "branch": "default", "desc": "Bug 1019116 - Remove old Promise selfhosting functions. r=till", "files": ["js/src/vm/SelfHosting.cpp"], "git_node": null, "git_parents": [null], "node": "919528a717da922e95f7788053af72c468db5efb", "parents": ["cdabc4808a0fc6bc99475a7011b07d0f2df22727"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1019116 - Implement Promise.prototype.finally. r=till,bz", "files": ["js/src/builtin/Promise.cpp", "js/src/builtin/Promise.h", "js/src/builtin/Promise.js", "js/src/vm/SelfH