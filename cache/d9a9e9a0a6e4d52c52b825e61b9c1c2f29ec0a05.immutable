 "layout/xul/nsMenuPopupFrame.h", "layout/xul/nsPopupSetFrame.cpp", "layout/xul/nsPopupSetFrame.h", "layout/xul/nsScrollBoxFrame.cpp", "layout/xul/nsScrollbarButtonFrame.cpp", "layout/xul/nsScrollbarButtonFrame.h", "layout/xul/nsSliderFrame.cpp", "layout/xul/nsSliderFrame.h", "layout/xul/nsSplitterFrame.cpp", "layout/xul/nsSplitterFrame.h", "layout/xul/nsTextBoxFrame.cpp", "layout/xul/nsTextBoxFrame.h", "layout/xul/nsXULLabelFrame.cpp", "layout/xul/nsXULLabelFrame.h", "layout/xul/tree/nsTreeBodyFrame.cpp", "layout/xul/tree/nsTreeBodyFrame.h", "layout/xul/tree/nsTreeColFrame.cpp", "layout/xul/tree/nsTreeColFrame.h"], "git_node": null, "git_parents": [null], "node": "ebc611dc8c85055ac62bc945e9871cdc317cf6f9", "parents": ["df53224b917158a08bccadeef488f30a2b2ac89b"], "tags": []}, {"author": "Alex Touchet \u003calextouchet@outlook.com\u003e", "branch": "default", "desc": "servo: Merge #19116 - Fix dead link in COMMAND_LINE_ARGS.md (from servo:cla-doc-link); r=KiChjang\n\n\u003c!-- Please describe your changes on the following line: --\u003e\n\n---\n\u003c!-- Thank you for contributing to Servo! Please replace each `[ ]` by `[X]` when the step is complete, and replace `__` with appropriate data: --\u003e\n- [ ] `./mach build -d` does not report any errors\n- [ ] `./mach test-tidy` does not report any errors\n- [ ] These changes fix #__ (github issue number if applicable).\n\n\u003c!-- Either: --\u003e\n- [ ] There are tests for these changes OR\n- [ ] These changes do not require tests because _____\n\n\u003c!-- Also, please make sure that \"Allow edits from maintainers\" checkbox is checked, so that we can help you if you get stuck somewhere along the way.--\u003e\n\n\u003c!-- Pull requests that do not address these steps are welcome, but they will require additional verification as part of the review process. --\u003e\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 8035679858eaf50ba68ac134efa02a969ec93de5", "files": ["servo/docs/COMMAND_LINE_ARGS.md"], "git_node": null, "git_parents": [null], "node": "72ee35bd086791e08bc0ee2d046f2ddda81edea4", "parents": ["f8164446177a17254ee649da73e12b726eb9d325"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "merge mozilla-central to autoland. r=merge a=merge", "files": [], "git_node": null, "git_parents": [null, null], "node": "cc1151e297c567f9fa2d931f682af1a37cbdf381", "parents": ["72ee35bd086791e08bc0ee2d046f2ddda81edea4", "e7fee7042d971d73c0e5caafba3b8d15da1bc8ca"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1414155 - Move a few things around. r=njn", "files": ["memory/build/mozjemalloc.cpp"], "git_node": null, "git_parents": [null], "node": "4a93fcad5d8e158d5525f2345a55669e536756a3", "parents": ["cc1151e297c567f9fa2d931f682af1a37cbdf381"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1414155 - Factor out size classes logic for tiny, quantum and sub-page classes. r=njn\n\nWe create a new helper class that rounds up allocations sizes and\ncategorizes them. Compilers are smart enough to elide what they don't\nneed, like in malloc_good_size, they elide the code related to the\nclass type enum.", "files": ["memory/build/mozjemalloc.cpp"], "git_node": null, "git_parents": [null], "node": "0b3250499ed0cb8046159f5f2e8caf18e3a445c3", "parents": ["4a93fcad5d8e158d5525f2345a55669e536756a3"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1414155 - Move arena_chunk_map_t and arena_chunk_t around. r=njn\n\nAt the moment, while they are used before their declaration, it's from a\nmacro. It is desirable to replace the macros with C++ constants, which\nwill require the structures being defined first.", "files": ["memory/build/Utils.h", "memory/build/mozjemalloc.cpp"], "git_node": null, "git_parents": [null], "node": "9ee0115104a45d00c5e29c49bddded59fdd633a3", "parents": ["0b3250499ed0cb8046159f5f2e8caf18e3a445c3"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1414155 - Define pagesize_2pow in terms of pagesize, not the opposite. r=njn\n\nAt the same time, add user-defined literals to make those constants more\nlegible.", "files": ["memory/build/Utils.h", "memory/build/mozjemalloc.cpp", "memory/gtest/TestJemalloc.cpp", "memory/gtest/moz.build"], "git_node": null, "git_parents": [null], "node": "fb8fa3f4449c6a215d8f69410829930d4d271882", "parents": ["9ee0115104a45d00c5e29c49bddded59fdd633a3"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1414155 - Consolidate \"constant/globals\". r=njn\n\nThere is a set of \"constants\" that are actually globals that depend on\nthe page size that we get at runtime, when compiling without\nMALLOC_STATIC_PAGESIZE, but that are actual constants when compiling\nwith it. Their value was unfortunately duplicated.\n\nWe setup a set of macros allowing to make the declarations unique.", "files": ["memory/build/mozjemalloc.cpp"], "git_node": null, "git_parents": [null], "node": "5bd88f059878634b15bc89787c9bf5ebb96c669b", "parents": ["fb8fa3f4449c6a215d8f69410829930d4d271882"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1414155 - Replace the cacheline-related macros with a constant. r=njn", "files": ["memory/build/mozjemalloc.cpp"], "git_node": null, "git_parents": [null], "node": "f6799dfca63cab9d29ac2443d9a93504f88a2afb", "parents": ["5bd88f059878634b15bc89787c9bf5ebb96c669b"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1414155 - Remove SIZE_INV values for QUANTUM_2POW_MIN \u003c 4. r=njn\n\nQUANTUM_2POW_MIN is exactly 4, and we are unlikely to ever make it\nsmaller. Also turn a MOZ_ASSERT into a static_assert, because it only\nuses constants, and will fail if QUANTUM_2POW_MIN is lowered without\ntouching size_invs.", "files": ["memory/build/mozjemalloc.cpp"], "git_node": null, "git_parents": [null], "node": "5617b30505014bc26e4e5fdc1f34baeac3fb8c4c", "parents": ["f6799dfca63cab9d29ac2443d9a93504f88a2afb"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1414155 - Replace size class related macros and constants. r=njn\n\nHopefully, this makes things a little clearer.", "files": ["memory/build/mozjemalloc.cpp"], "git_node": null, "git_parents": [null], "node": "9429ad8b651f4658301164892cf923fb46256b19", "parents": ["5617b30505014bc26e4e5fdc1f34baeac3fb8c4c"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1414155 - Replace chunk size related macros and constants. r=njn", "files": ["memory/build/mozjemalloc.cpp"], "git_node": null, "git_parents": [null], "node": "578f15a2e0f63e785065576f67f803a1fe8f8a87", "parents": ["9429ad8b651f4658301164892cf923fb46256b19"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1414155 - Rename page size related constants. r=njn", "files": ["memory/build/mozjemalloc.cpp"], "git_node": null, "git_parents": [null], "node": "9d00f52783833b3b4e1af733200dea4bc4f7151a", "parents": ["578f15a2e0f63e785065576f67f803a1fe8f8a87"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1414155 - Rename chunk related constants. r=njn", "files": ["memory/build/mozjemalloc.cpp"], "git_node": null, "git_parents": [null], "node": "a826adc9b1c76827939c31a2344edbb4e62175a7", "parents": ["9d00f52783833b3b4e1af733200dea4bc4f7151a"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1414155 - Replace constants describing size class numbers. r=njn", "files": ["memory/build/mozjemalloc.cpp"], "git_node": null, "git_parents": [null], "node": "c84122339c7f9358e59e5b7272c6600dab52cb59", "parents": ["a826adc9b1c76827939c31a2344edbb4e62175a7"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1414155 - Define AddressRadixTree node size as a size rather than a power of 2. r=njn", "files": ["memory/build/mozjemalloc.cpp"], "git_node": null, "git_parents": [null], "node": "849017ffe2976f7721c20c3625d8fafeb3cce8dd", "parents": ["c84122339c7f9358e59e5b7272c6600dab52cb59"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "merge mozilla-central to mozilla-inbound. r=merge a=merge", "files": [], "git_node": null, "git_parents": [null, null], "node": "c73851d5851b51f8d3cb262242e363a0962ba892", "parents": ["ebc611dc8c85055ac62bc945e9871cdc317cf6f9", "849017ffe2976f7721c20c3625d8fafeb3cce8dd"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1413867 - Remove StopIteration object. r=evilpie", "files": ["dom/tests/mochitest/general/test_interfaces.js", "dom/workers/test/serviceworkers/test_serviceworker_interfaces.js", "dom/workers/test/test_worker_interfaces.js", "js/ipc/JavaScriptTypes.ipdlh", "js/ipc/WrapperAnswer.cpp", "js/ipc/WrapperOwner.cpp", "js/src/jit-test/tests/basic/bug547911-1.js", "js/src/jit-test/tests/basic/bug547911-2.js", "js/src/jit-test/tests/basic/testDeepBailFromHasInstance.js", "js/src/jit-test/tests/collections/Map-forEach.js", "js/src/jsapi.cpp", "js/src/jsapi.h", "js/src/jscompartment.cpp", "js/src/jsiter.cpp", "js/src/jsiter.h", "js/src/jsprototypes.h", "js/src/vm/GlobalObject.cpp", "js/src/vm/StopIterationObject.h", "toolkit/components/promiseworker/PromiseWorker.jsm", "toolkit/components/promiseworker/worker/PromiseWorker.js"], "git_node": null, "git_parents": [null], "node": "73a48b92351a1c615108c36324c4900cb8ad41a6", "parents": ["c73851d5851b51f8d