s": ["4fbb17339bccdcd0a4641877b1863cf3c8e776ff"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\ndsb -\u003e a345df481b9e\nhsb -\u003e f75898161e1d\nur -\u003e ae632ad45acd", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "3de0b99031779fbc6091e75ea741e127a8baeaf5", "parents": ["33e7932eed98af3bf4438815a97c9229b7628794"], "tags": []}], "date": 1511774463, "git_changesets": [null, null], "user": "ffxbld"}, "8235": {"changesets": [{"author": "Daosheng Mu \u003cdaoshengmu@gmail.com\u003e", "branch": "default", "desc": "Bug 1413269 - Apply REQUIRE_COMPAT_PROFILE flag for WebGL 1 on Intel HD Grahpics 3000 on OSX. - r=jgilbert a=gchang\n\nMozReview-Commit-ID: FZzZpaU9uiv", "files": ["dom/canvas/WebGLContext.cpp"], "git_node": null, "git_parents": [null], "node": "700ddf967ab12709af45c564b138f62b246a4ef0", "parents": ["3de0b99031779fbc6091e75ea741e127a8baeaf5"], "tags": []}], "date": 1511775810, "git_changesets": [null], "user": "sledru@mozilla.com"}, "8236": {"changesets": [{"author": "Florian Qu\u00e8ze \u003cflorian@queze.net\u003e", "branch": "default", "desc": "Bug 1226616 - The presence of the general.config.filename preference should be reported on telemetry. r=chutten, data-review=francois a=gchang", "files": ["toolkit/components/telemetry/TelemetryEnvironment.jsm", "toolkit/components/telemetry/tests/unit/test_TelemetryEnvironment.js"], "git_node": null, "git_parents": [null], "node": "4be846045a34c2c2762bfab1e723bd5a5043a154", "parents": ["700ddf967ab12709af45c564b138f62b246a4ef0"], "tags": []}, {"author": "Chris H-C \u003cchutten@mozilla.com\u003e", "branch": "default", "desc": "bug 1381633 - Communicate whether getActiveAddons is serving full data r=Dexter,rhelmer a=gchang\n\ngetActiveAddons can either return partial or full data for use by the Telemetry\nEnvironment. This is just a spike that communicates that difference out of\nXPIProvider and into the Environment so we know whether the DB has been loaded.\n\nMozReview-Commit-ID: 4Y5mq5aM6uu", "files": ["browser/experiments/Experiments.jsm", "toolkit/components/telemetry/TelemetryEnvironment.jsm", "toolkit/mozapps/extensions/AddonManager.jsm", "toolkit/mozapps/extensions/internal/XPIProvider.jsm"], "git_node": null, "git_parents": [null], "node": "ea066a148edc446c547757bed141a165dd89a8f4", "parents": ["4be846045a34c2c2762bfab1e723bd5a5043a154"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "Bug 1389836 - Put HandlerServiceChild in the proper namespace. r=bz a=gchang\n\nNon ns-prefixed classes are supposed to be in either the mozilla namespace or\na sub namespace (such as dom, css, or others).\n\nMozReview-Commit-ID: 8bF6bP49NLG", "files": ["uriloader/exthandler/HandlerServiceChild.h"], "git_node": null, "git_parents": [null], "node": "67fcff4eba056e11c052240794788c4fca2595c2", "parents": ["ea066a148edc446c547757bed141a165dd89a8f4"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "Bug 1389836 - Push extensions from MIME info objects to the child. r=bz a=gchang\n\nIt would be really nice to push all of this back up to the parent or to at\nleast make it asynchronous. I think it should be possible since we control\nwhen we send the DOM events, but for the moment this should work.\n\nWith this patch, I extend ProxyMIMEInfo and HandlerInfo with information about\nthe available extensions for a given MIME type. On Linux, at least, we read\nthe system (in my case GNOME) registry in the child and handlers.json in the\nparent finally merging them again in the child (in\nContentHandlerService::FillHandlerInfo). Even though I was unable to get my\nmochitest to work, it did work well enough that I could verify that this patch\nwas getting all of the proper extensions to the nsContentAreaDragDrop.cpp\ncode.\n\nMozReview-Commit-ID: AR3VayMUiDN", "files": ["uriloader/exthandler/ContentHandlerService.cpp", "uriloader/exthandler/HandlerServiceParent.cpp", "uriloader/exthandler/PHandlerService.ipdl", "uriloader/exthandler/nsExternalHelperAppService.cpp"], "git_node": null, "git_parents": [null], "node": "f459b78ab427b120ceb6320565dfe77b77247414", "parents": ["67fcff4eba056e11c052240794788c4fca2595c2"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "Bug 1389836 - Don't recreate mHandlerInfo for every little change. r=bz a=gchang\n\nThere are non-cost reference return values on IPDL structs. We should take\nadvantage of them in order not to recopy everything everytime something\nchanges.\n\nMozReview-Commit-ID: D4hG2moE3f", "files": ["uriloader/exthandler/HandlerServiceParent.cpp"], "git_node": null, "git_parents": [null], "node": "35e083bb82efff62d48a0ca947816ab44d38eb81", "parents": ["f459b78ab427b120ceb6320565dfe77b77247414"], "tags": []}, {"author": "Tim Taubert \u003cttaubert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1396833 - Fix tab drag&drop not finishing due to CSS transform not kicking in r=mconley a=gchang\n\nSummary:\nIn very rare situations, the right number of tabs and the right drop position\nwill lead to the drop event handler trying to start a translateX() transform\nand then wait for the transitionend event that will never fire.\n\nIf the old and the new translateX values are too close together (e.g.\n1259.1000061035156 and 1259.0999450683594) then the layout engine won't\nactually start a transform.\n\nA simple solution is to round translateX values before comparing them and\ndeciding whether to initiate a transition.\n\nReviewers: mconley\n\nReviewed By: mconley\n\nBug #: 1396833\n\nDifferential Revision: https://phabricator.services.mozilla.com/D265", "files": ["browser/base/content/tabbrowser.xml"], "git_node": null, "git_parents": [null], "node": "33e95d96edd254f38dcd29bae7f9974ebfeea703", "parents": ["35e083bb82efff62d48a0ca947816ab44d38eb81"], "tags": []}, {"author": "Ted Campbell \u003ctcampbell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397049 - Fix debugger 'this' in functions with let. r=jorendorff a=gchang\n\nWhen the debugger evaluates code in the debuggee frame, the parser may\nfail to detect we are in a function context and will compute 'this'\nincorrectly as a result. This patch fixes the environment chain\ntraversal around DebugEnvironmentProxy to more accurately determine the\nbinding type of 'this' within a function.\n\nMozReview-Commit-ID: GzRDOJLK8fx", "files": ["js/src/frontend/Parser.cpp", "js/src/jit-test/tests/debug/bug1397049.js", "js/src/vm/EnvironmentObject.h"], "git_node": null, "git_parents": [null], "node": "47c97637717fc01e6abcf769bb00ce3cc7a16276", "parents": ["33e95d96edd254f38dcd29bae7f9974ebfeea703"], "tags": []}], "date": 1511777161, "git_changesets": [null, null, null, null, null, null, null], "user": "apavel@mozilla.com"}, "8237": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nbs -\u003e 391af61ce268\ncy -\u003e 1cef80e3bf70\nfi -\u003e 0166d6eecd9c\nfy-NL -\u003e cc9179a45527\nga-IE -\u003e bf66310c0312\nhu -\u003e c81ee93d7622\nid -\u003e 8a1606dcec35\nis -\u003e 2ea9cc247311\nka -\u003e fd916f0f5398\nkk -\u003e 406e6625d590\nlo -\u003e 8b7d4d19a75b\nlt -\u003e bce902b53bc6\nltg -\u003e f214b0c64207\noc -\u003e ced9142c1c2e\nsl -\u003e 06f6c7c99de2\ntrs -\u003e 42a17c31b288", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "168cc6fc9f82604937187b106e830f80d4e7f736", "parents": ["47c97637717fc01e6abcf769bb00ce3cc7a16276"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nbg -\u003e 8a0741e5f9af\nbs -\u003e 391af61ce268\ncy -\u003e 1cef80e3bf70\nff -\u003e d7a1cea11477\nfi -\u003e 0166d6eecd9c\nfy-NL -\u003e cc9179a45527\nga-IE -\u003e bf66310c0312\ngd -\u003e 2d65db07c66f\nhr -\u003e e2faec5ff2ce\nhsb -\u003e 23a4be0d5638\nhu -\u003e c81ee93d7622\nid -\u003e 8a1606dcec35\nis -\u003e 2ea9cc247311\nka -\u003e 6d8d17f605a5\nkab -\u003e 1afba505394f\nkk -\u003e 406e6625d590\nkm -\u003e e43a5c2374fb\nko -\u003e 30692c673f5d\nlij -\u003e 0bdad2cf2883\nlt -\u003e bce902b53bc6\nmy -\u003e 697db1e6863d\nte -\u003e a89702dd75e4", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "9724cc63f11a67d6ab9f7f4c4849d5e857e2ce97", "parents": ["168cc6fc9f82604937187b106e830f80d4e7f736"], "tags": []}], "date": 1511778056, "git_changesets": [null, null], "user": "ffxbld"}, "8238": {"changesets": [{"author": "Ray Lin \u003cralin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397173 - Apply dark overlay style when only error occurs in mobile video controls. r=jolin a=gchang\n\nMozReview-Commit-ID: CsVK90kmLlT", "files": ["mobile/android/themes/geckoview/videocontrols.css"], "git_node": null, "git_parents": [null], "node": "725b718e10c8374b5be64c41635581cf41866e6e", "parents": ["9724cc63f11a67d6ab9f7f4c4849d5e857e2ce97"], "tags": []}, {"author": "Matheus Longaray \u003cmlongaray@hp.com\u003e", "branch": "default", "desc": "Bug 1404176 - Remove aborted print preview browser before bailing out. r=mconley a=gchang\n\nThis patch clears out set of print preview browsers before bailing out when\nthere is an error while putting the document into print preview mode.\n\nMozReview-Commit-ID: 20cm4DCktQk", "files": ["toolkit/components/printing/content/printUtils.js"], "git_node": null, "git_parents": [null], "node": "14022278b66d392fdf203cf4bc08fee82b47d286", "parents": ["725b718e10c8374b5be64c41635581cf41866e6e"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1409133 - Avoid shrinking tabs through ::before elements when moving them. r=dao a=gchang\n\nAs mentioned in the comment:\n\nNote that this doesn't perfectly solve the issue (dragged tabs\nmay still resize very slightly) on some DPI settings with uneven\nscaling factors on Windows, because of bug 477157.\n\nWe consider the fix in this patch good enough for now.\n\nMozReview-Commit-ID: BbpxLVq8AEb", "files": ["browser/themes/shared/tabs.inc.css"], "git_node": null, "git_parents": [null], "node": "a66f23b1940632778b6447d967469bb97c2e72ab", "parents": ["14022278b66d392fdf203cf4bc08fee82b47d286"], "tags": []}, {"author": "Daosheng Mu \u003cdaoshengmu@gmail.com\u003e", "branch": "default", "desc": "Bug 1409677 - Adjust kCommonAliasedLineWidthRangeMax to 1 in WebGL resistFingerprint mode; r=cfu,jgilbert a=gchang\n\nMozReview-Commit-ID: 4gusUhU9VMI", "files": ["dom/canvas/WebGLContextValidate.cpp", "dom/canvas/test/webgl-mochitest/mochitest.ini", "dom/canvas/test/webgl-mochitest/test_webgl_fingerprinting_resistance.html"], "git_node": null, "git_parents": [null], "node": "99df250531e1b7aaa6d1cffa825a8beacb084e41", "parents": ["a66f23b1940632778b6447d967469bb97c2e72ab"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1413287: Ensure that interceptors do not marshal a handler payload unless they are the outermost marshal request; r=Jamie a=gchang\n\nMozReview-Commit-ID: 2rDreOpdwvy", "files": ["ipc/mscom/Interceptor.cpp"], "git_node": null, "git_parents": [null], "node": "780900bb90913f473e7722568dc62fa22e82d3aa", "parents": ["99df250531e1b7aaa6d1cffa825a8beacb084e41"], "tags": []}, {"author": "Ciure Andrei \u003caciure@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 023371c245a7 (bug 1226616) for not working as intended a=backout", "files": ["modules/libpref/Preferences.cpp", "toolkit/components/telemetry/Scalars.yaml"], "git_node": null, "git_parents": [null], "node": "24ed530c9a036f8a706743b8f93f2b7f493256be", "parents": ["780900bb90913f473e7722568dc62fa22e82d3aa"], "tags": []}], "date": 1511778816, "git_changesets": [null, null, null, null, null, null], "user": "aciure@mozilla.com"}, "8239": {"changesets": [{"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1416986 part 1: Allow an mscom Handler to signal that it knows an interface is definitely not available. r=aklotz a=gchang\n\nIf QueryHandlerInterface returns E_NOINTERFACE, the proxy will be queried for the interface.\nHowever, the handler might know that the interface is definitely not available and could thus avoid a pointless cross-process call.\nTo facilitate this, the handler can now return S_FALSE to signal that the proxy should not be queried, thus immediately returning E_NOINTERFACE to the client.\n\nMozReview-Commit-ID: 4RtBsA9BTOV", "files": ["ipc/mscom/oop/Handler.cpp", "ipc/mscom/oop/Handler.h"], "git_node": null, "git_parents": [null], "node": "ee921fb100b395920f8a5cdcb0c92f070d56aa33", "parents": ["24ed530c9a036f8a706743b8f93f2b7f493256be"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1416986 part 2: Include interfaces the client is likely to request in the accessible handler payload. r=aklotz a=gchang\n\nNow that virtual buffers have to render across processes, we want to eliminate as many cross-process calls as possible.\nThis includes QueryInterface calls, since buffers query for several interfaces on every node they visit.\nTo avoid these cross-process QI calls, we include interfaces clients are likely to request in the handler payload.\nThis way, they get marshaled in the single call used to retrieve the object.\n\nThis patch does the following:\n\n1. Passes the interceptor when building the payload.\nWe need this so we can get interceptors for other interfaces.\n\n2. Splits the payload into two main parts: a static part and a dynamic part.\nThe (new) static part contains the interface pointers. The dynamic part contains the rest.\nThis is necessary because the refresh call cannot pass the interceptor, but the interceptor is needed to build the static part.\nAlso, re-building the static part is pointless when refreshing.\n\n3. Includes the interface pointers in the payload (BuildStaticIA2Data).\nThe pointers also have to be cleaned up after marshaling.\n\n4. Releases the interface pointers in the handler after the payload is received.\nWe do this because they're aggregated by the proxy manager as they're unmarshaled.\n\nMozReview-Commit-ID: 6VRLMNScgwW", "files": ["accessible/ipc/win/HandlerProvider.cpp", "accessible/ipc/win/HandlerProvider.h", "accessible/ipc/win/handler/AccessibleHandler.cpp", "accessible/ipc/win/handler/HandlerData.idl"], "git_node": null, "git_parents": [null], "node": "9d771f65f35d6bcfcd7a412aff6f60061482cbe9", "parents": ["ee921fb100b395920f8a5cdcb0c92f070d56aa33"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1416986 part 3: AccessibleHandler: Avoid cross-process QI calls for interfaces which we know don't exist. r=aklotz a=gchang\n\nThe proxy manager caches interfaces marshaled in the payload and returns them on QI without a cross-process call.\nHowever, it doesn't know about interfaces which don't exist.\nWe can determine this from the payload, since interfaces which don't exist will have a null pointer.\nWe use this information to avoid querying the proxy in this case.\n\nMozReview-Commit-ID: FnzDetmTiPP", "files": ["accessible/ipc/win/handler/AccessibleHandler.cpp"], "git_node": null, "git_parents": [null], "node": "30014722ca5303b725978d66fb651273a0cbc85c", "parents": ["9d771f65f35d6bcfcd7a412aff6f60061482cbe9"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1416986 part 4: AccessibleHandler: Don't fall through to the proxy for IAccessibleHyperlink. r=aklotz a=gchang\n\nThe handler's implementation of IAHyperlink just forwards calls through to the proxy.\nHowever, it exists because we want the cache to be used when a hyperlink is retrieved.\nWhen querying from the handler to IAHyperlink, we should use the same implementation.\nThis is mostly about consistency/correctness, especially as we're increasing complexity.\n\nMozReview-Commit-ID: AwYibrFzUyf", "files": ["accessible/ipc/win/handler/AccessibleHandler.cpp"], "git_node": null, "git_parents": [null], "node": "7ebf334c8ed4fd51c3dc738a2274ed7485f7e5fc", "parents": ["30014722ca5303b725978d66fb651273a0cbc85c"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1417327 part 1: Accessible handler: Cache IAccessibleAction::nActions. r=MarcoZ a=gchang\n\nMozReview-Commit-ID: EJIhSxSiQGq", "files": ["accessible/ipc/win/HandlerProvider.cpp", "accessible/ipc/win/handler/AccessibleHandler.cpp", "accessible/ipc/win/handler/HandlerData.idl"], "git_node": null, "git_parents": [null], "node": "403ec09d449e557972cf017f4f094e76e7009c95", "parents": ["7ebf334c8ed4fd51c3dc738a2274ed7485f7e5fc"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1417327 part 2: Accessible handler: Cache IAccessibleTableCell row/column indexes/extents. r=MarcoZ a=gchang\n\nMozReview-Commit-ID: 8hMzyJZ5zFI", "files": ["accessible/ipc/win/HandlerProvider.cpp", "accessible/ipc/win/handler/AccessibleHandler.cpp", "accessible/ipc/win/handler/AccessibleHandler.h", "accessible/ipc/win/handler/HandlerData.idl"], "git_node": null, "git_parents": [null], "node": "5b467b5636efa46906af107b824ecfb4787cc971", "parents": ["403ec09d449e557972cf017f4f094e76e7009c95"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1417327 part 3: Accessible handler: Fix cache for IAccessible::accDefaultAction and use it for IAccessibleAction::name(0). r=MarcoZ a=gchang\n\n1. Bug 1363595 added support for retrieving accDefaultAction from the cache, but the value was never cached in the first place.\nThis would have meant that accDefaultAction was returning nothing to clients.\n\n2. Since accDefaultAction is the name of the first action, we can also use this cached value for IAccessibleAction::name for index 0.\n\nMozReview-Commit-ID: 6PGRH45kKdB", "files": ["accessible/ipc/win/HandlerProvider.cpp", "accessible/ipc/win/handler/AccessibleHandler.cpp"], "git_node": null, "git_parents": [null], "node": "ad61044a4ba8ce0077c8ad6a415a0555fd8fac7c", "parents": ["5b467b5636efa46906af107b824ecfb4787cc971"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1417411 - Invalidate nsDisplayPerspective items when the inner transform frame changes. r=miko a=gchang", "files": ["layout/painting/nsDisplayList.h"], "git_node": null, "git_parents": [null], "node": "3480ca96e9cd95c0c889899a07d8b738c594c517", "parents": ["ad61044a4ba8ce0077c8ad6a415a0555fd8fac7c"], "tags": []}, {"author": "Ted Campbell \u003ctcampbell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418841 - Fix DeletePolicy of WasmInstanceScope::Data. r=jonco a=gchang\n\nMozReview-Commit-ID: EgLb7uTE52G", "files": ["js/src/gc/Zone.h"], "git_node": null, "git_parents": [null], "node": "f24456236534520e2c381c765fcfd7a775fbc5cd", "parents": ["3480ca96e9cd95c0c889899a07d8b738c594c517"], "tags": []}, {"author": "Zibi Braniecki \u003czbraniecki@mozilla.com\u003e", "branch": "default", "desc": "Bug 1420255 - Fix a regression from bug 1410736. r=florian a=gchang\n\nMozReview-Commit-ID: H9pxFHecYip", "files": ["toolkit/components/search/nsSearchService.js"], "git_node": null, "git_parents": [null], "node": "1b83e2c69374e442636a7c79619b2a173ef9ad0d", "parents": ["f24456236534520e2c381c765fcfd7a775fbc5cd"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1417498 - Account for aRequest being null in onLocationChange. r=JanH a=gchang\n\nAccording to the documentation, aRequest may be null in some cases, and one such\ncase is when the location change was caused by a page using the history API.\n\nMozReview-Commit-ID: AUlHBgzaKDX", "files": ["mobile/android/chrome/content/browser.js"], "git_node": null, "git_parents": [null], "node": "66c82ad8b8a95a90f09e969eadbe312ada5663f5", "parents": ["1b83e2c69374e442636a7c79619b2a173ef9ad0d"], "tags": []}], "date": 1511780123, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "8240": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nhr -\u003e b2d7a7642bbc\nkab -\u003e 2efb6acc61a6\nlv -\u003e 8b0a0777344b\noc -\u003e a01324f85614\nsk -\u003e e766dd7da3f8", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "fec9f5cba7c7cf809f604566f419d2d43e179fa5", "parents": ["66c82ad8b8a95a90f09e969eadbe312ada5663f5"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nhe -\u003e f8d6a71de776\nhr -\u003e b2d7a7642bbc\nja -\u003e 5d3affb88755\nja-JP-mac -\u003e 510d65d13cdb\nkab -\u003e 2efb6acc61a6\nkn -\u003e e77d1fbca599\nlv -\u003e 8b0a0777344b\npt-BR -\u003e 6b53686ec50c\nsk -\u003e e766dd7da3f8\nsl -\u003e ab0e92e0306b\nte -\u003e ebf361fbc6fa", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "548e21d0ac1b9bbc079236f5d1e08db1e78e461f", "parents": ["fec9f5cba7c7cf809f604566f419d2d43e179fa5"], "tags": []}], "date": 1511781907, "git_changesets": [null, null], "user": "ffxbld"}, "8241": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "de