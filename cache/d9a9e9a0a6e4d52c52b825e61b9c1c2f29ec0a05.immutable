s saves unnecessary allocations and/or\nrefcounting.", "files": ["gfx/thebes/gfxBlur.cpp", "gfx/thebes/gfxGradientCache.cpp"], "git_node": null, "git_parents": [null], "node": "d0ddd9a98e74e8c736f4f11ffb5a8ed32adb0bda", "parents": ["186ee641ae417ac0217a0a656a8a4ce5c936fad0"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset d0ddd9a98e74 (bug 1415961) for bustage in thebes. r=backout on a CLOSED TREE", "files": ["gfx/thebes/gfxBlur.cpp", "gfx/thebes/gfxGradientCache.cpp"], "git_node": null, "git_parents": [null], "node": "ef4baef9df841886af07530afb4fa1f8ae8e93ab", "parents": ["d0ddd9a98e74e8c736f4f11ffb5a8ed32adb0bda"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1416009 - Update pdf.js to version 2.0.106. r=bdahl, r=Mossop on a CLOSED TREE", "files": ["browser/extensions/pdfjs/README.mozilla", "browser/extensions/pdfjs/content/PdfStreamConverter.jsm", "browser/extensions/pdfjs/content/build/pdf.js", "browser/extensions/pdfjs/content/build/pdf.worker.js"], "git_node": null, "git_parents": [null], "node": "20f7ef85a904f891d26a9dc7fed00b58e1006263", "parents": ["ef4baef9df841886af07530afb4fa1f8ae8e93ab"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset 0b07ff291caa (bug 1401250) because it'll probably do more harm than good.", "files": ["browser/app/module.ver"], "git_node": null, "git_parents": [null], "node": "6d174f463c1a70aa68e4f2292bd0aee6297c4947", "parents": ["20f7ef85a904f891d26a9dc7fed00b58e1006263"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": " Bug 1347515 - Get rid of nsIJSON.encodeFromJSVal, r=qdot", "files": ["dom/interfaces/json/nsIJSON.idl", "dom/json/nsJSON.cpp", "dom/json/nsJSON.h"], "git_node": null, "git_parents": [null], "node": "a3c81ef737006a74b0b7d23e85867f