b3d40ac0fe8536982a128a362b", "parents": ["572ebe407c6aaf408619d80b962b5543711e30b7"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nfi -\u003e 3b5e4b76bcad\ngu-IN -\u003e c1008db7f602", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "a89c6ace593b2e2a058fdbc179638589efead02a", "parents": ["e18b8937f9364bb3d40ac0fe8536982a128a362b"], "tags": []}], "date": 1512325258, "git_changesets": [null, null], "user": "ffxbld"}, "8299": {"changesets": [{"author": "Karl Tomlinson \u003ckarlt+@karlt.net\u003e", "branch": "default", "desc": "Bug 1408276 - Move to LIFECYCLE_WAITING_FOR_MAIN_THREAD_CLEANUP at end of iteration. r=padenot, a=gchang\n\nMozReview-Commit-ID: GbfIOPZPuGu", "files": ["dom/media/GraphDriver.cpp", "dom/media/MediaStreamGraph.cpp", "dom/media/MediaStreamGraphImpl.h"], "git_node": null, "git_parents": [null], "node": "cda8fcf76af1fef92fa7a4b2292beba4543a7b93", "parents": ["a89c6ace593b2e2a058fdbc179638589efead02a"], "tags": []}, {"author": "Karl Tomlinson \u003ckarlt+@karlt.net\u003e", "branch": "default", "desc": "Bug 1382366 - Disable AudioCallback -\u003e SystemClockDriver fallback before disowning graph. f=pehrsons, r=padenot, a=gchang\n\nMozReview-Commit-ID: ESr6yxjPVWf", "files": ["dom/media/GraphDriver.cpp", "dom/media/GraphDriver.h"], "git_node": null, "git_parents": [null], "node": "9b8d0f0783279786b4e5a59414308f47cbec15b1", "parents": ["cda8fcf76af1fef92fa7a4b2292beba4543a7b93"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1420332 - Use system locale when system default is selected for browser locale. r=snorp, a=gchang\n\nThis is a regression by bug 1337078.  When user selects system default for\nBrowser language, \"locale\" pref is empty.  So BrowserLocaleManager.getLocale\nalways returns null.  So, current locale is always en-US in Gecko code.\n\nSo we should return system locale when \"locale\" pref is empty.\n\nAlso, ReadSystemLocales expects language tag string for locale.  Since\nLocale.toString doesn't return language tag, so we should convert to it.\n\nMozReview-Commit-ID: 3NhAkuA4HaH", "files": ["mobile/android/base/java/org/mozilla/gecko/BrowserLocaleManager.java", "mobile/android/base/java/org/mozilla/gecko/LocaleManager.java"], "git_node": null, "git_parents": [null], "node": "9ebc50b8692dfa0e779024b28396b69dea7ee6a5", "parents": ["9b8d0f0783279786b4e5a59414308f47cbec15b1"], "tags": []}, {"author": "Jeremy Chen \u003cjeremychen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418433 - Add tests for style data update mechanism for non-displayed elements. r=emilio, r=heycam, a=gchang\n\nIn certain situations, we might access a non-displayed (i.e., display: none;)\nelement's style data through getComputedStyle API. In this patch, we add some\ntests to ensure that, if the inline style sheet is added/changed/removed, the\nstyle data of a non-displayed element is always up-to-date. Some more tests\nare added to verify the correctness of the style data when a style rule is\nadded/changed/removed via CSSOM.\n\nMozReview-Commit-ID: Ggjd4FMqZlo", "files": ["layout/style/test/test_computed_style.html"], "git_node": null, "git_parents": [null], "node": "005f0819a0cdbb88070d7fd1a8fa24e6903354c8", "parents": ["9ebc50b8692dfa0e779024b28396b69dea7ee6a5"], "tags": []}, {"author": "Jeremy Chen \u003cjeremychen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418433 - Move the implementation of SetStylistStyleSheetsDirty to .cpp file. r=heycam, a=gchang\n\nThis is a pre-patch for the real fix of Bug 1418433.\n\nIn the real fix, we'll add a IncrementUndisplayedRestyleGeneration() call into\nSetStylistStyleSheetsDirty(). However, the IncrementUndisplayedRestyleGeneration()\ncall needs get through some deep structures in nsPresContext, RestyleManager,...\netc., and doing so means we need to move bunches of related include files, forward\ndeclarations, from .cpp file to .h file, which doesn't make sense.\n\nInstead, we move the implementation parts of SetStylistStyleSheetsDirty() to .cpp\nfile (since it is now a bit more complicated than it was), so we can use the existing\ninclude files in the .cpp file to add IncrementUndisplayedRestyleGeneration() call\n(this is in a following patch).\n\nMozReview-Commit-ID: 3Vp9qyCf8NA", "files": ["layout/style/ServoStyleSet.cpp", "layout/style/ServoStyleSet.h"], "git_node": null, "git_parents": [null], "node": "25f3d0651a78a6d30dfe4237d5d41d3d653b463e", "parents": ["005f0819a0cdbb88070d7fd1a8fa24e6903354c8"], "tags": []}, {"author": "Jeremy Chen \u003cjeremychen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418433 - Increment RestyleGeneration for undisplayed elements when invalidating servo stylist. r=heycam, a=gchang\n\nIn the current implementation, we call SetStylistStyleSheetsDirty() every time\na style sheet is changed. However, the dirty bit setting may or may not always\nupdate the style data. For example, the style data for undisplayed elements are\ndeliberately not updated in Stylo. However, the getComputedStyle API is supposed\nto provide a way to get the up-to-date computed style data, even for undisplayed\nelements.\n\nIn this patch, we increment RestyleGeneration for undisplayed elements when we\ncall SetStylistStyleSheetsDirty(). This could flush the cached data that\ngetComputedStyle API holds, and ensures the getComputedStyle API computes a new\none.\n\nMozReview-Commit-ID: JDDhACOG3z4", "files": ["layout/style/ServoStyleSet.cpp"], "git_node": null, "git_parents": [null], "node": "d23f5b4bf54978803f0c4b5312b00b209d12b55d", "parents": ["25f3d0651a78a6d30dfe4237d5d41d3d653b463e"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1417961 - Fix Baseline debug mode OSR to delazify type monitor chains correctly. r=tcampbell, a=gchang", "files": ["js/src/jit-test/tests/debug/bug1417961.js", "js/src/jit/BaselineDebugModeOSR.cpp"], "git_node": null, "git_parents": [null], "node": "43f74013ae081e9b5a84cdc6c087d4e206af068b", "parents": ["d23f5b4bf54978803f0c4b5312b00b209d12b55d"], "tags": []}], "date": 1512326808, "git_changesets": [null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8300": {"changesets": [{"author": "David Anderson \u003cdanderson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1416864 - Synchronize how snapshots detach in DrawTargetD2D1. r=bas a=gchang", "files": ["gfx/2d/DrawTargetD2D1.cpp", "gfx/2d/DrawTargetD2D1.h", "gfx/2d/SourceSurfaceD2D1.cpp", "gfx/2d/SourceSurfaceD2D1.h"], "git_node": null, "git_parents": [null], "node": "503237c7de504e66df56ec3c16e2d8e262e11122", "parents": ["43f74013ae081e9b5a84cdc6c087d4e206af068b"], "tags": []}, {"author": "Ted Campbell \u003ctcampbell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418894 - Harden XDR data decoding. r=nbp a=gchang\n\nThis patch adds better error detection to XDR decoding to reduce memory\ncorruption in the event that XDR data is corrupt (which is not\n*supposed* to happen).\n\nAdd missing default cases. Make out-of-range values fail the decode by\nasserting in debug, and returning a TranscodeError in release. Mix a\nmagic value into enum value before transcoding to buffer (to reduce\nchance of garbage data being decoded).\n\nMozReview-Commit-ID: 1wPkho9dm8c", "files": ["js/src/jsapi.h", "js/src/jsscript.cpp", "js/src/shell/js.cpp", "js/src/vm/Xdr.h"], "git_node": null, "git_parents": [null], "node": "84ca5dce1d6a63bc64612876eccee30fc45080f9", "parents": ["503237c7de504e66df56ec3c16e2d8e262e11122"], "tags": []}, {"author": "Ted Campbell \u003ctcampbell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418894 - Use marker values in XDR data to detect corruption. r=nbp a=gchang\n\nMozReview-Commit-ID: D6PxPBdgtPP", "files": ["js/src/jsfun.cpp", "js/src/jsscript.cpp", "js/src/vm/Xdr.h"], "git_node": null, "git_parents": [null], "node": "73bde255ce55e61a3d01873d846d22b50e1a3428", "parents": ["84ca5dce1d6a63bc64612876eccee30fc45080f9"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Revert to using EnsureBackBufferIfFrontBuffer (bug 1416921, r=bas) a=gchang\n\nThis commit reverts DoubleBufferedContentClient to creating a back buffer\nif there is an existing front buffer. This reverts back to a sequence of a\nfinalize frame, unrotate, and initialize new back buffer. When we are\nnot async painting we do each buffer operation immediately. If we are\nasync painting, then we collect all of the buffer operations and perform\nthem on the paint thread.\n\nNote on locking: The destination for buffer copies must always be opened\nwith the async write flag, and the source must be unlocked.\n\nMozReview-Commit-ID: Gu4EcblY7Sg", "files": ["gfx/layers/PaintThread.cpp", "gfx/layers/PaintThread.h", "gfx/layers/client/ContentClient.cpp", "gfx/layers/client/ContentClient.h"], "git_node": null, "git_parents": [null], "node": "73a12159e3d7e829bab40a251d44f9a0e39b4286", "parents": ["73bde255ce55e61a3d01873d846d22b50e1a3428"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Add back mistakenly removed continue statement (bug 1421871, r=bas) a=gchang\n\nMozReview-Commit-ID: JaszzEY76nU", "files": ["gfx/layers/client/ContentClient.cpp"], "git_node": null, "git_parents": [null], "node": "810f9fabc68483d081ad8fbaa7a648e2f49fbb7a", "parents": ["73a12159e3d7e829bab40a251d44f9a0e39b4286"], "tags": []}], "date": 1512391097, "git_changesets": [null, null, null, null, null], "user": "ccoroiu@mozilla.com"}, "8301": {"changesets": [{"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "servo: Merge #19429 - Don't try to share style on quirks mode whenever two elements have different id (from upsuper:sharing-quirks-id); r=emilio a=gchang\n\nThis fixes [bug 1420946](https://bugzilla.mozilla.org/show_bug.cgi?id=1420946).\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: fce44a2e139478a5fc3524c2fd72fbeea6e3eec1", "files": ["servo/components/style/stylist.rs"], "git_node": null, "git_parents": [null], "node": "306f3de7c409ab29dd5c3c14b32a643b5e567b3a", "parents": ["810f9fabc68483d081ad8fbaa7a648e2f49fbb7a"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1420946 - Don't try to share style on quirks mode whenever two elements have different id. r=emilio a=gchang\n\nMozReview-Commit-ID: FcHXGUoMMbD", "files": ["layout/reftests/bugs/1420946-1-ref.html", "layout/reftests/bugs/1420946-1.html", "layout/reftests/bugs/reftest.list"], "git_node": null, "git_parents": [null], "node": "9b41fc04fab1a5f5670a324fd48ec03ccc0c6e24", "parents": ["306f3de7c409ab29dd5c3c14b32a643b5e567b3a"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "servo: Merge #19432 - style: Bail out from invalidation if we're the root and got tons of descendant invalidations (from emilio:invalidation-bail); r=heycam a=gchang\n\nBug: 1420741\nReviewed-by: heycam\nMozReview-Commit-ID: 4Kja20Ep9qD\nSource-Repo: https://github.com/servo/servo\nSource-Revision: e4d5e9699b9e784e5eba0aec316a35d048786052", "files": ["servo/components/style/invalidation/element/collector.rs"], "git_node": null, "git_parents": [null], "node": "0319dd2d58a9161baceb8d91e023573f4d40c279", "parents": ["9b41fc04fab1a5f5670a324fd48ec03ccc0c6e24"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1420507, r=freddyb,francois a=gchang", "files": ["dom/base/nsTreeSanitizer.cpp"], "git_node": null, "git_parents": [null], "node": "aded8e18768e3763243e38d948951e335ac6318c", "parents": ["0319dd2d58a9161baceb8d91e023573f4d40c279"], "tags": []}, {"author": "Andreas Pehrson \u003