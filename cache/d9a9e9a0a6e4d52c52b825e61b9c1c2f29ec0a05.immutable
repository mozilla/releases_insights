": [null], "node": "b42edef23af75eeac529ea4df6191570ffda340d", "parents": ["b0ae922973c1294a875dee38c6a0295957adee8b"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1409301 - Update the site security subview to the Photon style. r=johannh\n\nThe site security subview is now implemented using the \"photonpanelmultiview\" element, replacing the last instance of the \"panelmultiview\" element. The subview features a standard Photon header, hence the connection state icon was moved to the element below it. This makes the styles more similar between the main view and the subview. The connection state styles are now applied using a class name, and the tests have been updated accordingly.\n\nThis change required some fixes in the \"photonpanelmultiview\" implementation to make sure the height of the subview is correct and to allow keyboard navigation back to the main view.\n\nSince the expander button and the permission controls in the main view are not visible anymore after the subview is shown, some code related to focus and hover could be removed as well.\n\nMozReview-Commit-ID: 4nIAPWJPV8k", "files": ["browser/base/content/browser.js", "browser/base/content/test/general/browser_addCertException.js", "browser/base/content/test/performance/browser_appmenu_reflows.js", "browser/base/content/test/siteIdentity/browser_identity_UI.js", "browser/base/content/test/siteIdentity/browser_insecureLoginForms.js", "browser/base/content/test/siteIdentity/head.js", "browser/components/controlcenter/content/panel.inc.xul", "browser/components/customizableui/PanelMultiView.jsm", "browser/components/customizableui/content/panelUI.xml", "browser/locales/en-US/chrome/browser/browser.dtd", "browser/locales/en-US/chrome/browser/browser.properties", "browser/themes/shared/controlcenter/panel.inc.css"], "git_node": null, "git_parents": [null], "node": "ded163bd1d4603dc141e863b2462467b972ebf81", "parents": ["ea2100fcee92171fbb7f5b9a83dda324ed448d48"], "tags": []}, {"author": "Sylvestre Ledru \u003csledru@mozilla.com\u003e", "branch": "default", "desc": "Bug 1416484 - Fix some display issues on amazon nl search r=flod\n\nMozReview-Commit-ID: 5oplHfxUeBQ", "files": ["browser/locales/searchplugins/amazon-nl.xml"], "git_node": null, "git_parents": [null], "node": "b5523502e39c3b160813f330dc79cf9e2b5d87c5", "parents": ["ded163bd1d4603dc141e863b2462467b972ebf81"], "tags": []}, {"author": "JerryShih \u003chshih@mozilla.com\u003e", "branch": "default", "desc": "Bug 1416543 - use the gecko profiler macro to register/unregister the thread name. r=me\n\nMozReview-Commit-ID: 3ueSAuNCbGp", "files": ["gfx/layers/wr/WebRenderBridgeParent.cpp"], "git_node": null, "git_parents": [null], "node": "046d8bdbc0238ea0ea611c5ffd92770020a4abf6", "parents": ["b5523502e39c3b160813f330dc79cf9e2b5d87c5"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1416561 - update readability from git ( c3ff1a2d2c94c1db257b2c9aa88a4b8fbeb221c5 ), r=already-reviewed\n\nMozReview-Commit-ID: 3WX99CsZ4z5", "files": ["toolkit/components/reader/Readability.js"], "git_node": null, "git_parents": [null], "node": "7fb001f811d183095e9cfdd958c9215484377396", "parents": ["046d8bdbc0238ea0ea611c5ffd92770020a4abf6"], "tags": []}, {"author": "ffxbld", "branch": "default", "desc": "No bug, Automated HSTS preload list update from host bld-linux64-spot-030 - a=hsts-update", "files": ["security/manager/ssl/nsSTSPreloadList.errors", "security/manager/ssl/nsSTSPreloadList.inc"], "git_node": null, "git_parents": [null], "node": "bffd279e3780e516e0439724c7d0fa2e4a9a4c6f", "parents": ["ea2100fcee92171fbb7f5b9a83dda324ed448d48"], "tags": []}, {"author": "ffxbld", "branch": "default", "desc": "No bug, Automated HPKP preload list update from host bld-linux64-spot-030 - a=hpkp-update", "files": ["security/manager/ssl/StaticHPKPins.h"], "git_node": null, "git_parents": [null], "node": "77286