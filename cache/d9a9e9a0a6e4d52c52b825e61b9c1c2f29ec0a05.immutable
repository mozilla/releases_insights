y/Telemetry.cpp:1591. r=backout on a CLOSED TREE", "files": ["toolkit/components/telemetry/Telemetry.cpp", "toolkit/components/telemetry/Telemetry.h", "toolkit/components/telemetry/nsITelemetry.idl", "toolkit/components/telemetry/tests/unit/test_TelemetryController.js"], "git_node": null, "git_parents": [null], "node": "d0c21ca40a543227a1a1f2b1a075d9620abdefd5", "parents": ["0d15cd7ec41f36c03f83871c36a9208b3748a0e2"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "servo: Merge #19126 - style: Introduce SourceSizeList (from emilio:source-size-list); r=nox\n\nThis is part of the work for https://bugzilla.mozilla.org/show_bug.cgi?id=1408308.\n\nBut this can just land now IMO, before I do the integration bits.\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 0047c77f0374ec773fab1cb0c0b7fcfdbb6472d2", "files": ["servo/components/style/gecko/media_queries.rs", "servo/components/style/media_queries.rs", "servo/components/style/servo/media_queries.rs", "servo/components/style/values/computed/mod.rs", "servo/components/style/values/specified/mod.rs", "servo/components/style/values/specified/source_size_list.rs"], "git_node": null, "git_parents": [null], "node": "a156ab11569b74871f52e2e7024af0efbc182f0c", "parents": ["d0c21ca40a543227a1a1f2b1a075d9620abdefd5"], "tags": []}, {"author": "Edgar Chen \u003cechen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414317 - Add [CEReactions] to document.createElement and document.createElementNS; r=smaug\n\nPer https://github.com/w3c/webcomponents/issues/570.\n\nMozReview-Commit-ID: 610lZlF6QXg", "files": ["dom/webidl/Document.webidl"], "git_node": null, "git_parents": [null], "node": "46ebff3824d4abf7b8233ad3e5c491b7dad7f1bb", "parents": ["a156ab11569b74871f52e2e7024af0efbc182f0c"], "tags": []}, {"author": "Jan Odvarko \u003codvarko@gmail.com\u003e", "branch": "default", "desc": "Bug 1409413 - Split Netmonitor styles into more files; r=rickychien\n\nMozReview-Commit-ID: 7odPKz06XeA", "files": ["devtools/client/jar.mn", "devtools/client/netmonitor/src/assets/styles/MdnLink.css", "devtools/client/netmonitor/src/assets/styles/NetworkDetailsPanel.css", "devtools/client/netmonitor/src/assets/styles/RequestList.css", "devtools/client/netmonitor/src/assets/styles/StatisticsPanel.css", "devtools/client/netmonitor/src/assets/styles/StatusBar.css", "devtools/client/netmonitor/src/assets/styles/Toolbar.css", "devtools/client/netmonitor/src/assets/styles/httpi.css", "devtools/client/netmonitor/src/assets/styles/netmonitor.css", "devtools/client/netmonitor/src/assets/styles/variables.css", "devtools/client/themes/webconsole.css", "devtools/client/webconsole/local-dev/index.js", "devtools/client/webconsole/webconsole.html"], "git_node": null, "git_parents": [null], "node": "5ed21ce36c1ba7918b8163a14c692b382eb4d95b", "parents": ["46ebff3824d4abf7b8233ad3e5c491b7dad7f1bb"], "tags": []}, {"author": "Jan Odvarko \u003codvarko@gmail.com\u003e", "branch": "default", "desc": "Bug 1409413 - Put shared styles into network-monitor context; r=rickychien\n\nMozReview-Commit-ID: KVuFWsRxb2W", "files": ["devtools/client/netmonitor/src/assets/styles/MdnLink.css", "devtools/client/netmonitor/src/assets/styles/NetworkDetailsPanel.css", "devtools/client/webconsole/new-console-output/components/message-types/NetworkEventMessage.js"], "git_node": null, "git_parents": [null], "node": "9958747d871de36e8fd2788f72bc0d28a2344de6", "parents": ["5ed21ce36c1ba7918b8163a14c692b382eb4d95b"], "tags": []}, {"author": "Jan Odvarko \u003codvarko@gmail.com\u003e", "branch": "default", "desc": "Bug 1409413 - Make sure text in the Console command line is v-centered; r=nchevobbe\n\nMozReview-Commit-ID: 7TuLSPfzJ6k", "files": ["devtools/client/themes/webconsole.css"], "git_node": null, "git_parents": [null], "node": "e96092796151a5ccb95ad1fe822bde9fe7ca5ad8", "parents": ["9958747d871de36e8fd2788f72bc0d28a2344de6"], "tags": []}, {"author": "J. Ryan Stinnett \u003cjryans@gmail.com\u003e", "branch": "default", "desc": "Bug 1198013 - DevToolsModules now safe to call multiple times. r=miker\n\nMozReview-Commit-ID: 2wg78JE6Cb7", "files": ["devtools/templates.mozbuild"], "git_node": null, "git_parents": [null], "node": "f541c03beb5f21a380ec2146f37c609b708b5661", "parents": ["e96092796151a5ccb95ad1fe822bde9fe7ca5ad8"], "tags": []}, {"author": "Robin Miller \u003cmill2540@msu.edu\u003e", "branch": "default", "desc": "Bug 1403686 - Crops screenshots to a region based on a selector.  r=jaws\n\nCan now crop screenshots properly, for basic cases.\nAlso changed behavior so that if different window types are given, the application exits.\n\nMozReview-Commit-ID: CqmIJFufONw", "files": ["browser/tools/mozscreenshots/browser.ini", "browser/tools/mozscreenshots/browser_screenshots_cropping.js", "browser/tools/mozscreenshots/mozscreenshots/extension/Screenshot.jsm", "browser/tools/mozscreenshots/mozscreenshots/extension/TestRunner.jsm", "browser/tools/mozscreenshots/mozscreenshots/extension/lib/robot_center.png", "browser/tools/mozscreenshots/mozscreenshots/extension/lib/robot_upperleft.png"], "git_node": null, "git_parents": [null], "node": "d3ed36f4fb7a3139658b691956bdc28c6ca5e20e", "parents": ["f541c03beb5f21a380ec2146f37c609b708b5661"], "tags": []}, {"author": "Sam Foster \u003csfoster@mozilla.com\u003e", "branch": "default", "desc": "Bug 1408007 - Update tab loading throbber color for in-active tabs in darker themes r=dao\n\nMozReview-Commit-ID: 7msV7UA55jc", "files": ["browser/themes/shared/tabs.inc.css"], "git_node": null, "git_parents": [null], "node": "565d98335e7e83699c3237b40b2af2273fc6d488", "parents": ["d3ed36f4fb7a3139658b691956bdc28c6ca5e20e"], "tags": []}, {"author": "Jed Davis \u003cjld@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412480 - Fix syscall argument types in seccomp-bpf sandbox traps. r=gcp\n\nThe values in arch_seccomp_data::args are uint64_t even on 32-bit\nplatforms, and syscall takes varargs, so the arguments need to be\nexplicitly cast to the word size in order to be passed correctly.\n\nMozReview-Commit-ID: 5ldv6WbL2Z3", "files": ["security/sandbox/linux/SandboxFilter.cpp"], "git_node": null, "git_parents": [null], "node": "48b83b14ff3d1c47481980b5ec0b091d26d3d4c9", "parents": ["565d98335e7e83699c3237b40b2af2273fc6d488"], "tags": []}, {"author": "Jed Davis \u003cjld@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412480 - Statically check for overly large syscall arguments. r=gcp\n\nSee the previous patch for an explanation of the mistake that this is\nmeant to catch.\n\nNote that, even for arguments that really are 64-bit on 32-bit platforms\n(typically off_t), it's generally not safe to pass them directly to\nsyscall(): some architectures, like ARM, use ABIs that require such\narguments to be passed in aligned register pairs, and they'll be aligned\ndifferently for syscall() vs. the actual system call due to the leading\nsystem call number argument.  The syscall(2) man page discusses this\nand documents that such arguments should be split into high/low halves,\npassed separately, and manually padded.\n\nTherefore, this patch rejects any argument types larger than a word.\n\nMozReview-Commit-ID: FVhpri4zcWk", "files": ["security/sandbox/linux/SandboxFilter.cpp"], "git_node": null, "git_parents": [null], "node": "eeb1aae7683bac5303976c8ebd425f632ecb0b9b", "parents": ["48b83b14ff3d1c47481980b5ec0b091d26d3d4c9"], "tags": []}, {"author": "Jed Davis \u003cjld@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412464 - Change sandboxing inotify denial from seccomp-bpf to symbol interception. r=gcp\n\nMozReview-Commit-ID: DY0qdGYGNdL", "files": ["security/sandbox/linux/SandboxFilter.cpp", "security/sandbox/linux/SandboxHooks.cpp"], "git_node": null, "git_parents": [null], "node": "67cb7ca658a7a2e9a4aaebb0801a3f93c50deba7", "parents": ["eeb1aae7683bac5303976c8ebd425f632ecb0b9b"], "tags": []}, {"author": "Jed Davis \u003cjld@mozilla.com\u003e", "branch": "default", "desc": "Bug 1413312 - Fix media plugin sandbox policy for sched_get_priority_{min,max}. r=gcp\n\nMozReview-Commit-ID: Bz4EWU13HAJ", "files": ["security/sandbox/linux/SandboxFilter.cpp"], "git_node": null, "git_parents": [null], "node": "4ccd1fbb5ea660f79c573f5b95d15188de3b8a94", "parents": ["67cb7ca658a7a2e9a4aaebb0801a3f93c50deba7"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1411011 - stop offering context menu (re)move options on skipintoolbarset items, r=jaws\n\nGiving all these nodes ids doesn't seem like the right fix. `buildArea` already ignores skipintoolbarset\nitems before doing anything else with nodes, so bailing out early seemed like the right solution here.\n\nMozReview-Commit-ID: H3EyqoospNR", "files": ["browser/components/customizableui/CustomizableUI.jsm"], "git_node": null, "git_parents": [null], "node": "62b4fc74e72e6592f12827a53a318057fac8a59b", "parents": ["4ccd1fbb5ea660f79c573f5b95d15188de3b8a94"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "servo: Merge #18657 - script: Remove HTMLAppletElement (from emilio:bye-applet); r=KiChjang\n\nIt was removed from the spec, there's no reason to keep it in tree.\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: a509ebf90ccd24ef80b27737faefa340a5af8916", "files": ["servo/components/script/dom/create.rs", "servo/components/script/dom/document.rs", "servo/components/script/dom/htmlappletelement.rs", "servo/components/script/dom/htmlcollection.rs", "servo/components/script/dom/mod.rs", "servo/components/script/dom/virtualmethods.rs", "servo/components/script/dom/webidls/Document.webidl", "servo/components/script/dom/webidls/HTMLAppletElement.webidl", "servo/resources/presentational-hints.css"], "git_node": null, "git_parents": [null], "node": "40a86fa71825a4ff615d604b10914ec27b9695cd", "parents": ["62b4fc74e72e6592f12827a53a318057fac8a59b"], "tag