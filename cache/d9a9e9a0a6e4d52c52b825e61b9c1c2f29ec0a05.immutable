a/gecko/GeckoApp.java", "mobile/android/chrome/content/browser.js"], "git_node": null, "git_parents": [null], "node": "c818d9deb4627045e57217ed3274697496edff92", "parents": ["29d36b507287ce7f7c5f1a43bc80d0e311cff0b1"], "tags": []}], "date": 1511358599, "git_changesets": [null], "user": "apavel@mozilla.com"}, "8196": {"changesets": [{"author": "Ray Lin \u003cralin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1392947 - Add more credit card expiration date matching patterns to enhance prediction. r=lchang,seanlee a=gchang\n\nMozReview-Commit-ID: 3WyU6wSC8wD", "files": ["browser/extensions/formautofill/FormAutofillHeuristics.jsm", "browser/extensions/formautofill/test/unit/heuristics/third_party/test_QVC.js", "browser/extensions/formautofill/test/unit/heuristics/third_party/test_Sears.js", "browser/extensions/formautofill/test/unit/test_extractLabelStrings.js"], "git_node": null, "git_parents": [null], "node": "a8ed5d6e5ff37f33420e97f74cb5eab0531b0e6d", "parents": ["c818d9deb4627045e57217ed3274697496edff92"], "tags": []}], "date": 1511358701, "git_changesets": [null], "user": "apavel@mozilla.com"}, "8197": {"changesets": [{"author": "Dylan Roeh \u003cdroeh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1370915 - Reorganize compatibility checks in BrowserApp and GeckoApp to avoid attempting to load mozglue on unsupported hardware. r=jchen a=gchang", "files": ["mobile/android/base/java/org/mozilla/gecko/BrowserApp.java", "mobile/android/base/java/org/mozilla/gecko/GeckoApp.java"], "git_node": null, "git_parents": [null], "node": "383831f52344c32148287fa28f41a0e573448504", "parents": ["a8ed5d6e5ff37f33420e97f74cb5eab0531b0e6d"], "tags": []}], "date": 1511358797, "git_changesets": [null], "user": "apavel@mozilla.com"}, "8198": {"changesets": [{"author": "Cameron McCormack \u003ccam@mcc.id.au\u003e", "branch": "default", "desc": "servo: Merge #19263 - selectors: Allow white space in the brackets of an attribute selector (from heycam:attr-ws); r=SimonSapin a=gchang\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 7b886b4479763018ecad62aa6db96049732ca9ed", "files": ["servo/components/selectors/parser.rs"], "git_node": null, "git_parents": [null], "node": "65eaccbc3cdd8b2a3a8adda505bf998b1e659c6d", "parents": ["383831f52344c32148287fa28f41a0e573448504"], "tags": []}], "date": 1511358925, "git_changesets": [null], "user": "apavel@mozilla.com"}, "8199": {"changesets": [{"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412090 - patch 1 - Wrap the font family record used to pass font info from chrome to content on macOS in a union, in preparation for using the same mechanism with a different type of font record on Linux. (No functional change here, just the added union type and some renamings from 'font family list' to 'font list' to be more generic.) r=lsalzman a=gchang", "files": ["dom/ipc/ContentChild.cpp", "dom/ipc/ContentChild.h", "dom/ipc/ContentParent.cpp", "dom/ipc/PContent.ipdl", "gfx/thebes/gfxMacPlatformFontList.h", "gfx/thebes/gfxMacPlatformFontList.mm", "gfx/thebes/gfxPlatform.h", "gfx/thebes/gfxPlatformMac.cpp", "gfx/thebes/gfxPlatformMac.h"], "git_node": null, "git_parents": [null], "node": "bfe05205f198cf7e4aac88e515725ee3fc394023", "parents": ["65eaccbc3cdd8b2a3a8adda505bf998b1e659c6d"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412090 - patch 2 - Rework the fontconfig-based platform font list implementation to pass the list of available font patterns from chrome to content, instead of letting the content process get it directly from fontconfig. r=lsalzman a=gchang", "files": ["dom/ipc/ContentChild.cpp", "dom/ipc/ContentChild.h", "dom/ipc/ContentParent.cpp", "dom/ipc/ContentParent.h", "dom/ipc/PContent.ipdl", "gfx/thebes/gfxFcPlatformFontList.cpp", "gfx/thebes/gfxFcPlatformFontList.h", "gfx/thebes/gfxMacPlatformFontList.h", "gfx/thebes/gfxMacPlatformFontList.mm", "gfx/thebes/gfxPlatform.h", "gfx/thebes/gfxPlatformFontList.cpp", "gfx/thebes/gfxPlatformFontList.h", "gfx/thebes/gfxPlatformGtk.cpp", "gfx/thebes/gfxPlatformGtk.h", "gfx/thebes/gfxPlatformMac.cpp", "gfx/thebes/gfxPlatformMac.h"], "git_node": null, "git_parents": [null], "node": "a9f13ba650d2121ba8e519779a04e43815df0f7c", "parents": ["bfe05205f198cf7e4aac88e515725ee3fc394023"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412090 - patch 2.1 - Work around FcNameParse bug in fontconfig versions around 2.11.0, by escaping any leading space in the encoded charset element. r=lsalzman a=gchang", "files": ["gfx/thebes/gfxFcPlatformFontList.cpp"], "git_node": null, "git_parents": [null], "node": "a298f27945aafc8282c103c90916d4c7ca57c82f", "parents": ["a9f13ba650d2121ba8e519779a04e43815df0f7c"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412090 - patch 3 - Check the sandbox policy to verify font files will be readable by the content process before including them in the system font list. r=gps a=gchang", "files": ["gfx/thebes/gfxFcPlatformFontList.cpp", "gfx/thebes/gfxFcPlatformFontList.h"], "git_node": null, "git_parents": [null], "node": "5edf5a792dc37f502452fc103fbdf490b7b6874b", "parents": ["a298f27945aafc8282c103c90916d4c7ca57c82f"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412090 - patch 4 - Also adopt the ContentParent::NotifyUpdatedFonts method on macOS, so that only the parent process needs to register with CFNotificationCenter for font-changed notifications. r=lsalzman a=gchang", "files": ["gfx/thebes/gfxMacPlatformFontList.mm"], "git_node": null, "git_parents": [null], "node": "5758facf358ba61b7bebb63d9b8e873f30f33124", "parents": ["5edf5a792dc37f502452fc103fbdf490b7b6874b"], "tags": []}], "date": 1511359137, "git_changesets": [null, null, null, null, null], "user": "apavel@mozilla.com"}, "8200": {"changesets": [{"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Bug 1416448 - Don't update the ASR during merging for an empty container item, since we can't compute the ASR of the contents: fix merge conflict. r=bustage-fix a=bustage-fix on a CLOSED TREE", "files": ["layout/painting/RetainedDisplayListBuilder.cpp"], "git_node": null, "git_parents": [null], "node": "cdaf608ce668a2fc22df983f9db74dbade65e826", "parents": ["5758facf358ba61b7bebb63d9b8e873f30f33124"], "tags": []}], "date": 1511360992, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "8201": {"changesets": [{"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changesets cdaf608ce668 and 001b6191ff91 (bug 1416448) for build bustage. r=backout a=backout on a CLOSED TREE", "files": ["layout/painting/RetainedDisplayListBuilder.cpp", "layout/painting/RetainedDisplayListBuilder.h"], "git_node": null, "git_parents": [null], "node": "bab083518607c3e22a09a8befc6a1199748e31a4", "parents": ["cdaf608ce668a2fc22df983f9db74dbade65e826"], "tags": []}], "date": 1511367299, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "8202": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nast -\u003e 593527ffa6d4\nfi -\u003e 8e7d6225f3b4\nid -\u003e a3bf6ed07225\nis -\u003e cded4caf1852\nka -\u003e 0ee65c3ad6c6\nml -\u003e 861756783858\nne-NP -\u003e d07d9aa26c8c\noc -\u003e d879a08887c1\npt-BR -\u003e 7b818dc93e65\npt-PT -\u003e 63a9d0b5244a\nsq -\u003e d271c48622ec\ntrs -\u003e eef81cc0b272\nvi -\u003e cd9f8719e37b\nzh-CN -\u003e 1850efb554e6", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "f5b01d72d7c8c3662de269e54850dec3867ba4fe", "parents": ["bab083518607c3e22a09a8befc6a1199748e31a4"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nast -\u003e 07539f339719\nfi -\u003e 8e7d6225f3b4\nhr -\u003e b5c663cfab6e\nid -\u003e a3bf6ed07225\nis -\u003e 3a0d9d474dd5\nit -\u003e 62a5ce2d9dd3\nka -\u003e 0ee65c3ad6c6\nkm -\u003e 21dcf412d6d8\nml -\u003e 861756783858\nne-NP -\u003e d07d9aa26c8c\npt-BR -\u003e 7b818dc93e65\npt-PT -\u003e b261c3b27495\nsq -\u003e df2a22e066ac\nta -\u003e ee19364a4ac4\ntr -\u003e 1aceb0fa25df\nzh-CN -\u003e 1850efb554e6", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "73e6110048c494a82868859334a332eff364835a", "parents": ["f5b01d72d7c8c3662de269e54850dec3867ba4fe"], "tags": []}], "date": 1511374881, "git_changesets": [null, null], "user": "ffxbld"}, "8203": {"changesets": [{"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1418227 - TcpTransport.sock should not be used by consumers. r=automatedtester, a=test-only\n\nThe socket is managed by TcpTransport and as such the\nlatter should be used to retrieve the socket timeout.\n\nMozReview-Commit-ID: EzXCwDtfGvR", "files": ["testing/web-platform/tests/tools/wptrunner/wptrunner/executors/executormarionette.py"], "git_node": null, "git_parents": [null], "node": "c0da1f29b298e22178bcf71405f17528a5afe2fb", "parents": ["73e6110048c494a82868859334a332eff364835a"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1418227 - Indicate that sock instance is private. r=automatedtester, a=test-only\n\nThe sock instance in TcpTransport should not be modified by code\noutside of the class. As such indicate it least as private.\n\nMozReview-Commit-ID: FGgZHYj7EdV", "files": ["testing/marionette/client/marionette_driver/transport.py"], "git_node": null, "git_parents": [null], "node": "4eb0dd155ef28ef6a3b55d91cfa175d0ae919b03", "parents": ["c0da1f29b298e22178bcf71405f17528a5afe2fb"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1418227 - Socket timeout is lost in TcpTransport.connect(). r=automatedtester, a=test-only\n\nThe socket_timeout getter should not return the timeout directly\nfrom the socket instance, because right after socket.socket() it\nis set to \"None\" internally, which will cause the original value\nas requested by Marionette to be lost.\n\nMozReview-Commit-ID: DkmvvJ4bDF9", "files": ["testing/marionette/client/marionette_driver/transport.py", "testing/marionette/harness/marionette_harness/tests/unit/test_marionette.py"], "git_node": null, "git_parents": [null], "node": "bf5501f121c806a37fcf6fd503074f02ab0c8380", "parents": ["4eb0dd155ef28ef6a3b55d91cfa175d0ae919b03"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1378524 - Fix \"TypeError: tab is null\" exception raised from browser_inspector_extension_sidebar.js when running on beta. r=pbro, a=test-only\n\nMozReview-Commit-ID: DZPA07695VS", "files": ["devtools/client/inspector/test/head.js"], "git_node": null, "git_parents": [null], "node": "eb4996243c5e9a10346995acc3ce982b9158bbe5", "parents": ["bf5501f121c806a37fcf6fd503074f02ab0c8380"], "tags": []}, {"author": "Gabriele Svelto \u003cgsvelto@mozilla.com\u003e", "branch": "default", "desc": "Bug 1416028 - Prevent browser_pluginCrashedCommentAndURL.js from leaking crash dump files. r=mconley, a=test-only\n\nThis patch also checks for I/O errors when deleting leftover crashdump files\nin the test harness and reports them if the files couldn't be deleted. This\nwon't prevent tests from leaking crash dumps if they're not written correctly,\nbut it will make their presence visible and won't cause the harness to hang if\nit cannot delete them.\n\nMozReview-Commit-ID: FLvBJxEKkH5", "files": ["browser/base/content/test/plugins/browser_pluginCrashCommentAndURL.js", "testing/mochitest/browser-test.js"], "git_node": null, "git_parents": [null], "node": "b1aa00643e62f7d96a0d22415637d6dd96b0dc43", "parents": ["eb4996243c5e9a10346995acc3ce982b9158bbe5"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1416448 - Don't update the ASR during merging for an empty container item, since we can't compute the ASR of the contents. r=miko", "files": ["layout/painting/RetainedDisplayListBuilder.cpp", "layout/painting/RetainedDisplayListBuilder.h"], "git_node": null, "git_parents": [null], "node": "a41f982ed3a7e8995031fa2cd15d2ab7380a4010", "parents": ["b1aa00643e62f7d96a0d22415637d6dd96b0dc43"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1417442 - P1. Don't attempt to initialize MediaPrefs in the GPU process. r=dvander, a=sledru\n\nMozReview-Commit-ID: 66766Tx8vgM", "files": ["widget/GfxInfoBase.cpp"], "git_node": null, "git_parents": [null], "node": "799f29114d7465358383e4e6d2e561daf5e1d978", "parents": ["a41f982ed3a7e8995031fa2cd15d2ab7380a4010"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1417442 - P2. Fix nsIGfxInfo in GPU process. r=dvander, a=sledru\n\nMozReview-Commit-ID: FiU8Ygfh86s", "files": ["widget/windows/nsWidgetFactory.cpp"], "git_node": null, "git_parents": [null], "node": "38cedabd74d2977565b93b3c70f2f562db2aa058", "parents": ["799f29114d7465358383e4e6d2e561daf5e1d978"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1417442 - P3. Don't enable nv12 surfaces if we failed to parse the version string. r=mattwoodrow, a=sledru\n\nMozReview-Commit-ID: 1MKtCOO1gcS", "files": ["dom/media/platforms/wmf/DXVA2Manager.cpp"], "git_node": null, "git_parents": [null], "node": "c645b0914f627fd7db210ede85543c93cf25698b", "parents": ["38cedabd74d2977565b93b3c70f2f562db2aa058"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1417442 - P4. Indicate surface type in decoder description. r=mattwoodrow, a=sledru\n\nMozReview-Commit-ID: 3RXdPMfr7O", "files": ["dom/media/platforms/wmf/WMFVideoMFTManager.cpp"], "git_node": null, "git_parents": [null], "node": "e93cdfd48553bdff890cc1bbd27df7fbce123094", "parents": ["c645b0914f627fd7db210ede85543c93cf25698b"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1417010 - Invalidate MathML display items whenever we invalidate the referenced nsMathMLChar. r=miko, a=sledru", "files": ["layout/mathml/nsMathMLmencloseFrame.cpp", "layout/mathml/nsMathMLmfencedFrame.cpp"], "git_node": null, "git_parents": [null], "node": "b5b9ca5f99b999a53215356e1f3d4b42f7f76557", "parents": ["e93cdfd48553bdff890cc1bbd27df7fbce123094"], "tags": []}, {"author": "Mats Palmgren \u003cmats@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415541 - No need to destroy frames if Destroy was called on the shell. r=bz, a=gchang\n\nMozReview-Commit-ID: CgiFqeKHF3N", "files": ["dom/xml/nsXMLPrettyPrinter.cpp"], "git_node": null, "git_parents": [null], "node": "d55f73f1c890b02fb033accdcaf285633f93648e", "parents": ["b5b9ca5f99b999a53215356e1f3d4b42f7f76557"], "tags": []}], "date": 1511384702, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8204": {"changesets": [{"author": "tbirdbld", "branch": "THUNDERBIRD580b1_2017112217_RELBRANCH", "desc": "Automated checkin: version bump for thunderbird 58.0b1 release. DONTBUILD CLOSED TREE a=release", "files": [], "git_node": null, "git_parents": [null], "node": "e86b2a1443c7792a6caa4ff2076b8cdc19198db5", "parents": ["267010f9177f84745156c79c5cda48c1f2b6e6d9"], "tags": ["THUNDERBIRD_58_0b1_BUILD2"]}, {"author": "tbirdbld", "branch": "THUNDERBIRD580b1_2017112217_RELBRANCH", "desc": "Added THUNDERBIRD_58_0b1_RELEASE THUNDERBIRD_58_0b1_BUILD2 tag(s) for changeset e86b2a1443c7. DONTBUILD CLOSED TREE a=release", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "3be3d2e8c825111d19fd4c27da8e89402530d874", "parents": ["e86b2a1443c7792a6caa4ff2076b8cdc19198db5"], "tags": []}], "date": 1511390447, "git_changesets": [null, null], "user": "tbirdbld"}, "8205": {"changesets": [{"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418406 - Disable select-disabled-fieldset-1.html and select-disabled-fieldset-2.html on android for perma failures. a=test-only\n\nIt appears that both select-disabled-fieldset-1 and select-disabled-fieldset-2 rely\non some other test being run first: Neither test passes if run alone, and both\ntests fail with the current Android chunk divisions.", "files": ["layout/reftests/css-invalid/select/reftest.list"], "git_node": null, "git_parents": [null], "node": "2817b3785e54fc1585f9f3db71b0217fa2e52ced", "parents": ["d55f73f1c890b02fb033accdcaf285633f93648e"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1339568 - Disable 4 dom/media mochitests on linux/asan also. r=jmaher, a=test-only\n\nWe disabled these tests on linux/debug last week and that seems to effectively\navoid shutdown hangs on those platforms. This expands the scope of the disabling\nto linux/asan, where we still see intermittent hangs.", "files": ["dom/media/tests/mochitest/mochitest.ini"], "git_node": null, "git_parents": [null], "node": "138a90f7297a586dcb5ed124953dd1af7975ea0a", "parents": ["2817b3785e54fc1585f9f3db71b0217fa2e52ced"], "tags": []}, {"author": "Eric Rahm \u003cerahm@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414318 - Turn off |StartWriter| in leak checking builds. r=mccr8, a=NPOTB", "files": ["toolkit/components/terminator/nsTerminator.cpp", "toolkit/components/terminator/tests/xpcshell/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "0570e2cfb32b4ed0c44e35fb5bdf131ff5cc33cc", "parents": ["138a90f7297a586dcb5ed124953dd1af7975ea0a"], "tags": []}, {"author": "Florian Qu\u00e8ze \u003cflorian@queze.net\u003e", "branch": "default", "desc": "Bug 1405670 - Stop importing old search plugins from \u003cprofile\u003e/searchplugins/*.xml when the cache file is missing. r=adw, a=sledru", "files": ["toolkit/components/search/nsSearchService.js"], "git_node": null, "git_parents": [null], "node": "0abc56d5a1b16e8a228ab3ac34af9cbddbcc3a1b", "parents": ["0570e2cfb32b4ed0c44e35fb5bdf131ff5cc33cc"], "tags": []}, {"author": "Florian Qu\u00e8ze \u003cflorian@queze.net\u003e", "branch": "default", "desc": "Bug 1405670 - Stop saving the last modification date of directories we loaded engines from. r=adw, a=sledru", "files": ["toolkit/components/search/nsSearchService.js"], "git_node": null, "git_parents": [null], "node": "fe0befa1aa9d7d3ab29ba389c6e4878db2ca0f53", "parents": ["0abc56d5a1b16e8a228ab3ac34af9cbddbcc3a1b"], "tags": []}, {"author": "Florian Qu\u00e8ze \u003cflorian@queze.net\u003e", "branch": "default", "desc": "Bug 1405670 - Stop importing old search metadata from search-metadata.json. r=adw, a=sledru", "files": ["toolkit/components/search/nsSearchService.js"], "git_node": null, "git_parents": [null], "node": "6ad58e06da8cb83d759e11c16ecbf71f31bea7ca", "parents": ["fe0befa1aa9d7d3ab29ba389c6e4878db2ca0f53"], "tags": []}, {"author": "Florian Qu\u00e8ze \u003cflorian@queze.net\u003e", "branch": "default", "desc": "Bug 1405670 - Remove support for NS_APP_SEARCH_DIR_LIST and NS_APP_SEARCH_DIR from the directory service. r=adw, a=sledru", "files": ["browser/components/dirprovider/DirectoryProvider.cpp", "mobile/android/components/DirectoryProvider.js", "netwerk/base/nsIBrowserSearchService.idl", "xpcom/io/nsAppDirectoryServiceDefs.h", "xpcom/io/nsAppFileLocationProvider.cpp"], "git_node": null, "git_parents": [null], "node": "e4307e3d7f1f5f3b378f8fbc3a6b1458f8ed1f23", "parents": ["6ad58e06da8cb83d759e11c16