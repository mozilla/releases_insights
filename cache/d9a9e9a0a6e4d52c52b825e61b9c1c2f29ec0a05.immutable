locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "4039cd7e4e63c74622f4473426b5a877c530e93c", "parents": ["3d895bebedd22539c66b3a66220b18d1c528ca48"], "tags": []}], "date": 1513844428, "git_changesets": [null, null], "user": "ffxbld"}, "8413": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nzh-CN -\u003e 792b1c554b80", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "8794b3b003c844b52536a8273d63aae63c1f8e8a", "parents": ["4039cd7e4e63c74622f4473426b5a877c530e93c"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nbg -\u003e ff79c3cea82e\ncs -\u003e b86b7e36a8e9\nit -\u003e dbc68350a1cd\nzh-CN -\u003e 792b1c554b80", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "8318b6c7d319ce32674414c2bfdece19b9ced179", "parents": ["8794b3b003c844b52536a8273d63aae63c1f8e8a"], "tags": []}], "date": 1513847995, "git_changesets": [null, null], "user": "ffxbld"}, "8414": {"changesets": [{"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 1409115 - Fix leaks by adding promise window proxy. r=bkelly a=ritu\n\nThe service worker job queue can get stuck sometimes, so we don't want\nthe per-process service worker data structure to hold strong\nreferences to content. Instead, I add a proxy that is only a weak\nreference. The wrinkle is that we need to keep the promise alive as\nlong as the job and the window are otherwise alive. I solve this by\nputting a cycle collected reference to the promise on the window\nitself.", "files": ["dom/base/nsGlobalWindow.cpp", "dom/base/nsGlobalWindow.h", "dom/promise/PromiseWindowProxy.cpp", "dom/promise/PromiseWindowProxy.h", "dom/promise/moz.build", "dom/workers/ServiceWorkerManager.cpp", "dom/workers/ServiceWorkerRegistration.cpp"], "git_node": null, "git_parents": [null], "node": "914ddbe4a5f0d569e4d67798db3a031d582d9c94", "parents": ["8318b6c7d319ce32674414c2bfdece19b9ced179"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1420608. P1 - don't switch off blank decoder when seeking begins. r=gerald a=gchang\n\nWhen looping videos in a background tab, SeekingState::Enter() will switch off\nblank decoder and then DecodingState::Enter() will switch it on again. It is a\nwaste of CPU cycles when the tab never goes to the foreground. The overhread is\neven more significant when looping short files.\n\nWe should resume video decoding only when necessary that is we check in\nDecodingState::Enter() to see if mVideoDecodeSuspended matches mVideoDecodeMode.\n\nBug 1420608. P2 - fix the test timeout. r=alwu\n\nSee comment 50 for the cause. Since file_silentAudioTrack.html calls play() to\nstart playback immediately, it is possible that 'mozentervideosuspend' has been\nfired before check_video_decoding_state() has a chance to register event handlers.\nWe call load() and play() to start playback from the beginning so we won't miss\nany events.\n\nMozReview-Commit-ID: 9sKygfIxEtS", "files": ["dom/media/MediaDecoderStateMachine.cpp", "toolkit/content/tests/browser/browser_resume_bkg_video_on_tab_hover.js"], "git_node": null, "git_parents": [null], "node": "5a2fd74ee373d938c4c15b5a92f470fe813428bf", "parents": ["914ddbe4a5f0d569e4d67798db3a031d582d9c94"], "tags": []}, {"author": "Dylan Roeh \u003cdroeh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1422902 - Handle exceptions from WebAppManifest code rather than crashing. r=snorp a=gchang", "files": ["mobile/android/base/java/org/mozilla/gecko/webapps/WebAppActivity.java", "mobile/android/base/java/org/mozilla/gecko/webapps/WebAppManifest.java"], "git_node": null, "git_parents": [null], "node": "ccbe2255e35a2ec77a9c49ada482cf8193138549", "parents": ["5a2fd74ee373d938c4c15b5a92f470fe813428bf"], "tags": []}], "date": 1513853202, "git_changesets": [null, null, null], "user": "ncsoregi@mozilla.com"}, "8415": {"changesets": [{"author": "Honza Bambas \u003chonzab.moz@firemni.cz\u003e", "branch": "default", "desc": "Bug 1425296 - Don't let RequestContext's load state be reset to 'before-DOMContentLoaded' by any sub-requested document within the load group to prevent long delays of tailed (tracking) requests. r=bz a=jcristau", "files": ["dom/base/nsDocument.cpp"], "git_node": null, "git_parents": [null], "node": "6c4bbf9fb6456322be0a635135f2b8dad6e77ca4", "parents": ["ccbe2255e35a2ec77a9c49ada482cf8193138549"], "tags": []}, {"author": "Nils Ohlmeier [:drno] \u003cdrno@ohlmeier.org\u003e", "branch": "default", "desc": "Bug 1425697: WEBRTC_DATACHANNEL_MAX_MESSAGE_SIZE_REMOTE_DEFAULT++. r=lennart.grahl+594092 a=gchang\n\nMozReview-Commit-ID: 7TWwZ2Z6ZXt", "files": ["netwerk/sctp/datachannel/DataChannelProtocol.h"], "git_node": null, "git_parents": [null], "node": "4aaa982ec14eee08d9fb59dca66aab2153d387c5", "parents": ["6c4bbf9fb6456322be0a635135f2b8dad6e77ca4"], "tags": []}, {"author": "Jeff Gilbert \u003cjgilbert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1426289 - Add test for vertexAttrib4f updates. a=test-only\n MozReview-Commit-ID: E2BqeuyafUg", "files": ["dom/canvas/test/webgl-mochitest/mochitest.ini", "dom/canvas/test/webgl-mochitest/test_vertexattrib4f_update.html", "dom/canvas/test/webgl-mochitest/webgl-util.js"], "git_node": null, "git_parents": [null], "node": "a9eef658495137795554a5a2e14e867a02517bab", "parents": ["4aaa982ec14eee08d9fb59dca66aab2153d387c5"], "tags": []}, {"author": "Jeff Gilbert \u003cjgilbert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1426289 - Cherry-pick angle issue 1155. - r=lenzak a=gchang\n\nANGLE cherry-pick: 9088557fe47e0ce1487b248b60acbc740acd7801\n\n    D3D11: Fix dirty current value updates.\n\n    Fixes a bug where subsequent updates to a \"current value\" (disabled)\n    Vertex Attribute would not trigger the state change to D3D11 such that\n    the updated buffer handle would be applied to D3D11. Also adds a test\n    to cover the problem case.\n\n    This bug was introduced in 2bc947334cad:\n    \"D3D11: Minor optimizations to vertex attribute application.\"\n\n    BUG=chromium:779675\n    BUG=angleproject:1155\n\nMozReview-Commit-ID: CywgVRYwaKL", "files": ["gfx/angle/src/libANGLE/renderer/d3d/d3d11/StateManager11.cpp"], "git_node": null, "git_parents": [null], "node": "f681d554e292cc3ce7b5f22be7c96e7464094211", "parents": ["a9eef658495137795554a5a2e14e867a02517bab"], "tags": []}], "date": 1513854268, "git_changesets": [null, null, null, null], "user": "toros@mozilla.com"}, "8416": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nbg -\u003e a99ab7c23d36\ncy -\u003e d349b13eabed\ngu-IN -\u003e e1e90d6be475\nka -\u003e 303bd676724c\nko -\u003e a3ff6ce6257d\noc -\u003e 4fb15516388e\nuz -\u003e 9c8b6a6bdfdb", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "8ec532859b0af65fd08a185772daaccc76b0d39f", "parents": ["f681d554e292cc3ce7b5f22be7c96e7464094211"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nbg -\u003e 81f8122643f8\ncy -\u003e 96b0715a4881\nfr -\u003e ca7dcbead452\ngu-IN -\u003e e1e90d6be475\nit -\u003e 790f2d25e3a3\nka -\u003e 303bd676724c\nko -\u003e a3ff6ce6257d\nuz -\u003e 9c8b6a6bdfdb\nzh-CN -\u003e 8290eab0ea5c", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "9f1419ed50d72f028d88b2a2da2cb8e507f2dea0", "parents": ["8ec532859b0