 null, "git_parents": [null], "node": "371962185c20a1215281f0b129403990143584ed", "parents": ["257f99d6b09d6d9e3669c9472df3b4838fb906e7"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset f8eae610782a (bug 1414067) for Android build bustage at media/libstagefright/system/core/include/cutils/properties.h:61: use of undeclared identifier 'PROP_VALUE_MAX'. r=backout on a CLOSED TREE", "files": ["js/src/old-configure.in", "old-configure.in"], "git_node": null, "git_parents": [null], "node": "daca25aef92c34ceea45e67b0e26d37c1c74e7df", "parents": ["371962185c20a1215281f0b129403990143584ed"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out 1 changesets (bug 1413491) for eslint failure at browser/extensions/formautofill/test/unit/test_addressRecords.js:532: Missing semicolon. r=backout on a CLOSED TREE\n\nBacked out changeset 172216504d78 (bug 1413491)", "files": ["browser/extensions/formautofill/FormAutofillParent.jsm", "browser/extensions/formautofill/ProfileStorage.jsm", "browser/extensions/formautofill/test/mochitest/test_on_address_submission.html", "browser/extensions/formautofill/test/unit/test_addressRecords.js"], "git_node": null, "git_parents": [null], "node": "0214367ea60e3c11059b405a44ccedae59fc3aa1", "parents": ["daca25aef92c34ceea45e67b0e26d37c1c74e7df"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset bedc52fb5267 (bug 1414252) for failing browser-chrome's browser/base/content/test/performance/browser_windowopen_reflows.js, at least on OS X. r=backout on a CLOSED TREE", "files": ["browser/base/content/tabbrowser.xml"], "git_node": null, "git_parents": [null], "node": "194be9a406b301bf8f32761256aa88b8ba660f84", "parents": ["0214367ea60e3c11059b405a44ccedae59fc3aa1"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 4e49de4bbc6f (bug 1411640) for failing browser-chrome's browser/base/content/test/static/browser_all_files_referenced.js, at least on Windows. r=backout on a CLOSED TREE", "files": ["browser/themes/shared/customizableui/panelUI.inc.css", "toolkit/themes/linux/global/global.css", "toolkit/themes/linux/global/in-content/common.css", "toolkit/themes/linux/global/radio.css", "toolkit/themes/osx/global/radio.css", "toolkit/themes/shared/in-content/common.inc.css", "toolkit/themes/shared/non-mac.jar.inc.mn", "toolkit/themes/windows/global/checkbox.css", "toolkit/themes/windows/global/global.css", "toolkit/themes/windows/global/globalBindings.xml", "toolkit/themes/windows/global/in-content/common.css", "toolkit/themes/windows/global/radio.css", "toolkit/themes/windows/global/radio/radio-check-dis.gif", "toolkit/themes/windows/global/radio/radio-check.gif"], "git_node": null, "git_parents": [null], "node": "4dc4eae45e0a8c6562692a8509b512a8b6a088cb", "parents": ["194be9a406b301bf8f32761256aa88b8ba660f84"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "No bug - Update num_cpus to try to fix bustage. r=me\n\nOn a CLOSED TREE\n\nMozReview-Commit-ID: KxCbwtGxZnO\n", "files": ["js/src/Cargo.lock", "third_party/rust/num_cpus-1.6.2/.appveyor.yml", "third_party/rust/num_cpus-1.6.2/.cargo-checksum.json", "third_party/rust/num_cpus-1.6.2/.travis.yml", "third_party/rust/num_cpus-1.6.2/Cargo.toml", "third_party/rust/num_cpus-1.6.2/LICENSE-APACHE", "third_party/rust/num_cpus-1.6.2/LICENSE-MIT", "third_party/rust/num_cpus-1.6.2/README.md", "third_party/rust/num_cpus-1.6.2/src/lib.rs", "toolkit/library/gtest/rust/Cargo.lock", "toolkit/library/rust/Cargo.lock"], "git_node": null, "git_parents": [null], "node": "0fd6f8ab2c89fe5766e1b4339a675f14037f41e6", "parents": ["4dc4eae45e0a8c6562692a8509b512a8b6a088cb"], "tags": []}, {"author": "Gabriele Svelto \u003cgsvelto@mozilla.com\u003e", "branch": "default", "desc": "Bug 1408806 - Gracefully deal with errors when killing the minidump-analyzer on shutdown; r=mconley\n\nThis solves two problems that were causing tests to fail intermittently. The\nfirst issue is that calling nsIProcess.kill() on a process that had already\nterminated would throw an exception which wouldn't be caught. Since this might\nhappen in cases where the minidump-analyzer run significantly faster than the\nmain event loop during the test. The second issue is that we tried to\nunconditionally escape both the 'TelemetryEnvironment' and 'StackTraces'\nfield, but the latter would not be present in cases where the\nminidump-analyzer would fail or be killed. This led to another spurious\nexception.\n\nMozReview-Commit-ID: 7srQtzig7xw", "files": ["toolkit/components/crashes/CrashService.js"], "git_node": null, "git_parents": [null], "node": "cbac4c5957cd88538d46a7cc0248c68149b83e5d", "parents": ["4d3dc7f1d15d2794494bdb801551cd111b4c7fa3"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1119777 - Remove non-standard Function.prototype.isGenerator. r=arai,kmag", "files": ["js/src/jsfun.cpp", "js/src/tests/js1_8_5/extensions/is-generator.js", "js/xpconnect/tests/chrome/test_xrayToJS.xul", "toolkit/modules/DeferredTask.jsm"], "git_node": null, "git_parents": [null], "node": "a19aef803cdb0797029d2440b9320e9b22efc195", "parents": ["cbac4c5957cd88538d46a7cc0248c68149b83e5d"], "tags": []}, {"author": "David Major \u003cdmajor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412952 - Loosen clang's MSVC detection to accept our automation's fake paths. r=froydnj\n\nIn a proper VS install, the path to cl.exe looks like:\n...\\VC\\Tools\\MSVC\\14.11.25503\\bin\\HostX64\\x64\\cl.exe\n\nIn our automation, the path is just:\n...\\VC\\bin\\HostX64\\x64\\cl.exe\n\nClang tries to do some sanity-checking to make sure that the cl.exe it finds is the Microsoft compiler and not some other program. But the checks are a little too strict for us, so just look for \"bin\\Host*\\*\\cl.exe\".", "files": ["build/build-clang/clang-win32.json", "build/build-clang/clang-win64.json", "build/build-clang/loosen-msvc-detection.patch"], "git_node": null, "git_parents": [null], "node": "fb2b705b77cbf2d0b4607e262100bc3b7c1ee6d4", "parents": ["a19aef803cdb0797029d2440b9320e9b22efc195"], "tags": []}, {"author": "David Major \u003cdmajor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412952: We want a HostX64 linker even with 32-bit clang-cl.exe. r=froydnj\n\n32-bit clang-cl.exe was looking specifically for HostX86\\x86\\link.exe, which doesn't exist in our automation package. Make it look in HostX64\\x86 instead.\n\nThis is an ugly hack and it would be preferable to just use a 64-bit compiler (bug 1414287).", "files": ["build/build-clang/clang-win32.json", "build/build-clang/msvc-host-x64.patch"], "git_node": null, "git_parents": [null], "node": "ffb00b457b92b610b8aee77c79f00a5572b255d2", "parents": ["fb2b705b77cbf2d0b4607e262100bc3b7c1ee6d4"], "tags": []}, {"author": "David Major \u003cdmajor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412952 - Use VS2017 with clang-cl builds. r=froydnj", "files": ["browser/config/mozconfigs/win32/clang", "browser/config/mozconfigs/win32/clang-debug", "browser/config/mozconfigs/win32/debug-static-analysis", "browser/config/mozconfigs/win64/clang", "browser/config/mozconfigs/win64/clang-debug", "browser/config/mozconfigs/win64/debug-asan", "browser/config/mozconfigs/win64/nightly-asan", "build/moz.configure/toolchain.configure", "python/mozbuild/mozbuild/test/configure/test_toolchain_configure.py", "taskcluster/ci/build/windows.yml", "taskcluster/ci/static-analysis/kind.yml"], "git_node": null, "git_parents": [null], "node": "bcb92693eac8e4b6590e03b557bd5797848d95bb", "parents": ["ffb00b457b92b610b8aee77c79f00a5572b255d2"], "tags": []}, {"author": "David Major \u003cdmajor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412952 - Build clang-cl itself with VS2017. r=froydnj", "files": ["browser/config/tooltool-manifests/win32/build-clang-cl.manifest", "build/build-clang/build-clang.py", "taskcluster/scripts/misc/build-clang-windows-helper32.sh", "taskcluster/scripts/misc/build-clang-windows-helper64.sh"], "git_node": null, "git_parents": [null], "node": "dbcddce04a807ca68426691bfaaee642058506d0", "parents": ["bcb92693eac8e4b6590e03b557bd5797848d95bb"], "tags": []}, {"author": "Jim Mathies \u003cjmathies@mozilla.com\u003e", "branch": "default", "desc": "Bug 1413599 - Backed out changeset 5b1cc7fdfa40", "files": ["accessible/windows/msaa/Compatibility.cpp"], "git_node": null, "git_parents": [null], "node": "d2d9c80e36843979a5c03211dc90f1a5b3e28455", "parents": ["dbcddce04a807ca68426691bfaaee642058506d0"], "tags": []}, {"author": "Jim Mathies \u003cjmathies@mozilla.com\u003e", "branch": "default", "desc": "Bug 1413599 - Update the 'switch to ESR' prompt minimum version check to include JAWS versions 18 and lower. r=davidb\n\nMozReview-Commit-ID: EuA8pKE2KIe", "files": ["accessible/windows/msaa/Compatibility.cpp"], "git_node": null, "git_parents": [null], "node": "24f4d2216af90f509e8e490f811031d8fe52653a", "parents": ["d2d9c80e36843979a5c03211dc90f1a5b3e28455"], "tags": []}, {"author": "Marco Castelluccio \u003cmcastelluccio@mozilla.com\u003e", "branch": "default", "desc": "Bug 1413845 - Remove PluginPRLibrary as it is unused. r=jimm", "files": ["dom/plugins/base/PluginPRLibrary.cpp", "dom/plugins/base/PluginPRLibrary.h", "dom/plugins/base/moz.build", "dom/plugins/base/nsNPAPIPlugin.cpp", "dom/plugins/base/nsNPAPIPlugin.h", "dom/plugins/base/nsPluginHost.cpp", "dom/plugins/ipc/PluginModuleChild.cpp"], "git_node": null, "git_parents": [null], "node": "899a407832c09e685748779d288637a24aaae2af", "parents": ["24f4d2216af90f509e8e490f811031d8fe52653a"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "br