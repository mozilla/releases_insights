e376f\nit -\u003e cf6cd990d0a3\nka -\u003e 41bc289a45fb\nlij -\u003e 0ab26fda46bc\nlv -\u003e 9937fbcb6c92\nml -\u003e 059cc10fa016\nms -\u003e 67f697e5ba65\npt-BR -\u003e bd75c070aa1b\npt-PT -\u003e fec0456cb10e\nro -\u003e 01d60add546d\nsl -\u003e 65157a3e4898\nsr -\u003e 81382299f1ef\ntr -\u003e 5bc969239a65\nzh-CN -\u003e 5043fc071aff", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "1870c8271df0f4987489e42133cc87e12711aa65", "parents": ["a3a5b36546f3b5418582b3bd729e1157d9491e60"], "tags": []}], "date": 1512480042, "git_changesets": [null, null], "user": "ffxbld"}, "8314": {"changesets": [{"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411118 - Disable browser_notification_open_settings.js and browser_notification_remove_permission.js on Windows for frequent failures. a=test-only", "files": ["browser/base/content/test/alerts/browser.ini"], "git_node": null, "git_parents": [null], "node": "b7ac6d22d4b86dd336df9f10724612fd1c5dee2f", "parents": ["1870c8271df0f4987489e42133cc87e12711aa65"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1384354 - Remove bogus test /css/compositing-1/mix-blend-mode/mix-blend-mode-transition.html. r=birtles, a=test-only", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/css/compositing-1/mix-blend-mode/mix-blend-mode-transition.html", "testing/web-platform/tests/css/compositing-1/mix-blend-mode/reference/mix-blend-mode-transition-ref.html"], "git_node": null, "git_parents": [null], "node": "40cac44385346e29ce342bc913b9bb6b26d9b558", "parents": ["b7ac6d22d4b86dd336df9f10724612fd1c5dee2f"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1414322 - Refactor keyboard and visibility tests. r=ato, a=test-only\n\nBoth 'test_text.py' and 'test_typing.py' contained nearly duplicated\ntests for send_keys(), which have been removed from test_text.py now.\n\nThe HTML testcase file 'javaScript.html' was used in various tests\nwhereby it's initial purpose was to test keyboard events. As such\nunit tests have been updated to use inline HTML, or another more\ngeneric HTML testcase file. Also parts of the the file related to\nvisibility checks have been moved to 'visibility.html'.\n\nMozReview-Commit-ID: CEWPPGdAffW", "files": ["testing/marionette/harness/marionette_harness/tests/unit/test_crash.py", "testing/marionette/harness/marionette_harness/tests/unit/test_key_actions.py", "testing/marionette/harness/marionette_harness/tests/unit/test_mouse_action.py", "testing/marionette/harness/marionette_harness/tests/unit/test_rendered_element.py", "testing/marionette/harness/marionette_harness/tests/unit/test_switch_frame.py", "testing/marionette/harness/marionette_harness/tests/unit/test_text.py", "testing/marionette/harness/marionette_harness/tests/unit/test_typing.py", "testing/marionette/harness/marionette_harness/tests/unit/test_visibility.py", "testing/marionette/harness/marionette_harness/www/deletingFrame.html", "testing/marionette/harness/marionette_harness/www/javascriptPage.html", "testing/marionette/harness/marionette_harness/www/keyboard.html", "testing/marionette/harness/marionette_harness/www/visibility.html", "testing/marionette/harness/marionette_harness/www/xhtmlTest.html"], "git_node": null, "git_parents": [null], "node": "1ae1021cec72e2f745c936adac114025be2fcc4b", "parents": ["40cac44385346e29ce342bc913b9bb6b26d9b558"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1414322 - Update Marionette accessibility tests for non keyboard-interactable elements. r=yzen, a=test-only\n\nBecause with webdriver interactability checks turned on, accessability\nchecks are done afterward, and like in this case would even never run\ndue to \u003ch1\u003e is not a keyboard-interactability element, which causes an\nElementNotInteractableException.\n\nAs such those obsolete tests can be removed now.\n\nMozReview-Commit-ID: 6pw5TCgMb7l", "files": ["testing/marionette/harness/marionette_harness/tests/unit/test_accessibility.py"], "git_node": null, "git_parents": [null], "node": "9a6aa369b0d6b532a6ad64ca7d80f6566da0e8bd", "parents": ["1ae1021cec72e2f745c936adac114025be2fcc4b"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1414322 - Refactor sendKeysToElement methods. r=ato, a=test-only\n\nEach call to sendKeysToElement should go through the interaction\nmodule, and never by directly calling event.sendKeysToElement. This\nwill make sure that keyboard interactability checks will always be\nperformed, even for chrome scope like alerts or modal dialogs.\n\nMozReview-Commit-ID: GoDKjMsNZsq", "files": ["testing/marionette/driver.js", "testing/marionette/element.js", "testing/marionette/event.js", "testing/marionette/interaction.js", "testing/marionette/listener.js"], "git_node": null, "git_parents": [null], "node": "13dcd46fb2867118359c0dadcf23530139749aa2", "parents": ["9a6aa369b0d6b532a6ad64ca7d80f6566da0e8bd"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1414322 - Use WebDriver conformant interactability checks for sendKeysToElement. r=ato, a=test-only\n\nEnables webdriver spec keyboard interactability tests for 'Element Send Keys'\nby default by re-using the same capability 'moz:webdriverClick' from\n'Element Click'. It can be disabled by turning off this preference.\n\nAlso various webplatform tests for webdriver spec have been added which\ncover both the scroll into view action, and keyboard interactability check.\n\nExisting Marionette unit tests will be run in both modes, until we can\nget rid of the legacy mode.\n\nMozReview-Commit-ID: dFB8sQ6CN5", "files": ["testing/geckodriver/README.md", "testing/marionette/harness/marionette_harness/tests/unit/test_mouse_action.py", "testing/marionette/harness/marionette_harness/tests/unit/test_typing.py", "testing/marionette/harness/marionette_harness/www/double_click.html", "testing/marionette/harness/marionette_harness/www/keyboard.html", "testing/marionette/interaction.js", "testing/marionette/listener.js", "testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/webdriver/OWNERS", "testing/web-platform/tests/webdriver/tests/element_send_keys/__init__.py", "testing/web-platform/tests/webdriver/tests/element_send_keys/interactability.py", "testing/web-platform/tests/webdriver/tests/element_send_keys/scroll_into_view.py", "testing/web-platform/tests/webdriver/tests/support/asserts.py", "testing/web-platform/tests/webdriver/tests/support/fixtures.py"], "git_node": null, "git_parents": [null], "node": "e171f519ec08f9d8063f39331a694b27ff38d58d", "parents": ["13dcd46fb2867118359c0dadcf23530139749aa2"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1422373 - Re-add Firefox UI safebrowsing tests. r=jmaher, a=test-only\n\nMozReview-Commit-ID: 1BitgKPG1JD", "files": ["testing/firefox-ui/tests/functional/manifest.ini"], "git_node": null, "git_parents": [null], "node": "d9f3b75c28f1b0d6f4ac7ea3336acd02eba74061", "parents": ["e171f519ec08f9d8063f39331a694b27ff38d58d"], "tags": []}, {"author": "Armen Zambrano G. \u003carmenzg@mozilla.com\u003e", "branch": "default", "desc": "Bug 1422133 - Generate runnable-jobs.json.gz file as part of the Gecko decision task run. r=dustin, a=test-only\n\nThe runnable jobs API on Treeherder is timing out quite frequently.\nThis is due that it downloads the full-task-graph.json artifact from the Gecko decision task.\n\nThis file has grown to be massive (over 30MB) and that takes too long to fetch. The API times out after 20 seconds.\n\nThe data we need from the artifact is minimal. We can generate a file with just the minimum amount of data needed.\n\nThis code change adds logic to generate a runnable-jobs.json.gz file after the full-task-graph.json artifact is generated.\n\nMozReview-Commit-ID: 9u2H7HbUAcl", "files": ["taskcluster/docs/taskgraph.rst", "taskcluster/taskgraph/decision.py", "taskcluster/taskgraph/test/python.ini", "taskcluster/taskgraph/test/test_util_runnable_jobs.py"], "git_node": null, "git_parents": [null], "node": "60ab7fff591c6e237618468fa1bed5f8aed3d5ea", "parents": ["d9f3b75c28f1b0d6f4ac7ea3336acd02eba74061"], "tags": []}, {"author": "Morris Tseng \u003cmtseng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1419917 - Add nsDisplayTableThemedBackground. r=mattwoodrow, a=gchang\n\nMozReview-Commit-ID: 9IS2ehWvPHg", "files": ["layout/painting/nsDisplayList.cpp", "layout/painting/nsDisplayList.h"], "git_node": null, "git_parents": [null], "node": "91082bb1dc37e14dfc8b69eb4492b55e03042a08", "parents": ["60ab7fff591c6e237618468fa1bed5f8aed3d5ea"], "tags": []}, {"author": "Andreas Farre \u003cfarre@mozilla.com\u003e", "branch": "default", "desc": "Bug 1421009 - Don't schedule idle callback if window is shutting down. r=bkelly, a=gchang", "files": ["dom/base/nsGlobalWindow.cpp"], "git_node": null, "git_parents": [null], "node": "81488b5935facd7e475a86848e8d3d96590ebf7a", "parents": ["91082bb1dc37e14dfc8b69eb4492b55e03042a08"], "tags": []}], "date": 1512482989, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8315": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "Automatic version bump. CLOSED TREE NO BUG a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "64ff6ac12a0da2b79c27446213911680c6dc94be", "parents": ["81488b5935facd7e475a86848e8d3d96590ebf7a"], "tags": []}, {"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging 671706994162518e80a4b9f8125ff8e8c1bc3b1f with FENNEC_58_0b9_BUILD1, FENNEC_58_0b9_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "1c8e1e8481951a4ac521a1940ec6d2b4b70c5905", "parents": ["64ff6ac12a0da2b79c27446213911680c6dc94be"], "tags": []}], "date": 1512489865, "git_changesets": [null, null], "user": "ffxbld"}, "8316": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging 671706994162518e80a4b9f8125ff8e8c1bc3b1f with FIREFOX_58_0b9_BUILD1, FIREFOX_58_0b9_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "4535b4e501b2b48027ad7fe0ff77d1946424a010", "parents": ["1c8e1e8481951a4ac521a1940ec6d2b4b70c5905"], "tags": []}], "date": 1512491513, "git_changesets": [null], "user": "ffxbld"}, "8317": {"changesets": [{"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418448 - Part 1: Accessible HandlerProvider: Clean up DynamicIA2Data correctly. r=aklotz, a=gchang\n\nDynamicIA2Data contains several BSTRs that need to be freed with SysFreeString.\nPreviously, we just did a ZeroMemory without actually freeing them.\nThis cleanup code is placed in a header file so it can be used by AccessibleHandler as well.\n\nMozReview-Commit-ID: 4SWuK9oMRYZ", "files": ["accessible/ipc/win/HandlerProvider.cpp", "accessible/ipc/win/HandlerProvider.h", "accessible/ipc/win/handler/HandlerDataCleanup.h", "accessible/ipc/win/handler/moz.build"], "git_node": null, "git_parents": [null], "node": "273b7318c36eeb7e8428c8b0da5d52189090dc7c", "parents": ["4535b4e501b2b48027ad7fe0ff77d1946424a010"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418448 - Part 2: AccessibleHandler: Clean up DynamicIA2Data. r=aklotz, a=gchang\n\nWe need to clean up the VARIANT and BSTRs in DynamicIA2Data in the handler as well.\nWe do this in two places:\n1. Before reading a new payload (because we need to clean up the existing payload); and\n2. When we're being destroyed.\n\nMozReview-Commit-ID: GvO7csuxtwZ", "files": ["accessible/ipc/win/handler/AccessibleHandler.cpp"], "git_node": null, "git_parents": [null], "node": "27bbc48e99c7b7e510f197bc41641b802a083e43", "parents": ["273b7318c36eeb7e8428c8b0da5d52189090dc7c"], "tags": []}, {"author": "Bob Owen \u003cbobowencode@gmail.com\u003e", "branch": "default", "desc": "Bug 1420171 - Part 1: Only default the print-to file name on Linux if not already set. r=karlt, a=gchang\n\nThis allows the web extension saveAsPDF function to work properly.", "files": ["widget/gtk/nsDeviceContextSpecG.cpp"], "git_node": null, "git_parents": [null], "node": "b7d6ba8ab96b289c83fa29c2194f7afc4afec44d", "parents": ["27bbc48e99c7b7e510f197bc41641b802a083e43"], "tags": []}, {"author": "Bob Owen \u003cbobowencode@gmail.com\u003e", "branch": "default", "desc": "Bug 1420171 - Part 2: Remove some unused members from nsDeviceContextSpecG. r=karlt, a=gchang", "files": ["widget/gtk/nsDeviceContextSpecG.cpp", "widget/gtk/nsDeviceContextSpecG.h"], "git_node": null, "git_parents": [null], "node": "072ce042c1d87ea41caca8940d0f21c26517b980", "parents": ["b7d6ba8ab96b289c83fa29c2194f7afc4afec44d"], "tags": []}, {"author": "Bob Owen \u003cbobowencode@gmail.com\u003e", "branch": "default", "desc": "Bug 1420171 - Part 3: Don't default the settings printer name on Linux when printing to file. r=mconley, a=gchang", "files": ["toolkit/components/printingui/ipc/PrintingParent.cpp"], "git_node": null, "git_parents": [null], "node": "a447794c0dd0d34531ea0d9d16e725becf9c7669", "parents": ["072ce042c1d87ea41caca8940d0f21c26517b980"], "tags": []}, {"author": "Edgar Chen \u003cechen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1421561 - Use IgnoredErrorResult in TextEditRules::WillInsertText(). r=masayuki, a=gchang\n\nMozReview-Commit-ID: 5LV5lVEWKO1", "files": ["editor/libeditor/TextEditRules.cpp"], "git_node": null, "git_parents": [null], "node": "5c9a3a3e55b0c288a7c6d6507c729eaff2d3ac9a", "parents": ["a447794c0dd0d34531ea0d