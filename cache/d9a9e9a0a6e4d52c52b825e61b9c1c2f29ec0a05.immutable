sole.html"], "git_node": null, "git_parents": [null], "node": "772f0ebc6889484d1e17daf9062dffd1a17455e2", "parents": ["61505446ad650508f3a52d9648db8072a3711701"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1413840 - add a link to MDN on each about:devtools feature;r=flod,nchevobbe\n\nMozReview-Commit-ID: J9BXHha9SPe", "files": ["devtools/shim/aboutdevtools/aboutdevtools.css", "devtools/shim/aboutdevtools/aboutdevtools.js", "devtools/shim/aboutdevtools/aboutdevtools.xhtml", "devtools/shim/aboutdevtools/images/feature-responsive-mode.svg", "devtools/shim/aboutdevtools/images/feature-responsive.svg", "devtools/shim/aboutdevtools/images/feature-visual-editing.svg", "devtools/shim/aboutdevtools/images/feature-visualediting.svg", "devtools/shim/jar.mn", "devtools/shim/locales/en-US/aboutdevtools.properties"], "git_node": null, "git_parents": [null], "node": "15232bc444483026196d3b58fd1211ba7b9f6bde", "parents": ["772f0ebc6889484d1e17daf9062dffd1a17455e2"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403829 - Prefer fetching properly sized favicons from pages. r=Mardak\n\nMozReview-Commit-ID: CzMHWzsGuRo", "files": ["browser/base/content/test/favicons/browser.ini", "browser/base/content/test/favicons/browser_preferred_icons.js", "browser/modules/ContentLinkHandler.jsm"], "git_node": null, "git_parents": [null], "node": "fef50221fd78773c1b3cc83e3b81e4339381106f", "parents": ["15232bc444483026196d3b58fd1211ba7b9f6bde"], "tags": []}, {"author": "tigercosmos \u003cb04209032@ntu.edu.tw\u003e", "branch": "default", "desc": "servo: Merge #19115 - fix overflow_y_is_visible() in `element.rs` (from tigercosmos:overflow); r=jdm\n\n\u003c!-- Please describe your changes on the following line: --\u003e\nI think the original logic of `overflow_y_is_visible()` might be wrong.\nSo fix it to the correct logic, and also pass more tests.\n\n---\n\u003c!-- Thank you for contributing to Servo! Please replace each `[ ]` by `[X]` when the step is complete, and replace `__` with appropriate data: --\u003e\n- [X] `./mach build -d` does not report any errors\n- [X] `./mach test-tidy` does not report any errors\n- [ ] These changes fix #__ (github issue number if applicable).\n\n\u003c!-- Either: --\u003e\n- [X] There are tests for these changes OR\n- [ ] These changes do not require tests because _____\n\n\u003c!-- Also, please make sure that \"Allow edits from maintainers\" checkbox is checked, so that we can help you if you get stuck somewhere along the way.--\u003e\n\n\u003c!-- Pull requests that do not address these steps are welcome, but they will require additional verification as part of the review process. --\u003e\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 41a5a8c75faa348ff7301963a7f2f6fab7423750", "files": ["servo/components/script/dom/element.rs"], "git_node": null, "git_parents": [null], "node": "e282251e1b76cb929697fbc389257b372b5a2f04", "parents": ["fef50221fd78773c1b3cc83e3b81e4339381106f"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1400259 - Extend the workaround to cover all popup states and both opacity and transform. r=Gijs\n\nMozReview-Commit-ID: ADRPANKhQy8", "files": ["browser/base/content/browser.css", "toolkit/content/xul.css"], "git_node": null, "git_parents": [null], "node": "80a2fea82e8f627f3ed7d5823e6dd6c91c6ac647", "parents": ["e282251e1b76cb929697fbc389257b372b5a2f04"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1411393 - Marionette should not register listeners on the global window or document. r=ato,smaug\n\nRegistering listeners for the \"beforeunload\" and \"unload\" events currently\nhappens on the global window and document. This actually prevents Firefox\nfrom adding those pages to the bfcache.\n\nThe correct is to add all the listeners to the tabchildglobal, which is\nthe framescript itself. Also by using the capture and not the bubble phase\nthe unload events are correctly propagaded to our registered listeners.\n\nMozReview-Commit-ID: 4hJjuqWsoBP", "files": ["testing/marionette/listener.js"], "git_node": null, "git_parents": [null], "node": "59856e397ead753be46684b9a0498d3214bcdee4", "parents": ["80a2fea82e8f627f3ed7d5823e6dd6c91c6ac647"], "tags": []}, {"author": "steveck-chung \u003cschung@mozilla.com\u003e", "branch": "default", "desc": "Bug 1395123 - Unhide credit cards sync engine by default. r=lchang,markh\n\nMozReview-Commit-ID: 4WzzW327PTe", "files": ["browser/extensions/formautofill/bootstrap.js", "browser/extensions/formautofill/test/browser/browser_creditCard_doorhanger.js"], "git_node": null, "git_parents": [null], "node": "5f3d73530ca852d7425b7779f4559758e3dd77c8", "parents": ["59856e397ead753be46684b9a0498d3214bcdee4"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1413166 - Add gtk-csd atoms to configure rendering to titlebar on Linux/Gtk+, r=bz\n\nBased on patch by Andrew Comminos [:acomminos] \u003candrew@comminos.com\u003e\n\nMozReview-Commit-ID: 8mBFfQwYSKz", "files": ["dom/base/nsGkAtomList.h"], "git_node": null, "git_parents": [null], "node": "ac985ab9e0429690a115583db8ad000b00237cde", "parents": ["5f3d73530ca852d7425b7779f4559758e3dd77c8"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1413166 - Bind gtk_csd* atoms with LookAndFeel, r=bz\n\nBased on patch by Andrew Comminos [:acomminos] \u003candrew@comminos.com\u003e\n\nMozReview-Commit-ID: 91pyS53yTVt", "files": ["layout/style/nsCSSRuleProcessor.cpp"], "git_node": null, "git_parents": [null], "node": "a319c7bef8111ba7a3c3bd6d4203cde633fc6c16", "parents": ["ac985ab9e0429690a115583db8ad000b00237cde"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1413166 - Export gtk_csd* atoms as media features, r=bz\n\nBased on patch by Andrew Comminos [:acomminos] \u003candrew@comminos.com\u003e\n\nMozReview-Commit-ID: 26IV2A3vZAB", "files": ["layout/style/nsMediaFeatures.cpp"], "git_node": null, "git_parents": [null], "node": "7f8a59a04f196be9609f31cb3f00535e721ee666", "parents": ["a319c7bef8111ba7a3c3bd6d4203cde633fc6c16"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1413166 - Added parsing tests for moz-gtk-csd-* media features, r=bz\n\nMozReview-Commit-ID: G0fXDJ2Bjwf", "files": ["layout/style/test/test_media_queries.html"], "git_node": null, "git_parents": [null], "node": "df4b8747adde2fd0fb7a8f625d806c23fb2e073c", "parents": ["7f8a59a04f196be9609f31cb3f00535e721ee666"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1413166 - Added moz-gtk-csd-* media features to resistFingerprinting tests, r=bz\n\nMozReview-Commit-ID: FF1rVDSrpK", "files": ["layout/style/test/chrome/bug418986-2.js"], "git_node": null, "git_parents": [null], "node": "c7dadba6ceee2cbfec50e8b47c6b09d5f3fe4a78", "parents": ["df4b8747adde2fd0fb7a8f625d806c23fb2e073c"], "tags": []}, {"author": "Sylvestre Ledru \u003csledru@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414794 - Unbreak the lld usage by providing the right data structure r=froydnj\n\nMozReview-Commit-ID: 1caPjLBR4vS", "files": ["build/moz.configure/toolchain.configure"], "git_node": null, "git_parents": [null], "node": "d2a961ced3a0e752d729d690ea2519feed3bde22", "parents": ["c7dadba6ceee2cbfec50e8b47c6b09d5f3fe4a78"], "tags": []}, {"author": "Wander Lairson Costa \u003cwcosta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1413502: Use --taskcluster-worker on Windows talos. r=grenade\n\nWith migration of talos machines from buildbot to Taskcluster, we need a\nway to run jobs in Taskcluster without affecting production.\n\nWe accomplish this task by using the same approach we use for Linux:\nwhen we give the --taskcluster-worker flag, decision task switches from\nbuildbot-bridge to Taskcluster Windows work-type.\n\nMozReview-Commit-ID: LU5oaGCZ8uz", "files": ["taskcluster/taskgraph/transforms/tests.py"], "git_node": null, "git_parents": [null], "node": "4140e010e88f897baf09a5d6447ba8d542e4b2bb", "parents": ["d2a961ced3a0e752d729d690ea2519feed3bde22"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1397612 - Backed out changeset 63d97c8b46b2 r=jmaher\n\nThis backs-out the skip patch for:\ntest_quit_restart.py TestQuitRestart.test_in_app_restart_safe_mode\n\nMozReview-Commit-ID: 6lpUOdqoytT", "files": ["testing/marionette/harness/marionette_harness/tests/unit/test_quit_restart.py"], "git_node": null, "git_parents": [null], "node": "1a83be186f453c40b2b1fa1f91da827410d7950e", "parents": ["4140e010e88f897baf09a5d6447ba8d542e4b2bb"], "tags": []}, {"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 1412111 - Add mode lines to NativeOSFileInternals.{h,cpp}. r=Yoric\n\nMozReview-Commit-ID: ETHWPJo8OBF", "files": ["toolkit/components/osfile/NativeOSFileInternals.cpp", "toolkit/components/osfile/NativeOSFileInternals.h"], "git_node": null, "git_parents": [null], "node": "ac96809f0f2448cb2d11711aa8d4daa3ae3a018b", "parents": ["1a83be186f453c40b2b1fa1f91da827410d7950e"], "tags": []}, {"author": "Rand Mustafa \u003crndmustafa@gmail.com\u003e", "branch": "default", "desc": "Bug 1411339 - Configuration for different UI densities. r=jaws,mconley\n\nMozReview-Commit-ID: HDz4USew9YM", "files": ["browser/tools/mozscreenshots/mozscreenshots/extension/configurations/UIDensities.jsm"], "git_node": null, "git_parents": [null], "node": "43aea4af4a2005f96c4b4deb6b1dd5942b91c13a", "parents": ["ac96809f0f2448cb2d11711aa8d4daa3ae3a018b"], "tags": []}, {"author": "grenewode \u003cgrenewodemiller@gmail.com\u003e", "branch": "default", "desc": "Bug 1414053 - Adds the boundary crossing callback to DevTools.jsm.  r=mconley\n\nAlso, once this lands, it should clean up some of the failing tests on Bugs #1403686 and #1412357.\n\nMozReview-Commit-ID: 5rCjjlzuavq", "files": ["browser/tools/mozscreenshots/mozscreenshots/extension/configurations/DevTools.jsm"], "git_node": null, "git_parents": [null], "node": "13763ec9100053bc33afc138cb2bdabafbf299d9", "parents": ["43aea4af4a2005f96c4b4deb6b1dd5942b91c13a"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1414786: Do not match caption's labels with child combinators. r=dao\n\nNested captions are not used, nor nested labels inside captions.\n\nAnother approach would be to just move all our captions that currently use\n\u003ccaption\u003e\u003clabel\u003e to use \u003ccaption label=\"\"\u003e, and get rid of the \u003cxbl:children\u003e\nelement.\n\nLet me know if that's preferred, but seems not necessary to me.\n\nMozReview-Commit-ID: Gx7vB0tio5O", "files": ["browser/themes/linux/preferences/in-content/dialog.css", "browser/themes/linux/preferences/in-content/preferences.css", "browser/themes/osx/preferences/in-content/dialog.css", "browser/themes/osx/preferences/in-content/preferences.css", "browser/themes/windows/preferences/in-content/dialog.css", "browser/themes/windows/preferences/in-content/preferences.css", "toolkit/themes/shared/in-content/common.inc.css"], "git_node": null, "git_parents": [null], "node": "66212b8b4315fafb91f0178c39962a995114b7a7", "parents": ["13763ec9100053bc33afc138cb2bdabafbf299d9"], "tags": []}, {"author": "Chris H-C \u003cchutten@mozilla.com\u003e", "branch": "default", "desc": "bug 1410907 - Add CanRecord(Pre)Release data to nsITTelemetry r=Dexter\n\nWe're starting a shift towards talking about release/prerelease data instead of\nbase/extended collection. For now this is just a naming change.\n\nAt the same time, we can render these attributes read-only, which is nice.\n\nMozReview-Commit-ID: IRuKpzLYW7i", "files": ["toolkit/components/telemetry/Telemetry.cpp", "toolkit/components/telemetry/Telemetry.h", "toolkit/components/telemetry/nsITelemetry.idl", "toolkit/components/telemetry/tests/unit/test_TelemetryController.js"], "git_node": null, "git_parents": [null], "node": "58b0f65614bed267d3297baadf93d2f29f0c3886", "parents": ["66212b8b4315fafb91f0178c39962a995114b7a7"], "tags": []}, {"author": "Chris H-C \u003cchutten@mozilla.com\u003e", "branch": "default", "desc": "bug 1413258 - Collect SSL Telemetry on all channels r=mcmanus\n\nEver since bug 1340021 we were supposed to be collecting *_IS_SSL probes on\nrelease, but the code in nsHttpChannel prevented it from happening.\n\nMozReview-Commit-ID: IdU4Gppos6E", "files": ["netwerk/protocol/http/nsHttpChannel.cpp"], "git_node": null, "git_parents": [null], "node": "0d15cd7ec41f36c03f83871c36a9208b3748a0e2", "parents": ["58b0f65614bed267d3297baadf93d2f29f0c3886"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1413230 - Ensure we are attached to the GL context in SurfaceTextureHostOGL::PrepareTextureSource() r=jnicol,nical\n\nMozReview-Commit-ID: BxDng9OG3RF\n", "files": ["gfx/layers/opengl/TextureHostOGL.cpp", "gfx/layers/opengl/TextureHostOGL.h"], "git_node": null, "git_parents": [null], "node": "f5cc779a5d02be16eecbb93762aa2bb51c005a1b", "parents": ["fdb23b22f19a36f7928806e0f6e78dde216f506f"], "tags": []}, {"author": "ffxbld", "branch": "default", "desc": "No bug, Automated HSTS preload list update from host bld-linux64-spot-030 - a=hsts-update", "files": ["security/manager/ssl/nsSTSPreloadList.errors", "security/manager/ssl/nsSTSPreloadList.inc"], "git_node": null, "git_parents": [null], "node": "43d30acec37e3550aa261220598fbcfe8a6b7e30", "parents": ["2535bad09d720e71a982f3f70dd6925f66ab8ec7"], "tags": []}, {"author": "ffxbld", "branch": "default", "desc": "No bug, Automated HPKP preload list update from host bld-li