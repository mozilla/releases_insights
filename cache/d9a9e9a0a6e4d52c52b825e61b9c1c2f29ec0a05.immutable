0n-changesets.json"], "git_node": null, "git_parents": [null], "node": "4ea9ce3c76c3c592e5a2c89d0457e28ad4f1b27e", "parents": ["8f1c28af46e98fe53bf9057acfebaf6354ccdb7c"], "tags": []}], "date": 1513718410, "git_changesets": [null], "user": "ffxbld"}, "8406": {"changesets": [{"author": "Ciure Andrei \u003caciure@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 873f72d1eeb9 (bug 1423247) for taking a new approach targeting Mozilla59 r=backout a=backout", "files": ["browser/components/nsBrowserGlue.js", "browser/components/tests/browser/browser.ini", "browser/components/tests/browser/browser_urlbar_matchBuckets.js", "testing/modules/TestUtils.jsm", "toolkit/components/places/UnifiedComplete.js"], "git_node": null, "git_parents": [null], "node": "422fb348439770b71d08a87f8f8cf800e404b327", "parents": ["4ea9ce3c76c3c592e5a2c89d0457e28ad4f1b27e"], "tags": []}], "date": 1513724761, "git_changesets": [null], "user": "aciure@mozilla.com"}, "8407": {"changesets": [{"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401551 - Only check for acceleration after the page is shown and we know the layer managers have been initialized. r=dvander a=test-only\n\nMozReview-Commit-ID: CA2gQxMIuXn", "files": ["gfx/tests/mochitest/test_acceleration.html"], "git_node": null, "git_parents": [null], "node": "8e4d288b598bd0c977eb501d37de830b9ec978cc", "parents": ["422fb348439770b71d08a87f8f8cf800e404b327"], "tags": []}], "date": 1513777370, "git_changesets": [null], "user": "ebalazs@mozilla.com"}, "8408": {"changesets": [{"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 1409115 - Fix leaks by adding promise window proxy. r=bkelly a=ritu\n\nThe service worker job queue can get stuck sometimes, so we don't want\nthe per-process service worker data structure to hold strong\nreferences to content. Instead, I add a proxy that is only a weak\nreference. The wrinkle is that we need to keep the promise alive as\nlong as the job and the window are otherwise alive. I solve this by\nputting a cycle collected reference to the promise on the window\nitself.\n\nMozReview-Commit-ID: 4qFaKQYB9mX", "files": ["dom/base/nsGlobalWindow.cpp", "dom/base/nsGlobalWindow.h", "dom/promise/PromiseWindowProxy.cpp", "dom/promise/PromiseWindowProxy.h", "dom/promise/moz.build", "dom/workers/ServiceWorkerManager.cpp", "dom/workers/ServiceWorkerRegistration.cpp"], "git_node": null, "git_parents": [null], "node": "3db9f0dfe9aafcd32fdb9803b685ebb49b39121d", "parents": ["8e4d288b598bd0c977eb501d37de830b9ec978cc"], "tags": []}], "date": 1513779576, "git_changesets": [null], "user": "ccoroiu@mozilla.com"}, "8409": {"changesets": [{"author": "Alex Chronopoulos \u003cachronop@gmail.com\u003e", "branch": "default", "desc": "Bug 1423770. r=padenot, a=jcristau", "files": ["media/webrtc/signaling/src/mediapipeline/MediaPipeline.cpp"], "git_node": null, "git_parents": [null], "node": "c4f1df0162ae7fa631bf8e983967df3904a6e598", "parents": ["3db9f0dfe9aafcd32fdb9803b685ebb49b39121d"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1422928 - Disable browser/base/content/test/alerts/browser_notification_replace.js on windows for frequent failures. r=me, a=testonly", "files": ["browser/base/content/test/alerts/browser.ini"], "git_node": null, "git_parents": [null], "node": "fd15d342e90e7cdebef991521f75e49464d23439", "parents": ["c4f1df0162ae7fa631bf8e983967df3904a6e598"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1154206 - Don't end the test until all the advanceTimeAndRefresh calls are done. r=jrmuizel, a=test-only\n\nMozReview-Commit-ID: 69losfPM6bk", "files": ["layout/generic/test/test_bug784410.html"], "git_node": null, "git_parents": [null], "node": "d1d4524b20e404e275e5afc9eb766daaf4837102", "parents": ["fd15d342e90e7cdebef991521f75e49464d23439"], "tags": []}, {"author": "Shih-Chiang Chien \u003cschien@mozilla.com\u003e", "branch": "default", "desc": "Bug 1404454 - use about:blank as the inital page of the testing iframe. r=dragana, a=test-only\n\nIn our test script we set the unload handler on the inner iframe earlier than the page is loaded, therefore it pass the origin check since the contentWindow object is for about:blank.\nSecurity error will raise if the OnStartRequest for that iframe is received beforehand.\nUse about:blank can guarantee to have same-origin window on the inner iframe.\n\nMozReview-Commit-ID: 8AiwGIfoF4", "files": ["netwerk/test/mochitests/test_1396395.html"], "git_node": null, "git_parents": [null], "node": "c01621ab393389deec9e2c0ce28aac1a0c515712", "parents": ["d1d4524b20e404e275e5afc9eb766daaf4837102"], "tags": []}], "date": 1513780002, "git_changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "8410": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nar -\u003e 802745e14741\nfa -\u003e 00dd93c058a8\nfr -\u003e c76e9ab81494\ngu-IN -\u003e af0d8515e539\nit -\u003e 599ceae7b4f2\nms -\u003e 88ec9816fbda\nro -\u003e 133dcbd81532\nta -\u003e cc17248ab726\nzh-CN -\u003e b29f512a2f86", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "9569191d72474795b4f1f26b8e67e2448e22c1b8", "parents": ["c01621ab393389deec9e2c0ce28aac1a0c515712"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nan -\u003e 975287d8be0d\nar -\u003e 802745e14741\nbg -\u003e 07133348876d\ncy -\u003e db9e6e94db24\nfa -\u003e 00dd93c058a8\nfr -\u003e c76e9ab81494\ngu-IN -\u003e af0d8515e539\nis -\u003e c95003805fe0\nit -\u003e 599ceae7b4f2\nkab -\u003e e29cbd9f0f6d\nms -\u003e 88ec9816fbda\nne-NP 