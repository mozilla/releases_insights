bb684c4109e579ce4c7e9f2c7", "parents": ["6dc619f7460dee9762cb056ddb75cd1a00657a03"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1416142 - Intermittent timeout in browser_ext_omnibox.js. r=standard8, a=test-only\n\nMozReview-Commit-ID: DAZumEpI1xB", "files": ["browser/components/extensions/test/browser/browser_ext_omnibox.js"], "git_node": null, "git_parents": [null], "node": "939de878cd753f107bf4fbc25bb9fd6e5e46e488", "parents": ["9cf204dbec09f98bb684c4109e579ce4c7e9f2c7"], "tags": []}, {"author": "Samael Wang \u003cfreesamael@gmail.com\u003e", "branch": "default", "desc": "Bug 1362410 - Make the setTimeout run on the same target as HistoryTracker. r=smaug, a=test-only\n\nMozReview-Commit-ID: KvcFxG7RMNZ", "files": ["docshell/test/browser/browser_bug1347823.js"], "git_node": null, "git_parents": [null], "node": "3f9baaa05d42528e6d8afaf681bbe5782709706b", "parents": ["939de878cd753f107bf4fbc25bb9fd6e5e46e488"], "tags": []}, {"author": "Kit Cambridge \u003ckit@yakshaving.ninja\u003e", "branch": "default", "desc": "Bug 1414153 - Sync the `privacy.resistFingerprinting` pref by default. r=eoger, a=gchang\n\nMozReview-Commit-ID: 7f9dM7Rqiyi", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "298f965dbf54098415e7c7370996367909e3994e", "parents": ["3f9baaa05d42528e6d8afaf681bbe5782709706b"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1421295 - Always use process log to find children. r=jmaher, a=test-only\n\nWhen psutil is available, use it, but also add any processes found in the\nprocess log to the list of children. Hopefully this will ensure that all\nbrowser children are successfully killed.", "files": ["testing/mochitest/runtests.py"], "git_node": null, "git_parents": [null], "node": "fb9ff0d537b9f1106ef6269bb1becc160d106e77", "parents": ["298f965dbf54098415e7c7370996367909e3994e"], "tags": []}], "dat