Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nach -\u003e 90f8148e1515\nan -\u003e bcc202aa4b7b\nast -\u003e 286babd89a72\naz -\u003e 221893df3379\nbe -\u003e 79ad5fa30f94\nbr -\u003e 28ff6f403f17\nml -\u003e b57612790fb1", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "88c7c9af8b62d8deed31ab07b64e1f68e01d2f0a", "parents": ["33571dad2907b6074c5edffc70b6ce9ed2ab7478"], "tags": []}], "date": 1511619838, "git_changesets": [null, null], "user": "ffxbld"}, "8226": {"changesets": [{"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1409113 - Add nsIPresShell::HasHandledUserInput() r=masayuki a=Sylvestre\n\nMozReview-Commit-ID: 3Yr5UmFJx5h", "files": ["layout/base/PresShell.cpp", "layout/base/PresShell.h", "layout/base/nsIPresShell.h", "widget/BasicEvents.h", "widget/WidgetEventImpl.cpp"], "git_node": null, "git_parents": [null], "node": "60ef3560d15ae3f7b8efa5833a14c5f12f6f56e6", "parents": ["88c7c9af8b62d8deed31ab07b64e1f68e01d2f0a"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1409113 - Add nsIPresShell::HasHandledUserInput() status to InputContext r=masayuki a=Sylvestre\n\nMozReview-Commit-ID: 60x35NKEzhA", "files": ["dom/events/IMEStateManager.cpp", "widget/IMEData.h"], "git_node": null, "git_parents": [null], "node": "c97b0b34d8cc61d33138ee8b9ad73c5c2c21fea2", "parents": ["60ef3560d15ae3f7b8efa5833a14c5f12f6f56e6"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1409113 - Relax the user input requirement in order to show VKB on Android r=jchen a=Sylvestre\n\nMozReview-Commit-ID: 4lvuGFyWj76", "files": ["widget/android/GeckoEditableSupport.cpp"], "git_node": null, "git_parents": [null], "node": "d0eadbf8ab5bda4be4aecdbb08df007e138760c1", "parents": ["c97b0b34d8cc61d33138ee8b9ad73c5c2c21fea2"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1384956 - Get log level from main process when script is reloaded. r=whimboo a=test-only\n\nThis is a workaround for https://bugzil.la/1411513 about Log.jsm\nnot being compatible with E10s.  It queries the log level via\nsynchronous IPC message to the main process.\n\nMozReview-Commit-ID: 5RZluH8Rv9o", "files": ["testing/marionette/driver.js", "testing/marionette/frame.js", "testing/marionette/listener.js"], "git_node": null, "git_parents": [null], "node": "20b45a6b07c3284145fcb7dd9d1b62e2354ce990", "parents": ["d0eadbf8ab5bda4be4aecdbb08df007e138760c1"], "tags": []}], "date": 1511620253, "git_changesets": [null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "8227": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nast -\u003e 0d036338252a", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "6ab6ed6d16644add877596b4697a92180818f01f", "parents": ["20b45a6b07c3284145fcb7dd9d1b62e2354ce990"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nast -\u003e 23c4fddb353c\ncy -\u003e a30d441ee1b7\nml -\u003e 5592daf57295", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "fa6ed66e8a4f82cbf3f58385ebf38f8e414dd356", "parents": ["6ab6ed6d16644add877596b4697a92180818f01f"], "tags": []}], "date": 1511623350, "git_changesets": [null, null], "user": "ffxbld"}, "8228": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nast -\u003e 185d5f046734\nro -\u003e 30eecb6a53a0", "files": ["mobile/locales/l10n-c