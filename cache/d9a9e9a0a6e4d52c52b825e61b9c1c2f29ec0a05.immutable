der to release AbortSignal on the correct thread, r=bkelly a=gchang", "files": ["dom/fetch/Fetch.cpp"], "git_node": null, "git_parents": [null], "node": "3f1ae6d1d01d9e5baa7d89aeb31b9a2ead92008b", "parents": ["f47b24dad3907240e9ffcc6298b173820ae2f41f"], "tags": []}], "date": 1515419767, "git_changesets": [null, null], "user": "archaeopteryx@coole-files.de"}, "8496": {"changesets": [{"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 1bf31fdbfa8e (bug 1409449) for failing xpcshell's netwerk/test/unit/test_auth_proxy.js and toolkit/components/extensions/test/xpcshell/test_ext_proxy_auth.js. r=backout a=backout", "files": ["modules/libpref/init/all.js", "netwerk/protocol/http/nsHttpChannelAuthProvider.cpp", "netwerk/protocol/http/nsHttpChannelAuthProvider.h", "toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "60e4ebb5f15082a790d840a4dc51514252ce3fab", "parents": ["3f1ae6d1d01d9e5baa7d89aeb31b9a2ead92008b"], "tags": ["DEVEDITION_58_0b15_RELEASE", "FENNEC_58_0b15_BUILD1", "FENNEC_58_0b15_RELEASE", "FIREFOX_58_0b15_BUILD1", "FIREFOX_58_0b15_RELEASE"]}], "date": 1515420398, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "8497": {"changesets": [{"author": "Jamie Nicol \u003cjnicol@mozilla.com\u003e", "branch": "default", "desc": "Bug 1417310 - Don't attempt to create buffers of unreasonable sizes. r=bas, a=gchang\n\nCurrently ContentClient will attempt to create a buffer of any size\nthat Layers requires it to. If that fails it will then warn if the\nrequested buffer was an unreasonable size. This change makes it so\nthat we check whether the size is reasonable first, and do not attempt\nto create the buffer if it is unreasonable.\n\nPreviously the operating system would have managed to allocate some\nbuffers that we deem unreasonable, but at the cost of the system\nbecoming unresponsive. Now, some large buffers which would previously\nhave been created won't be, but the chances of the system becoming\nunresponsive should decrease.\n\nIdeally Layers wouldn't request buffers of these sizes in the first\nplace - there are measures in place to try to prevent it, and more work\nis certainly required. However, this will act as a last ditch defence.\n\nMozReview-Commit-ID: 7WCqEwkmViy", "files": ["gfx/layers/client/ContentClient.cpp"], "git_node": null, "git_parents": [null], "node": "31e1979f16c1778e257c4973ab7c7548cc7a6c5f", "parents": ["60e4ebb5f15082a790d840a4dc51514252ce3fab"], "tags": []}], "date": 1515420522, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "8498": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nbe -\u003e 53f879363443\nbg -\u003e d74448447ec4\nel -\u003e cc54eee61f6b\nfi -\u003e 08189233f70a\nid -\u003e b782e4d9b6a6", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "109c77b8bf0b9045c83889080cf87ae4bb31cd01", "parents": ["31e1979f16c1778e257c4973ab7c7548cc7a6c5f"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nbe -\u003e 18548e3b4c7d\nbg -\u003e d74448447ec4\nbn-BD -\u003e 3775531f087a\nfi -\u003e 85224ec9f9d6\nfy-NL -\u003e 9bf0802a31d8\nid -\u003e b782e4d9b6a6\npa-IN -\u003e 5634ac6e7d9b\nta -\u003e 26d7cbe37e4a\ntr -\u003e 860f0ea58677", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "c29eecb1695cf3fd8ef30782c89feb40c1c3da6f", "parents": ["109c77b8bf0b9045c83889080cf87ae4bb31cd01"], "tags": []}], "date": 1515421248, "git_changesets": [null, null], "user": "ffxbld"}, "8499": {"changesets": [{"author": "Dragana Damjanovic \u003cdd.mozilla@gmail.com\u003e", "branch": "default", "desc": 