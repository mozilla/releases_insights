s-AR -\u003e 3a197d57ec4c\nhi-IN -\u003e e1dddb32c7d0\nkn -\u003e 9d356f38d208\nmr -\u003e 074d705e44b7\nms -\u003e 58d9543d90aa\nor -\u003e 9420e75f84ba\npa-IN -\u003e b714262f5820\nro -\u003e c432d188a1c6\nth -\u003e aa91b43781fe", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "6cfa4831d73b98f78a81e5540f5cef09a818b70a", "parents": ["5e95701e0802b2f1829f2284f2ee67c1ecdac116"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nhi-IN -\u003e e1dddb32c7d0\nkn -\u003e 9d356f38d208\nmr -\u003e 074d705e44b7\nms -\u003e 58d9543d90aa\nor -\u003e 9420e75f84ba\npa-IN -\u003e b714262f5820\nro -\u003e ce4a00c06847\nsi -\u003e 5b5533ef2e97\nte -\u003e d30aefb49f2f\nth -\u003e aa91b43781fe\nzh-CN -\u003e 9ab59b4c446a", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "91436d1debb0816d76fb05924c4c4077023763f8", "parents": ["6cfa4831d73b98f78a81e5540f5cef09a818b70a"], "tags": []}], "date": 1515403260, "git_changesets": [null, null], "user": "ffxbld"}, "8489": {"changesets": [{"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1428728 - Snap: Fix media playback, webgl and printing r=sfraser a=release\n\nMozReview-Commit-ID: G31Iq6NjXN4", "files": ["taskcluster/docker/firefox-snap/snapcraft.yaml.in"], "git_node": null, "git_parents": [null], "node": "a0c1f3a8bdb40853e598c602fbf73c56f8a92d6a", "parents": ["91436d1debb0816d76fb05924c4c4077023763f8"], "tags": []}], "date": 1515405336, "git_changesets": [null], "user": "jlorenzo@mozilla.com"}, "8490": {"changesets": [{"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1352133 - Handle selected tab not yet existing when exiting BrowserSearch. r=nechen a=gchang\n\nEarly during startup there might not be a selected tab yet, so we can't use its\ndata to decide which home panel to show again.\n\nFortunately showHomePager can be called with a null panelId, in which case it\nwill eventually simply fall back to using the default home panel from our\nsettings.\n\nMozReview-Commit-ID: GbmozJeYZVb", "files": ["mobile/android/base/java/org/mozilla/gecko/BrowserApp.java"], "git_node": null, "git_parents": [null], "node": "ac3cd70b8967b4917b4c51ca9b6d71ad727b6942", "parents": ["a0c1f3a8bdb40853e598c602fbf73c56f8a92d6a"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1414309 - Tell ToolbarEditLayout's title background about private mode changes. r=nechen a=gchang\n\nThe background is enabled when using a theme to increase readability of the URL,\nbut disabled in private mode, because we don't show the theme while in private\nmode.\n\nHowever for the latter feature to work, the respective layout needs to be told\nabout the private mode state of the toolbar in the first place. We did this\nfor the ToolbarDisplayLayout, but had forgotten the ToolbarEditLayout.\n\nMozReview-Commit-ID: 3GAesHvwDEX", "files": ["mobile/android/base/java/org/mozilla/gecko/toolbar/ToolbarEditLayout.java"], "git_node": null, "git_parents": [null], "node": "46fabe0cc9dc12719f9f96f0146508093a6a0dfe", "parents": ["ac3cd70b8967b4917b4c51ca9b6d71ad727b6942"], "tags": []}, {"author": "Boris Chiou \u003cboris.chiou@gmail.com\u003e", "branch": "default", "desc": "Bug 1418806 servo: Merge #19607 - hashglobe: Dump the requested aligment if out of memory while allocating a table (from BorisChiou:stylo/crash/out_of_memory_alignment); r=emilio a=gchang\n\nThis is for Bug 1418806 and Bug 1416903. We need not only the requested size\nbut also the requested alignment for debugging.\n\n---\n- [X] `./mach build -d` does not report any errors\n- [X] `./mach test-tidy` does not report any errors\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 27a443fbaaf3e19fa3a753f68b20a7a7ccc5d199", "files": ["servo/components/hashglobe/src/lib.rs", "servo/components/hashglobe/src/table.rs"], "git_node": null, "git_parents": [null], "node": "641211059e52792538163f95dd447766e35a7d93", "parents": ["46fabe0cc9dc12719f9f96f0146508093a6a0dfe"], "tags": []}], "date": 1515406729, "git_changesets": [null, null, null], "user": "dluca@mozilla.com"}, "8491": {"changesets": [{"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1426613 - Determine private mode via browser toolbar. r=nechen a=gchang\n\nThe currently selected tab might not actually exist immediately after startup,\nin which case the browser toolbar is a safer bet for determining whether we're\nin private mode or not.\n\nI think the current worst case is when we're\n- not restoring a previous session, and\n- need to open some tab queue tabs, and\n- also need to open some other tab in response to our launch intent\n\nin which case we won't have a selected tab in Java until after Gecko is up and\nrunning. This in turn can take a while, especially when a fresh copy of\nlibxul.so needs to be extracted after an update/installation/cleared cache/...,\nwhich potentially gives the user ample time to click on a search result/Top\nSites entry/... that then triggers this crash.\n\nMozReview-Commit-ID: FlJZw2aL8OM", "files": ["mobile/android/base/java/org/mozilla/gecko/BrowserApp.java", "mobile/android/base/java/org/mozilla/gecko/Tabs.java"], "git_node": null, "git_parents": [null], "node": "cb843e26235503704b941d47370b1686ddcec11c", "parents": ["641211059e52792538163f95dd447766e35a7d93"], "tags": []}, {"author": "tera_1225@hotmail.com \u003ctera_1225@hotmail.com\u003e", "branch": "default", "desc": "Bug 1425839 Reduced requests-list-headers-wrapper z-index from 1000 to 1. r=rickychien a=gchang\n\nMozReview-Commit-ID: DwLsvluvNGm", "files": ["devtools/client/netmonitor/src/assets/styles/RequestList.css"], "git_node": null, "git_parents": [null], "node": "2609db38f7d82c2433ce9d6ecb4ac9d3a85e35f8", "parents": ["cb843e26235503704b941d47370b1686ddcec11c"], "tags": []}], "date": 1515408488, "git_changesets": [null, null], "user": "ccoroiu@mozilla.com"}, "8492": {"changesets": [{"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1426864 - Determine private mode via browser toolbar, 2nd edition. r=nechen a=gchang\n\nSimilar to maybeSwitchToTab in bug 1426613, a search might be launched while we\ndon't have a selected tab yet. Therefore we determine private mode state via the\nbrowser toolbar instead.\n\nMozReview-Commit-ID: 4idUR8v7MCx", "files": ["mobile/android/base/java/org/mozilla/gecko/BrowserApp.java"], "git_node": null, "git_parents": [null], "node": "05bca3daad744ba8fc16a97fbdbdce486309e236", "parents": ["2609db38f7d82c2433ce9d6ecb4ac9d3a85e35f8"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1427847 - Update strings for Firefox 58. r=k88hudson a=gchang\n\nMozReview-Commit-ID: 3bWFbT7pfxC", "files": ["browser/components/newtab/aboutNewTabService.js", "browser/extensions/activity-stream/install.rdf.in", "browser/extensions/activity-stream/prerendered/locales/ach/activity-stream-strings.js", "browser/extensions/activity-stream/prerendered/locales/ar/activity-stream-strings.js", "browser/extensions/activity-stream/prerendered/locales/ast/activity-stream-prerendered.html", "browser/extensions/activity-stream/prerendered/locales/ast/activity-stream-strings.js", "browser/extensions/activity-stream/prerendered/locales/az/activity-stream-strings.js", "browser/extensions/activity-stream/prerendered/locales/be/activity-stream-strings.js", "browser/extensions/activity-stream/prerendered/locales/bg/activity-stream-prerendered.html", "browser/extensions/activity-stream/prerendered/locales/bg/activity-stream-strings.js", "browser/extensions/activity-stream/prerendered/locales/bn-BD/activity-stream-strings.js"