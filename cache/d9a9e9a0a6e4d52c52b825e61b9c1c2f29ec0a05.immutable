 ["e4d5dee669102f6f271a6eebf749d0f9973fde0b"], "tags": []}], "date": 1512049741, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8273": {"changesets": [{"author": "Oriol Brufau \u003coriol-bugzilla@hotmail.com\u003e", "branch": "default", "desc": "Bug 1416391 - Fix Element.scrollIntoView in \"nearest\" mode to behave according to CSSOM spec. r=tnikkel a=gchang\n\nMozReview-Commit-ID: 5xhqKQ1ZDV6", "files": ["layout/base/PresShell.cpp", "layout/base/nsIPresShell.h", "layout/base/tests/test_scroll_selection_into_view.html"], "git_node": null, "git_parents": [null], "node": "71956196206bba1b9fab23b31ce5201eb0c52d0d", "parents": ["122e73935baa8d5dc0fcd0f473ff28deb22a5fd6"], "tags": []}, {"author": "Tom Tung \u003cshes050117@gmail.com\u003e", "branch": "default", "desc": "Bug 1416629: Add a telemetry to get how many precentage of synthesized cors response for same-origin mode request. r=bkelly, data-r=francois a=gchang", "files": ["dom/workers/ServiceWorkerEvents.cpp", "toolkit/components/telemetry/Scalars.yaml"], "git_node": null, "git_parents": [null], "node": "b9d29c50dff5b02df9aa33af951baf0981eb485a", "parents": ["71956196206bba1b9fab23b31ce5201eb0c52d0d"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418266 - add devtools onboarding preferences and probes (beta-only);r=ochameau a=gchang\n\nThe devtools.onboarding.experiment pref now supports 3 states:\n- off (default)\n- on\n- force\n\nWhen set to \"on\" or \"force\" the preference will flip devtools\nenabled to false.\n\nWhen set to \"force\" the devtools.enabled pref can no longer be\nflipped to true by looking at devtools.selfxss.count, users\nhave to go through the onboarding flow.\n\nTo make sure the devtools.enabled pref is only flipped once, we\nuse a supporting pref devtools.onboarding.experiment.flipped\n\nMozReview-Commit-ID: B5fPKuGxPW2", "files": ["devtools/shim/devtools-startup-prefs.js", "devtools/shim/devtools-startup.js", "toolkit/components/telemetry/Scalars.yaml"], "git_node": null, "git_parents": [null], "node": "5405d1ebc3155fa2574d4a66452cd283358136ed", "parents": ["b9d29c50dff5b02df9aa33af951baf0981eb485a"], "tags": []}], "date": 1512051390, "git_changesets": [null, null, null], "user": "shindli@mozilla.com"}, "8274": {"changesets": [{"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1417947 - Mark the correct frame as modified when invalidating due to blend mode. r=miko a=gchang", "files": ["layout/generic/nsFrame.cpp", "layout/painting/nsDisplayList.cpp"], "git_node": null, "git_parents": [null], "node": "c88f2766d765ad9af1a48ad84c7a4e7166515cdd", "parents": ["5405d1ebc3155fa2574d4a66452cd283358136ed"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418722 - Mark nsDisplayPerspective items for removal when the inner transform frame gets removed from the frame tree. r=mstange a=gchang", "files": ["layout/painting/crashtests/1418722-1.html", "layout/painting/crashtests/crashtests.list", "layout/painting/nsDisplayList.cpp", "layout/painting/nsDisplayList.h"], "git_node": null, "git_parents": [null], "node": "8e32013003246a66c93de4d1c5e6b53f3f2df08d", "parents": ["c88f2766d765ad9af1a48ad84c7a4e7166515cdd"], "tags": []}], "date": 1512053266, "git_changesets": [null, null], "user": "nerli@mozilla.com"}, "8275": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nar -\u003e c3397c7c41be\nbg -\u003e df488dfb240e\nbn-IN -\u003e b0ac71ff5351\nbs -\u003e 582a5084bc00\nca -\u003e 1c2e6fbc3b53\nda -\u003e df9d07d25100\ndsb -\u003e a345df481b9e\nen-GB -\u003e e6c4ba8362a7\nes-MX -\u003e a21f681431bb\net -\u003e 359b3e1f2da4\nfa -\u003e 60bd8f9ac026\nff -\u003e f7e926214ae2\nfi -\u003e e651d4b53f7b\nfr -\u003e 557890da977