alentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1415206 - Remove RustURL from Gecko r=bagder\n\nThis class isn't being used right now, and MozURL is a much better alternative if interaction with rust URLs is required.\n\nMozReview-Commit-ID: ADdYRrrTnr6", "files": ["browser/confvars.sh", "modules/libpref/init/all.js", "netwerk/base/RustURL.cpp", "netwerk/base/RustURL.h", "netwerk/base/moz.build", "netwerk/base/nsStandardURL.cpp", "netwerk/base/nsStandardURL.h", "netwerk/build/nsNetCID.h", "netwerk/build/nsNetModule.cpp", "netwerk/test/unit/test_rusturl.js", "netwerk/test/unit/xpcshell.ini", "old-configure.in"], "git_node": null, "git_parents": [null], "node": "5359b9edc63d7469c1fd993ad49fb78560924b1f", "parents": ["06538a745211663edaf19646b989095b36343bfa"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412029 - pass key shortcut id to aboutdevtools page;r=bgrins\n\nMozReview-Commit-ID: 4Fmj1p1bgsB", "files": ["devtools/shim/devtools-startup.js"], "git_node": null, "git_parents": [null], "node": "b8fc199eb8a48233ba82c35498c8ccdde8987196", "parents": ["5359b9edc63d7469c1fd993ad49fb78560924b1f"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412029 - add probes to about:devtools;r=bgrins,datareview=francois\n\nThis changeset adds 3 scalars:\n- devtools.aboutdevtools.opened -\u003e logged every time the page is loaded\n- devtools.aboutdevtools.installed -\u003e logged when the user clicks on the\n  install button\n- devtools.aboutdevtools.noinstall_exits -\u003e logged when leaving the page\n  if devtools is not enabled\n\nAnd 2 keyed histograms:\n- DEVTOOLS_ABOUT_DEVTOOLS_OPENED_REASON (is it a shortcut, is it a menu\n  item etc...)\n- DEVTOOLS_ABOUT_DEVTOOLS_OPENED_KEY (in case of a keyshortcut, what is\n  the keyshortcut id)\n\n\nMozReview-Commit-ID: 1DET1ozf8i4", "files": ["devtools/shim/aboutdevtools/aboutdevtools.js", "toolkit/components/telemetry/Histograms.json", "toolkit/components/telemetry/Scalars.yaml"], "git_node": null, "git_parents": [null], "node": "6ddd17e8d5c4129ec5a106b83352d9725f167c8d", "parents": ["b8fc199eb8a48233ba82c35498c8ccdde8987196"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1408369 - create about:devtools welcome message dynamically;r=flod,nchevobbe\n\nThe welcome message used to be defined in DTD. Since it has a dynamic part (the\ntoggle toolbox shortcut) it's easier for localization purposes to have it in a\nproperties file and dynamically insert it.\n\nMozReview-Commit-ID: FhgQjbs8Dw0", "files": ["devtools/shim/aboutdevtools/aboutdevtools.js", "devtools/shim/aboutdevtools/aboutdevtools.xhtml", "devtools/shim/aboutdevtools/tmp-locale/aboutdevtools.dtd", "devtools/shim/locales/en-US/aboutdevtools.properties"], "git_node": null, "git_parents": [null], "node": "43a6a070e9d3eb6055b200615f1351e5e9cac6cd", "parents": ["6ddd17e8d5c4129ec5a106b83352d9725f167c8d"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1408369 - move back aboutdevtools.dtd to devtools/shim/locales;r=flod\n\nAdd localization notes to aboutdevtools.dtd and move it back to the locales\nfolder where it can be picked up by localization teams.\n\nMozReview-Commit-ID: 8fDimFwdBXv", "files": ["browser/base/content/test/static/browser_misused_characters_in_strings.js", "devtools/shim/aboutdevtools/aboutdevtools.xhtml", "devtools/shim/aboutdevtools/tmp-locale/aboutdevtools.dtd", "devtools/shim/jar.mn", "devtools/shim/locales/en-US/aboutdevtools.dtd"], "git_node": null, "git_parents": [null], "node": "4cd32018fcd24a0f04519683ded252eb6fc221ce", "parents": ["43a6a070e9d3eb6055b200615f1351e5e9cac6cd"], "tags": []}, {"author": "Keith Yeung \u003ckungfukeith11@gmail.com\u003e", "branch": "default", "desc": "servo: Merge #19148 - Import sequence inner types if it appears in dictionary members (from KiChjang:import-sequence-inner-types); r=jdm\n\nRelands #19133, as it was backed out wrongly in #19143.\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: a1f733722167124eb1a63e235101a1dc40ac2aa0", "files": ["servo/components/script/dom/bindings/codegen/Configuration.py", "servo/components/script/dom/testbinding.rs", "servo/components/script/dom/webidls/TestBinding.webidl"], "git_node": null, "git_parents": [null], "node": "6169e97b09d2a501640290f9d4b5b6c7e7d41641", "parents": ["4cd32018fcd24a0f04519683ded252eb6fc221ce"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1415080 - Rename all 's' prefixed members of nsLookAndFeel as they're not static ones, r=jhorak\n\nMozReview-Commit-ID: 9LHIewRnbAY", "files": ["widget/gtk/nsLookAndFeel.cpp", "widget/gtk/nsLookAndFeel.h"], "git_node": null, "git_parents": [null], "node": "2623a4e8fa60ae45f9ca25855d3e2a04c14f7944", "parents": ["6169e97b09d2a501640290f9d4b5b6c7e7d41641"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415537 - Rename mTabstrip to arrowScrollbox. r=florian\n\nMozReview-Commit-ID: IcGH5npSsrg", "files": ["browser/base/content/tabbrowser.xml", "browser/base/content/test/performance/browser_tabstrip_overflow_underflow_reflows.js", "browser/base/content/test/performance/head.js", "browser/base/content/test/tabs/browser_overflowScroll.js", "browser/components/sessionstore/SessionStore.jsm"], "git_node": null, "git_parents": [null], "node": "7b36ace8b7078536d0cf309bac90c40e2e6e2056", "parents": ["2623a4e8fa60ae45f9ca25855d3e2a04c14f7944"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1393817 Use buildconfig to get the path for 7z rather than hardcoding it in exe_7z_archive.py r=ted\n\nWith that fixed, Re-enable MOZ_AUTOMATION_L10N_CHECK for MinGW\n\nMozReview-Commit-ID: BDTtY1J7sBj", "files": ["browser/config/mozconfigs/win32/mingw32", "python/mozbuild/mozbuild/action/exe_7z_archive.py"], "git_node": null, "git_parents": [null], "node": "25f21f22a34b6657f24cdc82a5327130ed600c99", "parents": ["7b36ace8b7078536d0cf309bac90c40e2e6e2056"], "tags": []}, {"author": "Scott Wu \u003cscottcwwu@gmail.com\u003e", "branch": "default", "desc": "Bug 1411509 - Add the country address format parser. r=lchang,steveck\n\nMozReview-Commit-ID: 9ViNsQYeO0d", "files": ["browser/extensions/formautofill/FormAutofillUtils.jsm", "browser/extensions/formautofill/test/unit/test_parseAddressFormat.js", "browser/extensions/formautofill/test/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "7b905cce83cdb4a3154977493613a830114c7c46", "parents": ["25f21f22a34b6657f24cdc82a5327130ed600c99"], "tags": []}, {"author": "Jan Beich \u003cjbeich@FreeBSD.org\u003e", "branch": "default", "desc": "Bug 1414440 - Always build libyuv x86 optimizations with Clang. r=sotaro\n\nSSE2 isn't enabled by default on BSD x86 systems which ends up disabling\nSIMD-optimized routines in libyuv. As Clang can build the code fine without\n-msse limit the requirement to GCC.\n\nhttps://github.com/llvm-mirror/clang/blob/6fc97e7c1cf4/lib/Driver/ToolChains/Arch/X86.cpp#L98\n\nMozReview-Commit-ID: BaVAbEpkoHj", "files": ["media/libyuv/clang_x86_asm.patch", "media/libyuv/libyuv/include/libyuv/compare_row.h", "media/libyuv/libyuv/include/libyuv/planar_functions.h", "media/libyuv/libyuv/include/libyuv/rotate_row.h", "media/libyuv/libyuv/include/libyuv/row.h", "media/libyuv/libyuv/include/libyuv/scale_row.h", "media/libyuv/libyuv/linux.mk", "media/libyuv/libyuv/source/row_gcc.cc", "media/libyuv/update.py"], "git_node": null, "git_parents": [null], "node": "848aaca92e63270bf744cd1469d4dc919f12ecda", "parents": ["7b905cce83cdb4a3154977493613a830114c7c46"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1415353: Don't allow creating shadow roots for elements with XBL bindings. r=smaug\n\nIt breaks all sorts of invariants.\n\nMozReview-Commit-ID: IGUDp91q0sF", "files": ["dom/base/Element.cpp"], "git_node": null, "git_parents": [null], "node": "bacc66989ae82ba2776ea6865dd920caa2c1c26d", "parents": ["848aaca92e63270bf744cd1469d4dc919f12ecda"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1415353: Crashtest. r=me\n\nMozReview-Commit-ID: GjeTrTPfSnP\n", "files": ["layout/style/crashtests/1415353.html", "layout/style/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "c4f23e11b58fa8a78c3b9f2f0ab5d54274e67c99", "parents": ["bacc66989ae82ba2776ea6865dd920caa2c1c26d"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "servo: Merge #19149 - style: minor cleanups (from emilio:random-cleanup); r=nox\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: cbf2ac35f7ba4188f20ba20284d5c218280537d7", "files": ["servo/components/style/gecko/pseudo_element.rs", "servo/components/style/matching.rs"], "git_node": null, "git_parents": [null], "node": "c16091f20f09a75d52aa3e1c3dd5dc0b441d33ed", "parents": ["c4f23e11b58fa8a78c3b9f2f0ab5d54274e67c99"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415522 - PlacesTransactions.Tag should take account of a URL that is already tagged. r=mak\n\nMozReview-Commit-ID: 9Tev7BhbujQ", "files": ["toolkit/components/places/PlacesTransactions.jsm", "toolkit/components/places/tests/unit/test_async_transactions.js"], "git_node": null, "git_parents": [null], "node": "ee5be9ad894ec7fbddb4c9eeb83722bb6c0dd32e", "parents": ["c16091f20f09a75d52aa3e1c3dd5dc0b441d33ed"], "tags": []}, {"author": "Ursula Sarracini", "branch": "default", "desc": "Bug 1413650 - Capture loaded page instead of relying on background screenshot r=Mardak\n\nMozReview-Commit-ID: FWToOSH8uL8", "files": ["browser/base/content/browser-thumbnails.js", "toolkit/components/thumbnails/test/browser.ini", "toolkit/components/thumbnails/test/browser_thumbnails_bg_topsites.js"], "git_node": null, "git_parents": [null], "node": "0f9f5ef2c14122360e4bd3ea2ae171fad7ae2554", "parents": ["ee5be9ad894ec7fbddb4c9eeb83722bb6c0dd32e"], "tags": []}, {"author": "Milan Sreckovic \u003cmilan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1389152: Change LogicalRect from having nsRect as a member variable, and exposing its member variable addresses, to storing four nscoord values separately and doing some operations by creating temporary rectangles to ensure consistency. Add a method to BaseRect to get OriginAndSize at once. r=bas,jfkthame.schouten\n\nMozReview-Commit-ID: FhmSXK7p5c6", "files": ["gfx/tests/gtest/TestRect.cpp", "layout/generic/WritingModes.h"], "git_node": null, "git_parents": [null], "node": "2a52e1d4c300aa71652652c4349d4e06c74c9dc7", "parents": ["0f9f5ef2c14122360e4bd3ea2ae171fad7ae2554"], "tags": []}, {"author": "Andrew Halberstadt \u003cahalberstadt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414399 - [mozbuild/moztest] Move mozbuild.testing.TestResolver to moztest.resolve r=gps\n\nThe TestMetadata and TestResolver classes aren't technically part of the build\nsystem. The only connection is that they consume some build system output.\n\nThe next patch in this series is going to be merging in a bunch of other test\nresolving logic from other parts of the tree. Moving this out first allows us\nto keep that extra logic out of mozbuild.\n\nMozReview-Commit-ID: 1eq4SjFVCyW", "files": ["python/mach_commands.py", "python/mozbuild/mozbuild/test/python.ini", "python/mozbuild/mozbuild/test/test_testing.py", "python/mozbuild/mozbuild/testing.py", "testing/mach_commands.py", "testing/mochitest/mach_commands.py", "testing/mozbase/moztest/moztest/resolve.py", "testing/mozbase/moztest/tests/manifest.ini", "testing/mozbase/moztest/tests/test_resolve.py", "tools/tryselect/mach_commands.py"], "git_node": null, "git_parents": [null], "node": "1ede5a47bb9877a7bd01eb4303d65b8462f1d32c", "parents": ["2a52e1d4c300aa71652652c4349d4e06c74c9dc7"], "tags": []}, {"author": "Andrew Halberstadt \u003cahalberstadt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414399 - [moztest] Refactor |mach test|'s resolving logic into moztest.resolve r=gps\n\nThe code in |mach test| for test resolving, should get merged with the TestResolver\nclass in moztest.resolve. This way it can be shared with other modules and we'll\nhave a single canonical place for all our test resolving logic.\n\nMozReview-Commit-ID: IHRXXi5mB4G", "files": ["testing/mach_commands.py", "testing/mozbase/moztest/moztest/resolve.py", "testing/mozbase/moztest/tests/test_resolve.py", "tools/tryselect/mach_commands.py", "tools/tryselect/selectors/syntax.py"], "git_node": null, "git_parents": [null], "node": "3170c6d82e89453a2301a8a8f594df2254db014e", "parents": ["1ede5a47bb9877a7bd01eb4303d65b8462f1d32c"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1415538: Remove dead frame construction code (InsertFirstLineFrames). r=mats\n\nInsertFirstLineFrames has been dead for a long time, and I don't think it's\nworth to keep it around. It's in the VCS history anyway.\n\nMozReview-Commit-ID: FetYB6nf38D", "files": ["layout/base/nsCSSFrameConstructor.cpp", "layout/base/nsCSSFrameConstructor.h"], "git_node": null, "git_parents": [null], "node": "6646fb7959a8c7c78179fa09b6522b7a0f805f97", "parents": ["3170c6d82e89453a2301a8a8f594df2254db014e"], "tags": []}, {"author": "Doug Thayer \u003cdothayer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1413989 - include Timer.jsm in MigrationUtils.jsm r=MattN\n\nsetTimeout was previously undefined. Created a test specifically\nfor MigrationUtils, since trying to test this through an actual\nChrome migration path seemed trickier and more fragile.\n\nMozReview-Commit-ID: 33U7ZzzG1CC", "files": ["browser/components/migration/MigrationUtils.jsm", "browser/components/migration/tests/unit/test_MigrationUtils_timedRetry.js", "browser/components/migration/tests/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "d0280b48ef5828a886d582c4162835b694ccafd3", "parents": ["6646fb7959a8c7c78179fa09b6522b7a0f805f97"], "tags": []}, {"author": "Delphine Leb\u00e9del \u003cdlebedel@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411102 - Add ach, bs, ia, ltg and oc to Fennec all-locales for single-locales builds, r=flod\n\nMozReview-Commit-ID: BX6azMD9G5c", "files": ["mobile/android/locales/all-locales", "mobile/android/locales/l10n.toml"], "git_node": null, "git_parents": [null], "node": "cae09668c272af64a2726a60a224ef7378442844", "parents": ["d0280b48ef5828a886d582c4162835b694ccafd3"], "tags": []}, {"author": "Delphine Leb\u00e9del \u003cdlebedel@mozilla.com\u003e", "branch": "default", "desc": "Bug 1413376 - [oc] Search engine setup for Firefox Mobile Occitan, r=flod\n\nMozReview-Commit-ID: 7SPWMd8n2UR", "files": ["mobile/locales/search/list.json", "mobile/locales/searchplugins/wikipedia-oc.xml", "mobile/locales/searchplugins/wiktionary-oc.xml"], "git_node": null, "git_parents": [null], "node": "d757529a93495e47e80c5b0ecf4d30238412d0ff", "parents": ["cae09668c272af64a2726a60a224ef7378442844"], "tags": []}, {"author": "CYBAI \u003ccyb.ai.815@gmail.com\u003e", "branch": "default", "desc": "servo: Merge #19153 - style: Move font-size-adjust outside of mako (from CYBAI:font-size-adjust-out-of-mako); r=emilio\n\nThis is a sub-PR of #19015\nr? emilio\n\n---\n- [x] `./mach build -d` does not report any errors\n- [x] `./mach test-tidy` does not report any errors\n- [x] These changes fix #19151  (github issue number if applicable).\n- [x] These changes do not require tests\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 294a24af4850bc06971fe7e78bb680cc8eb02150", "files": ["servo/components/style/properties/longhand/font.mako.rs", "servo/components/style/values/computed/font.rs", "servo/components/style/values/computed/mod.rs", "servo/components/style/values/specified/font.rs", "servo/components/style/values/specified/mod.rs"], "git_node": null, "git_parents": [null], "node": "2c0284a0451aac2eeb376835cfbdf50fbbe005cb", "parents": ["d757529a93495e47e80c5b0ecf4d30238412d0ff"], "tags": []}, {"author": "Narcis Beleuzu \u003cnbeleuzu@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland. r=merge a=merge on a CLOSED TREE", "files": [], "git_node": null, "git_parents": [null, null], "node": "ac109e443ac2facf708848a6f95a5a1e553596ed", "parents": ["2c0284a0451aac2eeb376835cfbdf50fbbe005cb", "3f797c2aedfb7be631be963e1a402fa9054076c7"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415283 - Increase timeout for tone events in RTCDTMFSender-helper.js; r=jgraham\n\nWith the current value of 150 milliseconds we get intermittent timeouts on our\ntest infrastructure. We are missing by only a small amount, e.g. 6 milliseconds\nin Bug 1415283, but it seems safer to increase the timeout to 250 milliseconds so\nthat we don't end up revisiting this problem in the future.\n\nThis also fixes the error message to say milliseconds rather than seconds.\n\nMozReview-Commit-ID: CqjTKZn33q8", "files": ["testing/web-platform/tests/webrtc/RTCDTMFSender-helper.js"], "git_node": null, "git_parents": [null], "node": "dcf4f46ab589f77392b9a5e867c8cdc2fff99290", "parents": ["ac109e443ac2facf708848a6f95a5a1e553596ed"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1387081 - stop re-adding the sidebar button to the toolbar now that it's there by default, r=mixedpuppy\n\nMozReview-Commit-ID: 9e1eFaVltMO", "files": ["browser/components/extensions/ext-sidebarAction.js", "browser/components/extensions/test/browser/browser_ext_sidebarAction.js"], "git_node": null, "git_parents": [null], "node": "1f5043322c8899aeef2b84f4ea76453f878caaf9", "parents": ["dcf4f46ab589f77392b9a5e867c8cdc2fff99290"], "tags": []}, {"author": "Brad Werth \u003cbwerth@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412173 Part 1: Implement the Document ignore-opens-during-unload counter required by spec. r=bz\n\nMozReview-Commit-ID: IWfT5c0H3t", "files": ["dom/base/nsDocument.cpp", "dom/base/nsIDocument.h", "dom/html/nsHTMLDocument.cpp", "layout/base/nsDocumentViewer.cpp"], "git_node": null, "git_parents": [null], "node": "3bc3d8b72947475088c68e358a70053b859e267c", "parents": ["1f5043322c8899aeef2b84f4ea76453f878caaf9"], "tags": []}, {"author": "Brad Werth \u003cbwerth@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412173 Part 2: Add a crashtest to check we can handle overlapping document open calls. r=bz\n\nMozReview-Commit-ID: LjyQgFicwuO", "files": ["dom/html/crashtests/1412173.html", "dom/html/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "315b2e8320b276ec5aef7fd413b50b413e2ce4fa", "parents": ["3bc3d8b72947475088c68e358a70053b859e267c"], "tags": []}, {"author": "Brad Werth \u003cbwerth@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412173 Part 3: Restore a WPT test to expected pass. r=bz\n\nMozReview-Commit-ID: 7Tdc4dZXdFm", "files": ["testing/web-platform/meta/html/browsers/browsing-the-web/unloading-documents/003.html.ini"], "git_node": null, "git_parents": [null], "node": "6e6b4edc850c6e69d800043792f9b0bd23a1ad82", "parents": ["315b2e8320b276ec5aef7fd413b50b413e2ce4fa"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415298 - Pre: Move assets/ into standard Gradle location. r=maliu\n\nThis is part of a larger project to standardize our source locations.\n\nMozReview-Commit-ID: Gbh9qSW7RJY", "files": ["mobile/android/app/assets/example_asset.txt", "mobile/android/app/assets/parental_controls_theme.png", "mobile/android/app/assets/publicsuffixlist", "mobile/android/app/build.gradle", "mobile/android/app/src/main/assets/example_asset.txt", "mobile/android/app/src/main/assets/parental_controls_theme.png", "mobile/android/app/src/main/assets/publicsuffixlist", "mobile/android/base/moz.build"], "git_node": null, "git_parents": [null], "node": "160586d66bcb37a6bd5822b747030ee0a8449248", "parents": ["6e6b4edc850c6e69d800043792f9b0bd23a1ad82"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415298 - Fix finding assets/ in |mach android test| locally. r=maliu\n\nUpgrading to the Android-Gradle plugin 3.0+ broke |mach android test|\nlocally.  This addresses the issue.\n\nMozReview-Commit-ID: 3vV47ET7d19", "files": ["mobile/android/app/build.gradle"], "git_node": null, "git_parents": [null], "node": "e046373e0dca3c6a3834812b2f04b2da35f508cf", "parents": ["160586d66bcb37a6bd5822b747030ee0a8449248"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "merge mozilla-central to autoland. a=backout on a CLOSED TREE", "files": [], "git_node": null, "git_parents": [null, null], "node": "db4daa1627fff3d54176ee8835ad3bb3d84aaf5d", "parents": ["e046373e0dca3c6a3834812b2f04b2da35f508cf", "75c04adb414bc00d39a0af80691a82af1ceebbd0"], "tags": []}, {"author": "Dale Harvey \u003cdale@arandomurl.com\u003e", "branch": "default", "desc": "Bug 1384582 - Ensure browser_urlbar_search_reflows.js test runs are isolated. r=mconley\n\nWhen running these tests with --verify the places results from\nprevious test runs can effect tests so give each test run a unique\nsearch term to ensure that they do not.\n\nMozReview-Commit-ID: Lp9YCoUdul5", "files": ["browser/base/content/test/performance/browser.ini", "browser/base/content/test/performance/browser_urlbar_search_reflows.js", "browser/base/content/test/performance/head.js"], "git_node": null, "git_parents": [null], "node