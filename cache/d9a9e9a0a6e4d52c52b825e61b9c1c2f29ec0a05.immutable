": "default", "desc": "Merge inbound to mozilla-central r=merge a=merge", "files": ["docshell/base/nsContextMenuInfo.cpp", "docshell/base/nsContextMenuInfo.h", "docshell/base/nsIContextMenuListener.idl", "docshell/base/nsIContextMenuListener2.idl"], "git_node": null, "git_parents": [null, null], "node": "c2fe4b3b1b930b3e7fdb84eae44cec165394f322", "parents": ["62aeebcc676e93dc56a97d44753f4e2f963d43c3", "338f65684d59e760b9050470a0b5bf32cf4cd133"], "tags": []}, {"author": "Coroiu Cristina \u003cccoroiu@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to mozilla-autoland. r=merge a=merge on a CLOSED TREE", "files": ["docshell/base/nsContextMenuInfo.cpp", "docshell/base/nsContextMenuInfo.h", "docshell/base/nsIContextMenuListener.idl", "docshell/base/nsIContextMenuListener2.idl", "layout/painting/nsDisplayList.cpp"], "git_node": null, "git_parents": [null, null], "node": "ab8fb74b86d40aff7a8f8fcd35d3c49e382da583", "parents": ["9d1a657e4d83dc9c2a3e3a304dc08054f4b7ed6b", "c2fe4b3b1b930b3e7fdb84eae44cec165394f322"], "tags": []}, {"author": "David Major \u003cdmajor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414306 - Use VS2017 for the gn toolchain task. r=cmanchester", "files": ["browser/config/tooltool-manifests/win32/gn-build.manifest", "taskcluster/scripts/misc/build-gn-win32.sh"], "git_node": null, "git_parents": [null], "node": "5364570f64079a8b95aa47fb2e067b53c9edb402", "parents": ["4864989da37ee59ed9318de7be1198f41075873a"], "tags": []}, {"author": "David Major \u003cdmajor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414304 - Use VS2017 for the sccache toolchain build. r=cmanchester", "files": ["browser/config/tooltool-manifests/win64/sccache-build.manifest", "taskcluster/scripts/misc/build-sccache.sh"], "git_node": null, "git_parents": [null], "node": "1593366f19f39d5ce6c0eaa900651451cdd94ac3", "parents": ["5364570f64079a8b95aa47fb2e067b53c9edb402"], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1413011 - Allow the UI/chrome process to shutdown if the compositor thread failed to start. r=dvander\n\nThere are up to two compositor threads spawned - one in the GPU process\nand one in the UI/chrome process. If the GPU process is used, then\nfailing to start the UI compositor thread is not fatal -- unless the GPU\nprocess crashes too much and we fallback to the UI/chrome process. If\nthe GPU process compositor thread failed to start, then the GPU process\nwill crash and either restart, or fallback to the UI/chrome process\nthread. If both fail, then Firefox crashes as expected.\n\nBefore we would not setup a content process properly unless the\nUI compositor thread was active, even when using the GPU process. Now we\ndo, which allows the browser to be fully functional. Additionally when\nshutting down, we ignore the lack of a compositor thread to permit a\ngraceful shutdown. In a future patch we will ideally we would not spawn\nthe compositor thread in a process until we actually need it, and\nrelease assert on its failing to start.", "files": ["dom/ipc/ContentParent.cpp", "gfx/layers/ipc/CompositorThread.cpp"], "git_node": null, "git_parents": [null], "node": "531d0b700225294144914cc606b8f2130707e7db", "parents": ["1593366f19f39d5ce6c0eaa900651451cdd94ac3"], "tags": []}, {"author": "Eric Rahm \u003cerahm@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414318 - Turn off |StartWriter| in leak checking builds. r=mccr8", "files": ["toolkit/components/terminator/nsTerminator.cpp", "toolkit/components/terminator/tests/xpcshell/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "b1ce6a65a2141c6ad7f8b3c83333878d976f75c2", "parents": ["531d0b700225294144914cc606b8f2130707e7db"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1414965 - Reset geo preferences for Firefox 57. r=florian\n\nMozReview-Commit-ID: FukSW7TB4Av", "files": ["browser/components/nsBrowser