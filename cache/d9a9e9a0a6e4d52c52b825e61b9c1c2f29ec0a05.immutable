DB.py"], "git_node": null, "git_parents": [null], "node": "888df756364281a9565e5aad3d1b373c33abeafa", "parents": ["d4fe05793ea607307bdb2a4c1e90da09cc096648"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1410723 - Throw DMError when getDirectory() fails suspiciously. r=bc, a=test-only\n\nIt looks like the main cause of intermittent failures in getDirectory is\nthat the adb pull command fails because the emulator has hung. For other\ncommands, we usually handle this by checking the return code and raising\nDMError if anything fails. There is mozharness/taskcluster code in\nplace to automatically retry tasks that throw DMError.", "files": ["testing/mozbase/mozdevice/mozdevice/devicemanagerADB.py"], "git_node": null, "git_parents": [null], "node": "c7a07000546af757f53499ce80f16d49a600114b", "parents": ["888df756364281a9565e5aad3d1b373c33abeafa"], "tags": []}, {"author": "Rob Wood \u003crwood@mozilla.com\u003e", "branch": "default", "desc": "Bug 934310 - Remove talos h1 from win 7 to fix intermittent faiure. r=jmaher, a=test-only\n\nMozReview-Commit-ID: CmpoYrdzw0t", "files": ["taskcluster/ci/test/talos.yml"], "git_node": null, "git_parents": [null], "node": "335dd789fb10da8708a8c8e029f1b4c9135992b9", "parents": ["c7a07000546af757f53499ce80f16d49a600114b"], "tags": []}, {"author": "James Cheng \u003cjacheng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1423518 - Add Samsung Galaxy S4 Mini GT-I9195 into blacklist. r=jolin, a=jcristau\n\nMozReview-Commit-ID: LYqXif8kMmm", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/util/HardwareCodecCapabilityUtils.java"], "git_node": null, "git_parents": [null], "node": "184854bea2fe93d6727ead1c530c1242cceb9851", "parents": ["335dd789fb10da8708a8c8e029f1b4c9135992b9"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1421313 - Remove TexturePoolOGL. r=jgilbert, a=jcristau\n\nMozReview-Commit-ID: