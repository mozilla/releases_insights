rents": [null], "node": "49281ca9bc9c07624f3070903aec0deb0e24d058", "parents": ["786d521ee926b7df598f581bb07846c03fca2247"], "tags": []}], "date": 1512934490, "git_changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "8364": {"changesets": [{"author": "Olli Pettay \u003cOlli.Pettay@helsinki.fi\u003e", "branch": "default", "desc": "Bug 1422092 - Revert the changes made by bug 1399603. r=mrbkap, a=jcristau", "files": ["dom/base/DOMIntersectionObserver.cpp", "dom/base/DOMIntersectionObserver.h", "dom/base/Element.cpp", "dom/base/test/mochitest.ini", "dom/base/test/test_bug1399603.html"], "git_node": null, "git_parents": [null], "node": "90dd6724eb2a62a06cbf726ff43979e790465845", "parents": ["49281ca9bc9c07624f3070903aec0deb0e24d058"], "tags": []}, {"author": "Olli Pettay \u003cOlli.Pettay@helsinki.fi\u003e", "branch": "default", "desc": "Bug 1423159 - Ensure proper multiprocess mouse enter/exit handling. r=stone, a=abillings", "files": ["dom/events/EventStateManager.cpp"], "git_node": null, "git_parents": [null], "node": "7e553ba7c247bdc9994a924e31f3d0f9b44b7c22", "parents": ["90dd6724eb2a62a06cbf726ff43979e790465845"], "tags": []}, {"author": "Bas Schouten \u003cbschouten@mozilla.com\u003e", "branch": "default", "desc": "Bug 1423281 - Store the userdata for freeing our memory on the longer living snapshot. r=dvander, a=jcristau\n\nMozReview-Commit-ID: 91tVpJC7gAe", "files": ["gfx/2d/SourceSurfaceCapture.cpp"], "git_node": null, "git_parents": [null], "node": "06039747cf8690dfb42b90574c3a8743efda6a3e", "parents": ["7e553ba7c247bdc9994a924e31f3d0f9b44b7c22"], "tags": []}], "date": 1512941770, "git_changesets": [null, null, null], "user": "ryanvm@gmail.com"}, "8365": {"changesets": [{"author": "Michal Novotny \u003cmichal.novotny@gmail.com\u003e", "branch": "default", "desc": "Bug 1418854 - Race condition in AutoClose. r=honzab, a=jcristau", "files": ["netwerk/base/AutoClose.h"], "git_node": null, "git_parents": [null], "node": "4186bb70043e1c56d2211d83273d47d631963891", "parents": ["06039747cf8690dfb42b90574c3a8743efda6a3e"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1419762 - Return the inline continuation of an IB split when appending. r=mats, a=jcristau\n\nThe only reason not to do that is when there's after content in there. We know\nthat there isn't really any ::after content, since it would've been handled by\nFindNextSibling, so we know we're performing a real append.\n\nMozReview-Commit-ID: ExoPolZy4gG", "files": ["layout/base/crashtests/1419762.html", "layout/base/crashtests/crashtests.list", "layout/base/nsCSSFrameConstructor.cpp"], "git_node": null, "git_parents": [null], "node": "df5c32622c0aad4a465951b0ec248138f9113a0b", "parents": ["4186bb70043e1c56d2211d83273d47d631963891"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1424013 - Change back to child combinator from descendant combinator for extension page detail-view. r=dao, a=jcristau\n\nMozReview-Commit-ID: LR7ce9TcsmP", "files": ["toolkit/themes/shared/extensions/extensions.inc.css"], "git_node": null, "git_parents": [null], "node": "aa78bfc225318b8e86f07ac56d8b65055e6d4f82", "parents": ["df5c32622c0aad4a465951b0ec248138f9113a0b"], "tags": []}, {"author": "Bob Owen \u003cbobowencode@gmail.com\u003e", "branch": "default", "desc": "Bug 1423296 - Don't use MITIGATION_IMAGE_LOAD_NO_LOW_LABEL when running from a network drive. r=jimm, a=jcristau", "files": ["security/sandbox/win/src/sandboxbroker/sandboxBroker.cpp"], "git_node": null, "git_parents": [null], "node": "b61b2f87160b375d54b121920b4befd9668963e5", "parents": ["aa78bfc225318b8e86f07ac56d8b65055e6d4f82"], "tags": []}, {"author": "Florian Qu\u00e8ze \u003cflorian@queze.net\u003e", "branch": "default", "desc": "Bug 1423811 - Do not attempt to reset search settings of users with an original default engine that isn't considered a default engine (likely due to a langpack). r=adw, a=jcristau", "files": ["browser/components/nsBrowserGlue.js"], "git_node": null, "git_parents": [null], "node": "d7ddb4b0dc03cb110b8936c89465ca5e08ea71be", "parents": ["b61b2f87160b375d54b121920b4befd9668963e5"], "tags": ["DEVEDITION_58_0b11_RELEASE", "FENNEC_58_0b11_BUILD1", "FENNEC_58_0b11_RELEASE", "FIREFOX_58_0b11_BUILD1", "FIREFOX_58_0b11_RELEASE"]}], "date": 1512958161, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8366": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nhy-AM -\u003e 6319eaf727dc\nka -\u003e 7bec7838b62e\nnl -\u003e d3e2d1b77c63\nuk -\u003e 73419969a37d\nwo -\u003e 03717d4b8d3b", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "e130cae4ad81cac3cab4a9aeffa63ccbcb2f8fa9", "parents": ["d7ddb4b0dc03cb110b8936c89465ca5e08ea71be"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nhy-AM -\u003e 6319eaf727dc\nka -\u003e 0f2bc097512e\nkab -\u003e ef9984caa30c\nnl -\u003e d3e2d1b77c63\nnn-NO -\u003e 881a8d8aec43\nuk -\u003e 73419969a37d\nvi -\u003e 9bfadbe6a1f7", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "fcd21eb1dcfeadef9eacec4c2f3f047031d18d61", "parents": ["e130cae4ad81cac3cab4a9aeffa63ccbcb2f8fa9"], "tags": []}], "date": 1512998499, "git_changesets": [null, null], "user": "ffxbld"}, "8367": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nbs -\u003e 185c908abc5d\nes-AR -\u003e a8b1b34502cc\ngu-IN -\u003e ad5427bbefa0\npt-BR -\u003e 5a833510cd66\nsl -\u003e b6971df009c1\nsq -\u003e 25ee68b87029\nth -\u003e 5ce795de7e57", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "c9794ae9ad369c3efe94267a0a3653a874393b94", "parents": ["fcd21eb1dcfeadef9eacec4c2f3f047031d18d61"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nbg -\u003e a48c33a5eb1f\nbs -\u003e 185c908abc5d\ngu-IN -\u003e ad5427bbefa0\nhe -\u003e feebeee669ef\nkab -\u003e 8ec76eb5c11b\npt-BR -\u003e 5a833510cd66\nsl -\u003e b6971df009c1\nsq -\u003e 25ee68b87029\nsr -\u003e eb7e16fd2b1b\nth -\u003e 5ce795de7e57\nzh-CN -\u003e 22fbea9e6f72", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "c9fa22389f1bb4df5783c73209c093cfae477e8b", "parents": ["c9794ae9ad369c3efe94267a0a3653a874393b94"], "tags": []}], "date": 1513081346, "git_changesets": [null, null], "user": "ffxbld"}, "8368": {"changesets": [{"author": "Rail Aliiev \u003crail@mozilla.com\u003e", "branch": "default", "desc": "Bug 1423663 - Release Dockerfiles from Ubuntu:vivid not working after EOL r=Callek a=release\n\nMozReview-Commit-ID: HiTT1b4I8Tt", "files": ["taskcluster/docker/beet-mover/Dockerfile", "taskcluster/docker/funsize-balrog-submitter/Dockerfile"], "git_node": null, "git_parents": [null], "node": "503f6ecc05118892f48d3613315524bcfdb0fc73", "parents": ["c9fa22389f1bb4df5783c73209c093cfae477e8b"], "tags": []}], "date": 1513089361, "git_changesets": [null], "user": "raliiev@mozilla.com"}, "8369": {"changesets": [{"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1405832 - part 1: ContentCacheInParent::RequestIMEToCommitComposition() should increment mPendingEventsNeedingAck itself if it treat the request handled synchronously without actually requesting IME to commit composition r=m_kato a=lizzard\n\nThis is a simple bug of ContentCacheInParent.  When\nContentCacheInParent::RequestIMEToCommitComposition() returns true,\nPuppetWidget::RequestIMEToCommitComposition() will send\neCompositionCommitRequestHandled pseudo event message back to the main process.\nThis causes counting down mPendingEventsNeedingAck in\nContentCacheInParent::OnEventNeedingAckHandled().  Therefore, in the normal\npath, ContentCacheInParent::OnCompositionEvent() increments it for receiving\nthe pseudo event message.\n\nHowever, if the tab parent has already lost focus,\nRequestIMEToCommitComposition() returns true without requesting native IME to\ncommit composition.  So, ContentCacheInParent::OnCompositionEvent() cannot\nincrement mPendingEventsNeedingAck for coming\neCompositionCommitRequestHandled.  Therefore, RequestIMEToCommitComposition()\nneeds to increment mPendingEventsNeedingAck by itself when it won't request\nIME to commit composition but it returns true.\n\nMozReview-Commit-ID: 4Alwfy8avB", "files": ["widget/ContentCache.cpp"], "git_node": null, "git_parents": [null], "node": "0136b24f43b38f65f12e97d90ef285b2702796b4", "parents": ["503f6ecc05118892f48d3613315524bcfdb0fc73"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1405832 - part 2: TextComposition::RequestToCommit() should request IME to commit or cancel composition only when it hasn't been request it yet and hasn't received commit event yet r=m_kato a=lizzard\n\nAccording to the log in crash reports, eCompositionCommitRequestHandled is\nsent to ContentCacheInParent twice or more for a composition.  This causes\nbreaking mPendingCompositionCount and mPendingEventsNeedingAck management.\n\nCurrently, nsIWidget::NotifyIME() should be called only by\nTextComposition::RequestToCommit().  Therefore, the method should manage if\nit should request it actually.  If the composition has already received\neCompositionCommit(AsIs) event, it shouldn't request it because parent process\nmay have already stated new composition and it shouldn't be broken by request\nfor old composition.\n\nMozReview-Commit-ID: 2ekSa6EIeRP", "files": ["dom/events/TextComposition.cpp", "dom/events/TextComposition.h", "widget/PuppetWidget.cpp"], "git_node": null, "git_parents": [null], "node": "31bb04b6df157ce911218040ba35f37f3df2a9b6", "parents": ["0136b24f43b38f65f12e97d90ef285b2702796b4"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1405832 - part 3: ContentCacheInParent::RequestIMEToCommitComposition() should call nsIWidget::NotifyIME() via TextComposition::RequestToCommit() r=m_kato a=lizzard\n\nNow, TextComposition::RequestToCommit() manages if it has already requested\nIME to commit or cancel composition and this is important for redundant\nrequests.  Therefore, ContentCacheInParent::RequestIMEToCommitComposition()\nshouldn't call nsIWidget::NotifyIME() directly.\n\nMozReview-Commit-ID: 69VpgyK9Jk5", "files": ["widget/ContentCache.cpp"], "git_node": null, "git_parents": [null], "node": "8e59e9aed42125f17012405842d4b4ae44148cc0", "parents": ["31bb04b6df157ce911218040ba35f37f3df2a9b6"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1405832 - part 4: ContentCacheInParent::OnEventNeedingAckHandled() shouldn't crash in release build r=m_kato a=lizzard\n\nFor protecting main process, we should stop crashing main process in release\nbuild even when we detect our bug.  However, we should keep crashing with\nMOZ_DIAGNOSTIC_ASSER which is enabled only on Night and Developer Edition.\n\nMozReview-Commit-ID: 5BQ46IFzXXj", "files": ["widget/ContentCache.cpp", "widget/ContentCache.h"], "git_node": null, "git_parents": [null], "node": "524a38fae76c36f9305b2603c1859386bc54a271", "parents": ["8e59e9aed42125f17012405842d4b4ae44148cc0"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1420849 - Make PuppetWidget discard composition events after requesting commit composition and synthesizing eCommitComposition event until new eCompositionStart event comes r=m_kato a=lizzard\n\nWhen ContentCacheInParent::RequestIMEToCommitComposition() returns true,\nthe remote process will synthesize eCompositionCommit event.  This causes\ndestroying TextComposition event in the remote process (by\nIMEStateManager::DispatchCompositionEvent()).  Then,\nIMEStateManager::DispatchCompositionEvent() will recreate new TextComposition\ninstance when it receives new composition event.  Then, it may request\nto commit composition to the main process via PuppetWidget accidentally.\n\nSo, after PuppetWidget::RequestIMEToCommitComposition() synthesizes\neCompositionCommit, PuppetWidget should discard following composition events\nuntil it receives eCompositionStart since they are unnecessary for the content\nand they are for the old composition, i.e., outdated events.\n\nMozReview-Commit-ID: BNRcoYxABpd", "files": ["widget/ContentCache.cpp", "widget/PuppetWidget.cpp", "widget/PuppetWidget.h"], "git_node": null, "git_parents": [null], "node": "1dc54b85de4dc4591fa46dab70a31ed79be4e41d", "parents": ["524a38fae76c36f9305b2603c1859386bc54a271"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1423456 - ContentCacheInParent::OnEventNeedingAckHandled() shouldn't decrement mPendingCompositionCount when it receives eCompositionCommit(AsIs) from the remote process but the composition has already been committed by a request to commit composition r=m_kato a=lizzard\n\nAfter fixing bug 1420849, remote process started to ignore composition events\nafter it synthesizes eCompositionCommit event after requesting to commit\ncomposition.  However, remote process still keeps returning composition events\nwhen it receives from the main process.  So, if the main process has already\nsent eCompositionCommit(AsIs) event when it's requested to commit composition\nfrom the remote process, ContentCacheInParent::OnEventNeedingAckHandled()\nreceives both eCompositionCommitRequestHandled and eCompositionCommit(AsIs)\nevents for *a* composition.  Therefore, mPendingCompositionCount may be\ndecremented twice for a composition.  This causes hitting MOZ_DIAGNOSTIC_ASSERT.\n\nSo, ContentCacheInParent need to manage if sent composition events are ignored\nor not.  Then, ContentCacheInParent::OnEventNeedingAckHandled() stops\ndecrementing mPendingCompositionCount when it receives eCompositionCommit(AsIs)\nevents which are ignored by the remote process.\n\nThis patch manages it with |mIsChildIgnoringCompositionEvents| and changes\n|bool mIsPendingLastCommitEvent| to |uint8_t mPendingCommitCount| for\nmaking ContentCache be able to manage multiple pending commit events if\nits remote process is too busy.\n\nMozReview-Commit-ID: CYQDeZXl7TJ", "files": ["widget/ContentCache.cpp", "widget/ContentCache.h"], "git_node": null, "git_parents": [null], "node": "df953324066b58824a34bcdedf7704674452b60d", "parents": ["1dc54b85de4dc4591fa46dab70a31ed79be4e41d"], "tags": []}, {"author": "Thom Chiovoloni \u003ctchiovoloni@mozilla.com\u003e", "branch": "default", "desc": "Bug 1423122 - Use the correct selection object in the getSelectionInfo when an input element is selected r=Felipe a=gchang\n\nMozReview-Commit-ID: L8nANaiYfyc", "files": ["toolkit/modules/BrowserUtils.jsm", "toolkit/modules/tests/browser/browser.ini", "toolkit/modules/tests/browser/browser_BrowserUtils.js", "toolkit/modules/tests/browser/file_getSelectionDetails_inputs.html"], "git_node": null, "git_parents": [null], "node": "23dd8e97b482d748b5c5ebea0a1d9d679bd66866", "parents": ["df953324066b58824a34bcdedf7704674452b60d"], "tags": []}, {"author": "Christian Sadilek \u003ccsadilek@mozilla.com\u003e", "branch": "default", "desc": "Bug 1424292 - Pocket referrer only sent when story has HTTPS URL r=Mardak a=gchang\n\nMozReview-Commit-ID: 5u18oc0GiNx", "files": ["browser/extensions/activity-stream/lib/ActivityStream.jsm"], "git_node": null, "git_parents": [null], "node": "f8ae2687ccc18da13270339d5a0c19fb41c72cb0", "parents": ["23dd8e97b482d748b5c5ebea0a1d9d679bd66866"], "tags": []}, {"author": "Florian Qu\u00e8ze \u003cflorian@queze.net\u003e", "branch": "default", "desc": "Bug 1424343 - Stop migrating the browser.search.selectedEngine preference, r=adw a=gchang", "files": ["browser/components/nsBrowserGlue.js"], "git_node": null, "git_parents": [null], "node": "96355d26b932219a8081bfe21ee80048e12ce274", "parents": ["f8ae2687ccc18da13270339d5a0c19fb41c72cb0"], "tags": []}], "date": 1513091748, "git_changesets": [null, null, null, null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "8370": {"changesets": [{"author": "Alexandre Poirot \u003cpoirot.alex@gmail.com\u003e", "branch": "default", "desc": "Bug 1408708 - Fetch stylesheet content via stylesheet window instead of top level content window. r=pbro a=lizzard\n\nMozReview-Commit-ID: AKXQLNAwy8t", "files": ["devtools/client/styleeditor/test/browser.ini", "devtools/client/styleeditor/test/browser_styleeditor_bug_1405342_serviceworker_iframes.js", "devtools/client/styleeditor/test/bug_1405342_serviceworker_iframes.html", "devtools/client/styleeditor/test/iframe_service_worker.js", "devtools/client/styleeditor/test/iframe_with_service_worker.html", "devtools/server/actors/stylesheets.js", "devtools/shared/DevToolsUtils.js"], "git_node": null, "git_parents": [null], "node": "198a20c061dadba7366c0963ec845823c8e9a034", "parents": ["96355d26b932219a8081bfe21ee80048e12ce274"], "tags": []}], "date": 1513092146, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "8371": {"changesets": [{"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Bug 1423122 - Use the correct selection object in the getSelectionInfo when an input element is selected: Add newline to fix eslint failure r=eslint a=Aryx", "files": ["npm-shrinkwr