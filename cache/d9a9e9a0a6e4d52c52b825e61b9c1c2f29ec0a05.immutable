kolib/glue.rs", "servo/tests/unit/style/animated_properties.rs", "servo/tests/unit/style/properties/serialization.rs"], "git_node": null, "git_parents": [null], "node": "92ff0c88e94d176ff9615abe61322413b7f38e55", "parents": ["6bc39f03ea571fb109ae603b0c8f69778ec14384"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1413858 - Resume() needs to reset mPendingSeekOffset before calling Seek(). r=gerald\n\nMozReview-Commit-ID: GbZ3SvSTMvR", "files": ["dom/media/ChannelMediaResource.cpp"], "git_node": null, "git_parents": [null], "node": "3aba4a72b8a524e137d45ae2e9545e6344fa584d", "parents": ["92ff0c88e94d176ff9615abe61322413b7f38e55"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1414073 - Rename arena_bin_t fields. r=njn\n\nAt the same time, fold malloc_bin_stats_t into it.", "files": ["memory/build/mozjemalloc.cpp"], "git_node": null, "git_parents": [null], "node": "e6d86b7284bae701700b9d300ee1476ebe5f3eed", "parents": ["3aba4a72b8a524e137d45ae2e9545e6344fa584d"], "tags": []}, {"author": "Ricky Chien \u003cricky060709@gmail.com\u003e", "branch": "default", "desc": "Bug 1413941 - Fix broken netmonitor launchpad regression from bug 1360457 r=Honza\n\nMozReview-Commit-ID: 6EzLlNfQ4FX", "files": ["devtools/client/netmonitor/src/components/RequestList.js", "devtools/client/netmonitor/src/components/RequestListEmptyNotice.js", "devtools/client/netmonitor/src/components/Toolbar.js"], "git_node": null, "git_parents": [null], "node": "180cd6b0a9748b0de0c563a7d58d8be7eedc94c8", "parents": ["e6d86b7284bae701700b9d300ee1476ebe5f3eed"], "tags": []}, {"author": "Ricky Chien \u003cricky060709@gmail.com\u003e", "branch": "default", "desc": "Bug 1413829 - RequestListContent scroll to bottom should avoid sync reflow r=Honza\n\nMozReview-Commit-ID: KwPVFJfRQQK", "files": ["devtools/client/netmonitor/src/components/RequestListContent.js"], "git_node": null, "git_parents": [null], "node": "6af2bb14bd4c1ada3e9dc68ff9c40b3a9e0893e0", "parents": ["180cd6b0a9748b0de0c563a7d58d8be7eedc94c8"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1413484 - tighten some assertions. r=gerald\n\nmCallback-\u003eGetMediaOwner() now is always called before Close() and won't\nreturn null. So is owner-\u003eGetMediaElement().\n\nMozReview-Commit-ID: HbxbyuogYAB", "files": ["dom/media/ChannelMediaResource.cpp"], "git_node": null, "git_parents": [null], "node": "1955a40abe6fadb8a2a870a98a626e3e4b6bae40", "parents": ["6af2bb14bd4c1ada3e9dc68ff9c40b3a9e0893e0"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411808. P1 - run Update() loops off the main thread. r=gerald\n\nNote we will fix bugs required to run Update() off the main thread\nin the following patches.\n\nMozReview-Commit-ID: CYwT5kDjD9R", "files": ["dom/media/MediaCache.cpp"], "git_node": null, "git_parents": [null], "node": "f26682779a1841d5ff52797e9693dee02d8fbade", "parents": ["1955a40abe6fadb8a2a870a98a626e3e4b6bae40"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411808. P2 - don't call mClient-\u003eIsSuspended() off the main thread in Update(). r=gerald\n\nBy mirroring the suspend status of the client, Update() is able to make\ndecisions on reading streams without calling mClient-\u003eIsSuspended().\n\nMozReview-Commit-ID: G4gS2VGiMjj", "files": ["dom/media/ChannelMediaResource.cpp", "dom/media/ChannelMediaResource.h", "dom/media/MediaCache.cpp", "dom/media/MediaCache.h"], "git_node": null, "git_parents": [null], "node": "875d91b29c311400cc3108f959da53d09bab66b3", "parents": ["f26682779a1841d5ff52797e9693dee02d8fbade"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411808. P3 - InitAsClone() shouldn't call |mMediaCache-\u003eOpenStream(this)| until initialization is done. r=gerald\n\nWe don't want MediaCache to use a half-initialized stream.\n\nMozReview-Commit-ID: LjPLOYwy0Wd", "files": ["dom/media/MediaCache.cpp", "dom/media/MediaCache.h"], "git_node": null, "git_parents": [null], "node": "efbfeacfdb9621ab2c67b2400cb89d92669b6c53", "parents": ["875d91b29c311400cc3108f959da53d09bab66b3"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1414097 - Convert nsDisplaySelectionOverlay to WebRender. r=ethlin\n\nMozReview-Commit-ID: 5icpe4OR0Qa", "files": ["layout/generic/nsFrame.cpp"], "git_node": null, "git_parents": [null], "node": "e15cf10f369acd8129126525c349ade395abf876", "parents": ["efbfeacfdb9621ab2c67b2400cb89d92669b6c53"], "tags": []}, {"author": "abhinav \u003cabhinav.koppula@gmail.com\u003e", "branch": "default", "desc": "Bug 1407561 - Lazy loading of tooltip text when user hovers the status column. r=gasolin\n\nMozReview-Commit-ID: BXP8B10Q5LT", "files": ["devtools/client/netmonitor/src/components/RequestListColumnStatus.js", "devtools/client/netmonitor/test/browser_net_brotli.js", "devtools/client/netmonitor/test/browser_net_cached-status.js", "devtools/client/netmonitor/test/browser_net_content-type.js", "devtools/client/netmonitor/test/browser_net_cyrillic-01.js", "devtools/client/netmonitor/test/browser_net_cyrillic-02.js", "devtools/client/netmonitor/test/browser_net_filter-01.js", "devtools/client/netmonitor/test/browser_net_filter-02.js", "devtools/client/netmonitor/test/browser_net_filter-flags.js", "devtools/client/netmonitor/test/browser_net_json-long.js", "devtools/client/netmonitor/test/browser_net_json-malformed.js", "devtools/client/netmonitor/test/browser_net_json_custom_mime.js", "devtools/client/netmonitor/test/browser_net_json_text_mime.js", "devtools/client/netmonitor/test/browser_net_jsonp.js", "devtools/client/netmonitor/test/browser_net_large-response.js", "devtools/client/netmonitor/test/browser_net_post-data-01.js", "devtools/client/netmonitor/test/browser_net_req-resp-bodies.js", "devtools/client/netmonitor/test/browser_net_service-worker-status.js", "devtools/client/netmonitor/test/browser_net_simple-request-data.js", "devtools/client/netmonitor/test/browser_net_sort-01.js", "devtools/client/netmonitor/test/browser_net_sort-02.js", "devtools/client/netmonitor/test/browser_net_status-codes.js", "devtools/client/netmonitor/test/browser_net_streaming-response.js"], "git_node": null, "git_parents": [null], "node": "2c77266e1b40c7a67901de4c3ccca2554422da4a", "parents": ["e15cf10f369acd8129126525c349ade395abf876"], "tags": []}, {"author": "Ethan Lin \u003cethlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1413397 - Avoid empty border's fallback. r=kats\n\nMozReview-Commit-ID: 1KXYjcObJdi", "files": ["layout/forms/nsButtonFrameRenderer.cpp", "layout/forms/nsButtonFrameRenderer.h", "layout/generic/nsColumnSetFrame.cpp", "layout/mathml/nsMathMLmtableFrame.cpp", "layout/painting/nsCSSRendering.cpp", "layout/painting/nsCSSRendering.h", "layout/painting/nsDisplayList.cpp", "layout/painting/nsDisplayList.h"], "git_node": null, "git_parents": [null], "node": "a16aef250227226e3abe41cf0e835fdbb57ded13", "parents": ["2c77266e1b40c7a67901de4c3ccca2554422da4a"], "tags": []}, {"author": "Ethan Lin \u003cethlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1413680 - DrawTargetRecording should return the real size instead of the dummy drawtarget's size. r=jrmuizel\n\nMozReview-Commit-ID: E63f8ZIGYm2", "files": ["gfx/2d/DrawTargetRecording.h"], "git_node": null, "git_parents": [null], "node": "9ee2bbdb739021cf352e4cac630d0bdd596b6c33", "parents": ["a16aef250227226e3abe41cf0e835fdbb57ded13"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403358 Only reference ActivationContext if Acessibility is enabled r=aklotz\n\nThis also enables the crash reporter on the MinGW build, as this is the\nonly thing blocking that from working.\n\nMozReview-Commit-ID: Hygd7UUQvwl", "files": ["browser/config/mozconfigs/win32/mingw32", "ipc/mscom/ProxyStream.cpp"], "git_node": null, "git_parents": [null], "node": "12f7bd502d4dbff24bc1e381de45df9c41cf5f6f", "parents": ["9ee2bbdb739021cf352e4cac630d0bdd596b6c33"], "tags": []}, {"author": "Kit Cambridge \u003ckit@yakshaving.ninja\u003e", "branch": "default", "desc": "Bug 1368209 - Add support for `sortindex` and `older` to the mock Sync server. r=tcsc\n\nMozReview-Commit-ID: 6YI1OEE8x7R", "files": ["services/sync/tests/unit/head_http_server.js"], "git_node": null, "git_parents": [null], "node": "4b8e56844ae98e4129f567c23491f34d4f6ce708", "parents": ["12f7bd502d4dbff24bc1e381de45df9c41cf5f6f"], "tags": []}, {"author": "Kit Cambridge \u003ckit@yakshaving.ninja\u003e", "branch": "default", "desc": "Bug 1368209 - Add a test for fetching backlogged history records. r=tcsc\n\nThe test captures the existing logic in `_processIncoming`, even though\nit's not quite correct:\n\n* First, we fetch all records changed since the last sync, up to the\n  download limit, and without an explicit sort order. This happens to\n  work correctly now because the Python server uses \"newest\" by\n  default, but can change in the future.\n* If we reached the download limit fetching records, we request\n  IDs for all records changed since the last sync, also up to the\n  download limit, and sorted by index. This is likely to return IDs\n  for records we've already seen, since the index is based on the\n  frecency. It's also likely to miss IDs for other changed records,\n  because the number of changed records might be higher than the\n  download limit.\n* Since we then fast-forward the last sync time, we'll never download\n  any remaining changed records that we didn't add to our backlog.\n* Finally, we backfill previously failed and backlogged records.\n\nMozReview-Commit-ID: 7uQLXMseMIU", "files": ["services/sync/modules/engines.js", "services/sync/tests/unit/test_history_engine.js", "services/sync/tests/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "b88c681ccdc1614c3589730e72ac37ff342d22a7", "parents": ["4b8e56844ae98e4129f567c23491f34d4f6ce708"], "tags": []}, {"author": "Kit Cambridge \u003ckit@yakshaving.ninja\u003e", "branch": "default", "desc": "Bug 1368209 - Refactor `Engine::_processIncoming` into three stages. r=eoger,tcsc\n\n* In the first stage, we fetch changed records, newest first, up to the\n  download limit. We keep track of the oldest record modified time we\n  see.\n* Once we've fetched all records, we reconcile, noting records that\n  fail to decrypt or reconcile for the next sync. We then ask the store\n  to apply all remaining records. Previously, `applyIncomingBatchSize`\n  specified how many records to apply at a time. I removed this because\n  it added an extra layer of indirection that's no longer necessary,\n  now that download batching buffers all records in memory, and all\n  stores are async.\n* In the second stage, we fetch IDs for all remaining records changed\n  between the last sync and the oldest modified time we saw in the\n  first stage. We *don't* set the download limit here, to ensure we\n  add *all* changed records to our backlog, and we use the `\"oldest\"`\n  sort order instead of `\"index\"`.\n* In the third stage, we backfill as before. We don't want large deltas\n  to delay other engines from syncing, so we still only take IDs up to\n  the download limit from the backlog, and include failed IDs from the\n  previous sync. On subsequent syncs, we'll keep fetching from the\n  backlog until it's empty.\n\nOther changes to note in this patch:\n\n* `Collection::_rebuildURL` now allows callers to specify both `older`\n  and `newer`. According to :rfkelly, this is explicitly and\n  intentionally supported.\n* Tests that exercise `applyIncomingBatchSize` are gone, since that's\n  no longer a thing.\n* The test server now shuffles records if the sort order is\n  unspecified.\n\nMozReview-Commit-ID: 4EXvNOa8mIo", "files": ["services/sync/modules/constants.js", "services/sync/modules/engines.js", "services/sync/modules/engines/forms.js", "services/sync/modules/engines/history.js", "services/sync/modules/engines/passwords.js", "services/sync/modules/record.js", "services/sync/tests/unit/head_http_server.js", "services/sync/tests/unit/test_history_engine.js", "services/sync/tests/unit/test_syncengine_sync.js", "testing/modules/TestUtils.jsm", "toolkit/components/places/PlacesSyncUtils.jsm"], "git_node": null, "git_parents": [null], "node": "1b868efa368f0e8f2caa4df8568fca04f756a00e", "parents": ["b88c681ccdc1614c3589730e72ac37ff342d22a7"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1404850 - Fix self-XSS protection in new console and enable test; r=Honza.\n\nThe self-XSS protection was broken since the switch to an HTML document. We\nwent from using the XUL \u003cnotificationbox\u003e tag to a simple div.\nBut notificationbox has method that a simple div has not, and when trying\nto display the warning message, there was an error in terminal.\nThis patch uses the NotificationBox React component and create it when needed.\nIt also rename and enable the test that ensures that XSS is working.\n\nMozReview-Commit-ID: BhxIqf7gzAG", "files": ["devtools/client/shared/components/NotificationBox.js", "devtools/client/webconsole/jsterm.js", "devtools/client/webconsole/new-console-output/test/mochitest/browser.ini", "devtools/client/webconsole/new-console-output/test/mochitest/browser_jsterm_selfxss.js", "devtools/client/webconsole/new-console-output/test/mochitest/browser_webconsole_autocomplete_and_selfxss.js", "devtools/client/webconsole/webconsole.html"], "git_node": null, "git_parents": [null], "node": "dfc3f11935aa57dbb750007a59c1758933cb957e", "parents": ["1b868efa368f0e8f2caa4df8568fca04f756a00e"], "tags": []}, {"author": "Moritz Brunner \u003cmoritzbrunner@freenet.de\u003e", "branch": "default", "desc": "Bug 366192 - Fixed http/https regex checks. r=mak\n\nMozReview-Commit-ID: FL0AWkM9Ggm", "files": ["toolkit/mozapps/handling/content/dialog.js"], "git_node": null, "git_parents": [null], "node": "bbbd75cd12a945396d21f2000f5a9d4bc09602bb", "parents": ["dfc3f11935aa57dbb750007a59c1758933cb957e"], "tags": []}, {"author": "NARCIS BELEUZU \u003cnbeleuzu@mozilla.com\u003e", "branch": "default", "desc": "Backed out 3 changesets (bug 1368209)xpcshell failures services/sync/tests/unit/test_syncengine_sync.js on CLOSED TREE\n\nBacked out changeset 1b868efa368f (bug 1368209)\nBacked out changeset b88c681ccdc1 (bug 1368209)\nBacked out changeset 4b8e56844ae9 (bug 1368209)", "files": ["services/sync/modules/constants.js", "services/sync/modules/engines.js", "services/sync/modules/engines/forms.js", "services/sync/modules/engines/history.js", "services/sync/modules/engines/passwords.js", "services/sync/modules/record.js", "services/sync/tests/unit/head_http_server.js", "services/sync/tests/unit/test_history_engine.js", "services/sync/tests/unit/test_syncengine_sync.js", "services/sync/tests/unit/xpcshell.ini", "testing/modules/TestUtils.jsm", "toolkit/components/places/PlacesSyncUtils.jsm"], "git_node": null, "git_parents": [null], "node": "f7206a54b9aaa37e811b91d8bb07f0901280bac5", "parents": ["bbbd75cd12a945396d21f2000f5a9d4bc09602bb"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1410940 - Make PlacesController#paste and PlacesControllerDragHelper#onDrop more similar to each other. r=mak\n\nMozReview-Commit-ID: EEFizNPmKpr", "files": ["browser/components/places/content/controller.js", "browser/components/places/tests/browser/browser.ini", "browser/components/places/tests/browser/browser_controller_onDrop_tagFolder.js"], "git_node": null, "git_parents": [null], "node": "37ceb314b2b3ae5c629a028dd5ac46c222015a56", "parents": ["f7206a54b9aaa37e811b91d8bb07f0901280bac5"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1410940 - Unify the parts of onDrop and paste that get the transaction information. r=mak\n\nThis also fixes inserting bookmarks on paste at the right insertion points.\n\nMozReview-Commit-ID: Km93oZt1UHm", "files": ["browser/components/places/content/controller.js", "browser/components/places/tests/browser/browser_controller_onDrop.js", "browser/components/places/tests/browser/browser_paste_bookmarks.js"], "git_node": null, "git_parents": [null], "node": "1c78029ded02384d293d27421ec5cce979f3d391", "parents": ["37ceb314b2b3ae5c629a028dd5ac46c222015a56"], "tags": []}, {"author": "James Cheng \u003cjacheng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1396698 - Part1 - Remove the dispatchTo gecko main thread attribute. r=kikuo\n\nMozReview-Commit-ID: 9Opa894ZQMQ", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/media/GeckoHLSResourceWrapper.java", "widget/android/GeneratedJNIWrappers.h"], "git_node": null, "git_parents": [null], "node": "b8fe495f5f4ba6510e08665031ae72da97b0de4c", "parents": ["1c78029ded02384d293d27421ec5cce979f3d391"], "tags": []}, {"author": "James Cheng \u003cjacheng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1396698 - Part2 - Dispatch to mainthread by ourself and do the synchronization to avoid race. r=kikuo\n\nMozReview-Commit-ID: 6rA2TvESyEz", "files": ["dom/media/hls/HLSDecoder.cpp"], "git_node": null, "git_parents": [null], "node": "183249d9d7f77f3c0f3ef13b7e5c18cb4feb40ec", "parents": ["b8fe495f5f4ba6510e08665031ae72da97b0de4c"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1413400 (part 1) - Move s{,Default}RootBranch into Preferences. r=froydnj.\n\nsRootBranch and sDefaultRootBranch have the same lifetime as sPreferences, so\nthis patch makes them non-static nsCOMPtr\u003c\u003e members of Preferences.\n\nMozReview-Commit-ID: 1TLhh13ZpBI", "files": ["modules/libpref/Preferences.cpp", "modules/libpref/Preferences.h"], "git_node": null, "git_parents": [null], "node": "352bbd41f1fa04267235faeec42dd463bcf8118a", "parents": ["008cf4865cb5cfd7766a7367875e184cf013c1c5"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1413400 (part 2) - Make Preferences::sPreferences a StaticRefPtr. r=froydnj.\n\nThe notable part of this change is Shutdown(). I've made it just null out\nsPreferences, contrary to the old comment, which was strange for a couple of\nreasons:\n\n- ~Preferences() used to null out sPreference, which is backwards compared to\n  how this sort of thing normally works.\n\n- In both the before and after cases, as far as I can tell,\n  Preferences::Shutdown() is called but ~Preferences() is never called;\n  something keeps the singleton Preferences instance alive until process\n  termination.\n\nMozReview-Commit-ID: Ab0ui31rVcI", "files": ["modules/libpref/Preferences.cpp", "modules/libpref/Preferences.h"], "git_node": null, "git_parents": [null], "node": "962343e8bdf0f90916487fcf81908589d70ff51f", "parents": ["352bbd41f1fa04267235faeec42dd463bcf8118a"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1410159: Add additional IUnknown resolution to a11y::HandlerProvider; r=Jamie\n\nMozReview-Commit-ID: 4duTGCN9xJ6", "files": ["accessible/ipc/win/HandlerProvider.cpp", "accessible/ipc/win/PlatformChild.cpp"], "git_node": null, "git_parents": [null], "node": "e255f93c08085eb8a4034d320c6af48827619908", "parents": ["962343e8bdf0f90916487fcf81908589d70ff51f"], "tags": []}, {"author": "sotaro \u003csotaro.ikeda.g@gmail.com\u003e", "branch": "default", "desc": "Bug 1408421 - Improving throttling GenerateFrame() r=jrmuizel", "files": ["gfx/layers/wr/WebRenderBridgeParent.cpp", "gfx/webrender_bindings/RenderThread.cpp", "gfx/webrender_bindings/RenderThread.h"], "git_node": null, "git_parents": [null], "node": "14a5ae97c682ed92861492a1e51f041b6d6cef40", "parents": ["e255f93c08085eb8a4034d320c6af48827619908"], "tags": []}, {"author": "NARCIS BELEUZU \u003cnbeleuzu@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-inbound to mozilla-central. r=merge a=merge", "files": [], "git_node": null, "git_parents": [null, null], "node": "4e6df5159df3e64c3c453c0db0a2e1d126819b71", "parents": ["e6d86b7284bae701700b9d300ee1476ebe5f3eed", "14a5ae97c682ed92861492a1e51f041b6d6cef40"], "tags": []}, {"author": "NARCIS BELEUZU \u003cnbeleuzu@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland. r=merge a=merge on CLOSED TREE", "files": [], "git_node": null, "git_parents": [null, null], "node": "83fe273bfdf2c388359f7dfe66e1dedb09ebf53f", "parents": ["183249d9d7f77f3c0f3ef13b7e5c18cb4feb40ec", "4e6df5159df3e64c3c453c0db0a2e1d126819b71"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411640 - Consolidate \u003cradio\u003e bindings and styling across platforms. r=bgrins\n\nMozReview-Commit-ID: p4dxfdpTs3", "files": ["browser/themes/shared/customizableui/panelUI.inc.css", "toolkit/themes/linux/global/global.css", "toolkit/themes/linux/global/in-content/common.css", "toolkit/themes/linux/global/radio.css", "toolkit/themes/osx/global/radio.css", "toolkit/themes/shared/in-content/common.inc.css", "toolkit/themes/shared/non-mac.jar.inc.mn", "toolkit/themes/windows/global/checkbox.css", "toolkit/themes/windows/global/global.css", "toolkit/themes/windows/global/globalBindings.xml", "toolkit/themes/windows/global/in-content/common.css", "toolkit/themes/windows/global/radio.css", "toolkit/themes/windows/global/radio/radio-check-dis.gif", "toolkit/themes/windows/global/radio/radio-check.gif"], "git_node": null, "git_parents": [null], "node": "4e49de4bbc6f0647dd82b752e52961106e7d4879", "parents": ["83fe273bfdf2c388359f7dfe66e1dedb09ebf53f"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1295886 - P1. Remove unused flac parser. r=gerald\n\nAll the flac parser jobs are done by FlacDemuxer\n\nMozReview-Commit-ID: L7VZG64gi52", "files": ["media/ffvpx/FILES", "media/ffvpx/README_MOZILLA", "media/ffvpx/config_darwin32.h", "media/ffvpx/config_darwin64.asm", "media/ffvpx/config_darwin64.h", "media/ffvpx/config_unix32.h", "media/ffvpx/config_unix64.asm", "media/ffvpx/config_unix64.h", "media/ffvpx/config_win32.asm", "media/ffvpx/config_win32.h", "media/ffvpx/config_win64.asm", "media/ffvpx/config_win64.h", "media/ffvpx/libavcodec/dummy_funcs.c", "media/ffvpx/libavcodec/flac_parser.c", "media/ffvpx/libavcodec/moz.build"], "git_node": null, "git_parents": [null], "node": "f682de302ea19ea7df2c62ccea026badd36b4bdd", "parents": ["4e49de4bbc6f0647dd82b752e52961106e7d4879"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1295886 - P2. Extract FFmpeg BSF config options. r=gerald\n\nWill simplify future resync.\n\nMozReview-Commit-ID: CwkIFKYvWsL", "files": ["media/ffvpx/README_MOZILLA", "media/ffvpx/config_darwin32.h", "media/ffvpx/config_darwin64.asm", "media/ffvpx/config_darwin64.h", "media/ffvpx/config_unix32.h", "media/ffvpx/config_unix64.asm", "media/ffvpx/config_unix64.h", "media/ffvpx/config_win32.asm", "media/ffvpx/config_win32.h", "media/ffvpx/config_win64.asm", "media/ffvpx/config_win64.h", "media/ffvpx/defaults_disabled.h"], "git_node": null, "git_parents": [null], "node": "6ba63e774fa9d804abe48604040e16aa1a7636b5", "parents": ["f682de302ea19ea7df2c62ccea026badd36b4bdd"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1295886 - P3. Remove darwin 32 bits support. r=gerald\n\nOS X 32 bits is no longer supported.\n\nMozReview-Commit-ID: 2SFxDUeQvpB", "files": ["media/ffvpx/README_MOZILLA", "media/ffvpx/config.h", "media/ffvpx/config_darwin32.h"], "git_node": null, "git_parents": [null], "node": "13389b0adb69b01fdd356bb1a463ee5f9afaceb4", "parents": ["6ba63e774fa9d804abe48604040e16aa1a7636b5"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1295886 - P4. Ensure HAVE_STDATOMIC_H is properly defined. r=gerald\n\nMozReview-Commit-ID: GDeob2KCAcq", "files": ["media/ffvpx/config_darwin64.asm", "media/ffvpx/config_darwin64.h", "media/ffvpx/config_unix32.h", "media/ffvpx/config_unix64.asm", "media/ffvpx/config_win32.asm", "media/ffvpx/config_win32.h", "media/ffvpx/config_win64.asm", "media/ffvpx/config_win64.h"], "git_node": null, "git_parents": [null], "node": "ee67bb4e6b7ab12ef6a4f294b92351083b70c2a6", "parents": ["13389b0adb69b01fdd356bb1a463ee5f9afaceb4"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1295886 - P5. Add flac support on Android. r=gerald\n\nFor now this is a C decoder only and FFmpeg isn't optimised to only decode flac (both vp8 and vp9 C decoders code is included, however they aren't enabled).\n\nMozReview-Commit-ID: 7ulwvJDJqVg", "files": ["media/ffvpx/README_MOZILLA", "media/ffvpx/config.h", "media/ffvpx/config_android.h", "old-configure.in"], "git_node": null, "git_parents": [null], "node": "c5db9b9847770bd9699fbe4ad21ae2e6467e60b6", "parents": ["ee67bb4e6b7ab12ef6a4f294b92351083b70c2a6"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1295886 - P6. Add ffmpeg libs to package manifest. r=snorp\n\nMozReview-Commit-ID: EhGDbCGycLe", "files": ["mobile/android/installer/package-manifest.in"], "git_node": null, "git_parents": [null], "node": "a7674738651f1bd54aa3fc6a79bf98091eb4c8ce", "parents": ["c5db9b9847770bd9699fbe4ad21ae2e6467e60b6"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1295886 - P7. Add support for S16 decoded output. r=gerald\n\nAndroid audio backend only supports S16 audio sample, so configure ffmpeg audio decoder to output 16 bits audio by default. Adding format conversions as necessary.\n\nMozReview-Commit-ID: J6N4rbMZ3Ug", "files": ["dom/media/platforms/ffmpeg/FFmpegAudioDecoder.cpp"], "git_node": null, "git_parents": [null], "node": "e6126e000672d4dea0f0d5d62cf92ac5feb6ae84", "parents": ["a7674738651f1bd54aa3fc6a79bf98091eb4c8ce"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1295886 - P8. Never use AndroidDecoderModule to decode FLAC. r=gerald\n\nThe behaviour of the system decoder is unpredictable.\n\nMozReview-Commit-ID: FubvCm0xyiL", "files": ["dom/media/platforms/android/AndroidDecoderModule.cpp"], "git_node": null, "git_parents": [null], "node": "003bffedc86e14fb6098c07d0fd16542dad33338", "parents": ["e6126e000672d4dea0f0d5d62cf92ac5feb6ae84"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1295886 - P9. Fix linkage of libmozav* libs on Android. r=snorp\n\nUsing flag PR_LD_LOCAL causes PR_LoadLibraryWithFlags to fail, and there should be no difference with PR_LD_GLOBAL anyway on Android.\n\nMozReview-Commit-ID: DAduV8yg8Sx", "files": ["dom/media/platforms/ffmpeg/ffvpx/FFVPXRuntimeLinker.cpp"], "git_node": null, "git_parents": [null], "node": "f34a22b5d9ffa39835ba7c4df23675a04c7bc1ff", "parents": ["003bffedc86e14fb6098c07d0fd16542dad33338"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1295886 - P10. Add a FLAC only option to ffvpx. r=gerald\n\nRemove the VP8 and VP9 decoder and the subsequently unused functions.\n\nThis drops the size to libmozavcodec to around 1MB down from 4MB.\n\nMozReview-Commit-ID: Ge57fauG35L", "files": ["media/ffvpx/libavcodec/moz.build", "media/ffvpx/libavutil/moz.build", "old-configure.in"], "git_node": null, "git_parents": [null], "node": "fbcfbb6be12f4c16ab0d5fb04d7d4ef030d7a566", "parents": ["f34a22b5d9ffa39835ba7c4df23675a04c7bc1ff"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1295886 - P11. Enable FFmpeg small mode. r=gerald\n\nThis mostly removes static strings declaration, replacing them with null pointers.\n\nIt does cause to switch to algorithms that are more geared toward space saving than speed gain. However, those are mostly in hash calculations, which the FLAC decoder doesn't use.\n\nMozReview-Commit-ID: 6Kl6xxlBOnw", "files": ["media/ffvpx/config_android.h", "media/ffvpx/libavcodec/moz.build"], "git_node": null, "git_parents": [null], "node": "8ed7a7c6472feb6b8784be1e5bfd4e7419142077", "parents": ["fbcfbb6be12f4c16ab0d5fb04d7d4ef030d7a566"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1295886 - P12. Have a generic C-only FLAC decoder. r=gerald\n\nMozReview-Commit-ID: C6A9YNaZBvZ", "files": ["media/ffvpx/config.h", "media/ffvpx/config_android.h", "media/ffvpx/config_flac.h"], "git_node": null, "git_parents": [null], "node": "2a9ed25ca816ec7ead0920df06940fd17c904787", "parents": ["8ed7a7c6472feb6b8784be1e5bfd4e7419142077"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1295886 - P13. Disable FAST_CLZ on Windows. r=gerald\n\nIt may not be supported on all CPUs.\n\nSee\nhttps://chromium-review.googlesource.com/c/chromium/third_party/ffmpeg/+/344671\n\nMozReview-Commit-ID: 643jBtSS1Fl", "files": ["media/ffvpx/config_flac.h", "media/ffvpx/config_win32.asm", "media/ffvpx/config_win32.h", "media/ffvpx/config_win64.asm", "media/ffvpx/config_win64.h", "media/ffvpx/libavcodec/moz.build", "media/ffvpx/libavutil/moz.build"], "git_node": null, "git_parents": [null], "node": "e9649d83f2be568ff2af337b2f1f46b15edb8b40", "parents": ["2a9ed25ca816ec7ead0920df06940fd17c904787"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1295886 - P14. Add arm neon and vfp optimized methods to ffmpeg. r=mshal\n\nMozReview-Commit-ID: KMUZoDWoisi", "files": ["media/ffvpx/config.h", "media/ffvpx/config_android32.h", "media/ffvpx/ffvpxcommon.mozbuild", "media/ffvpx/libavcodec/arm/flacdsp_arm.S", "media/ffvpx/libavcodec/arm/flacdsp_init_arm.c", "media/ffvpx/libavcodec/arm/mathops.h", "media/ffvpx/libavcodec/arm/moz.build", "media/ffvpx/libavcodec/dummy_funcs.c", "media/ffvpx/libavcodec/moz.build", "media/ffvpx/libavutil/arm/asm.S", "media/ffvpx/libavutil/arm/bswap.h", "media/ffvpx/libavutil/arm/cpu.c", "media/ffvpx/libavutil/arm/cpu.h", "media/ffvpx/libavutil/arm/float_dsp_arm.h", "media/ffvpx/libavutil/arm/float_dsp_init_arm.c", "media/ffvpx/libavutil/arm/float_dsp_init_neon.c", "media/ffvpx/libavutil/arm/float_dsp_init_vfp.c", "media/ffvpx/libavutil/arm/float_dsp_neon.S", "media/ffvpx/libavutil/arm/float_dsp_vfp.S", "media/ffvpx/libavutil/arm/intmath.h", "media/ffvpx/libavutil/arm/intreadwrite.h", "media/ffvpx/libavutil/arm/moz.build", "media/ffvpx/libavutil/arm/timer.h", "media/ffvpx/libavutil/dummy_funcs.c", "media/ffvpx/libavutil/moz.build", "old-configure.in"], "git_node": null, "git_parents": [null], "node": "cd2b7c34307eef0bf59b1a2184e1be5cc7c4d897", "parents": ["e9649d83f2be568ff2af337b2f1f46b15edb8b40"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1295886 - P15. Enable FLAC mochitest on Android. r=gerald\n\nMozReview-Commit-ID: 83mJleAMVro", "files": ["dom/media/mediasource/test/mochitest.ini", "dom/media/test/test_can_play_type_mpeg.html"], "git_node": null, "git_parents": [null], "node": "c387badaa88ba586c1fee17aabc35521ec781b42", "parents": ["cd2b7c34307eef0bf59b1a2184e1be5cc7c4d897"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1295886 - P16. Enable FLAC C decoder on aarch64 machines. r=mshal\n\nMozReview-Commit-ID: 9i3AaG5CGex", "files": [