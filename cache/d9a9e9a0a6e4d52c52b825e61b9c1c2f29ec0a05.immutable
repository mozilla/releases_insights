ting/web-platform/meta/encrypted-media/drm-temporary-license-type.https.html.ini"], "git_node": null, "git_parents": [null], "node": "6039726995022771be1e7a853fcc238f9fbac829", "parents": ["294ccf3ffc059ff6a206291715bcaa363a0cee0d"], "tags": []}, {"author": "James Cheng \u003cjacheng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1413427 - Part5 - Fix cross origin test failure. r=bz,jgraham\n\nBug 1322517 will make the EME APIs only run on secure context.\nThis bug will try to make WPT test run with https.\nAccording to the spec https://www.w3.org/TR/secure-contexts/#is-url-trustworthy\nI got \"TypeError: navigator.requestMediaKeySystemAccess is not a function\" by the original code.\nSo I need this patch to make the test work as expected.\n\nMozReview-Commit-ID: Gp23IcscXHE", "files": ["testing/web-platform/tests/encrypted-media/scripts/unique-origin.js"], "git_node": null, "git_parents": [null], "node": "8a306a5bc1da4a6c1ff7d3cd695b95bdfdccc0f4", "parents": ["6039726995022771be1e7a853fcc238f9fbac829"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415397 - use Span\u003c\u003e to replace low level pointer arithmetic in ReadFromCache(). r=bechen,gerald\n\nMozReview-Commit-ID: HH6KXtMfSIJ", "files": ["dom/media/MediaCache.cpp", "dom/media/MediaCache.h"], "git_node": null, "git_parents": [null], "node": "05002ad2b8f98d392a10811ce12f332ce2258210", "parents": ["8a306a5bc1da4a6c1ff7d3cd695b95bdfdccc0f4"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415766. P1 - we never pass anything other than NS_SEEK_SET to Seek(). r=bechen,gerald\n\nMozReview-Commit-ID: AgvapCwwSpr", "files": ["dom/media/MediaCache.cpp", "dom/media/MediaCache.h"], "git_node": null, "git_parents": [null], "node": "753f3591930d7a1ef1cd2a8e4cbe9e0f6b57d901", "parents": ["05002ad2b8f98d392a10811ce12f332ce2258210"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415766. P2 - move Seek() to private and tighten up some assertions. r=bechen,gerald\n\nMozReview-Commit-ID: BBsXqKUrOi1", "files": ["dom/media/MediaCache.cpp", "dom/media/MediaCache.h"], "git_node": null, "git_parents": [null], "node": "b12b1f6beb496de17cfcaa8af70d7216853b2866", "parents": ["753f3591930d7a1ef1cd2a8e4cbe9e0f6b57d901"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415069 - Add a member to ChannelMediaResource to remember seekability of the channel. r=bechen,gerald\n\nSo it doesn't need to call mCacheStream.IsTransportSeekable() which needs to\ntake the lock and might block the main thread.\n\nMozReview-Commit-ID: 99QVcSxzjCz", "files": ["dom/media/ChannelMediaResource.cpp", "dom/media/ChannelMediaResource.h", "dom/media/MediaCache.cpp", "dom/media/MediaCache.h"], "git_node": null, "git_parents": [null], "node": "2f059a9dbd9d0b76230f53a78bf29dfad1e56d06", "parents": ["b12b1f6beb496de17cfcaa8af70d7216853b2866"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415345 - Fix undefined variable in error message in FxAccountsStorageManager#getAccountData. r=markh\n\nMozReview-Commit-ID: 4mCdPfKX5lz", "files": ["services/fxaccounts/FxAccountsStorage.jsm"], "git_node": null, "git_parents": [null], "node": "798de42346d14e277a4f2de2189d4e1870eeef8e", "parents": ["2f059a9dbd9d0b76230f53a78bf29dfad1e56d06"], "tags": []}, {"author": "Fred Lin \u003cgasolin@gmail.com\u003e", "branch": "default", "desc": "Bug 1414981 - Request URL should not show #hash;r=Honza\n\nMozReview-Commit-ID: G3FqltGcaTC", "files": ["devtools/client/netmonitor/src/components/HeadersPanel.js", "devtools/client/netmonitor/test/browser_net_status-codes.js", "devtools/client/netmonitor/test/head.js"], "git_node": null, "git_parents": [null], "node": "ffd79ce93abd8199f4c98540b9cd32c8dc4dfe38", "parents": ["798de42346d14e277a4f2de2189d4e1870eeef8e"], "tags"