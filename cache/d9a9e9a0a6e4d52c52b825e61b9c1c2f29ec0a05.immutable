75b"], "tags": []}], "date": 1510924848, "git_changesets": [null, null], "user": "ffxbld"}, "8165": {"changesets": [{"author": "Mantaroh Yoshinaga \u003cmantaroh@gmail.com\u003e", "branch": "default", "desc": "Bug 1354832 - Sort a fuzzy-if condition of bugs/368020-1.html to descending order. r=mats, a=test-only\n\nCurrent fuzzy-if of reftest will use last specified fuzzy range which condition\nis true. In this test case, all fuzzy-if condition is true and doesn't order in\ndescending. We should sort this order in descending order.\n\nMozReview-Commit-ID: 2foJaqFAOwG", "files": ["layout/reftests/bugs/reftest.list"], "git_node": null, "git_parents": [null], "node": "ac34dc4fa2d40a3756fb1d4ade0527340ff2fe37", "parents": ["20e3c8f45c0d1b04c6559bf92e2772416bba067b"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1416628 - Wait for the \"popupshown\" event when opening the Site Identity panel. r=johannh, a=test-only\n\nMozReview-Commit-ID: D6JW4h32O5T", "files": ["browser/base/content/test/siteIdentity/browser_insecureLoginForms.js"], "git_node": null, "git_parents": [null], "node": "e8f0d29cabecc5f6c83573329bbe736cbd6481e6", "parents": ["ac34dc4fa2d40a3756fb1d4ade0527340ff2fe37"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1416314 - Guard against psutil exceptions when generating system-info.log. r=jmaher, a=test-only\n\nIt seems psutil can throw a wide range of exceptions when accessing system\ninformation on aws...intermittently, of course. Let's expect and discard\nsuch exceptions so that test jobs are not dependent on creating system-info.log.", "files": ["testing/mozharness/scripts/desktop_unittest.py"], "git_node": null, "git_parents": [null], "node": "d37f4f80965b7ea351dbf4c859a6d784bded62b5", "parents": ["e8f0d29cabecc5f6c83573329bbe736cbd6481e6"], "tags": []}, {"author": "Bevis Tseng \u003cbtseng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411823 - Disable IndexedDB/keypath-exceptions.htm. r=jgraham, a=test-only\n\nThe support of keypath evaluation is incomplete. This shall be revisited in bug 1404274.", "files": ["testing/web-platform/meta/IndexedDB/keypath-exceptions.htm.ini"], "git_node": null, "git_parents": [null], "node": "139db886b646719c635ae3854262ca90c3fc0112", "parents": ["d37f4f80965b7ea351dbf4c859a6d784bded62b5"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414802 - Change mitmproxy cryptograpy package requirement to use 1.8.2. r=rwood, a=test-only", "files": ["testing/talos/talos/mitmproxy/mitmproxy_requirements.txt"], "git_node": null, "git_parents": [null], "node": "38d0314b3f91e1de1222658097443f930e5f7e4b", "parents": ["139db886b646719c635ae3854262ca90c3fc0112"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415858 - Disable h2 on win7 except for try due to slow fileIO. r=rwood, a=test-only", "files": ["taskcluster/ci/test/talos.yml"], "git_node": null, "git_parents": [null], "node": "a144f70802556b43c56fb9f967b5a2ee7f5feec5", "parents": ["38d0314b3f91e1de1222658097443f930e5f7e4b"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415247 - Warn if Firefox is running before mochitest starts Firefox. r=jmaher, a=test-only\n\nWhen running mochitests in automation, we expect no more than 1 instance of\nFirefox to be running at any time: the browser under test. In local testing\nscenarios, additional browser instances might be running.\n\nWarn when mochitests find additional 'firefox' instances running before launching\na browser for testing, to make it easier to detect anomalies in automation.", "files": ["testing/mochitest/runtests.py"], "git_node": null, "git_parents": [null], "node": "c8042c122490e90495e8c37993406f0c63eb6735", "parents": ["a144f70802556b43c56fb9f967b5a2ee7f5feec5"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415290 - Check return codes in mozcrash kill_pid. r=jmaher, a=test-only", "files": ["testing/mochitest/runtests.py", "testing/mozbase/mozcrash/mozcrash/mozcrash.py"], "git_node": null, "git_parents": [null], "node": "1d4a6dc2023c7332de374aade71742917b40d726", "parents": ["c8042c122490e90495e8c37993406f0c63eb6735"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1339568 - Disable 4 dom/media mochitests on Linux Debug, in hopes of avoiding a shutdown hang. r=jmaher, a=test-only\n\nThis is a speculative \"fix\" for a chronic shutdown hang in mochitest-media-e10s-2,\ngenerally reported in bug 1411358. Experiments on try suggest that the hang\noccurs much less frequently when these tests are not run.", "files": ["dom/media/tests/mochitest/mochitest.ini"], "git_node": null, "git_parents": [null], "node": "d7122c593efe4ed1dba8a184c2a4b45d3647a63d", "parents": ["1d4a6dc2023c7332de374aade71742917b40d726"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1394671 - Disable test browser_perwindow_privateBrowsing.js on linux/debug for frequent intermittent leaks. a=test-only", "files": ["dom/indexedDB/test/browser.ini"], "git_node": null, "git_parents": [null], "node": "05c2e92032a42acc08cbf772ed0264423b5d5afc", "parents": ["d7122c593efe4ed1dba8a184c2a4b45d3647a63d"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1417189 - Try to avoid intermittent IOError following system-log generation. r=jmaher, a=test-only", "files": ["testing/mozharness/scripts/desktop_unittest.py"], "git_node": null, "git_parents": [null], "node": "7632efd3f660bd0d994d89b3dc66ed7291e372d0", "parents": ["05c2e92032a42acc08cbf772ed0264423b5d5afc"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1285500 - Disable browser_ext_browserAction_popup.js on windows/debug for frequent failures. a=test-only", "files": ["browser/components/extensions/test/browser/browser-common.ini"], "git_node": null, "git_parents": [null], "node": "333329b2e22cf0bb01f6c4d5da606718ed5a0149", "parents": ["7632efd3f660bd0d994d89b3dc66ed7291e372d0"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1363957 - Disable dom/animation/test/mozilla/test_deferred_start.html on android/debug and win10 for frequent failures. a=test-only", "files": ["dom/animation/test/mochitest.ini"], "git_node": null, "git_parents": [null], "node": "3cd2225da4a9d8fcd41e36cd98a9070dfadaee17", "parents": ["333329b2e22cf0bb01f6c4d5da606718ed5a0149"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1383315 - Disable browser/base/content/test/tabcrashed/browser_noPermanentKey.js on linux for frequent failures. a=test-only", "files": ["browser/base/content/test/tabcrashed/browser.ini"], "git_node": null, "git_parents": [null], "node": "42ab1a9359cbb7c3313035cc2b7911419fa74022", "parents": ["3cd2225da4a9d8fcd41e36cd98a9070dfadaee17"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1388624 - Disable dom/canvas/test/webgl-mochitest/test_capture.html on windows/debug for frequent failures. a=test-only", "files": ["dom/canvas/test/webgl-mochitest/mochitest.ini"], "git_node": null, "git_parents": [null], "node": "ff2c59d08d4ede18eb31c2e5d0c932c251ad34a1", "parents": ["42ab1a9359cbb7c3313035cc2b7911419fa74022"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1398120 - Disable toolkit/components/extensions/test/mochitest/test-oop-extensions/test_ext_webrequest_responseBody.html on linux for frequent failures. a=test-only", "files": ["toolkit/components/extensions/test/mochitest/mochitest-common.ini"], "git_node": null, "git_parents": [null], "node": "056f37f31cdf961292c4ffe0f84b10afd7fbdc05", "parents": ["ff2c59d08d4ede18eb31c2e5d0c932c251ad34a1"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414124 - Disable devtools/client/debugger/new/test/mochitest/browser_dbg-toggling-tools.js on all configs for frequent failures. a=test-only", "files": ["devtools/client/debugger/new/test/mochitest/browser.ini"], "git_node": null, "git_parents": [null], "node": "c2b80a6294c51d3336131a47895f3c94b163eca8", "parents": ["056f37f31cdf961292c4ffe0f84b10afd7fbdc05"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1385288 - Disable parser/htmlparser/tests/reftest/bug582940-1.html on osx for frequent failures. a=test-only", "files": ["parser/htmlparser/tests/reftest/reftest.list"], "git_node": null, "git_parents": [null], "node": "70b42ae89f23a5a9a17aaebc4a7c9f33150b6547", "parents": ["c2b80a6294c51d3336131a47895f3c94b163eca8"], "tags": []}], "date": 1510934876, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8166": {"changesets": [{"author": "Jason Laster \u003cjason.laster.11@gmail.com\u003e", "branch": "default", "desc": "Bug 1415300 - Update Debugger frontend (11-7). r=jdescottes, a=gchang\n\nTaken from upstream commit: be179268c9b89390c13bdc9c4cca6000f6f583e5\nAdded skip-if true to some new debugger mochitests that still look intermittent.\n\nMozReview-Commit-ID: EIcx5z9s7XF", "files": ["devtools/client/debugger/new/README.mozilla", "devtools/client/debugger/new/debugger.css", "devtools/client/debugger/new/debugger.js", "devtools/client/debugger/new/parser-worker.js", "devtools/client/debugger/new/pretty-print-worker.js", "devtools/client/debugger/new/search-worker.js", "devtools/client/debugger/new/test/mochitest/browser.ini", "devtools/client/debugger/new/test/mochitest/browser_dbg-breaking.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-debugger-buttons.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-editor-select.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-expressions-error.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-navigation.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-pause-exceptions.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-preview.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-quick-open.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-returnvalues.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-scopes-mutations.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-sourcemaps.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-sourcemaps2.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-wasm-sourcemaps.js", "devtools/client/debugger/new/test/mochitest/examples/doc-scripts.html", "devtools/client/debugger/new/test/mochitest/examples/simple1.js", "devtools/client/debugger/new/test/mochitest/examples/simple3.js", "devtools/client/debugger/new/test/mochitest/head.js"], "git_node": null, "git_parents": [null], "node": "fb1d0acce911246a649a595072a7b12ee7ac2833", "parents": ["70b42ae89f23a5a9a17aaebc4a7c9f33150b6547"], "tags": []}, {"author": "Jason Laster \u003cjason.laster.11@gmail.com\u003e", "branch": "default", "desc": "Bug 1416358 - Update Debugger frontend (11-10). r=jdescottes, a=gchang\n\nMozReview-Commit-ID: 1aEWMEignDN", "files": ["devtools/client/debugger/new/README.mozilla", "devtools/client/debugger/new/debugger.css", "devtools/client/debugger/new/debugger.js", "devtools/client/debugger/new/parser-worker.js", "devtools/client/debugger/new/pretty-print-worker.js", "devtools/client/debugger/new/search-worker.js"], "git_node": null, "git_parents": [null], "node": "d42d5cea8c10efee8d1f5bc1173d5e4be3bb039c", "parents": ["fb1d0acce911246a649a595072a7b12ee7ac2833"], "tags": []}, {"author": "Henri Sivonen \u003chsivonen@hsivonen.fi\u003e", "branch": "default", "desc": "Bug 1414490 - Permanently undefine the insertion point at EOF. r=smaug, a=gchang\n\nMozReview-Commit-ID: Kijs3Rxhq0X", "files": ["dom/html/nsHTMLDocument.cpp", "parser/html/nsHtml5Parser.cpp", "parser/html/nsHtml5Parser.h", "parser/html/nsHtml5TreeOpExecutor.cpp"], "git_node": null, "git_parents": [null], "node": "58c90e9bf49fae19507b3deb50ce3fffdb09db48", "parents": ["d42d5cea8c10efee8d1f5bc1173d5e4be3bb039c"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411968 - Only try launching BrowserApp when handling notifications. r=nechen, a=gchang\n\nUsually when we handle notification events, we try to launch whatever\nActivity showed the notification so that the user can see results.\nHowever, only BrowserApp supports being launched this way, so we should\nrestrict launching Activites to BrowserApp. For others like\nCustomTabsActivity, we should just handle the notification event\ndirectly. Currently, only download notifications are supported for these\nother Activities, so it's okay if we don't display the Activity.\n\nMozReview-Commit-ID: CNVRSEWBOQ6", "files": ["mobile/android/base/java/org/mozilla/gecko/notifications/NotificationReceiver.java"], "git_node": null, "git_parents": [null], "node": "66ecc5020b847eb2f705ee474b57e52507e09db2", "parents": ["58c90e9bf49fae19507b3deb50ce3fffdb09db48"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1416576 - Correctly handle Tab:OpenUri. r=me, a=gchang\n\nCorrectly handle the Tab:OpenUri event introduced in bug 1412872. r=me\nfor trivial patch.\n\nMozReview-Commit-ID: BIpKcLCi8sV", "files": ["mobile/android/chrome/content/browser.js"], "git_node": null, "git_parents": [null], "node": "2ef9343f628d39f1bad2280b01fd86fbfd1775c1", "parents": ["66ecc5020b847eb2f705ee474b57e52507e09db2"], "tags": []}, {"author": "Fischer.json \u003cfischer.json@gmail.com\u003e", "branch": "default", "desc": "Bug 1414721 - Colors of Onboarding nav icons are inconsistent. r=gasolin, a=gchang\n\nPreviously we used background images to display tour icons on the nav list and on the tour notification. This caused two pitfalls: First, if fill colors were different inside svg icons, we would see inconsistent tour icon colors. Second, for one tour icon there would need two svg files.\n\nThis patch switches to the mask-image approach, which makes a icon svg as a mask filtering the background color beneath, so we can unify icon colors by the external css and remove extra colored svg files.\n\nMozReview-Commit-ID: ErXexz15y8F", "files": ["browser/extensions/onboarding/content/img/icons_addons-colored.svg", "browser/extensions/onboarding/content/img/icons_customize-colored.svg", "browser/extensions/onboarding/content/img/icons_default-colored.svg", "browser/extensions/onboarding/content/img/icons_library-colored.svg", "browser/extensions/onboarding/content/img/icons_performance-colored.svg", "browser/extensions/onboarding/content/img/icons_private-colored.svg", "browser/extensions/onboarding/content/img/icons_screenshots-colored.svg", "browser/extensions/onboarding/content/img/icons_singlesearch-colored.svg", "browser/extensions/onboarding/content/img/icons_sync-colored.svg", "browser/extensions/onboarding/content/onboarding.css"], "git_node": null, "git_parents": [null], "node": "baabad5cb9682319526b9cfca04199b06fb1a290", "parents": ["2ef9343f628d39f1bad2280b01fd86fbfd1775c1"], "tags": []}, {"author": "Ray Lin \u003cralin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415596 - Make click to play button transparent when status overlay is present on video controls. r=jaws, a=gchang\n\nMozReview-Commit-ID: 6xweGJQoR6R", "files": ["toolkit/content/tests/widgets/test_videocontrols_error.html", "toolkit/content/widgets/videocontrols.xml", "toolkit/themes/shared/media/videocontrols.css"], "git_node": null, "git_parents": [null], "node": "1d2280710c0ddc112a1c51c9165445c222dee8fb", "parents": ["baabad5cb9682319526b9cfca04199b06fb1a290"], "tags": []}, {"author": "Dale Harvey \u003cdale@arandomurl.com\u003e", "branch": "default", "desc": "Bug 1408738 - Give more left margin to window controls. r=johannh, a=gchang\n\nMozReview-Commit-ID: A77ggiyxoAK", "files": ["browser/themes/osx/browser.css"], "git_node": null, "git_parents": [null], "node": "c69b7aea8761d7728652dd34f44e7982a1c30f2f", "parents": ["1d2280710c0ddc112a1c51c9165445c222dee8fb"], "tags": []}, {"author": "Ray Lin \u003cralin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415836 - Make form autofill dropdown footer text centered. r=lchang, a=gchang\n\nMozReview-Commit-ID: Aw8bQFlGQj3", "files": ["browser/extensions/formautofill/skin/shared/autocomplete-item.css"], "git_node": null, "git_parents": [null], "node": "c78d02a2b591e322dfb8430d49d5d76d8848e5ed", "parents": ["c69b7aea8761d7728652dd34f44e7982a1c30f2f"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1416618 - Cannot show short date format (yy/MM/dd'('ddd')') correctly. r=jfkthame, a=gchang\n\nOn Windows 7, there is yy/mm/dd'('ddd')' as short date format of Japanese.\nWhen selecting this, ddd isn't converted to day of the week correctly.\n\nFindInReadable will update start position iterator even if not found. So when\nusing FindInReadable again, we have to reset start position iterator.\n\nMozReview-Commit-ID: AoS1Txq3Twc", "files": ["intl/locale/windows/OSPreferences_win.cpp"], "git_node": null, "git_parents": [null], "node": "125c6999fe56a302bbeb5fd5c2d960c56fac3ec8", "parents": ["c78d02a2b591e322dfb8430d49d5d76d8848e5ed"], "tags": []}, {"author": "steveck-chung \u003cschung@mozilla.com\u003e", "branch": "default", "desc": "Bug 1417032 - Avoid reverting the masked number while saving credit card. r=lchang, a=gchang\n\nMozReview-Commit-ID: BhWC5cQIGF9", "files": ["browser/extensions/formautofill/FormAutofillParent.jsm", "browser/extensions/formautofill/test/browser/browser_creditCard_doorhanger.js"], "git_node": null, "git_parents": [null], "node": "ef08956b714db2dd288751c1dc9f65fd5cbbeaad", "parents": ["125c6999fe56a302bbeb5fd5c2d960c56fac3ec8"], "tags": []}, {"author": "Luke Chang \u003clchang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1417316 - [Form Autofill] Do not clear the cached autocomplete result when popup closed as it might be reused. r=ralin, a=gchang\n\nMozReview-Commit-ID: 5uOHP5Feuvh", "files": ["browser/extensions/formautofill/FormAutofillContent.jsm"], "git_node": null, "git_parents": [null], "node": "437d34756498ce0fa21717f8842572d11cad5ffe", "parents": ["ef08956b714db2dd288751c1dc9f65fd5cbbeaad"], "tags": []}], "date": 1510936093, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8167": {"changesets": [{"author": "Masatoshi Kimura \u003cVYV03354@nifty.ne.jp\u003e", "branch": "THUNDERBIRD570b1_2017110501_RELBRANCH", "desc": "Bug 1417209 - Do not fail when version parameter is found. r=mrbkap a=jorgk DONTBUILD\n\nI used ReportToConsoleNonLocalized to make the patch upliftable.\n\nMozReview-Commit-ID: LsOBOfzU9Hr", "files": ["dom/xul/nsXULContentSink.cpp"], "git_node": null, "git_parents": [null], "node": "0f5e48fc08a529b971cb401644d5a89ed001b61e", "parents": ["27a6d3559ff3eb09083071a4762d5e86b532af8d"], "tags": []}], "date": 1510936670, "git_changesets": [null], "user": "mozilla@jorgk.com"}, "8168": {"changesets": [{"author": "tbirdbld", "branch": "THUNDERBIRD570b2_2017111714_RELBRANCH", "desc": "Automated checkin: version bump for thunderbird 57.0b2 release. DONTBUILD CLOSED TREE a=release", "files": [], "git_node": null, "git_parents": [null], "node": "8724da62e7f463b902602c6d6811f38a3e0285c1", "parents": ["0f5e48fc08a529b971cb401644d5a89ed001b61e"], "tags": ["THUNDERBIRD_57_0b2_BUILD1", "THUNDERBIRD_57_0b2_RELEASE"]}, {"author": "tbirdbld", "branch": "THUNDERBIRD570b2_2017111714_RELBRANCH", "desc": "Added THUNDERBIRD_57_0b2_RELEASE THUNDERBIRD_57_0b2_BUILD1 tag(s) for changeset 8724da62e7f4. DONTBUILD CLOSED TREE a=release", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "b24d542d37808bafc270a1bfa07d8ce9d057acac", "parents": ["8724da62e7f463b902602c6d6811f38a3e0285c1"], "tags": []}], "date": 1510947479, "git_changesets": [null, null], "user": "tbirdbld"}, "8169": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nbn-BD -\u003e a31af6b306b7\nhy-AM -\u003e 8cd19e4df6e9\nit -\u003e 2d32d9915d64\nne-NP -\u003e 9a58086de54d\nro -\u003e 5f9b4c99b8a5\nsq -\u003e b193083e0bb0", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "46ad251f59c6d4359b0fb8644081872f5d47faea", "parents": ["437d34756498ce0fa21717f8842572d11cad5ffe"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nbn-BD -\u003e a31af6b306b7\nbn-IN -\u003e b0ac71ff5351\nhi-IN -\u003e a109c13086eb\nhy-AM -\u003e 8cd19e4df6e9\nis -\u003e fe4aa982192d\nit -\u003e 2b2a97a52dac\nne-NP -\u003e d22d9e927a21\nro -\u003e 5f9b4c99b8a5\nsq -\u003e b193083e0bb0\nta -\u003e d4905859ab64", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "27c174612a481da373b208b2d03fbcc2629ad399", "parents": ["46ad251f59c6d4359b0fb8644081872f5d47faea"], "tags": []}], "date": 1511011265, "git_changesets": [null, null], "user": "ffxbld"}, "8170": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nro -\u003e 610ab1b4728a", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "17147fcbb49616b1bef4f8e99c5586bf37e6da4e", "parents": ["27c174612a481da373b208b2d03fbcc2629ad399"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nro -\u003e 610ab1b4728a", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "14953770ed84a9973e1abda6b075dcf719588712", "parents": ["17147fcbb49616b1bef4f8e99c5586bf37e6da4e"], "tags": []}], "date": 1511065282, "git_changesets": [null, null], "user": "ffxbld"}, "8171": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nne-NP -\u003e 0881887f1fab\nth -\u003e 756bde45a1ad", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "47e092b7dfab8925f0c37efa223536523b0c7f6e", "parents": ["14953770ed84a9973e1abda6b075dcf719588712"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nbn-BD -\u003e 6fb511fd3049\nit -\u003e 960215fd093d\nne-NP -\u003e ec618cb554d4\nro -\u003e b3d31292886c\nsi -\u003e 55e43f352730\nth -\u003e 33055e96745b", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "c668d7762aede703fa61b1f792ed0876bf8fefa3", "parents": ["47e092b7dfab8925f0c37efa223536523b0c7f6e"], "tags": []}], "date": 1511086845, "git_changesets": [null, null], "user": "ffxbld"}, "8172": {"changesets": [{"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414016 - Remove the MinGW Build from beta due to build breaks. r=aki, a=test-only\n\nMozReview-Commit-ID: GqK0hNwLwoZ", "files": ["taskcluster/taskgraph/target_tasks.py"], "git_node": null, "git_parents": [null], "node": "18ff3d710d0b4c304cfd172e4365e6183c5a76e1", "parents": ["c668d7762aede703fa61b1f792ed0876bf8fefa3"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1384358 - Avoid racy check of focus manager in content process. r=enndeakin, a=test-only\n\nPreviously this was safe, as the synthesized mouse event would be processed in\nthe child process, updating the focus state, in order - before the content\nprocess would try to check its focus state. Now, thanks to multiple event queues\nwork, this isn't guaranteed.\n\nThis patch just adds retrying to the logic, so we retry up to 10 times, 100ms\napart. This should ensure that we don't incorrectly detect a test failure\nintermittently.\n\nMozReview-Commit-ID: J4uzl9jeafC", "files": ["dom/tests/browser/browser_focus_steal_from_chrome_during_mousedown.js"], "git_node": null, "git_parents": [null], "node": "459097e1f324f49d5713d41c50c895ae29bfbbf0", "parents": ["18ff3d710d0b4c304cfd172e4365e6183c5a76e1"], "tags": []}, {"author": "Benjamin Bouvier \u003cbenj@benj.me\u003e", "branch": "default", "desc": "Bug 1415549 - Use correct encoding when reporting an error with wasm module/field utf8 names. r=luke, a=gchang\n\nMozReview-Commit-ID: 8PcgvVfLa2V", "files": ["js/src/jit-test/tests/wasm/utf8.js", "js/src/jsapi.cpp", "js/src/wasm/AsmJS.cpp", "js/src/wasm/WasmBinaryToAST.cpp", "js/src/wasm/WasmBuiltins.cpp", "js/src/wasm/WasmInstance.cpp", "js/src/wasm/WasmJS.cpp", "js/src/wasm/WasmModule.cpp"], "git_node": null, "git_parents": [null], "node": "def7425b015c089ae7bd193bef7bac4a45074baf", "parents": ["459097e1f324f49d5713d41c50c895ae29bfbbf0"], "tags": []}, {"author": "sotaro \u003csotaro.ikeda.g@gmail.com\u003e", "branch": "default", "desc": "Bug 1416614 - Add checks to ImageBridgeParent::NotifyImageComposites. r=nical, a=gchang", "files": ["gfx/layers/ipc/ImageBridgeParent.cpp"], "git_node": null, "git_parents": [null], "node": "3221f428493e488068dc664e4752fef0b60edef3", "parents": ["def7425b015c089ae7bd193bef7bac4a45074baf"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1415013 - Clear servo data on flattened tree changes. r=bz, a=gchang\n\nMozReview-Commit-ID: 3TsM8tbzPMV", "files": ["dom/base/Element.h", "layout/base/PresShell.cpp"], "git_node": null, "git_parents": [null], "node": "fb8050fb78aa4117614f8fa14de10cf08876e4f3", "parents": ["3221f428493e488068dc664e4752fef0b60edef3"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1416473 - Don't treat MF_E_TRANSFORM_NEED_MORE_INPUT as fatal error. r=mattwoodrow, a=gchang\n\nThe VP9 decoder following a flush will often return MF_E_NOTACCEPTING. Attempting to request an output would cause the error MF_E_TRANSFORM_NEED_MORE_INPUT to be returned. We can simply feed the decoder with the compressed sample.\n\nMozReview-Commit-ID: GUNniZsOKWr", "files": ["dom/media/platforms/wmf/WMFMediaDataDecoder.cpp"], "git_node": null, "git_parents": [null], "node": "259b10e2934fd7043af8c575a013980e609bfe42", "parents": ["fb8050fb78aa4117614f8fa14de10cf08876e4f3"], "tags": []}, {"author": "Bob Owen \u003cbobowencode@gmail.com\u003e", "branch": "default", "desc": "Bug 1417959 - Bump Alternate Desktop to Level 5 and make that the Default on Nightly. r=jimm, a=gchang", "files": ["browser/app/profile/firefox.js", "security/sandbox/win/src/sandboxbroker/sandboxBroker.cpp"], "git_node": null, "git_parents": [null], "node": "df6d0aff01790273b36dae1cf0835e5d4d168eac", "parents": ["259b10e2934fd7043af8c575a013980e609bfe42"], "tags": []}, {"author": "Olli Pettay \u003cOlli.Pettay@helsinki.fi\u003e", "branch": "default", "desc": "Bug 1416450 - Ensure IntersectionObservers are deleted when adopting elements. r=mrbkap, a=gchang", "files": ["dom/base/Element.cpp", "dom/base/nsNodeUtils.cpp"], "git_node": null, "git_parents": [null], "node": "59d1822ef42e424b36850209345b678926f994e6", "parents": ["df6d0aff01790273b36dae1cf0835e5d4d168eac"], "tags": []}], "date": 1511123125, "git_changesets": [null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8173": {"changesets": [{"author": "Franziskus Kiefer \u003cfranziskuskiefer@gmail.com\u003e", "branch": "default", "desc": "Bug 1401594 - land NSS_3_34_RTM UPGRADE_NSS_RELEASE, r=me a=gchang", "files": ["security/nss/TAG-INFO", "security/nss/coreconf/coreconf.dep", "security/nss/lib/nss/nss.h", "security/nss/lib/softoken/softkver.h", "security/nss/lib/util/nssutil.h"], "git_node": null, "git_parents": [null], "node": "8297b7a3b50cdff3cf8eef7ff6698d253f146ab7", "parents": ["59d1822ef42e424b36850209345b678926f994e6"], "tags": []}], "date": 1511160163, "git_changesets": [null], "user": "franziskuskiefer@gmail.com"}, "8174": {"changesets": [{"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 1414447 - Use displayed definitions in toolbox component for kb nav. r=jryans a=gchang", "files": ["devtools/client/framework/components/toolbox-controller.js", "devtools/client/framework/toolbox.js"], "git_node": null, "git_parents": [null], "node": "13271ee1aac0e9d4afca5eadee3ef815f73e15e1", "parents": ["8297b7a3b50cdff3cf8eef7ff6698d253f146ab7"], "tags": []}, {"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 1414451 - Check that both documents share the same root. r=aklotz a=gchang", "files": ["accessible/windows/msaa/AccessibleWrap.cpp"], "git_node": null, "git_parents": [null], "node": "1dedf706dac630f65d7e677bdad6315f092a624b", "parents": ["13271ee1aac0e9d4afca5eadee3ef815f73e15e1"], "tags": []}, {"author": "Grigory Kruglov \u003cgkruglov@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403787 - Change try/catch to catch the correct exception r=nalexander a=gchang\n\nWe're aiming to catch FileNotFound exceptions here, but underneath they're re-thrown as IllegalStateException.\n\nMozReview-Commit-ID: HaCpbqq93q0", "files": ["mobile/android/services/src/main/java/org/mozilla/gecko/fxa/devices/FxAccountDeviceRegistrator.java"], "git_node": null, "git_parents": [null], "node": "062c4b37d9ab0653df560445c12ab5b951cd917a", "parents": ["1dedf706dac630f65d7e677bdad6315f092a624b"], "tags": []}, {"author": "Alex Gaynor \u003cagaynor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1417939 - do not crash in release builds when a PRFileDescStream is closed twice; r=bobowen a=gchang\n\nThis makes it API compatible with std::ostream, which it replaced. This silences a rare crash.\n\nMozReview-Commit-ID: JoNo1qRCb0n", "files": ["layout/printing/DrawEventRecorder.h"], "git_node": null, "git_parents": [null], "node": "59c2cb4225938b754a44b1c79877a988722e4a0c", "parents": ["062c4b37d9ab0653df560445c12ab5b951cd917a"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1417420 - Add the path used by FontAgent to the sandbox rules on macOS. r=haik a=gchang", "files": ["security/sandbox/mac/SandboxPolicies.h"], "git_node": null, "git_parents": [null], "node": "cd0cba138a4c336e25bd1b6e05dffe822f6bd537", "parents": ["59c2cb4225938b754a44b1c79877a988722e4a0c"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1417386 - Remove bogus end pedding from bookmarks toolbar folders without a label. r=mak a=gchang\n\nMozReview-Commit-ID: Cd6Rcvu8UA1", "files": ["browser/themes/shared/toolbarbuttons.inc.css"], "git_node": null, "git_parents": [null], "node": "430feea6f9a5a817ee36728bfd78ec8542d0dc24", "parents": ["cd0cba138a4c336e25bd1b6e05dffe822f6bd537"], "tags": []}, {"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1417036 - \"Save to Pocket\" drop down menu glitches. r=Gijs a=gchang\n\nMozReview-Commit-ID: 1JPOmQNLn26", "files": ["browser/base/content/browser-pageActions.js", "browser/extensions/pocket/bootstrap.js", "browser/modules/PageActions.jsm", "browser/modules/test/browser/browser_PageActions.js"], "git_node": null, "git_parents": [null], "node": "1e803860c220fdb0a1eabaafc23eeca5bf17313d", "parents": ["430feea6f9a5a817ee36728bfd78ec8542d0dc24"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1362065 - Add the touchdownstartsdrag attribute to selected tabs on Windows. r=dao a=gchang\n\nThis allows dragging them via touch gestures.\n\nI'm not adding this attribute to all tabs (so that you need\nto select a tab before dragging it), because the tab\nstrip can also be scrolled with touch gestures and\nthe two touch move actions would easily conflict\notherwise. It would also make it easier to accidentally\nmess up your tabs when touching your window somehow.\n\nMozReview-Commit-ID: IVWQtVGFE9j", "files": ["browser/base/content/tabbrowser.xml", "browser/components/customizableui/CustomizeMode.jsm"], "git_node": null, "git_parents": [null], "node": "fbfb9e53d29e4576c1b6ca999ba61eab85ba4f2e", "parents": ["1e803860c220fdb0a1eabaafc23eeca5bf17313d"], "tags": []}, {"author": "Ray Lin \u003cralin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411990 - Add consecutive cc-exp-* regex check in form autofill heuristics to enhance expiration date pattern matching. r=lchang,seanlee a=gchang\n\nMozReview-Commit-ID: 5P2nSSJd2Dl", "files": ["browser/extensions/formautofill/FormAutofillHeuristics.jsm", "browser/extensions/formautofill/test/fixtures/heuristics_cc_exp.html", "browser/extensions/formautofill/test/unit/heuristics/test_cc_exp.js"], "git_node": null, "git_parents": [null], "node": "1d9dd73c061c4192f7c3741eb05f35f8c464f2bb", "parents": ["fbfb9e53d29e4576c1b6ca999ba61eab85ba4f2e"], "tags": []}], "date": 1511180567, "git_changesets": [null, null, null, null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "8175": {"changesets": [{"author": "Luke Chang \u003clchang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1417336 - [Form Autofill] Enable credit card autofill by default on beta build. r=steveck a=gchang\n\nMozReview-Commit-ID: AOM6vqw2JvY", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "1ec9ad9a1be29b87779b9f5b895ca6d175009f5f", "parents": ["1d9dd73c061c4192f7c3741eb05f35f8c464f2bb"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Only return a valid RotatedBuffer in ContentClientBasic::CreateBuffer (bug 1416790, r=dvander a=gchang)\n\nMozReview-Commit-ID: C5l4OHAWBLL", "files": ["gfx/layers/client/ContentClient.cpp"], "git_node": null, "git_parents": [null], "node": "a706ed0c3235f882f8476c83290364d509b458aa", "parents": ["1ec9ad9a1be29b87779b9f5b895ca6d175009f5f"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Don't use CompositorBridgeChild in PrepareBuffer if sync OMTP is enabled (bug 1416782, r=dvander a=gchang)\n\nMozReview-Commit-ID: DMbKcDEkkeP", "files": ["gfx/layers/PaintThread.cpp"], "git_node": null, "git_parents": [null], "node": "645141391be71853e7a7dff8913f4df685b3ffb6", "parents": ["a706ed0c3235f882f8476c83290364d509b458aa"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1413741 - Improve the use of XHR.mProxy in workers after the dispatching of sync OpenRunnable, r=smaug a=gchang", "files": ["dom/xhr/XMLHttpRequestWorker.cpp"], "git_node": null, "git_parents": [null], "node": "bd9c24730b5b1bbd4a35d165eaafadd108e6115d", "parents": ["645141391be71853e7a7dff8913f4df685b3ffb6"], "tags": []}, {"author": "Jeremy Chen \u003cjeremychen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415581 - add reftest. r=jfkthame a=test-only\n\nAdd reftest to ensure that hyphenation breaks are not affected if there are\nmultiple inline elements inside a paragraph.\n\nMozReview-Commit-ID: Jmh0LPgjCVF", "files": ["layout/reftests/text/hyphenation-control-4-ref.html", "layout/reftests/text/hyphenation-control-4.html", "layout/reftests/text/reftest.list"], "git_node": null, "git_parents": [null], "node": "6a0f1693d6641bcb4bb0b00e3ae39ecd7bac3cce", "parents": ["bd9c24730b5b1bbd4a35d165eaafadd108e6115d"], "tags": []}, {"author": "Jeremy Chen \u003cjeremychen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415581 - get the correct positions of explicit hyphens while calling PropertyProvider::GetHyphenationBreaks. r=jfkthame a=gchang\n\nIn the current implementation, when hyphens property is set to auto, we do some\nmath to determine the index of text fragment, so we can check whether a character\nis an explicit hyphen. However, the math calculation is not reliable, and it is\nnot easy to calculate the fragment index when there are more than one fragments\nin a gfxTextRun, e.g., a paragraph which consists multiple inline elements.\n\nIn this patch, we simply use GetOriginalOffset() to get the position relative\nto the current text fragment, and scan/detect explicit hyphens correctly.\n\nMozReview-Commit-ID: JIg3tdpViRH", "files": ["layout/generic/nsTextFrame.cpp"], "git_node": null, "git_parents": [null], "node": "63888c62a7937154e9cbf8ebecdecadb734aa8ae", "parents": ["6a0f1693d6641bcb4bb0b00e3ae39ecd7bac3cce"], "tags": []}], "date": 1511181645, "git_changesets": [null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "8176": {"changesets": [{"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1416774 - Ensure that imgRequestProxy::CancelAndForgetObserver removes itself from the cache validator. r=tnikkel a=gchang\n\nAn imgRequestProxy may defer notifications when it needs to block on an\nimgCacheValidator. It may also be cancelled before the validator has\ncompleted its operation, but before this change, we did not remove the\nrequest from the set of proxies, imgCacheValidator::mProxies. When the\ndeferral was completed, it would assert to ensure each proxy was still\nexpecting a deferral before issuing the notifications. Cancelling a\nrequest can actually reset that state, which means we fail the assert.\n\nFailing the assert is actually harmless; in release we suffer no\nnegative consequences as a result of this sequence of events. Now we\njust remove the proxy from the validator set to avoid asserting.", "files": ["image/imgLoader.cpp", "image/imgLoader.h", "image/imgRequestProxy.cpp"], "git_node": null, "git_parents": [null], "node": "af82d0c3342786f2575a3bca847bd7e91d44b1d0", "parents": ["63888c62a7937154e9cbf8ebecdecadb734aa8ae"], "tags": []}, {"author": "Dale Harvey \u003cdale@arandomurl.com\u003e", "branch": "default", "desc": "Bug 1415870 - Update psl list and related tests. r=gerv a=gchang\n\nMozReview-Commit-ID: aYfQNU7lEJ", "files": ["netwerk/dns/effective_tld_names.dat", "netwerk/test/unit/data/test_psl.txt"], "git_node": null, "git_parents": [null], "node": "ed210b4ed61446769a587772b18d22a18d61a714", "parents": ["af82d0c3342786f2575a3bca847bd7e91d44b1d0"], "tags": []}, {"author": "David Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "bug 1368868 - give up on ocsp stapling strictness because we can't have nice things r=jcj a=Sylvestre\n\nMozReview-Commit-ID: nbX0c251oC", "files": ["CLOBBER", "security/certverifier/NSSCertDBTrustDomain.cpp", "security/manager/ssl/tests/unit/ocsp_certs/must-staple-ee.pem", "security/manager/ssl/tests/unit/ocsp_certs/must-staple-ee.pem.certspec", "security/manager/ssl/tests/unit/test_ocsp_must_staple.js", "security/manager/ssl/tests/unit/test_ocsp_stapling.js", "security/manager/ssl/tests/unit/test_ocsp_stapling_expired.js", "security/manager/ssl/tests/unit/tlsserver/cmd/OCSPStaplingServer.cpp"], "git_node": null, "git_parents": [null], "node": "b9e65f782b6bd6228ffdbfee166b6dbdaeed208e", "parents": ["ed210b4ed61446769a5877