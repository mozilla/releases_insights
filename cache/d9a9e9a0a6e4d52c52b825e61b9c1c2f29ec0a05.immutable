/test/browser_net_statistics-02.js"], "git_node": null, "git_parents": [null], "node": "1dfd52f8297352aac98ca530edb8d7931ea2ee4c", "parents": ["34b559b82c0354ba6bbe32c932994db991cb38c3"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 464450 - Get rid of the padded class and clean up related styling. r=mak\n\nMozReview-Commit-ID: KYKqH9vLQ3x", "files": ["browser/components/places/content/editBookmarkOverlay.xul", "browser/themes/linux/browser.css", "browser/themes/shared/urlbar-searchbar.inc.css", "browser/themes/windows/browser.css", "editor/reftests/xul/autocomplete-1.xul", "editor/reftests/xul/autocomplete.css", "editor/reftests/xul/input.css", "editor/reftests/xul/reftest.list", "toolkit/themes/linux/global/autocomplete.css", "toolkit/themes/osx/global/autocomplete.css", "toolkit/themes/windows/global/autocomplete.css"], "git_node": null, "git_parents": [null], "node": "294c88b3bd2cdb6592b1decc03c54f3931474447", "parents": ["1dfd52f8297352aac98ca530edb8d7931ea2ee4c"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414379 - Closing the extension popup tab should select the parent tab only if the popup tab was selected. r=mixedpuppy\n\nMozReview-Commit-ID: KgSTdblvmYe", "files": ["mobile/android/components/extensions/ext-utils.js", "mobile/android/components/extensions/test/mochitest/chrome.ini", "mobile/android/components/extensions/test/mochitest/test_ext_popup_behavior.html"], "git_node": null, "git_parents": [null], "node": "ec266337fc47fa3237579b50ba92663b479a91ee", "parents": ["294c88b3bd2cdb6592b1decc03c54f3931474447"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1414713 - EditorUtils::IsDescendantOf() should take EditorDOMPoint and EditorRawDOMPoint as out param r=catalinb,m_kato\n\nEditorUtils::IsDescendantOf() current takes a pointer to offset or a pointer to\nchild content if the caller needs to know the child of the most ancestor node.\n\nHowever, some callers should get a child as EditorDOMPoint or EditorRawDOMPoint.\nThen, they can be used for some editor methods which need to take child node\nfor performance optimization.\n\nThis patch makes EditorUtils::IsDescendantOf() as only two overloads.  One takes\npointer to EditorRawDOMPoint as optional out argument.  The other takes pointer\nto EditorDOMPoint as an out param.\n\nAdditionally, this creates new constructor of AutoTrackDOMPoint for making it\ncan treat EditorDOMPoint directly.\n\nMozReview-Commit-ID: IsAGTUvKI19", "files": ["dom/base/RangeBoundary.h", "editor/libeditor/EditorBase.cpp", "editor/libeditor/EditorUtils.cpp", "editor/libeditor/EditorUtils.h", "editor/libeditor/HTMLEditRules.cpp", "editor/libeditor/HTMLEditor.cpp", "editor/libeditor/HTMLEditorDataTransfer.cpp", "editor/libeditor/SelectionState.cpp", "editor/libeditor/SelectionState.h"], "git_node": null, "git_parents": [null], "node": "02c14327d1451d54d4e81da141453a93784848cc", "parents": ["ec266337fc47fa3237579b50ba92663b479a91ee"], "tags": []}, {"author": "Jan Odvarko \u003codvarko@gmail.com\u003e", "branch": "default", "desc": "Bug 1415137 - Group's vertical line is moved one pixel; r=nchevobbe\n\nMozReview-Commit-ID: CVfsJ6wx6HC", "files": ["devtools/client/themes/webconsole.css"], "git_node": null, "git_parents": [null], "node": "969d528d0de8c7477be900a0105f9325676f7b38", "parents": ["02c14327d1451d54d4e81da141453a93784848cc"], "tags": []}, {"author": "abhinav \u003cabhinav.koppula@gmail.com\u003e", "branch": "default", "desc": "Bug 1413832 - Keep the green/active toolbar icon styling when the tool is selected. r=jdescottes\n\nMozReview-Commit-ID: 6Sj0lECJMuC", "files": ["devtools/client/themes/toolbox.css"], "git_node": null, "git_parents": [null], "node": "e412b3da631e2b68ec68e86e7cbd2b5005de0dc0", "parents": ["969d528d0de8c7477be900a0105f9325676f7b38"], "tags": []}, {"author": "bechen@mozilla.com \u003cbechen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1412180 - implement regionID on TextTrackRegion. r=rillian,smaug\n\nMozReview-Commit-ID: 3uFAQuNfGjO", "files": ["dom/media/TextTrackRegion.cpp", "dom/media/TextTrackRegion.h", "dom/media/webvtt/vtt.jsm", "dom/webidl/VTTRegion.webidl"], "git_node": null, "git_parents": [null], "node": "3cb5c8d2f793d21e6a8d4a53f4827d84ce559f77", "parents": ["e412b3da631e2b68ec68e86e7cbd2b5005de0dc0"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1414298: Don't try to set yasm version config settings if yasm isn't found. r=froydnj\n\nMozReview-Commit-ID: LTDxJ5su7sM", "files": ["build/moz.configure/toolchain.configure"], "git_node": null, "git_parents": [null], "node": "a478fd716627ac9547b2783ea894fe4f877de84f", "parents": ["3cb5c8d2f793d21e6a8d4a53f4827d84ce559f77"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1408919 - Rename and enable browser_webconsole_autocomplete_crossdomain_iframe.js; r=Honza.\n\nThis bug also renames the support file, and create a dedicated one for the child iframe.\nAn helper method is created to only wait for a single message with given text in it, as\nwell as returning an array of matched message in waitForMessages (we were returning the\nresult of setting the listener, which I doubt is useful for any test.\n\nMozReview-Commit-ID: Gz7zqX825oR", "files": ["devtools/client/webconsole/new-console-output/test/mochitest/browser.ini", "devtools/client/webconsole/new-console-output/test/mochitest/browser_jsterm_autocomplete_crossdomain_iframe.js", "devtools/client/webconsole/new-console-output/test/mochitest/browser_webconsole_autocomplete_crossdomain_iframe.js", "devtools/client/webconsole/new-console-output/test/mochitest/head.js", "devtools/client/webconsole/new-console-output/test/mochitest/test-bug-989025-iframe-parent.html", "devtools/client/webconsole/new-console-output/test/mochitest/test-iframe-child.html", "devtools/client/webconsole/new-console-output/test/mochitest/test-iframe-parent.html"], "git_node": null, "git_parents": [null], "node": "ab8cb0873ccb66992d3fa34d7290125c910aee08", "parents": ["a478fd716627ac9547b2783ea894fe4f877de84f"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1408920 - Rename and enable browser_webconsole_autocomplete_in_debugger_stackframe.js; r=jdescottes.\n\nWe take this as an opportunity to add a jsterm helper function to set its value and\nwait for completion, and use it in a test where we did the same thing.\nThis also copies the openDebugger helper from the old frontend head.js .\nThe test still uses the old debugger, since it will be fixed in a specific bug\nfor all the console tests.\n\nMozReview-Commit-ID: AKB3CBY8GPv", "files": ["devtools/client/webconsole/new-console-output/test/mochitest/browser.ini", "devtools/client/webconsole/new-console-output/test/mochitest/browser_jsterm_autocomplete_cached_results.js", "devtools/client/webconsole/new-console-output/test/mochitest/browser_jsterm_autocomplete_in_debugger_stackframe.js", "devtools/client/webconsole/new-console-output/test/mochitest/browser_webconsole_autocomplete_in_debugger_stackframe.js", "devtools/client/webconsole/new-console-output/test/mochitest/head.js", "devtools/client/webconsole/new-console-output/test/mochitest/test-autocomplete-in-stackframe.html"], "git_node": null, "git_parents": [null], "node": "8823f33351025e25a949160bc23bae9fba9aac5f", "parents": ["ab8cb0873ccb66992d3fa34d7290125c910aee08"], "tags": []}, {"author": "Thom Chiovoloni \u003ctchiovoloni@mozilla.com\u003e", "branch": "default", "desc": "Bug 1415012 - Don't trigger a resync if the previous sync wasn't completely successful r=kitcambridge\n\nMozReview-Commit-ID: DcNsFUxXR1O", "files": ["services/sync/modules/policies.js", "services/sync/tests/unit/test_syncscheduler.js"], "git_node": null, "git_pare