trumentationTestRunner.java", "mobile/android/tests/browser/junit3/src/org/mozilla/tests/browser/junit3/harness/BrowserTestListener.java", "testing/instrumentation/Makefile.in", "testing/instrumentation/moz.build", "testing/instrumentation/runinstrumentation.py", "toolkit/mozapps/extensions/internal/AddonRepository_SQLiteMigrator.jsm"], "git_node": null, "git_parents": [null, null], "node": "60fd4a5b01ec70ded9ddfd560fd5be191b1c74b9", "parents": ["2af1c7c2375f251cd8dd53b05d05087378ab709d", "f63559d7e6a570e4e73ba367964099394248e18d"], "tags": []}, {"author": "Jonathan Watt \u003cjwatt@jwatt.org\u003e", "branch": "default", "desc": "Bug 1411552 - Improve the warning about attempting to overwrite prefs with a pref of the wrong type. r=njn\n\nMozReview-Commit-ID: AAlimIWoOgQ", "files": ["modules/libpref/Preferences.cpp"], "git_node": null, "git_parents": [null], "node": "49451ebb746c027e54388d572e40be5489233d60", "parents": ["60fd4a5b01ec70ded9ddfd560fd5be191b1c74b9"], "tags": []}, {"author": "Jonathan Watt \u003cjwatt@jwatt.org\u003e", "branch": "default", "desc": "Bug 1413216 - Fix some missing includes in dom code. r=baku\n\nMozReview-Commit-ID: 25hWPkXF0Wj", "files": ["dom/abort/AbortSignal.cpp", "dom/animation/AnimationEffectReadOnly.cpp", "dom/animation/CSSPseudoElement.cpp", "dom/base/ChromeUtils.cpp", "dom/base/CustomElementRegistry.cpp", "dom/base/DOMError.cpp", "dom/bindings/WebIDLGlobalNameHash.cpp", "dom/bindings/nsScriptError.cpp", "dom/bindings/nsScriptError.h", "dom/clients/manager/ClientState.cpp", "dom/clients/manager/ClientState.h", "dom/crypto/WebCryptoThreadPool.cpp", "dom/crypto/WebCryptoThreadPool.h"], "git_node": null, "git_parents": [null], "node": "dc16f72054aaabfa0dba46155bf1524b19fffe6f", "parents": ["49451ebb746c027e54388d572e40be5489233d60"], "tags": []}, {"author": "Jonathan Watt \u003cjwatt@jwatt.org\u003e", "branch": "default", "desc": "Bug 1413217 - Fix some includes etc. in widget code. r=jimm\n\nMozReview-Commit-ID: 8bW6WIPMun4", "files": ["docshell/base/nsIDocShell.idl", "widget/InProcessCompositorWidget.cpp", "widget/InputData.cpp", "widget/ScreenManager.cpp", "widget/nsAutoRollup.h", "widget/nsBaseAppShell.cpp", "widget/nsBaseClipboard.h", "widget/nsDragServiceProxy.cpp"], "git_node": null, "git_parents": [null], "node": "ff72063115f7dfed4f6b79dafc4575e929f51f51", "parents": ["dc16f72054aaabfa0dba46155bf1524b19fffe6f"], "tags": []}, {"author": "Jonathan Watt \u003cjwatt@jwatt.org\u003e", "branch": "default", "desc": "Bug 1413227 - Increase the line limit for Eclipse CDT's build console to 10,000. r=botond\n\nBy default the build console is limited to 500 lines.  This can be far too\nshort, especially when building using `mach build --verbose`.  I've run with\nthis value set to 1,000,000 before without issue, so 10,000 should be fine.\n\nMozReview-Commit-ID: GxBUjW7nOYJ", "files": ["python/mozbuild/mozbuild/backend/cpp_eclipse.py"], "git_node": null, "git_parents": [null], "node": "2a8ce3becbc5a29a629c5a798e71baf3fc7e0f0a", "parents": ["ff72063115f7dfed4f6b79dafc4575e929f51f51"], "tags": []}, {"author": "Jonathan Watt \u003cjwatt@jwatt.org\u003e", "branch": "default", "desc": "Bug 1413227 - Turn off Eclipse CDT's \"Limit console output\" option for debug output. r=botond\n\nThe default debug console line limit is far too short, especially when\ndebugging a debug build or a build with some logging turned on.  I've never\nhad any issues with turning off the limit, so hopefully this is fine for\neveryone else too.\n\nMozReview-Commit-ID: Krlo7XPEjE0", "files": ["python/mozbuild/mozbuild/backend/cpp_eclipse.py"], "git_node": null, "git_parents": [null], "node": "0a79d48df6cb4f9504e1e69c126021c5ae91f188", "parents": ["2a8ce3becbc5a29a629c5a798e71baf3fc7e0f0a"], "tags": []}, {"author": "Jonathan Watt \u003cjwatt@jwatt.org\u003e", "branch": "default", "desc": "Bug 1413755 - Have the build system use relative paths to specify the source files that should be built. r=mshal\n\nMozReview-Commit-ID: 3zdODGRdFkF", "files": ["config/rules.mk"], "git_node": null, "git_parents": [null], "node": "80798ac3e0ded9e9f9ec90db65da9529b30093e5", "parents": ["0a79d48df6cb4f9504e1e69c126021c5ae91f188"], "tags": []}, {"author": "Jonathan Watt \u003cjwatt@jwatt.org\u003e", "branch": "default", "desc": "Bug 1415217 - Try to replace reftest error 'load failed with unknown reason' with informative messages. r=dholbert\n\nIf the reftest harness times out the load of a URL before the 'load' event\nhas even fired then the error message that we get is 'load failed with unknown\nreason'.  This isn't very helpful for people unfamiliar with the harness.  This\nchange sets an initial error message that notes that we're waiting on the\n'load' event, what the timeout delay is, and what URL we are/were waiting on\nloading.  This will allow the timeout delay to be compared to log timestamps\nand will make it clear whether the timeout occurred for some other URL than\nthe one we were expecting to load (which would be an error in the harness\nlogic).\n\nIt should now be impossible for the 'load failed with unknown reason' to occur,\nbut if there is a logic error in the harness code (some race condition?) then\nit may still happen.\n\nMozReview-Commit-ID: JOb1kYBpLro", "files": ["layout/tools/reftest/reftest-content.js", "layout/tools/reftest/reftest.jsm"], "git_node": null, "git_parents": [null], "node": "27a656fe5be8be38ffe629e088a9496c7b1c1501", "parents": ["80798ac3e0ded9e9f9ec90db65da9529b30093e5"], "tags": []}, {"author": "Jonathan Watt \u003cjwatt@jwatt.org\u003e", "branch": "default", "desc": "Bug 1414644 - Stop importing XPCOMUtils.jsm into reftest-content.js. r=dholbert\n\nMozReview-Commit-ID: FSLy3R8ZVf2", "files": ["layout/tools/reftest/reftest-content.js"], "git_node": null, "git_parents": [null], "node": "2f3606eba4bc442780ea32f4227b4633b74280ae", "parents": ["27a656fe5be8be38ffe629e088a9496c7b1c1501"], "tags": []}, {"author": "Jonathan Watt \u003cjwatt@jwatt.org\u003e", "branch": "default", "desc": "Bug 1414070 - Expose whether the URL is a test or reference when telling reftest-content.js to load a URL. r=dholbert\n\nAs part of this change, the confusingly named global variable 'state' is\nrenamed to 'currentURLTargetType', and named \"enum\" values are assigned\nto it rather than raw integers.\n\nMozReview-Commit-ID: FTEOB9wF8Q1", "files": ["layout/tools/reftest/globals.jsm", "layout/tools/reftest/reftest-content.js", "layout/tools/reftest/reftest.jsm"], "git_node": null, "git_parents": [null], "node": "b8d6110960ac12692c5dddf46063425459790e8c", "parents": ["2f3606eba4bc442780ea32f4227b4633b74280ae"], "tags": []}, {"author": "Georg Fritzsche \u003cgeorg.fritzsche@googlemail.com\u003e", "branch": "default", "desc": "Bug 1408975 - Allow to register new addon events for an existing category. r=dexter", "files": ["toolkit/components/telemetry/TelemetryEvent.cpp", "toolkit/components/telemetry/docs/collection/events.rst", "toolkit/components/telemetry/tests/unit/test_TelemetryEvents.js"], "git_node": null, "git_parents": [null], "node": "618bbe87c8226d99e7a49203ed7acadbe1901d9c", "parents": ["b8d6110960ac12692c5dddf46063425459790e8c"], "tags": []}, {"author": "Georg Fritzsche \u003cgeorg.fritzsche@googlemail.com\u003e", "branch": "default", "desc": "Bug 1414638 - Remove expiry_date property for Telemetry events. r=dexter", "files": ["toolkit/components/telemetry/EventInfo.h", "toolkit/components/telemetry/Events.yaml", "toolkit/components/telemetry/TelemetryEvent.cpp", "toolkit/components/telemetry/docs/collection/events.rst", "toolkit/components/telemetry/gen-event-data.py", "toolkit/components/telemetry/parse_events.py", "toolkit/components/telemetry/tests/unit/test_TelemetryEvents.js"], "git_node": null, "git_parents": [null], "node": "ceeec2fbbfc151c7d5dc5c493589a6e88cdae4c7", "parents": ["618bbe87c8226d99e7a49203ed7acadbe1901d9c"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "