/lib/TopSitesFeed.test.js", "browser/extensions/activity-stream/test/unit/unit-entry.js", "layout/tools/reftest/reftest-preferences.js", "testing/profiles/prefs_general.js", "testing/talos/talos/config.py", "toolkit/modules/NewTabUtils.jsm", "toolkit/modules/tests/xpcshell/test_NewTabUtils.js"], "git_node": null, "git_parents": [null], "node": "6ff9a23d3212300a97e3779364e5afa66cfc280b", "parents": ["7fe3a16c32f703bc9ff5f8a8906e11b1f44d6664"], "tags": []}, {"author": "Andrei Oprea \u003candrei.br92@gmail.com\u003e", "branch": "default", "desc": "Bug 1421312 - Import buttons on activity Stream incorrectly wrap. r=Mardak, a=gchang\n\nMozReview-Commit-ID: V7NKvx79lK", "files": ["browser/extensions/activity-stream/css/activity-stream-linux.css", "browser/extensions/activity-stream/css/activity-stream-mac.css", "browser/extensions/activity-stream/css/activity-stream-windows.css"], "git_node": null, "git_parents": [null], "node": "18524c7a40b32c1bbc5d47bf8f0fa8c80fdd0cb1", "parents": ["6ff9a23d3212300a97e3779364e5afa66cfc280b"], "tags": []}], "date": 1512255854, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8294": {"changesets": [{"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1407228 - Collapsed sections should be animated when they are reopened. r=r1cky, a=gchang\n\nMozReview-Commit-ID: B8WVq8h6uAa", "files": ["browser/extensions/activity-stream/css/activity-stream-linux.css", "browser/extensions/activity-stream/css/activity-stream-mac.css", "browser/extensions/activity-stream/css/activity-stream-windows.css", "browser/extensions/activity-stream/data/content/activity-stream.bundle.js", "browser/extensions/activity-stream/install.rdf.in"], "git_node": null, "git_parents": [null], "node": "699b253725efc849c4587b8c961f65f3e97d0bce", "parents": ["18524c7a40b32c1bbc5d47bf8f0fa8c80fdd0cb1"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1419538 - Marionette log entries should show object details. r=ato, a=test-only\n\nBy missing to convert a Javascript object to a packet and serializing\nit, no details were printed eg for session capabilities for the call\nto \"start_session()\".\n\nMozReview-Commit-ID: HdcehGpBvdA", "files": ["testing/marionette/message.js"], "git_node": null, "git_parents": [null], "node": "89e5df69214e2970045b29bc16e6611642f2f3ee", "parents": ["699b253725efc849c4587b8c961f65f3e97d0bce"], "tags": []}], "date": 1512257504, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "8295": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\naz -\u003e 2d7156df9604\nkab -\u003e c76fa1b7cce2\npt-PT -\u003e 1d338310049e", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "5458d3423176c3d1891a2ea48b48bbd039a9e2cc", "parents": ["89e5df69214e2970045b29bc16e6611642f2f3ee"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nhi-IN -\u003e 4dccafe480ad\nkab -\u003e c76fa1b7cce2\npt-PT -\u003e 1d338310049e\nro -\u003e c33551cf7cc2\nsi -\u003e 0c1768f74118", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "2432a6631d703d6589795c09ba56c57fc513f562", "parents": ["5458d3423176c3d1891a2ea48b48bbd039a9e2cc"], "tags": []}], "date": 1512289259, "git_changesets": [null, null], "user": "ffxbld"}, "8296": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nbn-BD -\u003e bfcca8495342\ncs -\u003e 46b29c781793\noc -\u003e 84d310d370aa", "files": ["mobile/locales/l10n-changesets.json"], "git_node": 