changesets": [{"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1506756 - Remove the use of real_path added in bug 1501903. r=andi, a=NPOTB\n\nIn the first part of bug 1501903, paths were canonicalized in\ninThirdPartyPath. For some reason, this seems to add a non-negligible\noverhead on Windows. OTOH, most include paths handed by the build system\nare absolute, and most paths that contains .. are for system headers,\nwhich don't matter for the inThirdPartyPath test.\n\nConsidering the inThirdPartyPath has been using non-canonicalized paths\nfor the longest, we'll assume it's fine to come back to that mode.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D11725", "files": ["build/clang-plugin/Utils.h"], "git_node": null, "git_parents": [null], "node": "6b3e88486ae17007d89f1b4925104f6d9f33886d", "parents": ["5054b80f1878eaacd75e5226a4cd3b295e001834"], "tags": []}, {"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1500310 - Better scoping for code in IDBObjectStore::GetAddInfo. r=asuth, a=RyanVM", "files": ["dom/indexedDB/IDBObjectStore.cpp"], "git_node": null, "git_parents": [null], "node": "7473fdd1c21c00299314892ad74b10aa5af67179", "parents": ["6b3e88486ae17007d89f1b4925104f6d9f33886d"], "tags": ["DEVEDITION_64_0b10_BUILD1", "DEVEDITION_64_0b10_RELEASE", "FIREFOX_64_0b10_BUILD1", "FIREFOX_64_0b10_RELEASE"]}], "date": 1542294459, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "10204": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nbn-BD -\u003e 3035daff3f8b\nbn-IN -\u003e c45f76e84aac\nbs -\u003e 120ef8e69e60\nca -\u003e a86095836484\ncak -\u003e 7948eb7fc67b\ncs -\u003e 804b4c5cf386\ncy -\u003e f1cdeddefe20\nde -\u003e 9c98a9c2f886\ndsb -\u003e d23bcc203a73\nel -\u003e 7a8152d86eab\nen-CA -\u003e f385d20