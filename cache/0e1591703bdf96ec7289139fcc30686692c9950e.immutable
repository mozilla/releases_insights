["security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc"], "git_node": null, "git_parents": [null], "node": "1d1018c58a27b9cd4b09228ad04e51419fcd091c", "parents": ["dd698bfe963903495792e63e44c72fed704996cd"], "tags": []}, {"author": "ScottDowne \u003cscott.downe@gmail.com\u003e", "branch": "default", "desc": "Bug 1507599 - Top stories more Recommendations link showing up for German locale even though page is English. r=andreio, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D12598", "files": ["browser/components/newtab/content-src/components/Sections/Sections.jsx", "browser/components/newtab/data/content/activity-stream.bundle.js", "browser/components/newtab/data/content/activity-stream.bundle.js.map"], "git_node": null, "git_parents": [null], "node": "b519e727ee9eaa9496136670b81dbe5ba749c44c", "parents": ["1d1018c58a27b9cd4b09228ad04e51419fcd091c"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1474443 - Remove cycle between MP4Demuxer and MP4TrackDemuxer. r=padenot, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D12004", "files": ["dom/media/mp4/MP4Demuxer.cpp", "dom/media/mp4/MP4Demuxer.h"], "git_node": null, "git_parents": [null], "node": "fdd0d5ac1d28020c16b5da499d5e65441c4e1f09", "parents": ["b519e727ee9eaa9496136670b81dbe5ba749c44c"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1507157 - Set network.disable.ipc.security to true. r=kershaw, a=RyanVM\n\nThis pref is left over from B2G days. It is currently disabled for firefox\ndesktop, but not for Android. This didn't affect us until now because we\nalways ran Android tests in non-e10s mode.\n\nThe pref ought to be removed in bug 1306801.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D12293", "files": ["browser/app/profile/firefox.js", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "5cb26828de28e16dbd8e4cc61a13d3d4dd62507f", "parents": ["fdd0d5ac1d28020c16b5da499d5e65441c4e1f09"], "tags": []}, {"author": "Bryce Van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1507389 - Update GMP fallback downloader for Widevine 4.10.1196.0. r=rhelmer, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D11981", "files": ["toolkit/content/gmp-sources/widevinecdm.json"], "git_node": null, "git_parents": [null], "node": "20620b54cc8cb5bf7f4c346ee7973698230450cd", "parents": ["5cb26828de28e16dbd8e4cc61a13d3d4dd62507f"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1484528 - Prevent page loading indicator running continuously. r=JanH, a=RyanVM\n\nThe page loading indicator should be animated while it is visible.\nPreviously for controlling the animation the visibility state of the parent\nDrawable - ShiftDrawable would be checked, which in all cases would return\ntrue, so the animation would run indefinitely.\n\nThe patch modifies setVisible() in accordance with the Framework version of\nDrawableWrapper to corectly set the visibility of both the wrapper and the\nwrapped drawables so that isVisible() will now return the correct value which\nwill allow stopping the animation.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D12552", "files": ["mobile/android/base/java/org/mozilla/gecko/drawable/DrawableWrapper.java"], "git_node": null, "git_parents": [null], "node": "8d5ec415316b873f2bca4b89b48b7190f02ed306", "parents": ["20620b54cc8cb5bf7f4c346ee7973698230450cd"], "tags": []}], "date": 1543249998, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10259": {"changesets": [{"author": "ScottDowne \u003cscott.downe@gmail.com\u003e", "branch": "default", "desc": "Bug 1507973 - V2 personalization using remote settings attachments. r=nanj, a=RyanVM\n\nDiffe