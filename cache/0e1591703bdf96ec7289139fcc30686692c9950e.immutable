ents": [null], "node": "55364b902bda00060a81dcbaa8a8722a9b637055", "parents": ["eab3bbb3539c8a22890c8ec4a42b448018988af8"], "tags": []}, {"author": "Ricky Rosario \u003crickyrosario@gmail.com\u003e", "branch": "default", "desc": "Bug 1503685 - Add home_extension_id and newtab_extension_id info to PAGE_TAKEOVER_DATA telemetry ping r=k88hudson a=jcristau\n\nSummary: MozReview-Commit-ID: C2Fahx4LGHv\n\nReviewers: k88hudson\n\nReviewed By: k88hudson\n\nBug #: 1503685\n\nDifferential Revision: https://phabricator.services.mozilla.com/D11919", "files": ["browser/components/newtab/docs/v2-system-addon/data_events.md", "browser/components/newtab/lib/TelemetryFeed.jsm", "browser/components/newtab/test/schemas/pings.js", "browser/components/newtab/test/unit/lib/TelemetryFeed.test.js"], "git_node": null, "git_parents": [null], "node": "ce76875904c66eb097b352296c1c72ed03a2d4b3", "parents": ["55364b902bda00060a81dcbaa8a8722a9b637055"], "tags": []}, {"author": "Florian Qu\u00e8ze \u003cflorian\u003e", "branch": "default", "desc": "Bug 1506105 - \"Buttons and icons are not visible in High Contrast mode\" r=Felipe a=jcristau", "files": ["toolkit/components/aboutperformance/content/aboutPerformance.xhtml"], "git_node": null, "git_parents": [null], "node": "811d4b940b9b6589840aa30f0000c8885b6c36b0", "parents": ["ce76875904c66eb097b352296c1c72ed03a2d4b3"], "tags": []}], "date": 1542905760, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "apavel@mozilla.com"}, "10248": {"changesets": [{"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 1499209 - Refactor AccessibleWrap::ToBundle 1/2. r=Jamie a=jcristau\n\nThis refactor does a few things:\n1. Unifies the composition of the GeckoBundle, so that some tricky edge\ncases don't need to be implemented twice.\n2. Allows us to be more frugal with round trip sync ipc calls. Instead\nof retrieving everything from the start, only progressivley retrieve\nwhat we need.\n3. Sets the groundwork for the next patch that will return from this\nfunction earlier with a smaller bundle.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8778", "files": ["accessible/android/AccessibleWrap.cpp", "accessible/android/AccessibleWrap.h", "accessible/android/ProxyAccessibleWrap.cpp", "accessible/android/ProxyAccessibleWrap.h"], "git_node": null, "git_parents": [null], "node": "4194c702938e71fa21e907e531aa2aaddaf20ffa", "parents": ["811d4b940b9b6589840aa30f0000c8885b6c36b0"], "tags": []}, {"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 1499209 - Send abbreviated source bundles with accessibility events. r=Jamie a=jcristau\n\nDepends on D8778\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8779", "files": ["accessible/android/AccessibleWrap.cpp", "accessible/android/AccessibleWrap.h", "accessible/android/SessionAccessibility.cpp"], "git_node": null, "git_parents": [null], "node": "59b5d9b0fe7eb87cbf8d4556d2efcd690f2dfb12", "parents": ["4194c702938e71fa21e907e531aa2aaddaf20ffa"], "tags": []}, {"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 1501496 - Don't send accessible GeckoBundle in sendEvent, class names is enough. r=Jamie a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9689", "files": ["accessible/android/AccessibleWrap.cpp", "accessible/android/AccessibleWrap.h", "accessible/android/Platform.cpp", "accessible/android/SessionAccessibility.cpp", "accessible/android/SessionAccessibility.h", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/SessionAccessibility.java"], "git_node": null, "git_parents": [null], "node": "d901616bfe1a7e9a45bc404e4d586586c4d2eeee", "parents": ["59b5d9b0fe7eb87cbf8d4556d2efcd690f2dfb12"], "tags": []}, {"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 1502187 - Add Batch protocol to PDocAccessible. r=Jamie a=jcristau\n\nThis protocol is meant to be used by platform wrappers to push bulk data\nto the chrome process.\n\nDepends on D9689\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9864", "files": ["accessible/android/Platform.cpp", "accessible/base/Platform.h", "accessible/ipc/DocAccessibleParent.cpp", "accessible/ipc/DocAccessibleParent.h", "accessible/ipc/other/PDocAccessible.ipdl"], "git_node": null, "git_parents": [null], "node": "f96dbab7b6a3cdf977e1b92a8f76f77d2e79b330", "parents": ["d901616bfe1a7e9a45bc404e4d586586c4d2eeee"], "tags": []}, {"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 1502187 - Add FULL_ACCESSIBILITY_TREE to GeckoSessionSettings. r=jchen a=jcristau\n\nDefaults now to 'true', when caching is good enough I'll switch it off.\n\nGenerally, this would be used for apps/cases when full accessible tree\nis needed like UIAutomator.\n\nDepends on D9864\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9865", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSessionSettings.java", "mobile/android/geckoview_example/src/main/java/org/mozilla/geckoview_example/GeckoViewActivity.java"], "git_node": null, "git_parents": [null], "node": "f75f849333f5d4f2616e483cae97a3956083fb27", "parents": ["f96dbab7b6a3cdf977e1b92a8f76f77d2e79b330"], "tags": []}, {"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 1502187 - Implement native part of viewport caching. r=Jamie a=jcristau\n\nDepends on D9865\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9866", "files": ["accessible/android/AccessibleWrap.cpp", "accessible/android/AccessibleWrap.h", "accessible/android/DocAccessibleWrap.cpp", "accessible/android/DocAccessibleWrap.h", "accessible/android/Platform.cpp", "accessible/android/SessionAccessibility.cpp", "accessible/android/SessionAccessibility.h", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/SessionAccessibility.java"], "git_node": null, "git_parents": [null], "node": "b3869ac5fad25da3c0d9913eabaf2f0679a1d6cf", "parents": ["f75f849333f5d4f2616e483cae97a3956083fb27"], "tags": []}, {"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 1502187 - Implement Java part of viewport tree caching. r=jchen a=jcristau\n\nDepends on D9866\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9867", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/geckoview/SessionAccessibility.java"], "git_node": null, "git_parents": [null], "node": "26a874969a1e6efe27fbdc617f791bfdf141730d", "parents": ["b3869ac5fad25da3c0d9913eabaf2f0679a1d6cf"], "tags": []}, {"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 1505515 - Null check nodeInfo bundle before retrieving class name. r=snorp a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D11210", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/geckoview/SessionAccessibility.java"], "git_node": null, "git_parents": [null], "node": "60b4eadd89fc24f010404fc3c542fa60b60e191a", "parents": ["26a874969a1e6efe27fbdc617f791bfdf141730d"], "tags": []}, {"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 1479039 - Move PersistentPropertiesToArray to nsAccUtils. r=Jamie a=jcristau\n\nIn order to send send attributes in BatchData we will need to convert\nthem to an array. Here we factor out the private function that does that\nand put it in nsAccUtils.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D11211", "files": ["accessible/base/nsAccUtils.cpp", "accessible/base/nsAccUtils.h", "accessible/ipc/other/DocAccessibleChild.cpp", "accessible/ipc/other/DocAccessibleChild.h"], "git_node": null, "git_parents": [null], "node": "2da43796c5bd9154f75673dc1ad64e2f0a5d5094", "parents": ["60b4eadd89fc24f010404f