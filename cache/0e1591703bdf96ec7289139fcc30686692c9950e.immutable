": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging fa72e773a9ebcd6de1c0e0d25e1cb6b07f09b6e8 with DEVEDITION_64_0b14_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "29f7e13e6a7e081402b6abfa1b4f4b5ce930fbc0", "parents": ["2cc5c3f56a466e7a456285402dfae1216b79be60"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release DONTBUILD", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "96633aad9421e5ee9d4bace7a30ee505ff41cf37", "parents": ["29f7e13e6a7e081402b6abfa1b4f4b5ce930fbc0"], "tags": []}], "date": 1543508848, "git_changesets": [null, null], "user": "ffxbld"}, "10283": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging fa72e773a9ebcd6de1c0e0d25e1cb6b07f09b6e8 with FIREFOX_64_0b14_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "2534c71731b1a8a1088e09b37760440f673e287a", "parents": ["96633aad9421e5ee9d4bace7a30ee505ff41cf37"], "tags": []}], "date": 1543509024, "git_changesets": [null], "user": "ffxbld"}, "10284": {"changesets": [{"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1510441: Add `.cron.yml` to the taskgraph sparse profile; r=gps a=tomprince DONTBUILD\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13142", "files": ["build/sparse-profiles/taskgraph"], "git_node": null, "git_parents": [null], "node": "3dce43d9b92c7947a8de8638d80adc5b04c3d9d9", "parents": ["2534c71731b1a8a1088e09b37760440f673e287a"], "tags": []}], "date": 1543560282, "git_changesets": [null], "user": "mozilla@hocat.ca"}, "10285": {"changesets": [{"author": "Jason Orendorff \u003cjorendorff@mozilla.com\u003e", "branch": "default", "desc": "Bug 1391756 - Try to fix rare timeout in dom/tests/mochitest/fetch/test_readableStreams.html. r=baku, a=test-only\n\nAlso removes an infinite regress of nested iframes. The original problem was\nthat tests would start running before the child iframe was done loading. The\nstraightforward fix is to have the child frame start the test. But this caused\nfurther error messages because the child iframe is loaded more than once;\nremoving the iframe from the iframe fixes this.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13385", "files": ["dom/tests/mochitest/fetch/common_readableStreams.js", "dom/tests/mochitest/fetch/iframe_readableStreams.html", "dom/tests/mochitest/fetch/test_readableStreams.html"], "git_node": null, "git_parents": [null], "node": "24a6a9b747b34914d8dcd6ae714ca37fe5d56739", "parents": ["3dce43d9b92c7947a8de8638d80adc5b04c3d9d9"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1508144 - Ignore clicks on non-clickable menu items. r=mixedpuppy, a=jcristau\n\nBug 1469148 added support for detecting which mouse button was used,\nby synthetizing \"command\" events when a \"click\" event was captured.\nThe implementation did not account for unclickable menu items, such\nas items that act as the parent of a submenu (see bug report),\nseparators and disabled menu items.\n\nThis patch adds the necessary checks and regression tests for these\nscenarios to make sure that such clicks are ignored, as expected.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13084", "files": ["browser/components/extensions/parent/ext-menus.js", "browser/components/extensions/test/browser/browser_ext_menus_capture_secondary_click.js"], "git_node": null, "git_parents": [null], "node": "3be25c15b7e9e3326826739bdc4f24ba94e8578b", "parents": ["24a6a9b747b34914d8dcd6ae714ca37fe5d56739"], "tags": []}], "date": 1543606546, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "10286": {"changesets": [{"author": "Jeff Gilbert \u003cjgilbert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1467406 - Remove broken default-fb invalidation path. r=lsalzman a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13047", "files": ["dom/canvas/WebGL2ContextFramebuffers.cpp"], "git_node": null, "git_parents": [null], "node": "f4fe9800063b5110cb59f2eafdc1ffc45feb5a60", "parents": ["3be25c15b7e9e3326826739bdc4f24ba94e8578b"], "tags": []}], "date": 1543622884, "git_changesets": [null], "user": "ccoroiu@mozilla.com"}, "10287": {"changesets": [{"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1508494: Update WNP with locales for 64; r=flod a=whats-new\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13555", "files": ["browser/config/whats_new_page.yml"], "git_node": null, "git_parents": [null], "node": "f744e835c8bf344bcd6f64b4b894a0a4d64a1c1c", "parents": ["f4fe9800063b5110cb59f2eafdc1ffc45feb5a60"], "tags": []}], "date": 1543644599, "git_changesets": [null], "user": "mozilla@hocat.ca"}, "10288": {"changesets": [{"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1504780 - Prevent crash if GeckoProfile path is not known. r=snorp, a=lizzard\n\nIn this case the profile name will be null, situation already handled, in which\na telemetry ping about the crash will not be sent but the crash can still be\nreported to crash-stats.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D12741", "files": ["mobile/android/base/java/org/mozilla/gecko/CrashReporterActivity.java"], "git_node": null, "git_parents": [null], "node": "3bebbace6e4a76ba5c158a922b8f8b541a709e30", "parents": ["f744e835c8bf344bcd6f64b4b894a0a4d64a1c1c"], "tags": []}, {"author": "Brendan Dahl \u003cbdahl@mozilla.com\u003e", "branch": "default", "desc": "Bug 1509576 - Fix crash when showing tooltip. r=NeilDeakin, a=lizzard\n\nHandle the case when there is no tooltip text provider.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13105", "files": ["dom/xul/XULTooltipElement.cpp"], "git_node": null, "git_parents": [null], "node": "729dc4b0b006c47a77ce65fd129054962467d6ec", "parents": ["3bebbace6e4a76ba5c158a922b8f8b541a709e30"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1506447 - Check overlay before checking custom scrollbar style in nsNativeThemeCocoa::GetWidgetTransparency. r=spohl, a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D12856", "files": ["widget/cocoa/nsNativeThemeCocoa.mm"], "git_node": null, "git_parents": [null], "node": "cb70f86f71435d262a2686b2ff85d11bb53f4348", "parents": ["729dc4b0b006c47a77ce65fd129054962467d6ec"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1511516 - Update Firefox 64 to NSS 3.40.1. r=jcj, a=lizzard\nUPGRADE_NSS_RELEASE", "files": ["old-configure.in", "security/nss/TAG-INFO", "security/nss/coreconf/coreconf.dep", "security/nss/gtests/freebl_gtest/mpi_unittest.cc", "security/nss/gtests/freebl_gtest/rsa_unittest.cc", "security/nss/lib/freebl/mpi/mpi.c", "security/nss/lib/freebl/mpi/mpi.h", "security/nss/lib/freebl/rsapkcs.c", "security/nss/lib/nss/nss.h", "security/nss/lib/softoken/softkver.h", "security/nss/lib/ssl/ssl3con.c", "security/nss/lib/util/nssutil.h"], "git_node": null, "git_parents": [null], "node": "e4535e943651ce499a93bbc4592cb16adab897bd", "parents": ["cb70f86f71435d262a2686b2ff85d11bb53f4348"], "tags": ["FIREFOX_RELEASE_64_BASE"]}], "date": 1543785888, "git_changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "10289": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging mozilla-beta e4535e943651ce499a93bbc4592cb16adab897bd with FIREFOX_RELEAS