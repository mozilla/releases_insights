"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1499685 - Fix browser_aboutCertError.js test cases for the old cert error pages. r=nhnt11\n\nTwo of these tests simply require the new pref to be set, while there was some actual\nbreakage that required me to put some more code behind another gate.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8978", "files": ["browser/base/content/aboutNetError-new.xhtml", "browser/base/content/aboutNetError.js", "browser/base/content/test/about/browser_aboutCertError.js"], "git_node": null, "git_parents": [null], "node": "8d820a4fe6e63e80cb05e5c27351b7a3fdf57577", "parents": ["9305a99ea1c3aab53a9675be0f76ec60b1a30e5b"], "tags": []}, {"author": "Thomas Wisniewski \u003ctwisniewski@mozilla.com\u003e", "branch": "default", "desc": "Bug 1499136 - Disable dom.xhr.standard_content_type_normalization for now due to webcompat issues; r=hsivonen\n\nDisable dom.xhr.standard_content_type_normalization for now due to webcompat issues\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8789", "files": ["dom/xhr/tests/test_XHRSendData.html", "modules/libpref/init/StaticPrefList.h"], "git_node": null, "git_parents": [null], "node": "0bb500ba0c07c122610452184a162166ff47ce96", "parents": ["8d820a4fe6e63e80cb05e5c27351b7a3fdf57577"], "tags": []}, {"author": "Bogdan Tara \u003cbtara@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 0e8706e5d2ff (bug 1473841) for browser_jsterm_completion_invalid_dot_notation.js failures CLOSED TREE", "files": ["devtools/client/webconsole/components/JSTerm.js", "devtools/client/webconsole/test/mochitest/browser.ini", "devtools/client/webconsole/test/mochitest/browser_jsterm_completion_invalid_dot_notation.js"], "git_node": null, "git_parents": [null], "node": "638dee1dfab113b0c2333fb62509180cf21c2124", "parents": ["0bb500ba0c07c122610452184a162166ff47ce96"], "tags": []}, {"author": "Daniel Varga \u003cdvarga@mozilla.com\u003e", "branch": "default", "desc": "Removed files (Bug 1499111) Update test expectations for tests with unexpected results. a=wpt-fix", "files": ["testing/web-platform/meta/html/semantics/forms/the-select-element/common-HTMLOptionsCollection.html.ini", "testing/web-platform/meta/html/semantics/forms/the-select-element/select-remove.html.ini"], "git_node": null, "git_parents": [null], "node": "02ec505980f1a5945de491c094f7e72bc1da98ce", "parents": ["0658fbb91e05b270f67252ec87e918d59d4aaf6d"], "tags": []}, {"author": "Daniel Varga \u003cdvarga@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 37647eaadbc2 (bug 1498185) for browser chrome failure at browser/base/content/test/static/browser_all_files_referenced.js on a CLOSED TREE", "files": ["toolkit/components/aboutperformance/content/aboutPerformance.js", "toolkit/components/aboutperformance/content/aboutPerformance.xhtml", "toolkit/themes/shared/icons/shortcut.svg", "toolkit/themes/shared/jar.inc.mn"], "git_node": null, "git_parents": [null], "node": "2e10a4e7039458e8e20c71d9ff03cecb81b33869", "parents": ["02ec505980f1a5945de491c094f7e72bc1da98ce"], "tags": []}, {"author": "Daniel Varga \u003cdvarga@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 0658fbb91e05 (bug 1499483) for devtools chrome failure at devtools/client/inspector/test/browser_inspector_sidebarstate.js on a CLOSED TREE", "files": ["devtools/client/inspector/inspector.js", "devtools/client/preferences/devtools-client.js"], "git_node": null, "git_parents": [null], "node": "0d9b7b7a5aa5d30412233ffbbabe24dd26df97d0", "parents": ["2e10a4e7039458e8e20c71d9ff03cecb81b33869"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to mozilla-inbound. CLOSED TREE", "files": ["toolkit/components/telemetry/Histograms.json", "toolkit/mozapps/extensions/test/browser/browser_getmorethemes.js"], "git_node": null, "git_parents": [null, null], "node": "1ee3bf5fd803b1382548e6c0ae77ae8dcab9dd91", "parents": ["0d9b7b7a5aa5d30412233ffbbabe24dd26df97d0", "bfd23ad81ef4074f395036cc62fa31ff3cd97f96"], "tags": []}, {"author": "Jeff Gilbert \u003cjgilbert@mozilla.com\u003e", "branch": "default", "desc": "No bug - Strip EOL whitespace from widget/windows/nsWindow.cpp.\n\nMozReview-Commit-ID: 31tcxJWLRG2\n", "files": ["widget/windows/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "0ef00ee6c5312035280635f06e4790abd8b13729", "parents": ["1ee3bf5fd803b1382548e6c0ae77ae8dcab9dd91"], "tags": []}, {"author": "A. Wilcox \u003cAWilcox@Wilcox-Tech.com\u003e", "branch": "default", "desc": "Bug 1498938 - Support [implicit_jscontext] XPIDL calls on Linux/PPC64.; r=froydnj", "files": ["xpcom/reflect/xptcall/md/unix/xptcstubs_ppc64_linux.cpp"], "git_node": null, "git_parents": [null], "node": "06e5a5bfd05ef276dce035af837f2ba76e9a55a4", "parents": ["0ef00ee6c5312035280635f06e4790abd8b13729"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1498651 - make initial timer target setting more efficient; r=erahm\n\nThe NS_NewTimer* family of functions, when using a custom event target,\ncurrently go through a path that looks something like:\n\n  auto timer = createTimer()\n  timer-\u003eSetTarget(target);\n  // call the requisite Init* function\n  return timer;\n\nThis setup is inefficient, because SetTarget requires the timer mutex to\nbe acquired.  The mutex acquisition here is completely unnecessary,\nbecause the timer hasn't yet been shared out to the wider world; we can\nset the timer target without acquiring the mutex at all because we know\nthat no sharing is possible at this point.\n\nThis patch reworks things somewhat to make that possible.", "files": ["xpcom/build/XPCOMInit.cpp", "xpcom/build/XPCOMModule.inc", "xpcom/threads/nsTimerImpl.cpp", "xpcom/threads/nsTimerImpl.h"], "git_node": null, "git_parents": [null], "node": "3714d89762380c501cf13257d0c373260dc7de0e", "parents": ["06e5a5bfd05ef276dce035af837f2ba76e9a55a4"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1499726 - make main-thread XHR timer setting slightly more efficient; r=baku\n\nInstead of creating a timer and then setting the timer's target, we can\ndetermine the timer's target and pass it in directly when the timer is\ncreated.  This reordering of steps is slightly more efficient, since\nSetTarget() is both a virtual call and requires locking, both of which\ncan be skipped if we know the target at timer creation time.", "files": ["dom/xhr/XMLHttpRequestMainThread.cpp", "dom/xhr/XMLHttpRequestMainThread.h"], "git_node": null, "git_parents": [null], "node": "706f1a7eae882e297e85322e4dccba27a222e4a0", "parents": ["3714d89762380c501cf13257d0c373260dc7de0e"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1499727 - make nsHtml5StreamParser timers slightly more efficient; r=hsivonen\n\nInstead of creating a timer and then setting the timer's target, we can\ndetermine the timer's target and pass it in directly when the timer is\ncreated.  This reordering of steps is slightly more efficient, since\nSetTarget() is both a virtual call and requires locking, both of which\ncan be skipped if we know the target at timer creation time.", "files": ["parser/html/nsHtml5StreamParser.cpp"], "git_node": null, "git_parents": [null], "node": "fd914881db604175bdd129d62ec1cb3c8d0a0386", "parents": ["706f1a7eae882e297e85322e4dccba27a222e4a0"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1499848 - make TimeoutExecutor timers slightly more efficient; r=baku\n\nInstead of creating a timer and then setting the timer's target, we can\ndetermine the timer's target and pass it in directly when the timer is\ncreated.  This reordering of steps is slightly more efficient, since\nSetTarget() is both a virtual call and requires locking, both of which\ncan be skipped if we know the target at timer creation time.", "files": ["dom/base/TimeoutExecutor.cpp"], "git_node": null, "git_parents": [null], "node": "18c94f6d82046c4986c0c55f41a6fbf4039c8288", "parents": ["fd914881db604175bdd129d62ec1cb3c8d0a0386"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1499849 - make FileReader timers slightly more efficient; r=baku\n\nInstead of creating a timer and then setting the timer's target, we can\ndetermine the timer's target and pass it in directly when the timer is\ncreated.  This reordering of steps is slightly more efficient, since\nSetTarget() is both a virtual call and requires locking, both of which\ncan be skipped if we know the target at timer creation time.", "files": ["dom/file/FileReader.cpp"], "git_node": null, "git_parents": [null], "node": "8b037400fdbed6b9fd14c36a8b32acd78a742e1d", "parents": ["18c94f6d82046c4986c0c55f41a6fbf4039c8288"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1495748: Make sure ChannelWrappers get cleaned up before JS engine shutdown. r=aswan,mccr8\n\nThe gross contortions here are required to deal with the deferred finalizers\nHTTP channels use for their property bags. The actual channels get destroyed\nrelatively early during shutdown, but their property bag hashes which hold our\nChannelWrapper reference end up being destroyed after JS engine shutdown,\nwhich gives us no good point to clear our reference.\n\nThe stub holder class takes the place of our existing property bag entry, and\nbehaves more or less the same, but allows us to cut the reference to the\nChannelWrapper without having a strong reference to the channel.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8923", "files": ["toolkit/components/extensions/webrequest/ChannelWrapper.cpp", "toolkit/components/extensions/webrequest/