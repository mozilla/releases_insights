/test/unit/test_permmanager_notifications.js", "extensions/cookie/test/unit/test_permmanager_removebytype.js", "netwerk/test/unit/test_permmgr.js"], "git_node": null, "git_parents": [null], "node": "a96813612e0cee496e7d3e8e3b5d805233c0f74e", "parents": ["0e12912bc61b604fe805a4c0d6ec9bbc75ec00f6"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1506640 - Trace wrappers rooters during sweep phase. r=pbone, a=RyanVM", "files": ["js/src/gc/GC.cpp"], "git_node": null, "git_parents": [null], "node": "d4ce8b3cdee86a47d1e201bde99f81756b45193a", "parents": ["a96813612e0cee496e7d3e8e3b5d805233c0f74e"], "tags": []}, {"author": "Gabriele Svelto \u003cgsvelto@mozilla.com\u003e", "branch": "default", "desc": "Bug 1498942 - Don't attempt to take minidumps of hung content processes when shutting down. r=Ehsan, a=jcristau\n\nThis patch also takes the timeout for killing a content process back to its\noriginal value and removes a related but long unused field.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D11739", "files": ["dom/ipc/ContentParent.cpp", "dom/ipc/ContentParent.h", "modules/libpref/init/StaticPrefList.h"], "git_node": null, "git_parents": [null], "node": "be6c9c1f12a731ab06f4236848354e8190bb252e", "parents": ["d4ce8b3cdee86a47d1e201bde99f81756b45193a"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1504686 - Don't count search for same document changes. r=Standard8, a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D11394", "files": ["browser/modules/BrowserUsageTelemetry.jsm"], "git_node": null, "git_parents": [null], "node": "ceba8351e044c15a408e8302d41bafc21e70e528", "parents": ["be6c9c1f12a731ab06f4236848354e8190bb252e"], "tags": []}, {"author": "Benjamin Bouvier \u003cbenj@benj.me\u003e", "branch": "default", "desc": "Bug 1507564 - Bind code labels when generating lazy table stubs. r=luke, a=jcristau\n\nA lazy stub could generate CodeLabels on x86, because of a constant NaN\ngenerated for the entry's epilogue that ended up in a constant pool. We need to\nactually bind these code labels in general.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D12052", "files": ["js/src/jit-test/tests/wasm/regress/lazy-table-nan.js", "js/src/wasm/WasmCode.cpp"], "git_node": null, "git_parents": [null], "node": "f6a1e485be9a28e08d4eb1b22140a900d1676e8b", "parents": ["ceba8351e044c15a408e8302d41bafc21e70e528"], "tags": []}, {"author": "Kershaw Chang \u003ckershaw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1504512 - Do not delete mTrailers explicitly. r=valentin, a=jcristau\n\nSince mTrailers is nsAutoPtr, there is no need to delete it explicitly.", "files": ["netwerk/protocol/http/nsHttpChunkedDecoder.h"], "git_node": null, "git_parents": [null], "node": "af979f77c8384b56c66ba142d7f50e1c2675dfaf", "parents": ["f6a1e485be9a28e08d4eb1b22140a900d1676e8b"], "tags": []}], "date": 1542637249, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10227": {"changesets": [{"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1505310 - Enable certificate error page event telemetry on release. r=janerik, a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D11302", "files": ["toolkit/components/telemetry/Events.yaml"], "git_node": null, "git_parents": [null], "node": "467e62db7b1435dbcdb6b9033b2fc9484587c618", "parents": ["af979f77c8384b56c66ba142d7f50e1c2675dfaf"], "tags": []}, {"author": "Dale Harvey \u003cdale@arandomurl.com\u003e", "branch": "default", "desc": "Bug 1507444 - Add context fill opacity for windows share icon. r=Gijs, a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D12002", "files": ["browser/themes/windows/share.svg"], "git_node": null, "git_parents": [null], "node": "ec2a453085ce9a09884190065bd52ea1cb58f655", "parents": ["467e62db7b1435dbcdb6b9033b2fc9484587c618"], "tags": []}, {"author": "Lars T Hansen \u003clhansen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1507572 - Generalize alignments for memory ops testing. r=bbouvier, a=jcristau\n\nThese test cases already had some infrastructure for parameterizing\nover alignment, it just wasn't being used.  Once enabled it stubles\nacross the ARM bugs quickly.", "files": ["js/src/jit-test/tests/wasm/memory.js"], "git_node": null, "git_parents": [null], "node": "04a44178fb99f2f7877eb9fde7bb25785b389a0f", "parents": ["ec2a453085ce9a09884190065bd52ea1cb58f655"], "tags": []}, {"author": "Lars T Hansen \u003clhansen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1507572 - Correctly implement unaligned stores of i64 sub-fields. r=bbouvier, a=jcristau\n\nFixes Rabaldr by adding code to the ARM assembler to deal with\nunaligned 16- and 32-bit stores from a 64-bit datum.\n\nFixes Baldr by dispatching on the value type (as we do everywhere\nelse), not the access type, and then relying on the just-fixed\nassembler to do the right thing.", "files": ["js/src/jit-test/tests/wasm/regress/unaligned-store64.js", "js/src/jit/arm/CodeGenerator-arm.cpp", "js/src/jit/arm/MacroAssembler-arm.cpp"], "git_node": null, "git_parents": [null], "node": "34b98cadb7881503cbffe67c4b6e8a88e31a77a8", "parents": ["04a44178fb99f2f7877eb9fde7bb25785b389a0f"], "tags": []}, {"author": "Benjamin Bouvier \u003cbenj@benj.me\u003e", "branch": "default", "desc": "Bug 1507730 - Generate a temporary for negative power-of-two constants in mul64 on 32 bits platforms. r=lth, a=jcristau\n\nIn the code generator function, we assume we have a temp if a known constant is\na non-negative power of two. But lowering only checked for power of twos\nindependently of their sign, so this was incorrect. This patch syncs them up on\nboth ARM32 and x86.", "files": ["js/src/jit-test/tests/wasm/regress/imul64-ion-negative-power-of-two.js", "js/src/jit/arm/Lowering-arm.cpp", "js/src/jit/x86/Lowering-x86.cpp"], "git_node": null, "git_parents": [null], "node": "3910d176d5c23498232c207e5fb5e844c62e0ec8", "parents": ["34b98cadb7881503cbffe67c4b6e8a88e31a77a8"], "tags": []}, {"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1499193 - Follow-up 2: Update SEARCH_COUNTS key. r=mkaply, a=jcristau\n\nChange the `\u003cengine\u003e.\u003calias\u003e.urlbar` `SEARCH_COUNTS` keys to `\u003cengine\u003e.alias` as described in bug 1499193 comment 23 and later.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D12038", "files": ["browser/modules/BrowserUsageTelemetry.jsm", "browser/modules/test/browser/browser_UsageTelemetry_urlbar.js", "toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "32fc87f1af7c3af8f36fb6d8af72630441033231", "parents": ["3910d176d5c23498232c207e5fb5e844c62e0ec8"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1505897 - Initialize GeckoSystemStateListener in child process. r=agi, a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D11517", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoSystemStateListener.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoThread.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoRuntime.java", "widget/android/nsAppShell.cpp"], "git_node": null, "git_parents": [null], "node": "28b294890d1ceb2b6be070f0472b05ea9d9a7f49", "parents": ["32fc87f1af7c3af8f36fb6d8af72630441033231"], "tags": []}], "date": 1542639096, "git_changesets": [null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10228": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nbg -\u003e 9cd31b6aaf4e\nes-ES -\u003e c57dacf71d5f\nfr