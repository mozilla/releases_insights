zilla.com\u003e", "branch": "default", "desc": "Bug 1504370 - Update SEARCH_COUNTS telemetry for private browsing mode r=mkaply a=jcristau\n\n* If a search is performed in a private window and the new pref `browser.engagement.search_counts.pbm` is true, then do not record `SEARCH_COUNTS` telemetry. Note that the the pref must be true. If it's false or doesn't exist, then we record telemetry even in pbm like we normally do currently. (We record `SEARCH_COUNTS` telemetry in two places: (1) In BrowserUsageTelemetry.jsm, and (2) \"in-content\" telemetry directly in the search service. So skip both of those places.)\n* Also skip the other ancillary telemetry recorded by `BrowserUsageTelemetry._recordSearch`: a keyed scalar and a telemetry event.\n* I made some modifications to the search service to let me test the \"in-content\" telemetry keys\n\nDifferential Revision: https://phabricator.services.mozilla.com/D10851", "files": ["browser/base/content/browser.js", "browser/components/extensions/parent/ext-search.js", "browser/modules/BrowserUsageTelemetry.jsm", "browser/modules/test/browser/browser_UsageTelemetry_urlbar.js", "dom/media/platforms/agnostic/OpusDecoder.cpp", "toolkit/components/search/nsSearchService.js"], "git_node": null, "git_parents": [null], "node": "5336b29e9db097a82a4222e6332ba16063e9836e", "parents": ["a2196a27b2dd5c087b4a2aeda432651f2960f3a6"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1506643 - [marionette] Disable \"about:newtab\" page, and always load \"about:blank\". r=ato a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D11691", "files": ["testing/marionette/client/marionette_driver/geckoinstance.py", "testing/marionette/components/marionette.js"], "git_node": null, "git_parents": [null], "node": "fd2d2838220419e3e2682889598cfcded38211fd", "parents": ["5336b29e9db097a82a4222e6332ba16063e9836e"], "tags": []}], "date": 1542112138, "git_changesets": [null, null, null, null], "user": "cbrindusan@mozilla.com"}, "10176": {"changesets": [{"author": "Brindusan Cristian \u003ccbrindusan@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 5336b29e9db0 (bug 1504370). a=backout", "files": ["browser/base/content/browser.js", "browser/components/extensions/parent/ext-search.js", "browser/modules/BrowserUsageTelemetry.jsm", "browser/modules/test/browser/browser_UsageTelemetry_urlbar.js", "dom/media/platforms/agnostic/OpusDecoder.cpp", "toolkit/components/search/nsSearchService.js"], "git_node": null, "git_parents": [null], "node": "c1babc4f5dfc82eaf9edf4377c87d029dd6564c1", "parents": ["fd2d2838220419e3e2682889598cfcded38211fd"], "tags": []}], "date": 1542113859, "git_changesets": [null], "user": "cbrindusan@mozilla.com"}, "10177": {"changesets": [{"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1504944 - Only re-order channels for opus mapping 1. r=padenot a=jcristau\n\nFor channel mapping 0 (which is always mono or sterero), the mapping is identical to the SMPTE one, so can copy the mapping as-is.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D11000", "files": ["dom/media/platforms/agnostic/OpusDecoder.cpp"], "git_node": null, "git_parents": [null], "node": "072d56f53c88aa83db40ccb4be38226bf24ebddc", "parents": ["c1babc4f5dfc82eaf9edf4377c87d029dd6564c1"], "tags": []}, {"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1504370 - Update SEARCH_COUNTS telemetry for private browsing mode r=mkaply a=jcristau\n\n* If a search is performed in a private window and the new pref `browser.engagement.search_counts.pbm` is true, then do not record `SEARCH_COUNTS` telemetry. Note that the the pref must be true. If it's false or doesn't exist, then we record telemetry even in pbm like we normally do currently. (We record `SEARCH_COUNTS` telemetry in two places: (1) In BrowserUsageTelemetry.jsm, and (2) \"in-content\" telemetry directly in the search service. So skip both of those places.)\n* Also skip the other ancillary telemetry recorded by `BrowserUsageTelemetry._recordSearch`: a keyed scalar and a telemetry event.\n* I made some modifications to the search service to let me test the \"in-content\" telemetry keys\n\nDifferential Revision: https://phabricator.services.mozilla.com/D10851", "files": ["browser/base/content/browser.js", "browser/components/extensions/parent/ext-search.js", "browser/modules/BrowserUsageTelemetry.jsm", "browser/modules/test/browser/browser_UsageTelemetry_urlbar.js", "toolkit/components/search/nsSearchService.js"], "git_node": null, "git_parents": [null], "node": "f3c21b2ef2421f82a0d178489cf45b8eb44f516f", "parents": ["072d56f53c88aa83db40ccb4be38226bf24ebddc"], "tags": []}], "date": 1542114836, "git_changesets": [null, null], "user": "cbrindusan@mozilla.com"}, "10178": {"changesets": [{"author": "Andi-Bogdan Postelnicu \u003cbpostelnicu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1501351 - Gradle fails to download some artifacts even though bintray advertises it has them. r=nalexander\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9553", "files": ["mobile/android/config/mozconfigs/android-api-16-gradle-dependencies/nightly", "mobile/android/config/mozconfigs/common", "mobile/android/gradle.configure"], "git_node": null, "git_parents": [null], "node": "6899c552516d5d302c73a776400b82e435007d5f", "parents": ["f3c21b2ef2421f82a0d178489cf45b8eb44f516f"], "tags": []}, {"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1505514 - geckoview artifacts don't specify branch when mozilla-release r=snorp a=release\n\nDifferential Revision: https://phabricator.services.mozilla.com/D11447", "files": ["mobile/android/geckoview/build.gradle"], "git_node": null, "git_parents": [null], "node": "17a9ab8d9200549682861bde9c01e27e4e22c308", "parents": ["6899c552516d5d302c73a776400b82e435007d5f"], "tags": []}], "date": 1542115747, "git_changesets": [null, null], "user": "jlorenzo@mozilla.com"}, "10179": {"changesets": [{"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1501648 - Prevent crashes for unregistered receivers from MmaDelegate and GeckoMediaControlAgent. r=jchen,JanH, a=jcristau\n\nAlthough this two receivers are guarded by checks for if they were initialized\n(and so registered) there are reports of crashes because of trying to unregister\nthem without them actually being registered.\n\nThe underlying issue will be investigated further in bug 1505685 but for the\nmoment wrapping the unregister operations in a try-catch saves the users from\na crash and because the unregister is done when the app is closed\n(for the MmaDelegate receiver) or when the app finished playing media\n(for the GeckoMediaControlAgent receiver) the user doesn't loose any\nfunctionality going forward.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D11177", "files": ["mobile/android/base/java/org/mozilla/gecko/media/GeckoMediaControlAgent.java", "mobile/android/base/java/org/mozilla/gecko/mma/MmaDelegate.java"], "git_node": null, "git_parents": [null], "node": "7e437c76c2707ccadc0fcab0f2d24e7868c2a4c1", "parents": ["17a9ab8d9200549682861bde9c01e27e4e22c308"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1502083 - Move the 'Close Other Tabs' and 'Close Tabs to the Right' back to the main tab context menu and out of a submenu. r=dao, a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D11223", "files": ["browser/base/content/browser.xul", "browser/base/content/tabbrowser.js"], "git_node": null, "git_parents": [null], "node": "03052d0f2f71e4be86fb9b3fa438f88e0da49f38", "parents": ["7e437c76c2707ccadc0fcab0f2d24e7868c2a4c1"], "tags": []}, {"author": "Florian Qu\u00e8ze \u003cflorian@queze.net\u003e", "branch": "default", "desc": "Bug 1503680 - Fix about:performance styling to support RTL. r=felipe, a=RyanVM", "files": ["toolkit/components/aboutperformance/content/aboutPerformance.xhtml"], "git_node": null, "git_parents": [null], "node": "afb34abc2e8b56e3d0955d9a9a20438f61ed5ec1", "parents": ["03052d0f2f71e4be86fb9b3fa438f88e0da49f38"], "tags": []}, {"author": "Florian Qu\u00e8ze \u003cflorian@queze.net\u003e", "branch": "default", "desc": "Bug 1502951 - Fix about:performance layout issues caused by scrollbars on small windows and on Windows. r=felipe, a=jcristau", "files": ["toolkit/components/aboutperformance/content/aboutPerformance.xhtml"], "git_node": null, "git_parents": [null], "node": "7596f6afa47537bacba4e0f490c522260afc5edf", "parents": ["afb34abc2e8b56e3d0955d9a9a20438f61ed5ec1"], "tags": []}], "date": 1542124097, "git_changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "10180": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 6226ce7f4038d566fe750b1d13f107146d137463 with FENNEC_64_0b9_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "315e01841499e0aa66783d3e463ec2450464f2cd", "parents": ["7596f6afa47537bacba4e0f490c522260afc5edf"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release DONTBUILD", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "05e5d9e946b6a9a2dbc05f0a39206de553b026c6", "parents": ["315e01841499e0aa66783d3e463ec2450464f2cd"], "tags": []}], "date": 1542126948, "git_changesets": [null, null], "user": "ffxbld"}, "10181": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 6226ce7f4038d566fe750b1d13f107146d137463 with DEVEDIT