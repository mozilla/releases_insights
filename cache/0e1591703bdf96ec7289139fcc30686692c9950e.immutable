": [null, null], "user": "ffxbld"}, "10075": {"changesets": [{"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1497947 - Add nsStandardURL::TemplatedMutator to infrastructure/server WPT allowed list. r=mccr8, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D10218", "files": ["testing/web-platform/meta/infrastructure/server/__dir__.ini"], "git_node": null, "git_parents": [null], "node": "ec670e047c06c8822f746d59c7f2ef70748393eb", "parents": ["9c10dcb9a14d326c3bb53d964c079e53f439b003"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1502252 - Use thread-safe refcounting for nsFontCache. r=emilio, a=RyanVM", "files": ["gfx/src/nsDeviceContext.cpp"], "git_node": null, "git_parents": [null], "node": "c5c1526daf281e50a924bba862a760a9aea363f0", "parents": ["ec670e047c06c8822f746d59c7f2ef70748393eb"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 805f1a2737a0 (bug 1492074) for causing bug 1503009. a=RyanVM", "files": ["js/src/frontend/Parser.cpp", "js/src/jit-test/tests/modules/dynamic-import-lazy.js", "testing/web-platform/meta/html/semantics/scripting-1/the-script-element/module/dynamic-import/dynamic-imports-fetch-error.sub.html.ini", "testing/web-platform/meta/html/semantics/scripting-1/the-script-element/module/dynamic-import/dynamic-imports-script-error.html.ini"], "git_node": null, "git_parents": [null], "node": "dd2b79631e52ceea81d5b2e46b36901948608e53", "parents": ["c5c1526daf281e50a924bba862a760a9aea363f0"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset d1b2141b1c45 (bug 1484948) for causing bug 1503009. a=RyanVM", "files": ["js/src/builtin/ReflectParse.cpp", "js/src/frontend/BytecodeEmitter.cpp", "js/src/frontend/FoldConstants.cpp", "js/src/frontend/FullParseHandler.h", "js/src/frontend/NameFunctions.cpp", "js/src/frontend/ParseNode.h", "js/src/frontend/Parser.cpp", "js/src/frontend/Parser.h", "js/src/frontend/SyntaxParseHandler.h", "js/src/jit-test/tests/modules/dynamic-import-expression.js", "js/src/js.msg", "js/src/jsast.tbl", "testing/web-platform/meta/html/semantics/scripting-1/the-script-element/module/dynamic-import/dynamic-imports-fetch-error.sub.html.ini", "testing/web-platform/meta/html/semantics/scripting-1/the-script-element/module/dynamic-import/dynamic-imports-script-error.html.ini", "testing/web-platform/meta/html/semantics/scripting-1/the-script-element/module/dynamic-import/dynamic-imports.html.ini", "testing/web-platform/meta/html/semantics/scripting-1/the-script-element/module/dynamic-import/propagate-nonce-external-classic.html.ini", "testing/web-platform/meta/html/semantics/scripting-1/the-script-element/module/dynamic-import/propagate-nonce-external-module.html.ini", "testing/web-platform/meta/html/semantics/scripting-1/the-script-element/module/dynamic-import/propagate-nonce-inline-classic.html.ini", "testing/web-platform/meta/html/semantics/scripting-1/the-script-element/module/dynamic-import/propagate-nonce-inline-module.html.ini"], "git_node": null, "git_parents": [null], "node": "c2d642cb5eb28fedc0b8edb46e9fd02d2f689e2b", "parents": ["dd2b79631e52ceea81d5b2e46b36901948608e53"], "tags": []}], "date": 1540998704, "git_changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "10076": {"changesets": [{"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1499941 - Fix spatial vs. scroll coordinate confusion around APZCTreeManager::ProcessDynamicToolbarMovement() and helpers. r=kats, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9715", "files": ["gfx/layers/apz/src/APZCTreeManager.h", "gfx/layers/apz/src/AndroidDynamicToolbarAnimator.cpp", "gfx/layers/apz/src/SimpleVelocityTracker.cpp"], "git_node": null, "git_parents": [null], "node": "b5f86619d08561677cfab972b281e4c06fa6c8a6", "parents": ["c2d642cb5eb28fedc0b8edb46e9fd02d2f689e2b"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1498898 - Don't draw container-only widgets. r=jhorak, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9379", "files": ["widget/gtk/nsNativeThemeGTK.cpp", "widget/gtk/nsNativeThemeGTK.h"], "git_node": null, "git_parents": [null], "node": "2bb12341b0fd82417cddd5caf19fd4a25b854680", "parents": ["b5f86619d08561677cfab972b281e4c06fa6c8a6"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1500193 - Include a tooltip on add-on listing card. r=jaws, a=RyanVM\n\nInclude the tooltip from the old \"More\" link on listing cards.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9707", "files": ["toolkit/mozapps/extensions/content/extensions.xml"], "git_node": null, "git_parents": [null], "node": "9f3e14f67500fa0bb246abb3b6501067082578ae", "parents": ["2bb12341b0fd82417cddd5caf19fd4a25b854680"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1501402 - Include description in about:addons listing view again. r=jaws, a=RyanVM\n\nAdd the description back to the listing view. It might not get removed in the redesign so we'll keep it in for this version.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9706", "files": ["toolkit/mozapps/extensions/content/extensions.xml", "toolkit/themes/shared/extensions/extensions.inc.css"], "git_node": null, "git_parents": [null], "node": "761e9b73da90ed206ee661844f4a5cc6bb37fac8", "parents": ["9f3e14f67500fa0bb246abb3b6501067082578ae"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1498934 - Fix handler app enumeration issue. r=Gijs, a=RyanVM\n\nSince gioApps here is a plain nsIArray, it doesn't have any intrinsic type\ninformation, and we only get the correct interfaces if they've already been\nqueried. Adding an interface parameter to the enumerate() call fixes the\nissue.\n\nThis code is apparently untested, or incompletely tested.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9672", "files": ["toolkit/mozapps/handling/content/dialog.js"], "git_node": null, "git_parents": [null], "node": "c96f6ed751bf51a86d910aad441c3b1538f674a7", "parents": ["761e9b73da90ed206ee661844f4a5cc6bb37fac8"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1497526 - TransactionTooLargeException when downloading from Data URLs. r=jchen, a=RyanVM\n\nThe issue stems from putting download's source url as `cookie` in the\npending intent for when the download notification is clicked.\nThis cookie functions like a tag, allowing to identify a particular download.\n\nThe problem is that a download's url can be a Data URL for which Mozilla\nimposes no size limit.\nWhen an Android Intent with that payload is used it counts against Binder's\n1MB limit which can result in the TransactionTooLargeException.\n\nIf we are to truncate download's source url to an arbitrary length of 100\nwe should still get a unique `cookie` for that download and at the same time\navoid cluttering Notification's contentIntent.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9666", "files": ["mobile/android/modules/DownloadNotifications.jsm"], "git_node": null, "git_parents": [null], "node": "f9da620994ae1a1cf533882625c1777af07f56c3", "parents": ["c96f6ed751bf51a86d910aad441c3b1538f674a7"], "tags": []}], "date": 1541000256, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10077": {"changesets": [{"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1488011 - Set the checkbox label instead of using an adjacent XUL label so the checkbox focus ring appears correctly. r=MattN, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9708", "files": ["browser/extensions/formautofill/FormAutofillPreferences.jsm"], "git_node": null, "git_parents": [null], "node": "1bef24401c99d6375d189430885044fa77824818", "parents": ["f9da620994ae1a1cf533882625c1777af07f56c3"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1500876 - Remove PContent::GetSystemColors sync IPC. r=snorp,mccr8, a=RyanVM\n\nContent process of Android uses sync IPC when initializing LookAndFeel. But\ncurrent e10s has LookAndFeel cache for start up of content process.\nSo we should use it, then remove sync IPC for start up performance\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9750", "files": ["dom/ipc/ContentParent.cpp", "dom/ipc/ContentParent.h", "dom/ipc/PContent.ipdl", "ipc/ipdl/sync-messages.ini", "widget/LookAndFeel.h", "widget/android/nsLookAndFeel.cpp", "widget/android/nsLookAndFeel.h"], "git_node": null, "git_parents": [null], "node": "f82eaa1ff6a520b47242a776fbcf431b39900ed3", "parents": ["1bef24401c99d6375d189430885044fa77824818"], "tags": []}, {"author": "Mats Palmgren \u003cmats@mozilla.com\u003e", "branch": "default", "desc": "Bug 1501908 - Force line-height:normal for themed comboboxes for compat with other UAs. r=emilio, a=RyanVM", "files": ["servo/components/style/style_adjuster.rs", "testing/web-platform/tests/html/rendering/replaced-elements/the-select-element/select-1-line-height-ref.html", "testing/web-platform/tests/html/rendering/replaced-elements/the-select-element/select-1-line-height.html"], "git_node": null, "git_parents": [null], "node": "fcb8fd2dd657df97912e2d754ed613372456c32e", "parents": ["f82eaa1ff6a520b47242a776fbcf431b39900ed3"], "tags": []}, {"author": "Alexander Surkov \u003csurkov.alexander@gmail.com\u003e", "branch": "default", "desc": "Bug 1052866 - Expose IAccessibleText on tables, rows, etc. r=tbsaunde, a=RyanVM", "files": ["accessible/generic/ARIAGridAccessible.cpp", "accessible/generic/ARIAGridAccessible.h", "accessible/html/HTMLTableAccessible.h", "accessible/tests/mochitest/elm/test_HTMLSpec.html", "accessible/tests/mochitest/textrange/test_selection.html", "accessible/xpcom/xpcAccessibleTable.cpp", "accessible/xpcom/xpcAccessibleTable.h"], "git_node": null, "git_parents": [null], "node": "59be666e2781b30954d40ecf5a11543af40b5f95", "parents": ["fcb8fd2dd657df97912e2d754ed613372456c32e"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1052866 - Handle QI to IAccessibleText for tables. r=MarcoZ, a=RyanVM\n\nThe first patch inherits from the right classes, but because tables have additional interfaces, QueryInterface is overridden.\nIt had to be updated to also include HyperTextAccessibleWrap.\nRows worked correctly because they don't have any specific interfaces and thus don't override QI.\nThey just inherit their QI implementation from their base class.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D10022", "files": ["accessible/windows/msaa/ARIAGridAccessibleWrap.cpp", "accessible/windows/msaa/HTMLTableAccessibleWrap.cpp"], "git_node": null, "git_parents": [null], "node": "52b79f0655cb6bf92c4cd1fffafc617280feacd3", "parents": ["59be666e2781b30954d40ecf5a11543af40b5f95"], "tags": []}, {"author": "Ted Campbell \u003ctcampbell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1427860 - XDR failures should leave script isUncompleted(). r=nbp, a=RyanVM\n\nFailures during XDR may leave the script partially initialized in a way\nthat confuses coverage collection. This ensures the shared script data\nis removed from a script if there are any XDR failures in it.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9960", "files": ["js/src/jit-test/tests/xdr/bug1427860.js", "js/src/vm/JSScript.cpp"], "git_node": null, "git_parents": [null], "node": "af012e57e9de8ce72133fe5a1f2b8b0362336260", "parents": ["52b79f0655cb6bf92c4cd1fffafc617280feacd3"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1453078 - Do not assume segments are all non-null when not all null. r=padenot, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9545", "files": ["dom/media/encoder/MediaEncoder.cpp"], "git_node": null, "git_parents": [null], "node": "43d2c9744a7d94ef0609d6f1e099ccb19c538297", "parents": ["af012e57e9de8ce72133fe5a1f2b8b0362336260"], "tags": []}], "date": 1541006346, "git_changesets": [null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10078": {"changesets": [{"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1498023 - Search shortcuts should hide all one-off UI when typed. r=mak,Mardak, a=RyanVM\n\n* Disable or enable the one-offs per each new search based on whether the first char is \"@\". The patch does this in `onResultsAdded`, where other per-search initialization happens.\n* Remove the `disableOneOffButtons` option from the urlbar `search` method. It's not necessary anymore now that one-offs are automatically hidden for the only caller that uses this option (new tab with the \"@engine\" tiles).\n* Make the `oneOffSearchesEnabled` getter return the actual status of the one-off UI instead of relying on an `_oneOffSearchesEnabled` property.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9883", "files": ["browser/base/content/test/performance/browser_urlbar_keyed_search.js", "browser/base/content/test/performance/browser_urlbar_search.js", "browser/base/content/test/urlbar/browser_urlbarOneOffs.js", "browser/base/content/test/urlbar/browser_urlbarSearchFunction.js", "browser/base/content/urlbarBindings.xml", "browser/components/newtab/lib/PlacesFeed.jsm", "browser/components/newtab/test/unit/lib/PlacesFeed.test.js"], "git_node": null, "git_parents": [null], "node": "3931ebbd558836838926001aef24f4c4d1120653", "parents": ["43d2c9744a7d94ef0609d6f1e099ccb19c538297"], "tags": []}, {"author": "WR Updater Bot \u003cgraphics-team@mozilla.staktrace.com\u003e", "branch": "default", "desc": "Bug 1499908 - Uplift WebRender PR #3234 to Firefox 64. r=kats, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D10021", "files": ["gfx/webrender/src/device/gl.rs", "gfx/webrender/src/resource_cache.rs", "gfx/webrender_bindings/revision.txt"], "git_node": null, "git_parents": [null], "node": "bc7548ec328bb2ece1a2a0d519fd466cf2353ad1", "parents": ["3931ebbd558836838926001aef24f4c4d1120653"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1501006 - Reject cookieStoreId in perma-private browsing mode. r=mixedpuppy, a=RyanVM\n\nUntil container tabs are supported in private browsing mode\n(bug 1320757), extensions should not be able to open container tabs when\nperma-private browsing mode is off.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9517", "files": ["browser/components/extensions/test/browser/browser_ext_tabs_cookieStoreId.js", "browser/components/extensions/test/browser/browser_ext_windows_create_cookieStoreId.js", "toolkit/components/extensions/parent/ext-tabs-base.js"], "git_node": null, "git_parents": [null], "node": "a78fa2f251c0f213f7b06f45e7488e4f22a9a429", "parents": ["bc7548ec328bb2ece1a2a0d519fd466cf2353ad1"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1501006 - Reject cookieStoreId when contextual identities are disabled. r=mixedpuppy, a=RyanVM\n\nDepends on D9517\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9518", "files": ["browser/components/extensions/test/browser/browser_ext_tabs_cookieStoreId.js", "browser/components/extensions/test/browser/browser_ext_windows_create_cookieStoreId.js", "toolkit/components/extensions/parent/ext-tabs-base.js"], "git_node": null, "git_parents": [null], "node": "5d62582ba7ae1aed3ddfddf355abd84274ac9de1", "parents": ["a78fa2f251c0f213f7b06f45e7488e4f22a9a429"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1502488 - Fix opus mapping 2 channels count check. r=padenot, a=RyanVM\n\nAdd gtest\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9943", "files": ["dom/media/gtest/TestOpusParser.cpp", "dom/media/gtest/moz.build", "dom/media/ogg/OpusParser.cpp", "dom/media/ogg/OpusParser.h"], "git_node": null, "git_parents": [null], "node": "d709ec7593d0670a1de6df5ec39e6e34b9ef5ca9", "parents": ["5d62582ba7ae1aed3ddfddf355abd84274ac9de1"], "tags": []}, {"author": "Felipe Gomes \u003cfelipc@gmail.com\u003e", "branch": "default", "desc": "Bug 1499896 - Clean up listeners to an empty array instead of null. r=mconley, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9047", "files": ["toolkit/modules/ActorManagerChild.jsm"], "git_node": null, "git_parents": [null], "node": "20548d7c4ba4545b3158b58f50e4c96041be2d9a", "parents": ["d709ec7593d0670a1de6df5ec39e6e34b9ef5ca9"], "tags": []}, {"author": "Tom Schuster \u003cevilpies@gmail.com\u003e", "branch": "default", "desc": "Bug 1502889 - Revert TypedArray [[Set]] to previous behavior if not receiver. r=jorendorff, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D10116", "files": ["js/src/jit-test/tests/cacheir/typedarray-set.js", "js/src/jit-test/tests/proxy/testDirectProxySetArray4.js", "js/src/jit/CacheIR.cpp", "js/src/tests/non262/TypedArray/set-with-receiver.js", "js/src/vm/NativeObject.cpp"], "git_node": null, "git_parents": [null], "node": "831cb67404bdcb5ef9b9a4ed68702054803b81a0", "parents": ["20548d7c4ba4545b3158b58f50e4c96041be2d9a"], "tags": []}], "date": 1541013510, "git_changesets": [null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10079": {"changesets": [{"author": "Bob Clary \u003cbclary@bclary.com\u003e", "branch": "default", "desc": "Bug 1499246 - Specify tooltool_cache for android-hw. r=jmaher, a=test-only", "files": ["testing/mozharness/configs/android/android_hw.py"], "git_node": null, "git_parents": [null], "node": "bf07e6c3ea338ef4e0c4ce6742ec4117f322b4e5", "parents": ["831cb67404bdcb5ef9b9a4ed68702054803b81a0"], "tags": []}, {"author": "Jan-Erik Rediger \u003cjrediger@mozilla.com\u003e", "branch": "default", "desc": "Bug 1501329 - Set valid client ID on Fennec if canary is detected. r=chutten, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9544", "files": ["toolkit/components/telemetry/app/TelemetryController.jsm", "toolkit/components/telemetry/tests/unit/test_TelemetryClientID_reset.js"], "git_node": null, "git_parents": [null], "node": "6cfcc707ee835deb65fa583775d4aeec7c9647a6", "parents": ["bf07e6c3ea338ef4e0c4ce6742ec4117f322b4e5"], "tags": []}, {"author": "Jan-Erik Rediger \u003cjrediger@mozilla.com\u003e", "branch": "default", "desc": "Bug 1501329 - Persist information about canary after resetting client ID. r=chutten, a=RyanVM\n\nWe erroneously reset client IDs on Fennec to a canary client ID.\nThis is now detected and a new valid and random client ID is set.\n\nThis adds a new boolean attribute \"wasCanary\" to the `state.json` file\ngenerated by ClientID.jsm.\n\nDepends on D9544\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9903", "files": ["toolkit/components/telemetry/tests/unit/test_TelemetryClientID_reset.js", "toolkit/modules/ClientID.jsm", "toolkit/modules/tests/xpcshell/test_client_id.js", "toolkit/modules/tests/xpcshell/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "455c4d904d2778da6d3cd86ac960d4f20ac99eb4", "parents": ["6cfcc707ee835deb65fa583775d4aeec7c9647a6"], "tags": []}, {"author": "Jan-Erik Rediger \u003cjrediger@mozilla.com\u003e", "branch": "default", "desc": "Bug 1501329 - Expose \"wasCanary\" flag in saved-session pings for Fennec. r=chutten, a=RyanVM\n\nDepends on D9903\n\nDepends on D9903\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9904", "files": ["toolkit/components/telemetry/app/TelemetryController.jsm", "toolkit/components/telemetry/docs/data/environment.rst", "toolkit/components/telemetry/tests/unit/test_TelemetryClientID_reset.js"], "git_node": null, "git_parents": [null], "node": "c7c256c66f93a5c31efdd573aab6e4322fb50ea8", "parents": ["455c4d904d2778da6d3cd86ac960d4f20ac99eb4"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1502435 - Set valid clientId and save if previous was canary clientId. r=jchen, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D10202", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoProfile.java"], "git_node": null, "git_parents": [null], "node": "02cbbb3db3b576d57ad3f6f74916ea6d4b4f3306", "parents": ["c7c256c66f93a5c31efdd573aab6e4322fb50ea8"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1502435 - Include new `bug_1501329_affected` property in the core ping. r=jchen, a=RyanVM\n\nSummary: Depends on D10202\n\nReviewers: jchen\n\nReviewed By: jchen\n\nSubscribers: jchen, janerik\n\nBug #: 1502435\n\nDifferential Revision: https://phabricator.services.mozilla.com/D10205", "files": ["mobile/android/base/java/org/mozilla/gecko/telemetry/TelemetryCorePingDelegate.java", "mobile/android/base/java/org/mozilla/gecko/telemetry/pingbuilders/TelemetryCorePingBuilder.java", "toolkit/components/telemetry/docs/data/core-ping.rst"], "git_node": null, "git_parents": [null], "node": "81b5e0d8a72630490c41ccd34698c08413e2866b", "parents": ["02cbbb3db3b576d57ad3f6f74916ea6d4b4f3306"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1502435 - Update tests to include checks for canary clientId. r=jchen, a=RyanVM", "files": ["mobile/android/app/src/test/java/org/mozilla/gecko/TestGeckoProfile.java", "mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/testUnifiedTelemetryClientId.java"], "git_node": null, "git_parents": [null], "node": "cb358118e54de761923e4b29bee9d34c1560b98a", "parents": ["81b5e0d8a72630490c41ccd34698c08413e2866b"], "tags": []}], "date": 1541014501, "git_changesets": [null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10080": {"changesets": [{"author": "Ursula Sarracini \u003cursulasarracini@gmail.com\u003e", "branch": "default", "desc": "Bug 1503288 - Use 'args' in button_action params to fix busted simplified onboarding actions. r=k88hudson, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D10232", "files": ["browser/components/newtab/content-src/asrouter/templates/OnboardingMessage/OnboardingMessage.schema.json", "browser/components/newtab/lib/OnboardingMessageProvider.jsm", "browser/components/newtab/test/unit/asrouter/templates/OnboardingMessage.test.jsx"], "git_node": null, "git_parents": [null], "node": "6432de180d3c57360d0e9ddb9f8414dbaeb26745", "parents": ["cb358118e54de761923e4b29bee9d34c1560b98a"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1503401 - Keep Firefox 64 building on newer cbindgen versions. r=boris, a=RyanVM", "files": ["servo/components/style/cbindgen.toml"], "git_node": null, "git_parents": [null], "node": "6e4f5a616fe2a24e282ce7f23327d3f9ae17437d", "parents": ["6432de180d3c57360d0e9ddb9f8414dbaeb26745"], "tags": []}, {"author": "Boris Chiou \u003cboris.chiou@gmail.com\u003e", "branch": "default", "desc": "Bug 1500627 - Treat min-main-size:[keyword] as \"auto\" for flex items, if main axis is the item's block axis. r=dholbert, a=RyanVM\n\nKeywords on the sizing properties in the block axis should behave as\ninitial values in the flex frame. We store the keywords as enum, instead\nof auto or none in nsStyleCoord, so we have to handle it explicitly.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9438", "files": ["layout/generic/nsFlexContainerFrame.cpp", "layout/reftests/flexbox/flexbox-bsize-keywords-no-stretch-1-ref.html", "layout/reftests/flexbox/flexbox-bsize-keywords-no-stretch-1.html", "layout/reftests/flexbox/flexbox-min-bsize-keywords-horiz-1-ref.html", "layout/reftests/flexbox/flexbox-min-bsize-keywords-horiz-1.html", "layout/reftests/flexbox/flexbox-min-bsize-keywords-vert-1-ref.html", "layout/reftests/flexbox/flexbox-min-bsize-keywords-vert-1.html", "layout/reftests/flexbox/reftest.list"], "git_node": null, "git_parents": [null], "node": "1a9849bb7eae0bf78a5a9fa6117e8e2f4d46e4b8", "parents": ["6e4f5a616fe2a24e282ce7f23327d3f9ae17437d"], "tags": []}, {"author": "Boris Chiou \u003cboris.chiou@gmail.com\u003e", "branch": "default", "desc": "Bug 1500627 - Fix some potential bugs of sizing properties for keywords in the block axis. r=mats, a=RyanVM\n\n1. Drop {Width|MinWidth|MaxWidh}DependsOnContainer() and\n   {Height|MinHeight|MaxHeight}DependsOnContainer() because they are bogus\n   after introducing the writing mode. Dropping these functions needs\n   update nsLineLayout because it is the only one who still use\n   these functions.\n2. There are still some potential assertions and bugs on handling keywords\n   in the block size, so we should update them as well.\n\nDepends on D9438\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9439", "files": ["layout/base/nsLayoutUtils.cpp", "layout/generic/WritingModes.h", "layout/generic/nsLineLayout.cpp", "layout/style/nsStyleStruct.cpp", "layout/style/nsStyleStruct.h"], "git_node": null, "git_parents": [null], "node": "3dcc599a53b52e4a436017210768d5c1033c6b41", "parents": ["1a9849bb7eae0bf78a5a9fa6117e8e2f4d46e4b8"], "tags": []}, {"author": "Michael Cooper \u003cmcooper@mozilla.com\u003e", "branch": "default", "desc": "Bug 1501877 - Remove errant .only() from about:studies