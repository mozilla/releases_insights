03e d26604dc03f4\nru -\u003e 37ae2048b869\nsi -\u003e 677785d3379d\nsk -\u003e 178db168ff63\nsl -\u003e 160670c7de33\nson -\u003e 84520e4c6659\nsq -\u003e a56a82f3c88e\nsr -\u003e 79ceb82987ce\nsv-SE -\u003e 4e15289e2e7e\nta -\u003e 4036f8f404e6\nte -\u003e 5a5b63e890f3\nth -\u003e aa7efb27bb40\ntr -\u003e 59f63fa2f9dc\nuk -\u003e 1ecff845b685\nur -\u003e 9d370cbb2349\nuz -\u003e 4a764c95d50c\nvi -\u003e e16a3b419179\nxh -\u003e f607ba018d55\nzh-CN -\u003e 9e45e11608b7\nzh-TW -\u003e 8e6708ba20ad", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "2122185b0f1d102c1458170361788e805e13b1bb", "parents": ["6e16b8a0292bffdd96246279cdc5a1cd5903716a"], "tags": []}], "date": 1539986447, "git_changesets": [null, null], "user": "ffxbld"}, "10002": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1499991 - Ensure no-op will-change changes also get reflected in the change hint. r=heycam,firefox-style-system-reviewers\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9073", "files": ["layout/style/nsStyleStruct.cpp", "testing/web-platform/tests/css/css-will-change/will-change-inherit-dynamic.html"], "git_node": null, "git_parents": [null], "node": "b82c3a7696f945a86d775911d22854481ef4a305", "parents": ["638dee1dfab113b0c2333fb62509180cf21c2124"], "tags": []}, {"author": "Razvan Caliman \u003crcaliman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1497950 - Ensure CSSRuleView has immediate access to PageStyleFront from inspector; r=gl\n\nThe current iteration of the Fonts panel requires an instance of the Rules view\nin order to get access to the element's rules.\n\nIn 2-pane mode, when the Fonts panel is the default (last used panel), the Rules\nview is not yet instantiated. To guard against this, the Fonts panel makes a call\nto ensure an instance of the Rules view is created (and with it a CSSRuleView object).\n\nFor some reason, the pageStyle wasn't immediately assigned to the CSSRuleView in\nthe constructor. The constructor signature shows that pageStyle can be passed in as a\nparam, but this never happens. There's only one usage of `new CSSRuleView()`.\nThe pageStyle exist on the inspector instance passed in to the CSSRuleView.\n\nThis patch ensures that the CSSRuleView makes use of the PageStyleFront instance\nfrom the inspector and removes the unused param from the constructor.\n\nPerhaps it's better for the Fonts panel to manage its own ElementStyle instance to\nget access to the element's selected rules. But in the interest of time, since the\nmerge date is soon, I'd rather have this fix in quikcly now and keep the dependency\nto a Rules view instance with the promise to revisit the Fonts panel architecture and\nremove this dependency during the Firefox 65 Nightly cycle.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9002", "files": ["devtools/client/inspector/rules/rules.js"], "git_node": null, "git_parents": [null], "node": "32670a4721d4dac1a14315b16db5847a20749027", "parents": ["b82c3a7696f945a86d775911d22854481ef4a305"], "tags": []}, {"author": "Patrick Brosset \u003cpbrosset@mozilla.com\u003e", "branch": "default", "desc": "Bug 1497348 - Remove callbacks and use async await in browser_toolbox_window_reload_target.js; r=yzen\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8974", "files": ["devtools/client/framework/test/browser_toolbox_window_reload_target.js"], "git_node": null, "git_parents": [null], "node": "d3dc7831efa89c4a464ba2aeb4252ce984185cfb", "parents": ["32670a4721d4dac1a14315b16db5847a20749027"], "tags": []}, {"author": "Patrick Brosset \u003cpbrosset@mozilla.com\u003e", "branch": "default", "desc": "Bug 1497348 - Wait for the inspector to be ready after reload; r=yzen\n\nDepends on D8974\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8980", "files": ["devtools/client/framework/test/browser_toolbox_window_reload_target.js"], "git_node": null, "git_parents": [null], "node": "125e5170ef3a92d25ad95cf14df1cc564a4e0a52", "parents": ["d3dc7831efa89c4a464ba2aeb4252ce984185cfb"], "tags": []}, {"author": "yulia \u003cystartsev@mozilla.com\u003e", "branch": "default", "desc": "Bug 1488379 - Use target.getFront to instantiate animationsFront; r=ochameau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7986", "files": ["devtools/client/inspector/animation/animation.js"], "git_node": null, "git_parents": [null], "node": "d522a86504a76831e59348784c25e81162fe540a", "parents": ["125e5170ef3a92d25ad95cf14df1cc564a4e0a52"], "tags": []}, {"author": "yulia \u003cystartsev@mozilla.com\u003e", "branch": "default", "desc": "Bug 1488379 - guard for errors; r=daisuke\n\nDepends on D7986\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8736", "files": ["devtools/client/inspector/animation/animation.js", "devtools/client/inspector/animation/test/browser_animation_logic_mutations_fast.js", "devtools/client/inspector/animation/test/head.js"], "git_node": null, "git_parents": [null], "node": "a0e2d7e922d83b15720c193f672312e639634a33", "parents": ["d522a86504a76831e59348784c25e81162fe540a"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1497820 - Get rid of the 'compact' class for search textboxes. r=paolo\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9078", "files": ["toolkit/components/viewconfig/content/config.xul", "toolkit/themes/osx/global/textbox.css"], "git_node": null, "git_parents": [null], "node": "1f35618c6e3c52748c84e62a15854dbb7a575206", "parents": ["a0e2d7e922d83b15720c193f672312e639634a33"], "tags": []}, {"author": "Tom Schuster \u003cevilpies@gmail.com\u003e", "branch": "default", "desc": "Bug 1497580 - Save text/html as UTF-8 to the clipboard. r=karlt\n\nI verified that we can still copy from Firefox to an older version of Firefox without this patch.\nLibreOffice also still works. Talking to some GTK people on IRC they are also happy about UTF-8 instead of wrongly declared UCS2.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8467", "files": ["widget/gtk/nsClipboard.cpp"], "git_node": null, "git_parents": [null], "node": "695366afa355ad61c17dedd9498ac2feba7b0ecd", "parents": ["1f35618c6e3c52748c84e62a15854dbb7a575206"], "tags": []}, {"author": "Margareta Eliza Balazs \u003cebalazs@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland. a=merge CLOSED TREE", "files": ["browser/extensions/formautofill/OSKeyStore.jsm", "browser/extensions/formautofill/test/browser/browser_creditCard_fill_cancel_login.js", "browser/extensions/formautofill/test/fixtures/OSKeyStoreTestUtils.jsm", "browser/extensions/formautofill/test/unit/test_osKeyStore.js", "testing/web-platform/meta/infrastructure/reftest/reftest_or_0.html.ini", "testing/web-platform/meta/svg/shapes/ellipse-04.svg.ini", "testing/web-platform/meta/wasm/idlharness.any.js.ini", "testing/web-platform/tests/wasm/idlharness.any.js"], "git_node": null, "git_parents": [null, null], "node": "704e640a83c2a829f674ac4da73faec6fb1c04d7", "parents": ["695366afa355ad61c17dedd9498ac2feba7b0ecd", "8f709fd4aa463ecfc38deda95ac9cc68b5095356"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1458194 - Add mochitest to track number of bundles loaded when loading inspector;r=ochameau,jmaher\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8017", "files": ["devtools/client/framework/moz.build", "devtools/client/framework/test/metrics/browser_metrics_inspector.ini", "devtools/client/framework/test/metrics/browser_metrics_inspector.js", "devtools/client/framework/test/metrics/head.js"], "git_node": null, "git_parents": [null], "node": "f2d7d033c14fe7a9e94c6c5ddec4e5dcf165be7c", "parents": ["704e640a83c2a829f674ac4da73faec6fb1c04d7"], "tags": []}, {"author": "Jan-Erik Rediger \u003cjrediger@mozilla.com\u003e", "branch": "default", "desc": "Bug 1498160 - Define new snapshot APIs for scalars and histograms r=chutten\n\nFor now this defers to the existing APIs and determines the correct dataset from a global flag.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8858", "files": ["toolkit/components/telemetry/core/Telemetry.cpp", "toolkit/components/telemetry/core/nsITelemetry.idl"], "git_node": null, "git_parents": [null], "node": "a5849dab9066759af0c542aa608cad47fe8bc1c6", "parents": ["f2d7d033c14fe7a9e94c6c5ddec4e5dcf165be7c"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1499236 - remove customizableui menubar binding, r=Felipe\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8901", "files": ["browser/base/content/browser-customization.js", "browser/base/content/browser.css", "browser/base/content/browser.js", "browser/components/customizableui/content/toolbar.xml"], "git_node": null, "git_parents": [null], "node": "5c84e7821c57ada673b4cf554a000961f57efdf8", "parents": ["a5849dab9066759af0c542aa608cad47fe8bc1c6"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1499768 - camera, microphone and speaker feature policies should have 'self' as default allowlist, r=jib", "files": ["dom/security/featurepolicy/FeaturePolicyUtils.cpp", "dom/security/featurepolicy/test/mochitest/test_parser.html"], "git_node": null, "git_parents": [null], "node": "5b56f7a89ad4657ebc9dcc0ec444dacec3c0a69c", "parents": ["3eb04f5363eb661fa2ae544a934a7ace85b65282"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1499788 - midi feature policy should have 'self' as default allowlist, r=qdot", "files": ["dom/security/featurepolicy/FeaturePolicyUtils.cpp"], "git_node": null, "git_parents": [null], "node": "8f74f5dbf5c0d12bebf84841b