es": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "0135510c769483ed7bed240d0b3560fe6f6ba17f", "parents": ["138e28ddffbed14474d4f1a3876068033015b5a1"], "tags": []}], "date": 1541777135, "git_changesets": [null, null], "user": "ffxbld"}, "10151": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 222184270b1be4dd8be3be13e9ec3dd38da8d9e2 with FIREFOX_64_0b8_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "d73a441280f06d17c6759a0cc251a1d2a0f48be2", "parents": ["0135510c769483ed7bed240d0b3560fe6f6ba17f"], "tags": []}], "date": 1541777306, "git_changesets": [null], "user": "ffxbld"}, "10152": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Backout bug 1418470 in beta. r=bradwerth, a=jcristau", "files": ["servo/components/style/properties/longhands/svg.mako.rs"], "git_node": null, "git_parents": [null], "node": "57f9b3c8803318d2783a38b4bf14287613b96891", "parents": ["d73a441280f06d17c6759a0cc251a1d2a0f48be2"], "tags": []}], "date": 1541777837, "git_changesets": [null], "user": "jcristau@mozilla.com"}, "10153": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nbn-BD -\u003e ef482a63527c", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "e3511cbc883526d3603e0516873a6a282a23e967", "parents": ["57f9b3c8803318d2783a38b4bf14287613b96891"], "tags": []}], "date": 1541779246, "git_changesets": [null], "user": "ffxbld"}, "10154": {"changesets": [{"author": "Nicolas B. Pierron \u003cnicolas.b.pierron@nbp.name\u003e", "branch": "default", "desc": "Bug 1502013 - RemoveUnmarkedBlocks should only mark operands of removed blocks. r=jandem, a=jcristau", "files": ["js/src/jit/IonAnalysis.cpp"], "git_node": null, "git_parents": [null], "node": "4d3a4ce7e9c6c60a0be8d27b95223d7906d1bf2a", "parents": ["e3511cbc883526d3603e0516873a6a282a23e967"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1503424 - Null-check NSWorkspaceAccessibilityDisplayOptionsDidChangeNotification before using it in order to fix a startup crash on 10.10. r=hiro, a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D11239", "files": ["widget/cocoa/nsChildView.mm"], "git_node": null, "git_parents": [null], "node": "dc2f3f105676976a8e48bcce65e2a7c31578f3f6", "parents": ["4d3a4ce7e9c6c60a0be8d27b95223d7906d1bf2a"], "tags": []}, {"author": "Lars T Hansen \u003clhansen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1488515 - Avoid wasm hardfp -\u003e softfp transition twice on Android. r=bbouvier, a=jcristau\n\nThe baseline compiler should always call builtins assuming the hardfp\ncalling convention on ARM, but it would actually take the native\ncalling convention on the device into account and sometimes use the\nsoftfp convention.\n\nThe reason the baseline compiler should always use hardfp is that the\nbuiltin thunks already convert hardfp-\u003esoftfp along the call path and\nsoftfp-\u003ehardfp along the return path, if this is necessary, to allow\nwasm to call builtins using the hardfp convention always.\n\nIt is possible that the situation was different when the baseline\ncompiler was written and that the bug is the result of subsequent\nchanges to the thunk layer, but this is not known precisely.\n\nThere's a driveby fix here to simplify the logic around determining\nhardfp vs softfp for the system ABI; UseHardFpABI() is now always\navailable and does the right thing, we don't need the #ifdef nest we\nhad previously.", "files": ["js/src/jit-test/tests/wasm/regress/baseline-builtin-abi.js", "js/src/wasm/WasmBaselineCompile.cpp"], "git_node": null, "git_parents": [null], "node": "2da6ab9b72ac367f2dcf90cceb3dd2f85cbb5aad", "parents": ["dc2f3f105676976a8e48bcce65e2a7c31578f3f6"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1505608 - Try to ensure the bss section of the elfhack testcase stays large enough. r=froydnj, a=jcristau\n\nIn bug 1470701, we added a dummy global variable so that it ends up in\nthe bss section, making it large enough for two pointers. Unfortunately,\nin some cases, the symbol is eliminated by the linker because it is\nunused. So we try to ensure it stays there.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D11257", "files": ["build/unix/elfhack/test.c"], "git_node": null, "git_parents": [null], "node": "6598cfafc16242e19a616b138af4e142ece943c9", "parents": ["2da6ab9b72ac367f2dcf90cceb3dd2f85cbb5aad"], "tags": []}, {"author": "Benjamin Bouvier \u003cbenj@benj.me\u003e", "branch": "default", "desc": "Bug 1503326. r=sunfish, r=nbp, a=jcristau", "files": ["js/src/jit/RangeAnalysis.cpp"], "git_node": null, "git_parents": [null], "node": "d84c76f0ddddc7a4fe4d67a327af0de4b5a6fb65", "parents": ["6598cfafc16242e19a616b138af4e142ece943c9"], "tags": []}], "date": 1541781483, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10155": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1418470 - Skip test because fix got backed out. a=test-fix", "files": ["layout/style/test/mochitest.ini"], "git_node": null, "git_parents": [null], "node": "43799c2555d44546c7070927f50778007a9891b9", "parents": ["d84c76f0ddddc7a4fe4d67a327af0de4b5a6fb65"], "tags": []}], "date": 1541785199, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "10156": {"changesets": [{"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 7e6f51f7fca4 (bug 1470786) for causing bug 1505161; a=backout", "files": ["mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/testInputConnection.java", "widget/android/GeckoEditableSupport.cpp", "widget/android/GeckoEditableSupport.h"], "git_node": null, "git_parents": [null], "node": "12e947ab2054fc55828e447e755470bd2d4838b6", "parents": ["43799c2555d44546c7070927f50778007a9891b9"], "tags": []}], "date": 1541793281, "git_changesets": [null], "user": "nchen@mozilla.com"}, "10157": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nit -\u003e a2c6ba1924c3", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "189d2cf9ca93cde1a43f0cc12bbc14d037191fbc", "parents": ["12e947ab2054fc55828e447e755470bd2d4838b6"], "tags": []}], "date": 1541851220, "git_changesets": [null], "user": "ffxbld"}, "10158": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nar -\u003e 8fa85e137168\nbr -\u003e de34c1f9c46f\ncak -\u003e 8fb3d42a8889\ncs -\u003e e86c785e2916", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "e5425328d1759cdce1d4f3fd1388eaf3822273a1", "parents": ["189d2cf9ca93cde1a43f0cc12bbc14d037191fbc"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nar -\u003e 36d24d02b20c\ncs -\u003e 0f8204e3e18f\nit -\u003e 5eb20173bd1d", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "460e0094d65cc620e1e9a0f6eaf1ecc1838cc0ba", "parents": ["e5425328d1759cdce1d4f3fd1388eaf3822273a1"], "tags": []}], "date": 1541948425, "git_changesets": [null, null], "use