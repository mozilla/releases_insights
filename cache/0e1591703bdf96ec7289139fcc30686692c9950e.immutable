.cpp", "layout/generic/nsFlexContainerFrame.h"], "git_node": null, "git_parents": [null], "node": "d8e73cf6952fd03c118b8cdd3cc97a8f59045f95", "parents": ["082aaca611f9f0e13cd82d6cc708b687cfd35b7c"], "tags": []}, {"author": "Brad Werth \u003cbwerth@mozilla.com\u003e", "branch": "default", "desc": "Bug 1497589 Part 5: Add tests of Flex mainAxisDirection and crossAxisDirection. r=dholbert\n\nDepends on D8617\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8618", "files": ["dom/flex/test/chrome.ini", "dom/flex/test/chrome/test_flex_axis_directions.html"], "git_node": null, "git_parents": [null], "node": "49e1cc5fdf49b102fa27980622087fc550ed93bb", "parents": ["d8e73cf6952fd03c118b8cdd3cc97a8f59045f95"], "tags": []}, {"author": "Andrew Halberstadt \u003cahalberstadt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1493683 - [lint] Remove wpt_manifest linter, r=jgraham\n\nThis is no longer needed because the manifest update now happens out of tree.\nThe taskcluster task was already removed, though the actual linter\nimplementation was forgotten.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9118", "files": ["tools/lint/wpt/wpt_manifest.py", "tools/lint/wpt_manifest.yml"], "git_node": null, "git_parents": [null], "node": "5e123c35d1e82866b42ee86dbe74bdf4c02956f5", "parents": ["49e1cc5fdf49b102fa27980622087fc550ed93bb"], "tags": []}, {"author": "yulia \u003cystartsev@mozilla.com\u003e", "branch": "default", "desc": "Bug 1499683 - Remove Highlightable Trait; r=ochameau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8987", "files": ["devtools/client/framework/toolbox-highlighter-utils.js", "devtools/client/framework/toolbox.js", "devtools/server/actors/root.js", "devtools/server/actors/targets/addon.js", "devtools/server/actors/targets/content-process.js"], "git_node": null, "git_parents": [null], "node": "42a7995a7d3655675925610c92fe13c9b86cd7ec", "parents": ["5e123c35d1e82866b42ee86dbe74bdf4c02956f5"], "tags": []}, {"author": "yulia \u003cystartsev@mozilla.com\u003e", "branch": "default", "desc": "Bug 1499710 - Remove autohideOnDestroy trait; r=ochameau\n\nDepends on D8987\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8988", "files": ["devtools/client/framework/toolbox.js", "devtools/server/actors/highlighters.js"], "git_node": null, "git_parents": [null], "node": "f95e8040037226253522aea53a8b24dee6b75098", "parents": ["42a7995a7d3655675925610c92fe13c9b86cd7ec"], "tags": []}, {"author": "yulia \u003cystartsev@mozilla.com\u003e", "branch": "default", "desc": "Bug 1499686 - Remove _supportsFrameHighlight; r=ochameau\n\nDepends on D8988\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8989", "files": ["devtools/client/framework/toolbox.js"], "git_node": null, "git_parents": [null], "node": "88aa6ae72305247b0520e0d698e751749fb8d60b", "parents": ["f95e8040037226253522aea53a8b24dee6b75098"], "tags": []}, {"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1496814 - Show only search suggestion results when only an engine alias and query are typed in the address bar r=mak\n\nThis is based on the patch in bug 1496811.\n\nThis patch looks a little worse than it probably is. (Maybe not by much.) Some of this is indentation changes, moving code around, renaming, and adding jsdocs. It looks like we missed the boat on uplifting this (and the other couple of bugs) to 63, so there's not a super-pressing need to keep the patch minimal.\n\nPlacesSearchAutocompleteProvider assumes you're fetching suggestions from the current engine, so I had to modify it to take an engine. While I was doing that, I got a little frustrated with some of its implementation, naming, and interface. It seems like it was written to be a little more generic than it ended up being? There doesn't seem to be any need for it to return generic \"match\" objects instead of simply engines and `{ suggestion, historical }` objects, for example. The \"defaultMatch\" concept also doesn't make much sense IMO, especially with the aforementioned changes. So I made some improvements, hopefully, and I also added some jsdocs.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8818", "files": ["toolkit/components/places/PlacesSearchAutocompleteProvider.jsm", "toolkit/components/places/UnifiedComplete.js", "toolkit/components/places/tests/unifiedcomplete/head_autocomplete.js", "toolkit/components/places/tests/unifiedcomplete/test_PlacesSearchAutocompleteProvider.js", "toolkit/components/places/tests/unifiedcomplete/test_search_engine_alias.js", "toolkit/components/places/tests/unifiedcomplete/test_search_suggestions.js"], "git_node": null, "git_parents": [null], "node": "665fecc387403fd9336daaaa6bfa619dc5b7baed", "parents": ["88aa6ae72305247b0520e0d698e751749fb8d60b"], "tags": []}, {"author": "Bogdan Tara \u003cbtara@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 77d3179f96db (bug 1479008) for browser_browser_languages_subdialog.js failures", "files": ["browser/components/preferences/browserLanguages.js", "browser/components/preferences/in-content/tests/addons/pl-dictionary.xpi", "browser/components/preferences/in-content/tests/browser.ini", "browser/components/preferences/in-content/tests/browser_browser_languages_subdialog.js", "services/settings/dumps/main/language-dictionaries.json", "services/settings/dumps/main/moz.build"], "git_node": null, "git_parents": [null], "node": "26c0053b13cb7ea1cce71210709fc30472f68671", "parents": ["665fecc387403fd9336daaaa6bfa619dc5b7baed"], "tags": []}, {"author": "Patrick Brosset \u003cpbrosset@mozilla.com\u003e", "branch": "default", "desc": "Bug 1499755 - Select the right inline stylesheet on rule-view source url click; r=gl\n\nThe code we had to jump to the style-editor when a rule-view source link is clicked did\nnot make any distinction between multiple inline stylesheets. If you had many of them,\nthey would all have the same url (i.e. the url of the document, because they are\ninline). And we were matching stylesheets in the style-editor by url, so we would\nalways select the first inline stylesheet.\n\nThis change makes use of the fact that the style-editor's selectStyleSheet function\nalso accept a StyleSheetFront object. When passing this object, there can be no\nconfusion, because they're all different.\n\nNow, I'm only doing this for inlin stylesheets because other stylesheets have unique\nurls and it's important to preserve the previous logic since source-maps may also be\ninvolved.\n\nI'm taking this opportunity to re-enable browser_rules_style-editor-link.js which had\nbeen disabled a long time ago, and removing a part that just doesn't work anymore at\nall apparently.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9093", "files": ["devtools/client/inspector/rules/test/browser.ini", "devtools/client/inspector/rules/test/browser_rules_style-editor-link.js", "devtools/client/inspector/rules/views/rule-editor.js"], "git_node": null, "git_parents": [null], "node": "3a70a65a75cf9bf30152ebd0e69ccbde3a913f00", "parents": ["26c0053b13cb7ea1cce71210709fc30472f68671"], "tags": []}, {"author": "yulia \u003cystartsev@mozilla.com\u003e", "branch": "default", "desc": "Bug 1495387 - introduce async front instantiation; r=ochameau\n\nDepends on D8989\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8990", "files": ["devtools/shared/protocol.js"], "git_node": null, "git_parents": [null], "node": "a6b4461eadf0622f4d4f6ea1ee8389d1c655b336", "parents": ["3a70a65a75cf9bf30152ebd0e69ccbde3a913f00"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1500097 - Enable @supports selector() in those tests.\n", "files": ["testing/web-platform/meta/css/css-conditional/at-supports-040.html.ini", "testing/web-platform/meta/css/css-conditional/at-supports-041.html.ini", "testing/web-platform/meta/css/css-conditional/at-supports-042.html.ini", "testing/web-platform/meta/css/cssom/CSS.html.ini"], "git_node": null, "git_parents": [null], "node": "cec3c13a4ad5edbcc528d86abe8619ae2f9051fa", "parents": ["4a22c1051967e4edef65c5c68305e72618eb2c0d"], "tags": []}, {"author": "Ciure Andrei \u003caciure@mozilla.com\u003e", "branch": "default", "desc": "Merge inbound to mozilla-central. a=merge", "files": [], "git_node": null, "git_parents": [null, null], "node": "733484af9034cb0372ed1fd745ec3d321d48e8b9", "parents": ["5be96992e33cfdbd85374a419aeb1b8734a2edab", "cec3c13a4ad5edbcc528d86abe8619ae2f9051fa"], "tags": []}, {"author": "Ciure Andrei \u003caciure@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland.  a=merge CLOSED TREE", "files": [], "git_node": null, "git_parents": [null, null], "node": "a58112b87de672f400dc5d23ad8bac80d292a2fd", "parents": ["a6b4461eadf0622f4d4f6ea1ee8389d1c655b336", "733484af9034cb0372ed1fd745ec3d321d48e8b9"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1498352 - Apply root resolution when sending mouse events from child to parent; r=kats\n\nBecause the root resolution is conceptually at the parent/child process\nboundary, when sending mouse events from child to the parent, we need to\napply that resolution to the mouse coordinates.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8993", "files": ["widget/PuppetWidget.cpp"], "git_node": null, "git_parents": [null], "node": "084f6e60778f01d66bee26657e0e459f8fddcc3e", "parents": ["a58112b87de672f400dc5d23ad8bac80d292a2fd"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1496243 - Show \"Tracking Cookies\" label in the control center when only tracking cookies are blocked. r=Ehsan\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9092", "files": ["browser/base/content/browser-contentblocking.js", "browser/base/content/test/