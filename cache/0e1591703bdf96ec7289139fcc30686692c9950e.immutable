", "87b544fc71d59aa4c7386c847e97993add7df492"], "tags": []}, {"author": "Jeff Walden \u003cjwalden@mit.edu\u003e", "branch": "default", "desc": "Bug 1498458 - Properly report OOM on failure to allocate ArrayBuffer contents for a fresh ArrayBuffer that can't fit in inline storage.  r=nbp", "files": ["js/src/vm/ArrayBufferObject.cpp"], "git_node": null, "git_parents": [null], "node": "e08e5aa479a939385404466ea06227eb754f254b", "parents": ["cb09d07a1606d5efd84f849b97989ee29f283c79"], "tags": []}, {"author": "Jeff Walden \u003cjwalden@mit.edu\u003e", "branch": "default", "desc": "Bug 1498458 - Add a test for OOM on failure to allocate ArrayBuffer contents that won't fit in a typed array's inline storage.  r=nbp", "files": ["js/src/jit-test/tests/typedarray/oom-allocating-arraybuffer-contents.js"], "git_node": null, "git_parents": [null], "node": "5b5648ea1b5b33d8406a0a78661dd7c86f4cd7b0", "parents": ["e08e5aa479a939385404466ea06227eb754f254b"], "tags": []}, {"author": "Noemi Erli \u003cnerli@mozilla.com\u003e", "branch": "default", "desc": "Merge inbound to mozilla-central.  a=merge", "files": ["security/sandbox/chromium-shim/patches/with_update/mingw_msvc_requirement_error.patch"], "git_node": null, "git_parents": [null, null], "node": "3c8790a73b7f31b253704a07e1bf7d0a65696b04", "parents": ["8ceb713af9c7f2b453f42c46bd9ffd8ae1aece44", "5b5648ea1b5b33d8406a0a78661dd7c86f4cd7b0"], "tags": []}, {"author": "Noemi Erli \u003cnerli@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland. a=merge CLOSED TREE", "files": ["security/sandbox/chromium-shim/patches/with_update/mingw_msvc_requirement_error.patch"], "git_node": null, "git_parents": [null, null], "node": "b6f7a0b4345849cc9cf9a40abe1ff16cf1a6d905", "parents": ["2e7851b166cebcab9f5df591f33bc8d234f1ff7c", "3c8790a73b7f31b253704a07e1bf7d0a65696b04"], "tags": []}, {"author": "Sam Foster \u003csfoster@mozilla.com\u003e", "branch": "default", "desc": "Bug 1485105 - Allow 12-19 digit length card numbers. r=MattN\n\n* Change to isValidNumber to allow any number length in the range. This also removes 9 as a valid payment card number length\n* Amend form autocomplete test for sensitive 9 digit numbers. We no longer consider them valid cc numbers, test for 19 digit numbers instead\n* Fix intermittent issue in a session restore tests. It turns out Date.now().toString() can sometimes pass the Luhn algorithm and look like a valid credit card number. I believe this could lead to it being treated as sensitive data which is not saved and restored, failing the test\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8271", "files": ["browser/components/sessionstore/test/browser_248970_b_perwindowpb.js", "browser/components/sessionstore/test/browser_463206.js", "browser/components/sessionstore/test/browser_formdata_xpath.js", "toolkit/components/satchel/test/test_form_submission.html", "toolkit/modules/CreditCard.jsm", "toolkit/modules/tests/xpcshell/test_CreditCard.js"], "git_node": null, "git_parents": [null], "node": "583d689d630e68cb1f2ae5ae1e7f27f2ca28f359", "parents": ["b6f7a0b4345849cc9cf9a40abe1ff16cf1a6d905"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1498878 - Implement UrlbarInput::goButton. r=adw\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8670", "files": ["browser/components/urlbar/UrlbarInput.jsm"], "git_node": null, "git_parents": [null], "node": "0329775bb9a4321441c576b01a6f851800afcf6e", "parents": ["583d689d630e68cb1f2ae5ae1e7f27f2ca28f359"], "tags": []}, {"author": "Micah Tigley \u003cmtigley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1499052 - Enable both M1 and M2 milestones for the Flexbox inspector in DevEdidtion 64 (and keep it there). r=gl\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8738", "files": ["devtools/client/preferences/devtools-client.js"], "git_node": null, "git_parents": [null], "node": "ba7c1249b79b39df4be295ed0c65a32bc7eaa932", "parents": ["0329775bb9a4321441c576b01a6f851800afcf6e"], "tags": []}, {"author": "Mantaroh Yoshinaga \u003cmantaroh@gmail.com\u003e", "branch": "default", "desc": "Bug 1485501 - Change the calculated viewport if anchor element is displayed at second screen. r=birtles\n\nIf we displayed the devtools across the second screen, the Screen.availLeft\nmight be not zero. I.e., Screen.availLeft point to second screen's left.\nThe HTMLTooltip does't consider this case, so this patch will change the\nviewpor's left and right position if the left of anchor element is bigger than\nscreen.right.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8183", "files": ["devtools/client/shared/widgets/tooltip/HTMLTooltip.js"], "git_node": null, "git_parents": [null], "node": "70daf386e9d36a170da95d59009ef953ccb6310f", "parents": ["ba7c1249b79b39df4be295ed0c65a32bc7eaa932"], "tags": []}, {"author": "Mantaroh Yoshinaga \u003cmantaroh@gmail.com\u003e", "branch": "default", "desc": "Bug 1490358 - Hide menu popup when press the ctrl+t. r=birtles\n\nIf push the ctrl+t, browser will open the new tab. In this case,\nthe XUL popup panel doesn't hide automatically(autohide=false).\nAs the result of it, the popup menu will be displayed in the new tab\ncontent. So this patch will hide the popup when receiving the ctr+t\nshortcut in the MenuButton.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8809", "files": ["devtools/client/shared/components/menu/MenuButton.js"], "git_node": null, "git_parents": [null], "node": "d5cc1ab5bb162464e4be7593e6a71d330faf3b51", "parents": ["70daf386e9d36a170da95d59009ef953ccb6310f"], "tags": []}, {"author": "Jeff Walden \u003cjwalden@mit.edu\u003e", "branch": "default", "desc": "Bug 1493441 - Allow ScriptSource to store UTF-8 script data in addition to UTF-16 script data (but don't create any UTF-8-backed ScriptSources yet).  r=tcampbell", "files": ["dom/script/ScriptLoader.cpp", "js/src/vm/HelperThreads.h", "js/src/vm/JSFunction.cpp", "js/src/vm/JSScript.cpp", "js/src/vm/JSScript.h", "js/src/vm/SharedImmutableStringsCache.h", "mfbt/RecordReplay.cpp", "mfbt/RecordReplay.h", "parser/html/nsHtml5StreamParser.cpp", "toolkit/recordreplay/ipc/JSControl.cpp"], "git_node": null, "git_parents": [null], "node": "2ec2641a20ae953f6f6119777acb44c580310943", "parents": ["5b5648ea1b5b33d8406a0a78661dd7c86f4cd7b0"], "tags": []}, {"author": "Martin Thomson \u003cmartin.thomson@gmail.com\u003e", "branch": "default", "desc": "Bug 1488622 - Update NSS to 5180835aac1d, UPGRADE_NSS_RELEASE, r=me\n\nMozReview-Commit-ID: AxBAzwar81K\n", "files": ["security/nss/TAG-INFO", "security/nss/automation/taskcluster/graph/src/extend.js", "security/nss/automation/taskcluster/windows/build.sh", "security/nss/automation/taskcluster/windows/build_gyp.sh", "security/nss/automation/taskcluster/windows/setup.sh", "security/nss/automation/taskcluster/windows/setup32.sh", "security/nss/automation/taskcluster/windows/setup64.sh", "security/nss/build.sh", "security/nss/coreconf/coreconf.dep", "security/nss/coreconf/fuzz.sh", "security/nss/coreconf/msvc.sh", "security/nss/coreconf/nspr.sh", "security/nss/gtests/ssl_gtest/ssl_resumption_unittest.cc", "security/nss/gtests/ssl_gtest/tls_esni_unittest.cc", "security/nss/help.txt", "security/nss/lib/freebl/freebl.gyp", "security/nss/lib/freebl/freebl_base.gypi", "security/nss/lib/ssl/ssl3con.c", "security/nss/lib/ssl/sslnonce.c", "security/nss/lib/ssl/tls13con.c"], "git_node": null, "git_parents": [null], "node": "ff4002836b9b87c8bcf0db5023a2147b33d7ac67", "parents": ["2ec2641a20ae953f6f6119777acb44c580310943"], "tags": []}, {"author": "Randell Jesup \u003crjesup@jesup.org\u003e", "branch": "default", "desc": "Bug 1497985: Allow for MergeStacks() not writing any stacks within a sample r=mstange", "files": ["tools/profiler/core/ProfileBufferEntry.cpp"], "git_node": null, "git_parents": [null], "node": "ec837a14f8e8dff8056ee633c9a318073d25cda5", "parents": ["ff