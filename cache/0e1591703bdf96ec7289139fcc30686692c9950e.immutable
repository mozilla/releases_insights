@mozilla.com\u003e", "branch": "default", "desc": "Bug 1499125 - Remove the bogus assertion r=arai a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D10094", "files": ["js/src/builtin/Promise.cpp", "js/src/builtin/Promise.h", "js/src/jit-test/tests/promise/user-activation-propagation.js", "js/src/jsapi.cpp", "js/src/jsapi.h"], "git_node": null, "git_parents": [null], "node": "b2f18c10db561c718b38bca0a163e216c40afdc8", "parents": ["b1225231edcae9f4d88f66c417ce6b2c4107178f"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1499915 - Remove support for the elfhack filler segment r=froydnj a=RyanVM\n\nThis effectively backs out bug 822584, which worked around a similar\nproblem to what we are facing with Android xpcshell, being that the\ncrash reporter doesn't handle the address space \"fragmentation\" induced\nby elfhack. The work around worked, at the expense of some added\ncomplexity.\n\nIt was used for B2G only, and has effectively been unused since B2G was\nretired.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9622", "files": ["build/unix/elfhack/elf.cpp", "build/unix/elfhack/elfhack.cpp", "build/unix/elfhack/elfxx.h"], "git_node": null, "git_parents": [null], "node": "14271099afebac2058d21b57dbdebc64879d3c06", "parents": ["b2f18c10db561c718b38bca0a163e216c40afdc8"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1499915 - Support undoing elfhack when the elfhacked sections are in separate segments r=froydnj a=RyanVM\n\nThis is some sort of followup to bug 1423813, providing a minimalistic\nway to undo elfhack when the elfhack sections are in separate segments,\nwhich has been the case since bug 1385783 but didn't cause problems\non Android builds until bug 1423822.\n\nDepends on D9622\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9623", "files": ["build/unix/elfhack/elfhack.cpp"], "git_node": null, "git_parents": [null], "node": "67e9cba72b9a8f12e2d1a170498d69bd944e0020", "parents": ["14271099afebac2058d21b57dbdebc64879d3c06"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1499915 - Use elfhack from the build for Android xpcshell tests r=froydnj a=RyanVM\n\nAndroid xpcshell tests run `elfhack -r`, and do so by using an\nelfhack binary from an archive downloaded via tooltool (which contains\nother things).\n\nInstead, we just put the elfhack binary in the\ntarget.common.tests.tar.gz archive, and make the xpcshell harness\nuse it from there instead, allowing to pick in-tree changes to elfhack.\n\nDepends on D9623\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9624", "files": ["python/mozbuild/mozbuild/action/test_archive.py", "testing/xpcshell/remotexpcshelltests.py"], "git_node": null, "git_parents": [null], "node": "3fcac75fdb784833724bad75d88fb13378b95eeb", "parents": ["67e9cba72b9a8f12e2d1a170498d69bd944e0020"], "tags": []}, {"author": "Byron Campen [:bwc] \u003cdocfaraday@gmail.com\u003e", "branch": "default", "desc": "Bug 1502766 - Part 1 (beta only): Pass enough args to NrIceCtx::Create. r=mjf a=RyanVM", "files": ["media/webrtc/signaling/src/peerconnection/PeerConnectionMedia.cpp"], "git_node": null, "git_parents": [null], "node": "7749a380827aa8308975c4c2429dfe0c4e23bdc2", "parents": ["3fcac75fdb784833724bad75d88fb13378b95eeb"], "tags": []}, {"author": "Honza Bambas \u003chonzab.moz@firemni.cz\u003e", "branch": "default", "desc": "Bug 1503354 - Disable background HTTP response throttling for causing visible regressions. r=dragana a=RyanVM", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "c89f12000b079c50362ce52e661e3c5e24836a11", "parents": ["7749a380827aa8308975c4c2429dfe0c4e23bdc2"], "tags": []}], "date": 1541059702, "git_changesets": [null, null, null, null, null, null, null], "user": "ebalazs@mozilla.com"}, "10086": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset 08d5049ad5d9 (bug 1501605) because it was the wrong patch for uplift.", "files": ["media/libcubeb/README_MOZILLA", "media/libcubeb/include/cubeb.h", "media/libcubeb/src/cubeb_audiounit.cpp"], "git_node": null, "git_parents": [null], "node": "84baa2ea8fe21578473f9fc76f3d57fd7d6e8f7d", "parents": ["c89f12000b079c50362ce52e661e3c5e24836a11"], "tags": []}, {"author": "Alex Chronopoulos \u003cachronop@gmail.com\u003e", "branch": "default", "desc": "Bug 1501605 - Uplift a cubeb crash fix for Firefox 64. r=kinetik, a=RyanVM", "files": ["media/libcubeb/src/cubeb_audiounit.cpp", "media/libcubeb/update.sh", "media/libcubeb/uplift-bug1500109-to-beta.patch"], "git_node": null, "git_parents": [null], "node": "1ca9702a4960ee586097472bb2d4aaf10e3eed99", "parents": ["84baa2ea8fe21578473f9fc76f3d57fd7d6e8f7d"], "tags": []}, {"author": "Byron Campen [:bwc] \u003cdocfaraday@gmail.com\u003e", "branch": "default", "desc": "Bug 1502766 - Part 0: Re-enable test for \"relay\" ICE policy. r=jib, a=RyanVM", "files": ["dom/media/tests/mochitest/mochitest.ini", "dom/media/tests/mochitest/pc.js", "dom/media/tests/mochitest/test_peerConnection_relayOnly.html"], "git_node": null, "git_parents": [null], "node": "88adf850f1d275f5023332b7f962aa7395c4c366", "parents": ["1ca9702a4960ee586097472bb2d4aaf10e3eed99"], "tags": []}, {"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP remote-settings tld-suffixes - a=repo-update r=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D10548", "files": ["netwerk/dns/effective_tld_names.dat", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/main/sites-classification.json"], "git_node": null, "git_parents": [null], "node": "e062a0236c8e7167bcb1b7f72e7c867f98a49dc3", "parents": ["88adf850f1d275f5023332b7f962aa7395c4c366"], "tags": []}, {"author": "Alexandre Poirot \u003cpoirot.alex@gmail.com\u003e", "branch": "default", "desc": "Bug 1480953 - Force disabling tab animations in DAMP. r=jdescottes, a=RyanVM\n\nWe used to have animations during tab opening/closing, but this was introducing\nintermittents as we were not correctly waiting for animation's end.\n\nMozReview-Commit-ID: 2mscsA8Uosd\n\nDifferential Revision: https://phabricator.services.mozilla.com/D10263", "files": ["testing/talos/talos/tests/devtools/addon/content/damp.js", "testing/talos/talos/tests/devtools/addon/content/tests/netmonitor/complicated.js"], "git_node": null, "git_parents": [null], "node": "c79685defc28ae220abf01b05485536ac32c51bb", "parents": ["e062a0236c8e7167bcb1b7f72e7c867f98a49dc3"], "tags": []}], "date": 1541077688, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10087": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1494685 - Add a reftest. r=kats, a=test-only\n\nProbably not the most reliable test to catch this (as it depends on\nthe font and such) but still fails here and I'd like WPT to have a test-case\nfor this. I'm looking into adding a WR test-case ATM, though fighting with\nit way too much.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8438", "files": ["testing/web-platform/tests/css/css-transforms/text-perspective-001.html"], "git_node": null, "git_parents": [null], "node": "fa0dfb7abb5e0cc2466860580082c620e7819c86", "parents": ["c79685defc28ae220abf01b05485536ac32c51bb"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1503659 - Back out some debugging instrumentation from Firefox 64, now that it's in beta. r=mccr8, a=RyanVM", "files": ["dom/base/nsGlobalWindowInner.cpp", "dom/base/nsINode.cpp", "dom/bindings/BindingUtils.cpp", "dom/bindings/Codegen.py", "dom/html/ImageDocument.cpp", "dom/html/nsHTMLDocument.cpp", "dom/xml/XMLDocument.cpp", "dom/xul/XULDocument.cpp"], "git_node": null, "git_parents": [null], "node": "0a7792cc133f00007c69cd8e5200a977f801d876", "parents": ["fa0dfb7abb5e0cc2466860580082c620e7819c86"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1486984 - Fix find commands for PDF and special pages, and remove obsolete code. r=Gijs, a=RyanVM\n\nSupport for finding text in a page is now determined by a blacklist of locations, simplifying handling in multi-process mode and restoring the intended behavior.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8005", "files": ["browser/base/content/browser.js", "browser/base/content/test/general/browser_viewSourceInTabOnViewSource.js", "browser/components/preferences/in-content/preferences.xul", "toolkit/actors/FindBarChild.jsm", "toolkit/components/viewconfig/content/config.xul", "toolkit/modules/BrowserUtils.jsm", "toolkit/mozapps/extensions/content/extensions.xul"], "git_node": null, "git_parents": [null], "node": "a15c1d469c7593816633b1f9b9d579e5e2851a7e", "parents": ["0a7792cc133f00007c69cd8e5200a977f801d876"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1455924 - Clean up Dark/Light theme CSS. r=ntim, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9998", "files": ["browser/components/nsBrowserGlue.js", "browser/themes/shared/compacttheme.inc.css"], "git_node": null, "git_parents": [null], "node": "ba949aea60af0f625e690b684d2a81ed2ebc7457", "parents": ["a15c1d469c7593816633b1f9b9d579e5e2851a7e"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1503301 - Set tab_line property for Light and Dark themes. r=ntim, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D10345", "files": ["browser/components/nsB