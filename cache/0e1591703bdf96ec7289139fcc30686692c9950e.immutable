: "cc49be946af968c2091c0d777a0c8b167d72854a", "parents": ["06848028132d16f002e1a3b79bf3de157c5f4016"], "tags": []}, {"author": "Rob Wood \u003crwood@mozilla.com\u003e", "branch": "default", "desc": "Bug 1501040 - Raptor fix so unsigned webext will load on mozilla-beta. r=jmaher, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D10453", "files": ["testing/mozharness/mozharness/mozilla/testing/raptor.py", "testing/raptor/raptor/raptor.py"], "git_node": null, "git_parents": [null], "node": "560ec5d63826c4a8b510fa08a4510564f575ee2b", "parents": ["cc49be946af968c2091c0d777a0c8b167d72854a"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1500543 - Only inform windows that their parent is changing when being removed from their parent. r=bzbarsky, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D10085", "files": ["docshell/base/nsDocShell.cpp"], "git_node": null, "git_parents": [null], "node": "cc953fc99e9be4330c20d053af897f264f6a4170", "parents": ["560ec5d63826c4a8b510fa08a4510564f575ee2b"], "tags": []}, {"author": "Dylan Roeh \u003cdroeh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1477070 - Add STATE_IS_INSECURE check to checkIdentity in GeckoViewProgress.jsm. r=snorp, a=RyanVM", "files": ["mobile/android/modules/geckoview/GeckoViewProgress.jsm"], "git_node": null, "git_parents": [null], "node": "1597b2e3a491dedf4ce87d91ef89c63b5da476c2", "parents": ["cc953fc99e9be4330c20d053af897f264f6a4170"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1501680 - Don't send credentials in ssl error reports. r=Gijs, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D10594", "files": ["security/manager/ssl/tests/unit/test_toolkit_securityreporter.js", "toolkit/components/securityreporter/SecurityReporter.js"], "git_node": null, "git_parents": [null], "node": "309fbb6fbc62cd2fa09b4a2d6fc3d5b92b1f8b55", "parents": ["1597b2e3a491dedf4ce87d91ef89c63b5da476c2"], "tags": []}, {"author": "Eugen Sawin \u003cesawin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1478171 - [1.0] Forward channel redirect to nsILoadURIDelegate to allow external handling. r=snorp,smaug, a=RyanVM", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/NavigationDelegateTest.kt", "uriloader/base/nsDocLoader.cpp"], "git_node": null, "git_parents": [null], "node": "4c7bbc4c6fbc8a4233590f01cd74ae44fad5f24c", "parents": ["309fbb6fbc62cd2fa09b4a2d6fc3d5b92b1f8b55"], "tags": []}], "date": 1541184039, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10106": {"changesets": [{"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1405814 - Avoid crash with WebRender when the scroll metadata is unavailable. r=kats, a=RyanVM\n\nSimilar to bug 1471671, we are seeing missing scroll metadata in cases\nwe do not expect that, and have been observing low volume crashes in the\nwild as a result. It appears that in the non-WR path, it skips such items,\nso we should probably do the same thing with WebRender. If it is a real\nproblem, we will hopefully get a reproducible test case from a user if\nscrolling fails for them.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9815", "files": ["gfx/layers/wr/WebRenderScrollData.cpp"], "git_node": null, "git_parents": [null], "node": "1041bb5b5556cd21989d2af036f0acf1f323345b", "parents": ["4c7bbc4c6fbc8a4233590f01cd74ae44fad5f24c"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1493743 - Make AddFamilyToFontList return safely if passed a null font-family. r=lsalzman, a=RyanVM", "files": ["gfx/thebes/gfxTextRun.cpp"], "git_node": null, "git_parents": [null], "node": "da525e924591b4f1f1bfb92e182cdb6fbe76ea09", "parents": ["1041bb5b5556cd21989d2af036f0acf1f323345b"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1493743 - Make BuildFontList robust against an invalid FontFamilyName record with no name atom. r=lsalzman, a=RyanVM", "files": ["gfx/thebes/gfxTextRun.cpp"], "git_node": null, "git_parents": [null], "node": "42154e18f97c55e00950460b695406574bf0cf4c", "parents": ["da525e924591b4f1f1bfb92e182cdb6fbe76ea09"], "tags": []}], "date": 1541188728, "git_changesets": [null, null, null], "user": "ryanvm@gmail.com"}, "10107": {"changesets": [{"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Backed out changeset 64fa36b13e1a (bug 1473816) a=backout", "files": ["widget/nsBaseWidget.cpp"], "git_node": null, "git_parents": [null], "node": "e406bf1c8cd43ef04156d142cf5225d31c884f4e", "parents": ["42154e18f97c55e00950460b695406574bf0cf4c"], "tags": []}], "date": 1541222547, "git_changesets": [null], "user": "mozilla@upsuper.org"}, "10108": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP remote-settings tld-suffixes - a=repo-update r=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D10881", "files": ["netwerk/dns/effective_tld_names.dat", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc"], "git_node": null, "git_parents": [null], "node": "10cf5976e46f3fd3a0895873b6f73bf08ce7acef", "parents": ["e406bf1c8cd43ef04156d142cf5225d31c884f4e"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1503725 - Do not deallocate nsThreadShutdownContext when leaking thread. r=erahm, a=RyanVM\n\nSometimes when we call ShutdownWithTimeout on a thread pool, the unresponsive\nthread that we leak will actually complete before the main thread is done.\nIn that case, the thread will dereference the thread shutdown context, so\nwe must intentionally leak it too.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D10645", "files": ["xpcom/tests/gtest/TestThreadPool.cpp", "xpcom/threads/nsThread.cpp", "xpcom/threads/nsThread.h", "xpcom/threads/nsThreadPool.cpp"], "git_node": null, "git_parents": [null], "node": "8016d0d1a391f1327a0375fb6d4f20228b2784aa", "parents": ["10cf5976e46f3fd3a0895873b6f73bf08ce7acef"], "tags": []}], "date": 1541426503, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "10109": {"changesets": [{"author": "Paul Adenot \u003cpaul@paul.cx\u003e", "branch": "default", "desc": "Bug 1499426 - Only create AudioInputProcessing once in MediaEngineWebRTCAudio::Start. r=pehrsons a=jcristau", "files": ["dom/media/webrtc/MediaEngineWebRTCAudio.cpp"], "git_node": null, "git_parents": [null], "node": "9aacd377517c9d54df39a717b6f474e3666389ef", "parents": ["8016d0d1a391f1327a0375fb6d4f20228b2784aa"], "tags": []}], "date": 1541435587, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "10110": {"changesets": [{"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1503744 - Make HTMLEditor::SetHTMLBackgroundColorWithTransaction() not refer RefPtr after moving it. r=m_kato a=jcristau\n\nSimple fix of crash caused by referring nullptr.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D10705", "files": ["editor/libeditor/HTMLEditor.cpp"], "git_node": null, "git_parents": [null], "node": "2b2c323a635295870bfc3d4e5bf511185857a36e", "parents": ["9aacd377517c9d54df39a717b6f474e3666389ef"], "tags": []}, {"author": "Edgar Chen \u003cechen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1497480 - Part 1: Set the root for spelling checker to shadow root if the contenteditable nodes are in the shadow DOM; r=smaug a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D9542", "files": ["extensions/spellcheck/src/mozInlineSpellChecker.cpp", "extensions/spellcheck/src/mozInlineSpellWordUtil.cpp", "extensio