s": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1502936 - Fix SVGUseElement::GetFrame to not get confused. r=heycam, a=dveditz\n\nShould've noticed in bug 1502658 that GetFrame() was dead, to verify its\nassumptions... Oh well.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D10109", "files": ["dom/svg/SVGUseElement.cpp", "layout/svg/crashtests/1502936.html", "layout/svg/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "f3acb96d0b4f3271077c944a603dd65991058513", "parents": ["74b78f02330749197bbd4009fe20705490b6a86f"], "tags": []}, {"author": "Doug Thayer \u003cdothayer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1493447 - Add crashtest. r=mstange, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7631", "files": ["dom/svg/crashtests/1493447.html", "dom/svg/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "067542f72422b08670afde92d9fb2f816bf5d795", "parents": ["f3acb96d0b4f3271077c944a603dd65991058513"], "tags": []}, {"author": "k88hudson \u003ck88hudson@gmail.com\u003e", "branch": "default", "desc": "Bug 1501656 - Prevent CFR impression pings being sent twice because of redirect events. r=ursula, a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D10115", "files": ["browser/components/newtab/lib/ASRouterTriggerListeners.jsm", "browser/components/newtab/test/unit/unit-entry.js"], "git_node": null, "git_parents": [null], "node": "8ddaf87686591c4f8ff57535564f625efc2d8949", "parents": ["067542f72422b08670afde92d9fb2f816bf5d795"], "tags": []}], "date": 1540908934, "git_changesets": [null, null, null], "user": "ryanvm@gmail.com"}, "10067": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nbr -\u003e 59e0def26397\nit -\u003e b5faa