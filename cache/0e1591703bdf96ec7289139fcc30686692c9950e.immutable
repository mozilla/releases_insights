lbacks.kt"], "git_node": null, "git_parents": [null], "node": "b9614de52765a2da6de9eb067c2431c9517b95cd", "parents": ["45e3efb5e07666bd7e6e7bb0c0db34aa2cd75b4a"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1499906 - Use non-ASCII chars directly in the code. r=erahm\n\nThey're easier to read than \\uXXXX escapes, and there's no reason to stick to\nASCII in the source code.", "files": ["toolkit/components/aboutmemory/content/aboutMemory.js"], "git_node": null, "git_parents": [null], "node": "9d2fa6237585ae36ca4922d8064944c5168883b2", "parents": ["b9614de52765a2da6de9eb067c2431c9517b95cd"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1499906 - Improve treeline handling. r=erahm.\n\nThis commit reduces the appendTreeElements2's treeline arguments from 3 to 2,\nand makes the code easier to understand. It's also more efficient, because a\nconcatenation that used to be repeated for every child of a node is now done\nonce for all children.\n\nThis commit also shortens treeline variable names, because there are a lot of\nthem and they're easier to read when short.", "files": ["toolkit/components/aboutmemory/content/aboutMemory.js"], "git_node": null, "git_parents": [null], "node": "14cef5ef3dc4c9fb2e32b8b43778395ee6471c7d", "parents": ["9d2fa6237585ae36ca4922d8064944c5168883b2"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1499906 - Use for..of loops where possible. r=erahm", "files": ["toolkit/components/aboutmemory/content/aboutMemory.js"], "git_node": null, "git_parents": [null], "node": "075198910378e7bd8f3a84969017f178c501dccd", "parents": ["14cef5ef3dc4c9fb2e32b8b43778395ee6471c7d"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1499906 - Change `var` to `let`. r=erahm\n\nFor consistency; `let` is used in most places.", "files": ["toolkit/components/aboutmemory/content/aboutMemory.js"], "git_node": null, "git_parents": [null], "node": "97348d7aa09eace30cab2b769754bfc334f750f7", "parents": ["075198910378e7bd8f3a84969017f178c501dccd"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1499906 - Use toLocaleString(). r=erahm\n\nThis replaces a bunch of code that inserted separators by hand.\n\nFor now I've kept the output mostly the same by forcing the locale to en-US.\nBut at least now we could consider localizing the output.\n\nThe places where the output is different, it's more consistent with the new\ncode. E.g. printing \"-05.55%\" (which matches \"05.55%\") instead of \"-5.55%\".", "files": ["toolkit/components/aboutmemory/content/aboutMemory.js", "toolkit/components/aboutmemory/tests/test_aboutmemory.xul", "toolkit/components/aboutmemory/tests/test_aboutmemory3.xul"], "git_node": null, "git_parents": [null], "node": "9819dbed2d88c0aa7f4832a0cee383e68481ebd8", "parents": ["97348d7aa09eace30cab2b769754bfc334f750f7"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1499906 - Use String.prototype.padStart(). r=erahm\n\nThis lets us remove pad().", "files": ["toolkit/components/aboutmemory/content/aboutMemory.js"], "git_node": null, "git_parents": [null], "node": "eeea7ba794c30def2083f1a7555228b84d7b4626", "parents": ["9819dbed2d88c0aa7f4832a0cee383e68481ebd8"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1499906 - Put some parameters in `aFoo` form. erahm", "files": ["toolkit/components/aboutmemory/content/aboutMemory.js"], "git_node": null, "git_parents": [null], "node": "a4e7eb7be03c2d1b51fd3b3ee355720d999fb2a9", "parents": ["eeea7ba794c30def2083f1a7555228b84d7b4626"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozill