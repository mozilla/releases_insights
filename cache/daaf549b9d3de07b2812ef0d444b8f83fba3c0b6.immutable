latform/meta/IndexedDB/upgrade-transaction-lifecycle-user-aborted.html.ini", "testing/web-platform/meta/custom-elements/microtasks-and-constructors.html.ini", "testing/web-platform/meta/html/webappapis/scripting/event-loops/task_microtask_ordering.html.ini", "testing/web-platform/meta/webvtt/rendering/cues-with-video/processing-model/basic.html.ini", "testing/web-platform/meta/webvtt/rendering/cues-with-video/processing-model/bidi/bidi_ruby.html.ini", "testing/web-platform/meta/webvtt/rendering/cues-with-video/processing-model/bidi/u0041_first.html.ini", "testing/web-platform/meta/webvtt/rendering/cues-with-video/processing-model/bidi/u06E9_no_strong_dir.html.ini"], "git_node": null, "git_parents": [null, null], "node": "70b57f56868e804240f4ee0fc031ed3b01234e4c", "parents": ["3e515738e4b5230b58c23b1c8a8ee24574bd6c10", "69f9ae4f6e8943d24569a9e4380f6df869f56b73"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1428693 - Use GetOverflowAreasRelativeToSelf() instead of GetOverflowAreas() for scrollable parent. r=mattwoodrow\n\nBecause the scrollable parent might be transformed by its ancestors.\n\nMozReview-Commit-ID: FuCPLg54z7h", "files": ["dom/animation/test/mozilla/file_restyles.html", "layout/generic/nsFrame.cpp"], "git_node": null, "git_parents": [null], "node": "8ff883d778bfdc84e064457fc1f85617f034de1d", "parents": ["70b57f56868e804240f4ee0fc031ed3b01234e4c"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1441688 - Remove nsIIPCSerializableURI.Deserialize r=mayhemer\n\nMozReview-Commit-ID: 8gwX3vSKWNX", "files": ["caps/NullPrincipalURI.h", "dom/file/nsHostObjectURI.h", "dom/jsurl/nsJSProtocolHandler.h", "image/decoders/icon/nsIconURI.h", "ipc/glue/nsIIPCSerializableURI.h", "modules/libjar/nsJARURI.h", "netwerk/base/nsSimpleNestedURI.h", "netwerk/base/nsSimpleURI.h", "netwerk/base/nsStandardURL.h"], "git_node": null, "git_parents": [null], "node": "1e7b27d3a00ffd2ffd66b1b9cbdfdceb1b78d7bb", "parents": ["8ff883d778bfdc84e064457fc1f85617f034de1d"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441864 - Fix ContentProcessForward data handling; r=bgrins.\n\nIn ContentProcessForward, we listen for console-api-log-event in order\nto pass data to the Browser console and Browser toolbox.\nBut the data is modified and properties are cherry-picked from the original\nevent, missing some properties probably introduced later like `counter`,\n`prefix`, `private`, \u2026\nThe fix consists in cloning the original event data and only overriding what\nneeds to be overridden.\n\nMozReview-Commit-ID: 6jSfiRxcHQa", "files": ["devtools/client/webconsole/new-console-output/test/mochitest/browser.ini", "devtools/client/webconsole/new-console-output/test/mochitest/browser_console_webconsole_console_api_calls.js", "devtools/server/actors/webconsole/content-process-forward.js"], "git_node": null, "git_parents": [null], "node": "e365d166458b434e2968657b158db9adddb33c2b", "parents": ["1e7b27d3a00ffd2ffd66b1b9cbdfdceb1b78d7bb"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1364025 - Remove some sanity-checks for unscopables, because idlharness is invoked with only fragmentary idl. r=xidorn", "files": ["testing/web-platform/tests/resources/idlharness.js"], "git_node": null, "git_parents": [null], "node": "4b24e3da0dba92f96403a1402c4e69a2ff1e000e", "parents": ["84ea422093dd615bd191a3e579ed299d96c802f1"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1364025 - Fix Payment Request interface IDL test to not check EventHandler. r=bz\n\nMozReview-Commit-ID: 93Lcg6wo1Xs", "files": ["testing/web-platform/tests/payment-request/interfaces.https.html"], "git_node": null, "git_parents": [null], "node": "8e54d2f48d4f2a0b50c0fa58642328b898c63518", "parents": ["4b24e3da0dba92f96403a1402c4e69a2ff1e000e"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1364025 - Add Unscopable to Document.fullscreen. r=bz\n\nMozReview-Commit-ID: CK8pbdKeBas", "files": ["dom/webidl/Document.webidl", "testing/web-platform/meta/fullscreen/interfaces.html.ini"], "git_node": null, "git_parents": [null], "node": "fd432ad90d28c730dda9aa1b9a8fbde7ab86d519", "parents": ["8e54d2f48d4f2a0b50c0fa58642328b898c63518"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441754 - clang-format some Preferences.cpp code that needs it. r=glandium\n\nMozReview-Commit-ID: E6kxiIs92qB", "files": ["modules/libpref/Preferences.cpp"], "git_node": null, "git_parents": [null], "node": "4a6b832ce2521677f35b380245a621c2d46eb03c", "parents": ["fd432ad90d28c730dda9aa1b9a8fbde7ab86d519"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441754 - Split measurements of pref callbacks in two. r=glandium\n\nThis shows that the objects themselves are accounting for about 60% of the\ncallback memory on 64-bit, and the domains are about 40%.\n\nMozReview-Commit-ID: JndlyIvlrGs", "files": ["modules/libpref/Preferences.cpp"], "git_node": null, "git_parents": [null], "node": "17fe71b2e622c2ae4bfcc963156ddc8815f40dd1", "parents": ["4a6b832ce2521677f35b380245a621c2d46eb03c"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441754 - Privatize CallbackNode's field. r=glandium\n\nThis isn't compelling on its own, but it's necessary for the next patch.\n\nMozReview-Commit-ID: CFON8DCdGoA", "files": ["modules/libpref/Preferences.cpp"], "git_node": null, "git_parents": [null], "node": "13e0252c67c9caeb7fa73ae5b2e16080c84cb728", "parents": ["17fe71b2e622c2ae4bfcc963156ddc8815f40dd1"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441754 - Shrink CallbackNode by combining mMatchKind and mNext into a tagged pointer. r=glandium\n\nThe following table shows the effect of this change:\n\n\u003e                           old 64-bit  new 64-bit  old 32-bit  new 32-bit\n\u003e sizeof(CallbackNode)      40          32          20          16\n\u003e size when heap allocated  48          32          32          16\n\nThis reduces memory usage by about 15--40 KB per process.\n\nMozReview-Commit-ID: 4gXgGI3SiJz", "files": ["modules/libpref/Preferences.cpp"], "git_node": null, "git_parents": [null], "node": "e6680fcb17a0392208b7413a214a662f8b8ca284", "parents": ["13e0252c67c9caeb7fa73ae5b2e16080c84cb728"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441754 - Use MOZ_ASSERT instead of NS_ASSERTION and NS_PRECONDITION in Preferences.cpp. r=glandium\n\nI also removed the explanation string in cases where I felt it was obvious.\n\nMozReview-Commit-ID: IyHswX3s23y", "files": ["modules/libpref/Preferences.cpp"], "git_node": null, "git_parents": [null], "node": "76a740cc4454f92c44b10e63abcc3d68daf8ee06", "parents": ["e6680fcb17a0392208b7413a214a662f8b8ca284"], "tags": []}, {"author": "Andreea Pavel \u003capavel@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to mozilla-inbound. a=merge on a CLOSED TREE", "files": [], "git_node": null, "git_parents": [null, null], "node": "2a70fdfcfde97397e2c47844d85a8a9d7437385c", "parents": ["76a740cc4454f92c44b10e63abcc3d68daf8ee06", "69f9ae4f6e8943d24569a9e4380f6df869f56b73"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1439181: Stop mangling stack traces in AOM errors. r=aswan\n\nMozReview-Commit-ID: 6Nh4hwwvrWb", "files": ["toolkit/modules/Log.jsm"], "git_node": null, "git_parents": [null], "node": "99fd2c41687b7a9f7912a2b74b1eaaf4fa7a96f9", "parents": ["2a