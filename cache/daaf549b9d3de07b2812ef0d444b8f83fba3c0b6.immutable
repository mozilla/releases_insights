": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1454625 - Don't update settings from constraints if already updated from frame. r=padenot a=jcristau\n\nMozReview-Commit-ID: KgiPUnXCWoM", "files": ["dom/media/webrtc/MediaEngineRemoteVideoSource.cpp", "dom/media/webrtc/MediaEngineRemoteVideoSource.h"], "git_node": null, "git_parents": [null], "node": "3d90a56e773bdd283d116c16fcf9868f8cf841d4", "parents": ["7e549c71e606eaaf4945bca9e85ddff08375aea1"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1450954 - Test that a screenshare track's getSettings return sane dimensions. r=jib a=test-only\n\nMozReview-Commit-ID: GDSQLfXBFBU", "files": ["dom/media/tests/mochitest/test_getUserMedia_basicScreenshare.html"], "git_node": null, "git_parents": [null], "node": "9f024ae9a5a441dd931076e4833baf4947f8889d", "parents": ["3d90a56e773bdd283d116c16fcf9868f8cf841d4"], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1454824 - Disable discarding of animated image frames due to high CPU consumption. r=tnikkel a=jcristau", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "893ccda7531fba88b84bfb060772aa405189851f", "parents": ["9f024ae9a5a441dd931076e4833baf4947f8889d"], "tags": []}, {"author": "J. Ryan Stinnett \u003cjryans@gmail.com\u003e", "branch": "default", "desc": "Bug 1446496 - Revive DevTools time active probes. datareview=francois r=jdescottes a=jcristau\n\n* Mark all DevTools time active probes as opt-out\n* Revive the about:debugging and RDM probes\n* Remove dead tilt probe\n\nMozReview-Commit-ID: cmbQawo5g8", "files": ["toolkit/components/telemetry/Histograms.json", "toolkit/components/telemetry/histogram-whitelists.json"], "git_node": null, "git_parents": [null], "node": "38c8ace9652b5e8716d682b90a9c1c5b8384e54c", "parents": ["893ccda7531fba88b84bfb060772aa405189851f"], "tags": []}, {"author": "Peter Van der Beken \u003cpeterv@propagandism.org\u003e", "branch": "default", "desc": "Bug 1430818 - Crash in URIUtils::ResetWithSource. r=bz a=jcristau\n\nWe want to create the source fragment before trying to use it in URIUtils::ResetWithSource.\nThe testcase triggers an assertion related to unbalanced onload blocking/unblocking,\nfixing that by blocking onload on the new document we're setting in OnTransformDone and\nunblocking onload on the old document.", "files": ["dom/xml/nsXMLContentSink.cpp", "dom/xslt/crashtests/1430818.sjs", "dom/xslt/crashtests/1430818.xml", "dom/xslt/crashtests/crashtests.list", "dom/xslt/xslt/txMozillaXSLTProcessor.cpp"], "git_node": null, "git_parents": [null], "node": "14286e941bdfabec387a59da2b3bb07ee8e5fa90", "parents": ["38c8ace9652b5e8716d682b90a9c1c5b8384e54c"], "tags": []}, {"author": "Peter Van der Beken \u003cpeterv@propagandism.org\u003e", "branch": "default", "desc": "Bug 1436040 - xslt processor: \u003c?xslt-param name= value= ?\u003e isn't recognized. r=bz a=jcristau\n\nThe patch for bug 1387427 made us keep the source content in an array and we don't insert\nit into the document anymore. The code for xslt-param and xslt-param-namespace should look\nin the source content array instead of the document.", "files": ["dom/xml/nsXMLContentSink.cpp", "dom/xslt/nsIDocumentTransformer.h", "dom/xslt/tests/mochitest/mochitest.ini", "dom/xslt/tests/mochitest/test_bug1436040.html", "dom/xslt/xslt/txMozillaXSLTProcessor.cpp", "dom/xslt/xslt/txMozillaXSLTProcessor.h"], "git_node": null, "git_parents": [null], "node": "b72ae1a6c4a4a62c31f87cf56bc0269e2dcf3e12", "parents": ["14286e941bdfabec387a59da2b3bb07ee8e5fa90"], "tags": []}, {"author": "Brad Werth \u003cbwerth@mozilla.com\u003e", "branch": "default", "desc": "Bug 1437509 Part 1: Expand nsRange::ExtractRectFromOffset to correctly generate rects from vertical text runs. r=bz a=jcristau\n\nMozReview-Commit-ID: 2n9SCn0eu9B", "files": ["dom/base/nsRange.cpp"], "git_node": null, "git_parents": [null], "node": "20d2e80aa71b8fcefbe5e72d203007909810db03", "parents": ["b72ae1a6c4a4a62c31f87cf56bc0269e2dcf3e12"], "tags": []}, {"author": "Brad Werth \u003cbwerth@mozilla.com\u003e", "branch": "default", "desc": "Bug 1437509 Part 2: Add a test to ensure we can find vertical text. r=mikedeboer a=test-only\n\nMozReview-Commit-ID: Kh5HKzo2hsB", "files": ["toolkit/modules/tests/browser/browser.ini", "toolkit/modules/tests/browser/browser_Finder_vertical_text.js"], "git_node": null, "git_parents": [null], "node": "28ef3feed53a152327570e700ffa83d9dc0a5baf", "parents": ["20d2e80aa71b8fcefbe5e72d203007909810db03"], "tags": []}, {"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1450814 - generic implementation of DrawTarget::Blur using LockBits. r=rhunt a=jcristau\n\nMozReview-Commit-ID: 2jROASoiPQd", "files": ["gfx/2d/2D.h", "gfx/2d/DrawTarget.cpp", "gfx/2d/DrawTargetSkia.cpp", "gfx/2d/DrawTargetSkia.h"], "git_node": null, "git_parents": [null], "node": "2a0555131c04bffedb7a71be27ca97a3f8303d92", "parents": ["28ef3feed53a152327570e700ffa83d9dc0a5baf"], "tags": []}, {"author": "Kirk Steuber \u003cksteuber@mozilla.com\u003e", "branch": "default", "desc": "Bug 1451024 - Cookie settings should be disabled when the related prefs are locked r=jaws a=jcristau\n\nAlso adds too the cookie tests to ensure this takes effect.\n\nMozReview-Commit-ID: A85kv20BcnI", "files": ["browser/components/enterprisepolicies/tests/browser/browser_policy_cookie_settings.js", "browser/components/preferences/in-content/privacy.js"], "git_node": null, "git_parents": [null], "node": "c5734a8b1d7a590e4d1c54cdbf90ea0fa348f9d6", "parents": ["2a0555131c04bffedb7a71be27ca97a3f8303d92"], "tags": []}, {"author": "Thom Chiovoloni \u003ctchiovoloni@mozilla.com\u003e", "branch": "default", "desc": "Bug 1453887 - Avoid syncing as the network link changes to down r=eoger a=jcristau\n\nMozReview-Commit-ID: 5C2qDX4iITU", "files": ["services/sync/modules/policies.js", "services/sync/tests/unit/test_syncscheduler.js"], "git_node": null, "git_parents": [null], "node": "dad20eed22b948cfc168a6d4dcfe49e446a05c65", "parents": ["c5734a8b1d7a590e4d1c54cdbf90ea0fa348f9d6"], "tags": []}, {"author": "Jamie Nicol \u003cjnicol@mozilla.com\u003e", "branch": "default", "desc": "Bug 1443149 - Ensure WebGLFBAttachPoint::HasImage() before dereferencing Format(). r=jrmuizel a=jcristau\n\nPreviously we were checking IsDefined() rather than HasImage(), but\nwere hitting crashes. This was because Format() can return null if the\nattach point is defined but the attached texture level or renderbuffer\naren't themselves defined. HasImage() checks for this case.\n\nMozReview-Commit-ID: 8KY3zPXXAFv", "files": ["dom/canvas/WebGLContextFramebufferOperations.cpp"], "git_node": null, "git_parents": [null], "node": "6dccd26e00afeaa2b62671e87fd8b634ba67ed81", "parents": ["dad20eed22b948cfc168a6d4dcfe49e446a05c65"], "tags": []}, {"author": "Masatoshi Kimura \u003cVYV03354@nifty.ne.jp\u003e", "branch": "default", "desc": "Bug 1450538 - Use nsIURI::GetDisplaySpec to compensate a change to nsIURI::GetSpec. r=valentin a=jcristau\n\nMozReview-Commit-ID: 5xYAbx78K3q", "files": ["docshell/base/nsDocShell.cpp"], "git_node": null, "git_parents": [null], "node": "8b59be7c1ce63c7d70b53a8fd76f019c9a63ea6e", "parents": ["6dccd26e00afeaa2b62671e87fd8b634ba67ed81"], "tags": []}, {"author": "Masatoshi Kimura \u003cVYV03354@nifty.ne.jp\u003e", "branch": "default", "desc": "Bug 1450538 - Browser test to ensure that the StatusPanel displays an IDN. r=Gijs a=test-only\n\nMozReview-Commit-ID: 2DFZgqQTN7K", "files": ["browser/base/content/test/statuspanel/browser.ini", "browser/base/content/test/statuspanel/browser_show_statuspanel_idn.js", "browser/base/content/test/statuspanel/head.js"], "git_node": null, "git_parents": [null], "node": "fd3897b47e12f5a392f83914e0fbf9a2b8216366", "parents": ["8b59be7c1ce63c7d70b53a8fd76f019c9a63ea6e"], "tags": []}, {"author": "Francois Marier \u003cfrancois@mozilla.com\u003e", "branch": "default", "desc": "Bug 1452699 - Work-around caching issues in test_same_site_cookies_*. r=ckerschb a=jcristau\n\nMozReview-Commit-ID: cTH2uyPMTA", "files": ["dom/security/test/general/file_same_site_cookies_cross_origin_context.sjs", "dom/security/test/general/file_same_site_cookies_from_script.sjs", "dom/security/test/general/file_same_site_cookies_subrequest.sjs", "dom/security/test/general/file_same_site_cookies_toplevel_nav.sjs", "dom/security/test/general/test_same_site_cookies_cross_origin_context.html", "dom/security/test/general/test_same_site_cookies_from_script.html", "dom/security/test/general/test_same_site_cookies_subrequest.html", "dom/security/test/general/test_same_site_cookies_toplevel_nav.html"], "git_node": null, "git_parents": [null], "node": "3d169f37e563b87d5fd54d6c8ca9e4efa5722b14", "parents": ["fd3897b47e12f5a392f83914e0fbf9a2b8216366"], "tags": []}, {"author": "Francois Marier \u003cfrancois@mozilla.com\u003e", "branch": "default", "desc": "Bug 1452699 - Add a temporary pref to disable same-site cookies. r=ckerschb,valentin a=jcristau\n\nMozReview-Commit-ID: LRnaSmdSgVW", "files": ["dom/security/test/general/test_same_site_cookies_cross_origin_context.html", "dom/security/test/general/test_same_site_cookies_from_script.html", "dom/security/test/general/test_same_site_cookies_subrequest.html", "dom/security/test/general/test_same_site_cookies_toplevel_nav.html", "modules/libpref/init/all.js", "netwerk/cookie/CookieServiceChild.cpp", "netwerk/cookie/nsCookieService.cpp", "netwerk/cookie/nsCookieService.h"], "git_node": null, "git_parents": [null], "node": "daf993d98606d4df565ea61769ff9a5da729060a", "parents": ["3d169f37e563b87d5fd54d6c8ca9e4efa5722b14"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1454486 - Update eBay icon. r=flod a=jcristau\n\nMozReview-Commit-ID: 5c7jFtvYZes", "files": ["browser/local