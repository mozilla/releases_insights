anvm@gmail.com"}, "8812": {"changesets": [{"author": "Chris Pearce \u003ccpearce@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441153 - Block cross origin redirects after media channel setup for wav. r=jya", "files": ["dom/media/ChannelMediaDecoder.cpp", "dom/media/ChannelMediaDecoder.h", "dom/media/DecoderTraits.cpp", "dom/media/DecoderTraits.h", "dom/media/MediaDecoder.h"], "git_node": null, "git_parents": [null], "node": "1c354bfdde04756d61c8a4cf4d2769386ca1e224", "parents": ["2e11c53b5a51948e8afb845e2c1603cc2ecd8b9f"], "tags": []}, {"author": "Lars T Hansen \u003clhansen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441765 - Introduce EARLY_BETA_OR_EARLIER in SpiderMonkey. r=glandium", "files": ["js/src/old-configure.in"], "git_node": null, "git_parents": [null], "node": "6ed3cc037e85f85dd356f744d79fe78b38666d5d", "parents": ["1c354bfdde04756d61c8a4cf4d2769386ca1e224"], "tags": []}, {"author": "Lars T Hansen \u003clhansen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441765 - Guard WebAssembly.Global on EARLY_BETA_OR_EARLIER.  r=luke", "files": ["js/src/moz.build", "js/src/wasm/WasmJS.cpp", "js/src/wasm/WasmJS.h", "js/src/wasm/WasmModule.cpp"], "git_node": null, "git_parents": [null], "node": "ade8e3e4fbaf9a886c2454e8f5bc3202360e3af5", "parents": ["6ed3cc037e85f85dd356f744d79fe78b38666d5d"], "tags": []}, {"author": "Lars T Hansen \u003clhansen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1439403 - General SpiderMonkey support for wasm on ARM64.  r=bbouvier\n\nWe introduce a few things to round out ARM64 support for wasm\n\n- add flags so as to support GetCPUID()\n- enable WASM_HUGE_MEMORY\n- remove the definition of HeapLenReg, it is not used except\n  by a disused bounds checking method, which we also remove\n- add stubbed-out disassembler support so as to allow the\n  signal handler code to compile and link when huge memory\n  is enabled (stubs, because it is only required to work for\n  asm.js, which is not supported by the baseline compiler)", "files": ["js/src/jit/RegisterAllocator.h", "js/src/jit/arm64/Architecture-arm64.cpp", "js/src/jit/arm64/Architecture-arm64.h", "js/src/jit/arm64/Assembler-arm64.h", "js/src/jit/arm64/Disassembler-arm64.cpp", "js/src/jit/arm64/MacroAssembler-arm64.h", "js/src/moz.build", "js/src/wasm/WasmSignalHandlers.cpp", "js/src/wasm/WasmTypes.cpp"], "git_node": null, "git_parents": [null], "node": "a2507d4da91b3539dbd80b2d9e6c33d82c861cbc", "parents": ["ade8e3e4fbaf9a886c2454e8f5bc3202360e3af5"], "tags": []}, {"author": "Arthur Edelstein \u003carthuredelstein@gmail.com\u003e", "branch": "default", "desc": "Bug 1433592 - Don't spoof ctrl key modifier for privacy.resistFingerprinting=true r=masayuki", "files": ["browser/components/resistfingerprinting/test/browser/browser_spoofing_keyboard_event.js", "dom/events/KeyboardEvent.cpp", "toolkit/components/resistfingerprinting/nsRFPService.cpp"], "git_node": null, "git_parents": [null], "node": "f15ab7984211cc4252982b3e61bc75543e70a9a3", "parents": ["a2507d4da91b3539dbd80b2d9e6c33d82c861cbc"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1425580 part 14 - Devirtualize LNode::setOperand. r=nbp", "files": ["js/src/jit/LIR.h", "js/src/jit/shared/LIR-shared.h"], "git_node": null, "git_parents": [null], "node": "1a74aee7c5498625d7f6ddc9676bf931a225503b", "parents": ["f15ab7984211cc4252982b3e61bc75543e70a9a3"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1438151 - Fix race in CodeGenerator::visitLambda in debug builds. r=arai", "files": ["js/src/jit/CodeGenerator.cpp", "js/src/jit/MIR.h"], "git_node": null, "git_parents": [null], "node": "4780be3c03b490e2f1d7d0acb4f998cb729901dd", "parents": ["1a74aee7c5498625d7f6ddc9676bf931a225503b"], "tags": []}, {"author": "Ciure Andrei \u003caciure@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to mozilla-inbound.  a=merge CLOSED TRE