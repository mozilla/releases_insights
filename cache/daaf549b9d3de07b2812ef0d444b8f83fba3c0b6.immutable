git_parents": [null], "node": "c023fae29cccb9b4cc697360444ba7c9774d2900", "parents": ["522aa8e25bd64608446b9ff6cc899b8d0525c8b8"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441877 - remove unused css variable --breakpoint-hover-background;r=jaws\n\nMozReview-Commit-ID: HhXMTo93QnJ", "files": ["devtools/client/sourceeditor/codemirror/old-debugger.css"], "git_node": null, "git_parents": [null], "node": "f6264884db15464ccef643630e426c81a1236296", "parents": ["c023fae29cccb9b4cc697360444ba7c9774d2900"], "tags": []}, {"author": "Jonathan Kingston \u003cjkt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441794 - Add deprecation warning to passive OBJECT_SUBREQUEST loads. r=ckerschb\n\nMozReview-Commit-ID: 3j2t5FDZFmp", "files": ["dom/base/nsDeprecatedOperationList.h", "dom/locales/en-US/chrome/dom/dom.properties", "dom/security/nsMixedContentBlocker.cpp"], "git_node": null, "git_parents": [null], "node": "28e43d9319827dd423de2d039078a2ea5de4be02", "parents": ["f6264884db15464ccef643630e426c81a1236296"], "tags": []}, {"author": "Zibi Braniecki \u003czbraniecki@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441913 - Include sync-brand.ftl into Preferences.xul MessageContext. r=flod\n\nMozReview-Commit-ID: 1JuVwUXYB7N", "files": ["browser/components/preferences/in-content/preferences.xul"], "git_node": null, "git_parents": [null], "node": "97ad28cce3a107d58abd28092afcc5c6862db313", "parents": ["28e43d9319827dd423de2d039078a2ea5de4be02"], "tags": []}, {"author": "Ralph Giles \u003cgiles@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430927 - Require Rust 1.24. r=froydnj\n\nRequire the current stable Rust release so new features can\nbe used in development.\n\nMozReview-Commit-ID: 4NQNk3RfBkF", "files": ["build/moz.configure/rust.configure", "taskcluster/ci/build/linux.yml", "taskcluster/ci/toolchain/linux.yml"], "git_node": null, "git_parents": [null], "node": "4ff0b140243a419443ff288a486a54834ed26d93", "parents": ["97ad28cce3a107d58abd28092afcc5c6862db313"], "tags": []}, {"author": "Jed Davis \u003cjld@mozilla.com\u003e", "branch": "default", "desc": "Bug 1438401 - Quietly fail shmget() in sandboxed content processes. r=gcp\n\nThe X11 symbol interposition isn't enough, possibly because Cairo can\nalso use XCB.  Interposing XCB is more difficult because the API exposes\nmore protocol details.  Instead, just allow shmget to be called and\nfail; this will tell Cairo that it can't use SysV IPC with the X server,\nwhich is what we want.\n\nMozReview-Commit-ID: 5y9tE7UXMTE", "files": ["security/sandbox/linux/SandboxFilter.cpp", "security/sandbox/linux/SandboxHooks.cpp"], "git_node": null, "git_parents": [null], "node": "936b73ae6e3ce7a98e596b0422b2776db349e85d", "parents": ["4ff0b140243a419443ff288a486a54834ed26d93"], "tags": []}, {"author": "Jed Davis \u003cjld@mozilla.com\u003e", "branch": "default", "desc": "Bug 1438391 - Detect VirtualGL and weaken the sandbox enough for it to work. r=gcp\n\nMozReview-Commit-ID: BXmm8JSfkeI", "files": ["security/sandbox/common/SandboxSettings.cpp", "security/sandbox/linux/launch/SandboxLaunch.cpp"], "git_node": null, "git_parents": [null], "node": "fca779af7ef708dc4fd7b54a07ff2834747c7c86", "parents": ["936b73ae6e3ce7a98e596b0422b2776db349e85d"], "tags": []}, {"author": "J. Ryan Stinnett \u003cjryans@gmail.com\u003e", "branch": "default", "desc": "Bug 1441974 - Avoid duplicate clicks in sidebar toggle. r=gl\n\nAfter the React monkeypatch removal (bug 1420130), some events can be duplicated\nbecause both privileged and non-privileged versions are dispatched.\n\nTo work around this, we can stop propagation for the event in cases like this\nwhere it is safe to do so.\n\nMozReview-Commit-ID: L6cHpuTw1D2", "files": ["devtools/client/shared/components/SidebarToggle.js"], "git_node": null, "git_parents": [null], "node": "853caeaad89b97ae57584eb1958850a3e44f89f9", "parents": ["fca779af7ef708dc4fd7b54a07ff2834747c7c86"