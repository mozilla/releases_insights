"files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "3e0c4def4e8ac0c35a73407f0831b46433a0c427", "parents": ["35fb075df162f7fe8b5907f4ef6f3dcea88d71ee"], "tags": []}], "date": 1523388114, "git_changesets": [null, null], "user": "ffxbld"}, "9021": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset cb808626c8df (bug 1424505) because it didn't help with the crashes. r=jimm, a=RyanVM", "files": ["dom/ipc/ContentParent.cpp", "dom/ipc/PreallocatedProcessManager.cpp", "dom/ipc/PreallocatedProcessManager.h"], "git_node": null, "git_parents": [null], "node": "8e7c044b2e71af8b7dba06ced0298fe50446c575", "parents": ["3e0c4def4e8ac0c35a73407f0831b46433a0c427"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Revert changeset d856b4067e80 (bug 1421144) to work around the crashes in bug 1424505. r=Jamie, a=RyanVM", "files": ["accessible/windows/msaa/RootAccessibleWrap.cpp", "accessible/windows/msaa/RootAccessibleWrap.h"], "git_node": null, "git_parents": [null], "node": "7d6400c2038cf35259e42d30541654a94e7a7b9a", "parents": ["8e7c044b2e71af8b7dba06ced0298fe50446c575"], "tags": []}], "date": 1523392234, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "9022": {"changesets": [{"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1451727 - [marionette] Add \"WebDriver:AcceptAlert\" in favor of \"WebDriver:AcceptDialog\". r=ato a=test-only\n\nTo be consistent with the spec the command should be named\n\"WebDriver:AcceptAlert\".\n\nMozReview-Commit-ID: HGB9hJPAvcU", "files": ["testing/marionette/driver.js"], "git_node": null, "git_parents": [null], "node": "def0f8799e4f663e3062beef4d877000bfdd0f34", "parents": ["7d6400c2038cf35259e42d30541654a94e7a7b9a"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1451727 - [marionette] Update WebDriver specific commands to use the \"WebDriver\" prefix. r=ato a=test-only\n\nMozReview-Commit-ID: 57wk5BD8F2m", "files": ["testing/marionette/client/marionette_driver/marionette.py", "testing/marionette/client/marionette_driver/timeout.py"], "git_node": null, "git_parents": [null], "node": "1bcba4cdfa8611951396c98250aaa31a947f332e", "parents": ["def0f8799e4f663e3062beef4d877000bfdd0f34"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1451727 - [marionette] Update vendor specific commands to use custom prefixes. r=ato a=test-only\n\nAll chrome context related commands have to use the \"Marionette\"\nprefix. For those commands which accidentally have been put under\nthe \"WebDriver\" prefix a fallback to the old command is needed\nin the Marionette client.\n\nAlso update related comments about possible removal dates.\n\nMozReview-Commit-ID: IZLL6pineSO", "files": ["testing/marionette/client/marionette_driver/addons.py", "testing/marionette/client/marionette_driver/localization.py", "testing/marionette/client/marionette_driver/marionette.py", "testing/marionette/driver.js"], "git_node": null, "git_parents": [null], "node": "3d457aab66d4f828ea7e521b34e294f3a93e9ae2", "parents": ["1bcba4cdfa8611951396c98250aaa31a947f332e"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1451727 - [marionette] Remove unused execute_js_script method. r=ato a=test-only\n\nMozReview-Commit-ID: 3tkQmmRZfbd", "files": ["testing/marionette/client/marionette_driver/marionette.py"], "git_node": null, "git_parents": [null], "node": "0c798753bf0722e547644c323cd9bdc0e497a461", "parents": ["3d457aab66d4f828ea7e521b34e294f3a93e9ae2"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1451727 - [marionette] Remove deprecated WebDriver commands. r=ato a=test-only\n\nRemoves the following deprecated WebDriver commands from marionette\nclient: Element.size, Element.location, set_script_timeout,\nset_search_timeout, and set_page_load_timeout.\n\nIt doesn't touch get_window_position, set_window_position,\nwindow_size, and set_window_size because those are covered\nby bug 1348145.\n\nMozReview-Commit-ID: 9b74toO1Rzm", "files": ["layout/base/tests/marionette/test_accessiblecaret_cursor_mode.py", "testing/marionette/client/marionette_driver/marionette.py", "testing/marionette/harness/marionette_harness/tests/unit/test_mouse_action.py", "testing/marionette/harness/marionette_harness/tests/unit/test_timeouts.py"], "git_node": null, "git_parents": [null], "node": "5b7aa80c261963293a7f59a5845f67d85ab1c6cd", "parents": ["0c798753bf0722e547644c323cd9bdc0e497a461"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1452913 - Prevent hang of reftests when reading test objects list fails. r=gbrown a=test-only\n\nFor the promise as returned by \"OS.File.read()\" the catch handler\nis missing, and as such the tests will never be started when\nthe call to \"read()\" triggers an exception. It also results in\na hang of the reftest harness.\n\nTo prevent this, the failure has to be handled and appropriately\nreported.\n\nMozReview-Commit-ID: IX9thgjjahS", "files": ["layout/tools/reftest/reftest.jsm"], "git_node": null, "git_parents": [null], "node": "2906b68565838730bbcab48ba59f89c6f9810527", "parents": ["5b7aa80c261963293a7f59a5845f67d85ab1c6cd"], "tags": []}], "date": 1523451377, "git_changesets": [null, null, null, null, null, null], "user": "apavel@mozilla.com"}, "9023": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\naz -\u003e a7ef38e80b39\nbg -\u003e 7ae7da739c66\ncy -\u003e 520cfbef8c74\nel -\u003e 5be08eb300d8\nes-ES -\u003e 3cd373bedd3f\ngn -\u003e 2d24685f5e9c\ngu-IN -\u003e