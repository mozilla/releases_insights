"], "tags": []}], "date": 1523544319, "git_changesets": [null, null, null], "user": "ebalazs@mozilla.com"}, "9029": {"changesets": [{"author": "Christoph Kerschbaumer \u003cckerschb@christophkerschbaumer.com\u003e", "branch": "default", "desc": "Bug 1286861: Update CookieService to enforce same site cookies. r=valentin a=jcristau", "files": ["netwerk/base/nsNetUtil.cpp", "netwerk/base/nsNetUtil.h", "netwerk/cookie/CookieServiceChild.cpp", "netwerk/cookie/CookieServiceChild.h", "netwerk/cookie/CookieServiceParent.cpp", "netwerk/cookie/CookieServiceParent.h", "netwerk/cookie/PCookieService.ipdl", "netwerk/cookie/nsCookieService.cpp", "netwerk/cookie/nsCookieService.h", "netwerk/test/TestCookie.cpp"], "git_node": null, "git_parents": [null], "node": "ca8c228d8d97afdbf0577364d6a0acdd75874dc9", "parents": ["319231c9be3b788474869fa2fe2fa1f98fef7b72"], "tags": []}, {"author": "Christoph Kerschbaumer \u003cckerschb@christophkerschbaumer.com\u003e", "branch": "default", "desc": "Bug 1286861: Add tests for same site subrequests. r=mgoodwin a=jcristau", "files": ["dom/security/test/general/file_same_site_cookies_subrequest.sjs", "dom/security/test/general/mochitest.ini", "dom/security/test/general/test_same_site_cookies_subrequest.html"], "git_node": null, "git_parents": [null], "node": "9024291f55d418c046ebc93a03eac06f4976ccc5", "parents": ["ca8c228d8d97afdbf0577364d6a0acdd75874dc9"], "tags": []}, {"author": "Christoph Kerschbaumer \u003cckerschb@christophkerschbaumer.com\u003e", "branch": "default", "desc": " Bug 1286861: Add tests for same site top-level. r=mgoodwin a=jcristau", "files": ["dom/security/test/general/file_same_site_cookies_toplevel_nav.sjs", "dom/security/test/general/mochitest.ini", "dom/security/test/general/test_same_site_cookies_toplevel_nav.html"], "git_node": null, "git_parents": [null], "node": "923b9070f099f187bbde828b8266c8e97e22cf2c", "parents": ["9024291f55d418c046ebc93a03eac06f4976ccc5"], "tags": []}, {"author": "Nevin Chen \u003ccnevinchen@gmail.com\u003e", "branch": "default", "desc": "Bug 1399388 - Only when new page is exactly 'about:home' will be treated as default home page. r=sdaswani a=jcristau", "files": ["mobile/android/base/java/org/mozilla/gecko/AboutPages.java", "mobile/android/base/java/org/mozilla/gecko/GeckoApp.java"], "git_node": null, "git_parents": [null], "node": "e595eb784023406aa49fe62c3ac637295987cff9", "parents": ["923b9070f099f187bbde828b8266c8e97e22cf2c"], "tags": []}], "date": 1523545098, "git_changesets": [null, null, null, null], "user": "cbrindusan@mozilla.com"}, "9030": {"changesets": [{"author": "Vinothkumar Nagasayanan \u003cvnagasayanan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1424023 - Test run time reduced using another new iframe. r=ckerschb a=test-only", "files": ["dom/base/test/referrerHelper.js", "dom/base/test/test_bug704320.html"], "git_node": null, "git_parents": [null], "node": "bf3f15489315db3b1330dd866a478429baf3e2a1", "parents": ["e595eb784023406aa49fe62c3ac637295987cff9"], "tags": []}, {"author": "arthur.iakab \u003caiakab@mozilla.com\u003e", "branch": "default", "desc": "Bug 1425175  skip-waiting-using-registration.https.html.ini disabled on Linux, OSX opt, Windows 7 pgo platforms r=jmaher a=test-only", "files": ["testing/web-platform/meta/service-workers/service-worker/skip-waiting-using-registration.https.html.ini"], "git_node": null, "git_parents": [null], "node": "4caca965bb6c8d810f4a90f9678af95d3030e9b1", "parents": ["bf3f15489315db3b1330dd866a478429baf3e2a1"], "tags": []}, {"author": "Haik Aftandilian \u003chaftandilian@mozilla.com\u003e", "branch": "default", "desc": "Bug 1437281 - OSX dragging image to desktop changes OSX File associations r=mystor a=jcristau\n\nOn Mac, when dragging an image, add the image request's MIME type to\nthe transfer so that the MIME-extension check can be done in the\nparent process to avoid content sandboxing issues.\n\nMozReview-Commit-ID: 3cb4fCr6GnL", "files": ["dom/base/nsContentAreaDragDrop.cpp", "dom/base/nsContentAreaDragDrop.h", "dom/events/DataTransfer.cpp", "dom/events/DataTransfer.h", "widget/nsITransferable.idl"], "git_node": null, "git_parents": [null], "node": "5c9ecfe219442ce82186e6c4ee630c40a96d9219", "parents": ["4caca965bb6c8d810f4a90f9678af95d3030e9b1"], "tags": []}, {"author": "Haik Aftandilian \u003chaftandilian@mozilla.com\u003e", "branch": "default", "desc": "Bug 1448374 - Loading a .javascript file from a WebExtension's web_accessible_resources messing with macOS file associations r=jimm a=jcristau\n\nFrom content processes, on Mac, use ContentHandlerService::GetTypeFromExtension()\ninstead of trying to query the OS directly for MIME information.\nTrying to get MIME information from the OS is blocked by content process\nsandboxing on Mac.\n\nMozReview-Commit-ID: KGJHDBklxvb", "files": ["uriloader/exthandler/mac/nsOSHelperAppService.h", "uriloader/exthandler/mac/nsOSHelperAppService.mm"], "git_node": null, "git_parents": [null], "node": "6244d0e8ca93e80525c5d8d8efdcaa08e33b3242", "parents": ["5c9ecfe219442ce82186e6c4ee630c40a96d9219"], "tags": []}, {"author": "Adam Gashlin \u003cagashlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1437941: Don't ignore mousemove after fullscreen transition r=handyman a=jcristau\n\nMozReview-Commit-ID: Hr9dcKVeYEC", "files": ["dom/base/nsGlobalWindowOuter.cpp", "widget/nsBaseWidget.h", "widget/nsIWidget.h", "widget/windows/nsWindow.cpp", "widget/windows/nsWindow.h"], "git_node": null, "git_parents": [null], "node": "9c43b5c6ee7281835568b853c4104214c1c02809", "parents": ["6244d0e8ca93e80525c5d8d8efdcaa08e33b3242"], "tags": []}, {"author": "Richard Newman \u003crnewman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442248 - Don't attempt to advance to the next sync stage if we've aborted. r=eoger a=jcristau", "files": ["mobile/android/services/src/main/java/org/mozilla/gecko/sync/GlobalSession.java"], "git_node": null, "git_parents": [null], "node": "9b49a4d349240fc547bfe75eb8c4bca5df1784db", "parents": ["9c43b5c6ee7281835568b853c4104214c1c02809"], "tags": []}, {"author": "David Parks \u003cdparks@mozilla.com\u003e", "branch": "default", "desc": "Bug 1446499: Use static nsWindowsDllInterceptor in plugin's HookProtectedMode r=aklotz a=jcristau\n\nHookProtectedMode requires its nsWindowsDllInterceptor to last as long as the functions need to be overridden.  This uses a static object instead of a local one.", "files": ["dom/plugins/ipc/FunctionHook.cpp"], "git_node": null, "git_parents": [null], "node": "d464bc1927f02af0fa7c4a3d5c1b38e1530f6fab", "parents": ["9b49a4d349240fc547bfe75eb8c4bca5df1784db"], "tags": []}, {"author": "alexander :surkov \u003csurkov.alexander@gmail.com\u003e", "branch": "default", "desc": "Bug 1451673 - \"Crash in mozilla::a11y::HTMLTableAccessible::IsProbablyLayoutTable\" r=MarcoZ a=jcristau", "files": ["accessible/html/HTMLTableAccessible.cpp"], "git_node": null, "git_parents": [null], "node": "c0ae9d98922d58dd629644966a67b35f30e35bda", "parents": ["d464bc1927f02af0fa7c4a3d5c1b38e1530f6fab"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1452048 - Give Looper lifetime control to external callers. r=dminor a=jcristau\n\nLooper lifetime must be handled by external callers as otherwise internal\ncallers may accidentally and unknowingly quit the looper and essentially\nterminate the camera thread, stopping any flow of frames and preventing future\nmessages.\n\nIn this case, a reconfig of the capture settings through startCapture() causes\nstartCaptureOnCameraThread() to restart the capture by calling into\nstopCaptureOnCameraThread() (quitting the looper) and then re-calling\nstartCaptureOnCameraThread() (not restarting the looper as that is invalid).\n\nThe camera thread is set up by startCapture() on the external calling thread,\nwhich will never know that a seemingly graceful camera thread operation stopped\nthe camera thread altogether, and so it cannot take any action.\n\nMozReview-Commit-ID: DUTFdanTan1", "files": ["media/webrtc/trunk/webrtc/modules/video_capture/android/java/src/org/webrtc/videoengine/VideoCaptureAndroid.java"], "git_node": null, "git_parents": [null], "node": "b932d9bda916e058c01b7a6518a0d453edfbdc58", "parents": ["c0ae9d98922d58dd629644966a67b35f30e35bda"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1452048 - Leave critical section before calling into java StartCapture(). r=dminor a=jcristau\n\nIf we stay in the critical section, and the StartCapture() is a reconfiguring\none, we risk deadlocking with IncomingFrame which runs on the camera thread.\n\nMozReview-Commit-ID: 5rU4urrBWxr", "files": ["media/webrtc/trunk/webrtc/modules/video_capture/android/video_capture_android.cc"], "git_node": null, "git_parents": [null], "node": "5032bbe4c92fb0cb307b8c11c824993ce0d51e69", "parents": ["b932d9bda916e058c01b7a6518a0d453edfbdc58"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1452048 - Read _captureStarted under lock on the camera thread. r=dminor a=jcristau\n\nIt is written under lock on the controlling thread (CamerasParent) in\nStartCapture/StopCapture.\n\nMozReview-Commit-ID: E7eq1YElhwt", "files": ["media/webrtc/trunk/webrtc/modules/video_capture/android/video_capture_android.cc"], "git_node": null, "git_parents": [null], "node": "7617bd6c7f2c215fcdd344af2cad8b0a6b1537b6", "parents": ["5032bbe4c92fb0cb307b8c11c824993ce0d51e69"], "tags": []}, {"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1449352 - always composite 24 depth WindowSurfaceX11 as BGRX. r=jrmuizel a=jcristau\n\nMozReview-Commit-ID: 3xeE3EEttR6", "files": ["widget/gtk/WindowSurfaceX11.cpp", "widget/gtk/WindowSurfaceX11Image.cpp"], "git_node": null, "git_parents": [null], "node": "36b90debcd465bc6c7af1c3b01ba73aef7647611", "parents": ["7617bd6c7f2c215fcdd344af2cad8b0a6b1537b6"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1451940: Don't reparse stylesheets when assigning empty string to empty element. r=bz a=jcristau\n\nPer spec, assinging an empty string to textContent or innerHTML should not\ntrigger any mutation observers, and therefore should not trigger a stylesheet\nreparse, when the element is already empty.\n\nSince we need to apply some special handling to innerHTML and textContent\nassignments to \u003cstyle\u003e nodes, and therefore re-parse directly in the setter\nrather than in response to mutation observers, we need to special-case this\nscenario.\n\nMozReview-Commit-ID: KdOYFs8ayT7", "files": ["dom/html/HTMLStyleElement.cpp", "testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/css/cssom/css-style-reparse.html"], "git_node": null, "git_parents": [null], "node": "84d5902b3a0276cf83cb0d3fa742d2721935f59b", "parents": ["36b90debcd465bc6c7af1c3b01ba73aef7647611"], "tags": []}], "date": 1523547967, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "9031": {"changesets": [{"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1447607 - Correctly init and update ElfLoader::Singleton::lastError r=glandium a=RyanVM\n\nMozReview-Commit-ID: r1bclXdt4V", "files": ["mozglue/linker/ElfLoader.cpp", "mozglue/linker/ElfLoader.h"], "git_node": null, "git_parents": [null], "node": "99690fed70cc2a25e1b78efd2ec445969e92f3e7", "parents": ["84d5902b3a0276cf83cb0d3fa742d2721935f59b"], "tags": []}, {"author": "mayank.raj \u003cmayank9856@gmail.com\u003e", "branch": "default", "desc": "Bug 1442884 - Show request details button does not work when the first request list item is not shown using any filters. r=Honza a=jcristau\n\nMozReview-Commit-ID: uE44j14qMB", "files": ["devtools/client/netmonitor/src/actions/ui.js", "devtools/client/netmonitor/src/reducers/requests.js", "devtools/client/netmonitor/test/browser.ini", "devtools/client/netmonitor/test/browser_net_pane-network-details.js"], "git_node": null, "git_parents": [null], "node": "4f4f03584f6a7ce3bc5278b97cd0a090116db501", "parents": ["99690fed70cc2a25e1b78efd2ec445969e92f3e7"], "tags": []}, {"author": "Christoph Kerschbaumer \u003cckerschb@christophkerschbaumer.com\u003e", "branch": "default", "desc": "Bug 1451094 - Fix null loadinfo deref. r=mayhemer a=jcristau", "files": ["netwerk/protocol/http/HttpBaseChannel.cpp"], "git_node": null, "git_parents": [null], "node": "ce914d685d4950e0aa70d76534481edd6200ecdc", "parents": ["4f4f03584f6a7ce3bc5278b97cd0a090116db501"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1447273 - Reduce AudioChunk::CanCombineWithFollowing indentation. r=padenot a=jcristau\n\nMozReview-Commit-ID: 9pk5xKrYoa6", "files": ["dom/media/AudioSegment.h"], "git_node": null, "git_parents": [null], "node": "432a01ff2f83fb4e23f815c250a8eb07632ab3fc", "parents": ["ce914d685d4950e0aa70d76534481edd6200ecdc"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1447273 - Consider all AudioChunk members in AudioChunk::CanCombineWithFollowing. r=padenot a=jcristau\n\nMozReview-Commit-ID: 1Fz1GNxRF3P", "files": ["dom/media/AudioSegment.h"], "git_node": null, "git_parents": [null], "node": "d83cf78e4b25a9c649b3974b279280f6b3e74863", "parents": ["432a01ff2f83fb4e23f815c250a8eb07632ab3fc"], "tags": []}, {"author": "Bryce Van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1447273 - Add test to check that different GainNode configuraitons produce correct output. r=padenot a=jcristau\n\nMozReview-Commit-ID: 6iaCqotLmug", "files": ["dom/media/webaudio/test/mochitest.ini", "dom/media/webaudio/test/test_bug1447273.html"], "git_node": null, "git_parents": [null], "node": "e4795b79e8c256b7632434f103f0bfd85fe48cf6", "