ressor.cpp", "gfx/graphite2/src/FeatureMap.cpp", "gfx/graphite2/src/FileFace.cpp", "gfx/graphite2/src/Pass.cpp", "gfx/graphite2/src/SegCacheEntry.cpp", "gfx/graphite2/src/Segment.cpp", "gfx/graphite2/src/Silf.cpp", "gfx/graphite2/src/TtfUtil.cpp", "gfx/graphite2/src/gr_face.cpp", "gfx/graphite2/src/gr_features.cpp", "gfx/graphite2/src/gr_font.cpp", "gfx/graphite2/src/gr_logging.cpp", "gfx/graphite2/src/gr_segment.cpp", "gfx/graphite2/src/inc/Code.h", "gfx/graphite2/src/inc/Collider.h", "gfx/graphite2/src/inc/Compression.h", "gfx/graphite2/src/inc/FeatureMap.h", "gfx/graphite2/src/inc/Font.h", "gfx/graphite2/src/inc/List.h", "gfx/graphite2/src/inc/Machine.h", "gfx/graphite2/src/inc/Main.h", "gfx/graphite2/src/inc/Segment.h", "gfx/graphite2/src/inc/Sparse.h", "gfx/graphite2/src/inc/opcode_table.h", "gfx/graphite2/src/inc/opcodes.h"], "git_node": null, "git_parents": [null], "node": "e805bff87d630994704d70b1b38871efda4b12a4", "parents": ["a0014a24f1e72bb1746cb9975068953d1f3451e2"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1425626 - Properly allow overrecursion in bug1416727.js jit-test. r=me", "files": ["js/src/jit-test/tests/baseline/bug1416727.js"], "git_node": null, "git_parents": [null], "node": "292900fd9665f28c748b2b517b7de4432d7dab2f", "parents": ["e805bff87d630994704d70b1b38871efda4b12a4"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1425580 part 20 - Clean up wasm call LIR instructions a bit. r=bbouvier", "files": ["js/src/jit/shared/LIR-shared.h"], "git_node": null, "git_parents": [null], "node": "9c1efa8fb87afff35a88c02419fabd22125de310", "parents": ["292900fd9665f28c748b2b517b7de4432d7dab2f"], "tags": []}, {"author": "Petr Sumbera \u003cpetr.sumbera@oracle.com\u003e", "branch": "default", "desc": "Bug 1439885 - Fix RelocationOverlay for big-endian machines in JavaScript : GC. r=sfink", "files": ["js/src/gc/RelocationOverlay.h"], "