], "git_node": null, "git_parents": [null, null], "node": "667fe01d1d3e8c0b5e9f55c6517a0bb307811001", "parents": ["2a0de8aa19f97208df6eb0678142ed0b63d29881", "bccdc684210431c233622650a91454c09f6af9eb"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1441982 - Add a WithDisplay annotation to GeckoSessionTestRule r=jchen\n\nThis will cause the GeckoSession to use a display with the specified size, necessary if\nyou need to send input to elements on the page, for example.\n\nMozReview-Commit-ID: IOCzQebLERl\n", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/rule/GeckoSessionTestRule.java"], "git_node": null, "git_parents": [null], "node": "2a6f6866c736060c517778b95e7afcb498c50d03", "parents": ["667fe01d1d3e8c0b5e9f55c6517a0bb307811001"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1441982 - Add GeckoSessionTestRule.synthesizeTap() r=jchen\n\nMozReview-Commit-ID: AFV8i0RbttA\n", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/rule/GeckoSessionTestRule.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/gfx/NativePanZoomController.java"], "git_node": null, "git_parents": [null], "node": "5c570aa49dfb8b5021f6b0ae50f50050d5f9bada", "parents": ["2a6f6866c736060c517778b95e7afcb498c50d03"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1441982 - Only allow an unopened GeckoSession as a response to onNewSession() r=jchen\n\nThis is a little clearer than the current semantics and explicitly allows reusing an\nexisting GeckoSession instance (as long as it's not yet open).\n\nMozReview-Commit-ID: 8e8gvOEjYze\n", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/TestRunnerActivity.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSession.java"], "git_node": null, "git_parents": [null], "node": "cf7689be97bcac8c139615250dcb59f0ea676275", "parents": ["5c570aa49dfb8b5021f6b0ae50f50050d5f9bada"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1441982 - Don't wrap RuntimeException instances if they are already a RuntimeException r=jchen\n\nOtherwise we can't use @Test(expected = IllegalArgumentException)\n\nMozReview-Commit-ID: EWKtUu5ok8X\n", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/rule/GeckoSessionTestRule.java"], "git_node": null, "git_parents": [null], "node": "b71f6a4e18cb33cc6490963b75ff515533d67cd9", "parents": ["cf7689be97bcac8c139615250dcb59f0ea676275"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1441982 - Queue input events while waiting for APZ to attach r=jchen\n\nThis is necessary to avoid races when sending input immediately after opening a GeckoSession\n\nMozReview-Commit-ID: HWkmxTmYJHa\n", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/gfx/NativePanZoomController.java"], "git_node": null, "git_parents": [null], "node": "64a19db957b2291978c899a41eacf6234b0dc746", "parents": ["b71f6a4e18cb33cc6490963b75ff515533d67cd9"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1441982 - Add a test for GeckoSession.NavigationListener.onNewSession() r=jchen\n\nMozReview-Commit-ID: DiEzwr5ClEr\n", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/NavigationListenerTest.kt"], "git_node": null, "git_parents": [null], "node": "f8bc3fd98796c2aa205e90001eb75b3c90b160c3", "parents": ["64a19db957b2291978c899a41eacf6234b0dc746"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1441982 - Remove old busted GeckoView NavigationTests r=jchen\n\nMozReview-Commit-ID: CdE6DeBT3ng\n", "files": ["mobile/android/geckoview/src/android