E/de_DE.aff", "editor/composer/test/de-DE/de_DE.dic", "editor/composer/test/en-AU/en_AU.aff", "editor/composer/test/en-AU/en_AU.dic", "editor/composer/test/en-GB/en_GB.aff", "editor/composer/test/en-GB/en_GB.dic", "editor/composer/test/test_async_UpdateCurrentDictionary.html", "editor/composer/test/test_bug1200533.html", "editor/composer/test/test_bug1204147.html", "editor/composer/test/test_bug1205983.html", "editor/composer/test/test_bug1209414.html", "editor/composer/test/test_bug1219928.html", "editor/composer/test/test_bug1365383.html", "editor/composer/test/test_bug338427.html", "editor/composer/test/test_bug678842.html", "editor/composer/test/test_bug697981.html", "editor/composer/test/test_bug717433.html", "editor/txtsvc/TextServicesDocument.cpp", "editor/txtsvc/TextServicesDocument.h", "editor/txtsvc/moz.build", "editor/txtsvc/nsFilteredContentIterator.cpp", "editor/txtsvc/nsFilteredContentIterator.h", "editor/txtsvc/nsIInlineSpellChecker.idl", "editor/txtsvc/nsISpellChecker.h", "editor/txtsvc/nsITextServicesFilter.idl"], "git_node": null, "git_parents": [null, null], "node": "d611ebace04d202ff01d8e5100689f43736edc51", "parents": ["2219e0ec9d4f1e89dba54b3dfe213d2fc675ae75", "51200c0fdaddb2749549a82596da5323a4cbd499"], "tags": []}, {"author": "Jan Beich \u003cjbeich@FreeBSD.org\u003e", "branch": "default", "desc": "Bug 1442753 - Use in-tree copy of cubeb-sys even when cubeb-remoting is disabled. r=kamidphish\n\nMozReview-Commit-ID: 3dGtrSqr9HW", "files": ["toolkit/library/rust/shared/Cargo.toml"], "git_node": null, "git_parents": [null], "node": "b1431462ceaf023d852bf52a7608307a3fd4b33f", "parents": ["51200c0fdaddb2749549a82596da5323a4cbd499"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442945 - Fix DND in Places menus. r=standard8\n\nMozReview-Commit-ID: 1fFYgsWOJMV", "files": ["browser/components/places/content/menu.xml"], "git_node": null, "git_parents": [null], "node": "d97c0342dc0dee82622cb8de573ae1408c6cf36b", "parents": ["b1431462ceaf023d852bf52a7608307a3fd4b33f"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1440102 - increase timeout for browser_dbg-babel-scopes.js and reenable on win ccov;r=jlast\n\nMozReview-Commit-ID: 2by2m5WkPf", "files": ["devtools/client/debugger/new/test/mochitest/browser.ini", "devtools/client/debugger/new/test/mochitest/browser_dbg-babel-scopes.js"], "git_node": null, "git_parents": [null], "node": "195a3f9c9d2b3ec4d94c1cd9244d1241c62a224b", "parents": ["d97c0342dc0dee82622cb8de573ae1408c6cf36b"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1443101: Assert Gecko_ContentList_AppendAll is main-thread-only. r=xidorn\n\nIt's only used for DOM APIs.\n\nMozReview-Commit-ID: EFMLH4yDtBf", "files": ["layout/style/ServoBindings.cpp"], "git_node": null, "git_parents": [null], "node": "8993c0064edbf042a796150b9394cb82a0892402", "parents": ["195a3f9c9d2b3ec4d94c1cd9244d1241c62a224b"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1437155: Avoid giving a first-letter frame to a display: contents element. r=mats\n\nIt doesn't make sense, since they have no frame themselves, and it breaks\ninvariants other code relies on. Use the parent frame instead.\n\nThe stack overflow happens because we give the first-letter frame to the\ndisplay: contents element, then we reframe it.\n\nRemoving a display: contents node calls ContentRemoved on all the children. One\nof these children is this text-node inside the first-letter frame. Since it was\nsplit by bidi resolution we go ahead and reframe the parent in:\n\n  https://searchfox.org/mozilla-central/rev/d2b4b40901c15614fad2fa34718eea428774306e/layout/base/nsCSSFrameConstructor.cpp#9688\n\nBut the parent is the display: contents node, which results in infinite\nrecursion.\n\nThe usage of GetParent() is wrong anyway too, since it doesn't handle XBL or\nShadow DOM in any way.\n\nMozReview-Commit-ID: JFD16at316V", "files": ["layout/base/crashtests/1437155.html", "layout/base/crashtests/crashtests.list", "layout/base/nsCSSFrameConstructor.cpp"], "git_node": null, "git_parents": [null], "node": "a9b65eec6830b856787227c22a6166d203cd844a", "parents": ["8993c0064edbf042a796150b9394cb82a0892402"], "tags": []}, {"author": "sotaro \u003csotaro.ikeda.g@gmail.com\u003e", "branch": "default", "desc": "Bug 1442146 - Fix jiggle during resizing on Windows r=nical", "files": ["widget/windows/nsWindowGfx.cpp"], "git_node": null, "git_parents": [null], "node": "7de2bea66b04c4b7a784e48010299d925b71f203", "parents": ["d611ebace04d202ff01d8e5100689f43736edc51"], "tags": []}, {"author": "Michael Ratcliffe \u003cmratcliffe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442813 - Web console eslint fixes r=nchevobbe\n\nMozReview-Commit-ID: AjhsU2lrqKT", "files": [".eslintignore", "devtools/client/webconsole/new-console-output/test/mochitest/browser_console_addonsdk_loader_exception.js", "devtools/client/webconsole/new-console-output/test/mochitest/browser_console_clear_method.js", "devtools/client/webconsole/new-console-output/test/mochitest/browser_console_context_menu_entries.js", "devtools/client/webconsole/new-console-output/test/mochitest/browser_console_webconsole_console_api_calls.js", "devtools/client/webconsole/new-console-output/test/mochitest/browser_console_webconsole_private_browsing.js", "devtools/client/webconsole/new-console-output/test/mochitest/browser_jsterm_accessibility.js", "devtools/client/webconsole/new-console-output/test/mochitest/browser_jsterm_add_edited_input_to_history.js", "devtools/client/webconsole/new-console-output/test/mochitest/browser_jsterm_autocomplete_array_no_index.js", "devtools/client/webconsole/new-console-output/test/mochitest/browser_jsterm_autocomplete_cached_results.js", "devtools/client/webconsole/new-console-output/tes