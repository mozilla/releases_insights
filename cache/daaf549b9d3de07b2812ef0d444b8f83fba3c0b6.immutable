gs.js", "browser/extensions/activity-stream/prerendered/locales/tl/activity-stream-prerendered.html", "browser/extensions/activity-stream/prerendered/locales/tl/activity-stream-strings.js", "browser/extensions/activity-stream/prerendered/locales/tr/activity-stream-prerendered.html", "browser/extensions/activity-stream/prerendered/locales/tr/activity-stream-strings.js", "browser/extensions/activity-stream/prerendered/locales/uk/activity-stream-prerendered.html", "browser/extensions/activity-stream/prerendered/locales/uk/activity-stream-strings.js", "browser/extensions/activity-stream/prerendered/locales/ur/activity-stream-prerendered.html", "browser/extensions/activity-stream/prerendered/locales/ur/activity-stream-strings.js", "browser/extensions/activity-stream/prerendered/locales/uz/activity-stream-prerendered.html", "browser/extensions/activity-stream/prerendered/locales/uz/activity-stream-strings.js", "browser/extensions/activity-stream/prerendered/locales/vi/activity-stream-prerendered.html", "browser/extensions/activity-stream/prerendered/locales/vi/activity-stream-strings.js", "browser/extensions/activity-stream/prerendered/locales/zh-CN/activity-stream-prerendered.html", "browser/extensions/activity-stream/prerendered/locales/zh-CN/activity-stream-strings.js", "browser/extensions/activity-stream/prerendered/locales/zh-TW/activity-stream-prerendered.html", "browser/extensions/activity-stream/prerendered/locales/zh-TW/activity-stream-strings.js", "browser/extensions/activity-stream/prerendered/static/activity-stream-initial-state.js", "browser/extensions/activity-stream/prerendered/static/activity-stream-prerendered-debug.html", "browser/extensions/activity-stream/test/schemas/pings.js", "browser/extensions/activity-stream/test/unit/common/Reducers.test.js", "browser/extensions/activity-stream/test/unit/lib/ActivityStreamStorage.test.js", "browser/extensions/activity-stream/test/unit/lib/HighlightsFeed.test.js", "browser/extensions/activity-stream/test/unit/lib/SectionsManager.test.js", "browser/extensions/activity-stream/test/unit/lib/SnippetsFeed.test.js", "browser/extensions/activity-stream/test/unit/lib/TelemetryFeed.test.js"], "git_node": null, "git_parents": [null], "node": "9e902a91c375c01c3a50c4b118c8f4859f70b8fb", "parents": ["5fb1b1d9d6699eacb2d749edc095d0f5b2d3fe4f"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442817 - Add another variant of nsDocument::FlushPendingNotifications which are able to skip to flushing throttled animations. r=birtles,emilio\n\nMozReview-Commit-ID: BZ9yAoAmWBB", "files": ["dom/base/nsDocument.cpp", "dom/base/nsIDocument.h"], "git_node": null, "git_parents": [null], "node": "d7bf0574ec4ad70543861dba2606b1893ea7ce82", "parents": ["9e902a91c375c01c3a50c4b118c8f4859f70b8fb"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442817 - Introduce a function to observe synchronous restyling easily. r=birtles\n\nIn the subsequent patch, we want to observe animation restyles caused by\nsynchronous styling.  If we used the original asynchronous observer for that,\nwe will observe restyles in normal scheduled styling, it's bit confusing.\n\nMozReview-Commit-ID: 1V2IavKNECG", "files": ["dom/animation/test/mozilla/file_restyles.html"], "git_node": null, "git_parents": [null], "node": "127daa70875beb690e2ad6f4ef280a9cca825f9c", "parents": ["d7bf0574ec4ad70543861dba2606b1893ea7ce82"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442817 - Don't flush throttled animations on getAnimations(). r=birtles\n\nIf the element has throttled animations that will be affected by pending style\nchanges, the throttled animations will be updated though sequential tasks after\nnormal styling process.  E.g. UpdateEffectProperties, UpdateCascadeResults etc.\nSo we don't need to flush them in advance of the sequential tasks.\n\nThe first test case in this patch fails without this fix.\n\nMozReview-Commit-ID: GystAqK2bQE", "files": ["dom/animation/CSSPseudoElement.cpp", "dom/animation/test/mozilla/file_restyles.html", "dom/base/Element.cpp"], "git_node": null, "git_parents": [null], "node": "32826732144d7c5c162c85ae1cd2c5edfe3e498b", "parents": ["127daa70875beb690e2ad6f4ef280a9cca825f9c"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1444230 - Add binding document size to memory report. r=njn\n\nMozReview-Commit-ID: AiY64LDoZmD", "files": ["dom/xbl/nsXBLDocumentInfo.cpp"], "git_node": null, "git_parents": [null], "node": "e9ac6e70f8c4e61aa8f12fb344db262a0ae0981a", "parents": ["32826732144d7c5c162c85ae1cd2c5edfe3e498b"], "tags": []}, {"author": "Paul Rouget \u003cme@paulrouget.com\u003e", "branch": "default", "desc": "servo: Merge #19895 - unfork glutin (from paulrouget:unfork); r=paulrouget\n\nI'm taking over #19120.\n\nFix #18918.\n\nBeside the change in the API, I had to rewrite main loop.\n\nAt this point, we should have a very similar behavior as servo-glutin.\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: c9f60c5a6778fe47cae85fcd88cb38257a220bb1", "files": ["servo/Cargo.lock", "servo/components/compositing/compositor.rs", "servo/components/constellation/constellation.rs", "servo/components/script_traits/lib.rs", "servo/ports/servo/Cargo.toml", "servo/ports/servo/glutin_app/mod.rs", "servo/ports/servo/glutin_app/window.rs", "servo/ports/servo/main.rs"], "git_node": null, "git_parents": [null], "node": "037b50a168a5f2864bea44c6e2e693e623533425", "parents": ["e9ac6e70f8c4e61aa8f12fb344db262a0ae0981a"], "tags": []}, {"author": "Sam Foster \u003csfoster@mozilla.com\u003e", "branch": "default", "desc": "Bug 1440499 - Add debug options for the payer details and shipping requested. r=MattN\n\nMozReview-Commit-ID: FnKn639SvzR", "files": ["toolkit/components/payments/res/debugging.css", "toolkit/components/payments/res/debugging.html", "toolkit/components/payments/res/debugging.js"], "git_node": null, "git_parents": [null], "node": "d1a65f74a21cd71630da13e71cc18e2a3c40e30c", "parents": ["037b50a168a5f2864bea44c6e2e693e623533425"], "tags": []}, {"author": "Sam Foster \u003csfoster@mozilla.com\u003e", "branch": "default", "desc": "Bug 1440499 - Implement the payerName/payerEmail/payerPhone contact picker. r=MattN\n\n* Based on original patch by MattN\n* Make stored contacts available as payer data (MattN)\n* Add the address-picker element to the dialog for selecting payer details from stored contacts (MattN)\n* Add a field-names attribute to the payer address-picker, populated from the request paymentOptions\n* Basic CSS to selectively render address fields\n* Add mochitests to verify paymentOptions result in the correct payment picker behavior\n\nMozReview-Commit-ID: Br8i5MVyeQ3", "files": ["toolkit/components/payments/content/paymentDialogWrapper.js", "toolkit/components/payments/res/components/address-option.css", "toolkit/components/payments/res/containers/address-picker.js", "toolkit/components/payments/res/containers/payment-dialog.js", "toolkit/components/payments/res/debugging.js", "toolkit/components/payments/res/mixins/PaymentStateSubscriberMixin.js", "toolkit/components/payments/res/paymentRequest.xhtml", "toolkit/components/payments/test/mochitest/mochitest.ini", "toolkit/components/payments/test/mochitest/payments_common.js", "toolkit/components/payments/test/mochitest/test_order_details.html", "toolkit/components/payments/test/mochitest/test_payer_address_picker.html"], "git_node": null, "git_parents": [null], "node": "f1965cf7425fe422c9e9c78018f11b97e0a0f229", "parents": ["d1a65f74a21cd71630da13e71cc18e2a3c40e30c"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1443788 - motionmark tests need to report the FPS not the average. r=rwood", "files": ["third_party/webkit/PerformanceTests/MotionMark/resources/debug-runner/animometer.js"], "git_node": null, "git_parents": [null], "node": "461bb0cfa848d8f951471c32ff03344076549785", "parents": ["3db841301bfd8d7638b92575e76ecc550a2101af"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1443983: Follow-up: Force initial about:blank browser to non-remote. r=me\n\nIt looks like something about the removal of interpositions causes the inital\nbrowser to sometimes load remotely, which breaks the assumptions of the test.\n\nMozReview-Commit-ID: 9rmPem1VplE", "files": ["browser/base/content/test/general/browser_e10s_chrome_process.js"], "git_node": null, "git_parents": [null], "node": "bce9970180dc86666599d1af464beab098976fa7", "parents": ["461bb0cfa848d8f951471c32ff03344076549785"], "tags": []}, {"author": "Csoregi Natalia \u003cncsoregi@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to inbound.  a=merge CLOSED TREE", "files": ["mobile/android/geckoview/BuildConfig.java.in"], "git_node": null, "git_parents": [null, null], "node": "16cdea986fe14af9eb4a5b04e5e0769ae1d5a759", "parents": ["bce9970180dc86666599d1af464beab098976fa7", "31a33fc619562e5b326585c6864d86832dac5126"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1443964: Follow-up: Fix missed CPOW usage in devtools tests. r=bustage\n\nMozReview-Commit-ID: 1Hv3VR5yIO5", "files": ["devtools/client/shadereditor/test/head.js"], "git_node": null, "git_parents": [null], "node": "2be3c0d8f1e9ab1fa1a88d2716204b2005c8d6d4", "parents": ["16cdea986fe14af9eb4a5b04e5e0769ae1d5a759"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1443964: Follow-up: Fix event shim usage in DAMP. r=aswan\n\nMozReview-Commit-ID: EfVZidtHSMk", "files": ["testing/talos/talos/tests/devtools/addon/content/damp.js"], "git_node": null, "git_parents": [null], "node": "7550436e4ca33155397982f80a889cf509d66976", "parents": ["