l, null, null, null, null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "8821": {"changesets": [{"author": "Ben Hearsum \u003cbhearsum@mozilla.com\u003e", "branch": "default", "desc": "Backfill some old devedition release tags to support new update verify config tasks. r=release, a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "9b028aef17cb86ef1ca4a291ed33c92634f7c190", "parents": ["0938d48917b73d31fa8bfa4a7c3ccd79a3f4b3f5"], "tags": []}], "date": 1520521612, "git_changesets": [null], "user": "bhearsum@mozilla.com"}, "8822": {"changesets": [{"author": "Kit Cambridge \u003ckit@yakshaving.ninja\u003e", "branch": "default", "desc": "Bug 1443309 - Report wrong sync statuses in the mirror consistency check. r=tcsc\n\nMozReview-Commit-ID: HYqj1n2kubp", "files": ["toolkit/components/places/SyncedBookmarksMirror.jsm", "toolkit/components/places/tests/sync/test_bookmark_haschanges.js", "toolkit/components/places/tests/sync/test_bookmark_validation.js", "toolkit/components/places/tests/sync/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "843396ded02512d311b62bd50d4587dbf75f2590", "parents": ["08802a2ae2b51f41d5bbd049f766bb05c994c5b2"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "Bug 1326028 - Allow moving a reference into nsInterfaceHashtable. r=smaug\n\nWithout this patch, it's impossible for clients to move a reference into an\nnsInterfaceHashtable. That causes at least one extra addref/release pair when\nthey otherwise could. With this patch, a client can do `hashTable.Put(key,\ncomptr.forget());` to avoid the additional refcounting.\n\nMozReview-Commit-ID: Ghm7n41ziZp", "files": ["xpcom/ds/nsInterfaceHashtable.h"], "git_node": null, "git_parents": [null], "node": "414efc66b026b328dc661aa5edd1c1df8c26ae5f", "parents": ["843396ded02512d311b62bd50d4587dbf75f2590"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "bug 1326028 - Upgrade elements in the right order. r=smaug\n\nMozReview-Commit-ID: 4u5PipUqN0j", "files": ["dom/base/CustomElementRegistry.cpp"], "git_node": null, "git_parents": [null], "node": "ab4ee52d5a81ffedf1b54bdac08da7b2a68b579a", "parents": ["414efc66b026b328dc661aa5edd1c1df8c26ae5f"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "Bug 1326028 - We now upgrade elements in the proper order. r=smaug\n\nMozReview-Commit-ID: Dt4sc8FYmT7", "files": ["testing/web-platform/meta/custom-elements/CustomElementRegistry.html.ini"], "git_node": null, "git_parents": [null], "node": "38057b774238abb7e044d430819c6b3dca6d2ff1", "parents": ["ab4ee52d5a81ffedf1b54bdac08da7b2a68b579a"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1443650 - Remove additional true/false enums so GPO works. r=Felipe\n\nMozReview-Commit-ID: Ee0vl9T2Mmb", "files": ["browser/components/enterprisepolicies/schemas/policies-schema.json"], "git_node": null, "git_parents": [null], "node": "72f71c50d961ec8b531b74553cb96ddf624c4873", "parents": ["38057b774238abb7e044d430819c6b3dca6d2ff1"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1443483: FlushTarget doesn't really make sense. r=xidorn\n\nSummary:\nFlushTarget wants to decide whether we should flush the parent document or all\nof them. However, the only point of flushing parent documents is that media\nquery changes could affect the document we really want to flush.\n\nThat's completely pointless if we actually don't flush the subdocument, so just\nskip doing that. This case is already checked (see the DocumentNeedsRestyle\nstuff, which is also somewhat poorly named, which walks up the document chain).\n\nReviewers: xidorn\n\nBug #: 1443483\n\nDifferential Revision: https://phabricator.services.mozilla.com/D682\n\nMozReview-Commit-ID: LiI7IrUBeqq\n", "files": ["dom/base/FlushType.h", "dom/base/nsDocument.cpp", "dom/base/nsDocument.h", "dom/base/nsIDocument.h", "layout/style/nsComputedDOMStyle.cpp", "layout/style/nsComputedDOMStyle.h"], "git_node": null, "git_parents": [null], "node": "610e3fc1811691ba5780738bb8444df5d17c0e2d", "parents": ["72f71c50d961ec8b531b74553cb96ddf624c4873"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "servo: Merge #20222 - Do not disable thread pool in the parent process (from upsuper:chrome-thread-pool); r=bholley\n\nThis is the Servo side change of [bug 1375913](https://bugzilla.mozilla.org/show_bug.cgi?id=1375913).\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 3b96fb2cbe8754b30646e8bd914806048c0b6db2", "files": ["servo/components/style/gecko/generated/bindings.rs", "servo/components/style/gecko/global_style_data.rs"], "git_node": null, "git_parents": [null], "node": "a50ae6e8b614d0c1c1cc0196b691f7732def60f4", "parents": ["610e3fc1811691ba5780738bb8444df5d17c0e2d"], "tags": []}, {"author": "Chris AtLee \u003ccatlee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1421734 - Download and unpack toolchain artifacts in parallel; r=nalexander\n\nMozReview-Commit-ID: BMe6zqIqNHP", "files": ["python/mozbuild/mozbuild/artifacts.py", "python/mozbuild/mozbuild/mach_commands.py"], "git_node": null, "git_parents": [null], "node": "5ceb1365ae756eabe0763de42cb64fd9dc3e79dc", "parents": ["a50ae6e8b614d0c1c1cc0196b691f7732def60f4"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1442521 - Make width/height attr on \u003cwindow\u003e mean the inner size in nsXULWindow. r=bz\n\nIt seems that the layout system assumes those attributes are for size of\nthe \u003cwindow\u003e element, i.e. inner window size, not outer window size.\n\nSee for example nsContainerFrame::SyncWindowProperties. It reads\n{min,max}{width,height} attributes from the element via\nnsIFrame::GetXUL{Min,Max}Size, and passes them into SetSizeConstraints.\nThe latter inflates the sizes with window decoration size before calling\ninto widget code. It can also be seen that various XUL size related\nmethods on nsBox and nsIFrame put the same assumption.\n\nThe test test_windowminmaxsize.xul apparently puts the same assumption\nas the layout system on the meaning of those properties.\n\n(Another test test_resize_move_windows.xul, which tests effectiveness of\nfeatures of window.open, also fails if we size the window earlier than\ncurrent in bug 1439875, and doesn't fail with this patch on top. It may\nindicate that it makes use of the same assumption, but I can't really\nfigure out how it does so.)\n\nMozReview-Commit-ID: IdMwDc59Ltg", "files": ["toolkit/content/tests/chrome/test_screenPersistence.xul", "xpfe/appshell/nsXULWindow.cpp"], "git_node": null, "git_parents": [null], "node": "7d40106bafebdd868ca7f6d188b5f0e30cb6f0e3", "parents": ["5ceb1365ae756eabe0763de42cb64fd9dc3e79dc"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1375913 - Do not disable thread pool in the parent process. r=bholley\n\nMozReview-Commit-ID: 2EMq1IdlEof", "files": ["layout/style/ServoBindings.cpp", "layout/style/ServoBindings.h"], "git_node": null, "git_parents": [null], "node": "3954a5975f119825b31d2f6a6379ea019211d2fa", "parents": ["7d40106bafebdd868ca7f6d188b5f0e30cb6f0e3"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1443483 followup - Fix lint warning about virtual function keywords.", "files": ["dom/base/nsDocument.h"], "git_node": null, "git_parents": [null], "node": "e180161959e4253959405c90f5cc1d7060a7d00c", "parents": ["3954a5975f119825b31d2f6a6379ea019211d2fa"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 5ceb1365ae75 (bug 1421734) for build Bustage on MinGW", "files": ["python/mozbuild/mozbuild/artifacts.py", "python/mozbuild/mozbuild/mach_commands.py"], "git_node": null, "git_parents": [null], "node": "ff525890cbffb52c173629e38beaedb79b827f0b", "parents": ["e180161959e4253959405c90f5cc1d7060a7d00c"], "tags": []}, {"author": "Andrew Swan \u003caswan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441271 Show permissions notifications for distribution addons r=kmag\n\nAs described in the bug, this is intended as a temporary solution to\nenable some experiments.  If this becomes a real feature, UX will\nput some thought into a better startup experience.\n\nMozReview-Commit-ID: 4DGMHj29M3e", "files": ["browser/modules/ExtensionsUI.jsm", "toolkit/mozapps/extensions/AddonManager.jsm", "toolkit/mozapps/extensions/internal/XPIProvider.jsm", "toolkit/mozapps/extensions/test/xpcshell/test_shutdown.js"], "git_node": null, "git_parents": [null], "node": "30d415ab237851e61a2bc9d939e7ba81144911d5", "parents": ["ff525890cbffb52c173629e38beaedb79b827f0b"], "tags": []}, {"author": "o0Ignition0o \u003cjeremy.lempereur@gmail.com\u003e", "branch": "default", "desc": "servo: Merge #19947 - Add a --nightly | -n flag to mach run commands for linux (from o0Ignition0o:mach_run_nightly); r=jdm\n\nFirst tries to download and extract a specific nightly version to run mach commands against.\n\n\u003c!-- Please describe your changes on the following line: --\u003e\nI chose to split the Pull requests for each platform to avoid submitting a huge one, and to make sure I get the logic right.\nI'm able to download / extract a nightly version, and I keep nightly versions in the target folder.\nWindows and Mac OS support will be filed in separate PRs.\nThis is part of step two for #19505\n\nThe mentor on the issue is jdm\n\n---\n\u003c!-- Thank you for contributing to Servo! Please replace each `[ ]` by `[X]` when the step is complete, and replace `__` with appropriate data: --\u003e\n- [X] `./mach build -d` does not report any errors\n- [X] `./mach test-tidy` does not report any errors\n- [ ] These changes fix #__ (github issue number if applicable).\n\n\u003c!-- Either: --\u003e\n- [ ] There are tests for these changes OR\n- [X] These changes do not require tests because it is part of a ./mach command.\n\n\u003c!-- Also, please make sure that \"Allow edits from maintainers\" checkbox is checked, so that we can help you if you get stuck somewhere along the way.--\u003e\n\n\u003c!-- Pull requests that do not address these steps are welcome, but they will require additional verification as part of the review process. --\u003e\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 9eb417528b79415a9f04f337b701187ca4ffbdfd", "files": ["servo/python/servo/command_base.py", "servo/python/servo/post_build_commands.py"], "git_node": null, "git_parents": [null], "node": "d93c5f3b88c5ae767e67370e336eb4b8b26b9d9a", "parents": ["30d415ab237851e61a2bc9d939e7ba81144911d5"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442398 - Convert the TabBrowser class to a plain object and make gBrowser available already before gBrowser.init returns. r=bgrins\n\nMozReview-Commit-ID: Cmq8IOaoxn5", "files": ["browser/base/content/browser.js", "browser/base/content/tabbrowser.js"], "git_node": null, "git_parents": [null], "node": "f27d7eca013d66027d9579a619899fdda5fa4dbc", "parents": ["d93c5f3b88c5ae767e67370e336eb4b8b26b9d9a"], "tags": []}, {"author": "Andreea Pavel \u003capavel@mozilla.com\u003e", "branch": "default", "desc": "Backed out 3 changesets (bug 1326028) for wpt bustage in custom-elements/CustomElementRegistry.html on a CLOSED TREE\n\nBacked out changeset 38057b774238 (bug 1326028)\nBacked out changeset ab4ee52d5a81 (bug 1326028)\nBacked out changeset 414efc66b026 (bug 1326028)", "files": ["dom/base/CustomElementRegistry.cpp", "testing/web-platform/meta/custom-elements/CustomElementRegistry.html.ini", "xpcom/ds/nsInterfaceHashtable.h"], "git_node": null, "git_parents": [null], "node": "5f8f9db9e66db97bd5250357ce33e7a507bdf613", "parents": ["f27d7eca013d66027d9579a619899fdda5fa4dbc"], "tags": []}, {"author": "Zibi Braniecki \u003czbraniecki@mozilla.com\u003e", "branch": "default", "desc": "Bug 1443697 - Fix nits in Fluent for Firefox Developers. r=flod\n\nMozReview-Commit-ID: 4QSBa01XXp3", "files": ["intl/l10n/docs/fluent_tutorial.rst"], "git_node": null, "git_parents": [null], "node": "8f02fba87e70a1213a32d35d0937e90e96477506", "parents": ["5f8f9db9e66db97bd5250357ce33e7a507bdf613"], "tags": []}, {"author": "Glenn Watson \u003cgithub@intuitionlibrary.com\u003e", "branch": "default", "desc": "servo: Merge #20226 - Update WR (nVidia/ANGLE workaround, vertex shader optimizations) (from glennw:update-wr-nv-clip); r=jdm\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 46ad9f2a30a766863632aa5d24df0e691b72275c", "files": ["servo/Cargo.lock"], "git_node": null, "git_parents": [null], "node": "4d6f6524467a30ea8c3115e8941635dd4a7f2168", "parents": ["8f02fba87e70a1213a32d35d0937e90e96477506"], "tags": []}, {"author": "Daniel Stenberg \u003cdaniel@haxx.se\u003e", "branch": "default", "desc": "bug 1443489 - TRR: require a pref set to allow early AAAA responses r=valentin\n\nEarly AAAA responses might cause issues on hosts without working native\nIPv6 connectivity, of course especially notable in TRR-only mode.\n\nMozReview-Commit-ID: 6ZqE6AKnucH", "files": ["modules/libpref/init/all.js", "netwerk/dns/TRRService.cpp", "netwerk/dns/TRRService.h", "netwerk/dns/nsHostResolver.cpp"], "git_node": null, "git_parents": [null], "node": "4fb871a704a27cb28d37aa38016830fc218d1547", "parents": ["4d6f6524467a30ea8c3115e8941635dd4a7f2168"], "tags": []}, {"author": "Patrick Brosset \u003cpbrosset@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441462 - Avoid crashing the gridOutline when there are no fragments; r=gl\n\nMozReview-Commit-ID: 6TpYB4f33JI", "files": ["devtools/client/inspector/grids/components/GridOutline.js", "devtools/client/inspector/grids/test/browser.ini", "devtools/client/inspector/grids/test/browser_grids_no_fragments.js"], "git_node": null, "git_parents": [null], "node": "8aaf118e2e16ddba53bac4c5649bb36269bf5f30", "parents": ["4fb871a704a27cb28d37aa38016830fc218d1547"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1024082: Remove nsFrameManagerBase. r=dholbert\n\nInstead move UndisplayedNode to its own file, which is what causes the include\nhell due to requiring nsIContent / nsStyleContext.\n\nMozReview-Commit-ID: 1opiajueZNb\n", "files": ["layout/base/GeckoRestyleManager.cpp", "layout/base/UndisplayedNode.h", "layout/base/moz.build", "layout/base/nsFrameManager.cpp", "layout/base/nsFrameManager.h", "layout/base/nsFrameManagerBase.h", "layout/base/nsIPresShell.h"], "git_node": null, "git_parents": [null], "node": "5936540dc37961cca6280a0552d80fb20835cad5", "parents": ["8aaf118e2e16ddba53bac4c5649bb36269bf5f30"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1024082: Remove most of the nsIPresShell::FrameManager calls. r=dholbert\n\nMost of them just want GetRootFrame(), and there's no need to explicitly go\nthrough the frame manager for that, we have a handy alias in the shell.\n\nMozReview-Commit-ID: GriEqkasidY\n", "files": ["dom/base/Selection.cpp", "dom/base/nsDOMWindowUtils.cpp", "dom/events/EventStateManager.cpp", "dom/ipc/TabChild.cpp", "dom/ipc/TabParent.cpp", "layout/base/PresShell.cpp", "layout/base/nsLayoutUtils.cpp", "layout/base/nsPresContext.cpp", "layout/generic/nsCanvasFrame.cpp", "layout/generic/nsFrame.cpp", "layout/generic/nsFrameSelection.cpp", "layout/generic/nsPluginFrame.cpp", "layout/painting/nsCSSRendering.cpp", "layout/printing/nsPrintJob.cpp", "layout/xul/nsMenuPopupFrame.cpp", "layout/xul/nsResizerFrame.cpp", "layout/xul/nsRootBoxFrame.cpp", "layout/xul/nsXULPopupManager.cpp"], "git_node": null, "git_parents": [null], "node": "a387ecebd587214959b79c39274f8b33dcafa3c1", "parents": ["5936540dc37961cca6280a0552d80fb20835cad5"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1024082: Remove PresShell::FrameManager(), use PresShell::FrameConstructor instead. r=dholbert\n\nUnfortunately this means that we need to export a couple more headers, but that\nshould be ok.\n\nIn particular, we have to export some headers that are #included by\nnsCSSFrameConstructor.h, because nsCSSFrameConstructor.h itself will now be\nincluded in more places outside of layout/, by .cpp files that don't necessarily\nhave the ability to indirectly #include its other headers, unless we export\nthem.\n\nMozReview-Commit-ID: 2n9KHW6Yjrd\n", "files": ["dom/base/Element.cpp", "dom/xbl/nsXBLResourceLoader.cpp", "layout/base/GeckoRestyleManager.cpp", "layout/base/RestyleTracker.cpp", "layout/base/moz.build", "layout/base/nsCSSFrameConstructor.cpp", "layout/base/nsIPresShell.h", "layout/base/nsLayoutUtils.cpp", "layout/base/nsPresContext.cpp", "layout/base/nsPresContext.h", "layout/base/nsStyleChangeList.cpp", "layout/generic/nsFrame.cpp", "layout/generic/nsFrameSelection.cpp", "layout/generic/nsPlaceholderFrame.cpp"], "git_node": null, "git_parents": [null], "node": "a0bb325da8310423ce326c784d90a3e239963e75", "parents": ["a387ecebd587214959b79c39274f8b33dcafa3c1"], "tags": []}, {"author": "Ken VanDine \u003cken.vandine@canonical.com\u003e", "branch": "default", "desc": "Bug 1443736 - Improved mechanism for handing opening files after downloading with snap r=jlorenzo\n\nMozReview-Commit-ID: 6WR2HBJRlBy", "files": ["taskcluster/docker/firefox-snap/mime-handler.xml", "taskcluster/docker/firefox-snap/mimeapps.list", "taskcluster/docker/firefox-snap/runme.sh"], "git_node": null, "git_parents": [null], "node": "391c1ae6bb0dc6d7d9e2f3d9af0d89b7bc97bcd4", "parents": ["a0bb325da8310423ce326c784d90a3e239963e75"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1438990 - Remove common clip count code from FrameLayerBuilder, as it's no longer necessary now that we have ASRs. r=mstange", "files": ["layout/painting/DisplayItemClip.cpp", "layout/painting/DisplayItemClip.h", "layout/painting/FrameLayerBuilder.cpp", "layout/painting/FrameLayerBuilder.h"], "git_node": null, "git_parents": [null], "node": "1c81ecf4726878d2636f9a9a5d4a3b80807f87f1", "parents": ["fae6107e46e89cd44e31219344fc1d971ed2ff5f"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1440966 - Store optimized Layer in DisplayItemData as part of AddPaintedLayerFor. r=jnicol", "files": ["layout/painting/FrameLayerBuilder.cpp", "layout/painting/FrameLayerBuilder.h"], "git_node": null, "git_parents": [null], "node": "b3cf1b5c14cc373f90fda4f109e35bef5f69f84f", "parents": ["1c81ecf4726878d2636f9a9a5d4a3b80807f87f1"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 440908 - Remove gIsAnyPrefLocked. r=glandium\n\nIt optimizes Preferences::IsLocked(), but that function is called fewer than\n200 times while starting the browser and opening a range of tabs.\n\nMozReview-Commit-ID: 5q0zS8TSwdu", "files": ["modules/libpref/Preferences.cpp"], "git_node": null, "git_parents": [null], "node": "edb57fbc6beac233b12486fa7d7381220339de0f", "parents": ["b3cf1b5c14cc373f90fda4f109e35bef5f69f84f"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 440908 - Add support for `sticky` and `locked` attributes to default prefs. r=glandium\n\nSticky prefs are already specifiable with `sticky_pref`, but this is a more\ngeneral attribute mechanism. The ability to specify a locked pref in the data\nfile is new.\n\nThe patch also adds nsIPrefService.readDefaultPrefsFromFile, to match the\nexisting nsIPrefService.readUserPrefsFromFile method, and converts a number of\nthe existing tests to use it.\n\nMozReview-Commit-ID: 9LLMBJVZfg7", "files": ["modules/libpref/Preferences.cpp", "modules/libpref/nsIPrefService.idl", "modules/libpref/parser/src/lib.rs", "modules/libpref/test/gtest/Parser.cpp", "modules/libpref/test/unit/data/testParser.js", "modules/libpref/test/unit/data/testPrefLocked.js", "modules/libpref/test/unit/data/testPrefLockedUser.js", "modules/libpref/test/unit/test_locked_file_prefs.js", "modules/libpref/test/unit/test_parser.js", "modules/libpref/test/unit/test_stickyprefs.js", "modules/libpref/test/unit/xpcshell.ini", "services/sync/tests/unit/test_prefs_store.js"], "git_node": null, "git_parents": [null], "node": "b82802657783b6188e320ba966183ae1eedabf62", "parents": ["edb57fbc6beac233b12486fa7d7381220339de0f"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 440908 - Convert sticky prefs in default pref files to the new syntax. r=glandium\n\nMozReview-Commit-ID: GgkNSsdGhBV", "files": ["browser/app/profile/firefox.js", "devtools/shim/devtools-startup-prefs.js", "modules/libpref/init/all.js", "modules/libpref/test/unit/data/testPrefSticky.js", "modules/libpref/test/unit/data/testPrefStickyUser.js", "modules/libpref/test/unit/test_stickyprefs.js"], "git_node": null, "git_parents": [null], "node": "d1d9ef8f7c0ecdc6b9d8fa33b8b2a9238e0ad64f", "parents": ["b82802657783b6188e320ba966183ae1eedabf62"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset b3cf1b5c14cc (bug 1440966) for build bustages on a CLOSED TREE", "files": ["layout/painting/FrameLayerBuilder.cpp", "layout/painting/FrameLayerBuilder.h"], "git_node": null, "git_parents": [null], "node": "545df7f2c6bcfdab972b22b95fa3fd92b1df07c8", "parents": ["d1d9ef8f7c0ecdc6b9d8fa33b8b2a9238e0ad64f"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 1c81ecf47268 (bug 1438990) for build bustages on a CLOSED TREE", "files": ["layout/painting/DisplayItemClip.cpp", "layout/painting/DisplayItemClip.h", "layout/painting/FrameLayerBuilder.cpp", "layout/painting/FrameLayerBuilder.h"], "git_node": null, "git_parents": [null], "node": "aa22c7964b317297f10ca8d58b64202d1c80b6b9", "parents": ["545df7f2c6bcfdab972b22b95fa3fd92b1df07c8"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1442931: Part 1 - Forbid web-visible interfaces outside of WebIDL root. r=mystor\n\nWeb-visible WebIDL interfaces require DOM peer review with every change, which\nis enforced by a commit hook. ChromeOnly interfaces are not exposed to the\nweb, and therefore don't require the same strictures.\n\nThe current commit hook enforces the review requirement for changes to any\n(non-Servo) WebIDL file, and is not smart enough to determine if the change is\nweb-visible. In order to loosen that restriction, we need the build system to\nenforce the requirement that only WebIDL files in certain locations may\ncontain web-visible interfaces, so that the commit hook can restrict itself to\nchecking only those directories.\n\nThis change restricts the location of web-visible WebIDL interfaces to the\ndom/webidl/ and dom/bindings/ roots (along with the corresponding objdir root\nfor generated interfaces). A follow-up will change the commit hook to only\nenforce review requirements on these directories.\n\nMozReview-Commit-ID: CiDxXxN4oO4", "files": ["dom/bindings/Configuration.py", "dom/bindings/mozwebidlcodegen/__init__.py"], "git_node": null, "git_parents": [null], "node": "6cb20ada1a0aa1f6d621ba3c85ce9946a6f9841f", "parents": ["aa22c7964b317297f10ca8d58b64202d1c80b6b9"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1442931: Part 2 - Move internal WebIDL interfaces to separate directory. r=mystor DONTBUILD\n\nThis change moves several chrome-only WebIDL files to a separate chrome-only\ndirectory.\n\nThere are several other chrome-only interfaces which are heavily tied to DOM\ncode. Since those should probably still require DOM peer review for changes, I\nleft them where they were.\n\nMozReview-Commit-ID: K3NsNtfntV6", "files": ["dom/chrome-webidl/ChannelWrapper.webidl", "dom/chrome-webidl/ChromeUtils.webidl", "dom/chrome-webidl/DominatorTree.webidl", "dom/chrome-webidl/HeapSnapshot.webidl", "dom/chrome-webidl/InspectorUtils.webidl", "dom/chrome-webidl/MatchGlob.webidl", "dom/chrome-webidl/MatchPattern.webidl", "dom/chrome-webidl/MozStorageAsyncStatementParams.webidl", "dom/chrome-webidl/MozStorageStatementParams.webidl", "dom/chrome-webidl/MozStorageStatementRow.webidl", "dom/chrome-webidl/PrecompiledScript.webidl", "dom/chrome-webidl/PromiseDebugging.webidl", "dom/chrome-webidl/StructuredCloneHolder.webidl", "dom/chrome-webidl/WebExtensionContentScript.webidl", "dom/chrome-webidl/WebExtensionPolicy.webidl", "dom/chrome-webidl/moz.build", "dom/moz.build", "dom/webidl/ChannelWrapper.webidl", "dom/webidl/ChromeUtils.webidl", "dom/webidl/DominatorTree.webidl", "dom/webidl/HeapSnapshot.webidl", "dom/webidl/InspectorUtils.webidl", "dom/webidl/MatchGlob.webidl", "dom/webidl/MatchPattern.webidl", "dom/webidl/MozStorageAsyncStatementParams.webidl", "dom/webidl/MozStorageStatementParams.webidl", "dom/webidl/MozStorageStatementRow.webidl", "dom/webidl/PrecompiledScript.webidl", "dom/webidl/PromiseDebugging.webidl", "dom/webidl/StructuredCloneHolder.webidl", "dom/webidl/WebExtensionContentScript.webidl", "dom/webidl/WebExtensionPolicy.webidl", "dom/webidl/moz.build"], "git_node": null, "git_parents": [null], "node": "195cbf3d34334978e5a9d101d4b79f899598159c", "parents": ["6cb20ada1a0aa1f6d621ba3c85ce9946a6f9841f"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442433 - Remove the refcount from static atoms. r=froydnj\n\nThe refcount is only used for dynamic atoms.\n\nOn 64-bit, this reduces sizeof(nsStaticAtom) from 24 bytes to 16 bytes, and the\non-heap size from 32 bytes to 16 bytes. This saves 42 KiB per process.\n\nOn 32-bit, this reduces sizeof(nsStaticAtom) from 16 bytes to 12 bytes, but the\non-heap size stays at 16 bytes, so memory usage is unchanged.\n\nMozReview-Commit-ID: 7d9H7MRHN9a", "files": ["xpcom/ds/nsAtom.h", "xpcom/ds/nsAtomTable.cpp"], "git_node": null, "git_parents": [null], "node": "7e4bac75138f31d2c66a9ef2a235b4303c573b0c", "parents": ["195cbf3d34334978e5a9d101d4b79f899598159c"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442433 - Make some nsAtom fields `const`. r=froydnj\n\nAlso remove the unused SetKind() method.\n\nMozReview-Commit-ID: CIh6BmN7OLI", "files": ["xpcom/ds/nsAtom.h"], "git_node": null, "git_parents": [null], "node": "786c4905fe76d92f6f45cdce39ea4eb1228791b9", "parents": ["7e4bac75138f31d2c66a9ef2a235b4303c573b0c"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442433 - Make nsAtom::mString more const. r=froydnj\n\nThe patch also uses GetStringBuffer() in a couple of appropriate places.\n\nMozReview-Commit-ID: JufCUgmO8JL", "files": ["xpcom/ds/nsAtom.h", "xpcom/ds/nsAtomTable.cpp"], "git_node": null, "git_parents": [null], "node": "06e62ae8e4cc238cd75c69fa55997d28562ccf76", "parents": ["786c4905fe76d92f6f45cdce39ea4eb1228791b9"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442433 - Make nsAtom::mString even more const. r=froydnj\n\n\nMozReview-Commit-ID: ANm2nrnO4Lb", "files": ["xpcom/ds/nsAtom.h"], "git_node": null, "git_parents": [null], "node": "ca86b5f0a30a71d0e57e829176bd1eb611d8c2a1", "parents": ["06e62ae8e4cc238cd75c69fa55997d28562ccf76"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1438955 - Remove ImmReleaseContext hook. r=masayuki", "files": ["dom/plugins/ipc/PluginInstanceChild.cpp", "dom/plugins/ipc/PluginInstanceChild.h", "toolkit/xre/test/win/TestDllInterceptor.cpp"], "git_node": null, "git_parents": [null], "node": "ae730768385d79888333172a1902b5eae763dbff", "parents": ["ca86b5f0a30a71d0e57e829176bd1eb611d8c2a1"], "tags": []}, {"author": "Jason Orendorff \u003cjorendorff@mozilla.com\u003e", "branch": "default", "desc": "Bug 1443147 - Fix PosixNSPR build after bug 1441454. r=sfink", "files": ["js/src/shell/js.cpp"], "git_node": null, "git_parents": [null], "node": "926f80f2c5ccaa5b0374b48678d62c304cbc9a68", "parents": ["ae730768385d79888333172a1902b5eae763dbff"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Backed out two changesets (bug 1442931) for Windows build bustage\n\nMozReview-Commit-ID: EAP1dIdvd8g", "files": ["dom/bindings/Configuration.py", "dom/bindings/mozwebidlcodegen/__init__.py", "dom/chrome-webidl/ChannelWrapper.webidl", "dom/chrome-webidl/ChromeUtils.webidl", "dom/chrome-webidl/DominatorTree.webidl", "dom/chrome-webidl/HeapSnapshot.webidl", "dom/chrome-webidl/InspectorUtils.webidl", "dom/chrome-webidl/MatchGlob.webidl", "dom/chrome-webidl/MatchPattern.webidl", "dom/chrome-webidl/MozStorageAsyncStatementParams.webidl", "dom/chrome-webidl/MozStorageStatementParams.webidl", "dom/chrome-webidl/MozStorageStatementRow.webidl", "dom/chrome-webidl/PrecompiledScript.webidl", "dom/chrome-webidl/PromiseDebugging.webidl", "dom/chrome-webidl/StructuredCloneHolder.webidl", "dom/chrome-webidl/WebExtensionContentScript.webidl", "dom/chrome-webidl/WebExtensionPolicy.webidl", "dom/chrome-webidl/moz.build", "dom/moz.build", "dom/webidl/ChannelWrapper.webidl", "dom/webidl/ChromeUtils.webidl", "dom/webidl/DominatorTree.webidl", "dom/webidl/HeapSnapshot.webidl", "dom/webidl/InspectorUtils.webidl", "dom/webidl/MatchGlob.webidl", "dom/webidl/MatchPattern.webidl", "dom/webidl/MozStorageAsyncStatementParams.webidl", "dom/webidl/MozStorageStatementParams.webidl", "dom/webidl/MozStorageStatementRow.webidl", "dom/webidl/PrecompiledScript.webidl", "dom/webidl/PromiseDebugging.webidl", "dom/webidl/StructuredCloneHolder.webidl", "dom/webidl/WebExtensionContentScript.webidl", "dom/webidl/WebExtensionPolicy.webidl", "dom/webidl/moz.build"], "git_node": null, "git_parents": [null], "node": "44b331a2a53d9d12106c1711814ab80a2cd8829e", "parents": ["926f80f2c5ccaa5b0374b48678d62c304cbc9a68"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1442931: Part 1 - Forbid web-visible interfaces outside of WebIDL root. r=mystor\n\nWeb-visible WebIDL interfaces require DOM peer review with every change, which\nis enforced by a commit hook. ChromeOnly interfaces are not exposed to the\nweb, and therefore don't require the same strictures.\n\nThe current commit hook enforces the review requirement for changes to any\n(non-Servo) WebIDL file, and is not smart enough to determine if the change is\nweb-visible. In order to loosen that restriction, we need the build system to\nenforce the requirement that only WebIDL files in certain locations may\ncontain web-visible interfaces, so that the commit hook can restrict itself to\nchecking only those directories.\n\nThis change restricts the location of web-visible WebIDL interfaces to the\ndom/webidl/ and dom/bindings/ roots (along with the corresponding objdir root\nfor generated interfaces). A follow-up will change the commit hook to only\nenforce review requirements on these directories.\n\nMozReview-Commit-ID: CiDxXxN4oO4", "files": ["dom/bindings/Configuration.py", "dom/bindings/mozwebidlcodegen/__init__.py", "dom/bindings/mozwebidlcodegen/test/test_mozwebidlcodegen.py"], "git_node": null, "git_parents": [null], "node": "608e21fcd1674dae3f8b685cedab85c43ffdb485", "parents": ["44b331a2a53d9d12106c1711814ab80a2cd8829e"], "tags": []}, {"author": "Kris Maglione \u