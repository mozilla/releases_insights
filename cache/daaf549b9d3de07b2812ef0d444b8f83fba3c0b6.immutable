nner.js", "toolkit/components/normandy/test/browser/browser_ShieldPreferences.js", "toolkit/components/normandy/test/browser/browser_Storage.js", "toolkit/components/normandy/test/browser/browser_about_preferences.js", "toolkit/components/normandy/test/browser/browser_about_studies.js", "toolkit/components/normandy/test/browser/fixtures/addon-fixture/manifest.json", "toolkit/components/normandy/test/browser/fixtures/normandy.xpi", "toolkit/components/normandy/test/browser/head.js", "toolkit/components/normandy/test/unit/.eslintrc.js", "toolkit/components/normandy/test/unit/echo_server.sjs", "toolkit/components/normandy/test/unit/head_xpc.js", "toolkit/components/normandy/test/unit/invalid_recipe_signature_api/api/v1/index.json", "toolkit/components/normandy/test/unit/invalid_recipe_signature_api/api/v1/recipe/signed/index.json", "toolkit/components/normandy/test/unit/invalid_recipe_signature_api/normandy.content-signature.mozilla.org-20210705.dev.chain", "toolkit/components/normandy/test/unit/mock_api/api/v1/action/console-log/implementation/sha384-RGx3rydrSq53UfmW9kFcK0mQYra67XIvZvr4MhmAe--ljiiMQOtgM7Cmca48um3v", "toolkit/components/normandy/test/unit/mock_api/api/v1/action/console-log/index.json", "toolkit/components/normandy/test/unit/mock_api/api/v1/action/index.json", "toolkit/components/normandy/test/unit/mock_api/api/v1/action/opt-out-study/implementation/sha384-HM_avYcD00o27ufwU1V7PIBtiuMAXML6MMwlYrDEqDX-XzGVuOfL52RCM680JExN", "toolkit/components/normandy/test/unit/mock_api/api/v1/action/opt-out-study/index.json", "toolkit/components/normandy/test/unit/mock_api/api/v1/action/preference-experiment/implementation/sha384-KQgG38GQ7KZAb2VIB48ANQO6nBcxZoLm2ORzUviRT5nAvSywyPjZ5cJIElw6iXIt", "toolkit/components/normandy/test/unit/mock_api/api/v1/action/preference-experiment/index.json", "toolkit/components/normandy/test/unit/mock_api/api/v1/action/show-heartbeat/implementation/sha384-dEGiyKPEln8Ns5cQHzGpMIGdirSAAX0X-Kwlu-U3sJ05yNbO-ANij_a6c5SyL7G4", "toolkit/components/normandy/test/unit/mock_api/api/v1/action/show-heartbeat/index.json", "toolkit/components/normandy/test/unit/mock_api/api/v1/action/signed/index.json", "toolkit/components/normandy/test/unit/mock_api/api/v1/classify_client/index.json", "toolkit/components/normandy/test/unit/mock_api/api/v1/index.json", "toolkit/components/normandy/test/unit/mock_api/api/v1/recipe/index.json", "toolkit/components/normandy/test/unit/mock_api/api/v1/recipe/signed/index.json", "toolkit/components/normandy/test/unit/mock_api/normandy.content-signature.mozilla.org-20210705.dev.chain", "toolkit/components/normandy/test/unit/query_server.sjs", "toolkit/components/normandy/test/unit/test_NormandyApi.js", "toolkit/components/normandy/test/unit/test_Sampling.js", "toolkit/components/normandy/test/unit/test_SandboxManager.js", "toolkit/components/normandy/test/unit/test_Utils.js", "toolkit/components/normandy/test/unit/utils.js", "toolkit/components/normandy/test/unit/xpcshell.ini", "toolkit/components/normandy/vendor/LICENSE_THIRDPARTY", "toolkit/components/normandy/vendor/PropTypes.js", "toolkit/components/normandy/vendor/React.js", "toolkit/components/normandy/vendor/ReactDOM.js", "toolkit/components/normandy/vendor/classnames.js", "toolkit/components/normandy/vendor/mozjexl.js"], "git_node": null, "git_parents": [null], "node": "e03272cbedc0d2a792929ceef049280751656cd1", "parents": ["aeb71b8d8ca3f4c619a15b78e02c8e977160d43d"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441816 - Move mTabProgressListener into its own class. r=jaws\n\nMozReview-Commit-ID: Fj5MtThJvld", "files": ["browser/base/content/tabbrowser.js"], "git_node": null, "git_parents": [null], "node": "c884294ea2dd8a11a28e5eb38bf95524f26f03c5", "parents": ["e03272cbedc0d2a792929ceef049280751656cd1"], "tags": []}, {"author": "Matthew Gaudet \u003cmgaudet@mozilla.com\u003e", "branch": "default", "desc": "Bug 1341261: [Part 1] Implement LoadValueTag in CacheIR r=tcampbell\n\nThis op allows extracting the type tag for future uses. This commit introduces\nValueTagOperandId, which can be used to provide type safety around tags.", "files": ["js/src/jit/CacheIR.h", "js/src/jit/CacheIRCompiler.cpp", "js/src/jit/CacheIRCompiler.h"], "git_node": null, "git_parents": [null], "node": "38f4d206e39e67ade4764f3bff55d45962e62e64", "parents": ["f558cf2238e47aa1b4f2b92e7bd2171fd5c48720"], "tags": []}, {"author": "Matthew Gaudet \u003cmgaudet@mozilla.com\u003e", "branch": "default", "desc": "Bug 1341261: [Part 2] Implement GuardTagNotEqual r=tcampbell\n\nDoes a tag compare on two types; fails for number tags", "files": ["js/src/jit/CacheIR.h", "js/src/jit/CacheIRCompiler.cpp", "js/src/jit/CacheIRCompiler.h"], "git_node": null, "git_parents": [null], "node": "74bdd1f7a2f17d86b5d6176c5718c2ac8cfe5f8d", "parents": ["38f4d206e39e67ade4764f3bff55d45962e62e64"], "tags": []}, {"author": "Matthew Gaudet \u003cmgaudet@mozilla.com\u003e", "branch": "default", "desc": "Bug 1341261: [Part 3] Inline cache for comparing strictly different types r=tcampbell", "files": ["js/src/jit-test/tests/cacheir/compare.js", "js/src/jit/CacheIR.cpp", "js/src/jit/CacheIR.h"], "git_node": null, "git_parents": [null], "node": "591a2c93a43e59ef7cf6d5fe86268a1e8315f1f1", "parents": ["74bdd1f7a2f17d86b5d6176c5718c2ac8cfe5f8d"], "tags": []}, {"author": "Andrew Swan \u003caswan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1402850 Don't include runtime permissions in prompts for webextension updates r=zombie\n\nMozReview-Commit-ID: 1cnNsWLVGmg", "files": ["toolkit/components/extensions/Extension.jsm", "toolkit/components/extensions/ext-permissions.js", "toolkit/components/extensions/test/xpcshell/test_ext_permissions.js", "toolkit/mozapps/extensions/internal/XPIInstall.jsm"], "git_node": null, "git_parents": [null], "node": "85b12303f147a81cbeadd0a37e8418752415e334", "parents": ["591a2c93a43e59ef7cf6d5fe86268a1e8315f1f1"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1441284 - Part 1 - Remove the \"current\" property. r=Gijs\n\nMozReview-Commit-ID: GyqI8N3JQ9O", "files": ["browser/base/content/test/performance/browser_appmenu_reflows.js", "browser/components/customizableui/PanelMultiView.jsm", "browser/components/places/tests/browser/browser_stayopenmenu.js", "browser/components/uitour/test/browser_UITour5.js"], "git_node": null, "git_parents": [null], "node": "1687a0f1db4c639c3760d7e3bbcc84140b9d3efc", "parents": ["85b12303f147a81cbeadd0a37e8418752415e334"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1441284 - Part 2 - Remove the \"_currentSubView\" property. r=Gijs\n\nMozReview-Commit-ID: Aua3V8hOT39", "files": ["browser/components/customizableui/PanelMultiView.jsm"], "git_node": null, "git_parents": [null], "node": "a81851454a368ff8b23b7df497b0d88699be050b", "parents": ["1687a0f1db4c639c3760d7e3bbcc84140b9d3efc"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1441284 - Part 3 - Remove the \"showingSubView\" property. r=Gijs\n\nThe value \"single\" for the \"closemenu\" attribute on panel buttons is unused, so the only consumer of the \"showingSubView\" property can be removed.\n\nMozReview-Commit-ID: 2jf5YE4Uyd", "files": ["browser/components/customizableui/CustomizableUI.jsm", "browser/components/customizableui/PanelMultiView.jsm"], "git_node": null, "git_parents": [null], "node": "00d855c4d71defeebf6050454ac0ea675527531b", "parents": ["a81851454a368ff8b23b7df497b0d88699be050b"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1441284 - Part 4 - Remove redundant calls before _moveOutKids and simplify the function. r=Gijs\n\nThe main view is already included in the children of the view stack, so the code that moves it out separately can be removed. The \"mainview\" attribute is already set to the correct value the next time the view is opened.\n\nMozReview-Commit-ID: B8LMAxWvvTb", "files": ["browser/components/customizableui/PanelMultiView.jsm"], "git_node": null, "git_parents": [null], "node": "63cfc3426678cc22dec17a2544f8035e2e9d95db", "parents": ["00d855c4d71defeebf6050454ac0ea675527531b"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1441284 - Part 5 - Remove the \"_panelViewCache\" property. r=Gijs\n\nMozReview-Commit-ID: IjTCdzr6gZ5", "files": ["browser/components/customizableui/PanelMultiView.jsm"], "git_node": null, "git_parents": [null], "node": "c4b46b5edc28678ca60daaeccedd3e566e811b70", "parents": ["63cfc3426678cc22dec17a2544f8035e2e9d95db"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1441284 - Part 6 - Do not move out subviews when the window is closing. r=Gijs\n\nSince we control the code path that invokes the PanelMultiView destructor, it is now possible to call the _moveOutKids function only as needed, avoiding some unnecessary DOM modifications when the browser window is closing.\n\nMozReview-Commit-ID: JTJQmhZKFOh", "files": ["browser/components/customizableui/PanelMultiView.jsm"], "git_node": null, "git_parents": [null], "node": "3e819acb990a3ec8c9c8448eae9278266118642f", "parents": ["c4b46b5edc28678ca60daaeccedd3e566e811b70"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1441284 - Part 7 - Remove the \"_ephemeral\" property. r=Gijs\n\nThe \"ephemeral\" attribute was not actually used anymore, because it is redundant with the \"viewCacheId\" attribute.\n\nMozReview-Commit-ID: 6zxf2DmcEfI", "files": ["browser/components/customizableui/PanelMultiView.jsm", "browser/components/customizableui/content/panelUI.js"], "git_node": null, "git_parents": [null], "node": "cd1250f642803879894ad3e39362a9548b248096", "parents": ["3e819acb990a3ec8c9c8448eae9278266118642f"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1441284 - Part 8 - Remove the \"_mainView\" and \"_mainViewId\" properties. r=Gijs\n\nThe null check for the \"node\" property can also be removed since the caller already checks it synchronously.\n\nMozReview-Commit-ID: 7FaCdtWTz20", "files": ["browser/components/customizableui/PanelMultiView.jsm"], "git_node": null, "git_parents": [null], "node": "d0ecce89ac1aaf60e826afa9be9a92fbdb29a194", "parents": ["cd1250f642803879894ad3e39362a9548b248096"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1428839 - Part 1 - Remove previous workaround for flickering at the end of the transition. r=Gijs\n\nThis was originally introduced in bug 1374749 but isn't needed anymore, and removing this allows making the _cleanupTransitionPhase method synchronous.\n\nMozReview-Commit-ID: 6v78QoPXZoU", "files": ["browser/components/customizableui/PanelMultiView.jsm"], "git_node": null, "git_parents": [null], "node": "f579f320031ce52c558112299431b758df5706fa", "parents": ["d0ecce89ac1aaf60e826afa9be9a92fbdb29a194"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1428839 - Part 2 - Add a function to determine if a view is still open. r=Gijs\n\nThis makes the intent of the code clearer and hides the details of how the association is made.\n\nMozReview-Commit-ID: C2L0vsjhxNO", "files": ["browser/components/customizableui/PanelMultiView.jsm"], "git_node": null, "git_parents": [null], "node": "0605579057e6b57aac46deecae3ead4084575427", "parents": ["f579f320031ce52c558112299431b758df5706fa"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1428839 - Part 3 - Clean up view properties when opening them. r=Gijs\n\nThis allows the state to be handled correctly when views are moved to a different panel.\n\nThe \"margin-inline-start\" style property on the view stack is also reset unconditionally, allowing less state to be stored in the transition details object.\n\nMozReview-Commit-ID: IpgnYsVvx0w", "files": ["browser/components/customizableui/PanelMultiView.jsm"], "git_node": null, "git_parents": [null], "node": "288b230b356c58e0a4980e1f4cd3642d3fa2d872", "parents": ["0605579057e6b57aac46deecae3ead4084575427"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1428839 - Part 4 - Avoid re-entrancy in PanelMultiView navigation functions. r=Gijs\n\nWe now use the \"active\" property of views to track whether navigation is possible. This has the advantage of being already handled correctly when views are moved to a different panel, and is in line with the purpose of the \"active\" state. The note about using the \"popupshown\" event for navigation has been updated accordingly.\n\nKeyboard navigation is also linked to the \"active\" property now, so there is no need to track the state of the \"_transitioning\" property anymore.\n\nSince the goBack and showSubView methods can only be called when the view is active, we don't need to check for attempts to start a transition while the panel is closed anymore.\n\nMozReview-Commit-ID: 3KT3A5EwGFy", "files": ["browser/components/customizableui/PanelMultiView.jsm", "browser/components/customizableui/test/browser_PanelMultiView.js"], "git_node": null, "git_parents": [null], "node": "96dd6c0d53b9be1532119e23876d21e9d51b9078", "parents": ["288b230b356c58e0a4980e1f4cd3642d3fa2d872"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1428839 - Part 5 - Open the anchor when subview navigation starts and close it asynchronously afterwards. r=Gijs\n\nThe anchor state does not need to be cleaned up synchronously, so we can handle it seperately from the transition state.\n\nMozReview-Commit-ID: 1CBP9OS5WmM", "files": ["browser/components/customizableui/PanelMultiView.jsm"], "git_node": null, "git_parents": [null], "node": "1c4d69669156774e5e06b48a19cbe7f20b66cae2", "parents": ["96dd6c0d53b9be1532119e23876d21e9d51b9078"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1428839 - Part 6 - Remove previous workaround for the panel resizing at the end of the transition. r=Gijs\n\nThis was added in bug 1354141 and is not needed anymore.\n\nMozReview-Commit-ID: 42oF7LpCa6R", "files": ["browser/components/customizableui/PanelMultiView.jsm"], "git_node": null, "git_parents": [null], "node": "9ca146d063f1a5f39cd30fc3d8b0ff25a0cb1d45", "parents": ["1c4d69669156774e5e06b48a19cbe7f20b66cae2"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1428839 - Part 7 - Reduce calls to _cleanupTransitionPhase. r=Gijs\n\nThe transition code now returns early if the panel was closed during an \"await\" statement.\n\nGiven that transitions can only be interrupted when closing the panel, and the _cleanupTransitionPhase method handles exclusively state related to the panel rather than the individual views, it is now possible to call the _cleanupTransitionPhase method only when the panel is hidden or at the end of a transition.\n\nMozReview-Commit-ID: GYRKyyhJBPK", "files": ["browser/components/customizableui/PanelMultiView.jsm"], "git_node": null, "git_parents": [null], "node": "39605c4715d10ef1c0eece86c6a7663d34ad719b", "parents": ["9ca146d063f1a5f39cd30fc3d8b0ff25a0cb1d45"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1428839 - Part 8 - Fix the sliding transition when views are reordered. r=Gijs\n\nViews moved to a different panel and then moved back could be placed after the subviews they give access to, if the other subviews were not moved. The transition would be incorrect when these subviews are opened later.\n\nMozReview-Commit-ID: 6JJa0p0McxL", "files": ["browser/components/customizableui/PanelMultiView.jsm"], "git_node": null, "git_parents": [null], "node": "724aad27fd444a8b1a01eb96284079aae7cfbd25", "parents": ["39605c4715d10ef1c0eece86c6a7663d34ad719b"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1436845: Part 1 - Add BasicDllServices; r=jimm\n\nBasicDllServices is a simplified implementation that allows programs other than\nFirefox to link against mozglue and access DLL services without requiring any\nXPCOM baggage.", "files": ["mozglue/build/WindowsDllServices.h"], "git_node": null, "git_parents": [null], "node": "ff7e21c630eb634a2d59910d8f9b95388fc35c0d", "parents": ["724aad27fd444a8b1a01eb96284079aae7cfbd25"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1436845: Part 2 - Link minidump-analyzer with mozglue on Windows; r=ted\n\nI have already implemented code to check binary signatures in mozglue so that\nwe can do so from both firefox.exe and xul.dll.\n\nRather than including yet another implementation elsewhere, I'd rather just\nreuse that code by building minidump-analyzer as a GeckoProgram with Null\nXPCOM linkage, thus making it capable of using the mozglue implementation too.\n\nI'd also like to add this signature stuff to Mac builds at some point, so I'm\ntrying to make this functionality as easy as possible to expand and reuse in the\nfuture.", "files": ["toolkit/crashreporter/minidump-analyzer/moz.build"], "git_node": null, "git_parents": [null], "node": "a9c97aa6d78903db203f80a1d6d78b1547f15297", "parents": ["ff7e21c630eb634a2d59910d8f9b95388fc35c0d"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1436845: Part 3 - Add support for ModuleSignatureInfo field in .extra file on Windows builds; r=ted\n\nWe want to send information about the organization whose cert was used to sign\nmodules in our address space. Originally I had written this code to accumulate\nthat info within Firefox, but I realized that a better option is to do this\nfrom the minidump analyzer:\n\n(1) This way does not affect browser performance;\n(2) This way allows us to properly gather cert info even from startup crashes.\n\nThis functionality was reviewed for data collection via bug 1430857.", "files": ["toolkit/crashreporter/minidump-analyzer/minidump-analyzer.cpp"], "git_node": null, "git_parents": [null], "node": "341f20ef2627e0b19a324de14f9b32ed743bda92", "parents": ["a9c97aa6d78903db203f80a1d6d78b1547f15297"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1440465 - initialize more things in AutoPointerEventTargetUpdater; r=dholbert", "files": ["layout/base/PresShell.cpp"], "git_node": null, "git_parents": [null], "node": "cdb1de7522a998937acd695942aaa63f158357f4", "parents": ["341f20ef2627e0b19a324de14f9b32ed743bda92"], "tags": []}, {"author": "Eugen Sawin \u003cesawin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1440592 - [1.0] Use correct where constant for new window. r=smaug\n", "files": ["docshell/base/nsDocShell.cpp"], "git_node": null, "git_parents": [null], "node": "dcadcf486b78e82cb0cbf716be72805a489fc9a4", "parents": ["cdb1de7522a998937acd695942aaa63f158357f4"], "tags": []}, {"author": "Eugen Sawin \u003cesawin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1439615 - [1.0] Move nsILoadURIDelegate handling to content module. r=jchen\n", "files": ["mobile/android/chrome/geckoview/GeckoViewNavigationContent.js", "mobile/android/chrome/geckoview/jar.mn", "mobile/android/modules/geckoview/GeckoViewNavigation.jsm"], "git_node": null, "git_parents": [null], "node": "120334ac0e535522a7544773b06345ca94b0c64b", "parents": ["dcadcf486b78e82cb0cbf716be72805a489fc9a4"], "tags": []}, {"author": "Eugen Sawin \u003cesawin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441964 - [1.0] Return URI-load delegation success state instead of throwing. r=snorp\n", "files": ["docshell/base/nsDocShell.cpp", "mobile/android/chrome/geckoview/GeckoViewNavigationContent.js", "xpcom/base/nsILoadURIDelegate.idl"], "git_node": null, "git_parents": [null], "node": "f248db9bdb5c5fae6bc7f1fcede2eff6dc4808e8", "parents": ["120334ac0e535522a7544773b06345ca94b0c64b"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1420939 - Add an asynchronous version of the description height workaround. r=Gijs\n\nThis prevents synchronous reflows when opening subviews. This also removes a superfluous invocation of the workaround while the panel is still hidden.\n\nMozReview-Commit-ID: DohLjntVaPU", "files": ["browser/base/content/test/performance/browser_appmenu_reflows.js", "browser/components/customizableui/PanelMultiView.jsm"], "git_node": null, "git_parents": [null], "node": "2b0380882e88956b620e68c414663b02d08cb9d5", "parents": ["f248db9bdb5c5fae6bc7f1fcede2eff6dc4808e8"], "tags": []}, {"author": "Eric Rahm \u003cerahm@mozilla.com\u003e", "branch": "default", "desc": "Bug 1432323 - Refactor operator new in nsArrayEnumerator. r=froydnj", "files": ["xpcom/ds/nsArrayEnumerator.cpp"], "git_node": null, "git_parents": [null], "node": "209ecda9242cd997e7ddb14ee9203ecc46068f38", "parents": ["2b0380882e88956b620e68c414663b02d08cb9d5"], "tags": []}, {"author": "Philipp Kewisch \u003cmozilla@kewis.ch\u003e", "branch": "default", "desc": "Bug 1441791 - Use MOZILLA_DIR when including from mozilla topsrcdir. r=ted\n\nMozReview-Commit-ID: 47Euw1vkVw6", "files": ["config/config.mk"], "git_node": null, "git_parents": [null], "node": "c68b03e4324f349bd4c2ee1bd6c3cdd0910ad1f6", "parents": ["209ecda9242cd997e7ddb14ee9203ecc46068f38"], "tags": []}, {"author": "Andrew Swan \u003caswan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1402850 follow-up Remove old unused bit from permission test.  r=me CLOSED TREE\n\nMozReview-Commit-ID: 117NO5Ao1Mh", "files": ["toolkit/mozapps/extensions/test/xpcshell/test_webextension_install.js"], "git_node": null, "git_parents": [null], "node": "839b847c943e0908bf75da5915f37ddfe253037f", "parents": ["c68b03e4324f349bd4c2ee1bd6c3cdd0910ad1f6"], "tags": []}, {"author": "Justin Wood \u003cCallek@gmail.com\u003e", "branch": "default", "desc": "Bug 1439876 - Add scriptworker version bumping. r=aki", "files": ["taskcluster/ci/release-version-bump/kind.yml", "taskcluster/taskgraph/transforms/release_version_bump.py", "taskcluster/taskgraph/transforms/task.py", "taskcluster/taskgraph/util/workertypes.py"], "git_node": null, "git_parents": [null], "node": "3ae945fb4a84f7388b5e81f1bf67c1cd64519105", "parents": ["839b847c943e0908bf75da5915f37ddfe253037f"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441198 - Part 1 - Use correct copy for cookies and site data in about:preferences. r=nhnt11\n\nThis mostly changes \"cookies\" to \"cookies and site data\" and amends a few\nother details.\n\nMozReview-Commit-ID: 97xTSQPw2DA", "files": ["browser/components/preferences/in-content/privacy.js", "browser/components/preferences/in-content/privacy.xul", "browser/components/preferences/in-content/tests/browser_search_subdialogs_within_preferences_7.js", "browser/components/preferences/in-content/tests/browser_siteData.js", "browser/components/preferences/siteDataSettings.js", "browser/locales/en-US/chrome/browser/preferences/preferences.properties", "browser/locales/en-US/chrome/browser/preferences/privacy.dtd"], "git_node": null, "git_parents": [null], "node": "17ec5ecc5057aa69378e260aff120b0317efd0af", "parents": ["3ae945fb4a84f7388b5e81f1bf67c1cd64519105"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441198 - Part 2 - Fix side spacing and line breaking of items adjacent to the site data description in about:preferences. r=nhnt11\n\nWhen adding more characters to the description in the site data section,\nthe display of the adjacent items breaks in two ways:\n\n- The \"Learn More\" link is pushed to the next line while it should stay\n  on the same line as the description. I didn't really find a way to fix\n  this while using a XUL label, so I switched to an html:span which has\n  the correct layout. I don't see any drawbacks with using a span here.\n\n- The description text could in certain edge cases get too close to the\n  \"Clear Data\" button. To fix that I added a new class which adds some padding.\n  This isn't a problem in other parts of preferences except the history\n  section (bug 1441138), where I also added this class.\n\nMozReview-Commit-ID: FO5tEx19ZUm", "files": ["browser/components/preferences/in-content/privacy.xul", "browser/themes/shared/incontentprefs/preferences.inc.css"], "git_node": null, "git_parents": [null], "node": "86dbf9b038d475000cf7fa62edba8714a60c43b9", "parents": ["17ec5ecc5057aa69378e260aff120b0317efd0af"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441198 - Part 3 - Add some space above the cookies preferences. r=nhnt11\n\nMozReview-Commit-ID: 4d0aYIgZZ32", "files": ["browser/themes/shared/incontentprefs/preferences.inc.css"], "git_node": null, "git_parents": [null], "node": "a8f35224e73f485c6c9367a741cbc56faca065c4", "parents": ["86dbf9b038d475000cf7fa62edba8714a60c43b9"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441766 - Fix search keywords for site data and cookies in about:preferences. r=nhnt11\n\nWhen moving cookies to the site data section we forgot about some\nsearchkeywords which were left on the cookies exceptions dialog.\n\nWe also forgot to remove the status column label when removing the\nstatus column.\n\nFurther, the search tooltip is not displayed correctly on the three\nvertically aligned dialog buttons (it's always on the last button),\nbecause we did not put each of them in its own hbox (which is just way\ntoo easy to get wrong and needs a better mid term solution).\n\nMozReview-Commit-ID: L6ZaocWsjYU", "files": ["browser/components/preferences/in-content/preferences.xul", "browser/components/preferences/in-content/privacy.xul", "browser/locales/en-US/chrome/browser/preferences/siteDataSettings.dtd"], "git_node": null, "git_parents": [null], "node": "161a8e168596d92afa8c7f0c3bc46e185e2ee540", "parents": ["a8f35224e73f485c6c9367a741cbc56faca065c4"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441766 - Add a test for searching in the site data group. r=nhnt11\n\nMozReview-Commit-ID: I0TrEXIaBzY", "files": ["browser/components/preferences/in-content/tests/browser.ini", "browser/components/preferences/in-content/tests/browser_search_subdialogs_within_preferences_site_data.js"], "git_node": null, "git_parents": [null], "node": "13702241dca9ebf766973e607d1f3dee600de69b", "parents": ["161a8e168596d92afa8c7f0c3bc46e185e2ee540"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Backed out 2 changesets (bug 1402850) for mochitest browser chrome failures at browser_ext_devtools_inspectedWindow.js on a CLOSED TREE\n\nBacked out changeset 839b847c943e (bug 1402850)\nBacked out changeset 85b12303f147 (bug 1402850)", "files": ["toolkit/components/extensions/Extension.jsm", "toolkit/components/extensions/ext-permissions.js", "toolkit/components/extensions/test/xpcshell/test_ext_permissions.js", "toolkit/mozapps/extensions/internal/XPIInstall.jsm", "toolkit/mozapps/extensions/test/xpcshell/test_webextension_install.js"], "git_node": null, "git_parents": [null], "node": "a464d558ea8baa3daaba576c8bbed70d69c5af8f", "parents": ["13702241dca9ebf766973e607d1f3dee600de69b"], "tags": []}, {"author": "Dylan Roeh \u003cdroeh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1435500 - Close the existing GeckoSession if it exists during GeckoApp.onCreate()  r=jchen", "files": ["mobile/android/base/java/org/mozilla/gecko/GeckoApp.java"], "git_node": null, "git_parents": [null], "node": "e9f4d34d9451fffa07a106c22850c3d6b91e632c", "parents": ["a464d558ea8baa3daaba576c8bbed70d69c5af8f"], "tags": []}, {"author": "Dylan Roeh \u003cdroeh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1432487 - Rename all *Listeners to *Delegates and corresponding minor changes. r=snorp,jchen", "files": ["mobile/android/base/java/org/mozilla/gecko/BrowserApp.java", "mobile/android/base/java/org/mozilla/gecko/GeckoApp.java", "mobile/android/base/java/org/mozilla/gecko/customtabs/ActionBarPresenter.java", "mobile/android/base/java/org/mozilla/gecko/customtabs/CustomTabsActivity.java", "mobile/android/base/java/org/mozilla/gecko/customtabs/CustomTabsSecurityPopup.java", "mobile/android/base/java/org/mozilla/gecko/webapps/WebAppActivity.java", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/BaseGeckoViewTest.java", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/GeckoSessionTestRuleTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/NavigationListenerTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/NavigationTests.java", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/ProgressListenerTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/TestRunnerActivity.java", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/rule/GeckoSessionTestRule.java", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/util/Callbacks.kt", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSession.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSessionHandler.java", "mobile/android/geckoview_example/src/main/java/org/mozilla/geckoview_example/BasicGeckoViewPrompt.java", "mobile/android/geckoview_example/src/main/java/org/mozilla/geckoview_example/GeckoViewActivity.java"], "git_node": null, "git_parents": [null], "node": "2b86e947b043483e84d79c59772b7856609f5818", "parents": ["e9f4d34d9451fffa07a106c22850c3d6b91e632c"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to inbound. a=merge on a CLOSED TREE", "files": ["browser/themes/linux/places/starred48.png", "browser/themes/osx/places/starred48.png", "browser/themes/osx/places/starred48@2x.png", "browser/themes/windows/places/starred48.png"], "git_node": null, "git_parents": [null, null], "node": "3fa481af8f5b761082671b482079f0a6c6929d51", "parents": ["2b86e947b043483e84d79c59772b7856609f5818", "17e47288c2249ac21bd2d0585b19c835984ed32b"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441430 - Provide more detail about atoms memory usage. r=froydnj\n\nThe old output had a single value: \"atoms-table\". The new output looks like\nthis:\n\n\u003e 649,904 B (00.39%) -- atoms\n\u003e \u251c\u2500\u2500350,256 B (00.21%) -- dynamic\n\u003e \u2502  \u251c\u2500\u2500235,056 B (00.14%) \u2500\u2500 unshared-buffers\n\u003e \u2502  \u2514\u2500\u2500115,200 B (00.07%) \u2500\u2500 atom-objects\n\u003e \u251c\u2500\u2500212,992 B (00.13%) \u2500\u2500 table\n\u003e \u2514\u2500\u2500\u250086,656 B (00.05%) \u2500\u2500 static/atom-objects\n\nMozReview-Commit-ID: 924vUmxHAlh", "files": ["toolkit/components/aboutmemory/tests/test_memoryReporters.xul", "xpcom/base/nsMemoryReporterManager.cpp", "xpcom/ds/nsAtom.h", "xpcom/ds/nsAtomTable.cpp", "xpcom/ds/nsAtomTable.h"], "git_node": null, "git_parents": [null], "node": "2e2934676a8b1132723db6be553646d568b1dffc", "parents": ["3fa481af8f5b761082671b482079f0a6c6929d51"], "tags": []}, {"author":