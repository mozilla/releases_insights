_node": null, "git_parents": [null], "node": "d55b703721d234cc5730d3e12e735a03252baade", "parents": ["4bc59f0d944b45b4a6998e6d3e5dfd5627f15a81"], "tags": []}, {"author": "Geoff Lankow \u003cgeoff@darktrojan.net\u003e", "branch": "default", "desc": "Bug 1442851 - Use comm-central revision in routes; r=dustin,tomprince\n\nMozReview-Commit-ID: 4XV3SGQVT54", "files": ["taskcluster/taskgraph/transforms/task.py"], "git_node": null, "git_parents": [null], "node": "cc4a9008f2cea359c6ce76e94ac4f2365c3fd0bd", "parents": ["d55b703721d234cc5730d3e12e735a03252baade"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1443714 - Remove already_AddRefed for GetDocument and GetPresSehll on EditorBase. r=masayuki\n\nIt is unnecessary to use already_AddRefed for GetDocument and GetPresShell.\nThen, if we remove already_AddRefed, we can replace this with const method.\n\nMozReview-Commit-ID: KTVS0rYrY2i", "files": ["editor/libeditor/EditorBase.cpp", "editor/libeditor/EditorBase.h", "editor/libeditor/EditorEventListener.cpp", "editor/libeditor/EditorEventListener.h", "extensions/spellcheck/src/mozInlineSpellChecker.cpp", "extensions/spellcheck/src/mozInlineSpellChecker.h"], "git_node": null, "git_parents": [null], "node": "8b181d76f72968e9ae79094ff205eea819cb526a", "parents": ["cc4a9008f2cea359c6ce76e94ac4f2365c3fd0bd"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1440719 - Set MOZ_CRASHREPORTER_SHUTDOWN during tests, other than browser-chrome; r=ted", "files": ["build/mobile/remoteautomation.py", "testing/mochitest/runtests.py", "testing/mozbase/mozrunner/mozrunner/utils.py"], "git_node": null, "git_parents": [null], "node": "1383d36fdabf8b134973bc15b69587d2e74e9d8a", "parents": ["97d8b867071938df9e8e2126d986ea348f55c649"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1443613 - don't allocate temporary strings for DNSRequestChild; r=mayhemer\n\nDNSRequestChild's constructor takes `const nsCString&` parameters.  If\nyou have a `const nsACString&` argument to pass in to the constructor,\nyou're forced to construct a temporary nsCString object to satisfy the\nprototype.  But the temporary string will just get copied inside the\nconstructor and you'll have to destroy the temporary string object you\ncreated.\n\nLet's skip all this, and just have DNSRequestChild take `const\nnsACString&` arguments instead, and avoid the temporary object.", "files": ["netwerk/dns/ChildDNSService.cpp", "netwerk/dns/DNSRequestChild.cpp", "netwerk/dns/DNSRequestChild.h", "toolkit/components/telemetry/TelemetryEvent.cpp"], "git_node": null, "git_parents": [null], "node": "b87c9f3e9d5d314b553cd411a1554fa7cd11528f", "parents": ["1383d36fdabf8b134973bc15b69587d2e74e9d8a"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1424505: Ensure at least one consistent reference to the COM MTA at all times on Windows 7; r=jimm", "files": ["toolkit/xre/nsAppRunner.cpp"], "git_node": null, "git_parents": [null], "node": "35129c889938eeefd8ccc81cf78a223e045e7f00", "parents": ["b87c9f3e9d5d314b553cd411a1554fa7cd11528f"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1443812 - Update HarfBuzz to 1.7.6. r=jfkthame", "files": ["gfx/harfbuzz/NEWS", "gfx/harfbuzz/README-mozilla", "gfx/harfbuzz/TODO", "gfx/harfbuzz/autogen.sh", "gfx/harfbuzz/configure.ac", "gfx/harfbuzz/src/Makefile.am", "gfx/harfbuzz/src/Makefile.sources", "gfx/harfbuzz/src/check-defs.sh", "gfx/harfbuzz/src/check-libstdc++.sh", "gfx/harfbuzz/src/check-symbols.sh", "gfx/harfbuzz/src/dev-run.sh", "gfx/harfbuzz/src/dump-indic-data.cc", "gfx/harfbuzz/src/dump-khmer-data.cc", "gfx/harfbuzz/src/dump-myanmar-data.cc", "gfx/harfbuzz/src/dump-use-data.cc", "gfx/harfbuzz/src/gen-def.py", "gfx/harfbuzz/src/gen-unicode-ranges.py", "gfx/harfbuzz/sr