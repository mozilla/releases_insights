 of getPropertyCSSValue. rs=johannh\n\ngetPropertyCSSValue(\"foo\").cssText is the same as getPropertyValue(\"foo\").\n\nMozReview-Commit-ID: HxdSr4749hi\n", "files": ["devtools/client/shared/inplace-editor.js", "devtools/client/shared/test/browser_inplace-editor_maxwidth.js", "devtools/client/webconsole/utils.js", "toolkit/content/tests/chrome/test_autocomplete2.xul"], "git_node": null, "git_parents": [null], "node": "d15070cd21f43663e2a432839b76b316db79cbeb", "parents": ["ddc55ed650c48666ee45feeb369ac1286ceeb4a3"], "tags": []}, {"author": "Jan Odvarko \u003codvarko@gmail.com\u003e", "branch": "default", "desc": "Bug 1434855 - Refactor HAR builder options; r=ochameau\n\nMozReview-Commit-ID: FRcxp4XPFdf", "files": ["devtools/client/netmonitor/initializer.js", "devtools/client/netmonitor/src/har/har-exporter.js", "devtools/client/netmonitor/src/widgets/RequestListContextMenu.js"], "git_node": null, "git_parents": [null], "node": "73628e4869b31f1d06ebda2c8ea46ae038705bb9", "parents": ["d15070cd21f43663e2a432839b76b316db79cbeb"], "tags": []}, {"author": "Jan Odvarko \u003codvarko@gmail.com\u003e", "branch": "default", "desc": "Bug 1434855 - Improve performance of HAR export; r=ochameau\n\nMozReview-Commit-ID: 6H6P6wYmdQL", "files": ["browser/components/extensions/test/browser/browser_ext_devtools_network.js", "devtools/client/netmonitor/src/connector/chrome-connector.js", "devtools/client/netmonitor/src/connector/firefox-connector.js", "devtools/client/netmonitor/src/connector/firefox-data-provider.js", "devtools/client/netmonitor/src/connector/index.js", "devtools/client/netmonitor/src/har/har-exporter.js"], "git_node": null, "git_parents": [null], "node": "470c96bdde515239728d90e12c7bae067884f909", "parents": ["73628e4869b31f1d06ebda2c8ea46ae038705bb9"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1443423 - Call Animation::Play() or Pause() directly from CSSAnimation::XXXFromStyle(). r=birtles\n\nWhen CSS animation playState is changed, we should call RequestRestyle(Layer)\nto reflect the new state to the compositor just like when animation timing\nparams are changed.\n\nMozReview-Commit-ID: JNDBco5uuK2", "files": ["layout/style/nsAnimationManager.cpp"], "git_node": null, "git_parents": [null], "node": "ccc9d9b8901575420db2b703d46f1ccc613621eb", "parents": ["470c96bdde515239728d90e12c7bae067884f909"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1443423 - Drop Animation::PauseNoUpdate(). r=birtles\n\nCSSTransition still uses PlayNoUpdate().\n\nMozReview-Commit-ID: 5RHSXwaKYV2", "files": ["dom/animation/Animation.cpp", "dom/animation/Animation.h"], "git_node": null, "git_parents": [null], "node": "c4b5d2b85228620b60da1404431bb19ab761c06c", "parents": ["ccc9d9b8901575420db2b703d46f1ccc613621eb"], "tags": []}, {"author": "Patrick Brosset \u003cpbrosset@mozilla.com\u003e", "branch": "default", "desc": "Bug 1435749 - Cut out justify-content areas using the correct flex items in the flexbox highlighter; r=gl\n\nMozReview-Commit-ID: 6v9TrdRARlI", "files": ["devtools/server/actors/highlighters/flexbox.js"], "git_node": null, "git_parents": [null], "node": "71ecd11c2bf69c14ad4cca195cd576f65fc998e6", "parents": ["c4b5d2b85228620b60da1404431bb19ab761c06c"], "tags": []}, {"author": "glowka \u003cglowka.tom@gmail.com\u003e", "branch": "default", "desc": "Bug 1434885 - Netmonitor list of requests width and height synced with details panel using dedicated action r=Honza\n\nMozReview-Commit-ID: KNaTyJE0nbR", "files": ["devtools/client/netmonitor/src/actions/ui.js", "devtools/client/netmonitor/src/assets/styles/RequestList.css", "devtools/client/netmonitor/src/components/MonitorPanel.js", "devtools/client/netmonitor/src/components/RequestListContent.js", "devtools/client/netmonitor/src/constants.js", "devtools/client/netmonitor/src/reducers/ui.js"], "git_node": null, "git_parents": [null], "node": "661f27f91e1eef7ebe0