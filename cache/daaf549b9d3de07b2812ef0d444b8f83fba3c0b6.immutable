ent/extensions.js"], "git_node": null, "git_parents": [null], "node": "475eae4a6baf5ccf7f796aa7fd0451a06d82cdd1", "parents": ["020eaf3312633c006864de8fd5b4f97b5703d499"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442243 - 1. Add GeckoSessionTestRule.env; r=snorp\n\nAdd an env object to GeckoSessionTestRule to easily check if we're in\nautomation, in e10s mode, etc.\n\nMozReview-Commit-ID: 3LIOJoHWPR4", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/GeckoSessionTestRuleTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/rule/GeckoSessionTestRule.java"], "git_node": null, "git_parents": [null], "node": "72cd096b3ced624667af843614d8c34b168e7c9f", "parents": ["475eae4a6baf5ccf7f796aa7fd0451a06d82cdd1"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442243 - 2. Allow Callbacks interfaces for waitUntilCalled(Class\u003c?\u003e); r=jchen\n\nAllow calls like `waitUntilCalled(Callbacks.NavigationListener::class)`\nin addition to `waitUntilCalled(GeckoSession.NavigationListener::class)`.\n\nMozReview-Commit-ID: CZHYnjGlxtT", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/GeckoSessionTestRuleTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/rule/GeckoSessionTestRule.java"], "git_node": null, "git_parents": [null], "node": "c271ebbb2461bd15dbfb4129e8f57e80894e1692", "parents": ["72cd096b3ced624667af843614d8c34b168e7c9f"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442243 - 3. Add ClosedSessionAtStart test annotation; r=snorp\n\nAdd an annotation for having a closed session at the start of a test.\n\nMozReview-Commit-ID: 4oMJwhwhKU7", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/GeckoSessionTestRuleTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/rule/GeckoSessionTestRule.java"], "git_node": null, "git_parents": [null], "node": "c7d9be0e00a69aef30be3ea67cd045b1643dafff", "parents": ["c271ebbb2461bd15dbfb4129e8f57e80894e1692"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442243 - 4. Add calls for creating sessions; r=snorp\n\nAdd createOpenSession and createClosedSession to create new sessions\nfrom the test rule. The names are chosen to be explicit about the state\nof the newly created session.\n\nMozReview-Commit-ID: AtLKuyChMwt", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/GeckoSessionTestRuleTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/rule/GeckoSessionTestRule.java"], "git_node": null, "git_parents": [null], "node": "2205567d8b91237da2d37deb15dd29bbcdb01b45", "parents": ["c7d9be0e00a69aef30be3ea67cd045b1643dafff"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442243 - 5. Add session-specific versions of test rule calls; r=snorp\n\nKeep track of the session of recorded calls, and add session-specific\noverrides of the wait*, for*, and delegate* calls that allow operations\non a particular session. The session-less call will operate on all\nsessions.\n\nMozReview-Commit-ID: 170FPHw3DwR", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/rule/GeckoSessionTestRule.java"], "git_node": null, "git_parents": [null], "node": "396f4ce2ae488b8925c6e52ada678ae3d46b0272", "parents": ["2205567d8b91237da2d37deb15dd29bbcdb01b45"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442243 - 6. Add BaseSessionTest; r=snorp\n\nAdd BaseSessionTest to provide some common boilerplate code, as well as\nKotlin extension functions for operating on a GeckoSession.\n\nMozReview-Commit-ID: 73KTZN6Zo0K", "files": [