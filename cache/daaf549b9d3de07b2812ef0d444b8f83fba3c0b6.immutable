, "git_parents": [null], "node": "707fd3a2a6886566d9f7a56017c4983c869b5f2c", "parents": ["93bd90643c5b5bb0e90eee0dd3f71645c638d656"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1445235 part 5 - Refactor spectreBoundsCheck32 to work without a scratch register. r=nbp, a=RyanVM", "files": ["js/src/jit/MacroAssembler.h", "js/src/jit/arm/MacroAssembler-arm-inl.h", "js/src/jit/arm64/MacroAssembler-arm64-inl.h", "js/src/jit/mips-shared/MacroAssembler-mips-shared-inl.h", "js/src/jit/x64/MacroAssembler-x64-inl.h", "js/src/jit/x86-shared/MacroAssembler-x86-shared-inl.h", "js/src/jit/x86/MacroAssembler-x86-inl.h"], "git_node": null, "git_parents": [null], "node": "d757d31f4b9d88462f24e57f4823717b986d3572", "parents": ["707fd3a2a6886566d9f7a56017c4983c869b5f2c"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1445235 part 6 - Use spectreBoundsCheck32 for more stores in JIT code. r=nbp, a=RyanVM", "files": ["js/src/jit/BaselineCacheIRCompiler.cpp", "js/src/jit/CodeGenerator.cpp", "js/src/jit/CodeGenerator.h", "js/src/jit/IonCacheIRCompiler.cpp", "js/src/jit/Lowering.cpp", "js/src/jit/shared/LIR-shared.h"], "git_node": null, "git_parents": [null], "node": "ce00b156aeb78fb7ddafd71d03c9709278265880", "parents": ["d757d31f4b9d88462f24e57f4823717b986d3572"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1445235 followup - Add some blank lines to appease masm style checker. r=red, a=RyanVM", "files": ["js/src/jit/MacroAssembler.h"], "git_node": null, "git_parents": [null], "node": "ebe5227dc318fc234d0abb45d868b1e34c6779c2", "parents": ["ce00b156aeb78fb7ddafd71d03c9709278265880"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1450796 - Remove overzealous assert in spectreBoundsCheck32. r=luke, a=RyanVM", "files": ["js/src/jit-test/tests/ion/bug1450796.js", "js/src/jit/arm/MacroAssembler-arm-inl.h", "js/src/jit/arm64/MacroAssembler-arm64-inl.h", "js/src/jit/x64/MacroAssembler-x64-inl.h", "js/src/jit/x86/MacroAssembler-x86-inl.h"], "git_node": null, "git_parents": [null], "node": "d5ee6ae2e245f3b8093bd3627ef2bc6088eb4923", "parents": ["ebe5227dc318fc234d0abb45d868b1e34c6779c2"], "tags": []}], "date": 1523298368, "git_changesets": [null, null, null, null, null, null, null, null, null], "user": "jandemooij@gmail.com"}, "9008": {"changesets": [{"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1448329 followup - Fix nojit beta build. r=red, a=red", "files": ["js/src/jit/none/Lowering-none.h"], "git_node": null, "git_parents": [null], "node": "5b9ee6a707a068cd1ee79ea2fff7ff4147c694eb", "parents": ["d5ee6ae2e245f3b8093bd3627ef2bc6088eb4923"], "tags": ["DEVEDITION_60_0b11_BUILD1", "DEVEDITION_60_0b11_RELEASE", "FENNEC_60_0b11_BUILD1", "FENNEC_60_0b11_RELEASE", "FIREFOX_60_0b11_BUILD2", "FIREFOX_60_0b11_RELEASE"]}], "date": 1523299545, "git_changesets": [null], "user": "jandemooij@gmail.com"}, "9009": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1452525: Deduplicate proto bindings, not bindings. r=xidorn, a=RyanVM\n\nMozReview-Commit-ID: 2NWALzUhDjn", "files": ["dom/xbl/nsBindingManager.cpp", "dom/xbl/nsBindingManager.h", "layout/style/ServoStyleSet.cpp"], "git_node": null, "git_parents": [null], "node": "9ef40c935262a5af12474cfb34cb9c95f9222ba7", "parents": ["5b9ee6a707a068cd1ee79ea2fff7ff4147c694eb"], "tags": []}], "date": 1523320640, "git_changesets": [null], "user": "xquan@mozilla.com"}, "9010": {"changesets": [{"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1368767 - Fix race condition in test_set_location_through_execute_script. r=ato a=test-only\n\nUsing get_url() to wait for a page load to be done doesn't work because\nit already returns when the location bar gets updated. Instead wait for\na known element of the page.\n\nMozReview-Commit-ID: CdYux8sTAiP", "files": ["testing/marionette/harness/marionette_harness/tests/unit/test_navigation.py"], "git_node": null, "git_parents": [null], "node": "463126f49ddcf84bec22efe85ade6548b18c88dd", "parents": ["9ef40c935262a5af12474cfb34cb9c95f9222ba7"], "tags": []}, {"author": "Andrew Halberstadt \u003cahalberstadt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1452432 - Convert 'test' field to a string in assertionCount StructuredLog.jsm messages, r=gbrown a=test-only\n\nFor messages that have a test field (like testStart/testStatus/testEnd/etc),\nthe StructuredLog.jsm module converts the field to a string if it was an Array\n(as used by reftest). It looks like the assertionCount message accidentally got\nleft out.\n\nI don't believe this conversion should be happening in StructuredLog.jsm. It\nshould either happen in the formatters, or in reftest.jsm. But for now it's\nbetter to be consistent. Another bug for another time.\n\nMozReview-Commit-ID: DjdoEqxoujT", "files": ["testing/modules/StructuredLog.jsm"], "git_node": null, "git_parents": [null], "node": "2a948d61629384c23fbbf9187468cc00ebdcef81", "parents": ["463126f49ddcf84bec22efe85ade6548b18c88dd"], "tags": []}, {"author": "Olli Pettay \u003cbugs\u003e", "branch": "default", "desc": "Bug 1447993 - after ff update, anchors inside our slider stopped working. r=masayuki a=RyanVM", "files": ["dom/events/EventStateManager.cpp", "dom/events/EventStateManager.h", "layout/base/PresShell.cpp", "layout/base/PresShell.h", "layout/base/nsIPresShell.h"], "git_node": null, "git_parents": [null], "node": "36be32ab69d21f1c30b43229543b8938b7a03598", "parents": ["2a948d61629384c23fbbf9187468cc00ebdcef81"], "tags": []}, {"author": "Olli Pettay \u003cbugs\u003e", "branch": "default", "desc": "Bug 1447993 - after ff update, anchors inside our slider stopped working. r=masayuki a=test-only", "files": ["dom/events/test/mochitest.ini", "dom/events/test/test_bug1447993.html", "dom/events/test/window_bug1447993.html"], "git_node": null, "git_parents": [null], "node": "ed5444c44e74eb82618af08683ead07a0853ddc4", "parents": ["36be32ab69d21f1c30b43229543b8938b7a03598"], "tags": []}], "date": 1523361918, "git_changesets": [null, null, null, null], "user": "rgurzau@mozilla.com"}, "9011": {"changesets": [{"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1388020. r=nical a=RyanVM", "files": ["gfx/gl/GLTextureImage.cpp", "gfx/gl/GLUploadHelpers.cpp", "gfx/gl/GLUploadHelpers.h", "gfx/gl/TextureImageEGL.cpp", "gfx/layers/composite/TextureHost.cpp", "gfx/layers/opengl/TextureHostOGL.cpp"], "git_node": null, "git_parents": [null], "node": "7bd226b1ef552ce282f1468cfff42d72e8d2c7c7", "parents": ["ed5444c44e74eb82618af08683ead07a0853ddc4"], "tags": []}], "date": 1523363655, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "9012": {"changesets": [{"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1402018 - Fix some flakiness when tests are run in parallel. r=aswan, a=RyanVM\n\nWhen we run tests in parallel (and probably occasionally when we don't), we\nsometimes wind up getting a DOMContentLoaded event for about:blank before we\nactually start loading the background page, which causes tests which rely on\nthe background page being loaded to fail.\n\nThis also fixes some noisy warnings from XPIProvider which make actual issues\nmore difficult to diagnose.\n\nThis was originally landed on mozilla-central as a follow-up patch to bug 1444758.\n\nMozReview-Commit-ID: 4CiccISJ7Pt", "files": ["toolkit/components/extensions/ExtensionPageChild.jsm", "toolkit/mozapps/extensions/internal/XPIProvider.jsm"], "git_node": null, "git_parents": [null], "node": "345eb838f7866a6d4cfd87c92a77f1f674064850", "parents": ["7bd226b1ef552ce282f1468cfff42d72e8d2c7c7"], "tags": []}, {"author": "Tomislav Jovanovic \u003ctomica@gmail.com\u003e", "branch": "default", "desc": "Bug 1436450 - Fix \u003call_urls\u003e as an optional API permission. r=aswan, a=RyanVM\n\nMozReview-Commit-ID: FXiUuNgPlRo", "files": ["toolkit/components/extensions/ext-permissions.js", "toolkit/components/extensions/test/xpcshell/test_ext_permissions.js"], "git_node": null, "git_parents": [null], "node": "5dc2bed05d2ac1525dc9a4a146cbff0b84611cce", "parents": ["345eb838f7866a6d4cfd87c92a77f1f674064850"], "tags": []}, {"author": "Francois Marier \u003cfrancois@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430803 - Ignore SameSite cookie attribute when value is empty or unrecognised. r=valentin, a=RyanVM\n\nMake the parsing the the attribute spec-compliant:\nhttps://tools.ietf.org/html/draft-ietf-httpbis-rfc6265bis-02#section-5.3.7\n\nMozReview-Commit-ID: 8YpkZvgryJb", "files": ["netwerk/cookie/nsCookieService.cpp", "netwerk/test/TestCookie.cpp"], "git_node": null, "git_parents": [null], "node": "57318d4d7ca9f00ad4fa688516b43b4a39cadcf0", "parents": ["5dc2bed05d2ac1525dc9a4a146cbff0b84611cce"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1451798 - Check the variable actually containing the string. r=jib, a=RyanVM\n\nMozReview-Commit-ID: 2xizfHwVPiW", "files": ["dom/media/webrtc/MediaEngineRemoteVideoSource.cpp"], "git_node": null, "git_parents": [null], "node": "18f05dfc1f61a82feaa96b5dd9d896d9ce475d5a", "parents": ["57318d4d7ca9f00ad4fa688516b43b4a39cadcf0"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1451790 - Set Time Precision to 1ms with Jitter. r=baku, a=RyanVM", "files": ["modules/libpref/init/all.js", "toolkit/components/resistfingerprinting/nsRFPService.cpp"], "git_node": null, "git_parents": [null], "node": "ab7ad29703d5e7264a2f7f795bbe9b7be0f5e112", "parents": ["18f05dfc1f61a82feaa96b5dd9d896d9ce475d5a"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "bran