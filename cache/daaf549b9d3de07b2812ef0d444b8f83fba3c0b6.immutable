ll tests in telemetry/tests/unit/test_TelemetryHistograms.js to check functionality.", "files": ["toolkit/components/telemetry/TelemetryHistogram.cpp", "toolkit/components/telemetry/tests/unit/test_TelemetryHistograms.js"], "git_node": null, "git_parents": [null], "node": "a20d57bbd1b54566c77e30121eb8bc8b4f6bb8fb", "parents": ["a4136715d683ebc0fe3724abeab289ec9bbf3748"], "tags": []}, {"author": "shorlander@mozilla.com", "branch": "default", "desc": "Bug 1410498 - Fix autoscroll image. r=dao", "files": ["toolkit/content/widgets/browser.xml", "toolkit/themes/shared/icons/autoscroll-horizontal.svg", "toolkit/themes/shared/icons/autoscroll-vertical.svg", "toolkit/themes/shared/icons/autoscroll.svg"], "git_node": null, "git_parents": [null], "node": "c9d9579b0629a0441646e4209070b4ba4bbb78f4", "parents": ["a20d57bbd1b54566c77e30121eb8bc8b4f6bb8fb"], "tags": []}, {"author": "Jordan Lund \u003cjlund@mozilla.com\u003e", "branch": "default", "desc": "Bug 1431363 - Tracking bug for 2018-03-13 migration work, DONTBUILD r=mtabara\n\nMozReview-Commit-ID: E8GqWJZLmLB", "files": ["testing/mozharness/configs/merge_day/bump_central.py", "testing/mozharness/scripts/merge_day/gecko_migration.py"], "git_node": null, "git_parents": [null], "node": "5c880ac8f013cbd01571d4939e40b08648c761ba", "parents": ["c9d9579b0629a0441646e4209070b4ba4bbb78f4"], "tags": []}, {"author": "Tooru Fujisawa \u003carai_a@mac.com\u003e", "branch": "default", "desc": "Bug 1439472 - Wait for all transitions for arrow panel before operating on the content of the panel. r=Paolo", "files": ["browser/components/extensions/test/browser/head.js"], "git_node": null, "git_parents": [null], "node": "1c928c9f81cace6bc4dda2fcd61875106910e93a", "parents": ["5c880ac8f013cbd01571d4939e40b08648c761ba"], "tags": []}, {"author": "Tooru Fujisawa \u003carai_a@mac.com\u003e", "branch": "default", "desc": "Backed out changeset 1c928c9f81ca (bug 1439472)", "files": ["browser/components/extensions/test/browser/head.js"], "git_node": nu