ooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1438310 - Remove ScopedMatchPairs and devirtualize MatchPairs to avoid triggering undefined behavior. r=jwalden", "files": ["js/src/builtin/RegExp.cpp", "js/src/vm/MatchPairs.h", "js/src/vm/RegExpObject.cpp", "js/src/vm/RegExpShared.h", "js/src/vm/RegExpStatics.h"], "git_node": null, "git_parents": [null], "node": "41857846ad591e464cb690413edeab76cceac89e", "parents": ["35e4f2c811209ec8d5a27757e0cc3aedb26a1ec1"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1442207: Remove unneeded arguments to nsIMutationObserver. r=smaug\n\naDocument is always content-\u003eOwnerDoc().\naContainer is always content-\u003eGetParent().\n\nDifferential Revision: https://phabricator.services.mozilla.com/D664\n\nMozReview-Commit-ID: 4xwPCOnhyIL\n", "files": ["accessible/generic/DocAccessible.cpp", "docshell/shistory/nsSHEntryShared.cpp", "dom/base/NodeIterator.cpp", "dom/base/ShadowRoot.cpp", "dom/base/nsContentList.cpp", "dom/base/nsDOMMutationObserver.cpp", "dom/base/nsDOMMutationObserver.h", "dom/base/nsFrameLoader.cpp", "dom/base/nsIMutationObserver.h", "dom/base/nsNodeUtils.cpp", "dom/base/nsRange.cpp", "dom/base/nsTextNode.cpp", "dom/events/IMEContentObserver.cpp", "dom/html/HTMLMediaElement.cpp", "dom/html/HTMLOutputElement.cpp", "dom/html/HTMLStyleElement.cpp", "dom/html/HTMLTableElement.cpp", "dom/html/HTMLTextAreaElement.cpp", "dom/html/HTMLTitleElement.cpp", "dom/html/nsDOMStringMap.cpp", "dom/script/ScriptElement.cpp", "dom/svg/SVGMPathElement.cpp", "dom/svg/SVGStyleElement.cpp", "dom/svg/SVGTitleElement.cpp", "dom/svg/SVGUseElement.cpp", "dom/xbl/nsBindingManager.cpp", "dom/xml/nsXMLPrettyPrinter.cpp", "dom/xslt/xpath/XPathResult.cpp", "dom/xslt/xslt/txMozillaXSLTProcessor.cpp", "dom/xul/XULDocument.cpp", "editor/libeditor/HTMLAnonymousNodeEditor.cpp", "editor/libeditor/HTMLEditor.cpp", "editor/libeditor/HTMLEditor.h", "layout/base/PresShell.cpp