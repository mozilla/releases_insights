.org\u003e", "branch": "default", "desc": "Bug 1445519 - Use frameRectForContentRect:styleMask: for nsCocoaWindow::ClientToWindowSize. r=mstange a=jcristau\n\nThis aligns the behavior with windows, though that may not be the right thing\nto do, see bug 1445738.\n\nMozReview-Commit-ID: 6p97SXWfchA", "files": ["widget/cocoa/nsCocoaWindow.mm"], "git_node": null, "git_parents": [null], "node": "fb798a901a729b9dec35e07e4df140c3456b1ca0", "parents": ["944ddfae2be0d98c8e63765b8acf00948b9516e9"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414029 - Include learn more link on New Tab doorhanger r=aswan a=jcristau l10n=flod\n\nMozReview-Commit-ID: 8FhsOOqZcMu", "files": ["browser/components/extensions/ext-url-overrides.js", "toolkit/locales/en-US/chrome/global/extensions.properties"], "git_node": null, "git_parents": [null], "node": "cf8705c4a1bf45b6287fbf606b4ffc205adba671", "parents": ["fb798a901a729b9dec35e07e4df140c3456b1ca0"], "tags": []}], "date": 1521481306, "git_changesets": [null, null, null, null, null, null, null, null], "user": "dluca@mozilla.com"}, "8874": {"changesets": [{"author": "Nicolas Silva \u003cnsilva@mozilla.com\u003e", "branch": "default", "desc": "Bug 1440993 - Null-check the GLContext's screen when reading back canvas data. r=sotaro a=jcristau", "files": ["gfx/layers/CopyableCanvasRenderer.cpp"], "git_node": null, "git_parents": [null], "node": "b6d3473bfb804c6ae37e442089865fefd0324fef", "parents": ["cf8705c4a1bf45b6287fbf606b4ffc205adba671"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1446280 - Ensure a11y::SetInstantiator only runs once. r=eeejay a=RyanVM", "files": ["accessible/windows/msaa/Platform.cpp"], "git_node": null, "git_parents": [null], "node": "6a7dbe67e7b903713e3306f248b7f0d40985a405", "parents": ["b6d3473bfb804c6ae37e442089865fefd0324fef"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1402549 - Part 1 - Assert number of saved tabs, too. r=esawin a=test-only\n\nMozReview-Commit-ID: DIfqQo3Fvlg", "files": ["mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/SessionTest.java"], "git_node": null, "git_parents": [null], "node": "bd194ec65d783469fb8be9d2055c93cf8ddfd1b0", "parents": ["6a7dbe67e7b903713e3306f248b7f0d40985a405"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1402549 - Part 2 - Use something else to trigger session store activity. r=esawin a=test-only\n\nInstead of adding and immediately closing a tab, which carries the risk that we\ncatch a session store file that was written just in-between those two\noperations (although part 1 means that we should be able to handle this safely\nnow), we just reload the current tab.\n\nMozReview-Commit-ID: JbiH8rmbbwJ", "files": ["mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/testSessionFilePreservation.java"], "git_node": null, "git_parents": [null], "node": "80b491577ef9c29be320e9eb79b3297fabff522a", "parents": ["bd194ec65d783469fb8be9d2055c93cf8ddfd1b0"], "tags": []}, {"author": "Edouard Oger \u003ceoger@fastmail.com\u003e", "branch": "default", "desc": "Bug 1441376 - Stop the Syncing animation manually in browser_remote_tabs_button.js test. r=Paolo a=test-only\n\nThe UIState.ON_UPDATE notification should be enough to reset the state of the\npanel every time the test is about to be executed. Wrong.\nIn response to this notification, gSync.onActivityStop() is called, which disables\nthe syncing animation immediately ONLY if it has been running for at least 1.5sec\n(which is almost never happening in tests), otherwise we get a setTimeout with\nthe remaining time.\nWhen the sync animation is running, we also do not react to clicks (disabled),\nhence the test failing.\nWe fix this by stopping the animation ourselves manually at the end of the test,\nso any subsequent test will start with a correct UI state.\n\nMozReview-Commit-ID: CrEb82Tw5SO", "files": ["browser/components/customizableui/test/browser_remote_tabs_button.js"], "git_node": null, "git_parents": [null], "node": "760d74c088b29012c8f37a8ef61981b80fda22ac", "parents": ["80b491577ef9c29be320e9eb79b3297fabff522a"], "tags": ["DEVEDITION_60_0b5_BUILD1", "DEVEDITION_60_0b5_RELEASE", "FENNEC_60_0b5_BUILD1", "FENNEC_60_0b5_RELEASE", "FIREFOX_60_0b5_BUILD1", "FIREFOX_60_0b5_RELEASE"]}], "date": 1521482215, "git_changesets": [null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "8875": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nit -\u003e 6f2dd23fbb0d", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "d50cee55dd748dae29f730d88bac93dbebbbeec0", "parents": ["760d74c088b29012c8f37a8ef61981b80fda22ac"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nit -\u003e 6f2dd23fbb0d", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "3df1e92a917ca131e1a666fd7334962aa1525b6f", "parents": ["d50cee55dd748dae29f730d88bac93dbebbbeec0"], "tags": []}], "date": 1521490817, "git_changesets": [null, null], "user": "ffxbld"}, "8876": {"changesets": [{"author": "Aki Sasaki \u003casasaki@mozilla.com\u003e", "branch": "default", "desc": "bug 1432591 - use a simple source package name. r=froydnj\n\nThis is a non-elegant solution to get a simple source.tar.xz package name.\nAny pretty-naming is done on the beetmover side, although as of this writing\nwe'll upload source.tar.xz there, as well:\n\nhttps://github.com/mozilla-releng/beetmoverscript/pull/106\n\nMozReview-Commit-ID: 83Xz5Bxl7WA", "files": ["toolkit/mozapps/installer/package-name.mk"], "git_node": null, "git_parents": [null], "node": "1f4a7a73e368bd9e6622c71563b04919e5100786", "parents": ["3df1e92a917ca131e1a666fd7334962aa1525b6f"], "tags": []}, {"author": "Aki Sasaki \u003casasaki@mozilla.com\u003e", "branch": "default", "desc": "bug 1432591 - mozharness - back out source-related changes from 605111b6f51f. r=tomprince\n\nIn 605111b6f51f, we removed a bunch of unused actions. However, now that we're recreating the source tarball, some of those are no longer unused. This patch brings them back.\n\nMozReview-Commit-ID: 5WZMEeuatup", "files": ["taskcluster/ci/release-source/kind.yml", "testing/mozharness/mozharness/mozilla/building/buildbase.py"], "git_node": null, "git_parents": [null], "node": "d9a5d76b6c39d0787c5756c82c1f7fa6624d4d7e", "parents": ["1f4a7a73e368bd9e6622c71563b04919e5100786"], "tags": []}, {"author": "Aki Sasaki \u003casasaki@mozilla.com\u003e", "branch": "default", "desc": "bug 1432591 - mozharness - back out source readme changes from 35d738241395. r=Callek,tomprince\n\nThis backs out the source readme changes, and gets us to the original source tarball, but massaged for taskcluster's signing+beetmover model.\n\nMozReview-Commit-ID: QIaeQ9LdLb", "files": ["testing/mozharness/configs/builds/releng_sub_linux_configs/64_source.py", "testing/mozharness/scripts/fx_desktop_build.py", "testing/mozharness/scripts/fx_source.py"], "git_node": null, "git_parents": [null], "node": "6206fa9df580dd6470ba06543962af226383985c", "parents": ["d9a5d76b6c39d0787c5756c82c1f7fa6624d4d7e"], "tags": []}, {"author": "Aki Sasaki \u003casasaki@mozilla.com\u003e", "branch": "default", "desc": "bug 1432591 - taskgraph changes for source tarball. r=bhearsum a=release\n\nMozReview-Commit-ID: BtHVc9b5d7f", "files": ["taskcluster/ci/release-source/kind.yml", "taskcluster/ci/release-source/source.yml", "taskcluster/taskgraph/transforms/beetmover.py", "taskcluster/taskgraph/util/signed_artifacts.py"], "git_node"