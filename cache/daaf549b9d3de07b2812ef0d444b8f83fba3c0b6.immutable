t_parents": [null], "node": "a2a51018aa5f04013f6772306d8154389082c0ff", "parents": ["c59f42a79b5a3c74d7d5d2279b5dc52ba3564034"], "tags": []}, {"author": "Eugen Sawin \u003cesawin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1440592 - [2.0] Enable URI-loading delegation in openURI. r=snorp\n", "files": ["mobile/android/chrome/geckoview/GeckoViewNavigationContent.js", "mobile/android/modules/geckoview/GeckoViewNavigation.jsm", "mobile/android/modules/geckoview/LoadURIDelegate.jsm", "mobile/android/modules/geckoview/moz.build"], "git_node": null, "git_parents": [null], "node": "80169b0256617adc6be618a203bd01d6f2dd9499", "parents": ["a2a51018aa5f04013f6772306d8154389082c0ff"], "tags": []}, {"author": "Eugen Sawin \u003cesawin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1440592 - [3.0] Rename GeckoView event onLoadURI to onLoadRequest. r=snorp\n", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSession.java", "mobile/android/modules/geckoview/LoadURIDelegate.jsm"], "git_node": null, "git_parents": [null], "node": "7f0371f3d5f7c570db6f8bfa6a7dfc7636498aa4", "parents": ["80169b0256617adc6be618a203bd01d6f2dd9499"], "tags": []}, {"author": "Dylan Roeh \u003cdroeh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1422084 - Fix eslint failure CLOSED TREE r=me", "files": ["mobile/android/chrome/geckoview/ErrorPageEventHandler.js"], "git_node": null, "git_parents": [null], "node": "adcbaef0b0148559d5992697438210f61553b539", "parents": ["7f0371f3d5f7c570db6f8bfa6a7dfc7636498aa4"], "tags": []}, {"author": "Eugen Sawin \u003cesawin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1440592 - [4.0] Fix linter errors on CLOSED TREE. r=me\n", "files": ["mobile/android/modules/geckoview/GeckoViewNavigation.jsm", "mobile/android/modules/geckoview/LoadURIDelegate.jsm"], "git_node": null, "git_parents": [null], "node": "2c9d1c92da9b755dd91843c14912ec405150fd9a", "parents": ["adcbaef0b0148559d5992697438210f61553b539"], "tags": []}, {"author": "Nicolas B. Pierron \u003cnicolas.b.pierron@gmail.com\u003e", "branch": "default", "desc": "Bug 1438886 - Fix arm disassembler by adding support for CSDB instruction. r=me\nCLOSED TREE\n", "files": ["js/src/jit/arm/disasm/Constants-arm.h", "js/src/jit/arm/disasm/Disasm-arm.cpp"], "git_node": null, "git_parents": [null], "node": "bf56e43e67adee8116c18fd2245327219013c2e7", "parents": ["2c9d1c92da9b755dd91843c14912ec405150fd9a"], "tags": []}, {"author": "Eugen Sawin \u003cesawin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1440592 - [5.0] Fix merge error with bug 1422084 on CLOSED TREE. r=me\n", "files": ["mobile/android/chrome/geckoview/GeckoViewNavigationContent.js", "mobile/android/modules/geckoview/LoadURIDelegate.jsm"], "git_node": null, "git_parents": [null], "node": "4f5d6034a9ca884707d2d3054b8bbcc7d613d171", "parents": ["bf56e43e67adee8116c18fd2245327219013c2e7"], "tags": []}, {"author": "Andreea Pavel \u003capavel@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to mozilla-inbound. a=merge o a CLOSED TREE", "files": [], "git_node": null, "git_parents": [null, null], "node": "a471a4087690521628d99dd02f402447c67f404a", "parents": ["4f5d6034a9ca884707d2d3054b8bbcc7d613d171", "3dc420775cf024cedc9bdcc43d020f7319f00a77"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1422087: Purge startup caches after an incomplete startup. r=Mossop\n\nSince we know that corrupt startup caches can and do cause startup crashes, we\nshould ideally purge them any time we detect that the last startup resulted in\na crash. The alternative is waiting until the users restart enough times to\ntrigger safe mode, and hope that they start in safe mode and then immediately\nrestart in normal mode. This is not a great user experience.\n\nUnfortunately, the normal startup crash detection mechanism relies on\nthe preference service, which starts up far too late for us to make this\ndecision effectively.\n\nTo work around that, this patch adds a new startup crash detection mechanism\nthat creates an incomplete startup canary file which we remove at the end of\nthe startup crash detection window, or on any sort of graceful exit.\n\nMozReview-Commit-ID: ALaLsyF4meg", "files": ["toolkit/components/startup/nsAppStartup.cpp", "toolkit/xre/nsAppRunner.cpp", "toolkit/xre/nsAppRunner.h"], "git_node": null, "git_parents": [null], "node": "686b970032b4eff9d6513bbe3c2652b75a5378d8", "parents": ["a471a4087690521628d99dd02f402447c67f404a"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1443651: Don't return failure for access denied from createUnique() if file exists. r=Mossop\n\nThere are ways for Create() to return access denied for files which already\nexist, particularly in the case of locked files. When it does, createUnique()\nshould check whether the file exists before considering the attempt a failure.\n\nMozReview-Commit-ID: FyJTghk04jH", "files": ["xpcom/io/nsLocalFileCommon.cpp"], "git_node": null, "git_parents": [null], "node": "e957efe5d14c0a7a79483b477e9a6c9a8e7ddb3f", "parents": ["686b970032b4eff9d6513bbe3c2652b75a5378d8"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1443642: Remove obsolete Addon.hasBinaryComponents flag. r=aswan\n\nMozReview-Commit-ID: AlddwvjQmg1", "files": ["toolkit/components/telemetry/TelemetryEnvironment.jsm", "toolkit/components/telemetry/tests/unit/test_TelemetryEnvironment.js", "toolkit/mozapps/extensions/internal/XPIInstall.jsm", "toolkit/mozapps/extensions/internal/XPIProvider.jsm", "toolkit/mozapps/extensions/internal/XPIProviderUtils.js", "toolkit/mozapps/extensions/test/addons/test_install5/chrome.manifest", "toolkit/mozapps/extensions/test/addons/test_install5/install.rdf", "toolkit/mozapps/extensions/test/xpcshell/test_hasbinarycomponents.js", "toolkit/mozapps/extensions/test/xpcshell/test_install.j