content/browser-places.js", "browser/base/content/browser.js", "browser/base/content/browser.xul", "browser/components/customizableui/content/panelUI.inc.xul"], "git_node": null, "git_parents": [null], "node": "43df2081c89e3a5896cce246329725dc6364a940", "parents": ["4515376b3fdcd3324a1f06da2e4df8b40ba42d30"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1454148 - Fix class of the \"View Bookmarks Toolbar\" and \"View Bookmarks Sidebar\" items in the Bookmarks button menu. r=Gijs a=jcristau\n\nMozReview-Commit-ID: 9Dp1mSpSkNS", "files": ["browser/base/content/browser.xul"], "git_node": null, "git_parents": [null], "node": "6631c7ed99f233e27169fa29e5974620d1d8fdf6", "parents": ["43df2081c89e3a5896cce246329725dc6364a940"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1447925 - Add GetClipboardText() to get text data from clipboard, r=jhorak a=jcristau\n\nGetClipboardText() calls gtk_clipboard_request_text() to request text clipboard data from Gtk+\nand leave Gtk+ to do clipboard text format conversions. Also unify data getting code for text/data/targets.\n\nMozReview-Commit-ID: 9DGSdOACho1", "files": ["widget/gtk/nsClipboard.h", "widget/gtk/nsClipboardX11.cpp", "widget/gtk/nsClipboardX11.h"], "git_node": null, "git_parents": [null], "node": "f555ad8e039e173dd5b4e399d5d312d351c26cc6", "parents": ["6631c7ed99f233e27169fa29e5974620d1d8fdf6"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1447925 - Use GetClipboardText() to get text data at nsClipboard::GetData(), r=jhorak a=jcristau\n\nMozReview-Commit-ID: 3JnLLyk0BOF", "files": ["widget/gtk/nsClipboard.cpp", "widget/gtk/nsClipboard.h"], "git_node": null, "git_parents": [null], "node": "418c75e8af6ce069471d7a31732249ecbc6e8e58", "parents": ["f555ad8e039e173dd5b4e399d5d312d351c26cc6"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442183 - Allow multiple selection in the site data manager list. r=prathiksha a=jcristau", "files": ["browser/components/preferences/siteDataSettings.js", "browser/components/preferences/siteDataSettings.xul"], "git_node": null, "git_parents": [null], "node": "da52dbcbd71c7af9d72cf07ac7b004b9ce740a15", "parents": ["418c75e8af6ce069471d7a31732249ecbc6e8e58"], "tags": []}, {"author": "Nico Grunbaum \u003cna-g@nostrum.com\u003e", "branch": "default", "desc": "Bug 1449832 - restore screen share scaling code to prevent cropping r=pehrsons a=jcristau\n\nMozReview-Commit-ID: KctPLbF4PSa", "files": ["dom/media/webrtc/MediaEngineRemoteVideoSource.cpp"], "git_node": null, "git_parents": [null], "node": "0f1a77df404760e1786f79a920a03016ec57b5bc", "parents": ["da52dbcbd71c7af9d72cf07ac7b004b9ce740a15"], "tags": []}, {"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1452019 - Fix tab_selected when lwt-image attribute is not set. r=jaws a=jcristau\n\nMozReview-Commit-ID: KVhfU9siVH8", "files": ["browser/themes/shared/tabs.inc.css", "toolkit/components/extensions/test/browser/browser_ext_themes_tab_selected.js"], "git_node": null, "git_parents": [null], "node": "f48a56beb09d5bd7d386f79c009ec2f0153821be", "parents": ["0f1a77df404760e1786f79a920a03016ec57b5bc"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1452041 - nsClipboard::HasDataMatchingFlavors(): return immediately when there's no clipboard content, r=jhorak a=jcristau\n\nMozReview-Commit-ID: CTz0tRr3p57", "files": ["widget/gtk/nsClipboard.cpp"], "git_node": null, "git_parents": [null], "node": "eafece5d7f8c745759548a982f25ebd37455f863", "parents": ["f48a56beb09d5bd7d386f79c009ec2f0153821be"], "tags": []}, {"author": "Christoph Kerschbaumer \u003cckerschb@christophkerschbaumer.com\u003e", "branch": "default", "desc": "Bug 1452496: Discard same-site cookie in cross site context. r=valentin a=jcristau", "files": ["netwerk/base/nsNetUtil.cpp", "netwerk/base/nsNetUtil.h", "netwerk/cookie/CookieServiceChild.cpp", "netwerk/cookie/CookieServiceChild.h", "netwerk/cookie/CookieServiceParent.cpp", "netwerk/cookie/CookieServiceParent.h", "netwerk/cookie/PCookieService.ipdl", "netwerk/cookie/nsCookieService.cpp"], "git_node": null, "git_parents": [null], "node": "84c492af301f887e9281cbe10d89d85e874921b0", "parents": ["eafece5d7f8c745759548a982f25ebd37455f863"], "tags": []}, {"author": "Christoph Kerschbaumer \u003cckerschb@christophkerschbaumer.com\u003e", "branch": "default", "desc": "Bug 1452496: Test for discarding same-site cookie in cross site context. r=mgoodwin a=jcristau", "files": ["dom/security/test/general/file_same_site_cookies_cross_origin_context.sjs", "dom/security/test/general/mochitest.ini", "dom/security/test/general/test_same_site_cookies_cross_origin_context.html"], "git_node": null, "git_parents": [null], "node": "7aa5a506eaa06fb5c5a8f5e699d986fd47676c11", "parents": ["84c492af301f887e9281cbe10d89d85e874921b0"], "tags": []}, {"author": "Christoph Kerschbaumer \u003cckerschb@christophkerschbaumer.com\u003e", "branch": "default", "desc": "Bug 1452496: Test for discarding same-site cookies using inline scripts in cross origin context. r=mgoodwin a=jcristau", "files": ["dom/security/test/general/file_same_site_cookies_from_script.sjs", "dom/security/test/general/mochitest.ini", "dom/security/test/general/test_same_site_cookies_from_script.html"], "git_node": null, "git_parents": [null], "node": "d367a7b18722c40ed2237d6660f8a832f68ebac7", "parents": ["7aa5a506eaa06fb5c5a8f5e699d986fd47676c11"], "tags": []}, {"author": "Christoph Kerschbaumer \u003cckerschb@christophkerschbaumer.com\u003e", "branch": "default", "desc": "Bug 1452496: gtest for discarding same-site cookies in cross site context. r=dveditz a=jcristau", "files": ["netwerk/test/TestCookie.cpp"], "git_node": null, "git_parents": [null], "node": "9f6f88626ac485719aa63e9a6b399c4a4991b5b2", "parents": ["d367a7b18722c40ed2237d6660f8a832f68ebac7"], "tags": []}, {"author": "Zibi Braniecki \u003czbraniecki@mozilla.com\u003e", "branch": "default", "desc": "Bug 1453486 - Fix Fluent API use when building a dialog to disable containers. r=Gijs a=jcristau\n\nMozReview-Commit-ID: Kfs13ugmvNr", "files": ["browser/components/preferences/in-content/main.js"], "git_node": null, "git_parents": [null], "node": "1210b05b97b0155850741ec4f4e8f4f19269827a", "parents": ["9f6f88626ac485719aa63e9a6b399c4a4991b5b2"], "tags": []}, {"author": "Zibi Braniecki \u003czbraniecki@mozilla.com\u003e", "branch": "default", "desc": "Bug 1453486 - Include containers.ftl in main preferences.xul to fix the containers removal dialog. r=Gijs a=jcristau\n\nMozReview-Commit-ID: 6nUCRhBWJmF", "files": ["browser/components/preferences/in-content/preferences.xul"], "git_node": null, "git_parents": [null], "node": "7a38d42b6b698866536c78284ff18a64f09be3fc", "parents": ["1210b05b97b0155850741ec4f4e8f4f19269827a"], "tags": []}], "date": 1523892292, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "btara@mozilla.com"}, "9064": {"changesets": [{"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1453555: Fix accessibility group info for \u003cselect size=\"1\"\u003e options. r=surkov a=jcristau\n\nIn the e10s implementation, Accessible::NativeState for the options doesn't include the invisible state. (It does with e10s disabled.)\nIn HTMLSelectOptionAccessible::NativeState, rather than just flipping (xor) the invisible state, absolutely ensure it gets removed. We don't want to *add* the invisible state if it isn't there.\nThis allows group position info to be calculated correctly.\n\nMozReview-Commit-ID: LPEVhOOm2NT", "files": ["accessible/html/HTMLSelectAccessible.cpp"], "git_node": null, "git_parents": [null], "node": "b33e369571051fb5acd88b2b78c0f45a0820de24", "parents": ["7a38d42b6b698866536c78284ff18a64f09be3fc"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1453740 - Allow 1x1 windows in VP8EncoderImpl::InitEncode; r=pehrsons a=jcristau\n\nA minimized window has a resolution of 1x1. Although we removed minimized windows from the list\nof available windows to share, nothing prevents the user from minimizing it during a call. With\nthe current code, this will cause InitEncode to fail, resulting in a fatal release assert.\n\nI tested this patch with window sharing on meet.google.com and I was able to minimize and restore\nthe window several times without problem. While minimized, the window appears as a black screen\nto the other meeting participants. It renders normally when restored.\n\nMozReview-Commit-ID: LE2NBiEy8nw", "files": ["media/webrtc/trunk/webrtc/modules/video_coding/codecs/vp8/vp8_impl.cc"], "git_node": null, "git_parents": [null], "node": "f621f04ecd455fa1571bbc5c76d420624df40512", "parents": ["b33e369571051fb5acd88b2b78c0f45a0820de24"], "tags": []}, {"author": "Christoph Kerschbaumer \u003cckerschb@christophkerschbaumer.com\u003e", "branch": "default", "desc": "Bug 1453814: Treat any cross-origin redirects as foreign for same-site cookies. r=valentin a=jcristau", "files": ["netwerk/base/nsNetUtil.cpp"], "git_node": null, "git_parents": [null], "node": "a0774aff327c9162590a8d86a3d562d68ae08bc0", "parents": ["f621f04ecd455fa1571bbc5c76d420624df40512"], "tags": []}, {"author": "Christoph Kerschbaumer \u003cckerschb@christophkerschbaumer.com\u003e", "branch": "default", "desc": "Bug 1453814: Test redirects and same-site cookies. r=mgoodwin a=jcristau", "files": ["dom/security/test/general/file_same_site_cookies_redirect.sjs", "dom/security/test/general/mochitest.ini", "dom/security/test/general/test_same_site_cookies_redirect.html"], "git_node": null, "git_parents": [null], "node": "8249c87c7dd7c78260e7b31c39644c5f6fd57ab1", "parents": ["a0774aff327c9162590a8d86a3d562d68ae08bc0"], "tags": []}], "date": 1523894449, "git_changesets": [null, null, null, null], "user": "btara@mozilla.com"}, "9065": {"changesets": [{"author": "Bogdan Tara \u003cbtara@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 7a38d42b6b69 (bug 1453486) On request from gandalf a=backout", "files": ["browser/components/preferences/in-content/preferences.xul"], "git_node": null, "git_parents": [null], "node": "18f776b5b08011b84a75903883e961c1cd69249c", "parents": ["8249c87c7dd7c78260e7b31c39644c5f6fd57ab1"], "tags": []}], "date": 1523894682, "git_changesets": [null], "user": "btara@mozilla.com"}, "9066": {"changesets": [{"author": "Nicolas B. Pierron \u003cnicolas.b.pierron@gmail.com\u003e", "branch": "default", "desc": "Bug 1437510 - ARM: Zero the payload if the Value tag does not match the expected tag. r=jandem, a=RyanVM", "files": ["js/src/jit/arm/CodeGenerator-arm.cpp", "js/src/jit/arm/MacroAssembler-arm.cpp", "js/src/jit/arm/MacroAssembler-arm.h"], "git_node": null, "git_parents": [null], "node": "9c8731ec8be68c4ad2786a257b32efec783b2ddd", "parents": ["18f776b5b08011b84a75903883e961c1cd69249c"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1447982 - Squashed fixes for Firefox 60. r=padenot, a=jcristau\n\nThis patch includes the following patches rebased and squashed:\n\nCover channel count changes also when mic source is stopped (muted). r=padenot\nhttps://hg.mozilla.org/mozilla-central/rev/5ce4dd0d0ca5\n\nMic source's ApplySettings shouldn't have weird side effects. r=padenot\nhttps://hg.mozilla.org/mozilla-central/rev/5180d718e5a5\n\nApply and update mic source settings on Reconfigure. r=padenot\nhttps://hg.mozilla.org/mozilla-central/rev/e87afd1fda35\n\nPass GraphImpl into ApplySettings. r=padenot\nhttps://hg.mozilla.org/mozilla-central/rev/19e183125269\n\nRename mLastPrefs to mNetPrefs and update comment for clarity. r=padenot\nhttps://hg.mozilla.org/mozilla-central/rev/a67e5015e456", "files": ["dom/media/webrtc/MediaEngineWebRTC.h", "dom/media/webrtc/MediaEngineWebRTCAudio.cpp"], "git_node": null, "git_parents": [null], "node": "9e8eacca6e47f0b0a515260c85b5a691a391c8e4", "parents": ["9c8731ec8be68c4ad2786a257b32efec783b2ddd"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1447982 - Add mochitest for audio constraints. r=jib, a=jcristau\n\nMozReview-Commit-ID: DGlvTW6EXAO", "files": ["dom/media/tests/mochitest/mochitest.ini", "dom/media/tests/mochitest/test_getUserMedia_audioConstraints.html"], "git_node": null, "git_parents": [null], "node": "15079c3a4d0f9ca29cf4d737c7b112cbb409e741", "parents": ["9e8eacca6e47f0b0a515260c85b5a691a391c8e4"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1453873 - Stop firing accessible focus events for JAWS when combo box options are selected. r=MarcoZ, a=jcristau\n\nThese events were a hack implemented in bug 703198.\nAt that time, JAWS required focus events for selection changes in a collapsed combo box.\nHowever, these events also fire for expanded combo boxes.\nThis is problematic with e10s because now, for an expanded combo box, the real focus events come from the XUL dropdown implemented in the parent process, which is not associated with the document a11y tree in any way.\nJAWS seems to cope just fine with value changes for Firefox combo boxes now and VFO have agreed that this is the correct path forward.\n\nMozReview-Commit-ID: Iefop25bFe0", "files": ["accessible/windows/msaa/AccessibleWrap.cpp"], "git_node": null, "git_parents": [null], "node": "821855807c5b55884306ffe17c8b1e26e5d876eb", "parents": ["15079c3a4d0f9ca29cf4d737c7b112cbb409e741"], "tags": []}, {"author": "Bas Schouten \u003cbschouten@mozilla.com\u003e", "branch": "default", "desc": "Bug 1447141 - Blacklist all acceleration on a small subset of AMD device/driver combinations that show up in content crashes. r=milan, a=RyanVM\n\nMozReview-Commit-ID: FTBPGRTdmUG", "files": ["widget/GfxDriverInfo.cpp", "widget/GfxDriverInfo.h", "widget/windows/GfxInfo.cpp"], "git_node": null, "git_parents": [null], "node": "972d60b262109bfae35e9a8ed89d2d9b6860cdf2", "parents": ["821855807c5b55884306ffe17c8b1e26e5d876eb"], "tags": []}, {"author": "Miko Mynttinen \u003cmikokm@gmail.com\u003e", "branch": "default", "desc": "Bug 1393367 - Change MOZ_ASSERT to MOZ_RELEASE_ASSERT. r=mstange, r=fbraun, a=RyanVM", "files": ["gfx/2d/FilterNodeSoftware.cpp"], "git_node": null, "git_parents": [null], "node": "9718d92fab4d9a39acdc2afb0302b6fcd7997f6c", "parents": ["972d60b262109bfae35e9a8ed89d2d9b6860cdf2"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1453872 - Make HTMLEditRules::JoinNodesSmart() return { aRightNode - aLeftNode.Length() } by default. r=m_kato, a=jcristau\n\nThis is regression of bug 1423835.\n\nWhen I fixed the bug, I accidentally changed the result of\nHTMLEditRules::JoinNodesSmart() to use new API.  However, it was simple\nmisunderstand.  The original code sets the initial value of result to\n{ aRightNode - aLeftNode.Length() } but I understood it as\n{ aRightNode - aRightNode.Length() }.  Therefore, this patch backs out the\npatch only for this line.\n\nMozReview-Commit-ID: 5rD7YFij8v", "files": ["editor/libeditor/HTMLEditRules.cpp", "testing/web-platform/mozilla/meta/MANIFEST.json", "testing/web-platform/mozilla/meta/editor/joining_nodes.html.ini", "testing/web-platform/mozilla/tests/editor/joining_nodes.html"], "git_node": null, "git_parents": [null], "node": "01e680ea0270b9b84e409c686541b0db4dff3c54", "parents": ["9718d92fab4d9a39acdc2afb0302b6fcd7997f6c"], "tags": []}, {"author": "Christoph Kerschbaumer \u003cckerschb@christophkerschbaumer.com\u003e", "branch": "default", "desc": "Bug 1454242 - Setting samesite cookie should not rely on NS_IsSameSiteForeign. r=valentin, a=jcristau", "files": ["netwerk/cookie/nsCookieService.cpp"], "git_node": null, "git_parents": [null], "node": "a8a5ba53d104721c7c586c53bc52a61d82a53d73", "parents": ["01e680ea0270b9b84e409c686541b0db4dff3c54"], "tags": []}, {"author": "Christoph Kerschbaumer \u003cckerschb@christophkerschbaumer.com\u003e", "branch": "default", "desc": "Bug 1454242 - Test samesite cookie on top-level page from cross-origin context. r=mgoodwin, a=jcristau", "files": ["dom/security/test/general/file_same_site_cookies_toplevel_set_cookie.sjs", "dom/security/test/general/mochitest.ini", "dom/security/test/general/test_same_site_cookies_toplevel_set_cookie.html"], "git_node": null, "git_parents": [null], "node": "7cb7bafe04e4ab600d49a90302e8455748199431", "parents": ["a8a5ba53d104721c7c586c53bc52a61d82a53d73"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1453339 - Make it harder to mess up Promise::All. r=peterv, a=abillings\n\nMozReview-Commit-ID: UO4wssYHj7", "files": ["dom/base/nsFrameLoader.cpp", "dom/cache/Cache.cpp", "dom/promise/Promise.cpp", "dom/promise/Promise.h", "layout/style/FontFaceSet.cpp"], "git_node": null, "git_parents": [null], "node": "eb825e4db72f892b87e53fec8619d7643a17a990", "parents": ["7cb7bafe04e4ab600d49a90302e8455748199431"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1450954 - Add back code to undo screenshare constraints hack. r=jib, a=jcristau\n\nMozReview-Commit-ID: 9rDRj7U8vQi", "files": ["dom/media/webrtc/MediaEngineRemoteVideoSource.cpp"], "git_node": null, "git_parents": [null], "node": "bf6f0553eaeb4b41e4d9c70744b3818a42c27115", "parents": ["eb825e4db72f892b87e53fec8619d7643a17a990"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1450954 - Test that a screenshare track's getSettings return sane dimensions. r=jib, a=jcristau\n\nMozReview-Commit-ID: GDSQLfXBFBU", "files": ["dom/media/tests/mochitest/test_getUserMedia_basicScreenshare.html"], "git_node": null, "git_parents": [null], "node": "9f8ac6bbbd47a4da7cad5f138a58528d382a5f25", "parents": ["bf6f0553eaeb4b41e4d9c70744b3818a42c27115"], "tags": []}], "date": 1523896750, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9067": {"changesets": [{"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "Bug 1391154 - Handle edge cases around the borders of IntersectionObservers more consistently. r=dholbert, a=RyanVM\n\nThe old code would ignore mThresholds if we happened to update when the\nobserved element was edge-adjacent to its root. This could cause spurious\nnotifications if it happened to run during a CSS transformation. The new code\nmore closely follows the spec with a slight deviation where the code treats\nall values less than the smallest passed-in threshold as equivalent (when\nlooking at previousIndex). This matches Chrome's implementation and the tests.\n\nMozReview-Commit-ID: 7oAh1EdjMiY", "files": ["dom/base/DOMIntersectionObserver.cpp"], "git_node": null, "git_parents": [null], "node": "b8c46f48908450f837506d9a03d4b50017cffc66", "parents": ["9f8ac6bbbd47a4da7cad5f138a58528d382a5f25"], "tags": []}, {"author": "Eric Rahm \u003cerahm@mozilla.com\u003e", "branch": "default", "desc": "Bug 1452202 - Clean up PLDHashTable move operator. r=froydnj, a=RyanVM", "files": ["xpcom/ds/PLDHashTable.cpp"], "git_node": null, "git_parents": [null], "node": "041d1c561feb5f4d9bcd492f31f7203ca477f938", "parents": ["b8c46f48908450f837506d9a03d4b50017cffc66"], "tags": []}], "date": 1523898611, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "9068": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out 5 changesets (bug 1443587) for causing bug 1450690. a=RyanVM\n\nBacked out changeset 5c78a8fff848 (bug 1443587)\nBacked out changeset dbf8c7f084e1 (bug 1443587)\nBacked out changeset c7c67940a56c (bug 1443587)\nBacked out changeset edf99f34ac2c (bug 1443587)\nBacked out changeset 0681ad7a9915 (bug 1443587)", "files": ["toolkit/components/telemetry/EventInfo.h", "toolkit/components/telemetry/TelemetryCommon.cpp", "toolkit/components/telemetry/TelemetryCommon.h", "toolkit/components/telemetry/TelemetryEvent.cpp", "toolkit/components/telemetry/TelemetryHistogram.cpp"], "git_node": null, "git_parents": [null], "node": "1979fbb0fb9364067a2ae0bb2201166f1ef3c418", "parents": ["041d1c561feb5f4d9bcd492f31f7203ca477f938"], "tags": []}], "date": 1523900556, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "9069": {"changesets": [{"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1453658 - Use pip options when install python3 modules. r=bhearsum, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D924", "files": ["testing/mozharness/mozharness/base/python.py"], "git_node": null, "git_parents": [null], "node": "b36fb5458ecbde976a48ec0644d3b88154325eb8", "parents": ["1979fbb0fb9364067a2ae0bb2201166f1ef3c418"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1453658 - [talos] Install cffi before trying to install mitmproxy dependencies. r=bhearsum, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D925", "files": ["testing/mozharness/mozharness/mozilla/testing/talos.py"], "git_node": null, "git_parents": [null], "node": "1cf6b6ff8bd2d01bf14175640971f1c28d1ea7fe", "parents": ["b36fb5458ecbde976a48ec0644d3b88154325eb8"], "tags": ["DEVEDITION_60_0b13_BUILD1", "DEVEDITION_60_0b13_RELEASE", "FENNEC_60_0b13_BUILD1", "FENNEC_60_0b13_RELEASE", "FIREFOX_60_0b13_BUILD1", "FIREFOX_60_0b13_RELEASE"]}], "date": 1523901165, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "9070": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", 