1519926102, "git_changesets": [null, null], "user": "ffxbld"}, "8801": {"changesets": [{"author": "Robert Strong \u003crobert.bugzilla@gmail.com\u003e", "branch": "default", "desc": "bug 1442407 - Backed out 5 changesets for application update issues. r=backout, a=jcristau on a CLOSED TREE\n\nBack out bug 1417254, bug 1348087, and bug 1416295 for continuing to cause app update failures.\n\nBacked out changeset ec6f1b3c1317 (bug 1417254)\nBacked out changeset df5703f27971 (bug 1416295)\nBacked out changeset ae2fcdddead1 (bug 1348087)\nBacked out changeset fb54cd45fa10 (bug 1348087)\nBacked out changeset edfa340ec9fb (bug 1348087)", "files": ["browser/branding/aurora/pref/firefox-branding.js", "browser/branding/nightly/pref/firefox-branding.js", "browser/branding/official/pref/firefox-branding.js", "browser/branding/unofficial/pref/firefox-branding.js", "js/xpconnect/src/xpc.msg", "toolkit/.eslintrc.js", "toolkit/mozapps/update/UpdateTelemetry.jsm", "toolkit/mozapps/update/nsUpdateService.js", "toolkit/mozapps/update/tests/chrome/utils.js", "toolkit/mozapps/update/tests/data/shared.js", "toolkit/mozapps/update/tests/data/sharedUpdateXML.js", "toolkit/mozapps/update/tests/data/xpcshellUtilsAUS.js", "toolkit/mozapps/update/tests/unit_aus_update/downloadInterruptedNoRecovery.js", "toolkit/mozapps/update/tests/unit_aus_update/downloadInterruptedOffline.js", "toolkit/mozapps/update/tests/unit_aus_update/downloadInterruptedRecovery.js", "toolkit/mozapps/update/tests/unit_aus_update/downloadInterruptedRecoveryChannel.js", "toolkit/mozapps/update/tests/unit_aus_update/downloadResumeAfterRestart.js", "toolkit/mozapps/update/tests/unit_aus_update/downloadResumeErrorNoEntityID.js", "toolkit/mozapps/update/tests/unit_aus_update/downloadResumeForSameAppVersion.js", "toolkit/mozapps/update/tests/unit_aus_update/remoteUpdateXML.js", "toolkit/mozapps/update/tests/unit_aus_update/updateManagerXML.js", "toolkit/mozapps/update/tests/unit_aus_update/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "794037e3193dbcd8132130a515c292b63fc9f6e5", "parents": ["59ebd4b9e7de4c7b25ffe9b19bd6e9a0d005ab1e"], "tags": []}], "date": 1519982172, "git_changesets": [null], "user": "jcristau@mozilla.com"}, "8802": {"changesets": [{"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1433459 - part 1: Move bouncer submission tasks to scriptworker r=mtabara,rail\n\nMozReview-Commit-ID: 6SKhjf1ywoH", "files": ["taskcluster/ci/release-bouncer-sub/kind.yml", "taskcluster/taskgraph/transforms/bouncer_submission.py", "taskcluster/taskgraph/transforms/l10n.py", "taskcluster/taskgraph/transforms/task.py"], "git_node": null, "git_parents": [null], "node": "ff884199e8b1dfe369c3989422dba57467b50221", "parents": ["794037e3193dbcd8132130a515c292b63fc9f6e5"], "tags": []}, {"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1433459 - part 2: Move aliases tasks to scriptworker r=mtabara,rail\n\nMozReview-Commit-ID: Ld6ZQPBZYjX", "files": ["taskcluster/ci/release-bouncer-aliases/kind.yml", "taskcluster/ci/release-bouncer-sub/kind.yml", "taskcluster/taskgraph/transforms/bouncer_aliases.py", "taskcluster/taskgraph/transforms/task.py"], "git_node": null, "git_parents": [null], "node": "75bf6a6a5f8850bf9bb2c71e652b148338b1b683", "parents": ["ff884199e8b1dfe369c3989422dba57467b50221"], "tags": []}, {"author": "Justin Wood \u003cCallek@gmail.com\u003e", "branch": "default", "desc": "Bug 1439876 - Add scriptworker version bumping. r=aki p=Callek CLOSED TREE", "files": ["taskcluster/ci/release-version-bump/kind.yml", "taskcluster/taskgraph/transforms/release_version_bump.py", "taskcluster/taskgraph/transforms/task.py", "taskcluster/taskgraph/util/workertypes.py"], "git_node": null, "git_parents": [null], "node": "c6a858e76ba0e37b0f2def225c21b48ed6585858", "parents": ["75bf6a6a5f8850bf9bb2c71e652b148338b1b683"], "tags": []}], "date": 1519985749, "git_changesets": [null, null, null], "user": "jlorenzo@mozilla.com"}, "8803": {"changesets": [{"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1432219 - part 3: Fix bad beetmover worker type in production r=bhearsum a=release CLOSED TREE", "files": ["taskcluster/ci/release-generate-checksums-beetmover/kind.yml", "taskcluster/taskgraph/transforms/release_generate_checksums_beetmover.py"], "git_node": null, "git_parents": [null], "node": "dbe9214d56355abb026839a145a0580068f75e33", "parents": ["c6a858e76ba0e37b0f2def225c21b48ed6585858"], "tags": []}], "date": 1520001316, "git_changesets": [null], "user": "jlorenzo@mozilla.com"}, "8804": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging f83587c150abb271b3f15742007994ca57bc8395 with DEVEDITION_59_0b14_BUILD1, DEVEDITION_59_0b14_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "2a3716d0680fdb7616963cb556b897938a686302", "parents": ["dbe9214d56355abb026839a145a0580068f75e33"], "tags": []}], "date": 1520005135, "git_changesets": [null], "user": "ffxbld"}, "8805": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging f83587c150abb271b3f15742007994ca57bc8395 with FIREFOX_59_0b14_BUILD1, FIREFOX_59_0b14_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "8808128c228439609988ba0ac58fef8018873a6f", "parents": ["2a3716d0680fdb7616963cb556b897938a686302"], "tags": []}], "date": 1520005578, "git_changesets": [null], "user": "ffxbld"}, "8806": {"changesets": [{"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "FIREFOX_59b_RELBRANCH", "desc": "Bug 1440461 - Disable titlebar rendering for Linux/Firefox 59. r=glandium, a=lizzard\n\nThe titlebar rendering on Linux/Gtk+ is recently enabled at Beta59 but with many bugs fixed at Nightly.\nLet's disable this feature for Beta / Release 59 and ship it at Firefox 60 where majority of the issues are fixed.\n\nMozReview-Commit-ID: FQL7tNhcvUG", "files": ["browser/base/moz.build", "toolkit/modules/moz.build", "widget/gtk/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "68edd6cf79cee701dd8d222bec030d82b7c4df02", "parents": ["971dff3337096a304e3329e9de7acc8c7af3a7d2"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "FIREFOX_59b_RELBRANCH", "desc": "Bug 1428759 - Remove mutual exclusion from WeakReferenceSupport interface queries. r=Jamie, a=RyanVM", "files": ["ipc/mscom/Interceptor.cpp", "ipc/mscom/Interceptor.h", "ipc/mscom/WeakRef.cpp", "ipc/mscom/WeakRef.h"], "git_node": null, "git_parents": [null], "node": "595c03565718ce48d5c5c81ba6768857cc57588e", "parents": ["68edd6cf79cee701dd8d222bec030d82b7c4df02"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "FIREFOX_59b_RELBRANCH", "desc": "Bug 1433046 - Use WeakReferenceSupport::StabilizeRefCount instead of regular kung-fu death grips when aggregating. r=Jamie, a=RyanVM\n\nThis fix is completely speculative, but I have strong reason to believe that\nwe are having lifetime issues, and that refcount stabilization might be coming\ninto play.\n\nThe situation is this:\n\nSuppose we're aggregating an object, so we pass |this| as the outer IUnknown.\nThe inner object might perform AddRef() and Release() on |this| during its\ninitialization.\n\nBut if we're in the process of creating the outer object, that refcount might\nnot yet have been incremented by 1, so the inner object's invocation of the\nouter object's Release() could trigger a deletion.\n\nThe way around this is to temporarily bump the refcount when aggregating another\nobject. The key, though, is to not do this via AddRef() and Release(), but by\ndirect maniuplation of the refcount variable, so that we don't trigger any of\nthe self-deletion stuff.\n\nMozReview-Commit-ID: 3WA2AJvb6jY", "files": ["ipc/mscom/Interceptor.cpp", "ipc/mscom/WeakRef.cpp", "ipc/mscom/WeakRef.h"], "git_node": null, "git_parents": [null], "node": "98657145435de87ccc459fd074c1b873d1835ee4", "parents": ["595c03565718ce48d5c5c81ba6768857cc57588e"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "FIREFOX_59b_RELBRANCH", "desc": "Bug 1433046 - mscom::Interceptor: Don't destroy an aggregated interceptor before releasing its interface. r=aklotz, a=RyanVM\n\nWhen an object is aggregated, doing a QI to anything other than IUnknown on the inner object AddRefs the outer object.\nThus, before releasing our reference to the inner IUnknown (and thus destroying it), we *must* release any references to interfaces queried from it.\nOtherwise, any pointers to interfaces of the inner object would be invalidated.\n\nMozReview-Commit-ID: KXsA8Sagx6G", "files": ["ipc/mscom/Interceptor.cpp"], "git_node": null, "git_parents": [null], "node": "2761fe655c657cef4aa182bf034b0943c235241e", "parents": ["98657145435de87ccc459fd074c1b873d1835ee4"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "FIREFOX_59b_RELBRANCH", "desc": "Bug 1426006 - Do not expect ion scripts when ion is unavailable. r=bbouvier, a=RyanVM", "files": ["js/src/jsapi-tests/testPreserveJitCode.cpp"], "git_node": null, "git_parents": [null], "node": "d43e9e56d922fd52cfe0e0b1ad7ab7d2fa83adc5", "parents": ["2761fe655c657cef4aa182bf034b0943c235241e"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "FIREFOX_59b_RELBRANCH", "desc": "Bug 1404297 - Add a move constructor to SegmentedVector. r=smaug, a=RyanVM\n\nGiven that we have a SegmentedVector of nsCOMPtrs, it's probably worth\navoiding copying it.\n\nMozReview-Commit-ID: GHyfVLrdnlQ", "files": ["mfbt/SegmentedVector.h"], "git_node": null, "git_parents": [null], "node": "e3862490f52cdd2e1cbce24340c7a1a4888b3e7f", "parents": ["d43e9e56d922fd52cfe0e0b1ad7ab7d2fa83adc5"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "FIREFOX_59b_RELBRANCH", "desc": "Bug 1404297 - Change the way we iterate over our links to update. r=smaug, a=RyanVM\n\nMozReview-Commit-ID: BTADrB9itjh", "files": ["dom/base/nsDocument.cpp", "dom/base/nsIDocument.h"], "git_node": null, "git_parents": [null], "node": "32b9da85402a01147d514d96281e3a59fb356e1b", "parents": ["e3862490f52cdd2e1cbce24340c7a1a4888b3e7f"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "FIREFOX_59b_RELBRANCH", "desc": "Bug 1440775 - Make fetch API force-cache and only-if-cached use VALIDATE_NEVER instead of LOAD_FROM_CACHE. r=mayhemer, a=lizzard", "files": ["netwerk/protocol/http/HttpBaseChannel.cpp"], "git_node": null, "git_parents": [null], "node": "b2bc7a269882f020a5246cec7868f31b788485c5", "parents": ["32b9da85402a01147d514d96281e3a59fb356e1b"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "FIREFOX_59b_RELBRANCH", "desc": "Bug 1441006 - Use unsigned type for SlotsEdge start/count. r=jonco, a=RyanVM", "files": ["js/src/gc/Marking.cpp", "js/src/gc/StoreBuffer.h", "js/src/jit/VMFunctions.cpp"], "git_node": null, "git_parents": [null], "node": "063ac460d42f74ddfaf798710776189c3ed85d11", "parents": ["b2bc7a269882f020a5246cec7868f31b788485c5"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "FIREFOX_59b_RELBRANCH", "desc": "Bug 1437450 - Disable Ion no-clone optimization for regexps if the graph contains try blocks. r=nbp, a=RyanVM", "files": ["js/src/jit/IonAnalysis.cpp"], "git_node": null, "git_parents": [null], "node": "36f58000ec4156241ffa172c6e2aaf3228adc0d7", "parents": ["063ac460d42f74ddfaf798710776189c3ed85d11"], "tags": []}, {"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "FIREFOX_59b_RELBRANCH", "desc": "Bug 1442437 - Rename background_tab_text to tab_background_text. r=jaws, a=lizzard on a CLOSED TREE\n\nMozReview-Commit-ID: LFXUqxuHbBb", "files": ["browser/components/extensions/test/browser/browser_