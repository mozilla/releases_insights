/browser/browser_policies_setAndLockPref_API.js", "browser/components/enterprisepolicies/tests/browser/browser_policies_simple_policies.js", "browser/components/enterprisepolicies/tests/browser/browser_policies_simple_pref_policies.js", "browser/components/enterprisepolicies/tests/browser/browser_policy_clear_blocked_cookies.js", "browser/components/enterprisepolicies/tests/browser/browser_policy_default_browser_check.js", "browser/components/enterprisepolicies/tests/browser/browser_policy_disable_formhistory.js", "browser/components/enterprisepolicies/tests/browser/browser_policy_disable_fxaccounts.js", "browser/components/enterprisepolicies/tests/browser/browser_policy_disable_fxscreenshots.js", "browser/components/enterprisepolicies/tests/browser/browser_policy_disable_pocket.js", "browser/components/enterprisepolicies/tests/browser/browser_policy_enable_tracking_protection.js", "browser/components/enterprisepolicies/tests/browser/browser_policy_proxy.js", "browser/components/enterprisepolicies/tests/browser/browser_policy_remember_passwords.js", "browser/components/enterprisepolicies/tests/browser/browser_policy_set_homepage.js", "browser/components/enterprisepolicies/tests/browser/disable_fxscreenshots/browser.ini", "browser/components/enterprisepolicies/tests/browser/disable_fxscreenshots/browser_policy_disable_fxscreenshots.js", "browser/components/enterprisepolicies/tests/browser/disable_fxscreenshots/config_disable_fxscreenshots.json", "browser/components/enterprisepolicies/tests/browser/head.js", "browser/components/enterprisepolicies/tests/moz.build"], "git_node": null, "git_parents": [null], "node": "45249cb4b63e49e38d91e6424d509579620bb858", "parents": ["8bb565a35f45362c86e7a6844d87b8b260c994fd"], "tags": ["DEVEDITION_60_0b7_BUILD1", "DEVEDITION_60_0b7_RELEASE", "FENNEC_60_0b7_BUILD1", "FENNEC_60_0b7_RELEASE", "FIREFOX_60_0b7_BUILD1", "FIREFOX_60_0b7_RELEASE"]}], "date": 1522082463, "git_changesets": [null, null, null, null, null], "user": "felipc@gmail.com"}, "8926": {"changesets": [{"author": "Ben Hearsum \u003cbhearsum@mozilla.com\u003e", "branch": "default", "desc": "bug 1446160: update verify shouldn't be silent when diffs are found. r=aki, a=release", "files": ["taskcluster/ci/beetmover-cdns/kind.yml", "taskcluster/ci/release-balrog-scheduling/kind.yml", "taskcluster/ci/release-secondary-balrog-scheduling/kind.yml", "taskcluster/ci/release-secondary-update-verify/kind.yml", "taskcluster/ci/release-update-verify/kind.yml"], "git_node": null, "git_parents": [null], "node": "118f7f30f68af571995954f4df4bcd7ca2243947", "parents": ["45249cb4b63e49e38d91e6424d509579620bb858"], "tags": []}], "date": 1522164153, "git_changesets": [null], "user": "bhearsum@mozilla.com"}, "8927": {"changesets": [{"author": "\"Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e\"", "branch": "default", "desc": "No bug - Tagging 45249cb4b63e49e38d91e6424d509579620bb858 with FIREFOX_60_0b7_BUILD1, FIREFOX_60_0b7_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "45ddb8469955670a788b838e06935cedf017b269", "parents": ["118f7f30f68af571995954f4df4bcd7ca2243947"], "tags": []}, {"author": "\"Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e\"", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "e80d0a7c002a3de44a22fe516b4c0aee220e40c2", "parents": ["45ddb8469955670a788b838e06935cedf017b269"], "tags": []}], "date": 1522165244, "git_changesets": [null, null], "user": "ffxbld"}, "8928": {"changesets": [{"author": "\"Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e\"", "branch": "default", "desc": "No bug - Tagging 45249cb4b63e49e38d91e6424d509579620bb858 with DEVEDITION_60_0b7_BUILD1, DEVEDITION_60_0b7_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "80580f479b56c4628cef58dbc0bc86ae911bf26a", "parents": ["e80d0a7c002a3de44a22fe516b4c0aee220e40c2"], "tags": []}], "date": 1522165534, "git_changesets": [null], "user": "ffxbld"}, "8929": {"changesets": [{"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1446116 - Disable timer jitter on test_ext_alarms.js. r=gbrown, a=test-only\n\nMozReview-Commit-ID: 27Z3vIejv8y", "files": ["toolkit/components/extensions/test/xpcshell/test_ext_alarms.js"], "git_node": null, "git_parents": [null], "node": "d1aa2f0b928fdf9c164fae6847523cba0e55a574", "parents": ["80580f479b56c4628cef58dbc0bc86ae911bf26a"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1446394 - Turn off Time Jitter for test_audioParamSetTargetAtTimeZeroTimeConstant.html. r=baku, a=test-only\n\nDisable time jittering when comparing different AudioContexts because they might look\ndifferent.\n\nMozReview-Commit-ID: A3neLqokQ5c", "files": ["dom/media/webaudio/test/test_audioParamSetTargetAtTimeZeroTimeConstant.html"], "git_node": null, "git_parents": [null], "node": "c750b5f15c2b0ef8b2b22faca0c2257f0d9dd6b6", "parents": ["d1aa2f0b928fdf9c164fae6847523cba0e55a574"], "tags": []}, {"author": "vinoth \u003ccegvinoth@gmail.com\u003e", "branch": "default", "desc": "Bug 1433617 - Cache control headers added to png image. r=ckerschb, a=test-only", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/meta/content-security-policy/prefetch-src/prefetch-allowed.html.ini", "testing/web-platform/tests/content-security-policy/prefetch-src/prefetch-allowed.html", "testing/web-platform/tests/content-security-policy/support/file-prefetch-allowed.html"], "git_node": null, "git_parents": [null], "node": "2ac29892c9698adddf973a8dd33c4a2186617350", "parents": ["c750b5f15c2b0ef8b2b22faca0c2257f0d9dd6b6"], "tags": []}, {"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441941 - Limit allocations in SkTDArray. r=jrmuizel, a=jcristau\n\nMozReview-Commit-ID: 97eTGU3sUCC", "files": ["gfx/skia/skia/include/private/SkTDArray.h"], "git_node": null, "git_parents": [null], "node": "6fc09a406b3b2feeb4731d4c11f29be680229b1c", "parents": ["2ac29892c9698adddf973a8dd33c4a2186617350"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1444472 - Fix incorrect clang warning in nsCORSListenerProxy. r=valentin, a=jcristau\n\nOlder versions of clang complain about this code, with:\n\nnetwerk/protocol/http/nsCORSListenerProxy.cpp:230:5: error: default initialization of an object of const type 'const struct CheckHeaderToken' without a user-provided default constructor\n\nLater versions of the standard were amended to make this not an error,\nbut clang still warns.  Pacify clang by making the object not const.", "files": ["netwerk/protocol/http/nsCORSListenerProxy.cpp"], "git_node": null, "git_parents": [null], "node": "c90dadfb2b20b2d74f859f9c1a74fbbb1b909b77", "parents": ["6fc09a406b3b2feeb4731d4c11f29be680229b1c"], "tags": []}, {"author": "Matheus Longaray \u003cmlongaray@hp.com\u003e", "branch": "default", "desc": "Bug 1440638 - Render error message for the Simplify Page document. r=mconley, a=jcristau\n\nThis patch renders error message for the Simplify Page document when\nReader Mode fails to parse original document. This patch also adds a test\nto reliably produce a readable document that returns a parsing error when\nrun through the readability library.\n\nMozReview-Commit-ID: 686mBkU9eVM", "files": ["toolkit/components/printing/tests/browser.ini", "toolkit/components/printing/tests/browser_preview_print_simplify_non_article.js", "toolkit/components/printing/tests/simplifyNonArticleSample.html", "toolkit/content/browser-content.js"], "git_node": null, "git_parents": [null], "node": "545ac09b18b158a5b262a42efb3db83194ccc8e0", "parents": ["c90dadfb2b20b2d74f859f9c1a74fbbb1b909b77"], "tags": []}, {"author": "Matheus Longaray \u003cmlongaray@hp.com\u003e", "branch": "default", "desc": "Bug 1445837 - Fix race condition in toolkit/components/printing/tests/browser_preview_print_simplify_non_article.js. r=mconley, a=test-only\n\nThis patch address a race condition issue for toolkit/components/printing/tests/\nbrowser_preview_print_simplify_non_article.js test added in bug 1440638.\n\nMozReview-Commit-ID: 4X17u2CP4ea", "files": ["toolkit/components/printing/tests/browser_preview_print_simplify_non_article.js"], "git_node": null, "git_parents": [null], "node": "db2d0b1209813f847f33c0aadf23102f5b47f071", "parents": ["545ac09b18b158a5b262a42efb3db83194ccc8e0"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1447262 - BlobURLs must be mutable. r=valentin, a=jcristau", "files": ["dom/file/nsHostObjectProtocolHandler.cpp", "dom/file/nsHostObjectURI.cpp", "testing/web-platform/meta/FileAPI/url/url-with-fetch.any.js.ini"], "git_node": null, "git_parents": [null], "node": "d2a034b874a56cca4189050c5d88e1e6f1bc9361", "parents": ["db2d0b1209813f847f33c0aadf23102f5b47f071"], "tags": []}, {"author": "Jan Odvarko \u003codvarko@gmail.com\u003e", "branch": "default", "desc": "Bug 1448288 - Make devtools.network.getHAR API compatible with Chrome. r=rpl, a=jcristau\n\nMozReview-Commit-ID: 7woAf8iVC3B", "files": ["browser/components/extensions/test/browser/browser_ext_devtools_network.js", "devtools/client/framework/toolbox.js", "devtools/client/netmonitor/initializer.js"], "git_node": null, "git_parents": [null], "node": "c64404c2cc4b394d69de505ddd4e3b55a53cb060", "parents": ["d2a034b874a56cca4189050c5d88e1e6f1bc9361"], "tags": []}, {"author": "Doug Thayer \u003cdothayer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1444290 - Forget bg SDR runnable reference when dispatching. r=froydnj, a=jcristau\n\nWe're seeing a crash in tests from trying to release the promise in\nthis runnable from the background thread we create to run this\nmethod. The only way I can see that happening is that the bg thread\nloses the race with the main thread to drop its reference to the\nrunnable, causing it to call the destructor. Rather than calling the\nhelper that adds a reference to the runnable and then forgets it,\nlet's just forget it here.\n\nMozReview-Commit-ID: LXpC8Kr2SBb", "files": ["security/manager/ssl/SecretDecoderRing.cpp"], "git_node": null, "git_parents": [null], "node": "a47898b26ba9c047abd61fec864b2d16c7496c7c", "parents": ["c64404c2cc4b394d69de505ddd4e3b55a53cb060"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1445475 - Make service worker self-update fallibly store its timer on the private and cleanup if that fails. r=catalinb, a=jcristau", "files": ["dom/serviceworkers/ServiceWorkerPrivate.cpp", "dom/serviceworkers/ServiceWorkerPrivate.h", "dom/serviceworkers/ServiceWorkerRegistrationImpl.cpp"], "git_node": null, "git_parents": [null], "node": "a93e20c50c4b3d7662cc3170e2683bb8db295fb6", "parents": ["a47898b26ba9c047abd61fec864b2d16c7496c7c"], "tags": []}, {"author": "Tooru Fujisawa \u003carai_a@mac.com\u003e", "branch": "default", "desc": "Bug 1402380 - Set text/x-moz-url flavor of data transfer for places container with URLs inside it. r=enndeakin, a=jcristau", "files": ["browser/components/places/tests/browser/browser.ini", "browser/components/places/tests/browser/browser_drag_folder_on_newTab.js", "testing/mochitest/tests/SimpleTest/EventUtils.js", "toolkit/components/places/PlacesUtils.jsm"], "git_node": null, "git_parents": [null], "node": "3ae35e4029264fb326c45042b06948f9fed3a2e2", "parents": ["a93e20c50c4b3d7662cc3170e2683bb8db295fb6"], "tags": []}], "date": 1522176927, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8930": {"changesets": [{"author": "Nick Thomas \u003cnthomas@mozilla.com\u003e", "branch": "default", "desc": "Bug 1449350 - distutils.errors.DistutilsError: Could not find suitable distribution for Requirement.parse('six'), r=aki, a=release DONTBUILD", "files": ["testing/tools/websocketprocessbridge/websocketprocessbridge_requirements.txt"], "git_node": null, "git_parents": [null], "node": "cf9457f7129ac3b711e0a268c976cdaa39133e01", "parents": ["3ae35e4029264fb326c45042b06948f9fed3a2e2"], "tags": []}], "date": 1522191220, "git_changesets": [null], "user": "nthomas@mozilla.com"}, "8931": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nit -\u003e 8dda67185fb3", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "c29c8adf7742e0b8c50abdedf0db46f0e79f544f", "parents": ["cf9457f7129ac3b711e0a268c976cdaa39133e01"], "tags": []}], "date": 1522221626, "git_changesets": [null], "user": "ffxbld"}, "8932": {"changesets": [{"author": "Julien Cristau \u003cjcristau@mozilla.com\u003e", "branch": "default", "desc": "Bug 1447398 - turn off staged rollout for beta60 r=aki a=me DONTBUILD", "files": ["taskcluster/ci/push-apk/kind.yml"], "git_node": null, "git_parents": [null], "node": "f75bc49831f00f2b2d892acd4f0c5d6ba9ee83e5", "parents": ["c29c8adf7742e0b8c50abdedf0db46f0e79f544f"], "tags": []}], "date": 1522223563, "git_changesets": [null], "user": "jcristau@mozilla.com"}, "8933": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nzh-CN -\u003e ccb8a3c8b8fb", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "d05034041835c379a85508b496bc6b5c4463a572", "parents": ["f75bc49831f00f2b2d892acd4f0c5d6ba9ee83e5"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nzh-CN -\u003e 06815a13fa4c", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "1817d09e1811c94acc8912954b08f00525ed368e", "parents": ["d05034041835c379a85508b496bc6b5c4463a572"], "tags": []}], "date": 1522225237, "git_changesets": [null, null], "user": "ffxbld"}, "8934": {"changesets": [{"author": "Julien Cristau \u003cjcristau@mozilla.com\u003e", "branch": "default", "desc": "Post beta 7: unset EARLY_BETA_OR_EARLIER. a=release", "files": ["build/defines.sh"], "git_node": null, "git_parents": [null], "node": "861a4eb681ccaf3f1c5b10dc2b4a44a13b7b73ea", "parents": ["1817d09e1811c94acc8912954b08f00525ed368e"], "tags": []}], "date": 1522240167, "git_changesets": [null], "user": "jcristau@mozilla.com"}, "8935": {"changesets": [{"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1433923 - Use detailed failure message for wdspec test failures (pytest). r=jgraham a=test-only\n\nWhen adding failures to the test report, the hook for pytest_runtest_logreport\nmissed to extract the failure message from the stack, and as such passed in no\nmessage for the failure.\n\nMozReview-Commit-ID: CRhnnONMzbP", "files": ["testing/web-platform/tests/tools/wptrunner/wptrunner/executors/pytestrunner/runner.py"], "git_node": null, "git_parents": [null], "node": "f66887206a10ef7d176226b693be208952bc3868", "parents": ["861a4eb681ccaf3f1c5b10dc2b4a44a13b7b73ea"], "tags": []}, {"author": "Felipe Gomes \u003cfelipc@gmail.com\u003e", "branch": "default", "desc": "Bug 1433172 - Drop the pref that controls the policy engine. r=mossop a=jcristau\n\nThe policy engine should always be enabled, with no way to disable it.\n\nMozReview-Commit-ID: 9HGew1S33q1", "files": ["browser/app/profile/firefox.js", "browser/components/enterprisepolicies/EnterprisePolicies.js", "browser/components/enterprisepolicies/tests/browser/browser.ini", "browser/components/enterprisepolicies/tests/browser/disable_app_update/browser.ini", "browser/components/enterprisepolicies/tests/browser/disable_default_bookmarks/browser.ini", "browser/components/enterprisepolicies/tests/browser/disable_developer_tools/browser.ini", "browser/components/enterprisepolicies/tests/browser/disable_fxscreenshots/browser.ini", "toolkit/mozapps/extensions/test/xpcshell/test_system_update_enterprisepolicy.js"], "git_node": null, "git_parents": [null], "node": "797a21d3bca62037bf58cb0a849eddbeb0202800", "parents": ["f66887206a10ef7d176226b693be208952bc3868"], "tags": []}, {"author": "Kirk Steuber \u003cksteuber@mozilla.com\u003e", "branch": "default", "desc": "Bug 1428948 - Add policies to modify the available search engines r=Felipe,florian a=jcristau\n\nThis adds a policy with the capability of adding search engines, choosing the default search engine, and blocking the installation of new search engines.\n\nAdditionally, fixes the messages for errors reported by MainProcessSingleton.addSearchEngine so that the offending URL is printed rather than \"[xpconnect wrapped nsIURI]\".\n\nMozReview-Commit-ID: HuLT15Rnq0r", "files": ["browser/components/enterprisepolicies/Policies.jsm", "browser/components/enterprisepolicies/schemas/policies-schema.json", "browser/components/enterprisepolicies/tests/browser/browser.ini", "browser/components/enterprisepolicies/tests/browser/browser_policy_search_engine.js", "browser/components/enterprisepolicies/tests/browser/opensearch.html", "browser/components/enterprisepolicies/tests/browser/opensearchEngine.xml", "browser/components/preferences/in-content/search.js", "browser/modules/ContentLinkHandler.jsm", "toolkit/components/processsingleton/MainProcessSingleton.js"], "git_node": null, "git_parents": [null], "node": "6a48752640f539013f5af6c3a516de315ce81c69", "parents": ["797a21d3bca62037bf58cb0a849eddbeb0202800"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1431256 part 1: Accessible HandlerProvider: Implement a method to optimally retrieve all children in a single call. r=MarcoZ a=jcristau\n\nWhen considering a large document, a huge number of the children we return are text leaf nodes.\nMarshaling full objects is expensive, but for text leaf nodes, the client is only interested in the text and a few other pieces of information.\nTherefore, rather than returning the full object for text leaf accessibles, we just return the text and other necessary information.\nFor other non-text children, we return the full object as usual.\n\nIn addition, clients normally use the IEnumVARIANT interface to retrieve children in a single call.\nHowever, it doesn't allow you to specify a starting index.\nTherefore, you must first call the Reset method to reset the starting point to 0.\nPractically, this means an extra cross-process call whenever the caller fetches children.\nWhen dealing with a large document, this can be a significant number of wasted calls.\nThis new method retrieves all children always starting at the first using a single call.\n\nMozReview-Commit-ID: A9lc7BBTWdb", "files": ["accessible/ipc/win/HandlerProvider.cpp", "accessible/ipc/win/HandlerProvider.h", "accessible/ipc/win/handler/HandlerData.idl"], "git_node": null, "git_parents": [null], "node": "b319326019dff8a3c5600ad625acbf12e69e8a83", "parents": ["6a48752640f539013f5af6c3a516de315ce81c69"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1431256 part 2: AccessibleHandler: Implementation of IAccessible2 for text leaf accessibles using data provided in AccChildData. r=MarcoZ a=jcristau\n\nFor text leaf accessibles, the HandlerProvider::AllChildren property provides text and other necessary information in an AccChildData struct, rather than providing the full accessible object.\nTherefore, we must provide a specific local implementation of IAccessible2 which answers queries based on the data provided in this struct.\n\nMozReview-Commit-ID: 8BYMF59EoTe", "files": ["accessible/ipc/win/handler/HandlerTextLeaf.cpp", "accessible/ipc/win/handler/HandlerTextLeaf.h", "accessible/ipc/win/handler/moz.build"], "git_node": null, "git_parents": [null], "node": "c0512d8cd20fba291b1777561e75863206152a3d", "parents": ["b319326019dff8a3c5600ad625acbf12e69e8a83"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1431256 part 3: AccessibleHandler: When a client requests children, fetch them optimally using a single cross-process call. r=MarcoZ a=jcristau\n\nThis implements IEnumVARIANT locally using the new method provided by HandlerProvider.\nThis avoids marshaling full objects for text leaf accessibles (instead using HandlerTextLeaf), which is much faster.\nIt also avoids a pointless cross-process call to IEnumVARIANT::Reset (and possibly IEnumVARIANT::Clone).\nFinally, it caches children after the first query so that clients (such as UI Automation) which walk children one by one don't incur separate cross-process calls for every child.\n\nMozReview-Commit-ID: KUIXQoXxInQ", "files": ["accessible/ipc/win/handler/AccessibleHandler.cpp", "accessible/ipc/win/handler/HandlerChildEnumerator.cpp", "accessible/ipc/win/handler/HandlerChildEnumerator.h", "accessible/ipc/win/handler/moz.build"], "git_node": null, "git_parents": [null], "node": "df06bf127293c21f69e464bf4684ee0256459f52", "parents": ["c0512d8cd20fba291b1777561e75863206152a3d"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1431256 part 4: Remove IEnumVARIANT from the AccessibleHandler payload. r=MarcoZ a=jcristau\n\nNow that the handler implements IEnumVARIANT itself (and uses our own internal method to retrieve the children), caching this remote interface is pointless.\n\nMozReview-Commit-ID: FyagiEcHMP2", "files": ["accessible/ipc/win/HandlerProvider.cpp", "accessible/ipc/win/handler/AccessibleHandler.cpp", "accessible/ipc/win/handler/HandlerData.idl", "accessible/ipc/win/handler/HandlerDataCleanup.h"], "git_node": null, "git_parents": [null], "node": "57eb2c7e72d966b03f4eea6d9214fb8c83ef4f01", "parents": ["df06bf127293c21f69e464bf4684ee0256459f52"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1431256 correction: AccessibleHandler: Really return E_NOINTERFACE for IEnumVARIANT if there are no children. r=MarcoZ a=jcristau\n\nA typo meant we were checking the address of mChildCount, not the value.\n\nMozReview-Commit-ID: 7Hit3FBy9pr", "files": ["accessible/ipc/win/handler/AccessibleHandler.cpp"], "git_node": null, "git_parents": [null], "node": "983fc859d6ac5e2aff690ec746b392eb17936386", "parents": ["57eb2c7e72d966b03f4eea6d9214fb8c83ef4f01"], "tags": []}], "date": 1522242483, "git_changesets": [null, null, null, null, null, null, null, null], "user": "csabou@mozilla.com"}, "8936": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nan -\u003e 15f8a676acc9\nbg -\u003e df4568e60241\nen-GB -\u003e 26ffff084a87\neo -\u003e 3239cd34090c\nfr -\u003e 739d55628921\nfy-NL -\u003e e558cf7e860b\nhe -\u003e 47ba1f7edde5\nhy-AM -\u003e da1776f88a74\nit -\u003e 8dda67185fb3\nmy -\u003e 89f91484960c\npl -\u003e c4e3f90faf14\nsk -\u003e a60d7dcfd1c6\nsl -\u003e d4b862b16d80\nth -\u003e f8b44da4878e\nuk -\u003e 02ce6f4fa782\nzh-CN -\u003e 919a7a5b2934", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "881aa29b8132a54db48fd7ca6ae62a16ec0d9356", "parents": ["983fc859d6ac5e2aff690ec746b392eb17936386"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nan -\u003e 15f8a676acc9\nar -\u003e 7d7198ab681d\nbg -\u003e df4568e60241\nbr -\u003e 9e49f5a0c45c\ncs -\u003e 832da5337f9e\nen-GB -\u003e 0cfb5eaccf36\nes-AR -\u003e 8a6fc04c6897\nes-ES -\u003e c2cb9a9d8e89\nes-MX -\u003e ae299db4df89\nfr -\u003e 739d55628921\nfy-NL -\u003e e558cf7e860b\nhe -\u003e 1b3725111e6e\nhi-IN -\u003e c941c1886108\nhy-AM -\u003e 23ba8c0e6e7e\nis -\u003e ace41a932742\nka -\u003e 07d095592ff7\nkab -\u003e 4c109d39fd92\nkk -\u003e 5f8f075e1544\nkn -\u003e 3ec8fe33cf39\nlij -\u003e ee56445ced0c\nmy -\u003e e21b8ebcda4d\nne-NP -\u003e 42fb7cac45c6\nnl -\u003e ae73daf62fcf\nnn-NO -\u003e 9ce1cc0d441b\npl -\u003e c4e3f90faf14\npt-PT -\u003e 74a46967ea74\nro -\u003e baea76fd3515\nsk -\u003e f3bfe1141747\nsl -\u003e d4b862b16d80\nth -\u003e f8b44da4878e\ntr -\u003e f7a870e8bb1a\nzh-CN -\u003e 919a7a5b2934", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "ee86e817eb4dcc9bf91ef2f6811b66ee2583c969", "parents": ["881aa29b8132a54db48fd7ca6ae62a16ec0d9356"], "tags": []}], "date": 1522250426, "git_changesets": [null, null], "user": "ffxbld"}, "8937": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nkn -\u003e c4d3880a6134", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "a05c481b9b02da41145cb02aa65a14c2913b890e", "parents": ["ee86e817eb4dcc9bf91ef2f6811b66ee2583c969"], "tags": []}], "date": 1522254028, "git_changesets": [null], "user": "ffxbld"}, "8938": {"changesets": [{"author": "Felipe Gomes \u003cfelipc@gmail.com\u003e", "branch": "default", "desc": "Bug 1448198 - Make the DisplayBookmarksBar and DisplayMenuBar policies support both true and false params. r=bytesized a=jcristau", "files": ["browser/components/enterprisepolicies/Policies.jsm"], "git_node": null, "git_parents": [null], "node": "7481388f152426ebce47ccc3fb8c3fa6ecef053f", "parents": ["a05c481b9b02da41145cb02aa65a14c2913b890e"], "tags": []}], "date": 1522254251, "git_changesets": [null], "user": "felipc@gmail.com"}, "8939": {"changesets": [{"author": "\"Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e\"", "branch": "default", "desc": "No bug - Tagging 45249cb4b63e49e38d91e6424d509579620bb858 with FENNEC_60_0b7_BUILD1, FENNEC_60_0b7_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "43348f3afca0649b2be21aca87d99e2920b9ad34", "parents": ["7481388f152426ebce47ccc3fb8c3fa6ecef053f"], "tags": []}], "date": 1522256029, "git_changesets": [null], "user": "ffxbld"}, "8940": {"changesets": [{"author": "Paul Adenot \u003cpaul@paul.cx\u003e", "branch": "default", "desc": "Bug 1441509 - Start performing the analysis in test_seamless_looping.html after the second loop, to let things stabilize. r=karlt, a=test-only\n\nMozReview-Commit-ID: 5FK30GNk4s5", "files": ["dom/media/test/test_seamless_looping.html"], "git_node": null, "git_parents": [null], "node": "8f2fb6d4789019371c1817c5d2e42afa7dc3b6a7", "parents": ["43348f3afca0649b2be21aca87d99e2920b9ad34"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1405453 - Enable browser/components/extensions/test/browser/test-oop-extensions/browser_ext_browserAction_context.js for osx/windows. r=Oriol, a=test-only", "files": ["browser/components/extensions/test/browser/browser-common.ini"], "git_node": null, "git_parents": [null], "node": "2d0988f0d5c66c0b028cba97ac57dd7a5200190f", "parents": ["8f2fb6d4789019371c1817c5d2e42afa7dc3b6a7"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1446993 - Observe restyling count in `fixed 20` frames instead of tweaked count. r=birtles, a=test-only\n\nIn bug 1444177, I did accidentally replace the frame count with the tweaked\ncount.  The tweaked count represents that animation restyling should happen\nthe tweaked count times during *not-yet-tweaked* frame count.\n\nMozReview-Commit-ID: 1QmH5xaYexL", "files": ["dom/animation/test/mozilla/file_restyles.html"], "git_node": null, "git_parents": [null], "node": "098f8358feea26b6de30da4599014ccc25ba87d1", "parents": ["2d0988f0d5c66c0b028cba97ac57dd7a5200190f"], "tags": []}, {"author": "Georg Koppen \u003cgk@torproject.org\u003e", "branch": "default", "desc": "Bug 1442406 - Fix intermittent test failure of browser_no_mcb_for_onions.js test. r=ckerschb, a=test-only", "files": ["browser/base/content/test/siteIdentity/browser_no_mcb_for_onions.js"], "git_node": null, "git_parents": [null], "node": "f556bd020e0837f7c710beac70e85b3250fb2761", "parents": ["098f8358feea26b6de30da4599014ccc25ba87d1"], "tags": []}, {"author": "Tomislav Jovanovic \u003ctomica@gmail.com\u003e", "branch": "default", "desc": "Bug 1438025 - Drop invisible characters from downloads filename. r=kmag, r=Paolo, a=RyanVM", "files": ["toolkit/components/downloads/DownloadPaths.jsm", "toolkit/components/downloads/test/unit/test_DownloadPaths.js"], "git_node": null, "git_parents": [null], "node": "4702ec51711e54109358c3d7982c323543184353", "parents": ["f556bd020e0837f7c710beac70e85b3250fb2761"], "tags": []}, {"author": "Bob Owen \u003cbobowencode@gmail.com\u003e", "branch": "default", "desc": "Bug 1449480: Don't crash in opt builds when scoped_handle.cc CloseHandleWrapper fails. r=jimm, a=RyanVM\n\nI'm not adding a patch to security/sandbox/chromium-shim/patches for this,\nbecause we need to get this fixed ASAP, certainly before we take another update.", "files": ["security/sandbox/chromium/base/win/scoped_handle.cc"], "git_node": null, "git_parents": [null], "node": "17b23e75aceb41443341e8de0802f7b9d40e6040", "parents": ["4702ec51711e54109358c3d7982c323543184353"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1448091 - Part 1: Accessible HandlerProvider: Return an error if refreshing the cache fails. r=MarcoZ, a=jcristau\n\nBuildDynamicIA2Data can't return an HRESULT; failure is communicated by the fact that the unique id in the data is set to 0.\nHowever, IGeckoBackChannel::Refresh returned S_OK even if BuildDynamicIA2Data failed.\nWe now check the unique id and return an appropriate error code if it's 0.\nAmong other things, this means that the handler will return an error when querying dead objects instead of returning stale cache data.\n\nMozReview-Commit-ID: IorDRHCItD8", "files": ["accessible/ipc/win/HandlerProvider.cpp"], "git_node": null, "git_parents": [null], "node": "50c5d93932ca95a27cb9ddb5d9af37dc0c0d0ce1", "parents": ["17b23e75aceb41443341e8de0802f7b9d40e6040"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1448091 - Part 2: AccessibleHandler: Don't repeatedly and unnecessarily refresh the cache after the first change. r=MarcoZ, a=jcristau\n\nThe singleton AccessibleHandlerControl maintains a global cache generation counter which is incremented whenever any node is changed.\nThe handler for each node tracks the cache generation at the time its cache was initialized.\nTo check whether the cache needs to be updated, the handler compares its generation against the global generation from AccessibleHandlerControl.\nIf they differ, it refreshes the cache.\nPreviously, the handler didn't update its cache generation after refreshing.\nThis meant that every single query after the first change would refresh the whole cache, even if there wasn't a second change.\nThis resulted in a huge number of wasted cache updates for clients such as JAWS which hold onto accessibles, rather than releasing them and fetching them again for each update.\n\nMozReview-Commit-ID: 80d4n1cIjzQ", "files": ["accessible/ipc/win/handler/AccessibleHandler.cpp"], "git_node": null, "git_parents": [null], "node": "880bdfaff98ec3098a2fd2ea50c29c52b540ee53", "parents": ["50c5d93932ca95a27cb9ddb5d9af37dc0c0d0ce1"], "tags": []}, {"author": "Masatoshi Kimura \u003cVYV03354@nifty.ne.jp\u003e", "branch": "default", "desc": "Bug 1448071 - Support UNC paths for spell check dictionaries. r=masayuki, a=jcristau\n\nMozReview-Commit-ID: 5Ig2SZKf44R", "files": ["extensions/spellcheck/hunspell/glue/mozHunspell.cpp"], "git_node": null, "git_parents": [null], "node": "8b2c7b0546e96f508fc2608f3cc8a627518948d2", "parents": ["880bdfaff98ec3098a2fd2ea50c29c52b540ee53"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1433037 - WindowsPreviewPerTab should use decodeImageAsync. r=aosmond, a=RyanVM", "files": ["browser/modules/WindowsPreviewPerTab.jsm"], "git_node": null, "git_parents": [null], "node": "1a6f6fdaa772538a85509ff524da1bf6ed3d44c3", "parents": ["8b2c7b0546e96f508fc2608f3cc8a627518948d2"], "tags": []}, {"author": "Bryce Van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1447821 - Update EMEDecoderModule to handle profile values \u003c 1. r=jya, a=jcristau\n\nUpdate EMEDecoderModule to use 2 as profile number when the given profile is\nless than 1 or greater than 4. The CDM doesn't appear to care what values are\ngiven, but 2 was chosen as a safe fallback per discussion on the bug. This\naddresses the use case where 0 values are stored in mProfile due to the use of\nextended profiles (which are then stored in the mExtendedProfile field).\n\nMozReview-Commit-ID: 5XgabNDsgdf", "files": ["dom/media/platforms/agnostic/eme/EMEDecoderModule.cpp"], "git_node": null, "git_parents": [null], "node": "0db4e4e9ce11ba8310d7691cc13e235117d74e76", "parents": ["1a6f6fdaa772538a85509ff524da1bf6ed3d44c3"], "tags": []}, {"author": "Bryce Van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1447821 - Add logging to ADTSSampleConverter ctor. r=jya, a=jcristau\n\nAdd logging to aid in debugging of our EME ADTS conversion path.\n\nMozReview-Commit-ID: A7Wv8n31V8V", "files": ["dom/media/platforms/agnostic/eme/EMEDecoderModule.cpp"], "git_node": null, "git_parents": [null], "node": "a125dbf2164331723be980d0454975cd81b9ed85", "parents": ["0db4e4e9ce11ba8310d7691cc13e235117d74e76"], "tags": []}], "date": 1522264274, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8941": {"changesets": [{"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1409440. r=tnikkel, a=RyanVM", "files": ["image/Downscaler.cpp", "image/DownscalingFilter.h"], "git_node": null, "git_parents": [null], "node": "e724c32284b2f36ced44da4a3493b3634d8352f2", "parents": ["a125dbf2164331723be980d0454975cd81b9ed85"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1443092 - Avoid calling SVGAnimatedEnumeration::AnimVal() from nsSVGUtils::GetBBox(). r=jwatt, a=RyanVM\n\nAnimVal() is a DOM getter, and it flushes animations, which we don't want\nin GetBBox() which is called from display list building cide and\nFrameLayerBuilder.\n\nMozReview-Commit-ID: 80DyTcGs5io", "files": ["dom/svg/SVGClipPathElement.cpp", "dom/svg/SVGClipPathElement.h", "layout/svg/nsSVGUtils.cpp"], "git_node": null, "git_parents": [null], "node": "16307dd2fdf1afc83ca85eb60fa22ad3ee05df16", "parents": ["e724c32284b2f36ced44da4a3493b3634d8352f2"], "tags": []}, {"author": "Jeff Gilbert \u003cjgilbert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1444086 - TlsScope should use WeakPtr. r=jrmuizel, a=RyanVM\n\nMozReview-Commit-ID: DX99PqmxMpF", "files": ["gfx/gl/GLContext.h"], "git_node": null, "git_parents": [null], "node": "17a3b84a2ac3689c682b7ec69d4ea49af9b39af2", "parents": ["16307dd2fdf1afc83ca85eb60fa22ad3ee05df16"], "tags": []}, {"author": "Matthew Gaudet \u003cmgaudet@mozilla.com\u003e", "branch": "default", "desc": "Bug 1448136 - Ensure Debug OSR transition is respected in InstanceOf Fallback stub. r=jandem, a=RyanVM", "files": ["js/src/jit-test/tests/cacheir/bug1448136.js", "js/src/jit/BaselineIC.cpp"], "git_node": null, "git_parents": [null], "node": "bfe7012b7d583b9f4fa3ff305bc569c0688cd1d3", "parents": ["17a3b84a2ac3689c682b7ec69d4ea49af9b39af2"], "tags": []}], "date": 1522267046, "git_changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "8942": {"changesets": [{"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1449499 - Fix fullscreen_window.py:test_handle_prompt_missing_value for wrong dialog reference. r=ato, a=test-only\n\nMozReview-Commit-ID: GhQzudT6D1u", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/meta/webdriver/tests/fullscreen_window.py.ini", "testing/web-platform/tests/webdriver/tests/fullscreen_window.py"], "git_node": null, "git_parents": [null], "node": "50c2162dfe7fa9c81070734a2fa7596f84ea9465", "parents": ["bfe7012b7d583b9f4fa3ff305bc569c0688cd1d3"], "tags": []}, {"author": "Kirk Steuber \u003cksteuber@mozilla.com\u003e", "branch": "default", "desc": "Bug 1447345 - Change enterprise policy that sets homepage to set it as the default rather than the user value for the pref. r=Felipe, a=jcristau\n\nAdditionally removes a stray debugging line that I accidentally checked into the tree previously.\n\nMozReview-Commit-ID: 7F2S8WBgKCj", "files": ["browser/components/enterprisepolicies/Policies.jsm", "browser/components/enterprisepolicies/tests/EnterprisePolicyTesting.jsm"], "git_node": null, "git_parents": [null], "node": "0e8ea2c1220af0aab1aae4806e842516c5404da1", "parents": ["50c2162dfe7fa9c81070734a2fa7596f84ea9465"], "tags": []}, {"author": "Shane Caraveo \u003cscaraveo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1447796 - Fix closing page action panels using commands. r=rpl, a=jcristau\n\nIf commands are used with the page action panel, they will toggle open or\nclosed.  We need to keep a handle on our custom panel so we can close it.\n\nMozReview-Commit-ID: JfxwlyK8g8g", "files": ["browser/components/extensions/ext-pageAction.js", "browser/components/extensions/test/browser/browser_ext_commands_execute_page_action.js"], "git_node": null, "git_parents": [null], "node": "8f10c0a7a87fec424520e133e0038bf338324b02", "parents": ["0e8ea2c1220af0aab1aae4806e842516c5404da1"], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1444537 - Part 1: Ensure discarding of animated image frames is clear. r=tnikkel, a=jcristau\n\nWe should only attempt to discard animation image frames after passing\nthe frame threshold on the very first pass on the animation. Redecodes\nare already in the correct state, as it will discard frames as it\nadvances the animation. This patch makes it clear what it should be\ndoing when, but there should be no functional change.", "files": ["image/AnimationFrameBuffer.cpp"], "git_node": null, "git_parents": [null], "node": "9c6d282fa4b4c91ddfd7054e95cff07eecaa893c", "parents": ["8f10c0a7a87fec424520e133e0038bf338324b02"], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1444537 - Part 2: Shutting down the decode pool should make animated decoders bail early. r=tnikkel, a=jcristau\n\nWhen we shutdown the decode pool threads, it does not do a simple join\nwith the main thread. It will actually process the main thread event\nloop, which can cause a bad series of events. The refresh tick could\nstill be running and advancing our animated images, causing the animated\ndecoders to continue running, which in turn prevents the decoder threads\nfrom finishing shutting down, and the main thread from joining them.\n\nNow we check on each frame whether or not the decoder should just stop\ndecoding more frames because the decode pool has started shutdown. If it\nhas, it will stop immediately.", "files": ["image/AnimationSurfaceProvider.cpp", "image/DecodePool.cpp", "image/DecodePool.h"], "git_node": null, "git_parents": [null], "node": "a9b81a287bd326bbb6df92092d59b9bcb66db73d", "parents": ["9c6d282fa4b4c91ddfd7054e95cff07eecaa893c"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1448612 - Don't take ownership of the stream data too early. r=baku, a=RyanVM\n\nMozReview-Commit-ID: 8e8PNR9NvwW", "files": ["dom/fetch/FetchConsumer.cpp"], "git_node": null, "git_parents": [null], "node": "901288518dfd72bef560f8003f2eabcf75767aad", "parents": ["a9b81a287bd326bbb6df92092d59b9bcb66db73d"], "tags": []}, {"author": "Kirk Steuber \u003cksteuber@mozilla.com\u003e", "branch": "default", "desc": "Bug 1448085 - Fix the enterprise policy to set homepage to use the correct mechanism for setting complex prefs. r=Felipe, a=jcristau\n\nMozReview-Commit-ID: 4rGa9TWSEgw", "files": ["browser/components/enterprisepolicies/Policies.jsm", "browser/components/enterprisepolicies/tests/browser/browser_policy_set_homepage.js"], "git_node": null, "git_parents": [null], "node": "45de343ccebdb6b6c28ebf4dd9f4acef0bb92015", "parents": ["901288518dfd72bef560f8003f2eabcf75767aad"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1449018 - The bookmark panel should listen to keypress event at the system event group. r=mak, a=jcristau\n\nThe bookmark panel should handle keypress events at the system event group\nbecause it needs to handle keypress events after autocomplete module which\nhandles keypress events at the system event group.\n\nMozReview-Commit-ID: 9KjBlQ59gHw", "files": ["browser/base/content/browser-places.js", "browser/base/content/test/general/browser_bookmark_popup.js"], "git_node": null, "git_parents": [null], "node": "294c100c1a17f2087ad712fab7861521ef4247ef", "parents": ["45de343ccebdb6b6c28ebf4dd9f4acef0bb92015"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1448771 - Update hnjstdio to handle additional functions from stdio.h that libhyphen wants to use. r=glandium, a=RyanVM", "files": ["intl/hyphenation/glue/hnjalloc.h", "intl/hyphenation/glue/hnjstdio.cpp"], "git_node": null, "git_parents": [null], "node": "2f2e601e1394cbe2965a65f0218708eec9d5b81d", "parents": ["294c100c1a17f2087ad712fab7861521ef4247ef"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1448771 - Merge fix from upstream. r=ryanvm, a=RyanVM", "files": ["intl/hyphenation/hyphen/hyphen.c"], "git_node": null, "git_parents": [null], "node": "75cefda36f283a32b8b48f5ac7924f4d41b44463", "parents": ["2f2e601e1394cbe2965a65f0218708eec9d5b81d"], "tags": []}], "date": 1522332595, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8943": {"changesets": [{"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1447969 - r=nchevobbe,a=abillings", "files": ["devtools/client/debugger/new/debugger.js", "devtools/client/webconsole/console-output.js"], "git_node": null, "git_parents": [null], "node": "2bb8a74aa36cfb0430bfdab09adb7fcce0dab1c7", "parents": ["75cefda36f283a32b8b48f5ac7924f4d41b44463"], "tags": []}], "date": 1522337981, "git_changesets": [null], "user": "gijskruitbosch@gmail.com"}, "8944": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1448612 - Mark ContinueConsumeBodyControlRunnable as explicit to make the static analysis happy. r=emilio, a=bustage", "files": ["dom/fetch/FetchConsumer.cpp"], "git_node": null, "git_parents": [null], "node": "da6d3b5f248b266857f9a1a434b9ea35a4ecde50", "parents": ["2bb8a74aa36cfb0430bfdab09adb7fcce0dab1c7"], "tags": []}, {"author": "Brian Grinstead \u003cbgrinstead@mozilla.com\u003e", "branch": "default", "desc": "Bug 1447052 - Set up LightweightThemeConsumer in onDOMContentLoaded instead of onLoad. r=dao, a=jcristau\n\nThis is specifically for Fx60 uplift, since the patch landed for Fx61 used onBeforeInitialXULLayout\nwhich isn't available on earlier releases.", "fi