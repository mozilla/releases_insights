 in more places, r=froydnj\n\nMozReview-Commit-ID: K1lkVr6KdZo\n", "files": ["ipc/ipdl/ipdl/lower.py"], "git_node": null, "git_parents": [null], "node": "3dcd0320b88c3662b6a83ddb4ee8063584a56883", "parents": ["016d3604bf18a6c03438e4494d642bdd68e115b4"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1440511 - Part 7: Include c++ includes in ipdlh generated .cpp files, r=froydnj\n\nThis is important as these includes are often used to define ParamTraits\nimplementations which are needed to serialize struct members and\nparameters. The place where the code which uses these implementations\nwill be moving from the protocol where they are used to the file where\nthe structs are defined, which means we need to includes these files\nthere.\n\nMozReview-Commit-ID: H1wqgyv5mel\n", "files": ["ipc/ipdl/ipdl/lower.py"], "git_node": null, "git_parents": [null], "node": "53b7368786a6c4c25b81ebd7eb3fb3da6a525b23", "parents": ["3dcd0320b88c3662b6a83ddb4ee8063584a56883"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1440511 - Part 8: Include ParamTraits impls which are used in ipdlh files, r=froydnj\n\nMozReview-Commit-ID: 9AfzlhyTgsY\n", "files": ["dom/ipc/DOMTypes.ipdlh", "dom/media/gmp/GMPTypes.ipdlh", "gfx/layers/ipc/WebRenderMessages.ipdlh", "gfx/layers/wr/WebRenderMessageUtils.h"], "git_node": null, "git_parents": [null], "node": "13bcebbf334e7b45abbf640debdbe4d987953414", "parents": ["53b7368786a6c4c25b81ebd7eb3fb3da6a525b23"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1440511 - Part 9: Correct serialization and deserialization of arrays of Shmem objects, r=froydnj\n\nMozReview-Commit-ID: KEFduw2Pn8r\n", "files": ["gfx/layers/wr/WebRenderBridgeChild.cpp", "ipc/ipdl/ipdl/lower.py"], "git_node": null, "git_parents": [null], "node": "5005aa065ba5300decb126e6cc0eab62c551d75b", "parents": ["13bce