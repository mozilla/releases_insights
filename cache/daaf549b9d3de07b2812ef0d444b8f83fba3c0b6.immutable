hsBRfg", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "fffb18b9cb46e4ed9b323d94283e6fdc64419d13", "parents": ["a95b0b28ca16d84b92b3831c9ff12297254cd048"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1444169 Fix capitalization for a few Windows files r=aklotz\n\nMozReview-Commit-ID: BlWgIVobOBK", "files": ["accessible/ipc/win/handler/HandlerDataCleanup.h", "gfx/layers/d3d11/CompositorD3D11.cpp", "toolkit/crashreporter/minidump-analyzer/Win64ModuleUnwindMetadata.cpp", "toolkit/crashreporter/minidump-analyzer/Win64ModuleUnwindMetadata.h", "tools/fuzzing/libfuzzer/FuzzerUtilWindows.cpp"], "git_node": null, "git_parents": [null], "node": "93b6538bc167b53884d1a8590f0e2f67f124c358", "parents": ["fffb18b9cb46e4ed9b323d94283e6fdc64419d13"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1401195 - Make double-clicking draggable parts of the window always do the titlebar-double-click action, regardless of whether the click targeted the titlebar or some other draggable element. r=spohl\n\nIn the past there were cases where treating double click behavior differently from draggability\nwas necessary, but there don't seem to exist such cases any more. For example, we don't have any\nwindows with bottom bars / draggable status bars any more.\nThis change simplifies the code and frees the frontend from having to use special -moz-appearance\nvalues to indicate titlebary parts of the window.\n\nMozReview-Commit-ID: IRe3FPU2EaT", "files": ["widget/cocoa/nsChildView.mm"], "git_node": null, "git_parents": [null], "node": "5e9db9c66ccdbe20d8ebb8c498a4385c4dc54ea0", "parents": ["93b6538bc167b53884d1a8590f0e2f67f124c358"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1435959 - Fix missing network requests in netmonitor panel for oop extensions. r=ochameau\n\nMozReview-Commit-ID: F8jzwBveACm", "files": ["browser/components/extensions/test/browser/browser-common.ini", "browser/components/extensions/test/browser/browser_ext_addon_debugging_netmonitor.js", "devtools/client/framework/ToolboxProcess.jsm", "devtools/server/actors/webconsole.js", "devtools/server/actors/webextension.js"], "git_node": null, "git_parents": [null], "node": "e561c88fc549429f597dd0c3b93cbbcbedfd009f", "parents": ["5e9db9c66ccdbe20d8ebb8c498a4385c4dc54ea0"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1444507: Remove unused binding functions. r=bholley\n\nMozReview-Commit-ID: EGceLrhKVIm", "files": ["layout/style/ServoBindings.cpp", "layout/style/ServoBindings.h", "layout/style/ServoUtils.h"], "git_node": null, "git_parents": [null], "node": "2ea235b4dedb3f3141f1fd845df0c20935361a16", "parents": ["e561c88fc549429f597dd0c3b93cbbcbedfd009f"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1444209 - Update expiration date for mobile session restore failure telemetry. r=liuche\n\nMozReview-Commit-ID: FgwH8uyvqSe", "files": ["toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "a82647c958da3525ac24ec5b9410d4c8b01644f3", "parents": ["2ea235b4dedb3f3141f1fd845df0c20935361a16"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441102 - Replace --titlebar-text-color with a class. r=florian\n\nMozReview-Commit-ID: 9ruAARse3LU", "files": ["browser/base/content/browser.xul", "browser/themes/windows/browser-aero.css", "browser/themes/windows/browser.css", "browser/themes/windows/compacttheme.css"], "git_node": null, "git_parents": [null], "node": "275400cc371d1710e698f60d350f436e1d4e4349", "parents": ["a82647c958da3525ac24ec5b9410d4c8b01644f3"], "tags": []}, {"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442020 - Ensure neither style nor layout flushes are required when running promiseDocumentFlushed callbacks. r=bz\n\nMozReview-Commit-ID: INGpltVvNmZ", "files": ["dom/base/nsGlobalWindowInner.cpp", "dom/base/test/browser_promiseDocumentFlushed.js", "layout/base/nsIPresShell.h"], "git_node": null, "git_parents": [null], "node": "ef78c1a7149dfeb3b564d29ba5e2f2ea4beaaea9", "parents": ["275400cc371d1710e698f60d350f436e1d4e4349"], "tags": []}, {"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442020 - Make PanelMultiView's description height workaround account for the possibility that panels have closed before a refresh driver tick. r=Paolo\n\nMozReview-Commit-ID: IIjGYjoxMx5", "files": ["browser/components/customizableui/PanelMultiView.jsm"], "git_node": null, "git_parents": [null], "node": "e506d81c512b7312a46f85c780d0d62b4978bf4e", "parents": ["ef78c1a7149dfeb3b564d29ba5e2f2ea4beaaea9"], "tags": []}, {"author": "Ted Campbell \u003ctcampbell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1408673 - Update EnvironmentObject comments for Gecko r=kmag\n\nMozReview-Commit-ID: AIt3eQ33k7m", "files": ["js/src/vm/EnvironmentObject.h"], "git_node": null, "git_parents": [null], "node": "45b3adc56a5338592e0973ef78c03c957e059bfe", "parents": ["e506d81c512b7312a46f85c780d0d62b4978bf4e"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442250 - 1. Add SessionLifecycleTest; r=esawin\n\nAdd session lifecycle tests for testing behavior for\nopenWindow/closeWindow, Parcelable support, and how some methods behave\nwhen the session is open.\n\nMozReview-Commit-ID: 4UfBRY1pLv6", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/SessionLifecycleTest.kt", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSessionSettings.java"], "git_node": null, "git_parents": [null], "node": "c11a0b091095465c85c37b7b6b35f18714a1c796", "parents": ["45b3adc56a5338592e0973ef78c03c957e059bfe"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442250 - 2. Unregister then re-register all listeners on close; r=esawin\n\nEnsure that we unregister and re-register all listeners on\ncloseWindow, so that the listeners are ready for any new windows that\nare subsequently opened.\n\nMozReview-Commit-ID: EKzCRS10odN", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSession.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSessionHandler.java", "widget/android/GeneratedJNIWrappers.h"], "git_node": null, "git_parents": [null], "node": "e534002a0483610dd61b6277c70be628aa1f5bc5", "parents": ["c11a0b091095465c85c37b7b6b35f18714a1c796"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442250 - 3. Track EventDispatcher attach/detach; r=esawin\n\nIn an \"attach \u003e detach \u003e attach\" sequence, detach will post a call to\ndisposeNative, so the sequence looks like \"attach \u003e detach \u003e attach \u003e\ndisposeNative\". In that case, disposeNative will cancel attach. This\npatch makes us ignore disposeNative in that case, so the second attach\nworks as intended.\n\nMozReview-Commit-ID: Kr55PZcsPg1", "files": ["widget/android/EventDispatcher.cpp", "widget/android/EventDispatcher.h"], "git_node": null, "git_parents": [null], "node": "f06bf979916a4cb4a65402272827c1aa86c8e1d4", "parents": ["e534002a0483610dd61b6277c70be628aa1f5bc5"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442250 - 4. Fix crash when child preloading fails; r=jchen\n\nFix a null pointer crash when we fail to preload a child process.\n\nMozReview-Commit-ID: FIJopxOVAEj", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/process/GeckoProcessManager.java"], "git_node": null, "git_parents": [null], "node": "beefe251970fd65eaa9b52bb28fa784a02488c97", "parents": ["f06bf979916a4cb4a65402272827c1aa86c8e1d4"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442250 - 5. Reset native queue early when transferring; r=esawin\n\nWhen we reset the old native queue when transferring to another session,\nperform the reset right after the transfer() call, instead of in\nonTransfer(), which is too late for clearing stale pending calls.\n\nThen, after transferring to a new queue, let Gecko call Window.onReady\nto set the new queue's state if needed. That way the Java queue state is\nconsistent with the Gecko state.\n\nMozReview-Commit-ID: CUXGrhR4FCD", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/EventDispatcher.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSession.java", "widget/android/GeneratedJNINatives.h", "widget/android/GeneratedJNIWrappers.cpp", "widget/android/GeneratedJNIWrappers.h", "widget/android/nsAppShell.cpp", "widget/android/nsWindow.cpp", "widget/android/nsWindow.h"], "git_node": null, "git_parents": [null], "node": "a49ec516aafd994407a19e50052e0c0e0e7546da", "parents": ["beefe251970fd65eaa9b52bb28fa784a02488c97"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1307555 - Create a hit test info item for a scroll frame's scrolled frame that's not clipped to the displayport. r=mstange\n\nMozReview-Commit-ID: 5MJg4zqxSAk", "files": ["layout/generic/nsGfxScrollFrame.cpp"], "git_node": null, "git_parents": [null], "node": "d9910fc2faa6b0054668551c4f892798c5668850", "parents": ["a49ec516aafd994407a19e50052e0c0e0e7546da"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1307555 - Mochitest. r=kats\n\nMozReview-Commit-ID: 1e06rX4SQD8", "files": ["gfx/layers/apz/test/mochitest/helper_hittest_checkerboard.html", "gfx/layers/apz/test/mochitest/mochitest.ini", "gfx/layers/apz/test/mochitest/test_group_hittest.html"], "git_node": null, "git_parents": [null], "node": "3a4d96efd68f90a033516a3d68d30ebee01a5f08", "parents": ["d9910fc2faa6b0054668551c4f892798c5668850"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1442749 - Add back line accidentally removed in bug 1432355. r=Gijs\n\nMozReview-Commit-ID: B6BfCzwfeuc", "files": ["browser/components/nsBrowserContentHandler.js"], "git_node": null, "git_parents": [null], "node": "010b589f89a0ded63676176e08255a927c429f94", "parents": ["3a4d96efd68f90a033516a3d68d30ebee01a5f08"], "tags": []}, {"author": "Bogdan Tara \u003cbtara@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 609e4952a46e (bug 1444082) for perma-failing android-4.3-arm7-api-16/opt-robocop-3 (RC3) CLOSED TREE", "files": ["toolkit/components/reader/JSDOMParser.js", "toolkit/components/reader/Readability.js", "toolkit/components/reader/ReaderWorker.js", "toolkit/components/reader/test/readerModeNonArticle.html"], "git_node": null, "git_parents": [null], "node": "dd45b23b67c8eabffaeb17111d23e1d887e57173", "parents": ["010b589f89a0ded63676176e08255a927c429f94"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1444404 - Use default (true) value for browser.newtabpage.enabled for testing. r=jmaher\n\nBefore bug 1383599, the pref had effectively been always true as about:newtab always just loaded activity stream. Switching the test pref to be true matches the old behavior to fix the AWSY regression to later decide what this pref should be for testing in bug 1444498.\n\nMozReview-Commit-ID: Af9v2rgUZdl", "files": ["testing/geckodriver/src/prefs.rs", "testing/marionette/client/marionette_driver/geckoinstance.py", "testing/marionette/components/marionette.js"], "git_node": null, "git_parents": [null], "node": "9a200b344efec72f896bf4ebda15a53b357da00a", "parents": ["dd45b23b67c8eabffaeb17111d23e1d887e57173"], "tags": []}, {"author": "Anthony Ramine \u003cn.oxyde@gmail.com\u003e", "branch": "default", "desc": "servo: Merge #20258 - Continue to improve style_derive (from servo:derive-all-the-things); r=emilio\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 909ebff1844c3fcf95ea3b479b61077ff5a552e2", "files": ["servo/components/style/values/computed/mod.rs", "servo/components/style/values/computed/percentage.rs", "servo/components/style/values/generics/grid.rs", "servo/components/style/values/generics/image.rs", "servo/components/style/values/generics/transform.rs", "servo/components/style_derive/cg.rs", "servo/components/style_derive/to_animated_value.rs", "servo/components/style_derive/to_computed_value.rs"], "git_node": null, "git_parents": [null], "node": "31d94cfa44e855ad81fb70779f6568ed902e930e", "parents": ["9a200b344efec72f896bf4ebda15a53b357da00a"], "tags": []}, {"author": "J. Ryan Stinnett \u003cjryans@gmail.com\u003e", "branch": "default", "desc": "Bug 1442312 - Finish DevTools server conversion to DOM Promises. r=ochameau\n\nRemove the last sync promises from the server.\n\nThis causes server replies to be sent later than before, potentially later\nenough that the connection has since been closed.  We now throw errors in such\ncases.\n\nMozReview-Commit-ID: 2x213g7poH5", "files": ["devtools/server/main.js"], "git_node": null, "git_parents": [null], "node": "fbc3768c446ad1b74439e6a16e08e353656b1c0c", "parents": ["31d94cfa44e855ad81fb70779f6568ed902e930e"], "tags": []}, {"author": "J. Ryan Stinnett \u003cjryans@gmail.com\u003e", "branch": "default", "desc": "Bug 1442312 - Move allowed rejections into specific tests they apply to. r=ochameau\n\nBy moving only the rejections that actually still apply into each test and out\nof the shared head file, we are much more likely to notice new instances and\ncatch them when writing and editing tests in the future.\n\nBug 1018184 can be used to actually resolve these issues.\n\nMozReview-Commit-ID: Qb71PsuutB", "files": ["devtools/client/aboutdebugging/test/browser.ini", "devtools/client/aboutdebugging/test/browser_addons_debug_bootstrapped.js", "devtools/client/aboutdebugging/test/browser_addons_debug_webextension.js", "devtools/client/aboutdebugging/test/browser_addons_debug_webextension_inspector.js", "devtools/client/aboutdebugging/test/browser_addons_debug_webextension_nobg.js", "devtools/client/aboutdebugging/test/browser_addons_debug_webextension_popup.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-chrome-create.js", "devtools/client/debugger/test/mochitest/browser.ini", "devtools/client/debugger/test/mochitest/browser_dbg_chrome-create.js", "devtools/client/debugger/test/mochitest/browser_dbg_worker-console-04.js", "devtools/client/framework/test/browser_browser_toolbox.js", "devtools/client/framework/test/browser_browser_toolbox_debugger.js", "devtools/client/framework/test/browser_source_map-01.js", "devtools/client/framework/test/browser_source_map-absolute.js", "devtools/client/framework/test/browser_source_map-inline.js", "devtools/client/inspector/boxmodel/test/browser_boxmodel_computed-accordion-state.js", "devtools/client/inspector/test/browser_inspector_breadcrumbs_visibility.js", "devtools/client/inspector/test/browser_inspector_textbox-menu.js", "devtools/client/netmonitor/test/browser_net_simple-request-data.js", "devtools/client/netmonitor/test/browser_net_view-source-debugger.js", "devtools/client/responsive.html/test/browser/browser_ext_messaging.js", "devtools/client/shared/test/browser_toolbar_basic.js", "devtools/client/shared/test/shared-head.js", "devtools/client/webconsole/new-console-output/test/mochitest/browser_webconsole_location_debugger_link.js", "devtools/client/webconsole/new-console-output/test/mochitest/browser_webconsole_stacktrace_location_debugger_link.js", "devtools/client/webconsole/test/browser_webconsole_bug_766001_JS_Console_in_Debugger.js", "devtools/client/webconsole/test/browser_webconsole_output_dom_elements_01.js"], "git_node": null, "git_parents": [null], "node": "3ca7ee7f010fbb8e85fbe5dc71edfe61fa15c8dd", "parents": ["fbc3768c446ad1b74439e6a16e08e353656b1c0c"], "tags": []}, {"author": "J. Ryan Stinnett \u003cjryans@gmail.com\u003e", "branch": "default", "desc": "Bug 1442312 - Wait for addon reload to finish in tests. r=jdescottes\n\nIn about:debugging's browser_addon_reload.js test, we would request a reload\nwithout waiting for it to reply.  This led to the RDP connection closing before\nthe reply could be sent, triggering later errors.\n\nFor better test correctness, we now emit an event on reply and the test waits to\nreceive it before proceeding.\n\nMozReview-Commit-ID: Jfps7MJ6Pzo", "files": ["devtools/client/aboutdebugging/components/addons/Target.js", "devtools/client/aboutdebugging/initializer.js", "devtools/client/aboutdebugging/test/browser_addons_reload.js"], "git_node": null, "git_parents": [null], "node": "bedc6f6583bf50e57135d20af8b75c5138a655e8", "parents": ["3ca7ee7f010fbb8e85fbe5dc71edfe61fa15c8dd"], "tags": []}, {"author": "Daniel Holbert \u003cdholbert@cs.stanford.edu\u003e", "branch": "default", "desc": "Bug 1444481 part 1: Add some needed #includes to ComputedTimingFunction.h and FrameMetrics.h. r=xidorn\n\n(This is a helper patch -- I'm splitting this into its own patch since it's\nchanging files in other directories, and also so that the main patches here\ncan be a bit more direct.)\n\nWithout this change, the other patches in this series would cause compile\nfailures in the headers that I'm fixing up here (because the other patches will\nbe removing #includes from some headers that these files were inadvertently\ndepending on).\n\nAs of this patch, ComputedTimingFunction.h will now be including:\n - nsDebug.h to provide NS_ASSERTION\n - nsStringFwd.h to provide a forward-declaration for \"nsAString&\"\n - Assertions.h to provide MOZ_ASSERT\n - Maybe.h to provide Maybe\u003cComputedTimingFunction\u003e\n(I think it's been leaning on nsTimingFunction.h's include of nsString.h to\nindirectly provide these.)\n\nFrameMetrics.h will now be including:\n - PLDHashTable.h to provide PLDHashNumber\n(I think it's been leaning on nsStyleCoord.h/nsStyleConsts.h to indirectly\nprovide this.)\n\nMozReview-Commit-ID: AoFoEe9GisK", "files": ["dom/animation/ComputedTimingFunction.h", "gfx/layers/FrameMetrics.h"], "git_node": null, "git_parents": [null], "node": "37e3ec770550abec14beb8eb9939da78d578a2bb", "parents": ["bedc6f6583bf50e57135d20af8b75c5138a655e8"], "tags": []}, {"author": "Daniel Holbert \u003cdholbert@cs.stanford.edu\u003e", "branch": "default", "desc": "Bug 1444481 part 2: Replace unneeded #includes in nsStyleConsts.h with more specific ones (and add missing headers to nsStyleCoord.h). r=xidorn\n\nnsStyleConsts.h doesn't use anything from gfxRect.h or nsFont.h, so this patch\nremoves those #includes from it. However, it does need some other headers that\nit was pulling in indirectly via those #includes, which I'm now making it\n*directly* #include. Specifically, it needs:\n - inttypes.h for \"uint8_t\"\n - gfxFontConstants.h for NS_FONT_WEIGHT_BOLD and related constants.\n\nOn its own, the above changes cause build errors in nsStyleCoord.h, because\nthat other header has an #include for nsStyleConsts.h, which it was\ninadvertently depending on (very indirectly) to provide some definitions (via\nthe aforementioned removed #includes). So we need to give nsStyleCoord.h some\nnew #includes to directly provide what it needs & keep it\ncompiling. Specifically:\n - mozilla/gfx/Types.h for the mozilla::Side type\n - nsISupportsImpl.h for the NS_INLINE_DECL_THREADSAFE_REFCOUNTING macro\n\nMozReview-Commit-ID: BDlaIIOQiPE", "files": ["layout/style/nsStyleConsts.h", "layout/style/nsStyleCoord.h"], "git_node": null, "git_parents": [null], "node": "54aa980d30f7a4d96e18dda8f298bbb32d95035d", "parents": ["37e3ec770550abec14beb8eb9939da78d578a2bb"], "tags": []}, {"author": "Daniel Holbert \u003cdholbert@cs.stanford.edu\u003e", "branch": "default", "desc": "Bug 1444481 part 3: #include nsStringFwd.h rather than nsString.h in some layout/style headers. r=xidorn\n\nThese files only use references to string types, e.g. \"nsAString&\", so they\nonly need forward-declarations of these types -- not the full definition.\n\nNote that the last file here (nsStyleUtil.h) already has an #include for\nnsStringFwd.h, which is why that files change is just a pure removal (of the\nunnecessary nsString.h #include).\n\nMozReview-Commit-ID: 9sLSyeBS49M", "files": ["layout/style/CSSStyleSheet.h", "layout/style/ServoCSSParser.h", "layout/style/nsCSSProps.h", "layout/style/nsICSSDeclaration.h", "layout/style/nsStyleUtil.h"], "git_node": null, "git_parents": [null], "node": "14f77d01522bf9881b6659e6f8bbbf2677f81ee3", "parents": ["54aa980d30f7a4d96e18dda8f298bbb32d95035d"], "tags": []}, {"author": "Shane Caraveo \u003cscaraveo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1443749 only reload sidebar when the url has changed r=kmag\n\nRegression from bug 1398713.  Before that, we reloaded the entire webext-panel.xul if the\nsidebar changed.  This verifies we don't reload unecessarily as well as discards\nthe browser to force a runtime disconnect for the extension if it does change.\n\nMozReview-Commit-ID: LuYxmj9mSb7", "files": ["browser/base/content/webext-panels.js", "browser/components/extensions/test/browser/browser-common.ini", "browser/components/extensions/test/browser/browser_ext_sidebarAction_runtime.js"], "git_node": null, "git_parents": [null], "node": "3bf5123d0218751b86fdff5654ab5bcdefabec6d", "parents": ["14f77d01522bf9881b6659e6f8bbbf2677f81ee3"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "servo: Merge #20262 - constellation: Make setting up the WebGL state fallible (from emilio:webgl-fallible); r=jdm\n\nThis fixes a regression caused by the glutin update.\n\nWe now are creating EGL contexts in Linux Wayland, instead of X context, so the\nGLContextFactory assumption of one GL back-end per platform is broken.\n\nThis just works around it, for now, but in general I think not relying on\navailable WebGL state is a good thing, and we do that already for WebVR anyway.\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 95f9e14e67766b36a8b72e62925a34b1818be2c8", "files": ["servo/components/canvas/gl_context.rs", "servo/components/constellation/constellation.rs", "servo/components/constellation/pipeline.rs", "servo/components/script/dom/webglrenderingcontext.rs", "servo/components/script/dom/window.rs", "servo/components/script/script_thread.rs", "servo/components/script_traits/lib.rs", "servo/components/servo/lib.rs"], "git_node": null, "git_parents": [null], "node": "5f5da5116bfa9b16e9b9cd35cd7e9237dfc2785a", "parents": ["3bf5123d0218751b86fdff5654ab5bcdefabec6d"], "tags": []}, {"author": "Bogdan Tara \u003cbtara@mozilla.com\u003e", "branch": "default", "desc": "Backed out 2 changesets (bug 1223726) for failing devtools/client/styleeditor/test/browser_styleeditor_fetch-from-netmonitor.js a=backout on a CLOSED TREE\n\nBacked out changeset a95b0b28ca16 (bug 1223726)\nBacked out changeset 6adb35cc708e (bug 1223726)", "files": ["devtools/client/netmonitor/src/har/test/browser_net_har_copy_all_as_har.js", "devtools/client/netmonitor/test/browser_net_truncate.js", "devtools/client/preferences/devtools.js", "devtools/client/webconsole/webconsole-connection-proxy.js", "devtools/shared/webconsole/network-monitor.js", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "1dfc5eba64f1b2ddb308da27206bd39de8a7f1a6", "parents": ["5f5da5116bfa9b16e9b9cd35cd7e9237dfc2785a"], "tags": []}, {"author": "Dmitry \u003cdk@elonsoft.ru\u003e", "branch": "default", "desc": "servo: Merge #20252 - Extract text emphasis style (from NeverHappened:extract_text_emphasis_style); r=upsuper\n\n\u003c!-- Please describe your changes on the following line: --\u003e\nExtracted the text-emphasis-style property out of the inherited_text.mako.rs.\nThis is a part of #19015\n\n---\n\u003c!-- Thank you for contributing to Servo! Please replace each `[ ]` by `[X]` when the step is complete, and replace `__` with appropriate data: --\u003e\n- [X] `./mach build -d` does not report any errors\n- [X] `./mach test-tidy` does not report any errors\n- [X] `./mach cargo-geckolib check` does not report any errors\n- [X] These changes fix #19940 (github issue number if applicable).\n\n\u003c!-- Either: --\u003e\n- [X] These changes do not require tests because it's a refactoring\n\n\u003c!-- Also, please make sure that \"Allow edits from maintainers\" checkbox is checked, so that we can help you if you get stuck somewhere along the way.--\u003e\n\n\u003c!-- Pull requests that do not address these steps are welcome, but they will require additional verification as part of the review process. --\u003e\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: aa8fb3a2044c03301e23aa9ffbee1161b9bd092c", "files": ["servo/components/style/properties/gecko.mako.rs", "servo/components/style/properties/longhand/inherited_text.mako.rs", "servo/components/style/values/computed/mod.rs", "servo/components/style/values/computed/text.rs", "servo/components/style/values/specified/mod.rs", "servo/components/style/values/specified/text.rs"], "git_node": null, "git_parents": [null], "node": "49c2fbd9779e6272a994f50478872cb47fdda756", "parents": ["1dfc5eba64f1b2ddb308da27206bd39de8a7f1a6"], "tags": []}, {"author": "Zibi Braniecki \u003czbraniecki@mozilla.com\u003e", "branch": "default", "desc": "Bug 1444564 - Fix a typo in Preferences main.xul. r=gandalf\n\nMozReview-Commit-ID: 5X8crQ5dXb1", "files": ["browser/components/preferences/in-content/main.xul"], "git_node": null, "git_parents": [null], "node": "d9c906ec2b7de5f540521985f002b3633e153ba6", "parents": ["49c2fbd9779e6272a994f50478872cb47fdda756"], "tags": []}, {"author": "Matthew Noorenberghe \u003cmozilla@noorenberghe.ca\u003e", "branch": "default", "desc": "Bug 1443632 - Change screenshots tour action button back to an \u003ca\u003e. r=kitcambridge\n\nMozReview-Commit-ID: DeEWxnurLty", "files": ["browser/extensions/onboarding/content/onboarding.js"], "git_node": null, "git_parents": [null], "node": "a28f113ffa3fe9d5253d388c272abdb76e007ebf", "parents": ["d9c906ec2b7de5f540521985f002b3633e153ba6"], "tags": []}, {"author": "Kit Cambridge \u003ckit@yakshaving.ninja\u003e", "branch": "default", "desc": "Bug 1444552 - Store bookmark creation dates as milliseconds in the mirror. r=tcsc\n\nMozReview-Commit-ID: 8xaMl3sfUm7", "files": ["toolkit/components/places/SyncedBookmarksMirror.jsm"], "git_node": null, "git_parents": [null], "node": "a29e9196602f897fcb88e8b78e96b8b939b732a8", "parents": ["a28f113ffa3fe9d5253d388c272abdb76e007ebf"], "tags": []}, {"author": "Noemi Erli \u003cnerli@mozilla.com\u003e", "branch": "default", "desc": "Merge autoland to mozilla-central. a=merge", "files": ["gfx/webrender/res/brush_picture.glsl"], "git_node": null, "git_parents": [null, null], "node": "8a0f43c3f5dd1fcb889d601a547e1d06b2964171", "parents": ["415e9b18ca2a1532086d5e2d5d21343cd004b5fd", "a29e9196602f897fcb88e8b78e96b8b939b732a8"], "tags": []}, {"author": "Noemi Erli \u003cnerli@mozilla.com\u003e", "branch": "default", "desc": "Merge inbound to mozilla-central.  a=merge", "files": ["image/test/reftest/generic/1443232-1.gif", "image/test/reftest/generic/1443232-1.html", "js/src/jsarray.cpp", "js/src/jsarray.h", "js/src/jsarrayinlines.h", "js/src/jsbool.cpp", "js/src/jsbool.h", "js/src/jsboolinlines.h", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSession.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSessionSettings.java", "modules/libpref/init/all.js", "toolkit/mozapps/extensions/test/addons/test_install5/chrome.manifest", "toolkit/mozapps/extensions/test/addons/test_install5/install.rdf", "toolkit/mozapps/extensions/test/xpcshell/test_hasbinarycomponents.