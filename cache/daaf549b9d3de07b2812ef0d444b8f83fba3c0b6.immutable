sl/nsNSSCallbacks.cpp", "security/manager/ssl/nsNSSComponent.cpp", "toolkit/components/backgroundhangmonitor/BackgroundHangMonitor.cpp", "toolkit/components/backgroundhangmonitor/HangDetails.cpp", "toolkit/components/backgroundhangmonitor/HangDetails.h", "toolkit/components/backgroundhangmonitor/HangTypes.ipdlh", "toolkit/components/backgroundhangmonitor/nsIHangDetails.idl", "toolkit/xre/nsUpdateDriver.cpp", "xpcom/tests/gtest/TestThreadPool.cpp", "xpcom/threads/BlockingResourceBase.cpp", "xpcom/threads/CondVar.h", "xpcom/threads/HangMonitor.cpp", "xpcom/threads/Monitor.h", "xpcom/threads/Scheduler.cpp", "xpcom/threads/TimerThread.cpp", "xpcom/threads/nsThreadPool.cpp"], "git_node": null, "git_parents": [null], "node": "f082f787a988d88f2fd14962f7af37671c539a7f", "parents": ["e372427420a80b8953cd16a55ee41e4250fdc697"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Backed out 2 changesets (bug 1432362) for build bustages at tests/gtest/TestHistograms.cp on a CLOSED TREE\n\nBacked out changeset e372427420a8 (bug 1432362)\nBacked out changeset aed9a827a1b9 (bug 1432362)", "files": ["toolkit/components/telemetry/tests/gtest/TestHistograms.cpp"], "git_node": null, "git_parents": [null], "node": "fd038d63f99f3b9bc855e8aab4eb0a0c60353149", "parents": ["f082f787a988d88f2fd14962f7af37671c539a7f"], "tags": []}, {"author": "Ben Hearsum \u003cbhearsum@mozilla.com\u003e", "branch": "default", "desc": "bug 1443190: fix watersheds for all platforms and branches in update verify config tasks. r=nthomas", "files": ["taskcluster/ci/release-secondary-update-verify-config/kind.yml", "taskcluster/ci/release-update-verify-config/kind.yml", "taskcluster/taskgraph/transforms/update_verify_config.py"], "git_node": null, "git_parents": [null], "node": "23c473f89743b37f27cfaba632ac686843e75385", "parents": ["fd038d63f99f3b9bc855e8aab4eb0a0c60353149"], "tags": []}, {"author": "Ben Hearsum \u003cbhearsum@mozilla.com\u003e", "branch": "default", "desc": "bug 1443313: select betas and RCs for testing when generating secondary update verify configs. r=nthomas", "files": ["taskcluster/ci/release-secondary-update-verify-config/kind.yml"], "git_node": null, "git_parents": [null], "node": "18cd69ebc9579635e748dbe8c93704b327565b8e", "parents": ["23c473f89743b37f27cfaba632ac686843e75385"], "tags": []}, {"author": "Jim Blandy \u003cjimb@mozilla.com\u003e", "branch": "default", "desc": "Bug 1438121: Part 6: Improve comments for js::LiveSavedFrameCache. DONTBUILD r=fitzgen\n\nMozReview-Commit-ID: C4W5cgwdNtv", "files": ["js/src/vm/Stack.h"], "git_node": null, "git_parents": [null], "node": "8fd9c1479159335e4d4e9d71e2bf99d1d62b8ba7", "parents": ["18cd69ebc9579635e748dbe8c93704b327565b8e"], "tags": []}, {"author": "Jim Blandy \u003cjimb@mozilla.com\u003e", "branch": "default", "desc": "Bug 1438121: Part 8: AutoSetAsyncStackForNewCalls doc fix. DONTBUILD r=fitzgen\n\nMozReview-Commit-ID: JwIM2EAmPZY", "files": ["js/src/jsapi.h"], "git_node": null, "git_parents": [null], "node": "7d93207d01801b99e5a4464145f61a02e98b701f", "parents": ["8fd9c1479159335e4d4e9d71e2bf99d1d62b8ba7"], "tags": []}, {"author": "Jim Blandy \u003cjimb@mozilla.com\u003e", "branch": "default", "desc": "Bug 1438121: Part 12: Make LiveSavedFrameCache::getFramePtr's parameter const. r=fitzgen\n\nMozReview-Commit-ID: K4JAFidKNzJ", "files": ["js/src/vm/SavedStacks.cpp", "js/src/vm/Stack.h"], "git_node": null, "git_parents": [null], "node": "182dc936ca731074c7a332768c8123efffe79951", "parents": ["7d93207d01801b99e5a4464145f61a02e98b701f"], "tags": []}, {"author": "Jim Blandy \u003cjimb@mozilla.com\u003e", "branch": "default", "desc": "Bug 1438121: Part 5: Don't propagate the 'hasCachedSavedFrame_' bit from the RematerializedFrame to the BaselineFrame. r=fitzgen\n\nWhen capturing the JavaScript stack as a chain of SavedFrames, the\nhasCachedSavedFrame flag on a frame indicates that the frame has an entry in\nthe LiveSavedFrameCache, which may hand us the SavedFrame for a previously\ncaptured remainder of the stack, letting us stop the stack walk early.\n\nThe LiveSavedFrameCache uses AbstractFramePtr and jit::CommonFrameLayout* values\nas keys. A RematerializedFrame uses an AbstractFramePtr as its key, but the\nBaselineFrame we build from it has a jit::CommonFrameLayout* as its key; the two\nkeys are unequal. It's valuable to be able to assert that, if a frame has its\nhasCachedSavedFrame flag set, then it must have an entry in the cache; to allow\nthat, converting a RematerializedFrame to a BaselineFrame must clear the flag,\nsince the BaselineFrame's key is not present.\n\nWe could instead fix up the cache entry's key, and carry over the flag, but it's\nsimpler to just let the cache get repopulated as needed.\n\nMozReview-Commit-ID: 612daDJ1R4w", "files": ["js/src/jit/BaselineBailouts.cpp"], "git_node": null, "git_parents": [null], "node": "03528c9063b3647f70324b120a951a8cdf470d4f", "parents": ["182dc936ca731074c7a332768c8123efffe79951"], "tags": []}, {"author": "Jim Blandy \u003cjimb@mozilla.com\u003e", "branch": "default", "desc": "Bug 1438121: Part 1: Add job dispatch primitive to shell. r=fitzgen\n\nSee JS_FN documentation for details.\n\nMozReview-Commit-ID: 8ZLyOX85qqh", "files": ["js/src/jsfriendapi.h", "js/src/shell/js.cpp", "js/src/vm/JSContext.cpp"], "git_node": null, "git_parents": [null], "node": "6f555aced81dac6cde601db7ca6589e42efe5f57", "parents": ["03528c9063b3647f70324b120a951a8cdf470d4f"], "tags": []}, {"author": "Jim Blandy \u003cjimb@mozilla.com\u003e", "branch": "default", "desc": "Bug 1438121: Part 2: Define the 'bindToAsyncStack' JS shell testing function. r=fitzgen\n\nSee JS_FN documentation for details.\n\nMozReview-Commit-ID: 6WUaGfdwogX", "files": ["js/src/shell/js.cpp"], "git_node": null, "git_parents": [null], "node": "4ca86bbdc4090adb24956c783e1b42fd495e0f1f", "parents": ["6f555aced81dac6cde601db7ca6589e42efe5f57"], "tags": []}, {"author": "Jim Blandy \u003cjimb@mozilla.com\u003e", "branch": "default", "desc": "Bug 1438121: Part 3: Add shell tests for implicit async stacks. r=fitzgen\n\nMozReview-Commit-ID: BfPPrvEGSgg", "files": ["js/src/jit-test/tests/saved-stacks/async-implicit.js"], "git_node": null, "git_parents": [null], "node": "f72fd25e822fc7c8f625a0b6f659a7aaee4d4a41", "parents": ["4ca86bbdc4090adb24956c783e1b42fd495e0f1f"], "tags": []}, {"author": "Kannan Vijayan \u003ckvijayan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411415 - r=bz r=fitzgen", "files": ["dom/bindings/BindingUtils.cpp", "dom/bindings/ErrorResult.h", "dom/xslt/xpath/txXPCOMExtensionFunction.cpp", "js/public/Value.h", "js/rust/build.rs", "js/src/jit/BaselineFrameInfo.h", "js/src/jit/CacheIRCompiler.cpp", "js/src/jit/RegisterSets.h", "js/src/jit/RematerializedFrame.cpp", "js/src/wasm/AsmJS.cpp", "js/xpconnect/src/XPCWrappedNative.cpp", "layout/style/ServoBindings.toml", "xpcom/reflect/xptcall/xptcall.h"], "git_node": null, "git_parents": [null], "node": "61ca8af8e31332158c4307c8277282d27012d46e", "parents": ["f72fd25e822fc7c8f625a0b6f659a7aaee4d4a41"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Backed out 3 changesets (bug 1387976) because of merge conflicts on AsyncTabSwitcher.jsm.\n\nBacked out changeset d91b6a40b32a (bug 1387976)\nBacked out changeset b708ab55bc72 (bug 1387976)\nBacked out changeset 7958b0ccbe0b (bug 1387976)", "files": ["browser/base/content/tabbrowser.js", "browser/base/content/tabbrowser.xml", "browser/base/content/test/tabs/browser.ini", "browser/base/content/test/tabs/browser_bug_1387976_restore_lazy_tab_browser_muted_state.js"], "git_node": null, "git_parents": [null], "node": "7c01c3875cae3d9b8a3fab22c4b07efe20f6d48f", "parents": ["61ca8af8e31332158c4307c8277282d27012d46e"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Merge inbound to mozilla-central. a=merge", "files": ["browser/base/content/tabbrowser.js", "browser/base/content/tabbrowser.xml", "browser/modules/AsyncTabSwitcher.jsm", "python/mozbuild/mozbuild/backend/templates/android_eclipse_empty_resource_directory/.not_an_android_resource", "services/sync/tests/unit/test_errorhandler_eol.js"], "git_node": null, "git_parents": [null, null], "node": "19838b896cd704a4cbf50d7e57b8d7dd8cafcbfd", "parents": ["7c01c3875cae3d9b8a3fab22c4b07efe20f6d48f", "36c84344de23aa92f96c0d40076d5262aab32ad2"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland. a=merge on a CLOSED TREE", "files": [], "git_node": null, "git_parents": [null, null], "node": "490f87831c110acaa3eb966679ad94a1eaf51dd9", "parents": ["fea7978f3af6c940383e540d0605ed8456b2b827", "19838b896cd704a4cbf50d7e57b8d7dd8cafcbfd"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 662591 - HTMLEditor should set caret to start of first editable text node or before first editable inline node r=m_kato\n\nCurrently, HTMLEditor doesn't initialize caret position when it gets focus by\nitself in most cases.  Only when it's in designMode, it may move caret to the\nfirst visible (not checking CSS actually).\n\nIn most cases, caret position is adjusted when EditorBase::InitializeSelection()\ncalls Selection::SetAncestorLimiter().  If selected range is outside of\nnew limiter, it moves caret to start of the new limiter.  However, this is\nreally different behavior from the other browsers.  The other browsers try\nto move caret to the first editable text node or before the first editable\ncontent such as \u003cimg\u003e, \u003cinput\u003e, etc.\n\nThis difference causes a serious incompatible issue with Draft.js.  It doesn't\ninitialize caret position when it gets focus but it assumes that caret is\nalways set to before \u003cbr\u003e element if there is no other content.\n\nSo, let's try to behave as what other browsers do as far as possible.\n\nThis patch makes editor behave as:\n* if selection is already in the editing host except start of the editing host,\n  does nothing.\n* if there is non-editable element before any editable node, move caret to\n  start of the editing host.\n* if there is editable text node or element node which cannot have a text node,\n  move its start or before it.\n* if there is no editable nodes which can contain text nodes, move caret to\n  start of the editing host.\n\nNote that before applying this patch, in designMode, BeginningOfDocument() used\ndocument element instead of \u003cbody\u003e element.  Therefore, it may set odd position\nif \u003chead\u003e element has some text nodes with \u003cscript\u003e or \u003cstyle\u003e.  However,\nthis doesn't make sense and for making more consistent behavior between\ndesignMode and contenteditable, this patch makes it use editing host (it's\n\u003cbody\u003e element if it's in designMode).\n\nMozReview-Commit-ID: 5neYoTMq6Cc", "files": ["editor/libeditor/EditorBase.cpp", "editor/libeditor/EditorBase.h", "editor/libeditor/HTMLEditor.cpp", "editor/libeditor/HTMLEditor.h", "editor/libeditor/tests/test_contenteditable_focus.html", "editor/nsIEditor.idl", "testing/web-platform/moz.build", "testing/web-platform/mozilla/meta/MANIFEST.json", "testing/web-platform/mozilla/tests/editor/initial_selection_on_focus.html"], "git_node": null, "git_parents": [null], "node": "575562183a3bc245c50dcf45d8dc21043b4565ae", "parents": ["490f87831c110acaa3eb966679ad94a1eaf51dd9"], "tags": []}, {"author": "Olli Pettay \u003cOlli.Pettay@helsinki.fi\u003e", "branch": "default", "desc": "Bug 1066965, make contentEditable and spellchecking to work in ShadowDOM, r=mrbkap", "files": ["dom/base/Element.cpp", "dom/base/Selection.cpp", "dom/base/nsINode.cpp", "dom/base/nsINode.h", "dom/html/nsGenericHTMLElement.cpp", "editor/libeditor/EditorBase.cpp", "editor/libeditor/EditorEventListener.cpp", "editor/libeditor/HTMLEditRules.cpp", "editor/libeditor/HTMLEditor.cpp", "editor/spellchecker/EditorSpellCheck.cpp", "extensions/spellcheck/src/mozInlineSpellChecker.cpp"], "git_node": null, "git_parents": [null], "node": "5934e66f2c778eace5a8cd80ed734c3596119af4", "parents": ["61ca8af8e31332158c4307c8277282d27012d46e"], "tags": []}, {"author": "Jim Blandy \u003cjimb@mozilla.com\u003e", "branch": "default", "desc": "Bug 1438121: Part 13: Make LiveSavedFrameCache::Entry's members const. r=fitzgen\n\nMozReview-Commit-ID: GbJhE9nylaa", "files": ["js/src/vm/SavedStacks.cpp", "js/src/vm/Stack.h"], "git_node": null, "git_parents": [null], "node": "bc9778de0b084afaaca48cd5d27d84fc8d259348", "parents": ["5934e66f2c778eace5a8cd80ed734c3596119af4"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to inbound. a=merge on a CLOSED TREE", "files": ["browser/base/content/test/tabs/browser_bug_1387976_restore_lazy_tab_browser_muted_state.js", "python/mozbuild/mozbuild/backend/templates/android_eclipse_empty_resource_directory/.not_an_android_resource"], "git_node": null, "git_parents": [null, null], "node": "709eae4e54ffa3f3518745516dd5d27a05255af2", "parents": ["bc9778de0b084afaaca48cd5d27d84fc8d259348", "19838b896cd704a4cbf50d7e57b8d7dd8cafcbfd"], "tags": []}, {"author": "Tiberius Oros \u003ctoros@mozilla.com\u003e", "branch": "default", "desc": "Merge autoland to mozilla-central. a=merge", "files": ["editor/libeditor/EditorBase.cpp", "editor/libeditor/HTMLEditor.cpp"], "git_node": null, "git_parents": [null, null], "node": "a007dd56b9947a93c276e82275d7065db1949c9e", "parents": ["709eae4e54ffa3f3518745516dd5d27a05255af2", "575562183a3bc245c50dcf45d8dc21043b4565ae"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Merge mozilla-central to beta. a=merge, l10n=me on a CLOSED TREE", "files": ["devtools/client/netmonitor/src/utils/redux-connect.js", "devtools/client/webconsole/new-console-output/test/mochitest/browser_netmonitor_shows_reqs_in_webconsole.js", "python/mozbuild/mozbuild/backend/templates/android_eclipse_empty_resource_directory/.not_an_android_resource"], "git_node": null, "git_parents": [null, null], "node": "af9d5a9c1e28fd790adc5eef0d0e335a99072e9c", "parents": ["f149ea88f20108dec9d7937b8f45138744461150", "a007dd56b9947a93c276e82275d7065db1949c9e"], "tags": []}], "date": 1520346794, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "8818": {"changesets": [{"author": "\"Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e\"", "branch": "default", "desc": "No bug - Tagging a1098c825a9c5e07f03ec4ad7a760c868bf20d75 with DEVEDITION_60_0b1_BUILD3, DEVEDITION_60_0b1_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "b899cc137fa02175d20323b4940f65508c3220fb", "parents": ["af9d5a9c1e28fd790adc5eef0d0e335a99072e9c"], "tags": []}, {"author": "\"Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e\"", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "a4105117aed9d4fba32619c2654175d68c9e58f0", "parents": ["b899cc137fa02175d20323b4940f65508c3220fb"], "tags": []}], "date": 1520354740, "git_changesets": [null, null], "user": "ffxbld"}, "8819": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging 2d10a10c32dc26b6dc0b13ee7805ad6241f82081 with FENNEC_59_0b15_BUILD1, FENNEC_59_0b15_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "8b92defaf0b1a77c190c21f971d57ddc27ab0519", "parents": ["a4105117aed9d4fba32619c2654175d68c9e58f0"], "tags": []}], "date": 1520357360, "git_changesets": [null], "user": "ffxbld"}, "8820": {"changesets": [{"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442255 - 1. Replace setLastIntent with extras bundle; r=esawin\n\nGeckoLoader.setLastIntent is not a very good API for setting environment\nvariables and is often forgotten. Replace it with an extras bundle that\nis passed to setupGeckoEnvironment.\n\nMozReview-Commit-ID: IFhHjLdwFC5", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/mozglue/GeckoLoader.java"], "git_node": null, "git_parents": [null], "node": "d7a43e59a1b4ea7c294e7645c4f77d798fe7be67", "parents": ["575562183a3bc245c50dcf45d8dc21043b4565ae"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442255 - 2. Replace GeckoThread fields with extras bundle; r=esawin\n\nIntroduce an extras bundle in GeckoThread, which we use to store things\nsuch as extra main process arguments and child process FDs. Also use the\nextras bundle to store environment variables to be passed to\nGeckoLoader.\n\nMozReview-Commit-ID: tRlBaAXxVa", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoThread.java"], "git_node": null, "git_parents": [null], "node": "08f906f3a0c836d333699f528f70a6b86a69f5eb", "parents": ["d7a43e59a1b4ea7c294e7645c4f77d798fe7be67"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442255 - 3. Use extras bundle to initialize Gecko in GeckoView; r=esawin\n\nUse extras bundle to initialize Gecko in GeckoSession and\nGeckoViewActivity.\n\nMozReview-Commit-ID: 7dtaziVBDcg", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/TestRunnerActivity.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSession.java", "mobile/android/geckoview_example/src/main/java/org/mozilla/geckoview_example/GeckoViewActivity.java"], "git_node": null, "git_parents": [null], "node": "c3305648ad30458a5eb098c6f4fdea5358d339a0", "parents": ["08f906f3a0c836d333699f528f70a6b86a69f5eb"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442255 - 4. Use extras bundle to initialize Gecko in Fennec; r=esawin\n\nUse extras bundle (e.g. from an Intent) to initialize Gecko in GeckoApp\nand GeckoService.\n\nMozReview-Commit-ID: AmLZ8Uir8f4", "files": ["mobile/android/base/java/org/mozilla/gecko/GeckoApp.java", "mobile/android/base/java/org/mozilla/gecko/GeckoApplication.java", "mobile/android/base/java/org/mozilla/gecko/GeckoService.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoThread.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/mozglue/SafeIntent.java"], "git_node": null, "git_parents": [null], "node": "5d0f72867f53c055f461321798a08ce09d6889c6", "parents": ["c3305648ad30458a5eb098c6f4fdea5358d339a0"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442255 - 5. Use extras bundle to initialize child processes; r=esawin\n\nPass the extras bundle from the main process to the child process\nthrough IChildProcess.start, instead of through the Intent, which never\nworked because intent extras are not passed to Service.onBind.\n\nMozReview-Commit-ID: I2EToBNE2Y6", "files": ["mobile/android/geckoview/src/main/aidl/org/mozilla/gecko/process/IChildProcess.aidl", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/mozglue/GeckoLoader.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/process/GeckoProcessManager.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/process/GeckoServiceChildProcess.java"], "git_node": null, "git_parents": [null], "node": "62d1c57c37b46778999b628196decfa5c5fa7d27", "parents": ["5d0f72867f53c055f461321798a08ce09d6889c6"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442255 - 6. Adjust process count for GeckoView; r=jchen\n\nSet process count to 1 because we only support one child process right\nnow.\n\nMozReview-Commit-ID: HJAWvN4aqSX", "files": ["mobile/android/app/geckoview-prefs.js"], "git_node": null, "git_parents": [null], "node": "6a794e14fcebb137e82ca679fd647680fe31d3fe", "parents": ["62d1c57c37b46778999b628196decfa5c5fa7d27"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442255 - 7. Switch the order of fd arguments; r=jchen\n\nSwitch the order of the IPC FD argument and the crash FD argument in\ne10s calls, because the IPC FD is the primary FD, and the crash FD\nshould be grouped with the crash annotation FD.\n\nMozReview-Commit-ID: CAVyYAIIBPm", "files": ["ipc/glue/GeckoChildProcessHost.cpp", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoThread.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/mozglue/GeckoLoader.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/process/GeckoServiceChildProcess.java", "mozglue/android/APKOpen.cpp", "toolkit/xre/Bootstrap.cpp", "toolkit/xre/Bootstrap.h", "toolkit/xre/nsEmbedFunctions.cpp", "xpcom/build/nsXULAppAPI.h"], "git_node": null, "git_parents": [null], "node": "208c4c42f641e189ac930ef0831b38d502c7374c", "parents": ["6a794e14fcebb137e82ca679fd647680fe31d3fe"], "tags": []}, {"author": "Zibi Braniecki \u003czbraniecki@mozilla.com\u003e", "branch": "default", "desc": "Bug 1363862 - Add Node.localize API as a fast-path for Fluent DOM localization. r=baku\n\nMozReview-Commit-ID: 6mj0q21Nbey", "files": ["dom/base/nsGkAtomList.h", "dom/base/nsINode.cpp", "dom/base/nsINode.h", "dom/base/test/chrome/chrome.ini", "dom/base/test/chrome/test_node_localize.xul", "dom/bindings/Bindings.conf", "dom/webidl/L10nUtils.webidl", "dom/webidl/Node.webidl", "dom/webidl/moz.build"], "git_node": null, "git_parents": [null], "node": "3ce625a515974b62ff3eaa623ae2c1c48c2c4983", "parents": ["208c4c42f641e189ac930ef0831b38d502c7374c"], "tags": []}, {"author": "Zibi Braniecki \u003czbraniecki@mozilla.com\u003e", "branch": "default", "desc": "Bug 1363862 - Use Node.localize for fragment translation in Fluent DOM. r=stas\n\nMozReview-Commit-ID: 1zAbSMapi86", "files": ["browser/components/preferences/in-content/tests/browser_fluent.js", "intl/l10n/DOMLocalization.jsm", "intl/l10n/Localization.jsm", "intl/l10n/test/chrome.ini", "intl/l10n/test/dom/test_domloc_attr_sanitized.html", "intl/l10n/test/dom/test_domloc_overlay_missing_all.html", "intl/l10n/test/dom/test_domloc_overlay_sanitized.html", "intl/l10n/test/dom/test_domloc_repeated_l10nid.html"], "git_node": null, "git_parents": [null], "node": "c483f8c3bf074db6be630993067e80c2bedd8f49", "parents": ["3ce625a515974b62ff3eaa623ae2c1c48c2c4983"], "tags": []}, {"author": "Dan Glastonbury \u003cdan.glastonbury@gmail.com\u003e", "branch": "default", "desc": "Bug 1443368 - Update cubeb-pulse-rs to commit 22cdde3. r=kinetik\n\nPull for change to replace assert in get_server_info callback with\nproper handling for null pointer.\n\nMozReview-Commit-ID: 996HQw3FyYQ", "files": ["media/libcubeb/cubeb-pulse-rs/README_MOZILLA", "media/libcubeb/cubeb-pulse-rs/pulse-rs/src/context.rs", "media/libcubeb/cubeb-pulse-rs/src/backend/context.rs"], "git_node": null, "git_parents": [null], "node": "f56d6bee4412e82392e7bfdb7acf0c9e59da217b", "parents": ["c483f8c3bf074db6be630993067e80c2bedd8f49"], "tags": []}, {"author": "Chris Peterson \u003ccpeterson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1443402 - Fix some -Wmissing-prototypes warnings in layout. r=dholbert\n\n-Wmissing-prototypes is a new optional warning available in clang ToT. It warns about global functions that have no previous function declaration (e.g. from an #included header file). These functions can probably be made static (allowing the compiler to better optimize them) or they may be unused.\n\nConfusingly, clang's -Wmissing-prototypes is equivalent to gcc's -Wmissing-declarations, not gcc's -Wmissing-prototypes. A function prototype is a function declaration that specifies the function's argument types. C++ requires that all function declarations specify their argument types, but C does not. As such, gcc's -Wmissing-prototypes is a C-only warning about C functions that have no previous function *prototypes* (with argument types), even if a previous function *declaration* (without argument types) was seen.\n\nMozReview-Commit-ID: FGKVLzeQ2oK", "files": ["layout/base/PresShell.cpp", "layout/base/RestyleManager.cpp", "layout/base/ZoomConstraintsClient.cpp", "layout/base/gtest/TestAccessibleCaretEventHub.cpp", "layout/base/nsLayoutDebugger.cpp", "layout/base/nsLayoutUtils.cpp", "layout/build/nsContentDLF.cpp", "layout/build/nsLayoutModule.cpp", "layout/generic/ReflowInput.cpp", "layout/generic/nsFlexContainerFrame.cpp", "layout/generic/nsFrame.cpp", "layout/generic/nsGfxScrollFrame.cpp", "layout/generic/nsSimplePageSequenceFrame.cpp", "layout/generic/nsTextFrame.cpp", "layout/ipc/RenderFrameParent.cpp", "layout/mathml/nsMathMLmactionFrame.cpp", "layout/painting/DisplayItemClip.cpp", "layout/painting/FrameLayerBuilder.cpp", "layout/painting/RetainedDisplayListBuilder.cpp", "layout/painting/nsCSSRendering.cpp", "layout/painting/nsCSSRenderingBorders.cpp", "layout/painting/nsDisplayList.cpp", "layout/style/ImageLoader.cpp", "layout/style/ServoBindings.cpp", "layout/style/StyleAnimationValue.cpp", "layout/style/nsCSSProps.cpp", "layout/svg/nsSVGIntegrationUtils.cpp", "layout/tables/nsTableRowFrame.cpp", "layout/xul/nsBoxFrame.cpp", "layout/xul/nsImageBoxFrame.cpp", "layout/xul/nsSliderFrame.cpp"], "git_node": null, "git_parents": [null], "node": "6650c3db53ec00d4e8e8cee800755607fe7f08f5", "parents": ["f56d6bee4412e82392e7bfdb7acf0c9e59da217b"], "tags": []}, {"author": "Jesse Cordeiro \u003cjesse.cordeiro@mail.utoronto.ca\u003e", "branch": "default", "desc": "Bug 1421387 - Change the error banner for styleditor load errors to warnings; r=pbro\n\nMozReview-Commit-ID: 9zdvMIuGw0P", "files": ["devtools/client/styleeditor/StyleEditorUI.jsm", "devtools/client/styleeditor/StyleSheetEditor.jsm", "devtools/client/styleeditor/styleeditor-panel.js"], "git_node": null, "git_parents": [null], "node": "08afac3c7b3c3e9bec8fb38d6e645ec1aa87897b", "parents": ["6650c3db53ec00d4e8e8cee800755607fe7f08f5"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1443205: Convert media feature values to enum classes. r=xidorn\n\nReviewers: xidorn\n\nBug #: 1443205\n\nDifferential Revision: https://phabricator.services.mozilla.com/D677\n\nMozReview-Commit-ID: E0zQHBv0Ysc\n", "files": ["layout/style/nsMediaFeatures.cpp", "layout/style/nsStyleConsts.h"], "git_node": null, "git_parents": [null], "node": "3ff3e950bcffbde279141b8fa37ccccdedaa04c4", "parents": ["08afac3c7b3c3e9bec8fb38d6e645ec1aa87897b"], "tags": []}, {"author": "Zibi Braniecki \u003czbraniecki@mozilla.com\u003e", "branch": "default", "desc": "Bug 1438608 - Improve error reporting of Fluent missing strings. r=stas\n\nMozReview-Commit-ID: 5HOsUGtDi3V", "files": ["intl/l10n/Localization.jsm"], "git_node": null, "git_parents": [null], "node": "8381ed38af109e758322070dd997e52cfab714fe", "parents": ["3ff3e950bcffbde279141b8fa37ccccdedaa04c4"], "tags": []}, {"author": "Anthony Ramine \u003cn.oxyde@gmail.com\u003e", "branch": "default", "desc": "servo: Merge #20200 - Derive some more ToCss stuff again (from servo:derive-all-the-things); r=emilio\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 17b5a8332b4309188ea7ce9c1aa5919aeb7834e6", "files": ["servo/components/style/font_face.rs", "servo/components/style/gecko/url.rs", "servo/components/style/properties/properties.mako.rs", "servo/components/style/values/computed/font.rs", "servo/components/style/values/generics/font.rs", "servo/components/style/values/specified/font.rs", "servo/components/style/values/specified/table.rs", "servo/components/style_derive/to_css.rs", "servo/components/style_traits/values.rs"], "git_node": null, "git_parents": [null], "node": "6bf29a26a10daad2756b8eb795b4b1a1c95a2da3", "parents": ["8381ed38af109e758322070dd997e52cfab714fe"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1443205: followup: Fix a typo from the previous patch. r=me\n\nMozReview-Commit-ID: Iv3sGbJUin8\n", "files": ["layout/style/nsMediaFeatures.cpp"], "git_node": null, "git_parents": [null], "node": "7a38746fc555b6a9ec1c0ea09864dd14b5b8823f", "parents": ["6bf29a26a10daad2756b8eb795b4b1a1c95a2da3"], "tags": []}, {"author": "Christoph Diehl \u003ccdiehl@mozilla.com\u003e", "branch": "default", "desc": "Bug 1436156 CHECK() in Chromium IPC code should be fatal when not fuzzing. r=jld", "files": ["ipc/chromium/src/base/logging.h"], "git_node": null, "git_parents": [null], "node": "7aef35642e5facf784d9a41b96e54cf35f6fb5a3", "parents": ["a007dd56b9947a93c276e82275d7065db1949c9e"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442984 - Correct pointer math in timer fuzzing. r=baku\n\nNegative input times would carry a negative sign all the way\nthrough to where we do pointer math. That's bad, and embaressing.\n\nAs far as I know, there was no way to have the resulting value be\noutside [-32, 28]. We coerce it down to [0, 28] to always stay in\nbounds.", "files": ["toolkit/components/resistfingerprinting/nsRFPService.cpp"], "git_node": null, "git_parents": [null], "node": "7376ba7d44f18b85ddbe0718498626d7165e9669", "parents": ["7aef35642e5facf784d9a41b96e54cf35f6fb5a3"], "tags": []}, {"author": "Erica Wright \u003cewright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401847 - Custom layout grid colors should be restored per domain. r=jdescottes\n\nMozReview-Commit-ID: GYrZl3r7040", "files": ["devtools/client/inspector/grids/grid-inspector.js", "devtools/client/inspector/grids/test/browser.ini", "devtools/client/inspector/grids/test/browser_grids_persist-color-palette.js", "devtools/client/inspector/grids/test/head.js", "devtools/client/inspector/test/shared-head.js"], "git_node": null, "git_parents": [null], "node": "6e462b0ef1692b12f6156be7877de8be0473a4c2", "parents": ["7a38746fc555b6a9ec1c0ea09864dd14b5b8823f"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1443446 - Enable geckodriver/Marionette trace output for wdspec test jobs in automation. r=ato\n\nMozReview-Commit-ID: 14l4teCjrbY", "files": ["testing/mozharness/scripts/web_platform_tests.py"], "git_node": null, "git_parents": [null], "node": "c98fcd016d3d49f9ca10adee2d3a2938c4b1fcb6", "parents": ["6e462b0ef1692b12f6156be7877de8be0473a4c2"], "tags": []}, {"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1443432 - Set scopes to push to Snap store's candidate channel r=mtabara\n\nMozReview-Commit-ID: B2Z6bdDJw6f", "files": ["taskcluster/ci/release-snap/kind.yml"], "git_node": null, "git_parents": [null], "node": "4e86684e2bf651c18f0f2261d530f87782e98919", "parents": ["c98fcd016d3d49f9ca10adee2d3a2938c4b1fcb6"], "tags": []}, {"author": "Michael Ratcliffe \u003cmratcliffe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1437807 - Enable browser_console_addonsdk_loader_exception.js in new frontend r=jdescottes\n\nMozReview-Commit-ID: 4vGsRWzuFpn", "files": ["devtools/client/webconsole/new-console-output/test/mochitest/browser.ini", "devtools/client/webconsole/new-console-output/test/mochitest/browser_console_addonsdk_loader_exception.js"], "git_node": null, "git_parents": [null], "node": "c132fa7abc4bf0f526be5d21a98bf1c8f1623b4d", "parents": ["4e86684e2bf651c18f0f2261d530f87782e98919"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1407383 - [wdspec] Remove unused imports from fixtures module. r=jgraham\n\nMozReview-Commit-ID: LgAI7fOhyqB", "files": ["testing/web-platform/tests/webdriver/tests/support/fixtures.py"], "git_node": null, "git_parents": [null], "node": "880cc555591a971a9b04790a93a694315a293297", "parents": ["c132fa7abc4bf0f526be5d21a98bf1c8f1623b4d"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1407383 - [wdspec] Remove usage of mozlog to prevent process lock. r=jgraham\n\nDue to misbehavior of the threading module in how threads are forked,\nthe mozlog module and specifically the Lock instance in StructuredLogger\ncan cause a hang of random duration when trying to require the lock.\n\nGiven that mozlog isn't used anywhere workaround this problem by\nremoving all instances of it.\n\nMozReview-Commit-ID: 10yrUIb0XW4", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/lint.whitelist", "testing/web-platform/tests/tools/webdriver/webdriver/client.py", "testing/web-platform/tests/webdriver/tests/support/fixtures.py"], "git_node": null, "git_parents": [null], "node": "c26cb6d150d56cb8b2a1e4136da7cff7c60c5d51", "parents": ["880cc555591a971a9b04790a93a694315a293297"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1407383 - [wdspec] Re-enable key.py on Linux64. r=jgraham\n\nThe timeout failures for key.py only happen on Linux 32 due to\na slow startup of Firefox for the very first test. Bug 1377805\ntracks enabling the test for Linux32.\n\nMozReview-Commit-ID: JKVMQfz0rpx", "files": ["testing/web-platform/meta/webdriver/tests/actions/key.py.ini"], "git_node": null, "git_parents": [null], "node": "bf1d69a11d6f0ff209eebe8893e143dea24a5d6f", "parents": ["c26cb6d150d56cb8b2a1e4136da7cff7c60c5d51"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1442543 - Add type checks for WebDriver:{ExecuteScript,ExecuteAsyncScript}. r=whimboo\n\nAdds type checks for the WebDriver:ExecuteScript and\nWebDriver:ExecuteAsyncScript commands.  This should help prevent\naccidental programming mistakes with the Marionette Python client.\n\nMozReview-Commit-ID: JjKgG9OWrdL", "files": ["testing/marionette/driver.js", "testing/marionette/listener.js"], "git_node": null, "git_parents": [null], "node": "b57bed48434f4ce1696e674d0e71fdcd9749f083", "parents": ["bf1d69a11d6f0ff209eebe8893e143dea24a5d6f"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "servo: Merge #20210 - style: Add a comment about the weird setup for justify-items (from emilio:justify-items-kinda-sucks); r=Manishearth\n\nAnd derive ToCss while at it.\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 226d9a5b0e69185b95c62e79b81044beba477654", "files": ["servo/components/style/values/computed/align.rs"], "git_node": null, "git_parents": [null], "node": "0ca4ef640c8b7d1a25e0dcaf80d0410b807b64d5", "parents": ["b57bed48434f4ce1696e674d0e71fdcd9749f083"], "tags": []}, {"author": "Gerald Squelart \u003cgsquelart@mozilla.com\u003e", "branch": "default", "desc": "Bug 1443367 - Rework MakeNotNull to build with VS 2017 15.6 - r=njn\n\nVS 2017 15.6 (March 2018) doesn't seem to understand\n`*DeclVal\u003cSharedFontList*\u003e()` anymore.\nTo work around this issue, the pointed-to type is now extracted in a separate\nstruct, for which we provide a specialization for raw pointers, so we don't\nencounter the shaky `*DeclVal\u003cT*\u003e()` statement anymore.\n\nMozReview-Commit-ID: FuslManbfdB", "files": ["mfbt/NotNull.h"], "git_node": null, "git_parents": [null], "node": "b9a8c5d66bb91065962537c56f4759b8f29b47a1", "parents": ["0ca4ef640c8b7d1a25e0dcaf80d0410b807b64d5"], "tags": []}, {"author": "Ken VanDine \u003cken.vandine@canonical.com\u003e", "branch": "default", "desc": "Bug 1443419 - Extract gtk30.mo files from all the Ubuntu langpacks and bundle them into the snap. r=jlorenzo\n\nMozReview-Commit-ID: BGioikt15CL", "files": ["taskcluster/docker/firefox-snap/runme.sh", "taskcluster/docker/firefox-snap/snapcraft.yaml.in"], "git_node": null, "git_parents": [null], "node": "32c3c20fd489fde2b9c90dfa94579896b6822bbf", "parents": ["b9a8c5d66bb91065962537c56f4759b8f29b47a1"], "tags": []}, {"author": "Alexandre Poirot \u003cpoirot.alex@gmail.com\u003e", "branch": "default", "desc": "Bug 1442160 - Remove unnecessary usages of generators in storage test. r=miker\n\nMozReview-Commit-ID: 3x06Clvqtyq", "files": ["devtools/client/storage/test/browser_storage_dynamic_updates_localStorage.js", "devtools/client/storage/test/browser_storage_dynamic_updates_sessionStorage.js", "devtools/client/storage/test/storage-updates.html"], "git_node": null, "git_parents": [null], "node": "d82a087fd56d04ca9034e3850750898b5a55439a", "parents": ["32c3c20fd489fde2b9c90dfa94579896b6822bbf"], "tags": []}, {"author": "Tiberius Oros \u003ctoros@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 32c3c20fd489 (bug 1443419) for shell failure on shell failure on /firefox-snap/runme.sh:53 on CLOSED TREE", "files": ["taskcluster/docker/firefox-snap/runme.sh", "taskcluster/docker/firefox-snap/snapcraft.yaml.in"], "git_node": null, "git_parents": [null], "node": "031b19788dfcff8743238dd46416333060f64245", "parents": ["d82a087fd56d04ca9034e3850750898b5a55439a"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1443180 - Move Marionette contribution advice to firefox-source-docs.m.o. r=me\n\nBecause testing/marionette/CONTRIBUTING.md is hard to find and not indexed\nanywhere, this patch moves all its content to the online documentation\nat https://firefox-source-docs.mozilla.org/testing/marionette/marionette/.\n\nThe file has been split up in four documents:\n\n  * Contributing.md, which covers introduction to new contributors\n    and a brief summary of the Marionette architecture.\n\n  * Building.md, covering build instructions.\n\n  * Patches.md, explaining how to write and get patches reviewed.\n\n  * Testing.md, which explains how to test a patch.\n\nMozReview-Commit-ID: HuEAls8Kpfg\n", "files": ["testing/marionette/CONTRIBUTING.md", "testing/marionette/doc/Building.md", "testing/marionette/doc/Contributing.md", "testing/marionette/doc/Patches.md", "testing/marionette/doc/Testing.md", "testing/marionette/doc/index.rst"], "git_node": null, "git_parents": [null], "node": "3aaddfc0ad3b2564dda5bb8136f14713901a19bc", "parents": ["7376ba7d44f18b85ddbe0718498626d7165e9669"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1443180 - Move Marionette README contents to firefox-source-docs.m.o. r=me\n\nMozReview-Commit-ID: 5t4ofKmGvyC\n", "files": ["testing/marionette/README.md", "testing/marionette/doc/Protocol.md", "testing/marionette/doc/index.rst"], "git_node": null, "git_parents": [null], "node": "056e7543e0bfc79401cdfdd1f8368c12d938160a", "parents": ["3aaddfc0ad3b2564dda5bb8136f14713901a19bc"], "tags": []}, {"author": "Csoregi Natalia \u003cncsoregi@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 7aef35642e5f (bug 1436156) for failing ipc/chromium/src/base/id_map.h:60. CLOSED TREE", "files": ["ipc/chromium/src/base/logging.h"], "git_node": null, "git_parents": [null], "node": "406e69f3fd2e8ac5c2254556a72332a02222723b", "parents": ["056e7543e0bfc79401cdfdd1f8368c12d938160a"], "tags": []}, {"author": "Jason Laster \u003cjason.laster.11@gmail.com\u003e", "branch": "default", "desc": "Bug 1443193 - Release debugger v19.2 (remove reference to babel-traverse);r=jdescottes\n\nMozReview-Commit-ID: 1vdPSsZIWp0", "files": ["devtools/client/debugger/new/README.mozilla", "devtools/client/debugger/new/debugger.js", "devtools/client/debugger/new/parser-worker.js", "devtools/client/debugger/new/pretty-print-worker.js", "devtools/client/debugger/new/search-worker.js"], "git_node": null, "git_parents": [null], "node": "dd7752d5a3927cb5545d126da66ebc19381a8805", "parents": ["406e69f3fd2e8ac5c2254556a72332a02222723b"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1443466 - Improve --marionette-port documentation. r=me\n\nExplains how --marionette-port interacts with --connect-existing.\n\nMozReview-Commit-ID: 8WwM7wHXfcn\n", "files": ["testing/geckodriver/README.md"], "git_node": null, "git_parents": [null], "node": "64b2a49404badcf0c9f4b03791306c11fb99e966", "parents": ["dd7752d5a3927cb5545d126da66ebc19381a8805"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1443466 - Link to firefox-source-docs.m.o in geckodriver README. r=me\n\nMozReview-Commit-ID: CONSsWFMQiI\n", "files": ["testing/geckodriver/README.md"], "git_node": null, "git_parents": [null], "node": "4abd228e8630bf7ba00a5d6c119dbae9873956ed", "parents": ["64b2a49404badcf0c9f4b03791306c11fb99e966"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1443466 - Reference --marionette-port in --connect-existing docs. r=me\n\nMozReview-Commit-ID: 16ZCieH8Pm4\n", "files": ["testing/geckodriver/README.md"], "git_node": null, "git_parents": [null], "node": "0cf68337438c40dfb45019148759e72