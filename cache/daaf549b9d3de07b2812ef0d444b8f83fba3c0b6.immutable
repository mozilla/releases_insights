KfG8oEYArKm", "files": ["browser/components/shell/nsGNOMEShellService.cpp"], "git_node": null, "git_parents": [null], "node": "0b8f6cf95d39dd430297fce89d9ab996361b91a4", "parents": ["11c7370ae92e99b06b6b1869edbd25418773acb8"], "tags": []}], "date": 1521763153, "git_changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "8905": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\npl -\u003e de6268083995", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "653ca8a2d6aec1477017df8120178c59d2755811", "parents": ["0b8f6cf95d39dd430297fce89d9ab996361b91a4"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\npl -\u003e ea2284c41e88", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "fe7964ba2561d10984407f9ceee2179903442b62", "parents": ["653ca8a2d6aec1477017df8120178c59d2755811"], "tags": []}], "date": 1521786185, "git_changesets": [null, null], "user": "ffxbld"}, "8906": {"changesets": [{"author": "Jorg K \u003cjorgk@jorgk.com\u003e", "branch": "THUNDERBIRD600b1_2018031401_RELBRANCH", "desc": "Backed out changeset c7ef50161fd7 (bug 1446110). a=jorgk", "files": ["tools/update-packaging/common.sh"], "git_node": null, "git_parents": [null], "node": "2a56c32fe5d171a8abbce12d6696b26e5dde83b3", "parents": ["f87ba53e04ff338f8c1cec80ec419f112b27cb73"], "tags": []}, {"author": "Jorg K \u003cjorgk@jorgk.com\u003e", "branch": "THUNDERBIRD600b1_2018031401_RELBRANCH", "desc": "Backed out changeset 40237ca354be: Backout bug 1439860 [tools/update-packaging scripts need cleaning up for safety] to build Thunderbird 60 beta. a=jorgk DONTBUILD", "files": ["tools/lint/shellcheck.yml", "tools/update-packaging/common.sh", "tools/update-packaging/make_full_update.sh", "tools/update-packaging/make_incremental_update.sh", "tools/update-packaging/test/buildrefmars.sh", "tools/update-packaging/test/catmanifest.sh", "tools/update-packaging/test/common.sh", "tools/update-packaging/test/diffmar.sh", "tools/update-packaging/test/make_full_update.sh"], "git_node": null, "git_parents": [null], "node": "e277e3f0ab13152b12744f02f5c54db3c35614ed", "parents": ["2a56c32fe5d171a8abbce12d6696b26e5dde83b3"], "tags": []}], "date": 1521795479, "git_changesets": [null, null], "user": "mozilla@jorgk.com"}, "8907": {"changesets": [{"author": "tbirdbld", "branch": "THUNDERBIRD600b1_2018032308_RELBRANCH", "desc": "Automated checkin: version bump for thunderbird 60.0b1 release. DONTBUILD CLOSED TREE a=release", "files": [], "git_node": null, "git_parents": [null], "node": "a9f88b1f29ce49ceddbd7f3f86cc5de73c03c3cb", "parents": ["e277e3f0ab13152b12744f02f5c54db3c35614ed"], "tags": ["THUNDERBIRD_60_0b1_BUILD6", "THUNDERBIRD_60_0b1_RELEASE"]}, {"author": "tbirdbld", "branch": "THUNDERBIRD600b1_2018032308_RELBRANCH", "desc": "Added THUNDERBIRD_60_0b1_RELEASE THUNDERBIRD_60_0b1_BUILD6 tag(s) for changeset a9f88b1f29ce. DONTBUILD CLOSED TREE a=release", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "7bf654d519a5fde30e5b9865aeaeecf65c55ad95", "parents": ["a9f88b1f29ce49ceddbd7f3f86cc5de73c03c3cb"], "tags": []}], "date": 1521807910, "git_changesets": [null, null], "user": "tbirdbld"}, "8908": {"changesets": [{"author": "\"Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e\"", "branch": "default", "desc": "No bug - Tagging 998a57bd05ada832da0cd78e2db628699afee80e with FIREFOX_60_0b6_BUILD1, FIREFOX_60_0b6_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "e0745c04349f023ac64d7f4c4db9d52eb66de47d", "parents": ["fe7964ba2561d10984407f9ceee2179903442b62"], "tags": []}, {"author": "\"Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e\"", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "ce509f7f5284222759f90f4f0847d305408853ba", "parents": ["e0745c04349f023ac64d7f4c4db9d52eb66de47d"], "tags": []}], "date": 1521819254, "git_changesets": [null, null], "user": "ffxbld"}, "8909": {"changesets": [{"author": "\"Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e\"", "branch": "default", "desc": "No bug - Tagging 998a57bd05ada832da0cd78e2db628699afee80e with DEVEDITION_60_0b6_BUILD1, DEVEDITION_60_0b6_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "a2135d9a2e61dd1cc81ede41ed66be700a7d904b", "parents": ["ce509f7f5284222759f90f4f0847d305408853ba"], "tags": []}], "date": 1521819448, "git_changesets": [null], "user": "ffxbld"}, "8910": {"changesets": [{"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1371888 - Cache plugin information in pluginreg.dat to avoid sync startup load. r=florian, r=mossop, a=jcristau\n\nThis changes the pluginreg.dat format to include the blocklist state.\n\nThere is now only the saved blocklist state in a plugin tag instance, rather than\nlooking it up from in there using the blocklist service, so it was renamed from\nmCachedBlocklistState to mBlocklistState. We pass the 'right' state to the plugin\ninstance when the plugintag is constructed. If we don't have state, we mark it as\nunblocked.\n\nmCachedBlocklistStateChanged was never read so it's being removed.\n\nBug 1439519 adds a 'blocklist-loaded' notification that is fired once the blocklist is loaded.\nThe plugin host implementation will listen to this in the parent process and update the\nblocklist state of all the plugins, and broadcast changes to the child process, just like when\nwe update the blocklist from the server. We now also avoid re-sending plugin content to the\ncontent processes if the plugin state hasn't changed as a result of the blocklist having been\nloaded.\n\nFinally, because new plugins should still get an up-to-date blocklist state, and\ntelemetry should get up-to-date data about which plugins are and aren't enabled\nonce we have that data, we ensure that once we've loaded the blocklist async,\nwe schedule an idle task to parse it and consider it loaded.\n\nAll this means that plugin blocklist information could be mistaken between the points where\na new plugin is installed and we first run Firefox with the new plugin, and the point where\nwe load the blocklist. Given the trade-offs, that size of window (tiny) seems OK, also given\nthat there's already a much larger window in blocklist updates (which only happen once every 24h).\n\nMozReview-Commit-ID: 1gsojRkUzTw", "files": ["dom/base/nsObjectLoadingContent.cpp", "dom/base/nsPluginArray.cpp", "dom/plugins/base/nsPluginHost.cpp", "dom/plugins/base/nsPluginTags.cpp", "dom/plugins/base/nsPluginTags.h", "toolkit/mozapps/extensions/internal/PluginProvider.jsm", "toolkit/mozapps/extensions/nsBlocklistService.js", "toolkit/mozapps/extensions/test/xpcshell/test_asyncBlocklistLoad.js"], "git_node": null, "git_parents": [null], "node": "a04c414e17eab22de90d505235d13eff0f75ebf9", "parents": ["a2135d9a2e61dd1cc81ede41ed66be700a7d904b"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1371888 - Stop having a sync IPC message to pass blocklist state. r=florian, a=jcristau\n\nBecause plugin state in the content now contains blocklist state, and is updated\nwhen the blocklist updates, we don't need to ask the parent if we're checking\nblocklist state. All the consumers should now be asking the plugin code directly,\nso we can stub out the last API here. We should look at removing the content side\nof this service entirely, but that's something for a follow-up bug.\n\nMozReview-Commit-ID: DE8s8RwT42r", "files": ["toolkit/mozapps/extensions/nsBlocklistService.js", "toolkit/mozapps/extensions/nsBlocklistServiceContent.js"], "git_node": null, "git_parents": [null], "node": "6ab477572d7fdba3c983015cafda415158a6f390", "parents": ["a04c414e17eab22de90d505235d13eff0f75ebf9"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1443870 - Remove content-process blocklist service. r=florian, a=jcristau\n\nMozReview-Commit-ID: KmlQ99rA201", "files": ["browser/installer/package-manifest.in", "toolkit/mozapps/extensions/extensions.manifest", "toolkit/mozapps/extensions/moz.build", "toolkit/mozapps/extensions/nsBlocklistServiceContent.js"], "git_node": null, "git_parents": [null], "node": "2ba05f9a5032a83b99deee4d24050bd92b3acd8a", "parents": ["6ab477572d7fdba3c983015cafda415158a6f390"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1443870 - Update tests for lack of content-process blocklist. r=florian, a=jcristau\n\nMozReview-Commit-ID: 4PyUDd6BNsM", "files": ["browser/base/content/test/plugins/browser_blocking.js", "browser/base/content/test/plugins/browser_blocklist_content.js", "browser/base/content/test/plugins/browser_bug743421.js", "browser/base/content/test/plugins/browser_bug812562.js", "browser/base/content/test/plugins/browser_plugin_reloading.js", "browser/base/content/test/plugins/browser_pluginnotification.js", "browser/base/content/test/plugins/head.js"], "git_node": null, "git_parents": [null], "node": "3f2e1e8f3d63988f5974988b8b9c9b2633de0b4a", "parents": ["2ba05f9a5032a83b99deee4d24050bd92b3acd8a"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1445990 - Fix initialization of blocklist service in non-browser apps. r=florian, a=jcristau\n\nMozReview-Commit-ID: GK4SA8gJ8Pf", "files": ["browser/components/nsBrowserGlue.js", "toolkit/mozapps/extensions/extensions.manifest", "toolkit/mozapps/extensions/moz.build", "toolkit/mozapps/extensions/nsBlocklistService.js", "toolkit/mozapps/extensions/test/xpcshell/test_asyncBlocklistLoad.js", "xpcom/system/nsIBlocklistService.idl"], "git_node": null, "git_parents": [null], "node": "ede0dcc21041cf3c16f9b1a5e02145e20e34f63a", "parents": ["3f2e1e8f3d63988f5974988b8b9c9b2633de0b4a"], "tags": []}, {"author": "Grigory Kruglov \u003cgkruglov@mozilla.com\u003e", "branch": "default", "desc": "Bug 1445462 - Pre: Clean up \"ignore records on batch failure\" code. r=rnewman, a=jcristau\n\nNo functional change; added tests to cover the decision tree a bit better, renamed stuff.\n\nMozReview-Commit-ID: LwvyBaAg421", "files": ["mobile/android/services/src/main/java/org/mozilla/gecko/sync/repositories/uploaders/BatchingUploader.java", "mobile/android/services/src/test/java/org/mozilla/gecko/background/testhelpers/NullPayloadRecord.java", "mobile/android/services/src/test/java/org/mozilla/gecko/sync/repositories/uploaders/BatchingUploaderTest.java"], "git_node": null, "git_parents": [null], "node": "ab70ed8311a24c380d7e5f215444f166b74c7827", "parents": ["ede0dcc21041cf3c16f9b1a5e02145e20e34f63a"], "tags": []}, {"author": "Grigory Kruglov \u003cgkruglov@mozilla.com\u003e", "branch": "default", "desc": "Bug 1445462 - Ensure tasks aren't scheduled during upload after flow has been aborted. r=rnewman, a=jcristau\n\nThis should have been a part of Bug 1408710, but alas, here we are.\n\nPatch changes two things:\n- serializes process failures in BatchingUploader if record-to-be-uploaded fails sanity checks and server requirements\n-- this helps us short-circuit flow in RecordsChannel\n- avoids performing any work in ServerSession's storeDone if flow has been aborted\n\nMozReview-Commit-ID: 9qevdzRvHEx", "files": ["mobile/android/services/src/main/java/org/mozilla/gecko/sync/repositories/uploaders/BatchingUploader.java", "mobile/android/services/src/main/java/org/mozilla/gecko/sync/synchronizer/RecordsChannel.java"], "git_node": null, "git_parents": [null], "node": "2d9c633028adf9a9bf47c918314684a79195254e", "parents": ["ab70ed8311a24c380d7e5f215444f166b74c7827"], "tags": []}, {"author": "Vlad Baicu \u003cvlad.baicu@softvision.ro\u003e", "branch": "default", "desc": "Bug 1444549 - Remove unused IconTabWidget XML attr. r=mcomella, a=RyanVM\n\nThis code was crashing in the framework; removing it should hopefully fix the\ncrash.\n\nMozReview-Commit-ID: 2G3q4JrJ9tP", "files": ["mobile/android/app/src/main/res/values/attrs.xml", "mobile/android/base/java/org/mozilla/gecko/widget/IconTabWidget.java"], "git_node": null, "git_parents": [null], "node": "2a545f0077a2aab0d8bbe6a8ea24cae8f9911cc3", "parents": ["2d9c633028adf9a9bf47c918314684a79195254e"], "tags": []}, {"author": "J.C. Jones \u003cjjones@mozilla.com\u003e", "branch": "default", "desc": "Bug 1444440 - Ensure the correct error is emitted for policy distrusts. r=keeler, a=jcristau\n\nBug 1441223 added MOZILLA_PKIX_ERROR_ADDITIONAL_POLICY_CONSTRAINT_FAILED to be\nemitted when we hit certificates affected by the Symantec distrust.\n\nSince some sites have multiple certificate trust paths possible, sometimes\nSEC_ERROR_UNKNOWN_ISSUER is emitted instead of the more specific error.\n\nThis patch uses a flag to ensure that the specific error is emitted out of the\nCert Verifier.", "files": ["security/certverifier/CertVerifier.cpp", "security/certverifier/NSSCertDBTrustDomain.cpp", "security/certverifier/NSSCertDBTrustDomain.h", "security/manager/ssl/tests/unit/test_symantec_apple_google.js", "security/manager/ssl/tests/unit/test_symantec_apple_google/intermediate-other-crossigned.pem", "security/manager/ssl/tests/unit/test_symantec_apple_google/intermediate-other-crossigned.pem.certspec", "security/manager/ssl/tests/unit/test_symantec_apple_google/moz.build"], "git_node": null, "git_parents": [null], "node": "f88944c6ae0d2f8d204f8489540823e7f2e697a5", "parents": ["2a545f0077a2aab0d8bbe6a8ea24cae8f9911cc3"], "tags": []}, {"author": "Jeff Gilbert \u003cjgilbert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442791 - Build _linux files on BSDs in ANGLE. r=jrmuizel, a=jcristau\n\nMozReview-Commit-ID: DWgXTnUtyrp", "files": ["gfx/angle/targets/angle_common/moz.build", "gfx/angle/targets/angle_gpu_info_util/moz.build", "gfx/angle/targets/angle_image_util/moz.build", "gfx/angle/targets/libANGLE/moz.build", "gfx/angle/targets/libEGL/moz.build", "gfx/angle/targets/libGLESv2/moz.build", "gfx/angle/targets/preprocessor/moz.build", "gfx/angle/targets/translator/moz.build", "gfx/angle/update-angle.py"], "git_node": null, "git_parents": [null], "node": "eda76924220abf46cc0280e8efce488bf5f1247c", "parents": ["f88944c6ae0d2f8d204f8489540823e7f2e697a5"], "tags": []}, {"author": "Andrew Swan \u003caswan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1446948 - Fix presentation of unsigned langpacks in about:addons. r=kmag, a=jcristau\n\nMozReview-Commit-ID: CE7tcq7Bp1g", "files": ["toolkit/mozapps/extensions/content/extensions.js", "toolkit/mozapps/extensions/content/extensions.xml", "toolkit/mozapps/extensions/test/browser/browser.ini", "toolkit/mozapps/extensions/test/browser/browser_langpack_signing.js"], "git_node": null, "git_parents": [null], "node": "1b2c48ee942a2ed462e09729bc431b4c8c8953b5", "parents": ["eda76924220abf46cc0280e8efce488bf5f1247c"], "tags": []}], "date": 1521819638, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8911": {"changesets": [{"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1445131 - When testing the event's position against the window's draggable region, read the position when it's still in the correct coordinate space. r=spohl, a=jcristau\n\nMozReview-Commit-ID: HqnXgIjDWrW", "files": ["widget/cocoa/nsChildView.mm"], "git_node": null, "git_parents": [null], "node": "5f60c50c33cb871516e833ac24ef8d0fcc7d2132", "parents": ["1b2c48ee942a2ed462e09729bc431b4c8c8953b5"], "tags": []}, {"author": "Chris H-C \u003cchutten@mozilla.com\u003e", "branch": "default", "desc": "Bug 1439222 - Stop recording VSIZE_MAX_CONTIGUOUS on Win64. r=erahm, a=jcristau\n\nMozReview-Commit-ID: 8Tjz3tfwGfw", "files": ["toolkit/components/telemetry/TelemetrySession.jsm"], "git_node": null, "git_parents": [null], "node": "ea46bb8bb65a6be282be80a9276b9656454fcedd", "parents": ["5f60c50c33cb871516e833ac24ef8d0fcc7d2132"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1444630 - Don't update dictionary after calling UninitSpellChecker. r=masayuki, a=jcristau\n\nWhen calling UninitSpellChecker during calling UpdateDictionary, this crash\noccurs.  Since Thunderbird calls UninitSpellChecker by [Recheck Text] button,\nthis only occurs on Thunderbird.\n\nAfter calling UninitSpellChecker, we should not update dictionary.\n\nMozReview-Commit-ID: K4SPJ5FDo8n", "files": ["editor/libeditor/crashtests/1444630.html", "editor/libeditor/crashtests/crashtests.list", "editor/spellchecker/EditorSpellCheck.cpp"], "git_node": null, "git_parents": [null], "node": "16f5fd01de8087005c747a60607c19606c0f47b1", "parents": ["ea46bb8bb65a6be282be80a9276b9656454fcedd"], "tags": []}], "date": 1521820977, "git_changesets": [null, null, null], "user": "ryanvm@gmail.com"}, "8912": {"changesets": [{"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1447987 - Additional engine for mitigation. r=florian, a=RyanVM", "files": ["browser/components/nsBrowserGlue.js"], "git_node": null, "git_parents": [null], "node": "d77ddb1c28caedfad7b2c5709eb8cd3620e6c7b6", "parents": ["16f5fd01de8087005c747a60607c19606c0f47b1"], "tags": []}], "date": 1521828218, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "8913": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox