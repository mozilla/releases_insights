ult", "desc": "Bug 1440627 - Use fallible setLength in StructuredCloneHolder. r=baku", "files": ["dom/base/StructuredCloneHolder.cpp", "dom/crypto/WebCryptoCommon.h", "dom/url/URLSearchParams.cpp"], "git_node": null, "git_parents": [null], "node": "b8f0901cc921872fe903a90a1fcab96b3aca2c24", "parents": ["2b6ae1c732d4ed8da69286869faa59de05697780"], "tags": []}, {"author": "Christian Holler \u003ccholler@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442716 - [caps] Handle empty origin gracefully in FUZZING. r=baku", "files": ["caps/nsJSPrincipals.cpp"], "git_node": null, "git_parents": [null], "node": "23b9459e1db5a9a2096b37ae706b3a023b435505", "parents": ["b8f0901cc921872fe903a90a1fcab96b3aca2c24"], "tags": []}, {"author": "Simon Fraser \u003csfraser@mozilla.com\u003e", "branch": "default", "desc": "Bug 1436369 Move buildbot periodic file updates to clearer name r=callek\n\nSummary:\nWe'll be adding the new periodic file updates task to run in parallel. This patch\nmoves the existing one to make it clear it's running on buildbot, so we don't get confused\nlater on.\n\nReviewers: Callek\n\nReviewed By: Callek\n\nBug #: 1436369\n\nDifferential Revision: https://phabricator.services.mozilla.com/D681", "files": ["taskcluster/ci/repo-update-bb/kind.yml", "taskcluster/ci/repo-update/kind.yml", "taskcluster/taskgraph/target_tasks.py"], "git_node": null, "git_parents": [null], "node": "b3b9609544ec30fffe6efa6100db7fd4806b23bb", "parents": ["23b9459e1db5a9a2096b37ae706b3a023b435505"], "tags": []}, {"author": "Simon Fraser \u003csfraser@mozilla.com\u003e", "branch": "default", "desc": "Bug 1436369 Add taskcluster periodic file updates r=callek\n\nReviewers: Callek\n\nReviewed By: Callek\n\nDifferential Revision: https://phabricator.services.mozilla.com/D683", "files": ["taskcluster/ci/repo-update/kind.yml", "taskcluster/docs/kinds.rst", "taskcluster/taskgraph/target_tasks.py"], "git_node": null, "git_parents": [null], "node": "370c9dbdd5729e944b277706fa73785a8fd6fef0", "parents": ["b3b9609544ec30fffe6efa6100db7fd4806b23bb"], "tags": []}, {"author": "Neil Deakin \u003cneil@mozilla.com\u003e", "branch": "default", "desc": "Bug 1440146, remove unused menubutton-item binding, r=bgrins", "files": ["toolkit/content/widgets/menu.xml", "toolkit/content/xul.css"], "git_node": null, "git_parents": [null], "node": "33d3f93924ac7a7e6b6b46fc3eb791089eb74faa", "parents": ["370c9dbdd5729e944b277706fa73785a8fd6fef0"], "tags": []}, {"author": "Simon Fraser \u003csfraser@mozilla.com\u003e", "branch": "default", "desc": "Bug 1436469 Fix task definition r=callek CLOSED TREE", "files": ["taskcluster/ci/repo-update/kind.yml"], "git_node": null, "git_parents": [null], "node": "a03dea3992782ed64a7a2c7d8d9958cee621174e", "parents": ["33d3f93924ac7a7e6b6b46fc3eb791089eb74faa"], "tags": []}, {"author": "Csoregi Natalia \u003cncsoregi@mozilla.com\u003e", "branch": "default", "desc": "Backed out 3 changesets (bug 1436469) for Gecko Decision task failure. CLOSED TREE\n\nBacked out changeset a03dea399278 (bug 1436469)\nBacked out changeset 370c9dbdd572 (bug 1436369)\nBacked out changeset b3b9609544ec (bug 1436369)", "files": ["taskcluster/ci/repo-update-bb/kind.yml", "taskcluster/ci/repo-update/kind.yml", "taskcluster/docs/kinds.rst", "taskcluster/taskgraph/target_tasks.py"], "git_node": null, "git_parents": [null], "node": "3363cb492aa149a43e196e127080b8b5bcf60684", "parents": ["a03dea3992782ed64a7a2c7d8d9958cee621174e"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Merge autoland to mozilla-central. a=merge", "files": ["dom/base/nsINode.cpp", "dom/base/nsINode.h"], "git_node": null, "git_parents": [null, null], "node": "b498494cfac55b99668607280756bee3cb60791a", "parents": ["a4ef1082c51d5b4508882c22487f6c8de5b35e2a", "a10eb278c3b247242196b015e5e71a5058ef1166"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-inbound to mozilla-central. a=merge", "files": ["taskcluster/ci/repo-update/kind.yml", "testing/marionette/CONTRIBUTING.md"], "git_node": null, "git_parents": [null, null], "node": "efe1f380d0279d7786b0c6340a60aaf6c76eabbe", "parents": ["b498494cfac55b99668607280756bee3cb60791a", "3363cb492aa149a43e196e127080b8b5bcf60684"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland", "files": ["testing/marionette/CONTRIBUTING.md"], "git_node": null, "git_parents": [null, null], "node": "c2469b3f1a0441cdaa032633fc61c311ceaabbd8", "parents": ["ca36a410083e0d3e83da58ef4cace584c5bd65ae", "efe1f380d0279d7786b0c6340a60aaf6c76eabbe"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414901 - part 1a - make mozWritePoison respect its documentation; r=Waldo\n\nThe documentation for mozWritePoison says that only an even number of\nsizeof(uintptr_t) bytes are overwritten; any trailing bytes are not\ntouched.  This documentation doesn't correspond to how the function\nactually works.  The function as written will happily overwrite trailing\nbytes and any bytes not contained in the object, if the passed-in size\nisn't divisible by sizeof(uintptr_t).  Let's fix that.", "files": ["mfbt/Poison.h"], "git_node": null, "git_parents": [null], "node": "0d24a10002a9410c461a967ea397b06ebef2f9dc", "parents": ["3363cb492aa149a43e196e127080b8b5bcf60684"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414901 - part 1b - eliminate alignment requirements for poisoning memory; r=Waldo\n\nmozWritePoison secretly depended on the passed-in pointer being aligned\nas though it were a pointer to uintptr_t, as it used bare stores to\nC-casted pointers to accomplish poisoning.  But this is an unnecessary\nlimitation: we can use memcpy and rely on the compiler to appropriately\ninline the store to an unaligned store instruction if necessary.", "files": ["mfbt/Poison.h"], "git_node": null, "git_parents": [null], "node": "8c6f13a64b497f968eab5e4d618f70a1299ec90b", "parents": ["0d24a10002a9410c461a967ea397b06ebef2f9dc"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414901 - part 2 - poison Maybe\u003cT\u003e instances when not in use; r=Waldo", "files": ["mfbt/Maybe.h"], "git_node": null, "git_parents": [null], "node": "06d57a43b11a4ade5379efdfaafd2736117a1922", "parents": ["8c6f13a64b497f968eab5e4d618f70a1299ec90b"], "tags": []}, {"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1433459 - part 3: Fix bad scopes for aliases task r=mtabara", "files": ["taskcluster/ci/release-bouncer-aliases/kind.yml", "taskcluster/taskgraph/transforms/bouncer_aliases.py"], "git_node": null, "git_parents": [null], "node": "f51ec69adf23c9ea2ed65ded3b78c1c5c1712d7f", "parents": ["06d57a43b11a4ade5379efdfaafd2736117a1922"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 851471 - Decommission nsIDownloadManager. r=mak\n\nMozReview-Commit-ID: HfqdrdJcLrh", "files": ["browser/base/content/test/static/browser_all_files_referenced.js", "browser/installer/package-manifest.in", "mobile/android/installer/package-manifest.in", "toolkit/components/build/moz.build", "toolkit/components/build/nsToolkitCompsCID.h", "toolkit/components/build/nsToolkitCompsModule.cpp", "toolkit/components/downloads/moz.build", "toolkit/components/downloads/nsDownloadManager.cpp", "toolkit/components/downloads/nsDownloadManager.h", "toolkit/components/downloads/nsIDownload.idl", "toolkit/components/downloads/nsIDownloadManager.idl", "toolkit/components/downloads/nsIDownloadManagerUI.idl", "toolkit/components/downloads/nsIDownloadProgressListener.idl", "toolkit/components/moz.build", "toolkit/modules/Services.jsm", "toolkit/modules/tests/xpcshell/test_Services.js", "toolkit/themes/linux/mozapps/downloads/downloadIcon.png", "toolkit/themes/linux/mozapps/jar.mn", "toolkit/themes/osx/mozapps/downloads/downloadIcon.png", "toolkit/themes/osx/mozapps/jar.mn", "toolkit/themes/windows/mozapps/downloads/downloadIcon.png", "toolkit/themes/windows/mozapps/jar.mn"], "git_node": null, "git_parents": [null], "node": "89eeb314f7ba2b93734fa6331ebfae4c2729ac3b", "parents": ["f51ec69adf23c9ea2ed65ded3b78c1c5c1712d7f"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1280099 - Retain image size after stopping MediaEngineDefaultVideoSource. r=jib\n\nMozReview-Commit-ID: Kacol64Jo0F", "files": ["dom/media/webrtc/MediaEngineDefault.cpp"], "git_node": null, "git_parents": [null], "node": "42c6ec43f7829aa95692c83cbb8a75e77bd9dd33", "parents": ["89eeb314f7ba2b93734fa6331ebfae4c2729ac3b"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1436694 - Make a PostTask variant that returns a MozPromise. r=jib, r=jya\n\nMozReview-Commit-ID: 76mLpntaU5v", "files": ["dom/media/MediaManager.cpp", "dom/media/MediaManager.h"], "git_node": null, "git_parents": [null], "node": "59f19fc034cf7fc035710ff97e5b0a983ca920e6", "parents": ["42c6ec43f7829aa95692c83cbb8a75e77bd9dd33"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1436694 - MozPromisify device initialization and move it to SourceListener. r=jib\n\nThis so that SourceListener can keep its internal state in sync with the result\nof the start operation.\n\nMozReview-Commit-ID: Cgl5TFnpCeW", "files": ["dom/media/MediaManager.cpp"], "git_node": null, "git_parents": [null], "node": "0451fe123f5b9168de34b3f927bb421c8e9864ca", "parents": ["59f19fc034cf7fc035710ff97e5b0a983ca920e6"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1436694 - Clarify that MediaEngineSources can be double-stopped. r=padenot\n\nThis is already true for the audio sources. It should be for all.\n\nCrashtests showed that shutting down amidst the async init can lead to\ndouble-stops. It is impossible to completely protect yourself from them without\nwaiting for all queued operations to resolve (results to become known) before\ntaking action. Doing that would require a refactor in MediaManager and cause\nhigher latency for device operations so it seems like the wrong way to go.\n\nMozReview-Commit-ID: 5Cci6whzTL7", "files": ["dom/media/webrtc/MediaEngineDefault.cpp", "dom/media/webrtc/MediaEngineRemoteVideoSource.cpp", "dom/media/webrtc/MediaEngineSource.h", "dom/media/webrtc/MediaEngineTabVideoSource.cpp"], "git_node": null, "git_parents": [null], "node": "04b165b560de7746ab20988189619bd213c7c01b", "parents": ["0451fe123f5b9168de34b3f927bb421c8e9864ca"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1436074 - Reduce turn-off timer by time since we turned on. r=jib\n\nMozReview-Commit-ID: 2AvnJxUSTmy", "files": ["dom/media/MediaManager.cpp"], "git_node": null, "git_parents": [null], "node": "07fad8b0b417d9ae8580f23d697172a3735b546b", "parents": ["04b165b560de7746ab20988189619bd213c7c01b"], "tags": []}, {"author": "Stephen A Pohl \u003cspohl.mozilla.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1362303: Avoid crashes when dragging on macOS due to failed allocations of large shmem segments. r=glandium", "files": ["dom/base/nsContentUtils.cpp", "ipc/glue/SharedMemoryBasic_mach.mm"], "git_node": null, "git_parents": [null], "node": "7a6bc227dc03ad3cfa268cb4b6349d191b46baf5", "parents": ["07fad8b0b417d9ae8580f23d697172a3735b546b"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1434822 part 1: Disable COM ping functionality for our parent process instead of for external processes. r=aklotz\n\nMozReview-Commit-ID: 2ayfzIxh8Lo", "files": ["ipc/mscom/FastMarshaler.cpp"], "git_node": null, "git_parents": [null], "node": "1556761288cc035d01169df3752c005ec511c5de", "parents": ["c2469b3f1a0441cdaa032633fc61c311ceaabbd8"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1434822 part 2: mscom: Add a function to disconnect all remote clients associated with a given target. r=aklotz\n\nBecause Interceptors disable COM garbage collection to improve performance, they never receive Release calls from remote clients.\nIf the object can be shut down while clients still hold a reference, this function can be used to force COM to disconnect all remote connections (using CoDisconnectObject) and thus release the associated references to the Interceptor, its target and any objects associated with the HandlerProvider.\nA HandlerProvider::DisconnectHandlerRemotes method also had to be added to allow HandlerProviders to disconnect clients for their own objects.\n\nMozReview-Commit-ID: JaxEkOtrP1M", "files": ["ipc/mscom/IHandlerProvider.h", "ipc/mscom/Interceptor.cpp", "ipc/mscom/Interceptor.h", "ipc/mscom/MainThreadHandoff.cpp", "ipc/mscom/MainThreadHandoff.h"], "git_node": null, "git_parents": [null], "node": "86288678c3d6a67b9f581f7396d063d199ea5af3", "parents": ["1556761288cc035d01169df3752c005ec511c5de"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1434822 part 3: On Windows, when a content Accessible shuts down, disconnect all associated remote clients. r=MarcoZ\n\nTo improve performance for cross-process COM, we disable COM garbage collection.\nHowever, this means we never receive Release calls from clients, so defunct accessibles can never be deleted.\nSince we know when an accessible is shutting down, we can work around this by forcing COM to disconnect this object from all of its remote clients, which will cause associated references to be released.\n\nMozReview-Commit-ID: 5sIuxnaRJWj", "files": ["accessible/ipc/win/HandlerProvider.cpp", "accessible/ipc/win/HandlerProvider.h", "accessible/windows/msaa/AccessibleWrap.cpp"], "git_node": null, "git_parents": [null], "node": "4811c426205d64975325c471f897ede03fba2757", "parents": ["86288678c3d6a67b9f581f7396d063d199ea5af3"], "tags": []}, {"author": "Nicolas Silva \u003cnical@fastmail.com\u003e", "branch": "default", "desc": "servo: Merge #20213 - Add the option in servo-tidy to not check for alphabetical ordering (from nical:tidy-alphabetical-bs); r=jdm\n\n\u003c!-- Please describe your changes on the following line: --\u003e\n\nAn option to disable checking for alphabetical ordering of use/mod/extern crate statements in servo-tidy.\n\nThese checks are still enabled by default but WebRender will turn them off.\n\n---\n\u003c!-- Thank you for contributing to Servo! Please replace each `[ ]` by `[X]` when the step is complete, and replace `__` with appropriate data: --\u003e\n- [x] `./mach build -d` does not report any errors\n- [x] `./mach test-tidy` does not report any errors\n\n\u003c!-- Either: --\u003e\n- [ ] There are tests for these changes OR\n- [x] These changes do not require tests because it doesn't affect servo.\n\n\u003c!-- Also, please make sure that \"Allow edits from maintainers\" checkbox is checked, so that we can help you if you get stuck somewhere along the way.--\u003e\n\n\u003c!-- Pull requests that do not address these steps are welcome, but they will require additional verification as part of the review process. --\u003e\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: c8eceb90a15f0a28478bf0d26702070225d5f1c1", "files": ["servo/python/tidy/servo_tidy/tidy.py", "servo/servo-tidy.toml"], "git_node": null, "git_parents": [null], "node": "a30bf832849293bae5b24454518121a74ab4d7bc", "parents": ["4811c426205d64975325c471f897ede03fba2757"], "tags": []}, {"author": "Kirk Steuber \u003cksteuber@mozilla.com\u003e", "branch": "default", "desc": "Bug 1436851 - Implement mechanism to disable system addon updates via enterprise policy r=aswan,Felipe,rhelmer\n\nThis patch additionally removes the check where if AddonManagerPrivate.backgroundUpdateTimerHandler does not call AddonManagerInternal.backgroundUpdateCheck if updates to all addons are disabled. The check is redundant as AddonManagerInternal.backgroundUpdateCheck makes those same checks.\n\nMozReview-Commit-ID: FxS8127JYkn", "files": ["toolkit/mozapps/extensions/AddonManager.jsm"], "git_node": null, "git_parents": [null], "node": "da7d8d24de6135355ebe6b2f72eefa8c475a9d30", "parents": ["a30bf832849293bae5b24454518121a74ab4d7bc"], "tags": []}, {"author": "Kirk Steuber \u003cksteuber@mozilla.com\u003e", "branch": "default", "desc": "Bug 1436851 - Prevent AddonTestUtils.jsm from overriding a pref value r=kmag\n\nAddonTestUtils.overrideBuiltIns sets |security.turn_off_all_security_so_that_viruses_can_take_over_this_computer| to true when it starts. It then naively sets it to false, assuming that that was the original value. This patch simply corrects that behavior to return the value to the previously set value, whatever that may have been.\n\nMozReview-Commit-ID: KbhmoixBvpW", "files": ["toolkit/mozapps/extensions/internal/AddonTestUtils.jsm"], "git_node": null, "git_parents": [null], "node": "3a38bc5be24cf2466f7184842bedd199898f66b3", "parents": ["da7d8d24de6135355ebe6b2f72eefa8c475a9d30"], "tags": []}, {"author": "Kirk Steuber \u003cksteuber@mozilla.com\u003e", "branch": "default", "desc": "Bug 1436851 - Create an enterprise policy to disable system addon updates r=Felipe\n\nMozReview-Commit-ID: AzxFGpFvxtm", "files": ["browser/components/enterprisepolicies/EnterprisePolicies.js", "browser/components/enterprisepolicies/Policies.jsm", "browser/components/enterprisepolicies/schemas/policies-schema.json"], "git_node": null, "git_parents": [null], "node": "c173796004442a82a84c602f9cfad4be8a9c1132", "parents": ["3a38bc5be24cf2466f7184842bedd199898f66b3"], "tags": []}, {"author": "Kirk Steuber \u003cksteuber@mozilla.com\u003e", "branch": "default", "desc": "Bug 1436851 - Add test for enterprise policy to disable system addon updates r=Felipe,rhelmer\n\nMozReview-Commit-ID: K3NtpeVLFf4", "files": ["browser/components/enterprisepolicies/tests/EnterprisePolicyTesting.jsm", "browser/components/enterprisepolicies/tests/browser/head.js", "browser/components/enterprisepolicies/tests/moz.build", "toolkit/mozapps/extensions/test/xpcshell/test_system_update_enterprisepolicy.js", "toolkit/mozapps/extensions/test/xpcshell/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "7c7f2203da21f40a2f02fb2f068a2a45d9f62ae6", "parents": ["c173796004442a82a84c602f9cfad4be8a9c1132"], "tags": []}, {"author": "Kit Cambridge \u003ckit@yakshaving.ninja\u003e", "branch": "default", "desc": "Bug 1443278 - Fetch folder children in a single statement when staging synced items for upload. r=tcsc\n\nMozReview-Commit-ID: 3wLATQGV4W8", "files": ["toolkit/components/places/SyncedBookmarksMirror.jsm", "toolkit/components/places/tests/sync/test_bookmark_deletion.js"], "git_node": null, "git_parents": [null], "node": "89666bb6fff92ffdac4108b7a4b2a5b0f9e40f30", "parents": ["7c7f2203da21f40a2f02fb2f068a2a45d9f62ae6"], "tags": []}, {"author": "Kit Cambridge \u003ckit@yakshaving.ninja\u003e", "branch": "default", "desc": "Bug 1443619 - Ignore items with older creation dates that are already flagged for explicit weak upload. r=eoger\n\nMozReview-Commit-ID: 5Sgn9WLebv2", "files": ["toolkit/components/places/SyncedBookmarksMirror.jsm", "toolkit/components/places/tests/sync/test_bookmark_explicit_weakupload.js"], "git_node": null, "git_parents": [null], "node": "363ed8b83c214b6366441166b14d01ca962d7d61", "parents": ["89666bb6fff92ffdac4108b7a4b2a5b0f9e40f30"], "tags": []}, {"author": "Jed Davis \u003cjld@mozilla.com\u003e", "branch": "default", "desc": "Bug 1443612 - Pre-start cubeb before content sandboxing if not remoting audio. r=kinetik\n\nMozReview-Commit-ID: HBtBH5gCKR4", "files": ["dom/ipc/ContentChild.cpp"], "git_node": null, "git_parents": [null], "node": "94db8d320385886ad9a96e3648bd935f64582b49", "parents": ["363ed8b83c214b6366441166b14d01ca962d7d61"], "tags": []}, {"author": "Matt Brubeck \u003cmbrubeck@mozilla.com\u003e", "branch": "default", "desc": "Bug 1443248 - Update u2fhid to core-foundation-sys 0.5. r=ttaubert\n\nMozReview-Commit-ID: 4xTSQpvHHAV", "files": ["Cargo.lock", "dom/webauthn/u2f-hid-rs/Cargo.toml", "dom/webauthn/u2f-hid-rs/src/macos/iokit.rs", "third_party/rust/core-foundation-sys-0.3.1/.cargo-checksum.json", "third_party/rust/core-foundation-sys-0.3.1/Cargo.toml", "third_party/rust/core-foundation-sys-0.3.1/build.rs", "third_party/rust/core-foundation-sys-0.3.1/src/array.rs", "third_party/rust/core-foundation-sys-0.3.1/src/base.rs", "third_party/rust/core-foundation-sys-0.3.1/src/bundle.rs", "third_party/rust/core-foundation-sys-0.3.1/src/data.rs", "third_party/rust/core-foundation-sys-0.3.1/src/date.rs", "third_party/rust/core-foundation-sys-0.3.1/src/dictionary.rs", "third_party/rust/core-foundation-sys-0.3.1/src/error.rs", "third_party/rust/core-foundation-sys-0.3.1/src/lib.rs", "third_party/rust/core-foundation-sys-0.3.1/src/messageport.rs", "third_party/rust/core-foundation-sys-0.3.1/src/number.rs", "third_party/rust/core-foundation-sys-0.3.1/src/propertylist.rs", "third_party/rust/core-foundation-sys-0.3.1/src/runloop.rs", "third_party/rust/core-foundation-sys-0.3.1/src/set.rs", "third_party/rust/core-foundation-sys-0.3.1/src/string.rs", "third_party/rust/core-foundation-sys-0.3.1/src/url.rs"], "git_node": null, "git_parents": [null], "node": "141a3103a248206af8178cdac0e5c90cb4f7efec", "parents": ["94db8d320385886ad9a96e3648bd935f64582b49"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to mozilla-inbound", "files": [], "git_node": null, "git_parents": [null, null], "node": "9ee84efab9c8ad0835f8f5f1630138e9049ca53b", "parents": ["7a6bc227dc03ad3cfa268cb4b6349d191b46baf5", "efe1f380d0279d7786b0c6340a60aaf6c76eabbe"], "tags": []}, {"author": "ffxbld", "branch": "default", "desc": "No bug, Automated HSTS preload list update from host bld-linux64-spot-303 - a=hsts-update", "files": ["security/manager/ssl/nsSTSPreloadList.errors", "security/manager/ssl/nsSTSPreloadList.inc"], "git_node": null, "git_parents": [null], "node": "43622ad45afeb27ba416f9613513730b4e59ca40", "parents": ["efe1f380d0279d7786b0c6340a60aaf6c76eabbe"], "tags": []}, {"author": "ffxbld", "branch": "default", "desc": "No bug, Automated HPKP preload list update from host bld-linux64-spot-303 - a=hpkp-update", "files": ["security/manager/ssl/StaticHPKPins.h"], "git_node": null, "git_parents": [null], "node": "c7543a3e938d5ec408a7d0c93dc71b40607e7d5b", "parents": ["43622ad45afeb27ba416f9613513730b4e59ca40"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Merge Autoland to mozilla-central. a=merge", "files": [], "git_node": null, "git_parents": [null, null], "node": "f89b9a3c44d2a340de57b0645cf6fb682c0c94db", "parents": ["c7543a3e938d5ec408a7d0c93dc71b40607e7d5b", "c2469b3f1a0441cdaa032633fc61c311ceaabbd8"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-inbound to mozilla-central. a=merge", "files": ["toolkit/components/downloads/moz.build", "toolkit/components/downloads/nsDownloadManager.cpp", "toolkit/components/downloads/nsDownloadManager.h", "toolkit/components/downloads/nsIDownload.idl", "toolkit/components/downloads/nsIDownloadManager.idl", "toolkit/components/downloads/nsIDownloadManagerUI.idl", "toolkit/components/downloads/nsIDownloadProgressListener.idl", "toolkit/themes/linux/mozapps/downloads/downloadIcon.png", "toolkit/themes/osx/mozapps/downloads/downloadIcon.png", "toolkit/themes/windows/mozapps/downloads/downloadIcon.png"], "git_node": null, "git_parents": [null, null], "node": "bccdc684210431c233622650a91454c09f6af9eb", "parents": ["f89b9a3c44d2a340de57b0645cf6fb682c0c94db", "9ee84efab9c8ad0835f8f5f1630138e9049ca53b"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland", "files": ["toolkit/components/downloads/moz.build", "toolkit/components/downloads/nsDownloadManager.cpp", "toolkit/components/downloads/nsDownloadManager.h", "toolkit/components/downloads/nsIDownload.idl", "toolkit/components/downloads/nsIDownloadManager.idl", "toolkit/components/downloads/nsIDownloadManagerUI.idl", "toolkit/components/downloads/nsIDownloadProgressListener.idl", "toolkit/themes/linux/mozapps/downloads/downloadIcon.png", "toolkit/themes/osx/mozapps/downloads/downloadIcon.png", "toolkit/themes/windows/mozapps/downloads/downloadIcon.png"], "git_node": null, "git_parents": [null, null], "node": "d9e59ad16af432f6a57e91e57aad49ad0771d7c5", "parents": ["141a3103a248206af8178cdac0e5c90cb4f7efec", "bccdc684210431c233622650a91454c09f6af9eb"], "tags": []}, {"author": "Byron Campen [:bwc] \u003cdocfaraday@gmail.com\u003e", "branch": "default", "desc": "Bug 1442404: Don't spin STS when shutting down the mtransport thread. r=drno\n\nMozReview-Commit-ID: 47BImEsl9xi", "files": ["media/mtransport/nr_socket_prsock.cpp"], "git_node": null, "git_parents": [null], "node": "82b7012c02bc586fe8cc682ce5e8b925f6dcfcd7", "parents": ["d9e59ad16af432f6a57e91e57aad49ad0771d7c5"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442850 - Update how history mode and cookie lifetime controls interact to fit our new preferences UI. r=Gijs\n\nWe recently updated the cookie settings in about:preferences to live outside\nof the history mode settings, but did not change the way that changes to history\nmode (toggling the privatebrowsing.autostart pref) reflected in the cookies section.\n\nThis patch takes care of that by moving the cookie related pieces out of the code\nthat sets history settings and makes sure that the respective functions get called\nin all appropriate cases.\n\nI also moved some site data settings code to be closer to the cookies code.\n\nMozReview-Commit-ID: 6ly079uDz4C", "files": ["browser/components/preferences/in-content/privacy.js", "browser/components/preferences/in-content/privacy.xul", "browser/components/preferences/in-content/tests/privacypane_tests_perwindow.js"], "git_node": null, "git_parents": [null], "node": "f1e47fffcf5d62a812f21b91bf9e62432cd0f4f7", "parents": ["82b7012c02bc586fe8cc682ce5e8b925f6dcfcd7"], "tags": []}, {"author": "Edouard Oger \u003ceoger@fastmail.com\u003e", "branch": "default", "desc": "Bug 1439777 p1 - Remove X-Weave-Alert support. r=markh\n\nMozReview-Commit-ID: L9GTrn8HPYJ", "files": ["services/sync/modules/policies.js", "services/sync/modules/service.js", "services/sync/modules/status.js", "services/sync/services-sync.js", "services/sync/tests/unit/test_errorhandler_eol.js", "services/sync/tests/unit/xpcshell.ini", "services/sync/tps/extensions/tps/resource/tps.jsm"], "git_node": null, "git_parents": [null], "node": "76c0ebfa6f087fec78b2be5f0ac102a59e42e96c", "parents": ["f1e47fffcf5d62a812f21b91bf9e62432cd0f4f7"], "tags": []}, {"author": "Edouard Oger \u003ceoger@fastmail.com\u003e", "branch": "default", "desc": "Bug 1439777 p2 - Remove weave:ui:* related code. r=markh,tcsc\n\nMozReview-Commit-ID: D1H36YeiJCS", "files": ["browser/base/content/browser-sync.js", "browser/components/customizableui/test/browser_remote_tabs_button.js", "services/sync/modules/constants.js", "services/sync/modules/policies.js", "services/sync/services-sync.js", "services/sync/tests/unit/test_errorhandler_1.js", "services/sync/tests/unit/test_errorhandler_2.js", "services/sync/tests/unit/test_errorhandler_filelog.js", "services/sync/tests/unit/test_fxa_node_reassignment.js", "services/sync/tests/unit/test_node_reassignment.js", "services/sync/tests/unit/test_service_sync_updateEnabledEngines.js", "tools/lint/eslint/modules.json"], "git_node": null, "git_parents": [null], "node": "157f93b585b18e810942d3fc421b8dc9327b4419", "parents": ["76c0ebfa6f087fec78b2be5f0ac102a59e42e96c"], "tags": []}, {"author": "Martin Robinson \u003cmrobinson@igalia.com\u003e", "branch": "default", "desc": "servo: Merge #20214 - Stop using LocalClip::RoundedRect (from mrobinson:stop-using-using-localclip-roundedrect); r=glennw\n\nWe would like to remove this functionality from WebRender, so convert\nits use to clip scroll nodes. This change also removes the redundant\nBlocBlockStackingContextType in favor of Option\u003cStackingContextType\u003e,\nwhich is just as expressive. This simplifies the code a bit.\n\n\u003c!-- Please describe your changes on the following line: --\u003e\n\n---\n\u003c!-- Thank you for contributing to Servo! Please replace each `[ ]` by `[X]` when the step is complete, and replace `__` with appropriate data: --\u003e\n- [x] `./mach build -d` does not report any errors\n- [x] `./mach test-tidy` does not report any errors\n- [ ] These changes fix #__ (github issue number if applicable).\n\n\u003c!-- Either: --\u003e\n- [ ] There are tests for these changes OR\n- [x] These changes do not require tests because they should not change behavior.\n\n\u003c!-- Also, please make sure that \"Allow edits from maintainers\" checkbox is checked, so that we can help you if you get stuck somewhere along the way.--\u003e\n\n\u003c!-- Pull requests that do not address these steps are welcome, but they will require additional verification as part of the review process. --\u003e\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 26d2e77410f8fbc308f63282f435fbc8788c9bcc", "files": ["servo/components/layout/block.rs", "servo/components/layout/display_list/builder.rs"], "git_node": null, "git_parents": [null], "node": "60b1f8616b22e378c8b0575d9d62bc1ff6463fc6", "parents": ["157f93b585b18e810942d3fc421b8dc9327b4419"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442255 - 1. Replace setLastIntent with extras bundle; r=esawin\n\nGeckoLoader.setLastIntent is not a very good API for setting environment\nvariables and is often forgotten. Replace it with an extras bundle that\nis passed to setupGeckoEnvironment.\n\nMozReview-Commit-ID: IFhHjLdwFC5", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/mozglue/GeckoLoader.java"], "git_node": null, "git_parents": [null], "node": "47c1e6667b85c4c7fca36f2454bdd54b1474f0af", "parents": ["60b1f8616b22e378c8b0575d9d62bc1ff6463fc6"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442255 - 2. Replace GeckoThread fields with extras bundle; r=esawin\n\nIntroduce an extras bundle in GeckoThread, which we use to store things\nsuch as extra main process arguments and child process FDs. Also use the\nextras bundle to store environment variables to be passed to\nGeckoLoader.\n\nMozReview-Commit-ID: tRlBaAXxVa", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoThread.java"], "git_node": null, "git_parents": [null], "node": "ab953c63958b117b87353f94c682f7e6817bfd04", "parents": ["47c1e6667b85c4c7fca36f2454bdd54b1474f0af"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442255 - 3. Use extras bundle to initialize Gecko in GeckoView; r=esawin\n\nUse extras bundle to initialize Gecko in GeckoSession and\nGeckoViewActivity.\n\nMozReview-Commit-ID: 7dtaziVBDcg", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/TestRunnerActivity.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSession.java", "mobile/android/geckoview_example/src/main/java/org/mozilla/geckoview_example/GeckoViewActivity.java"], "git_node": null, "git_parents": [null], "node": "10aa0b36b674537050b0e6297fe9df01ee5e879d", "parents": ["ab953c63958b117b87353f94c682f7e6817bfd04"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442255 - 4. Use extras bundle to initialize Gecko in Fennec; r=esawin\n\nUse extras bundle (e.g. from an Intent) to initialize Gecko in GeckoApp\nand GeckoService.\n\nMozReview-Commit-ID: AmLZ8Uir8f4", "files": ["mobile/android/base/java/org/mozilla/gecko/GeckoApp.java", "mobile/android/base/java/org/mozilla/gecko/GeckoApplication.java", "mobile/android/base/java/org/mozilla/gecko/GeckoService.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoThread.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/mozglue/SafeIntent.java"], "git_node": null, "git_parents": [null], "node": "f5947781c9902c69774137f8a70891fda04ef013", "parents": ["10aa0b36b674537050b0e6297fe9df01ee5e879d"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442255 - 5. Use extras bundle to initialize child processes; r=esawin\n\nPass the extras bundle from the main process to the child process\nthrough IChildProcess.start, instead of through the Intent, which is not\nguaranteed to work because intent extras are not guaranteed to be passed\nto Service.onBind.\n\nMozReview-Commit-ID: I2EToBNE2Y6", "files": ["mobile/android/geckoview/src/main/aidl/org/mozilla/gecko/process/IChildProcess.aidl", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/mozglue/GeckoLoader.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/process/GeckoProcessManager.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/process/GeckoServiceChildProcess.java"], "git_node": null, "git_parents": [null], "node": "be83fd0b04b6585c603b061ae16bbe99420fb890", "parents": ["f5947781c9902c69774137f8a70891fda04ef013"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442255 - 6. Adjust process count for GeckoView; r=jchen\n\nSet process count to 1 because we only support one child process right\nnow.\n\nMozReview-Commit-ID: HJAWvN4aqSX", "files": ["mobile/android/app/geckoview-prefs.js"], "git_node": null, "git_parents": [null], "node": "ec84d9eb435165c92a3a220bef59ea469f650678", "parents": ["be83fd0b04b6585c603b061ae16bbe99420fb890"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442255 - 7. Switch the order of fd arguments; r=jchen\n\nSwitch the order of the IPC FD argument and the crash FD argument in\ne10s calls, because the IPC FD is the primary FD, and the crash FD\nshould be grouped with the crash annotation FD.\n\nMozReview-Commit-ID: CAVyYAIIBPm", "files": ["ipc/glue/GeckoChildProcessHost.cpp", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoThread.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/mozglue/GeckoLoader.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/process/GeckoServiceChildProcess.java", "mozglue/android/APKOpen.cpp", "toolkit/xre/Bootstrap.cpp", "toolkit/xre/Bootstrap.h", "toolkit/xre/nsEmbedFunctions.cpp", "xpcom/build/nsXULAppAPI.h"], "git_node": null, "git_parents": [null], "node": "140e1bb89e8b90bb1847d1c10fae5a3b6f3f68e7", "parents": ["ec84d9eb435165c92a3a220bef59ea469f650678"], "tags": []}, {"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 1443230 - Keep hashtable of interface indexes in xpt.py. r=glandium\n\nA lot of time is spent during the final big XPT link determining what\nthe index is for each interface.  Changing this to use a map\neliminates about 2/3 of the running time. This patch reduces the run\ntime to a little under a second on my local OSX machine.\n\nMozReview-Commit-ID: CH4OYXtT19q", "files": ["xpcom/typelib/xpt/tools/xpt.py"], "git_node": null, "git_parents": [null], "node": "08802a2ae2b51f41d5bbd049f766bb05c994c5b2", "parents": ["140e1bb89e8b90bb1847d1c10fae5a3b6f3f68e7"], "tags": []}, {"author": "Nicolas Silva \u003cnsilva@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442748 - Don't generate frames if we haven't received a display list. r=kats", "files": ["gfx/layers/wr/WebRenderBridgeParent.cpp", "gfx/layers/wr/WebRenderBridgeParent.h"], "git_node": null, "git_parents": [null], "node": "4cf7f246faed504f8568adcf786124f8aff88031", "parents": ["9ee84efab9c8ad0835f8f5f1630138e9049ca53b"], "tags": []}, {"author": "Nicolas Silva \u003cnsilva@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442748 - Remove the workaround from 1442608. r=kats", "files": ["gfx/webrender/src/render_backend.rs"], "git_node": null, "git_parents": [null], "node": "31760a89ed73ccdbd491cc3e8862f98c55917337", "parents": ["4cf7f246faed504f8568adcf786124f8aff88031"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1443357: Remove CertAnnotator as it is now obsolete; r=mhowell", "files": ["toolkit/crashreporter/CertAnnotator.cpp", "toolkit/crashreporter/CertAnnotator.h", "toolkit/crashreporter/moz.build"], "git_node": null, "git_parents": [null], "node": "e195f02546227d60b508aeee66ba612601262949", "parents": ["31760a89ed73ccdbd491cc3e8862f98c55917337"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1443393.  Stop trying to import light-theme.css from URLs that don't return anything useful.  r=jdescottes\n\nMozReview-Commit-ID: BZrZMHWGN3X", "files": ["devtools/client/netmonitor/src/assets/styles/httpi.css", "devtools/client/netmonitor/src/assets/styles/netmonitor.css", "devtools/client/shared/components/test/mochitest/test_tabs_menu.html", "devtools/client/webconsole/webconsole.html"], "git_node": null, "git_parents": [null], "node": "6a0f29000b2920674c97df88987067bd932b0473", "parents": ["e195f02546227d60b508aeee66ba612601262949"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1442126.  Make sure to consistently fail a sheet load if any of its imports fail.  r=bholley\n\nThis fixes a race where we would fail if and only if 