e": "72465600d1f27690cbf3a73bacba075d88cf97ef", "parents": ["f1238ac69cfd801abc49b7b0db7ef9a6ee48ecdd"], "tags": []}], "date": 1522014683, "git_changesets": [null, null], "user": "gijskruitbosch@gmail.com"}, "8917": {"changesets": [{"author": "Nick Thomas \u003cnthomas@mozilla.com\u003e", "branch": "default", "desc": "Bug 1446296 - builds should use the internal pypi mirror, r=aki, a=release", "files": ["testing/mozharness/configs/builds/releng_base_android_64_builds.py", "testing/mozharness/configs/builds/releng_base_firefox.py"], "git_node": null, "git_parents": [null], "node": "090520707f4da8ebdca18bd71ade9306851b1677", "parents": ["72465600d1f27690cbf3a73bacba075d88cf97ef"], "tags": []}], "date": 1522029691, "git_changesets": [null], "user": "nthomas@mozilla.com"}, "8918": {"changesets": [{"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Backed out 2 changesets (bug 1442840) for mochitest devtools failures on devtools/client/jsonview/test/browser_jsonview_url_linkification.js. a=backout\n\nBacked out changeset 72465600d1f2 (bug 1442840)\nBacked out changeset f1238ac69cfd (bug 1442840)", "files": ["devtools/client/jsonview/components/JsonPanel.js", "devtools/client/jsonview/converter-child.js"], "git_node": null, "git_parents": [null], "node": "357a7ece1bc2777de4e3f56d60df4a0ab589eada", "parents": ["090520707f4da8ebdca18bd71ade9306851b1677"], "tags": []}], "date": 1522032896, "git_changesets": [null], "user": "csabou@mozilla.com"}, "8919": {"changesets": [{"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1448239 - Force apt database update so snapcraft can fetch packages r=rail a=release\n\nMozReview-Commit-ID: KAp4dCyHMRA", "files": ["taskcluster/docker/firefox-snap/runme.sh"], "git_node": null, "git_parents": [null], "node": "70dcf4f4efa51f6fad39e8e302fc7ef8f667870a", "parents": ["357a7ece1bc2777de4e3f56d60df4a0ab589eada"], "tags": []}], "date": 1522055121, "git_changesets": [null], "user": "jlorenzo@mozilla.com"}, "8920": {"changesets": [{"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1446811 - Support exporting array and object binding patterns r=jorendorff a=abillings a=jcristau", "files": ["js/src/builtin/ModuleObject.cpp", "js/src/builtin/ModuleObject.h", "js/src/frontend/Parser.cpp", "js/src/frontend/Parser.h", "js/src/jit-test/tests/modules/export-destructuring.js"], "git_node": null, "git_parents": [null], "node": "ef1614cd592b831c0f1116270a7ad4934017d645", "parents": ["70dcf4f4efa51f6fad39e8e302fc7ef8f667870a"], "tags": []}], "date": 1522069440, "git_changesets": [null], "user": "jcoppeard@mozilla.com"}, "8921": {"changesets": [{"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1439332 - todo assertions for \"no site data\" in site data cookies tests for now. r=jaws, a=test-only\n\nMozReview-Commit-ID: LOy30KvMBg2", "files": ["browser/components/preferences/in-content/tests/browser_siteData.js"], "git_node": null, "git_parents": [null], "node": "1635a57d13f60a4914dc3d5803c34a825eea48bf", "parents": ["ef1614cd592b831c0f1116270a7ad4934017d645"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset 7d40106bafeb (bug 1442521) for various window sizing regressions. a=jcristau", "files": ["toolkit/content/tests/chrome/test_screenPersistence.xul", "xpfe/appshell/nsXULWindow.cpp"], "git_node": null, "git_parents": [null], "node": "270b317fe5c319adc9ed3ab24ed8e0e0cb15d73f", "parents": ["1635a57d13f60a4914dc3d5803c34a825eea48bf"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1439834 - Draw titlebar with some extent. r=dao, a=jcristau\n\nSome themes (Adwaita for instance) draws bold dark line at\ntitlebar bottom. It does not fit well with Firefox tabbar UI so\ndraw themed titlebar with some extent to make the titlebar\nbottom part invisible (it's clipped by cairo).\n\nMozReview-Commit-ID: 3rs4UzFJdPa", "files": ["widget/gtk/gtk3drawing.cpp"], "git_node": null, "git_parents": [null], "node": "48151778db661b967db3f8e6ebca118752e0b203", "parents": ["270b317fe5c319adc9ed3ab24ed8e0e0cb15d73f"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1439834 - Stretch #titlebar over dragspace. r=dao, a=jcristau\n\nAdd missing drag space height (present as #TabsToolbar padding) to\ntitlebar height computation.\n\nMozReview-Commit-ID: 8JhP2zuNexb", "files": ["browser/themes/linux/browser.css"], "git_node": null, "git_parents": [null], "node": "115138a61e50a81f19982f0d5c3e33a555bdbcb0", "parents": ["48151778db661b967db3f8e6ebca118752e0b203"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1439834 - Make #TabsToolbar transparent when styled #titlebar (-moz-window-titlebar) should be shown. r=dao, a=jcristau\n\nWhen #titlebar (-moz-window-titlebar) should be rendered\n(disabled system headerbar rendering and disabled menubar)\nwe also need to make #TabsToolbar transparent because #titlebar\nis bellow it.\n\nMozReview-Commit-ID: AruTMVyC8WD", "files": ["browser/themes/linux/browser.css"], "git_node": null, "git_parents": [null], "node": "3d541b457493ffa308b544dc48dfaa29b37991b5", "parents": ["115138a61e50a81f19982f0d5c3e33a555bdbcb0"], "tags": []}, {"author": "Hector Zhao \u003cbzhao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1340039 - Set contentPolicyType when copying image, and pass it between processes. r=smaug, a=jcristau\n\nMozReview-Commit-ID: CJj1a1Lj699", "files": ["dom/base/nsContentUtils.cpp", "dom/base/nsContentUtils.h", "dom/base/nsCopySupport.cpp", "dom/events/EventStateManager.cpp", "dom/ipc/ContentParent.cpp", "dom/ipc/ContentParent.h", "dom/ipc/PBrowser.ipdl", "dom/ipc/PContent.ipdl", "dom/ipc/TabChild.cpp", "dom/ipc/TabChild.h", "dom/ipc/TabParent.cpp", "dom/ipc/TabParent.h", "widget/nsClipboardProxy.cpp"], "git_node": null, "git_parents": [null], "node": "485d4b89c0cdd2a5e0d3ea3e364eddcb1d2df0c1", "parents": ["3d541b457493ffa308b544dc48dfaa29b37991b5"], "tags": []}, {"author": "Bob Owen \u003cbobowencode@gmail.com\u003e", "branch": "default", "desc": "Bug 1445167 - Part 1: Revert change to make USER_NON_ADMIN a blacklist. r=handyman, a=jcristau\n\nThis is only used by default in the file content process now and we also have a\nFILES_ALLOW_READONLY rule for all paths anyway.", "files": ["security/sandbox/chromium-shim/patches/after_update/change_USER_NON_ADMIN_to_blacklist.patch", "security/sandbox/chromium-shim/patches/after_update/patch_order.txt", "security/sandbox/chromium/sandbox/win/src/restricted_token.cc", "security/sandbox/chromium/sandbox/win/src/restricted_token.h", "security/sandbox/chromium/sandbox/win/src/restricted_token_utils.cc"], "git_node": null, "git_parents": [null], "node": "0c055f790f2ed7e8c3ad84a1bd5e1fe85a726fb9", "parents": ["485d4b89c0cdd2a5e0d3ea3e364eddcb1d2df0c1"], "tags": []}, {"author": "Bob Owen \u003cbobowencode@gmail.com\u003e", "branch": "default", "desc": "Bug 1445167 - Part 2: Make LOG_FATAL messages in chromium sandbox code crash. r=jld, a=jcristau", "files": ["security/sandbox/chromium-shim/base/logging.cpp"], "git_node": null, "git_parents": [null], "node": "0bea88fd85ba1b5a306b9b0df5a57b13e0726a19", "parents": ["0c055f790f2ed7e8c3ad84a1bd5e1fe85a726fb9"], "tags": []}, {"author": "Jeff Walden \u003cjwalden@mit.edu\u003e", "branch": "default", "desc": "Bug 1445524 - Always embed ICU data directly into the library, not storing it in a separate file in the file system. r=ted, a=jcristau", "files": ["CLOBBER", "build/autoconf/icu.m4"], "git_node": null, "git_parents": [null], "node": "a315114363461db1035fde0f8ed4e201bd6fcd77", "parents": ["0bea88fd85ba1b5a306b9b0df5a57b13e0726a19"], "tags": []}, {"author": "Mark Hammond \u003cmhammond@skippinet.com.au\u003e", "branch": "default", "desc": "Bug 1447832 - Ensure a bookmark that is deleted during a sync gets a tombstone on the server. r=kitcambridge, a=jcristau\n\nMozReview-Commit-ID: 6vmxxBSTT3e", "files": ["toolkit/components/places/PlacesSyncUtils.jsm", "toolkit/components/places/tests/sync/test_sync_utils.js"], "git_node": null, "git_parents": [null], "node": "a641151295d6b00b1d78c242ec37d362c6648758", "parents": ["a315114363461db1035fde0f8ed4e201bd6fcd77"], "tags": []}, {"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1447913 - Fix building of Skia on BSDs. r=jbeich, a=jcristau\n\nMozReview-Commit-ID: AiaAgVMRLNN", "files": ["gfx/skia/skia/include/config/SkUserConfig.h", "gfx/skia/skia/src/gpu/GrAutoLocaleSetter.h", "toolkit/moz.configure"], "git_node": null, "git_parents": [null], "node": "03dd8392b317edca7984298d50c3d20361a9dad8", "parents": ["a641151295d6b00b1d78c242ec37d362c6648758"], "tags": []}, {"author": "Jan Beich \u003cjbeich@FreeBSD.org\u003e", "branch": "default", "desc": "Bug 1448189 - Realign stack before using SSE2 in Skia. r=lsalzman, a=jcristau", "files": ["gfx/skia/generate_mozbuild.py", "gfx/skia/moz.build"], "git_node": null, "git_parents": [null], "node": "a15c367a272ec68da4bb517d97ef2410e47e43e9", "parents": ["03dd8392b317edca7984298d50c3d20361a9dad8"], "tags": []}], "date": 1522075236, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8922": {"changesets": [{"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442840 - update test; r=Honza,nchevobbe,gijs,a=jcristau\n\nWe don't populate the href attribute on links anymore.\nThis had an impact on the test where we are testing those links.\n\nMozReview-Commit-ID: Hj2PBX79HZu", "files": ["devtools/client/jsonview/test/browser_jsonview_url_linkification.js"], "git_node": null, "git_parents": [null], "node": "8d789986907596c226fc78a04a71852e13efc665", "parents": ["a15c367a272ec68da4bb517d97ef2410e47e43e9"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1442840, r=bgrins,a=jcristau", "files": ["devtools/client/jsonview/components/JsonPanel.js"], "git_node": null, "git_parents": [null], "node": "7b163623e961117d5ba5bfccb837b5be1dbcb30d", "parents": ["8d789986907596c226fc78a04a71852e13efc665"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1442840, r=ckerschb,a=jcristau", "files": ["devtools/client/jsonview/converter-child.js"], "git_node": null, "git_parents": [null], "node": "225edeab2594a34028bce2e808c1412de1f0a711", "parents": ["7b163623e961117d5ba5bfccb837b5be1dbcb30d"], "tags": []}], "date": 1522075883, "git_changesets": [null, null, null], "user": "gijskruitbosch@gmail.com"}, "8923": {"changesets": [{"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1447685 - Move nsIRandomGenerator creation out of a lock to avoid a deadlock. r=keeler, a=jcristau\n\ndo_GetService(\"@mozilla.org/security/random-generator;1\" may initialize NSS.\nNSS Initialization occurs on Main Thread only.\n\nIf we lock on a subthread, then try to initialize NSS, it _might_ be the case\nthat the main thread is blocked on the same lock (same location or a different\none.) NSS can't initialize on Main Thread - deadlock.\n\nMove do_GetService out of the lock. Now if NSS tries to initialize on a\nsubthread, the main thead can't be blocked (because the subthread hasn't locked\nanything.)\n\nNow, the only statements that occur in locks are pointer asignment, new, memcpy,\nand randomGenerator-\u003eGenerateRandomBytes.\n\nMozReview-Commit-ID: 9C1Ok910A11", "files": ["toolkit/components/resistfingerprinting/nsRFPService.cpp"], "git_node": null, "git_parents": [null], "node": "8ab8e9ddda16a8213440eb6d8dffdc09aa5f3aaa", "parents": ["225edeab2594a34028bce2e808c1412de1f0a711"], "tags": []}, {"author": "Shane Caraveo \u003cscaraveo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1447723 - Fix triggering pageAction when using pattern matching. r=rpl, a=jcristau\n\nMozReview-Commit-ID: 8B8QR2ltYmr", "files": ["browser/components/extensions/ext-pageAction.js", "browser/components/extensions/test/browser/browser_ext_commands_execute_page_action.js"], "git_node": null, "git_parents": [null], "node": "7f9921c6775a809ec655107e44eaa7299c5f19d1", "parents": ["8ab8e9ddda16a8213440eb6d8dffdc09aa5f3aaa"], "tags": []}, {"author": "Jan Odvarko \u003codvarko@gmail.com\u003e", "branch": "default", "desc": "Bug 1447679 - Raw headers are displayed in alphabetical order. r=jryans, a=jcristau\n\nMozReview-Commit-ID: PGbaLmTdI1", "files": ["devtools/client/netmonitor/src/components/HeadersPanel.js", "devtools/client/netmonitor/src/utils/headers-provider.js", "devtools/client/netmonitor/test/browser_net_headers_sorted.js"], "git_node": null, "git_parents": [null], "node": "79c7a5ef721f97f3bd08eca89d26ed81562e51fd", "parents": ["7f9921c6775a809ec655107e44eaa7299c5f19d1"], "tags": []}, {"author": "Andrew Sutherland \u003casutherland@asutherland.org\u003e", "branch": "default", "desc": "Bug 1446225 - Ensure client id's are consistently {}-less UUIDs. r=catalinb, a=jcristau\n\nOur Client.id values were being normalized from \"{uuid}\" to \"uuid\", but not\nour FetchEvent.clientId values.  Because nsID::Parse accepts both forms,\nthis was not being caught by any tests.\n\nAlthough there are ServiceWorker WPT tests that verify consistency of\nreturned Client.id values across multiple matchAll invocations (ex:\nclient-id.https.html), there are no tests that compare Client.id with\nFetchEvent.clientId.  All the tests largely use Clients.get() to verify\ncorrectness/round-tripping.  I looked into adding WPT tests, but we\nquickly run into the test logistics problem where it's preferable to\navoid adding tests that involve effectively global state.\n\nSo, this patch:\n- Changes Clients::Get() to explicitly treat client id's that start with a\n  \"{\" as invalid.  This causes existing FetchEvent.clientId-related WPT\n  tests to fail, as we would hope.\n- Duplicates the client id normalization logic that strips {} for the\n  FetchEvent.clientId to its point of origin in\n  ContinueDispatchFetchEventRunnable::Run.\n- Augments our dom/serviceworkers/test/test_match_all_client_properties.html\n  test, which has been enforcing {}-less UUIDs for a while, to also test\n  FetchEvent.clientId to verify it conforms.  I added some comments to the\n  test files too.", "files": ["dom/clients/api/Clients.cpp", "dom/serviceworkers/ServiceWorkerManager.cpp", "dom/serviceworkers/test/match_all_clients/match_all_controlled.html", "dom/serviceworkers/test/match_all_properties_worker.js"], "git_node": null, "git_parents": [null], "node": "49448fdb2c96b17a290395110f3492870ccfebd5", "parents": ["79c7a5ef721f97f3bd08eca89d26ed81562e51fd"], "tags": []}], "date": 1522076460, "git_changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "8924": {"changesets": [{"author": "vinoth \u003ccegvinoth@gmail.com\u003e", "branch": "default", "desc": "Bug 1416045. r=mayhemer, a=RyanVM\n\nReviewers: mayhemer\n\nReviewed By: mayhemer\n\nSubscribers: freddyb, dveditz, mayhemer, ckerschb, vinoth\n\nTags: PHID-PROJ-wkydohdk6pajyfn2llkb\n\nBug #: 1416045\n\nDifferential Revision: https://phabricator.services.mozilla.com/D675", "files": ["dom/security/test/csp/file_multipart_testserver.sjs", "dom/security/test/csp/test_multipartchannel.html", "netwerk/streamconv/converters/nsMultiMixedConv.cpp", "netwerk/streamconv/converters/nsMultiMixedConv.h"], "git_node": null, "git_parents": [null], "node": "1d6d0bc1cb27eb3e90fa33367869297b451ddb9c", "parents": ["49448fdb2c96b17a290395110f3492870ccfebd5"], "tags": []}], "date": 1522080289, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "8925": {"changesets": [{"author": "Yuki Hiroshi \u003cyuki@clear-code.com\u003e", "branch": "default", "desc": "Bug 1440574 - Policy: Disable commands to send feedback. r=felipe a=jcristau", "files": ["browser/base/content/browser-safebrowsing.js", "browser/base/content/utilityOverlay.js", "browser/components/enterprisepolicies/Policies.jsm", "browser/components/enterprisepolicies/schemas/policies-schema.json", "browser/components/enterprisepolicies/tests/browser/browser.ini", "browser/components/enterprisepolicies/tests/browser/browser_policy_disable_feedback_commands.js"], "git_node": null, "git_parents": [null], "node": "2285a70156004c86a568fcc7a9fdc51bb0063fd0", "parents": ["1d6d0bc1cb27eb3e90fa33367869297b451ddb9c"], "tags": []}, {"author": "Felipe Gomes \u003cfelipc@gmail.com\u003e", "branch": "default", "desc": "Bug 1429177 - Policy: Set network proxy settings. r=mixedpuppy a=jcristau", "files": ["browser/components/enterprisepolicies/Policies.jsm", "browser/components/enterprisepolicies/helpers/ProxyPolicies.jsm", "browser/components/enterprisepolicies/helpers/moz.build", "browser/components/enterprisepolicies/helpers/sample_proxy.json", "browser/components/enterprisepolicies/schemas/policies-schema.json", "browser/components/enterprisepolicies/tests/browser/browser.ini", "browser/components/enterprisepolicies/tests/browser/browser_policy_proxy.js", "browser/components/preferences/connection.js", "toolkit/components/extensions/ext-browserSettings.js"], "git_node": null, "git_parents": [null], "node": "8df92d67493bd89cdc22082e75cb4c7bc7b20828", "parents": ["2285a70156004c86a568fcc7a9fdc51bb0063fd0"], "tags": []}, {"author": "Felipe Gomes \u003cfelipc@gmail.com\u003e", "branch": "default", "desc": "Bug 1439443 - Policies: Don't create the default and smart bookmarks on the profile. r=mak a=jcristau", "files": ["browser/components/enterprisepolicies/Policies.jsm", "browser/components/enterprisepolicies/schemas/policies-schema.json", "browser/components/enterprisepolicies/tests/browser/disable_default_bookmarks/bookmarks_policies.json", "browser/comp