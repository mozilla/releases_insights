desc": "Bug 1444097 - Clean up env_logger dependencies. r=ted\n\nFor the \"js\" crate, disable the \"regex\" feature to reduce binary size.\n\nFor the \"u2fhid\" crate, it's used only in examples. Make it a dev-dependency\nso it won't be part of the Firefox build.\n\nMozReview-Commit-ID: DY9indMqrRw", "files": ["Cargo.lock", "dom/webauthn/u2f-hid-rs/Cargo.toml", "js/rust/Cargo.toml"], "git_node": null, "git_parents": [null], "node": "8d62a6ff5d9aa2ebfce7bf90a044bc6caaa7840e", "parents": ["144f1e24df60507c7af072a446baaab39c1270a7"], "tags": []}, {"author": "Brian Grinstead \u003cbgrinstead@mozilla.com\u003e", "branch": "default", "desc": "Bug 1440729 - Include use counters for the console API r=baku\n\nMozReview-Commit-ID: 9A1lllxW7lM", "files": ["dom/base/UseCounters.conf", "dom/webidl/Console.webidl"], "git_node": null, "git_parents": [null], "node": "da5ed94719185e9e8843e2765350a4650d2d7894", "parents": ["8d62a6ff5d9aa2ebfce7bf90a044bc6caaa7840e"], "tags": []}, {"author": "Matt Brubeck \u003cmbrubeck@mozilla.com\u003e", "branch": "default", "desc": "Bug 1443257 - Update log crate from 0.3.8 to 0.3.9. r=ted\n\nMozReview-Commit-ID: DMzMun9EgnG", "files": ["Cargo.lock", "third_party/rust/log-0.3.8/.cargo-checksum.json", "third_party/rust/log-0.3.8/.travis.yml", "third_party/rust/log-0.3.8/Cargo.toml", "third_party/rust/log-0.3.8/LICENSE-APACHE", "third_party/rust/log-0.3.8/LICENSE-MIT", "third_party/rust/log-0.3.8/README.md", "third_party/rust/log-0.3.8/appveyor.yml", "third_party/rust/log-0.3.8/src/lib.rs", "third_party/rust/log-0.3.8/src/macros.rs", "third_party/rust/log-0.3.8/tests/filters.rs", "third_party/rust/log-0.3.9/.cargo-checksum.json", "third_party/rust/log-0.3.9/.travis.yml", "third_party/rust/log-0.3.9/Cargo.toml", "third_party/rust/log-0.3.9/LICENSE-APACHE", "third_party/rust/log-0.3.9/LICENSE-MIT", "third_party/rust/log-0.3.9/README.md", "third_party/rust/log-0.3.9/appveyor.yml", "third_party/rust/log-0.3.9/src/lib.rs", "third_party/rust/log-0.3.9/src/macros.rs"], "git_node": null, "git_parents": [null], "node": "17584837b003846159d5ae59ba1c465b9a2f6947", "parents": ["da5ed94719185e9e8843e2765350a4650d2d7894"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1420189 - [wdspec] Re-enable test key_shortcuts.py. r=maja_zf\n\nMozReview-Commit-ID: ELAPmEW5EQv", "files": ["testing/web-platform/meta/webdriver/tests/actions/key_shortcuts.py.ini"], "git_node": null, "git_parents": [null], "node": "021837e8787df3d76063633be7e745ac6f99fc07", "parents": ["17584837b003846159d5ae59ba1c465b9a2f6947"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1429964 - Re-enable browser_packaged_as_locales.js with dynamically testing app locales. r=gandalf\n\nMozReview-Commit-ID: FDyzUg0sq3W", "files": ["browser/components/newtab/aboutNewTabService.js", "browser/components/newtab/tests/browser/browser.ini", "browser/components/newtab/tests/browser/browser_packaged_as_locales.js"], "git_node": null, "git_parents": [null], "node": "543721b84a367418331320f6dd4fbd82945a1b8b", "parents": ["021837e8787df3d76063633be7e745ac6f99fc07"], "tags": []}, {"author": "Michael Ratcliffe \u003cmratcliffe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1443461 - Change devtools/client/storage/ui.js to ES6 classes r=ochameau\n\nSmall changes due to conflicts on rebase... async test runs fine but I will do another try run just in case.\n\nMozReview-Commit-ID: I9TwRArZl2f", "files": ["devtools/client/storage/panel.js", "devtools/client/storage/test/browser_storage_dynamic_updates_cookies.js", "devtools/client/storage/ui.js"], "git_node": null, "git_parents": [null], "node": "38b1cc41779caa473eed6fb78ba500faded0e615", "parents": ["543721b84a367418331320f6dd4fbd82945a1b8b"], "tags": []}, {"author": "Chris Manchester \u003ccmanchester@mozilla.com\u003e", "branch": "default", "desc": "Bug 1298328 - Fix dependency between buildid.h and libxul, do not re-generate buildid.h for every developer build. r=ted\n\nFor automation builds, force buildid.h to be regenerated, and always\n#include buildid.h in nsAppRunner.cpp. This will eliminate the mismatch at the\ncost of re-linking libxul on every build.\n\nFor developer builds, always #include buildid.h in nsAppRunner.cpp, but do not\nforce buildid.h to be re-generated for incremental builds. This means we will\nnever have a mismatch between platform and application buildids, although\nsubsequent builds are no longer guaranteed to have a new buildid.\n\nMozReview-Commit-ID: 19hvu8AQXgN", "files": ["Makefile.in", "toolkit/xre/Makefile.in", "toolkit/xre/nsAppRunner.cpp"], "git_node": null, "git_parents": [null], "node": "2d981ccf4c2e1f905698d0dcbecb0b52e0e49911", "parents": ["38b1cc41779caa473eed6fb78ba500faded0e615"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1427186 - stop ever showing 'new tab' as a title for about:privatebrowsing in private windows, r=dao\n\nThere are 3 issues here:\n- the runtime changing of the title causes issues where the content title is\n  not set. This is fixed by setting it to the private title by default;\n  there is very little (if any) UI that allows users to even open\n  about:privatebrowsing in 'normal' windows so we care a lot less about\n  flicker there. To be able to include this title in the markup, we switched\n  to a dtd.\n- the 'empty tab' title we set on the tab initially is set when the tab is\n  created. This has been updated to check for private windows, and default to\n  'Private Browsing' instead. This will obviously also affect other new tabs\n  in private browsing, but that seems desirable/consistent.\n- Likewise, we use this title when updating a tab's title that we don't yet\n  have a content title for (which can still happen while about:privatebrowsing\n  is loading because e10s), and so that is updated, too.\n\nMozReview-Commit-ID: nVfXD2M6UZ", "files": ["browser/base/content/tabbrowser.js", "browser/components/privatebrowsing/content/aboutPrivateBrowsing.js", "browser/components/privatebrowsing/content/aboutPrivateBrowsing.xhtml", "browser/locales/en-US/chrome/browser/aboutPrivateBrowsing.dtd", "browser/locales/en-US/chrome/browser/aboutPrivateBrowsing.properties", "browser/locales/en-US/chrome/browser/tabbrowser.properties", "browser/locales/jar.mn"], "git_node": null, "git_parents": [null], "node": "4e5253710464b7ae1bbe600ae7f36a95212b5f90", "parents": ["2d981ccf4c2e1f905698d0dcbecb0b52e0e49911"], "tags": []}, {"author": "glowka \u003cglowka.tom@gmail.com\u003e", "branch": "default", "desc": "Bug 1434885 - Netmonitor list of requests width and height synced with details panel using dedicated action r=Honza\n\nMozReview-Commit-ID: KNaTyJE0nbR", "files": ["devtools/client/netmonitor/src/actions/ui.js", "devtools/client/netmonitor/src/assets/styles/RequestList.css", "devtools/client/netmonitor/src/components/MonitorPanel.js", "devtools/client/netmonitor/src/components/RequestListContent.js", "devtools/client/netmonitor/src/constants.js", "devtools/client/netmonitor/src/reducers/ui.js"], "git_node": null, "git_parents": [null], "node": "0922530dcf5f140ba6ac44c6b405725a3121716b", "parents": ["4e5253710464b7ae1bbe600ae7f36a95212b5f90"], "tags": []}, {"author": "Matt Brubeck \u003cmbrubeck@limpet.net\u003e", "branch": "default", "desc": "servo: Merge #20245 - Disable logging in bindgen to reduce code size (from mbrubeck:logging); r=emilio\n\nThis disables bindgen's `logging` feature, which builds `env_logger`\nwith default features, including regex support.  Disabling it allows\nGecko to build `env_logger` without the `regex` crate, reducing code\nsize.\n\nPart of https://bugzilla.mozilla.org/show_bug.cgi?id=1444097\n\n---\n\n- [x] `./mach build -d` does not report any errors\n- [x] `./mach test-tidy` does not report any errors\n- [x] These changes do not require tests because they only change unused build config\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 46dfc3536472c1b68be501dc5b37ff6fdd7dba35", "files": ["servo/Cargo.lock", "servo/components/style/Cargo.toml", "servo/ports/geckolib/tests/Cargo.toml", "servo/servo-tidy.toml"], "git_node": null, "git_parents": [null], "node": "3836a743ba539056cb8b38240861e339cad579c3", "parents": ["0922530dcf5f140ba6ac44c6b405725a3121716b"], "tags": []}, {"author": "Josh Matthews \u003cjosh@joshmatthews.net\u003e", "branch": "default", "desc": "servo: Merge #20244 - Ensure readonly files can be removed on Windows (from servo:jdm-patch-10); r=SimonSapin\n\nThis is based off of https://bugs.python.org/issue19643. At worst, it makes our deletion function more robust and doesn't help with the ongoing windows CI problems.\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: f1338d3df8d76f821353686efe2d6a0a4691da02", "files": ["servo/python/servo/bootstrap_commands.py", "servo/python/servo/util.py"], "git_node": null, "git_parents": [null], "node": "5330f4f93f271daefae6db0df8612a291c377659", "parents": ["3836a743ba539056cb8b38240861e339cad579c3"], "tags": []}, {"author": "Bobby Holley \u003cbobbyholley@gmail.com\u003e", "branch": "default", "desc": "servo: Merge #20247 - Stop unconditionally collecting traversal statistics in nightly builds (from bholley:fix_stat_collection); r=Manishearth\n\nThe current code also makes us panic when DUMP_STYLE_STATISTICS=1 is\nset. :-(\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 4c797dfb5239c5e9a4014e91ed121ef9cf641ad0", "files": ["servo/components/style/driver.rs"], "git_node": null, "git_parents": [null], "node": "cdf8e9c396b9d8a3a1fb77d8c72dfde43e978c3e", "parents": ["5330f4f93f271daefae6db0df8612a291c377659"], "tags": []}, {"author": "Servo VCS Sync \u003cservo-vcs-sync@mozilla.com\u003e", "branch": "default", "desc": "No bug - Revendor rust dependencies", "files": ["Cargo.lock", "third_party/rust/env_logger-0.4.3/.cargo-checksum.json", "third_party/rust/