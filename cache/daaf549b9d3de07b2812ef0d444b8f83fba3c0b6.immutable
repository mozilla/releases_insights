desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\naz -\u003e 4fabc7a3b4da\nit -\u003e e04ad5e7e5d6", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "1a21a1405900f329801dfbe9d788baef016eba1a", "parents": ["b5370560ab61323380f83a43289c13529e4adadd"], "tags": []}], "date": 1523107319, "git_changesets": [null, null], "user": "ffxbld"}, "9001": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\naz -\u003e 481101affe23\nhu -\u003e 57820454b796\nlt -\u003e a7a3493a0c5d\nnl -\u003e 4dd125eaddd0\npa-IN -\u003e 4e4ae1a31060\npl -\u003e 91ed6afc3bff", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "0153a899e55e1930cc4e6cbfa9fadbdc177cb99c", "parents": ["1a21a1405900f329801dfbe9d788baef016eba1a"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nar -\u003e dad670c71b38\naz -\u003e 481101affe23\nbr -\u003e dab14fd342a2\ndsb -\u003e 9432c8923feb\nes-CL -\u003e 79e9b8219d9e\nes-MX -\u003e b515a3f195b8\nff -\u003e bc87d06f166a\nhsb -\u003e 5da2b9d624c1\nhu -\u003e 9b397902520d\nka -\u003e b522314e1c97\nkk -\u003e 8ace43f50a0a\nlt -\u003e cc240d6a49c7\nnl -\u003e 4dd125eaddd0\npl -\u003e 91ed6afc3bff\nsl -\u003e 1cd030632747", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "122c684d629a2d726a6a1f209c7b1e8966f46f25", "parents": ["0153a899e55e1930cc4e6cbfa9fadbdc177cb99c"], "tags": []}], "date": 1523200958, "git_changesets": [null, null], "user": "ffxbld"}, "9002": {"changesets": [{"author": "Maja Frydrychowicz \u003cmjzffr@gmail.com\u003e", "branch": "default", "desc": "Bug 1447844 - Disable modifier click tests. r=whimboo, a=test-only\n\nMozReview-Commit-ID: F3aXpxZq8Ht", "files": ["testing/web-platform/meta/webdriver/tests/actions/modifier_click.py.ini"], "git_node": null, "git_parents": [null], "node": "0157f046b18f97810497532fa4a0c4ffa959deb5", "parents": ["122c684d629a2d726a6a1f209c7b1e8966f46f25"], "tags": []}, {"author": "Daniel Holbert \u003cdholbert@cs.stanford.edu\u003e", "branch": "default", "desc": "Bug 1451723 - Annotate first load of reftest 'font-matching/1394311-ref.htm' as random on Win7. a=test-only\n\nThis test started failing after a reftest rebucketing.  It's likely a\nparticularly-bad special case of known win7 intermittent bug 1392106.  For now,\nlet's mark it as random on Win7 and continue investigating the general issue in\nbug 1392106.\n\nMozReview-Commit-ID: KX707Y9ycIC", "files": ["layout/reftests/font-matching/reftest.list"], "git_node": null, "git_parents": [null], "node": "f0f776ba2f3b541e0d4fb509564d0298b9a494ab", "parents": ["0157f046b18f97810497532fa4a0c4ffa959deb5"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1203273 - Add a canary to check gray buffers are valid. r=sfink, a=RyanVM", "files": ["js/src/gc/RootMarking.cpp"], "git_node": null, "git_parents": [null], "node": "eafdd39a64d3c80944497d6fadd66f37139a2826", "parents": ["f0f776ba2f3b541e0d4fb509564d0298b9a494ab"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1432793 - Force screensharing simulcast to one layer and stop generating layers once an odd width and height are found. r=bwc, a=RyanVM\n\nThis limits screensharing simulcast to a single layer. When window sharing, our\nsource video can have arbitrary dimensions. If one of those dimensions ends up\nbeing odd, the aspect ratio of the smaller layer will not match the aspect ratio\nof the odd sized layer, causing a runtime assertion failure and crash.\n\nIt is not sufficient to prevent the creation of odd sized layers in\nCreateEncoderStreams because the user can resize the window while it is being\nshared, which will cause a fatal assertion prior to the streams being recreated.\n\nWhen switching back from window sharing to camera, a call to\nCreateEncoderStreams will occur with resolutions matching the dimensions of\nthe window that was just shared. To prevent a crash, this also adds a check\nwhich prevents the creation of layers with odd resolutions.\n\nLooking at cricket::GetSimulcastConfig for the version of webrtc.org in tree,\nthe number of simulcast layers is limited to one, or two if a field experiment\nis enabled. That code also limits resolutions at which screensharing is allowed\nas well as the number of layers that can be created for each resolution, and\nensures that each layer is exactly half the size of the layer above.\n\nAdding these new constraints to CreateEncoderStreams makes us more consistent\nwith what the webrtc.org code would do when creating streams, which should\nhelp to avoid more assertion failures in the future. Long term, I believe we\nshould just switch to using cricket::GetSimulcastConfig.\n\nMozReview-Commit-ID: 8gjdY5GPPjl", "files": ["media/webrtc/signaling/src/media-conduit/VideoConduit.cpp"], "git_node": null, "git_parents": [null], "node": "70140bcf230dd1c21015401b7250937ab9302360", "parents": ["eafdd39a64d3c80944497d6fadd66f37139a2826"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1432793 - Add mochitest for odd simulcast resolutions. r=bwc, a=RyanVM\n\nThis creates a simulcast stream with an odd resolution. This previously would\nhave caused a runtime assertion failure and crash.\n\nMozReview-Commit-ID: IsywVOu6UeV", "files": ["dom/media/tests/mochitest/head.js", "dom/media/tests/mochitest/mochitest.ini", "dom/media/tests/mochitest/test_peerConnection_simulcastOddResolution.html"], "git_node": null, "git_parents": [null], "node": "e493c1e01d247213839e85c1887fc3663b4c172e", "parents": ["70140bcf230dd1c21015401b7250937ab9302360"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1432793 - Add gtests for simulcast screenshare and odd resolutions. r=bwc, a=RyanVM\n\nMozReview-Commit-ID: ADBh7SCVgoC", "files": ["media/webrtc/signaling/gtest/videoconduit_unittests.cpp"], "git_node": null, "git_parents": [null], "node": "bb3cfe7f354defce79b764925e1f80262bc46c8a", "parents": ["e493c1e01d247213839e85c1887fc3663b4c172e"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1446904 - Do not generate drag gestures from synthesized/mouse events while in touch drag mode. r=kats, r=smaug, a=RyanVM\n\nCalling GenerateDragGesture at this point should not be necessary, since\neTouchMove events are already handled in the same function. This code\nis intermittently triggered through (what I can only call \"rogue\")\neMouseMove, ePointerDown and ePointerMove events, which is causing hangs\nin the native DoDragDrop function further down the stack.\n\nArguably this shouldn't be triggered by e.g. ePointerDown either, and\nI'm unclear on why exactly DoDragDrop is hanging (likely because it is\ncalled again before the user does a drop), but this is a quick fix that\nshould be suitable for uplift.\n\nMozReview-Commit-ID: A0hBlS85icx", "files": ["dom/events/EventStateManager.cpp"], "git_node": null, "git_parents": [null], "node": "975203f0114ddcce4a02378a9b7a4e6cbb803db6", "parents": ["bb3cfe7f354defce79b764925e1f80262bc46c8a"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1445799 - User Attribute for Leanplum for Android Users that have Opted Out of Pocket in their Top Sites. r=mcomella, a=RyanVM\n\nAdded a new user attribute in LP: \"Top Sites by Pocket\" to indicate if the user has the feature enabled or not, which will stored in LP along with the other attributes when the app first starts.\nSmall refactoring to avoid duplicated code and use newly created way of checking if Pocket is recommending Top Sites.\n\nMozReview-Commit-ID: IWieAorkB1P", "files": ["mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/ActivityStreamPanel.java", "mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/StreamRecyclerAdapter.java", "mobile/android/base/java/org/mozilla/gecko/mma/MmaDelegate.java"], "git_node": null, "git_parents": [null], "node": "50977d34a015f159285f339e8412c927dceb87d8", "parents": ["975203f0114ddcce4a02378a9b7a4e6cbb803db6"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1445799 - User Attribute for Leanplum for Android Users that have Opted Out of Pocket in their Top Sites. r=mcomella, a=RyanVM\n\nSmall refactoring to avoid duplicated code and use newly created way of checking if Pocket is recommending Top Sites.\n\nMozReview-Commit-ID: Lw9hvcM4uya", "files": ["mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/ActivityStreamConfiguration.java", "mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/ActivityStreamPanel.java", "mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/StreamRecyclerAdapter.java", "mobile/android/base/java/org/mozilla/gecko/mma/MmaDelegate.java"], "git_node": null, "git_parents": [null], "node": "dc9b50d160e1d7a715055d29fad9c309d41e18e8", "parents": ["50977d34a015f159285f339e8412c927dceb87d8"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1449226 - Add better debug information for GPO. r=Felipe, a=RyanVM\n\nMozReview-Commit-ID: GCw0kARRuJ5", "files": ["browser/components/enterprisepolicies/WindowsGPOParser.jsm"], "git_node": null, "git_parents": [null], "node": "8495b5dc53c76f5190046e337e0b19a25810de74", "parents": ["dc9b50d160e1d7a715055d29fad9c309d41e18e8"], "tags": []}, {"author": "Kirk Steuber \u003cksteuber@mozilla.com\u003e", "branch": "default", "desc": "Bug 1429164 - Add enterprise policy to prevent showing the profile import wizard. r=Felipe, r=Gijs, a=RyanVM\n\nMozReview-Commit-ID: Lg7r1NrFbKl", "files": ["browser/components/enterprisepolicies/Policies.jsm", "browser/components/enterprisepolicies/schemas/policies-schema.json", "browser/components/enterprisepolicies/tests/browser/browser.ini", "browser/components/enterprisepolicies/tests/browser/browser_policy_disable_profile_import.js", "browser/components/places/content/places.js"], "git_node": null, "git_parents": [null], "node": "1a77d1f0ddc242652d9862e55d7133a0f300270a", "parents": ["8495b5dc53c76f5190046e337e0b19a25810de74"], "tags": []}], "date": 1523280449, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9003": {"changesets": [{"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1445164 - Disable /css/css-tables/table-model-fixup-2.html on linux. r=RyanVM, a=test-only", "files": ["testing/web-platform/meta/css/css-tables/table-model-fixup-2.html.ini"], "git_node": null, "git_parents": [null], "node": "28514415973b9e4c714fb27066352d1534ebf19d", "parents": ["1a77d1f0ddc242652d9862e55d7133a0f300270a"], "tags": []}, {"author": "Jed Davis \u003cjld@mozilla.com\u003e", "branch": "default", "desc": "Bug 1450740 - Don't sandbox network namespace when X11 named sockets aren't accessible. r=gcp, a=RyanVM\n\nMozReview-Commit-ID: KiL4GwMms3a", "files": ["security/sandbox/linux/launch/SandboxLaunch.cpp"], "git_node": null, "git_parents": [null], "node": "73fab5fbc84369a3fd29c592301187f1e445e481", "parents": ["28514415973b9e4c714fb27066352d1534ebf19d"], "tags": []}, {"author": "Jed Davis \u003cjld@mozilla.com\u003e", "branch": "default", "desc": "Bug 1323302 - Refuse to run under sudo or otherwise as root in a non-root user's session. r=glandium, a=RyanVM\n\nMozReview-Commit-ID: EFq9hULWqA8", "files": ["toolkit/xre/moz.build", "toolkit/xre/nsAppRunner.cpp"], "git_node": null, "git_parents": [null], "node": "64b1913329634cbba8bb270f224f36807bf5a65f", "parents": ["73fab5fbc84369a3fd29c592301187f1e445e481"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1452104 - Final tweaks to policy names and params. r=Felipe, a=RyanVM\n\nMozReview-Commit-ID: CxxCqnyavfL", "files": ["browser/components/enterprisepolicies/Policies.jsm", "browser/components/enterprisepolicies/schemas/policies-schema.json", "browser/components/enterprisepolicies/tests/browser/browser_policies_simple_pref_policies.js", "browser/components/enterprisepolicies/tests/browser/browser_policy_block_set_desktop_background.js", "browser/components/enterprisepolicies/tests/browser/browser_policy_cookie_settings.js", "browser/components/enterprisepolicies/tests/browser/browser_policy_disable_masterpassword.js", "browser/components/enterprisepolicies/tests/browser/config_popups_cookies_addons_flash.json", "toolkit/mozapps/extensions/test/xpcshell/test_system_update_enterprisepolicy.js"], "git_node": null, "git_parents": [null], "node": "aab0d3647635d424f4ee300bd4fcd53dc83de949", "parents": ["64b1913329634cbba8bb270f224f36807bf5a65f"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1448499 - Destroy deviceFront when destroying the toolbox. r=jryans, a=RyanVM\n\nMozReview-Commit-ID: IMlKbiaUKu7", "files": ["devtools/client/framework/toolbox.js", "devtools/shared/fronts/device.js"], "git_node": null, "git_parents": [null], "node": "4ec5bcc4d729dcd83faa2783ab0a9134ee79e812", "parents": ["aab0d3647635d424f4ee300bd4fcd53dc83de949"], "tags": []}, {"author": "Kim Moir \u003ckmoir@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441358 - Ensure langpacks across platforms are identical. r=Callek, a=RyanVM", "files": ["browser/base/content/test/static/browser_all_files_referenced.js", "browser/locales/jar.mn", "toolkit/locales/jar.mn"], "git_node": null, "git_parents": [null], "node": "305aefdbaf13dbd515248c4f4762a576f03ae91d", "parents": ["4ec5bcc4d729dcd83faa2783ab0a9134ee79e812"], "tags": []}, {"author": "Justin Wood \u003cCallek@gmail.com\u003e", "branch": "default", "desc": "Bug 1441359 - Make langpack version include buildid. r=mshal, a=RyanVM\n\nFor Automated submission to AMO we need unique language pack versions for every submitted build.\n\nThis will produce versions that are not valid for AMO on nightly (61.0a1buildid2018...) but that's ok, we're not ready to\nsubmit these automatically on the nightly channel yet, they do still install fine into Firefox manually.\n\nOn beta/release/esr the version will however be ok for AMO \"60.0buildid2018...\" and will be reasonably unique per push.\n\nThis patch has the intent that, outside of automation, users who don't set a buildid get a langpack version without that\nspecified (rather than a buildid being automatically generated for them).\n\nThe releng scriptworker (addonscript) that will do the publishing to AMO will additionally sanity check that the string\n'buildid' is present in the version part, so we don't accidentally break this functionality in production.\n\nThis patch is also intended to be uplifted to Gecko 60 to support ESR60 needs.\n\nMozReview-Commit-ID: KuvwMyD6bwd", "files": ["python/mozbuild/mozbuild/action/langpack_manifest.py"], "git_node": null, "git_parents": [null], "node": "eead32dddd0222c20c4527cbda8639a9cbcc7e63", "parents": ["305aefdbaf13dbd515248c4f4762a576f03ae91d"], "tags": []}], "date": 1523283687, "git_changesets": [null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9004": {"changesets": [{"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1427480 - Increase the MAX_FONT_SIZE limit applied in cairo_ft_font to match the gfxFont size limit. r=lsalzman, a=RyanVM", "files": ["gfx/cairo/cairo/src/cairo-ft-font.c", "gfx/cairo/max-font-size.patch"], "git_node": null, "git_parents": [null], "node": "4aee8de5790b1675c5c776c3616976f11730a74c", "parents": ["eead32dddd0222c20c4527cbda8639a9cbcc7e63"], "tags": []}, {"author": "Gian-Carlo Pascutto \u003cgcp@mozilla.com\u003e", "branch": "default", "desc": "Bug 1434711 - WebGL causes a crash with the AMDGPU-PRO video driver. r=jld, a=RyanVM\n\nFactor out the ATI-based driver detection code and use this to set\nspecific permissions needed by this driver. In passing, unnest some\nof the SandboxBroker fallback paths, and make it properly report\nthe operation in all error paths.\n\nMozReview-Commit-ID: FrRpicj5NF", "files": ["security/sandbox/linux/SandboxBrokerClient.cpp", "security/sandbox/linux/broker/SandboxBroker.cpp", "security/sandbox/linux/broker/SandboxBrokerPolicyFactory.cpp", "security/sandbox/linux/launch/SandboxLaunch.cpp", "security/sandbox/linux/launch/SandboxLaunch.h"], "git_node": null, "git_parents": [null], "node": "7b34158d42f3f8c4ce347b3d790dcefd26e613e3", "parents": ["4aee8de5790b1675c5c776c3616976f11730a74c"], "tags": []}, {"author": "Nicolas B. Pierron \u003cnicolas.b.pierron@gmail.com\u003e", "branch": "default", "desc": "Bug 1444473 - Spectre: Add Jit inline caches mitigation for values returned from C++. r=jandem, a=RyanVM", "files": ["js/src/jit/BaselineCacheIRCompiler.cpp", "js/src/jit/CacheIRCompiler.cpp", "js/src/jit/IonCacheIRCompiler.cpp"], "git_node": null, "git_parents": [null], "node": "a3dff4cabfb7796847bff64e068e57783e3ac0bd", "parents": ["7b34158d42f3f8c4ce347b3d790dcefd26e613e3"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441585 - Set picture size to something valid. r=dminor, a=RyanVM\n\nMozReview-Commit-ID: 13lZcfR9wlC", "files": ["media/webrtc/trunk/webrtc/modules/video_capture/android/java/src/org/webrtc/videoengine/VideoCaptureAndroid.java"], "git_node": null, "git_parents": [null], "node": "4ecc63b45a4f0aea3611d61d1df534b1fb36a947", "parents": ["a3dff4cabfb7796847bff64e068e57783e3ac0bd"], "tags": []}, {"author": "Vlad Baicu \u003cvlad.baicu@softvision.ro\u003e", "branch": "default", "desc": "Bug 1429386 - Added missing functionalities from a newer LP SDK version. r=nechen, a=RyanVM\n\nMozReview-Commit-ID: EWGABsN3Diu", "files": ["mobile/android/thirdparty/com/leanplum/messagetemplates/HTMLOptions.java", "mobile/android/thirdparty/com/leanplum/messagetemplates/HTMLTemplate.java", "mobile/android/thirdparty/com/leanplum/messagetemplates/MessageTemplates.java", "mobile/android/thirdparty/com/leanplum/utils/SizeUtil.java"], "git_node": null, "git_parents": [null], "node": "64c9c9119d105548f38b6eb731c6b85b7ff2094b", "parents": ["4ecc63b45a4f0aea3611d61d1df534b1fb36a947"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1452525 - Deduplicate proto bindings, not bindings. r=xidorn, a=RyanVM\n\nMozReview-Commit-ID: 2NWALzUhDjn", "files": ["dom/xbl/nsBindingManager.cpp", "dom/xbl/nsBindingManager.h", "layout/style/ServoStyleSet.cpp"], "git_node": null, "git_parents": [null], "node": "567b3f0eaddfdcf59187662480bd5dc69b6d3c8f", "parents": ["64c9c9119d105548f38b6eb731c6b85b7ff2094b"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1440255 - Backout bug 1420585 deadlock wallpaper fix. r=dminor, a=RyanVM\n\nMozReview-Commit-ID: DurGH2RmXQH", "files": ["media/webrtc/trunk/webrtc/modules/video_capture/android/java/src/org/webrtc/videoengine/VideoCaptureAndroid.java"], "git_node": null, "git_parents": [null], "node": "70432546852c4ad08fbbd076917eabddd09dc1c5", "parents": ["567b3f0eaddfdcf59187662480bd5dc69b6d3c8f"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1440255 - Move thread exchanging out to runnables. r=dminor, a=RyanVM\n\nThis is the proper fix for bug 1420585.\n\nMozReview-Commit-ID: 5WKMvbpQFSE", "files": ["media/webrtc/trunk/webrtc/modules/video_capture/android/java/src/org/webrtc/videoengine/VideoCaptureAndroid.java"], "git_node": null, "git_parents": [null], "node": "88d31bceba4719c1f7c3d3ca7d75bfa09ab900c1", "parents": ["70432546852c4ad08fbbd076917eabddd09dc1c5"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1440255 - Make VideoCaptureAndroid reconfigurable through subsequent startCapture. r=dminor, a=RyanVM\n\nMozReview-Commit-ID: 9yslx7rMN2w", "files": ["media/webrtc/trunk/webrtc/modules/video_capture/android/java/src/org/webrtc/videoengine/VideoCaptureAndroid.java"], "git_node": null, "git_parents": [null], "node": "866aefe6026da5de622d865ffc6f6ec21ddafeee", "parents": ["88d31bceba4719c1f7c3d3ca7d75bfa09ab900c1"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1440255 - Consolidate failure paths. r=dminor, a=RyanVM\n\nThe cameraThread is set by startCapture(), so a failed startCapture() that\nquits the Looper and runs the cameraThread to completion needs to set\ncameraThread back to null for consistency.\n\nLikewise, stopCapture() shall always quit the Looper and set cameraThread to\nnull.\n\nMozReview-Commit-ID: H1ExLyTixYw", "files": ["media/webrtc/trunk/webrtc/modules/video_capture/android/java/src/org/webrtc/videoengine/VideoCaptureAndroid.java"], "git_node": null, "git_parents": [null], "node": "4e9b4893ee3e2b9d8a8f73ed5b50f49428ff5dbb", "parents": ["866aefe6026da5de622d865ffc6f6ec21ddafeee"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1440255 - Remove tabs from VideoCaptureAndroid. r=dminor, a=RyanVM\n\nMozReview-Commit-ID: Ga3TgD9J030", "files": ["media/webrtc/trunk/webrtc/modules/video_capture/android/java/src/org/webrtc/videoengine/VideoCaptureAndroid.java"], "git_node": null, "git_parents": [null], "node": "784c44089b9e0071f8c172aba9e91237a52ec2fd", "parents": ["4e9b4893ee3e2b9d8a8f73ed5b50f49428ff5dbb"], "tags": []}, {"author": "Kai Engert \u003ckaie@kuix.de\u003e", "branch": "default", "desc": "Bug 1448404 - Update NSS to version 3.36.1 for Firefox 60. r=kaie, a=RyanVM\nUPGRADE_NSS_RELEASE", "files": ["old-configure.in", "security/nss/TAG-INFO", "security/nss/coreconf/coreconf.dep", "security/nss/lib/dev/devslot.c", "security/nss/lib/dev/devt.h", "security/nss/lib/freebl/blinit.c", "security/nss/lib/nss/nss.h", "security/nss/lib/pk11wrap/dev3hack.c", "security/nss/lib/pkcs7/p7create.c", "security/nss/lib/softoken/softkver.h", "security/nss/lib/util/nssutil.h"], "git_node": null, "git_parents": [null], "node": "83b358633328cc642a2cefc83527854e9b91c23c", "parents": ["784c44089b9e0071f8c172aba9e91237a52ec2fd"], "tags": []}], "date": 1523293889, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9005": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nca -\u003e 1bc9e713773e\ncak -\u003e 7e5273795f39\ncs -\u003e cc8f7cb6efe8\nes-ES -\u003e 2b049f9dcc09\nfy-NL -\u003e fafa1dc1e31a\nko -\u003e 218bb63d298c\nnn-NO -\u003e 6bb9a0b398db\npa-IN -\u003e cf9384486a61\npt-PT -\u003e fc24ec919f85\nru -\u003e 7bafe259d6a6", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "a0f53fb1ff7b9eb1fe4d62a429898a868944ba06", "parents": ["83b358633328cc642a2cefc83527854e9b91c23c"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nca -\u003e 1bc9e713773e\ncak -\u003e 7e5273795f39\ncs -\u003e cc8f7cb6efe8\nes-AR -\u003e 415a4a314785\nes-ES -\u003e 2b049f9dcc09\nfy-NL -\u003e fafa1dc1e31a\nko -\u003e 3cc4383c1acc\nlij -\u003e b48acaf90432\nnn-NO -\u003e 869bc4f12d25\npa-IN -\u003e cf9384486a61\npt-PT -\u003e dbab25123a10\nru -\u003e 7bafe259d6a6\nvi -\u003e 4977189415bc", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "3e95e05908949295486367ed88f5da0ae479fd79", "parents": ["a0f53fb1ff7b9eb1fe4d62a429898a868944ba06"], "tags": []}], "date": 1523294531, "git_changesets": [null, null], "user": "ffxbld"}, "9006": {"changesets": [{"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1444431 - Filter logs from familiar logging targets. r=jgraham, a=test-only\n\ngeckodriver uses log 0.4, but it depends on a version of hyper that\nuses log 0.3.\n\nPreviously this meant that geckodriver's logger could only see\nmessages from crates using log 0.4, and had no access to messages\nfrom hyper or other crates using log 0.3.  However, log 0.3.9 added\ninteroperability so that programs built with a mix of log 0.3 and\nlog 0.4 can again display messages from all crates.\n\nThis patches geckodriver::logging to contain a whitelist of logged\ntargets we care about.  Currently this list includes geckodriver,\nmozprofile, mozrunner, mozversion, and webdriver.  This will revert\nus to the behaviour prior to upgrading hyper to use log 0.3.9,\nand would be similar to the old implementation we had for filtering\nlogs we had when geckodriver used slog.\n\nThanks-to: Matt Brubeck \u003cmbrubeck@mozilla.com\u003e\nMozReview-Commit-ID: 6Xj0k6VD1dQ", "files": ["testing/geckodriver/src/logging.rs"], "git_node": null, "git_parents": [null], "node": "ca36ebc45fd477aab9dbbf0fd7bb701f1b2266a9", "parents": ["3e95e05908949295486367ed88f5da0ae479fd79"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset 567b3f0eaddf (bug 1452525) for bustage.", "files": ["dom/xbl/nsBindingManager.cpp", "dom/xbl/nsBindingManager.h", "layout/style/ServoStyleSet.cpp"], "git_node": null, "git_parents": [null], "node": "5ee0d4fb20f40403df6ef9106d64116e5dcfe630", "parents": ["ca36ebc45fd477aab9dbbf0fd7bb701f1b2266a9"], "tags": []}], "date": 1523295692, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "9007": {"changesets": [{"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1445235 part 1 - Also add Spectre mitigations for MBoundsCheck added for stores. r=luke, a=RyanVM", "files": ["js/src/jit/IonBuilder.cpp", "js/src/jit/IonBuilder.h", "js/src/jit/MCallOptimize.cpp", "js/src/jit/MIR.h"], "git_node": null, "git_parents": [null], "node": "39a6945f06ed8899c0146e91418ee8e322c3a0aa", "parents": ["5ee0d4fb20f40403df6ef9106d64116e5dcfe630"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1445235 part 2 - Rename MacroAssembler boundsCheck32ForLoad to spectreBoundsCheck32. r=nbp, a=RyanVM", "files": ["js/src/jit/BaselineCacheIRCompiler.cpp", "js/src/jit/CacheIRCompiler.cpp", "js/src/jit/CodeGenerator.cpp", "js/src/jit/MacroAssembler.cpp", "js/src/jit/MacroAssembler.h", "js/src/jit/arm/MacroAssembler-arm-inl.h", "js/src/jit/arm64/MacroAssembler-arm64-inl.h", "js/src/jit/mips-shared/MacroAssembler-mips-shared-inl.h", "js/src/jit/mips32/Lowering-mips32.cpp", "js/src/jit/mips64/Lowering-mips64.cpp", "js/src/jit/x86-shared/MacroAssembler-x86-shared-inl.h"], "git_node": null, "git_parents": [null], "node": "02a7736cbf001656b7aa15480fd92520632f5872", "parents": ["39a6945f06ed8899c0146e91418ee8e322c3a0aa"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1448329 - Remove 32-bit-x86-only static typed array access optimization. r=tcampbell, a=RyanVM", "files": ["js/public/TrackedOptimizationInfo.h", "js/src/jit/AliasAnalysisShared.cpp", "js/src/jit/IonBuilder.cpp", "js/src/jit/IonBuilder.h", "js/src/jit/Lowering.cpp", "js/src/jit/Lowering.h", "js/src/jit/MIR.cpp", "js/src/jit/MIR.h", "js/src/jit/MOpcodes.h", "js/src/jit/RangeAnalys