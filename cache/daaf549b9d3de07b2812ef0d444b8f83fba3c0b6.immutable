olkit/components/payments/content/paymentDialogWrapper.js", "toolkit/components/payments/paymentUIService.js", "toolkit/components/payments/res/containers/payment-dialog.js", "toolkit/components/payments/res/debugging.html", "toolkit/components/payments/res/debugging.js", "toolkit/components/payments/res/paymentRequest.css", "toolkit/components/payments/res/paymentRequest.xhtml", "toolkit/components/payments/test/browser/browser.ini", "toolkit/components/payments/test/browser/browser_show_dialog.js", "toolkit/components/payments/test/mochitest/test_payment_dialog.html"], "git_node": null, "git_parents": [null], "node": "61ac0108bef63654c2ab2d75161e18a985f7adfd", "parents": ["f5a456a57edd6646ad6db081b0e3282ab734b88c"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 349222d58373 (bug 1442800) for frequent wpt failures on a CLOSED TREE", "files": ["accessible/base/XULMap.h", "accessible/base/nsAccessibilityService.cpp", "accessible/base/nsAccessibilityService.h"], "git_node": null, "git_parents": [null], "node": "a07c7148dac649770a3444bc4dd15322ada62976", "parents": ["61ac0108bef63654c2ab2d75161e18a985f7adfd"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset d679c9a9afa0 (bug 1442582) for mochitest browser chrome failures at browser_ext_tabs_create.js on a CLOSED TREE", "files": ["browser/base/content/tabbrowser.css", "browser/base/content/tabbrowser.js", "browser/base/content/tabbrowser.xml", "testing/mochitest/browser-test.js"], "git_node": null, "git_parents": [null], "node": "af2dffa14ef9301d39cf863be40b3ce2774693ed", "parents": ["a07c7148dac649770a3444bc4dd15322ada62976"], "tags": []}, {"author": "Simon Sapin \u003csimon.sapin@exyr.org\u003e", "branch": "default", "desc": "servo: Merge #20232 - Update mozjs_sys (from servo:up); r=jdm\n\nPick up https://github.com/servo/mozjs/pull/132\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 72d09202f4e5207cee606e122729dd007e6b5ac8", "files": ["servo/Cargo.lock"], "git_node": null, "git_parents": [null], "node": "2ace79cd8e52c1937fc45ef7167faff376fb2ad5", "parents": ["af2dffa14ef9301d39cf863be40b3ce2774693ed"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442515 Turn MOZ_LOG's in Timer Reduction on in non-debug builds also r=baku\n\nMozReview-Commit-ID: C3JkX8RogeW", "files": ["toolkit/components/resistfingerprinting/nsRFPService.cpp"], "git_node": null, "git_parents": [null], "node": "e75e7b54212427cbe63eafff40b67720d1e24b88", "parents": ["2ace79cd8e52c1937fc45ef7167faff376fb2ad5"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442515 Refactor test_eventTimeStamp.html to pass r=baku\n\nPreviously, we waited for the load event and used that event timestamp.\nBut as far as I can tell the intent of this test is not to test the load\nevent specifically, but just event timestamps.\n\nIn opt builds, the reduceTimerPrecision pref was not being populated fast\nenough to take effect during the load process, and was causing (a lot of)\nintermittent failures.\n\nWe refactor the test to use PushPrefEnv and test a different event.\n\nMozReview-Commit-ID: ILJYHRhUHnM", "files": ["dom/events/test/test_eventTimeStamp.html"], "git_node": null, "git_parents": [null], "node": "10dbb119af2b915f5fa926b89fb97e983b79e7c6", "parents": ["e75e7b54212427cbe63eafff40b67720d1e24b88"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1442938: Nil-check the title in nsCocoaWindow::importState / exportState. r=mstange\n\nLooking at the docs for [NSWindow title] I don't think it's supposed to return\nnil under any circumstances...\n\nBut it does in our automation, for some reason, with the patches for bug 1439875\nwhich make our fullscreen code run a bit earlier.\n\nMozReview-Commit-ID: AX4qzjzsqST", "files": ["widget/cocoa/nsCocoaWindow.mm"], "git_node": null, "git_parents": [null], "node": "4b56d0a2859f9da961078be439102101290d8170", "parents": ["10dbb119af2b915f5fa926b89fb97e983b79e7c6"], "tags": []}, {"author": "Thom Chiovoloni \u003ctchiovoloni@mozilla.com\u003e", "branch": "default", "desc": "Bug 1443268 - Remove test_places_guid_downgrade.js from sync r=kitcambridge\n\nMozReview-Commit-ID: 2P8EnTfugmz", "files": ["services/common/tests/unit/head_global.js", "services/sync/tests/unit/head_appinfo.js", "services/sync/tests/unit/places_v10_from_v11.sqlite", "services/sync/tests/unit/test_places_guid_downgrade.js", "services/sync/tests/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "e6069d8a3dafd6bbb06b321562adcd5aa55f9c4e", "parents": ["4b56d0a2859f9da961078be439102101290d8170"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442940 Turn off jitter for dom/base/test/test_timeout_clamp.html which is (likely) causing intermittents r=baku\n\nMozReview-Commit-ID: 9nfiBbqsATT", "files": ["dom/base/test/test_timeout_clamp.html"], "git_node": null, "git_parents": [null], "node": "635d311ec745da07a7e893787fb29ab2aa13dcfe", "parents": ["e6069d8a3dafd6bbb06b321562adcd5aa55f9c4e"], "tags": []}, {"author": "Ralph Giles \u003cgiles@mozilla.com\u003e", "branch": "default", "desc": "Bug 1443865 - Use 16-bit eobs count. r=kinetik\n\nMozReview-Commit-ID: 4lfBbvSTNPO", "files": ["media/libvpx/libvpx/vp9/encoder/x86/vp9_quantize_ssse3_x86_64.asm"], "git_node": null, "git_parents": [null], "node": "a628b2125a1b860c6d8124387040ec9589c219ab", "parents": ["635d311ec745da07a7e893787fb29ab2aa13dcfe"], "tags": []}, {"author": "Timothy Guan-tin Chien \u003ctimdream@gmail.com\u003e", "branch": "default", "desc": "Bug 1443635 - Remove the custom XUL \u003cupdate\u003e tag r=Paolo\n\nRestore it to be \u003crichlistitem\u003es so that nsAccessibilityService can produce\ncorrect accessibles.\n\nMozReview-Commit-ID: 1QiGyKPNifZ", "files": ["browser/components/preferences/in-content/tests/browser_advanced_update.js", "toolkit/mozapps/update/content/history.js", "toolkit/mozapps/update/content/updates.css"], "git_node": null, "git_parents": [null], "node": "6030763a531d2d2810687b971378c1c3d35e3ffb", "parents": ["a628b2125a1b860c6d8124387040ec9589c219ab"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1370131 - Allow shadows on accelerated popups. r=kmag\n\nIt looks like the work in bug 1291457 was all that was necessary to get working\nwindow shadows for accelerated popups. It seems that macOS is able to compute\nthe correct shadow style consistently for whatever is drawn in the\nNSOpenGLContext during the first paint of the window (inside the drawRect call\nduring the orderFront call that opens the window).\n\nWe only ran into problems when we animated the contents of the window in a way\nthat affects the shadow style; we're no longer doing that after bug 1291457.\n\nMozReview-Commit-ID: 62mfWuAsrg2", "files": ["widget/cocoa/nsCocoaWindow.mm"], "git_node": null, "git_parents": [null], "node": "cd1a68c40c3bbf5e75705fda1ead35893a1e18e9", "parents": ["6030763a531d2d2810687b971378c1c3d35e3ffb"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442560 - Add a note for deprecating passing a storage option to indexedDB.open(). r=asuth\n\nMozReview-Commit-ID: 44yCmYrPP26", "files": ["dom/base/nsDeprecatedOperationList.h", "dom/indexedDB/IDBFactory.cpp", "dom/locales/en-US/chrome/dom/dom.properties"], "git_node": null, "git_parents": [null], "node": "78dd2074db57f399611335aaed9357921ba95fe5", "parents": ["cd1a68c40c3bbf5e75705fda1ead35893a1e18e9"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1443204 - Pre: Clean-up unused Android data structures in mozbuild frontend. r=chmanches