 "parents": ["2bf3d2cdef340f1352ec2a0e91ded10b4e579236"], "tags": []}], "date": 1521644885, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8894": {"changesets": [{"author": "Jorg K \u003cjorgk@jorgk.com\u003e", "branch": "THUNDERBIRD600b1_2018031401_RELBRANCH", "desc": "Backed out changeset d443027a615c: Backout bug 1432219 [migrate release checksums builder off of BBB to TC] to build Thunderbird 60 beta. a=jorgk", "files": ["taskcluster/ci/release-generate-checksums-signing/kind.yml", "taskcluster/taskgraph/transforms/release_generate_checksums_signing.py"], "git_node": null, "git_parents": [null], "node": "19c02038da5a9da5a7ec0d642b67d743a48b507d", "parents": ["c614b6e7cf588a20720260defd1ce7a9ae60892e"], "tags": []}, {"author": "Jorg K \u003cjorgk@jorgk.com\u003e", "branch": "THUNDERBIRD600b1_2018031401_RELBRANCH", "desc": "Backed out changeset 07922a7fba83: Backout bug 1432219 [migrate release checksums builder off of BBB to TC] to build Thunderbird 60 beta. a=jorgk DONTBUILD", "files": ["taskcluster/ci/release-generate-checksums-beetmover/kind.yml", "taskcluster/ci/release-generate-checksums-signing/kind.yml", "taskcluster/ci/release-generate-checksums/kind.yml", "taskcluster/docs/kinds.rst", "taskcluster/taskgraph/transforms/release_generate_checksums.py", "taskcluster/taskgraph/transforms/release_generate_checksums_beetmover.py", "taskcluster/taskgraph/transforms/release_generate_checksums_signing.py", "testing/mozharness/configs/releases/checksums_devedition.py", "testing/mozharness/configs/releases/checksums_fennec.py", "testing/mozharness/configs/releases/checksums_firefox.py", "testing/mozharness/configs/releases/dev_checksums_devedition.py", "testing/mozharness/configs/releases/dev_checksums_fennec.py", "testing/mozharness/configs/releases/dev_checksums_firefox.py", "testing/mozharness/scripts/release/generate-checksums.py"], "git_node": null, "git_parents": [null], "node": "f87ba53e04ff338f8c