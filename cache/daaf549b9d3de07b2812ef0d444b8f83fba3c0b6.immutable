anch": "default", "desc": "Bug 1358598 - Show ongoing notifications even if they're not the \"official\" foreground notification. r=jchen a=jcristau\n\nWe can have only one \"official\" foreground notification that's associated with\nthe NotificationService to keep the OS from background-killing us at the same\ntime, but that doesn't mean that we should simply ignore any further ongoing\nnotifications possibly arriving afterwards.\n\nMozReview-Commit-ID: L8rigs6GKzH", "files": ["mobile/android/base/java/org/mozilla/gecko/notifications/NotificationClient.java"], "git_node": null, "git_parents": [null], "node": "e51c4126451301e3ffb577640b1544480997afeb", "parents": ["1d1b5770dffd4c5873915624bc1f3c0e6ebccfe0"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1439728 - Don't force a switch-to-tab for the Address Bar heuristic match.  r=adw a=jcristau\n\nMozReview-Commit-ID: 2sfJBxbYefi", "files": ["toolkit/components/places/UnifiedComplete.js", "toolkit/components/places/tests/unifiedcomplete/test_tab_matches.js"], "git_node": null, "git_parents": [null], "node": "d30ae32ee90e7488d9cd72e7f79dcaf4d8d98737", "parents": ["e51c4126451301e3ffb577640b1544480997afeb"], "tags": []}, {"author": "Christoph Kerschbaumer \u003cckerschb@christophkerschbaumer.com\u003e", "branch": "default", "desc": "Bug 1443110: Add NullCheck for loadinfo within InitCSP. r=smaug a=jcristau", "files": ["dom/base/nsDocument.cpp"], "git_node": null, "git_parents": [null], "node": "e96ddf050a5651fea3b7f1ffc1a525753fa069be", "parents": ["d30ae32ee90e7488d9cd72e7f79dcaf4d8d98737"], "tags": []}, {"author": "Julien Cristau \u003cjcristau@mozilla.com\u003e", "branch": "default", "desc": "Bug 1443830 - Backed out changeset 1236752bf224 (bug 785440) for installer size regression. r=mstange a=jcristau", "files": ["dom/bindings/Codegen.py"], "git_node": null, "git_parents": [null], "node": "61018626779e19ac66142c9eecad035f309ece00", "parents": ["e96ddf0