m"}, "9124": {"changesets": [{"author": "Justin Wood \u003cCallek@gmail.com\u003e", "branch": "default", "desc": "Bug 1456246 - taskgraph: Perform release promotion needs on mozilla-esr60 on-push. (No Android). r=rail a=release\n\nMozReview-Commit-ID: BFpSAz3oj3F", "files": ["taskcluster/taskgraph/decision.py", "taskcluster/taskgraph/target_tasks.py"], "git_node": null, "git_parents": [null], "node": "97f050e4c9da14fb0166bc71a5742dd255ca2a69", "parents": ["de786672a738e38f3ab30160b97690947f604f0a"], "tags": []}, {"author": "Justin Wood \u003cCallek@gmail.com\u003e", "branch": "default", "desc": "Bug 1453274 - Add testing for python/mozrelease/versions.py r=rail a=release\nfor: taskgraph: Make update tasks support esr60\n\nMozReview-Commit-ID: GUmAq3sBXGB", "files": ["build/virtualenv_packages.txt", "python/moz.build", "python/mozrelease/test/python.ini", "python/mozrelease/test/test_versions.py"], "git_node": null, "git_parents": [null], "node": "46a0d50672cea5246c8244ba68c114e62786850e", "parents": ["97f050e4c9da14fb0166bc71a5742dd255ca2a69"], "tags": []}, {"author": "Justin Wood \u003cCallek@gmail.com\u003e", "branch": "default", "desc": "Bug 1453274 - Support esr version strings. r=rail a=release\n\nMozReview-Commit-ID: K7khNCzOwQK", "files": ["python/mozrelease/mozrelease/versions.py", "python/mozrelease/test/test_versions.py"], "git_node": null, "git_parents": [null], "node": "cb3a85e429f635ca0d77a264e53dd317fedf89c4", "parents": ["46a0d50672cea5246c8244ba68c114e62786850e"], "tags": []}], "date": 1524515709, "git_changesets": [null, null, null], "user": "Callek@gmail.com"}, "9125": {"changesets": [{"author": "Aki Sasaki \u003casasaki@mozilla.com\u003e", "branch": "default", "desc": "bug 1450012 - add rerun task. r=bstack", "files": ["taskcluster/taskgraph/actions/rerun.py", "taskcluster/taskgraph/util/taskcluster.py"], "git_node": null, "git_parents": [null], "node": "af372a7d4fd7001876545e97d445ff199a96141a", "parents": ["cb3a85e429f635ca0d77a264e53dd317fedf89c4"], "tags": []}, {"author": "Aki Sasaki \u003casasaki@mozilla.com\u003e", "branch": "default", "desc": "bug 1450012 - fix lint issue. r=lintfix a=release\n\nuplifting the rerun action, primarily since 60 is a long-lived version", "files": ["taskcluster/taskgraph/actions/rerun.py"], "git_node": null, "git_parents": [null], "node": "345b67c3fb35f8adaf71025c76bedb68ad383ada", "parents": ["af372a7d4fd7001876545e97d445ff199a96141a"], "tags": []}], "date": 1524523263, "git_changesets": [null, null], "user": "asasaki@mozilla.com"}, "9126": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nda -\u003e c9167074e0e9\nsl -\u003e ad230ec7cce5\nuz -\u003e afba28898693", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "af9fdb58f7a9184760ae3c682cf7c626b70422ed", "parents": ["345b67c3fb35f8adaf71025c76bedb68ad383ada"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nda -\u003e 13992dc01dc7\nfr -\u003e 6825be0dd7dd\nsl -\u003e abeca120fd16\nuz -\u003e afba28898693", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "059226cf0195aed9b2b7d5c5834e2b289c42c0fd", "parents": ["af9fdb58f7a9184760ae3c682cf7c626b70422ed"], "tags": []}], "date": 1524529389, "git_changesets": [null, null], "user": "ffxbld"}, "9127": {"changesets": [{"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1455448: Don't include `firefox` in the decision task index; r=dustin,mshal,rail,Callek a=release\n\nThe decision task is used for everything built as part of a push (for\nmozilla-central, this is firefox, devedition and fennec, as well as tasks that\naren't strictly part of any product). Thus, having `firefox` encoded as part of\nthe decision task doesn't make sense.\n\nThis changes the route from\n    index.gecko.v2.${repository.project}.latest.firefox.decision\nto\n    index.gecko.v2.${repository.project}.latest.taskgraph.decision\nwhile leaving the latter for backwards compatability with tools that expect it.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D996", "files": [".taskcluster.yml", "taskcluster/taskgraph/parameters.py"], "git_node": null, "git_parents": [null], "node": "82e0d69ecde1d708ba327f125e32d7478b7d16b5", "parents": ["059226cf0195aed9b2b7d5c5834e2b289c42c0fd"], "tags": []}], "date": 1524533374, "git_changesets": [null], "user": "mozilla@hocat.ca"}, "9128": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\ngu-IN -\u003e e070e6475845\npl -\u003e 7efa0fbcd616\nta -\u003e ec05a7e0c692", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "7fb24c4b9c3cf0f0a92bf6f167fbd1db0bfd6e9a", "parents": ["82e0d69ecde1d708ba327f125e32d7478b7d16b5"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\ngu-IN -\u003e e070e6475845\npl -\u003e 7efa0fbcd616\npt-PT -\u003e 0ae50cbbeec3\nta -\u003e 54273c993594", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "ab3e39cbfa32b91ff94ac0f7307ec512b4799269", "parents": ["7fb24c4b9c3cf0f0a92bf6f167fbd1db0bfd6e9a"], "tags": []}], "date": 1524547374, "git_changesets": [null, null], "user": "ffxbld"}, "9129": {"changesets": [{"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1437302 - Fix width of textbox[type=number] consumers. r=Paolo, Neil Deakin a=lizzard", "files": ["accessible/tests/mochitest/name/test_general.xul", "browser/components/preferences/connection.xul", "browser/themes/shared/incontentprefs/preferences.inc.css", "toolkit/components/printing/content/printPreviewBindings.xml", "toolkit/content/tests/chrome/test_textbox_number.xul", "toolkit/themes/linux/global/jar.mn", "toolkit/themes/linux/global/numberbox.css", "toolkit/themes/osx/global/jar.mn", "toolkit/themes/osx/global/numberbox.css", "toolkit/themes/shared/numberbox.inc.css", "toolkit/themes/windows/global/jar.mn", "toolkit/themes/windows/global/numberbox.css", "toolkit/themes/windows/global/printPreview.css"], "git_node": null, "git_parents": [null], "node": "2eb1065270bb851b87548ca26f05974b67153372", "parents": ["ab3e39cbfa32b91ff94ac0f7307ec512b4799269"], "tags": []}, {"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1437302 - Followup: fix reftest failures on a CLOSED TREE. r=me a=lizzard", "files": ["toolkit/themes/shared/numberbox.inc.css"], "git_node": null, "git_parents": [null], "node": "363aebb824a06ea3ce94543122f866d8e6abdb52", "parents": ["2eb1065270bb851b87548ca26f05974b67153372"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1454572: nsComputedDOMStyle: Don't crash when used on a detached pseudo-element. r=emilio,xidorn:emilio a=RyanVM\n\nThis shouldn't normally happen, but it does in some rare cases; e.g. if an accessibility client queries info for a node that is being removed.\n\nMozReview-Commit-ID: 3nac9ITN66f", "files": ["layout/style/nsComputedDOMStyle.cpp"], "git_node": null, "git_parents": [null], "node": "9215ab5bc95411c5c2b1b0a746a9c84c5f2ec57a", "parents": ["363aebb824a06ea3ce94543122f866d8e6abdb52"], "tags": []}, {"author": "Jan Horak \u003cjhorak@redhat.com\u003e", "branch": "default", "desc": "Bug 1455235 [gtk] Don't start moving window before mousemove event, r=dao a=lizzard\n\nWe need to start moving the window in GTK after mousemove event arrives,\nnot with mousedown, because the drag area can also process doubleclick\nevent to restore/maximize window. This also match to the GTK implementation,\nsee gedit behaviour for example.\n\nMozReview-Commit-ID: WXP3D2wIp0", "files": ["toolkit/modules/WindowDraggingUtils.jsm"], "git_node": null, "git_parents": [null], "node": "06f6ddcfe8d9020925359210acdcfd3edb787277", "parents": ["9215ab5bc95411c5c2b1b0a746a9c84c5f2ec57a"], "tags": []}, {"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1454607 - [macOS] \"Zoom\" and \"Edit\" labels are no longer aligned to text in other items in the hamburger panel. r=Gijs a=ritu\n\nMozReview-Commit-ID: 1ZylXanmN92", "files": ["browser/themes/osx/customizableui/panelUI.css"], "git_node": null, "git_parents": [null], "node": "37c3ffc007e5980779ebf06a02247916b895062f", "parents": ["06f6ddcfe8d9020925359210acdcfd3edb787277"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1449326: Account for min- / max- block size changes too in the flex caching code. r=dholbert a=lizzard\n\nWe may be reflowing the same kid with different (definite / non-definite)\ncontaining block sizes, which changes the min block size in:\n\n  https://searchfox.org/mozilla-central/rev/f65d7528e34ef1a7665b4a1a7b7cdb1388fcd3aa/layout/generic/ReflowInput.cpp#3077\n\nIn which case we may need to reflow in order to properly align the flex item.\n\nMozReview-Commit-ID: 27aS2UrgXjs", "files": ["layout/generic/nsFlexContainerFrame.cpp", "layout/reftests/w3c-css/submitted/flexbox/flexbox-definite-sizes-001-ref.html", "layout/reftests/w3c-css/submitted/flexbox/flexbox-definite-sizes-001.html", "layout/reftests/w3c-css/submitted/flexbox/flexbox-definite-sizes-002.html", "layout/reftests/w3c-css/submitted/flexbox/flexbox-definite-sizes-003.html", "layout/reftests/w3c-css/submitted/flexbox/flexbox-definite-sizes-004.html", "layout/reftests/w3c-css/submitted/flexbox/reftest.list"], "git_node": null, "git_parents": [null], "node": "bb01c965834f75b4558353870c69d5dd0c20d4eb", "parents": ["37c3ffc007e5980779ebf06a02247916b895062f"], "tags": []}, {"author": "Nicolas B. Pierron \u003cnicolas.b.pierron@gmail.com\u003e", "branch": "default", "desc": "Bug 1448089 - Make MBasicBlock::addPredecessorSameInputsAs fallible. r=tcampbell a=lizzard", "files": ["js/src/jit/IonAnalysis.cpp", "js/src/jit/MIRGraph.cpp", "js/src/jit/MIRGraph.h"], "git_node": null, "git_parents": [null], "node": "dc7d484e8d3dbbc21ab500aa1282bcfcf1ca89a1", "parents": ["bb01c965834f75b4558353870c69d5dd0c20d4eb"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1448089 followup, remove now-unused variable to fix a CLOSED TREE. a=lizzard", "files": ["js/src/jit/MIRGraph.cpp"], "git_node": null, "git_parents": [null], "node": "e378f069dee417b32c92799299245bab46b7c09a", "parents": ["dc7d484e8d3dbbc21ab500aa1282bcfcf1ca89a1"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1454126 - HTMLEditor should adjust selection outside native anonymous subtree when it inserts something at selection r=m_kato a=RyanVM\n\nHTMLEditor::InsertElementAtSelection() doesn't check if selection is in\nnative anonymous subtree.  Therefore, it could insert element into \u003cinput\u003e\nelement etc.\n\nThis patch adds new API to EditorDOMPointBase to compute ancestor point which\nis not in native-anonymous subtree and make\nHTMLEditor::GetBetterInsertionPointFor() use it to not return point in any\nnative-anonymous subtrees.", "files": ["editor/libeditor/EditorDOMPoint.h", "editor/libeditor/HTMLEditor.cpp"], "git_node": null, "git_parents": [null], "node": "e41d8e56d3e644e1984bc353ac55bb1c05d016fb", "parents": ["e378f069dee417b32c92799299245bab46b7c09a"], "tags": []}, {"author": "J.C. Jones \u003cjjones@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441338 - Change pgo certificates to use certspec/keyspec files r=keeler r=franziskus a=jcristau\n\n(This also fixes Bug 879740 and Bug 1204543.)\n\nbuild/pgo/certs contains an NSS database set that has a bunch of hand-generated\ncertificates, and many of these hand-generated certificates are specifically\ndepended upon for a variety of unit tests. This patch changes all of these to\nuse the \"pycert.py\" and \"pykey.py\" utilities that produce deterministic keys\nand certificates.\n\nThe naming convention here is new, and defined in the README. It is based on\nthe mochitest runtest.py naming convention that imports .ca and .client\nPEM-encoded certificates.\n\nUnfortunately, the updates to build/pgo/genpgocert.py to generate these files\ndepends on OpenSSL in order to produce PKCS12 archives for pk11tool to import\ninto NSS. This could be done with pure-NSS tooling, but it'd require some new\ncommand line functionality, which is out-of-scope for this change.\n\nNote that build/pgo/genpgocert.py no longer takes arguments when run. It's not\nrun automatically anywhere that I can see, but could (reasonably) be, now.\n\n(This patch rebased for Beta)\n\nDifferential Revision: https://phabricator.services.mozilla.com/D971", "files": ["browser/base/content/test/general/browser_ssl_error_reports.js", "browser/base/content/test/general/pinning_headers.sjs", "browser/base/content/test/general/ssl_error_reports.sjs", "build/pgo/certs/README", "build/pgo/certs/alternateroot.ca", "build/pgo/certs/alternateroot.ca.keyspec", "build/pgo/certs/alternateroot.certspec", "build/pgo/certs/bug413909cert.certspec", "build/pgo/certs/cert9.db", "build/pgo/certs/dynamicPinningBad.certspec", "build/pgo/certs/dynamicPinningBad.server.keyspec", "build/pgo/certs/dynamicPinningGood.certspec", "build/pgo/certs/escapeattack1.certspec", "build/pgo/certs/evintermediate.ca", "build/pgo/certs/evintermediate.ca.keyspec", "build/pgo/certs/evintermediate.certspec", "build/pgo/certs/expired.certspec", "build/pgo/certs/imminently_distrusted.certspec", "build/pgo/certs/jartests-object.ca", "build/pgo/certs/key4.db", "build/pgo/certs/mochitest.certspec", "build/pgo/certs/mochitest.client", "build/pgo/certs/mochitest.client.keyspec", "build/pgo/certs/pgoca.ca", "build/pgo/certs/pgoca.ca.keyspec", "build/pgo/certs/pgoca.certspec", "build/pgo/certs/pgoca.p12", "build/pgo/certs/secmod.db", "build/pgo/certs/selfsigned.certspec", "build/pgo/certs/sha1_end_entity.certspec", "build/pgo/certs/sha256_end_entity.certspec", "build/pgo/certs/staticPinningBad.certspec", "build/pgo/certs/staticPinningBad.server.keyspec", "build/pgo/certs/unknown_ca.certspec", "build/pgo/certs/untrusted.certspec", "build/pgo/certs/untrustedandexpired.certspec", "build/pgo/genpgocert.py", "security/manager/ssl/tests/mochitest/browser/browser_clientAuth_ui.js", "security/manager/ssl/tests/unit/pycert.py", "security/manager/ssl/tests/unit/pykey.py", "testing/mochitest/runtests.py"], "git_node": null, "git_parents": [null], "node": "8471e4e4f0df5888fe04ac0c060d426b94883239", "parents": ["e41d8e56d3e644e1984bc353ac55bb1c05d016fb"], "tags": []}], "date": 1524550556, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "9130": {"changesets": [{"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1449338 - Activity Stream part of Replace search icon with logo of user's search engine. r=k88hudson a=lizzard\n\nMozReview-Commit-ID: 8jTznH1QYQV", "files": ["browser/extensions/activity-stream/css/activity-stream-linux.css", "browser/extensions/activity-stream/css/activity-stream-linux.css.map", "browser/extensions/activity-stream/css/activity-stream-mac.css", "browser/extensions/activity-stream/css/activity-stream-mac.css.map", "browser/extensions/activity-stream/css/activity-stream-windows.css", "browser/extensions/activity-stream/css/activity-stream-windows.css.map", "browser/extensions/activity-stream/install.rdf.in"], "git_node": null, "git_pare