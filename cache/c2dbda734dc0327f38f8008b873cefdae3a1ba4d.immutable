lBlocklistDefs.in"], "git_node": "982654f5f0bd3322d09e98e06d34ec1756871c4f", "git_parents": ["a5551c4c2ed995565dc9549f79cd737cac32f237"], "node": "2656a81d3ec393b3027cd6187587e38c03cd8bd7", "parents": ["80863fe949e53fbd793e5214cc3cd0c29747f234"], "tags": []}], "date": 1768409230, "git_changesets": ["982654f5f0bd3322d09e98e06d34ec1756871c4f"], "user": "dmeehan@mozilla.com"}, "24332": {"changesets": [{"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 2009439 - Make nsHTTPCompressConv::mDispatchToMainThread atomic  a=dmeehan DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D278772\n\nDifferential Revision: https://phabricator.services.mozilla.com/D278961\n", "files": ["netwerk/streamconv/converters/nsHTTPCompressConv.cpp", "netwerk/streamconv/converters/nsHTTPCompressConv.h"], "git_node": "99f39a14a381a4d0a77336e16e25e85f5db740c5", "git_parents": ["982654f5f0bd3322d09e98e06d34ec1756871c4f"], "node": "429822924e4f378d04f991a26441f2b02cf8dc69", "parents": ["2656a81d3ec393b3027cd6187587e38c03cd8bd7"], "tags": []}], "date": 1768409280, "git_changesets": ["99f39a14a381a4d0a77336e16e25e85f5db740c5"], "user": "dmeehan@mozilla.com"}, "24333": {"changesets": [{"author": "Jeff Muizelaar \u003cjmuizelaar@mozilla.com\u003e", "branch": "default", "desc": "Bug 2009849. Add *.si.com to dom.timeout.defer_during_load.force-disable. r=RyanVM a=dmeehan\n\nKsenia, confirmed that setting dom.timeout.defer_during_load appears to fix the\ninfinite reloading.\n\nThat makes sense because we see code like:\n\n      setTimeout(\n        function () {\n          n &&\n          s &&\n          window.dispatchEvent(n),\n          r &&\n          window.dispatchEvent(r)\n        }\n      )\n\nand the dispatchEvent ends up getting reordered with code that installs the listener for consent.onetrust\n\n  co.prototype.OnConsentChanged = function (e) {\n      var t = e.toString();\n      ao.consentChangedEventMap[t] ||\n      (\n        ao.consentChangedEventMap[t] = !0,\n        window.addEventListener('consent.onetrust', e)\n      )\n    }\n\nso that it fires after the listener has been installed instead of\nbefore.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D278909\n", "files": ["modules/libpref/init/StaticPrefList.yaml"], "git_node": "285965da3022da2dfaba59ed4b17b210069025b6", "git_parents": ["99f39a14a381a4d0a77336e16e25e85f5db740c5"], "node": "b2e38764f293820f266096e11fc0171aa9c93b82", "parents": ["429822924e4f378d04f991a26441f2b02cf8dc69"], "tags": []}], "date": 1768409952, "git_changesets": ["285965da3022da2dfaba59ed4b17b210069025b6"], "user": "dmeehan@mozilla.com"}, "24334": {"changesets": [{"author": "Teodor Tanasoaia \u003cttanasoaia@mozilla.com\u003e", "branch": "default", "desc": "Bug 2007754 - Update `wgpu` to revision a3164af1e1922052966e00147be12ea7e2a5bb22. r=webgpu-reviewers,supply-chain-reviewers,nical a=dmeehan\n\nThis is a `wgpu` update for Firefox 148 (currently in beta) that fixes a topcrash.\n\nIt only includes https://github.com/gfx-rs/wgpu/commit/a3164af1e1922052966e00147be12ea7e2a5bb22.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D278642\n", "files": [".cargo/config.toml.in", "Cargo.lock", "gfx/wgpu_bindings/Cargo.toml", "gfx/wgpu_bindings/moz.yaml", "supply-chain/audits.toml", "supply-chain/imports.lock", "third_party/rust/wgpu-hal/.cargo-checksum.json", "third_party/rust/wgpu-hal/src/dx12/adapter.rs", "third_party/rust/wgpu-hal/src/lib.rs"], "git_node": "11ca06b45dc5eee5f2eafb11da785b08c8c6bc60", "git_parents": ["285965da3022da2dfaba59ed4b17b210069025b6"], "node": "98e9ce00762339159716016e22560fc51b9d4535", "parents": ["b2e38764f293820f266096e11fc0171aa9c93b82"], "tags": []}], "date": 1768414148, "git_changesets": ["11ca06b45dc5eee5f2eafb11da785b08c8c6bc60"], "user": "dmeehan@mozilla.com"}, "24335": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "defau