5e7d38e627e9bba36a2f"], "node": "71f2d8227d835d956e22db9d2912b17ecad6a2fc", "parents": ["35040360acd4791f1c3595a4123a93927f3ee377"], "tags": []}], "date": 1768583702, "git_changesets": ["3c027d773a8e759f351a507db104e2a6c29975b5"], "user": "dmeehan@mozilla.com"}, "24362": {"changesets": [{"author": "Dave Townsend \u003cdtownsend@oxymoronical.com\u003e", "branch": "default", "desc": "Bug 2010535: Fall back to the remoting service for opening URLs if the profile service is in an invalid state.  a=dmeehan DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D279122\n\nDifferential Revision: https://phabricator.services.mozilla.com/D279271\n", "files": ["browser/components/profiles/SelectableProfileService.sys.mjs"], "git_node": "fc4ed45153d1e627712d42cd378f4d3f16abf8dd", "git_parents": ["3c027d773a8e759f351a507db104e2a6c29975b5"], "node": "5a78d2d57ee730e1d4e448c46e5f5b08580262b9", "parents": ["71f2d8227d835d956e22db9d2912b17ecad6a2fc"], "tags": []}], "date": 1768583746, "git_changesets": ["fc4ed45153d1e627712d42cd378f4d3f16abf8dd"], "user": "dmeehan@mozilla.com"}, "24363": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2006820 - Fix some popup moving edge cases. r=stransky a=dmeehan\n\nThe issue here is that we show a popup that doesn't need move for the\nfirst time. The anchor is not initially set, so we bail out of\nmove-to-rect and move it to the parent-relative position (fine).\n\nBut then we MoveResize and that lazily fetches the anchor info and tries\nto move_to_rect. For some reason, the move-to-rect callback doesn't ever\nappear, leaving us with a broken position.\n\nPrevent this by doing two changes:\n\n * First, gather the anchor information on move lazily if not set, not\n   just from MoveResize.\n\n * Avoid doing the work twice on show unnecessarily.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D277302\n", "files": ["widget/gtk/nsWindow.cpp"], "git_node": "01cfea63d92bf0160ed1eecc12b03a82ad169a75", "git_parents": ["fc4ed45153d1e627712d42cd378f4d3f16abf8dd"], "node": "5a499a89a0ed5927757fe9419820d92f18b10cda", "parents": ["5a78d2d57ee730e1d4e448c46e5f5b08580262b9"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2010484 - Avoid custom styled select if the select uses background-image. r=mconley a=dmeehan\n\nSee the comment, and the extra context in the bug. This used to kinda\nwork on light mode before the regressing bug, because we forced the dark\ncolor, but it never worked properly...\n\nDifferential Revision: https://phabricator.services.mozilla.com/D279142\n", "files": ["browser/base/content/test/forms/browser_selectpopup_colors.js", "toolkit/actors/SelectChild.sys.mjs"], "git_node": "c03fe6f15a0cdcc83c95f9eb79ee647884d1fff5", "git_parents": ["01cfea63d92bf0160ed1eecc12b03a82ad169a75"], "node": "447ef87f2e7de8ab7967ffa897d26dcb4e739403", "parents": ["5a499a89a0ed5927757fe9419820d92f18b10cda"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2010056 - Make document viewer initialization more infallible. r=layout-reviewers,dshin a=dmeehan\n\nNo behavior change, just less code.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D278848\n", "files": ["dom/events/EventStateManager.cpp", "dom/events/EventStateManager.h", "layout/base/nsDocumentViewer.cpp", "layout/base/nsPresContext.cpp", "layout/base/nsPresContext.h", "layout/printing/nsPrintJob.cpp"], "git_node": "d8956971aa89d08674ef4f7635f2f2e2eeff70c9", "git_parents": ["c03fe6f15a0cdcc83c95f9eb79ee647884d1fff5"], "node": "a867a2eb94dcda4fc63f71261185e94255e084d9", "parents": ["447ef87f2e7de8ab7967ffa897d26dcb4e739403"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2010056 - Don't return a print pres shell from GetSubDocumentForPainting(). r=layout-reviewers,dshin a=dmeehan\n\nDifferential Revision: https://phabricator.services.mozilla.com/D278850\n", "files": ["layout/generic/nsSubDocumentFrame.cpp"], "git_node": "28722f4953de20a5460daa387e5d223f3f21be69", "git_parents": ["d8956971aa89d08674ef4f7635f2f2e2eeff70c9"], "node": "f37fb82a8a53a879cd4811a5d67eddcb3522f3a3", "parents": ["a867a2eb94dcda4fc63f71261185e94255e084d9"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2010056 - Don't create a pres context for print documents. r=layout-reviewers,dshin a=dmeehan\n\nWe currently end up in this weird state where the document ends up with two\npres contexts (one from print job, one from viewer), one of them uninitialized\n(because InitPresentationStuff never runs).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D278849\n", "files": ["layout/base/nsDocumentViewer.cpp"], "git_node": "5a3cad9831fe85c2fbe56b60509f0cdd29674d79", "git_parents": ["28722f4953de20a5460daa387e5d223f3f21be69"], "node": "29a8b353d83bde761beb43e4d45234bd62439fb2", "parents": ["f37fb82a8a53a879cd4811a5d67eddcb3522f3a3"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2010056 - Add a test. r=layout-reviewers,dshin a=dmeehan\n\nAnd fix cleanup so that it passes.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D278851\n", "files": ["dom/base/nsGlobalWindowOuter.cpp", "toolkit/components/printing/tests/browser.toml", "toolkit/components/printing/tests/browser_print_silent_about_config.js"], "git_node": "f13fdfefd42fe5a351b4c7e010ca54aca4446637", "git_parents": ["5a3cad9831fe85c2fbe56b60509f0cdd29674d79"], "node": "1dd092ee3d03dee078f3126755efb64fe7310fab", "parents": ["29a8b353d83bde761beb43e4d45234bd62439fb2"], "tags": []}], "date": 1768584473, "git_changesets": ["01cfea63d92bf0160ed1eecc12b03a82ad169a75", "c03fe6f15a0cdcc83c95f9eb79ee647884d1fff5", "d895697