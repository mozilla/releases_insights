85", "parents": ["8130b323cbffbb465d73da07f062f141904ad869"], "tags": []}], "date": 1769713753, "git_changesets": ["97695caa864e4c12a6372d1ea0f13f088482d1cd"], "user": "dmeehan@mozilla.com"}, "24507": {"changesets": [{"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 2005800 - Part 1: Support Translations and SidebarChatbot AI controls with AIFeature  a=dmeehan\n\nIntegrate the AIFeature for Translations and create an AIFeature handler\nfor the SidebarChatbot control.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D280118\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281002\n", "files": ["browser/components/genai/GenAI.sys.mjs", "browser/components/preferences/OnDeviceModelManager.mjs", "browser/components/preferences/config/aiFeatures.mjs", "browser/components/preferences/tests/browser_aiFeatures.js", "toolkit/components/pdfjs/content/PdfJsAIFeature.sys.mjs", "toolkit/components/translations/TranslationsFeature.sys.mjs", "toolkit/components/translations/tests/browser/browser_translations_ai_feature.js"], "git_node": "ffdaabb2822d545188164b138dadaa06f5cbfca3", "git_parents": ["97695caa864e4c12a6372d1ea0f13f088482d1cd"], "node": "cdd74852fee7a5912a12d2325498d45b2acd400a", "parents": ["28b0b6404ff602d5c66b447eb0dba33829d42e85"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 2005800 - Part 2: Block AI enhancements button in Settings  a=dmeehan\n\nProvide a toggle to disable or enable AI enhancements in Settings. Using\nthe toggle will tell each feature to block itself and uninstall any\ndownloaded models if the feature was previously used. When all features\nare blocked, an individual feature can still be enabled by the user with\nits feature dropdown.\n\nManually setting the browser.ai.control.default pref to \"blocked\" is not\nguaranteed to block all AI features at this time. In the future features\nmay be updated to respect this pref directly rather than going through\nthe Settings page.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D277275\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281003\n", "files": ["browser/app/profile/firefox.js", "browser/components/preferences/OnDeviceModelManager.mjs", "browser/components/preferences/config/aiFeatures.mjs", "browser/components/preferences/main.js", "browser/components/preferences/preferences.js", "browser/components/preferences/tests/browser_aiFeatures.js"], "git_node": "121673467b36e73c079217b8dd0aac7bf82b2076", "git_parents": ["ffdaabb2822d545188164b138dadaa06f5cbfca3"], "node": "2356aad7a19db6352c956c38d93f0d50057b1100", "parents": ["cdd74852fee7a5912a12d2325498d45b2acd400a"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 2005800 - Part 3: Component updates for block AI Controls  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D280119\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281004\n", "files": ["toolkit/content/widgets/lit-utils.mjs", "toolkit/content/widgets/moz-input-common.css"], "git_node": "55ae6325503a75be5c5e769461666317219a1d73", "git_parents": ["121673467b36e73c079217b8dd0aac7bf82b2076"], "node": "776c8692a7e86f78b69836563e83e6a09ee00138", "parents": ["2356aad7a19db6352c956c38d93f0d50057b1100"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 2005804 - Part 1: Show descriptions and images in AI controls  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D280200\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281005\n", "files": ["browser/base/content/test/static/browser_parsable_css.js", "browser/components/preferences/config/aiFeatures.mjs", "browser/components/preferences/preferences.js", "browser/components/preferences/widgets/setting-pane/setting-pane.css", "browser/c