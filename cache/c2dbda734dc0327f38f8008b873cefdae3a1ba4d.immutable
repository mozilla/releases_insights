it_node": "cecb23ccecb5f06ca516aa60907078cb5bb0a8fb", "git_parents": ["33ce5d8fffa0a4772cf531e6a5e7b3e495924726"], "node": "54fc010e1ede352707a622a519b74537e12a9d9b", "parents": ["c99ba2375421f90c85e551c481b19271d24b7dd5"], "tags": []}], "date": 1770554640, "git_changesets": ["cecb23ccecb5f06ca516aa60907078cb5bb0a8fb"], "user": "dmeehan@mozilla.com"}, "24628": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2014986 - Improve prev sibling computation for flex / grid containers.  a=dmeehan\n\nThe situation this patch deals with is when you have the following frame\ntree structure:\n\n  ns{Flex,Grid}ContainerFrame\n   ::-moz-anonymous-item\n     Some text\n\nAnd you append something after \"Some text\".\n\nBefore the regressing bug, we ended up in different codepaths for\ninsertion and append: Append always ended with the grid container as a\nparent (and the anonymous item as a prev sibling), while insert ended\nwith the current nightly behavior of choosing the text frame as a\nsibling, and the anonymous item as a parent.\n\nWipeContainingBlock has code to deal with the wrong choice, but that\nforces the container to be reconstructed, which is inefficient and in\ncases like this one has correctness implications (because we store the\n\"view transition live capture bit\" on the frame). I filed bug 2015007\nfor that since that's technically wrong too.\n\nThis is the relatively-minimal upliftable fix to minimize reframes in\nboth cases, which of course fixes the regression. I think it might be\nworth looking into whether we can make the right decision later in the\npipeline (e.g., making WipeContainingBlock override the insertion parent\nrather than bailing out). But that seems riskier.\n\nAdd a test for the different cases here.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D282161\n\nDifferential Revision: https://phabricator.services.mozilla.com/D282288\n", "files": ["layout/base/nsCSSFrameConstructor.cpp", "layout/style/test/test_dynamic_change_causing_reflow.html"], "git_node": "bf7a235a8ec9685fcf4697699d8d060d4465bdab", "git_parents": ["cecb23ccecb5f06ca516aa60907078cb5bb0a8fb"], "node": "922decb19c5b950c0a037f0b05409c57969096c0", "parents": ["54fc010e1ede352707a622a519b74537e12a9d9b"], "tags": []}], "date": 1770554764, "git_changesets": ["bf7a235a8ec9685fcf4697699d8d060d4465bdab"], "user": "dmeehan@mozilla.com"}, "24629": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Import translations from main\n", "files": ["mobile/android/android-components/components/browser/errorpages/src/main/res/values-km/strings.xml", "mobile/android/android-components/components/feature/addons/src/main/res/values-km/strings.xml", "mobile/android/android-components/components/feature/findinpage/src/main/res/values-km/strings.xml", "mobile/android/android-components/components/feature/prompts/src/main/res/values-cs/strings.xml", "mobile/android/android-components/components/feature/prompts/src/main/res/values-eu/strings.xml", "mobile/android/android-components/components/feature/prompts/src/main/res/values-fi/strings.xml", "mobile/android/android-components/components/feature/prompts/src/main/res/values-km/strings.xml", "mobile/android/android-components/components/feature/prompts/src/main/res/values-nb-rNO/strings.xml", "mobile/android/android-components/components/feature/prompts/src/main/res/values-sk/strings.xml", "mobile/android/android-components/components/feature/prompts/src/main/res/values-tg/strings.xml", "mobile/android/android-components/components/feature/prompts/src/main/res/values-th/strings.xml", "mobile/android/android-components/components/lib/crash/src/main/res/values-ast/strings.xml", "mobile/android/android-components/components/lib/crash/src/main/res/values-km/strings.xml", "mobile/android/fenix/app/src/main/res/values-cs/strings.xml", "mobile/an