erential Revision: https://phabricator.services.mozilla.com/D281392\n", "files": ["security/sandbox/chromium-shim/patches/52_surface_kPolMemPageCount_and_revert_to_14.patch", "security/sandbox/chromium/sandbox/win/src/sandbox_policy.h", "security/sandbox/win/src/sandboxbroker/sandboxBroker.cpp"], "git_node": "545f356277f3bcf3c60aba213ce107fe9b9df39b", "git_parents": ["0ec4d6e8f1277edab2adad242760515ce2f11b4c"], "node": "cc9f8f31e18e0809c722f68ee3d16b8bb34db63f", "parents": ["a258da708d2ec02cc3e22e05a53fdc30795a1398"], "tags": []}], "date": 1770055876, "git_changesets": ["545f356277f3bcf3c60aba213ce107fe9b9df39b"], "user": "dmeehan@mozilla.com"}, "24547": {"changesets": [{"author": "Bob Owen \u003cbobowencode@gmail.com\u003e", "branch": "default", "desc": "Bug 2010286: Add sandbox rules for GetUserGeoID.  a=dmeehan DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D279940\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281391\n", "files": ["security/sandbox/win/src/sandboxbroker/sandboxBroker.cpp"], "git_node": "05cd03acab47551d32d339faccae166b2d02ec8f", "git_parents": ["545f356277f3bcf3c60aba213ce107fe9b9df39b"], "node": "74de9d08b83d3e9f99bca851732f5def767bed76", "parents": ["cc9f8f31e18e0809c722f68ee3d16b8bb34db63f"], "tags": []}], "date": 1770055932, "git_changesets": ["05cd03acab47551d32d339faccae166b2d02ec8f"], "user": "dmeehan@mozilla.com"}, "24548": {"changesets": [{"author": "Jari Jalkanen \u003cjjalkanen@mozilla.com\u003e", "branch": "default", "desc": "Bug 2011916: Disable certain partitioning tests for on mac.  a=dmeehan DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D280078\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281378\n", "files": ["testing/web-platform/mozilla/meta/dom/quota/test-partitioned-access-to-fs-in-iframes.https.window.js.ini", "testing/web-platform/mozilla/meta/dom/quota/test-partitioned-access-to-idb-in-iframes.https.window.js.ini"], "git_node": "f5266cd813f1bba727b7140e976ed0603dafedf6", "git_parents": ["05cd03acab47551d32d339faccae166b2d02ec8f"], "node": "c13dae7c048a39b8f550c9ea2cd46ecc3a9b8c86", "parents": ["74de9d08b83d3e9f99bca851732f5def767bed76"], "tags": []}], "date": 1770055971, "git_changesets": ["f5266cd813f1bba727b7140e976ed0603dafedf6"], "user": "dmeehan@mozilla.com"}, "24549": {"changesets": [{"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 2012755 - fix network error page TRR/DoH exceptions and helpful links for cert mismatches,  a=dmeehan DONTBUILD\n\nAfter bug 1941148, HOST_NAME is now display-based. That's mostly good, but there\nwere a few places that actually need/want the internal hostname only - the DoH\nexceptions list, and the handling that suggests opening `www.example.com` in the\ncase of certificate mismatch errors based on the SAN. Both of these need ASCII\nhosts (not display, ie \"pretty\" hosts in the case of IDN), and don't want/need\nthe port number.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D280733\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281418\n", "files": ["browser/base/content/test/about/browser_aboutNetError.js", "toolkit/actors/NetErrorChild.sys.mjs", "toolkit/actors/NetErrorParent.sys.mjs", "toolkit/content/aboutNetError.mjs", "toolkit/content/aboutNetErrorHelpers.mjs", "toolkit/modules/RemotePageAccessManager.sys.mjs", "tools/lint/eslint/eslint-plugin-mozilla/lib/environments/remote-page.mjs"], "git_node": "a2f2c9c3c0d1c13df85824da69f2dcdcf244dfa8", "git_parents": ["f5266cd813f1bba727b7140e976ed0603dafedf6"], "node": "6084ea7f516c68a3e5f9b2732a9e5fb53a31ab58", "parents": ["c13dae7c048a39b8f550c9ea2cd46ecc3a9b8c86"], "tags": []}], "date": 1770056072, "git_changesets": ["a2f2c9c3c0d1c13df85824da69f2dcdcf244dfa8"], "user": "dmeehan@mozilla.com"}, "24550": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP tld-suffixes ct-logs -  a=dmeehan\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281405\n", "files": ["netwerk/dns/effective_tld_names.dat", "security/ct/CTKnownLogs.h", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "security/manager/tools/log_list.json", "toolkit/components/certviewer/content/components/logNameTable.mjs"], "git_node": "dffeb53731159459d401123e244c79f050df2f3d", "git_parents": ["a2f2c9c3c0d1c13df85824da69f2dcdcf244dfa8"], "node": "ea878bda36b19068b2aa7170ea9f293f467b6487", "parents": ["6084ea7f516c68a3e5f9b2732a9e5fb53a31ab58"], "tags": []}], "date": 1770056252, "git_changesets": ["dffeb53731159459d401123e244c79f050df2f3d"], "user": "dmeehan@mozilla.com"}, "24551": {"changesets": [{"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 2012606 - Fix type confusion when matching hash table keys r=spidermonkey-reviewers,mgaudet a=dmeehan DONTBUILD\n\nThe problem here is that we previously only checked the type of |l| and if it\nwas a symbol then we called toSymbol() on |k| which could potentially be an\nobject. This could result in an assertion failure in debug builds.\n\nFortunately we never dereferenced this pointer and simply compared it to |l|'s\npointer, and since these will always compare not equal if they are of different\ntypes the match will fail.\n\nThe fix is to check the types first to avoid any possibility of type confusion.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D280570\n", "files": ["js/src/gc/FinalizationObservers.h"], "git_node": "7eb85927659c61c901c319253aab5691be9cd43f", "git_parents": ["dffeb53731159459d401123e244c79f050df2f3d"], "node": "5471251efdd44eb281ae56ec64672a26043007dc", "parents": ["ea878bda36b19068b2aa7170ea9f293f467b6487"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 2010940 - Clear queued objects for dead finalization registries during sweep r=sfink a=dmeehan DONTBUILD\n\nWhat's happening here is that a FinalizationQueueObject is surviving a GC in\nwhich its owning FinalizationRegistryObject object dies. I think this happens\nbecause it gets queued for cleanup but the next GC happens before this runs.\nThe queue ends up containing dangling pointers to dead\nFinalizationRecordObjects and this causes a UAF when we attempt to access them.\n\nThe problem is that we don't have a read barrier when we take a weak pointer to\na finalization record and make it strong by adding it to the queue of records\nto clean up. It's not really feasible to add one here either since we may have\nfinished marking at this point. Instead we can clear any queued records when we\nnotice that a registy is dead, removing any that may be about to die. (The\nrecords are in the same zone as the registry so they won't be destroyed before\nthis happens).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D279644\n", "files": ["js/src/builtin/FinalizationRegistryObject.cpp", "js/src/builtin/FinalizationRegistryObject.h", "js/src/gc/FinalizationObservers.cpp"], "git_node": "a6b800ce8680671f794cd2bb85e021f8f97f138b", "git_parents": ["7eb85927659c61c901c319253aab5691be9cd43f"], "node": "e1ccf431c9d7e53b7eaede114dd66b06124e1bb2", "parents": ["5471251efdd44eb281ae56ec64672a26043007dc"], "tags": []}], "date": 1770060941, "git_changesets": ["7eb85927659c61c901c319253aab5691be9cd43f", "a6b800ce8680671f794cd2bb85e021f8f97f138b"], "user": "dmeehan@mozilla.com"}, "24552": {"changesets": [{"author": "Nicholas Rishel \u003cnrishel@mozilla.com\u003e", "branch": "default", "desc": "Bug 2004494 - Hook Microsoft Store Ads attribution from install attribution data into Glean.  a=dmeehan DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D275328\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281503\n", "files": ["browser/components/aboutwelcome/tests/xpcshell/test_AboutWelcomeTelemetry.js", "browser/components/asrouter/metrics.yaml", "browser/components/attribution/metrics.yaml", "toolkit/components/telemetry/app/TelemetryEnvironment.sys.mjs", "toolkit/components/telemetry/tests/unit/TelemetryEnvironmentTesting.sys.mjs"], "git_node": "a0474122cea8b4fb6c72888ee581926a8e7dee9a", "git_parents": ["a6b800ce8680671f794cd2bb85e021f8f97f138b"], "node": "de717dbcbe23bd9cc5d7de71f3fed9d770df4c44", "parents": ["e1ccf431c9d7e53b7eaede114dd66b06124e1bb2"], "tags": []}], "date": 1770061641, "git_changesets": ["a0474122cea8b4fb6c72888ee581926a8e7dee9a"], "user": "dmeehan@mozilla.com"}, "24553": {"changesets": [{"author": "James Teow \u003cjteow@mozilla.com\u003e", "branch": "default", "desc": "Bug 2010941 - Part 1: Autofill origins only when they are typed -  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D279386\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281472\n", "files": ["browser/components/urlbar/UrlbarProviderAutofill.sys.mjs", "browser/components/urlbar/tests/unit/test_autofill_origins_typed_frecency.js", "browser/components/urlbar/tests/unit/xpcshell.toml", "toolkit/components/places/Database.cpp", "toolkit/components/places/Database.h", "toolkit/components/places/PlacesFrecencyRecalculator.sys.mjs", "toolkit/components/places/nsINavHistoryService.idl", "toolkit/components/places/tests/migration/places_v84.sqlite", "toolkit/components/places/tests/migration/places_v85.sqlite", "toolkit/components/places/tests/migration/xpcshell.toml"], "git_node": "69526adb3f2ecd4b5465753ba4b7146a19db4c44", "git_parents": ["a0474122cea8b4fb6c72888ee581926a8e7dee9a"], "node": "078c647268100456fe2354c97f444bc8307783d2", "parents": ["de717dbcbe23bd9cc5d7de71f3fed9d770df4c44"], "tags": []}, {"author": "James Teow \u003cjteow@mozilla.com\u003e", "branch": "default", "desc": "Bug 2010941 - Part 2: Fix tests -  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D279842\n\nDifferen