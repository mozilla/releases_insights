/fenix/app/src/main/res/drawable/nova_onboarding_toolbar_top_active.xml", "mobile/android/fenix/app/src/main/res/drawable/nova_onboarding_toolbar_top_inactive.xml", "mobile/android/fenix/app/src/main/res/drawable/nova_onboarding_tou.xml", "mobile/android/fenix/app/src/main/res/drawable/nova_onboarding_widget.xml"], "git_node": "5c607c2de52209c3b99b42a5f37286758116e327", "git_parents": ["9e2517973e01f98f65856c121d1ebbce4f698e08"], "node": "948050cf898f691cc0cabcb43b0bbada59e8f4d1", "parents": ["eef64f4a5a9c1d1a50c31f80ecd5824f0d7c804c"], "tags": []}, {"author": "t-p-white \u003ctowhite@mozilla.com\u003e", "branch": "default", "desc": "Bug 2012103 - Part 3: Refactor the sub-header implementation for `TermsOfServiceOnboardingPageRedesign`, and fix link warning for `updateFirstPlaceholder`  a=dmeehan DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D280590\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281400\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/redesign/view/TermsOfServiceOnboardingPageRedesign.kt"], "git_node": "7072f18dc2e621f812e2c5f4ae2b7a8e7ff39cab", "git_parents": ["5c607c2de52209c3b99b42a5f37286758116e327"], "node": "dfd739298b1d47915305f61e02b49b4b471f1bd7", "parents": ["948050cf898f691cc0cabcb43b0bbada59e8f4d1"], "tags": []}, {"author": "t-p-white \u003ctowhite@mozilla.com\u003e", "branch": "default", "desc": "Bug 2012103 - Part 4: Update the onboarding screen redesign to pagination dots to use the updated M3 color tokens defined in the Figma  a=dmeehan DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D280731\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281401\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/redesign/view/OnboardingScreenRedesign.kt"], "git_node": "a2fd4ce99d83e2c5a48781079e205a3d3b4855de", "git_parents": ["7072f18dc2e621f812e2c5f4ae2b7a8e7ff39cab"], "node": "adc32a48ec5d2ccf4f05f507db7c3ed1f1e77328", "parents": ["dfd739298b1d47915305f61e02b49b4b471f1bd7"], "tags": []}, {"author": "t-p-white \u003ctowhite@mozilla.com\u003e", "branch": "default", "desc": "Bug 2012103 - Part 5: Add Kit sync QR asset to the Sync sign in fragment.  a=dmeehan DONTBUILD\n\n{F56642173}\n\nOriginal Revision: https://phabricator.services.mozilla.com/D280730\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281402\n", "files": ["mobile/android/fenix/app/src/main/res/drawable/ic_scan.xml", "mobile/android/fenix/app/src/main/res/drawable/nova_onboarding_sync_qr.xml", "mobile/android/fenix/app/src/main/res/layout/fragment_turn_on_sync.xml"], "git_node": "593af840261fd899ec48806487a3414aab1028c3", "git_parents": ["a2fd4ce99d83e2c5a48781079e205a3d3b4855de"], "node": "de3de4c04de184a4dc5c38143e182e81031d23e0", "parents": ["adc32a48ec5d2ccf4f05f507db7c3ed1f1e77328"], "tags": []}, {"author": "t-p-white \u003ctowhite@mozilla.com\u003e", "branch": "default", "desc": "Bug 2012103 - Part 6: Nova onboarding ToU card Kit easter egg - change image on press  a=dmeehan DONTBUILD\n\n{F56660470}\n\nOriginal Revision: https://phabricator.services.mozilla.com/D280748\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281403\n", "files": ["mobile/android/fenix/app/lint-baseline.xml", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/redesign/view/TermsOfServiceOnboardingPageRedesign.kt", "mobile/android/fenix/app/src/main/res/drawable/nova_onboarding_tou_2.xml"], "git_node": "dc6002f91a96e9554cf5aacafadc4463eb06fe44", "git_parents": ["593af840261fd899ec48806487a3414aab1028c3"], "node": "37fba31b078645829c99d63dceb8aa6b1bd2292e", "parents": ["de3de4c04de184a4dc5c38143e182e81031d23e0"], "tags": []}], "date": 1770137577, "git_changesets": ["9e2517973e01f98f65856c121d1ebbce4f698e08", "5c607c2de52209c3b99b42a5f37286758116e327", "7072f18dc2e621f812e2c5f4ae2b7a8e7ff39cab", "a2fd4ce99d83e2c5a48781079e205a3d3b4855de", "593af840261fd899ec48806487a3414aab1028c3", "dc6002f91a96e9554cf5aacafadc4463eb06fe44"], "user": "dmeehan@mozilla.com"}, "24565": {"changesets": [{"author": "t-p-white \u003ctowhite@mozilla.com\u003e", "branch": "default", "desc": "Bug 2013625 - Enable Nova onboarding by default for Beta builds  a=dmeehan DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D281239\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281404\n", "files": ["mobile/android/fenix/app/onboarding.fml.yaml"], "git_node": "2bcb1d42225b84c762057beaaab376328c34c820", "git_parents": ["dc6002f91a96e9554cf5aacafadc4463eb06fe44"], "node": "10aa603e1efe2f9b23ec973e93ab811c57bf38d0", "parents": ["37fba31b078645829c99d63dceb8aa6b1bd2292e"], "tags": []}], "date": 1770137941, "git_changesets": ["2bcb1d42225b84c762057beaaab376328c34c820"], "user": "dmeehan@mozilla.com"}, "24566": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2013337 - Fix missing-closing-characters checks in custom property parsing. r=firefox-style-system-reviewers,dshin a=dmeehan\n\nWhat is going on in this page is:\n\n * We have two nested references + fallback, both with missing closing\n   parens.\n * But the value actually ends with a closing paren, the rgb() function.\n\nSo we fail to detect that the closing parens are missing, and we mess up\nthe indices during substitution because we rely on the fallback end\nbeing the end of the var() reference minus 1.\n\nProperly tests for it by checking the block end against the\noutside-of-the-block start. If they're the same there was no closing\nparen. We could extend cssparser with this information maybe but for now\nthis seems ok. UnquotedUrl I think we can leave as-is.\n\nAdd two tests, once with a would be successful substitution that we get\nwrong right now, but this patch fixes, and the actually crashing test.\n\nI'm a bit surprised that no fuzzer has found this before tbh...\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281506\n", "files": ["servo/components/style/custom_properties.rs", "testing/web-platform/tests/css/css-variables/missing-closing-nested-fallback-crash.html", "testing/web-platform/tests/css/css-variables/missing-closing-nested-fallback.html"], "git_node": "591fffc956da19cb8409ce2d22aa3745646442cb", "git_parents": ["2bcb1d42225b84c762057beaaab376328c34c820"], "node": "e6b975d05673eab7897c95fe46c68c423eb9d738", "parents": ["10aa603e1efe2f9b23ec973e93ab811c57bf38d0"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2013337 - Fix a regression with trailing unclosed comments. a=dmeehan\n", "files": ["servo/components/style/custom_properties.rs"], "git_node": "e2ed047fb7fdb9806c92dceccc08e9ce948672e8", "git_parents": ["591fffc956da19cb8409ce2d22aa3745646442cb"], "node": "f88f6b3bde9e5978ea0d298011c8f59321ba3fd4", "parents": ["e6b975d05673eab7897c95fe46c68c423eb9d738"], "tags": []}], "date": 1770138563, "git_changesets": ["591fffc956da19cb8409ce2d22aa3745646442cb", "e2ed047fb7fdb9806c92dceccc08e9ce948672e8"], "user": "dmeehan@mozilla.com"}, "24567": {"changesets": [{"author": "Haik Aftandilian \u003chaftandilian@mozilla.com\u003e", "branch": "default", "desc": "Bug 2010507 - Allow access to additional IO properties from the GPU process sandbox r=mac-reviewers,bradwerth a=dmeehan DONTBUILD\n\nAvoid long delays during GPU process startup caused by sandbox\nviolations on VMs. Add access to additional IO properties and sysctls\nand remove a duplicate entry. These changes are similar to the\nchanges added for bug 1893921 for content process startup delays\non virtual machines.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281138\n", "files": ["security/sandbox/mac/SandboxPolicyGPU.h"], "git_node": "12c0372164a7b2ff8a45e9675c18ded6c94225c0", "git_parents": ["e2ed047fb7fdb9806c92dceccc08e9ce948672e8"], "node": "46ba382f231bcf97f44ec0877882307c3a664386", "parents": ["f88f6b3bde9e5978ea0d298011c8f59321ba3fd4"], "tags": []}, {"author": "Brad Werth \u003cwerth@efn.org\u003e", "branch": "default", "desc": "Bug 2011063: Reject snapshots for unsupported formats. r=gfx-reviewers,jnicol a=dmeehan DONTBUILD\n\nDifferential Revision: https://phabricator.services.mozilla.com/D280864\n", "files": ["gfx/layers/wr/WebRenderBridgeParent.cpp"], "git_node": "37d8ac03915be0651e813c32056e34ebfaa7027e", "git_parents": ["12c0372164a7b2ff8a45e9675c18ded6c94225c0"], "node": "71cd0a6817f66ab9f0c732276731058b3628814a", "parents": ["46ba382f231bcf97f44ec0877882307c3a664386"], "tags": []}], "date": 1770142896, "git_changesets": ["12c0372164a7b2ff8a45e9675c18ded6c94225c0", "37d8ac03915be0651e813c32056e34ebfaa7027e"], "user": "dmeehan@mozilla.com"}, "24568": {"changesets": [{"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 2013274 - Show chatbot provider selection when changed via pref  a=dmeehan DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D281054\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281545\n", "files": ["browser/components/preferences/config/aiFeatures.mjs", "browser/components/preferences/tests/browser_aiFeatures.js"], "git_node": "22df560a9bb875eac6a1e5b1db1c9c2e059b1904", "git_parents": ["37d8ac03915be0651e813c32056e34ebfaa7027e"], "node": "d727c70ac41866cbc83579d64a56adc9b3d46f13", "parents": ["71cd0a6817f66ab9f0c732276731058b3628814a"], "tags": []}], "date": 1770143673, "git_changesets": ["22df560a9bb875eac6a1e5b1db1c9c2e059b1904"], "user": "dmeehan@mozilla.com"}, "24569": {"changesets": [{"author": "Mark Striemer \u003cmark@striemer.ca\u003e", "branch": "default", "desc": "Bug 2012995 - Improve Block AI dialog initial read with screen reader  a=dmeehan DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D281270\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281632\n", "files": ["br