e\npt-PT -\u003e f21d0a8a1319f034286121d43abb128ba3ef46ee\nrm -\u003e f21d0a8a1319f034286121d43abb128ba3ef46ee\nro -\u003e f21d0a8a1319f034286121d43abb128ba3ef46ee\nru -\u003e f21d0a8a1319f034286121d43abb128ba3ef46ee\nsk -\u003e f21d0a8a1319f034286121d43abb128ba3ef46ee\nsl -\u003e f21d0a8a1319f034286121d43abb128ba3ef46ee\nson -\u003e f21d0a8a1319f034286121d43abb128ba3ef46ee\nsq -\u003e f21d0a8a1319f034286121d43abb128ba3ef46ee\nsr -\u003e f21d0a8a1319f034286121d43abb128ba3ef46ee\nsv-SE -\u003e f21d0a8a1319f034286121d43abb128ba3ef46ee\nta -\u003e f21d0a8a1319f034286121d43abb128ba3ef46ee\nte -\u003e f21d0a8a1319f034286121d43abb128ba3ef46ee\nth -\u003e f21d0a8a1319f034286121d43abb128ba3ef46ee\ntl -\u003e f21d0a8a1319f034286121d43abb128ba3ef46ee\ntr -\u003e f21d0a8a1319f034286121d43abb128ba3ef46ee\ntrs -\u003e f21d0a8a1319f034286121d43abb128ba3ef46ee\nuk -\u003e f21d0a8a1319f034286121d43abb128ba3ef46ee\nur -\u003e f21d0a8a1319f034286121d43abb128ba3ef46ee\nuz -\u003e f21d0a8a1319f034286121d43abb128ba3ef46ee\nvi -\u003e f21d0a8a1319f034286121d43abb128ba3ef46ee\nwo -\u003e f21d0a8a1319f034286121d43abb128ba3ef46ee\nxh -\u003e f21d0a8a1319f034286121d43abb128ba3ef46ee\nzam -\u003e f21d0a8a1319f034286121d43abb128ba3ef46ee\nzh-CN -\u003e f21d0a8a1319f034286121d43abb128ba3ef46ee\nzh-TW -\u003e f21d0a8a1319f034286121d43abb128ba3ef46ee\n", "files": ["mobile/locales/l10n-changesets.json"], "git_node": "2b169eea95f1282b2ef58bbe1730687fbea88d7d", "git_parents": ["d5f0c260e28290d9d3b7326f4c5f8c12d9e9bf36"], "node": "5280464885e3f21180c33d84c8673265e0369342", "parents": ["1ebedf27c2225d6d9de09245563b559eb86e32d6"], "tags": []}], "date": 1770282234, "git_changesets": ["d5f0c260e28290d9d3b7326f4c5f8c12d9e9bf36", "2b169eea95f1282b2ef58bbe1730687fbea88d7d"], "user": "ffxbld@lando.moz.tools"}, "24594": {"changesets": [{"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 2014296 - Fix telemetry for the `quicksuggest.online.available` pref.  a=dmeehan DONTBUILD\n\nThis fixes the bug and makes a couple of other minor changes:\n\nRemove the `newValue` param to `#recordPref`. It's unnecessary complexity and an\nunnecessary secondary code path, and it doesn't really save anything perf-wise.\n\nDon't get `prefValue` when it's not needed. `onPrefChanged` and\n`onNimbusChanged` are called when *any* urlbar pref/variable changes, not just\nthe small number of prefs in `#PING_PREFS`.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D281692\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281791\n", "files": ["browser/components/urlbar/UrlbarController.sys.mjs", "browser/components/urlbar/tests/engagementTelemetry/browser/browser_glean_telemetry_record_preferences.js"], "git_node": "eaf209fc7e0bebc0dd3ba695f849d3dc24bc075b", "git_parents": ["2b169eea95f1282b2ef58bbe1730687fbea88d7d"], "node": "a2f665eb4f7bf9f14f6f1459d22127964ac225e0", "parents": ["5280464885e3f21180c33d84c8673265e0369342"], "tags": []}], "date": 1770297245, "git_changesets": ["eaf209fc7e0bebc0dd3ba695f849d3dc24bc075b"], "user": "dmeehan@mozilla.com"}, "24595": {"changesets": [{"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 2014318 - Record urlbar pref telemetry in the metrics ping in addition to the events ping.  a=dmeehan DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D281707\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281797\n", "files": ["browser/components/urlbar/metrics.yaml"], "git_node": "3f32c4a47be61a2e30886e34cbe43597c4191d60", "git_parents": ["eaf209fc7e0bebc0dd3ba695f849d3dc24bc075b"], "node": "59d2a75a7522a5b935a0577d6f34f128b4aadfcb", "parents": ["a2f665eb4f7bf9f14f6f1459d22127964ac225e0"], "tags": []}], "date": 1770297295, "git_changesets": ["3f32c4a47be61a2e30886e34cbe43597c4191d60"], "user": "dmeehan@mozilla.com"}, "24596": {"changesets": [{"author": "Roger Yang \u003croyang@mozilla.com\u003e", "branch": "default", "desc": "Bug 2004982 - Disable browser toolbar CFR in Beta and Nightly.  a=dmeehan DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D281878\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281885\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/utils/Settings.kt"], "git_node": "8fcd7cca6efb749ba8a336b802056fc29e2c1fb8", "git_parents": ["3f32c4a47be61a2e30886e34cbe43597c4191d60"], "node": "6afef23fe7a5f1997146b755f7b41837a445483e", "parents": ["59d2a75a7522a5b935a0577d6f34f128b4aadfcb"], "tags": []}], "date": 1770297832, "git_changesets": ["8fcd7cca6efb749ba8a336b802056fc29e2c1fb8"], "user": "dmeehan@mozilla.com"}, "24597": {"changesets": [{"author": "Hubert Boma Manilla \u003chmanilla@mozilla.com\u003e", "branch": "default", "desc": "Bug 2010743 - [devtools] Avoid prototype pollution when parsing form data  a=dmeehan DONTBUILD\n\nHighlights of this patch\n\n- Use `Object.create(null)` instead of `{}` when mapping the format data sections array to a array of dictionaries.\n- Use `URLSearchParams` to parse the format-data sections\n- Added tests to assert the fix for the prototype pollution.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D279525\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281928\n", "files": ["devtools/client/netmonitor/src/components/request-details/RequestPanel.js", "devtools/client/netmonitor/src/utils/request-utils.js", "devtools/client/netmonitor/test/browser_net_complex-params.js", "devtools/client/netmonitor/test/html_params-test-page.html"], "git_node": "a1e74eccb9084ae88a4c0c4da8c3ad00a9027f52", "git_parents": ["8fcd7cca6efb749ba8a336b802056fc29e2c1fb8"], "node": "469df201d96dbc01f834518573fa118f01e34016", "parents": ["6afef23fe7a5f1997146b755f7b41837a445483e"], "tags": []}], "date": 1770297875, "git_changesets": ["a1e74eccb9084ae88a4c0c4da8c3ad00a9027f52"], "user": "dmeehan@mozilla.com"}, "24598": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP tld-suffixes ct-logs -  a=dmeehan\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281931\n", "files": ["netwerk/dns/effective_tld_names.dat", "security/ct/CTKnownLogs.h", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "security/manager/tools/log_list.json"], "git_node": "898246e1846671f43cc25e2a9c72a9daa0254829", "git_parents": ["a1e74eccb9084ae88a4c0c4da8c3ad00a9027f52"], "node": "081175cdf0f7f53be976c01582b57f6db5536739", "parents": ["469df201d96dbc01f834518573fa118f01e34016"], "tags": []}], "date": 1770298132, "git_changesets": ["898246e1846671f43cc25e2a9c72a9daa0254829"], "user": "dmeehan@mozilla.com"}, "24599": {"changesets": [{"author": "John Lin \u003cjolin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1999402 - revoke old channel when redirect. r=alwu a=dmeehan DONTBUILD\n\nmSuspendAgent could holds an out-of-date channel reference while\nredirect and should stop managing it.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D280171\n", "files": ["dom/media/ChannelMediaResource.cpp", "dom/media/ChannelMediaResource.h"], "git_node": "faabfdddbd2626c72ff2200f83597c898fb82b16", "git_parents": ["898246e1846671f43cc25e2a9c72a9daa0254829"], "node": "0fbc650bc24ae0de6aa6f6f65c9318c25ddaeca2", "parents": ["081175cdf0f7f53be976c01582b57f6db5536739"], "tags": []}, {"author": "stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 2010733 [Wayland] Set mIsMapped before RequestFrameCallbackLocked() to make sure we register frame callback at WaylandSurface::MapLocked() r=emilio a=dmeehan DONTBUILD\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281759\n", "files": ["widget/gtk/WaylandSurface.cpp"], "git_node": "b0e01406eacb81f52ccaa3f249bf3313a1e77f1e", "git_parents": ["faabfdddbd2626c72ff2200f83597c898fb82b16"], "node": "8ddc5ec3786455caaa705b6eae2877cbb238420d", "parents": ["0fbc650bc24ae0de6aa6f6f65c9318c25ddaeca2"], "tags": []}], "date": 1770307124, "git_changesets": ["faabfdddbd2626c72ff2200f83597c898fb82b16", "b0e01406eacb81f52ccaa3f249bf3313a1e77f1e"], "user": "dmeehan@mozilla.com"}, "24600": {"changesets": [{"author": "Calixte Denizet \u003ccalixte.denizet@gmail.com\u003e", "branch": "default", "desc": "Bug 2014167 - Enable/disable 'guess alt-text' feature from the alt-text dialog when it's 'Available' from AI settings in beta 148  a=dmeehan DONTBUILD\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281973\n", "files": ["toolkit/components/pdfjs/content/build/pdf.mjs", "toolkit/components/pdfjs/content/build/pdf.scripting.mjs", "toolkit/components/pdfjs/content/build/pdf.worker.mjs", "toolkit/components/pdfjs/content/web/viewer-geckoview.mjs", "toolkit/components/pdfjs/content/web/viewer.mjs", "toolkit/components/pdfjs/moz.yaml"], "git_node": "b080920f3f5a6fa03f970ce0152aa9256a10a7f5", "git_parents": ["b0e01406eacb81f52ccaa3f249bf3313a1e77f1e"], "node": "49919fdf9f83af5b5eef6c47602c3e64ed25a230", "parents": ["8ddc5ec3786455caaa705b6eae2877cbb238420d"], "tags": []}], "date": 1770307497, "git_changesets": ["b080920f3f5a6fa03f970ce0152aa9256a10a7f5"], "user": "dmeehan@mozilla.com"}, "24601": {"changesets": [{"author": "pollymce \u003cpmceldowney@mozilla.com\u003e", "branch": "default", "desc": "Bug 2011536 - sanitize intent before interacting with it.  a=dmeehan DONTBUILD\n\nWe are seeing `ClassCastException`s in the crash report - this is likely to be happening because some external intent has serialized some class that our app doesn't know about.\nCalling this `sanitize()` function strips out unknown classes from the bundle.\n`Intent.putExtra()` will internally call unparcel(), which assumes the bundle is serializable, so we need to call sanitize before doing this.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281930\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/IntentReceiverActivity.kt"], "git_node": "5d613117b0d062b5f5b01f50bdbf7f15293ce610", "git_parents": ["b080920f3f5a6fa03f970ce0152aa9256a10a7f5"], "node": "29b2c0c349c78d0024b9e161387e0dac81fbae25", "parents": ["49919fdf9f83af5b5eef6c47602c3e64ed25a230"], "tags": []}], "date": 1770307570, "git_changesets": ["5d613117b0d062b5f5b01f50bdbf7f15293ce610"], "user": "dmeehan@mozilla.com"}, "24602": {"changesets": [{"author": "Mugurell \u003cMugurell@users.noreply.github.com\u003e", "branch": "default", "desc": "Bug 2014037 - Avoid race in starting a Fenix search  a=dmeehan\n\nTesting the buggy scenario I saw that when the issue reproduces we act upon\nSearchStarted before acting upon the Init action.\nThis change ensures that we always complete the search setup based on Init\nbefore acting upon SearchStarted.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D281591\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281979\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/search/BrowserToolbarToFenixSearchMapperMiddleware.kt"], "git_node": "13b96b0a06f5082e22c196976072db3957843979", "git_parents": ["5d613117b0d062b5f5b01f50bdbf7f15293ce610"], "node": "096d6a8a9f8b3f0f404d532d5e867b602077374a", "parents": ["29b2c0c349c78d0024b9e161387e0dac81fbae25"], "tags": []}, {"author": "Mugurell \u003cMugurell@users.noreply.github.com\u003e", "branch": "default", "desc": "Bug 2014042 - Ensure the private search suggestions banner is shown only if query is not blank  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D281612\n\nDifferential Revision: https://phabricator.services.mozilla.com/D281980\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/search/FenixSearchMiddleware.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/search/FenixSearchMiddlewareTest.kt"], "git_node": "fa762422cf6fcb1806a2ed9de15a92ecf5039c8a", "git_parents": ["13b96b0a06f5082e22c196976072db3957843979"], "node": "c312a56b408fad6102f25f4096d62beb2c4987fd", "parents": ["096d6a8a9f8b3f0f404d532d5e867b602077374a"], "tags": []}], "date": 1770308450, "git_changesets": ["13b96b0a06f5082e22c196976072db3957843979", "fa762422cf6fcb1806a2ed9de15a92ecf5039c8a"], "user": "dmeehan@mozilla.com"}, "24603": {"changesets": [{"author": "Michael Kaply \u003c345868+mkaply@users.noreply.github.com\u003e", "branch": "default", "desc": "Bug 2013938 - Update policies to work correctly with AI kill switch.  a=dmeehan DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D281505\n\nDifferential Revision: https://phabricator.services.mozilla.com/D282020\n", "files": ["browser/components/enterprisepolicies/Policies.sys.mjs", "toolkit/components/pdfjs/content/PdfJsAIFeature.sys.mjs"], "git_node": "30e0b15b14cd5ed0bda5db22a30f329a8bac2dfe", "git_parents": ["fa762422cf6fcb1806a2ed9de15a92ecf5039c8a"], "node": "cca5390e9d30096dd30b1ea05996e69fedc89205", "parents": ["c312a56b408fad6102f25f4096d62beb2c4987fd"], "tags": []}], "date": 1770318717, "git_changesets": ["30e0b15b14cd5ed0bda5db22a30f329a8bac2dfe"], "user": "dmeehan@mozilla.com"}, "24604": {"changesets": [{"author": "canalun \u003ci.am.kanaru.sato@gmail.com\u003e", "branch": "default", "desc": "Bug 2009901 - Fix bound check in intgemm.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D278910\n\nDifferential Revision: https://phabricator.services.mozilla.com/D282002\n", "files": ["js/src/intgemm/IntegerGemmIntrinsic.cpp"], "git_node": "5820f883fd81553d01de4b6849124cbc76bc983b", "git_parents": ["30e0b15b14cd5ed0bda5db22a30f329a8bac2dfe"], "node": "79e1c9cab4b3d5843bc31cf06306751730842c39", "parents": ["cca5390e9d30096dd30b1ea05996e69fedc89205"], "tags": []}], "date": 1770318873, "git_changesets": ["5820f883fd81553d01de4b6849124cbc76bc983b"], "user": "dmeehan@mozilla.com"}, "24605": {"changesets": [{"author": "Aaron Train \u003caaron.train@gmail.com\u003e", "branch": "default", "de