/translations/translations.d.ts"], "git_node": "d67e132d87859c5e65566b093731fd8fa5932162", "git_parents": ["3cdb2ec7a86b2545ce0dcbf9baf5c51d2001a87d"], "node": "2f447970480405da8517750e15be17a03f7ecaa9", "parents": ["0e28b4a7df5cf851635ba908ee6aaad480bb512e"], "tags": []}, {"author": "Greg Tatum \u003ctatum.creative@gmail.com\u003e", "branch": "default", "desc": "Bug 1998228 - Type check StaticEmbeddingsPipeline.mjs  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D271264\n\nDifferential Revision: https://phabricator.services.mozilla.com/D279954\n", "files": ["toolkit/components/ml/content/ModelHub.sys.mjs", "toolkit/components/ml/content/Utils.sys.mjs", "toolkit/components/ml/content/backends/StaticEmbeddingsPipeline.d.ts", "toolkit/components/ml/content/backends/StaticEmbeddingsPipeline.mjs", "toolkit/components/ml/ml.d.ts"], "git_node": "e900f56deb13683d79e3f5608bd60e13d7d3b594", "git_parents": ["d67e132d87859c5e65566b093731fd8fa5932162"], "node": "0249c53474ec509c58b2c12562bead939088fe5e", "parents": ["2f447970480405da8517750e15be17a03f7ecaa9"], "tags": []}, {"author": "Greg Tatum \u003ctatum.creative@gmail.com\u003e", "branch": "default", "desc": "Bug 1998228 - Create mapped types for the Engine run types;  a=dmeehan\n\nThis interface is a bit harder to type since it's so polymorphic, but we\ncan do it with mapped types. This may need a more complicated key than a\nfeature id, but it will do for now.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D277366\n\nDifferential Revision: https://phabricator.services.mozilla.com/D279955\n", "files": ["browser/components/urlbar/private/MLSuggest.sys.mjs", "toolkit/components/ml/actors/MLEngineParent.sys.mjs", "toolkit/components/ml/content/EngineProcess.sys.mjs", "toolkit/components/ml/ml.d.ts"], "git_node": "f780a0324bf85728a909257692fe212f3a742904", "git_parents": ["e900f56deb13683d79e3f5608bd60e13d7d3b594"], "node": "80e27edb35e20359b37e42293b76704e03be71ba", "parents": ["0249c53474ec509c58b2c12562bead939088fe5e"], "tags": []}, {"author": "Aristide Tossou \u003catossou@mozilla.com\u003e", "branch": "default", "desc": "Bug 2010081 - Support Complete ML Engine and Feature Removal.  a=dmeehan\n\nFix db closing\n\nAdditional fixes\n\nmore refinement\n\nFix telemetry\n\nOriginal Revision: https://phabricator.services.mozilla.com/D278846\n\nDifferential Revision: https://phabricator.services.mozilla.com/D279956\n", "files": ["toolkit/components/ml/actors/MLEngineChild.sys.mjs", "toolkit/components/ml/actors/MLEngineParent.sys.mjs", "toolkit/components/ml/content/EngineProcess.sys.mjs", "toolkit/components/ml/content/ModelHub.sys.mjs", "toolkit/components/ml/content/Utils.sys.mjs", "toolkit/components/ml/ml.d.ts", "toolkit/components/ml/tests/browser/browser_ml_cache.js", "toolkit/components/ml/tests/browser/browser_ml_engine_e2e.js", "toolkit/components/ml/tests/browser/browser_ml_telemetry.js", "toolkit/components/ml/tests/browser/browser_ml_utils.js", "toolkit/components/ml/tests/browser/shared-head.js"], "git_node": "4dc870908a2cf2403a491803d9e751519faab8d7", "git_parents": ["f780a0324bf85728a909257692fe212f3a742904"], "node": "52fa6d7f68f754a0cc8be29f8969b95a8e5b0bd4", "parents": ["80e27edb35e20359b37e42293b76704e03be71ba"], "tags": []}, {"author": "Vasish Baungally \u003cvbaungally@mozilla.com\u003e", "branch": "default", "desc": "Bug 2010313 - Add Smart Tab Grouping APIs for Settings.  a=dmeehan\n\nThis patch adds various helper methods for STG to be used for the upcoming AI Killswitch feature.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D278813\n\nDifferential Revision: https://phabricator.services.mozilla.com/D279957\n", "files": ["browser/components/tabbrowser/SmartTabGrouping.sys.mjs", "browser/components/tabbrowser/test/xpcshell/smarttabgrouping/test_settings_utils.js", "browser/components/tabbrowser/test/xpcshell/smarttabgrouping/xpcshell.toml"], "git_node": "7a78217e7cdb04985f3d328fdd55755e463420e9", "git_parents": ["4dc870908a2cf2403a491803d9e751519faab8d7"], "node": "1e32921b719d1ce041759956283820d22a7030cd", "parents": ["52fa6d7f68f754a0cc8be29f8969b95a8e5b0bd4"], "tags": []}, {"author": "Aristide Tossou \u003catossou@mozilla.com\u003e", "branch": "default", "desc": "Bug 2010412 - Support LinkPreview model removal.  a=dmeehan\n\nlink preview fix\n\nlink preview engineid\n\nOriginal Revision: https://phabricator.services.mozilla.com/D279082\n\nDifferential Revision: https://phabricator.services.mozilla.com/D279958\n", "files": ["browser/components/genai/LinkPreview.sys.mjs", "browser/components/genai/LinkPreviewModel.sys.mjs"], "git_node": "4d142795152fa78b1d9b80c793d47d07fe456ae2", "git_parents": ["7a78217e7cdb04985f3d328fdd55755e463420e9"], "node": "d2b2e2bc75eb9dbd45b5b25abd3b25c90e2cb634", "parents": ["1e32921b719d1ce041759956283820d22a7030cd"], "tags": []}, {"author": "Calixte Denizet \u003ccalixte.denizet@gmail.com\u003e", "branch": "default", "desc": "Bug 2009272 - Add some API in order to disable/enable 'guess image alt-text' feature  a=dmeehan\n\nFix pdfjs\n\npdfjs fixes\n\nMore\n\nOriginal Revision: https://phabricator.services.mozilla.com/D279179\n\nDifferential Revision: https://phabricator.services.mozilla.com/D279959\n", "files": ["toolkit/components/pdfjs/content/PdfJsAIFeature.sys.mjs", "toolkit/components/pdfjs/content/PdfjsParent.sys.mjs", "toolkit/components/pdfjs/jar.mn", "toolkit/components/pdfjs/test/browser.toml", "toolkit/components/pdfjs/test/browser_pdfjs_aifeature_settings.js", "toolkit/components/pdfjs/test/browser_pdfjs_check_alttext_en.js"], "git_node": "276e0227ca7706003ea67b3c80fc5f10904da12b", "git_parents": ["4d142795152fa78b1d9b80c793d47d07fe456ae2"], "node": "e32f9d89f4738c8d97e2e7b347289e4b0268022c", "parents": ["d2b2e2bc75eb9dbd45b5b25abd3b25c90e2cb634"], "tags": []}, {"author": "Tim Xia \u003ctxia@mozilla.com\u003e", "branch": "default", "desc": "Bug 2009271 - Implement link preview Key Points model management,  a=dmeehan\n\n- Convert LinkPreview object to LinkPreviewFeature class extending AIFeature\n- Implement required static methods: id, enable, disable, isEnabled, isAllowed\n- Implement model deletion logic with MLUninstallService.uninstall call\n- Add teardown coordination to ensure cleanup completes before re-enabling\n- Add comprehensive AIFeature interface tests\n- move uninstallmodels to disable()\n- fix linter on shared-head.js\n- change class back to object\n- use lazy.LinkPreviewModel.id for id of LinkPreview module\n- fix test failure related to engineID\n\nOriginal Revision: https://phabricator.services.mozilla.com/D279204\n\nDifferential Revision: https://phabricator.services.mozilla.com/D279960\n", "files": ["browser/components/genai/LinkPreview.sys.mjs", "browser/components/genai/tests/browser/browser.toml", "browser/components/genai/tests/browser/browser_link_preview.js", "browser/components/genai/tests/browser/browser_link_preview_aifeature_lifecycle.js", "toolkit/components/ml/AIFeature.sys.mjs"], "git_node": "fecb72c82def6b7ed98453dbf8c5c21866c7f905", "git_parents": ["276e0227ca7706003ea67b3c80fc5f10904da12b"], "node": "780eb2cfbe0c964928b92ad89bb48284f735a420", "parents": ["e32f9d89f4738c8d97e2e7b347289e4b0268022c"], "tags": []}], "date": 1769116207, "git_changesets": ["816311ada2c416d9dec54a32324302a5f15526a4", "3cdb2ec7a86b2545ce0dcbf9baf5c51d2001a87d", "d67e132d87859c5e65566b093731fd8fa5932162", "e900f56deb13683d79e3f5608bd60e13d7d3b594", "f780a0324bf85728a909257692fe212f3a742904", "4dc870908a2cf2403a491803d9e751519faab8d7", "7a78217e7cdb04985f3d328fdd55755e463420e9", "4d142795152fa78b1d9b80c793d47d07fe456ae2", "276e0227ca7706003ea67b3c80fc5f10904da12b", "fecb72c82def6b7ed98453dbf8c5c21866c7f905"], "user": "dmeehan@mozilla.com"}, "24430": {"changesets": [{"author": "Simon Farre \u003csimon.farre.cx@gmail.com\u003e", "branch": "default", "desc": "Bug 2009144 - Allow Navigation API to navigate sandboxed frames sometimes  a=dmeehan\n\nUse the correct source document, from which we create source snapshot\nparams, so that step 6.2 in https://html.spec.whatwg.org/#navigate,\nwhich calls \"allowed by sandboxing to navigate\" get the correct input.\n\nThis makes the two tests referenced in this commit pass.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D278268\n\nDifferential Revision: https://phabricator.services.mozilla.com/D280097\n", "files": ["docshell/base/BrowsingContext.cpp", "testing/web-platform/meta/navigation-api/navigation-methods/sandboxing-navigate-parent.html.ini", "testing/web-platform/meta/navigation-api/navigation-methods/sandboxing-navigate-sibling.html.ini"], "git_node": "76bae29ade18cb2b6426035e4044b80b4d068c07", "git_parents": ["fecb72c82def6b7ed98453dbf8c5c21866c7f905"], "node": "b03ef6821ff5dd1b042a5277206fdd2f66546498", "parents": ["780eb2cfbe0c964928b92ad89bb48284f735a420"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1951791 - Use container's writing mode when ResolvedAscent needs to synthesize baseline offset for an orthogonal flex item.  a=dmeehan\n\nAlso rename the writing mode param of SynthesizeBOffsetFromInnerBox\nfrom aWM to aCBWM to make it clearer that it should be the writing\nmode of the containing block, not the inner frame.\n\nThis fixes the incorrectly-synthesized flex-item baseline in\ngrid-baseline-001-ref.html, which was causing the test to show\na spurious failure.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D279229\n\nDifferential Revision: https://phabricator.services.mozilla.com/D280098\n", "files": ["layout/base/Baseline.cpp", "layout/generic/nsFlexContainerFrame.cpp", "testing/web-platform/meta/css/css-grid/alignment/grid-baseline-001.html.ini"], "git_node": "53b151caa759b851223e71031b8521693dad6e74", "git_parents": ["76bae29ade18cb2b6426035e4044b80b4d068c07"], "node": "cffa21c38c8c593c03de1ae612e0fb9dfbe16a14", "parents": ["b03ef6821ff5dd1b042a5277206fdd2f66546498"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1866930 - Swap logical axes when inheriting line names in an orthogonal subgrid.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D279143\n\nDifferential Revision: https://phabricator.services.mozilla.com/D280099\n", "files": ["layout/generic/nsGridContainerFrame.cpp", "testing/web-platform/meta/css/css-grid/subgrid/orthogonal-writing-mode-005.html.ini"], "git_node": "3e9aa1b9dab907514ea9e9abcd0625b1cc310ebd", "git_parents": ["53b151caa759b851223e71031b8521693dad6e74"], "node": "def0f7b699f25a7f387c87a44991bd46a022f459", "parents": ["cffa21c38c8c593c03de1ae612e0fb9dfbe16a14"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2009424 - Make containing block adjustment work for default anchored frames.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D278497\n\nDifferential Revision: https://phabricator.services.mozilla.com/D280100\n", "files": ["layout/generic/AbsoluteContainingBlock.cpp", "testing/web-platform/meta/css/css-anchor-position/anchor-scroll-position-try-006.html.ini", "testing/web-platform/meta/css/css-anchor-position/anchor-scroll-position-try-007.html.ini", "testing/web-platform/meta/css/css-anchor-position/anchor-scroll-position-try-009.html.ini", "testing/web-platform/meta/css/css-anchor-position/anchor-scroll-position-try-010.html.ini"], "git_node": "b14f9803ee4c3f249ea5d99bb211f1f74a12666e", "git_parents": ["3e9aa1b9dab907514ea9e9abcd0625b1cc310ebd"], "node": "e4989aa589c7082be6f150ac3fb8369a54d0bfaa", "parents": ["def0f7b699f25a7f387c87a44991bd46a022f459"], "tags": []}, {"author": "David Shin \u003cdshin@mozilla.com\u003e", "branch": "default", "desc": "Bug 2009225: Only contribute scroll-shifted overflow of anchor positioned elements.  a=dmeehan\n\nPreviously contributed an additional overflow with normal position, which was\nthe positioned element's overflow when all scrollers are at their initial\npositions.\n\nUse `OverflowChangedTracker` to properly propagate overflow changes up the\nancestor chain.\n\nWithout anchor recalculation points, this change causes the scroller to\nfluctuate as the positioned element moves around.\n\nAdjust `position-visibility-no-overflow-scroll-002.html` - In this case,\ndue to the double rAF, positioned elements are evaluated with the scrollers\nat its initial position. However, in this configuration, the computed position\narea grid for `#target1` does not leave enough space to fit the element, so it\nshifts up into fit within the containing block [1]. However, the test's\nreference does not seem to expect this shifting behaviour. Prior to this patch,\nGecko would contribute the unscrolled overflow's space to expand the position\narea grid, which made us pass this test (But this behaviour is not in spec).\n\nSo, change the test to force the computation of position-area grid to be after\nscrolling, which still should preserve the purpose of the test. `anchor()`\nfunctions could be used instead, but that's covered by\nposition-visibility-no-overflow-scroll.html.\n\n[1]: https://drafts.csswg.org/css-anchor-position-1/#position-area-alignment\n\nCo-authored-by: Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e\n\nOriginal Revision: https://phabricator.services.mozilla.com/D278989\n\nDifferential Revision: https://phabricator.services.mozilla.com/D280101\n", "files": ["layout/base/PresShell.cpp", "layout/generic/AbsoluteContainingBlock.cpp", "layout/generic/nsIFrame.cpp", "testing/web-platform/meta/css/css-anchor-position/anchor-scroll-chained-002.html.ini", "testing/web-platform/meta/css/css-anchor-position/anchor-scroll-chained-004.html.ini", "testing/web-platform/tests/css/css-anchor-position/position-visibility-no-overflow-scroll-002.html"], "git_node": "967fdeff57d111cccc9a2237132a42143a5f07de", "git_parents": ["b14f9803ee4c3f249ea5d99bb211f1f74a12666e"], "node": "a885d40d81296db36a983317a8fac588383c6d98", "parents": ["e4989aa589c7082be6f150ac3fb8369a54d0bfaa"], "tags": []}], "date": 1769122524, "git_changesets": ["76bae29ade18cb2b6426035e4044b80b4d068c07", "53b151caa759b851223e71031b8521693dad6e74", "3e9aa1b9dab907514ea9e9abcd0625b1cc310ebd", "b14f9803ee4c3f249ea5d99bb211f1f74a12666e", "967fdeff57d111cccc9a2237132a42143a5f07de"], "user": "dmeehan@mozilla.com"}, "24431": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Import translations from main\n", "files": ["mobile/android/android-components/components/compose/awesomebar/src/main/res/values-hr/strings.xml", "mobile/android/android-components/components/compose/awesomebar/src/main/res/values-ml/strings.xml", "mobile/android/android-components/components/compose/browser-toolbar/src/main/res/values-es-rAR/strings.xml", "mobile/android/fenix/app/src/main/res/values-bqi/strings.xml", "mobile/android/fenix/app/src/main/res/values-es-rAR/strings.xml", "mobile/android/fenix/app/src/main/res/values-es-rCL/strings.xml", "mobile/android/fenix/app/src/main/res/values-hr/strings.xml", "mobile/android/fenix/app/src/main/res/values-in/strings.xml", "mobile/android/fenix/app/src/main/res/values-ml/strings.xml", "mobile/android/fenix/app/src/main/res/values-ug/strings.xml"], "git_node": "d0ccbd80887f684a3a6cbc16f65c0ed67fface00", "git_parents": ["967fdeff57d111cccc9a2237132a42143a5f07de"], "node": "81efbbe8eec4c323a7ead3124d654028932ef426", "parents": ["a885d40d81296db36a983317a8fac588383c6d98"], "tags": []}], "date": 1769134434, "git_changesets": ["d0ccbd80887f684a3a6cbc16f65c0ed67fface00"], "user": "ffxbld@lando.moz.tools"}, "24432": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Bumping Firefox l10n changesets r=release a=l10n-bump\n\nach -\u003e 098df70fec0490b59f69b4a096aea3848c2dd5b9\naf -\u003e 098df70fe