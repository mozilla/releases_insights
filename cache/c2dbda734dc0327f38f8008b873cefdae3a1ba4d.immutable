m"}, "24366": {"changesets": [{"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 2008912 - New checks for synced contexts, r=smaug a=dmeehan\n\nDifferential Revision: https://phabricator.services.mozilla.com/D278703\n", "files": ["docshell/base/BrowsingContext.cpp", "docshell/base/BrowsingContextGroup.cpp", "docshell/base/BrowsingContextGroup.h", "docshell/base/WindowContext.cpp"], "git_node": "a4c078ce8d211f924b281ba9b84915f61d140653", "git_parents": ["98b75ff7d4fb06d6c1359059b0f71b77652c130c"], "node": "ed507a93ac2b5c95abbc541cd3475eda93a7397b", "parents": ["499d6fa952928905be4a530c9fc9b3aac01510f4"], "tags": []}], "date": 1768595790, "git_changesets": ["a4c078ce8d211f924b281ba9b84915f61d140653"], "user": "dmeehan@mozilla.com"}, "24367": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Import translations from main\n", "files": ["mobile/android/android-components/components/compose/awesomebar/src/main/res/values-bg/strings.xml", "mobile/android/android-components/components/compose/awesomebar/src/main/res/values-cy/strings.xml", "mobile/android/android-components/components/compose/awesomebar/src/main/res/values-de/strings.xml", "mobile/android/android-components/components/compose/awesomebar/src/main/res/values-dsb/strings.xml", "mobile/android/android-components/components/compose/awesomebar/src/main/res/values-en-rGB/strings.xml", "mobile/android/android-components/components/compose/awesomebar/src/main/res/values-es-rAR/strings.xml", "mobile/android/android-components/components/compose/awesomebar/src/main/res/values-fr/strings.xml", "mobile/android/android-components/components/compose/awesomebar/src/main/res/values-fy-rNL/strings.xml", "mobile/android/android-components/components/compose/awesomebar/src/main/res/values-gl/strings.xml", "mobile/android/android-components/components/compose/awesomebar/src/main/res/values-hs