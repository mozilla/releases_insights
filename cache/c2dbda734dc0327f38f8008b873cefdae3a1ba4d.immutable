3e 5d8b7c20d9f9213e54c0e63eb5d97da50875a11a\nth -\u003e 5d8b7c20d9f9213e54c0e63eb5d97da50875a11a\ntl -\u003e 5d8b7c20d9f9213e54c0e63eb5d97da50875a11a\ntr -\u003e 5d8b7c20d9f9213e54c0e63eb5d97da50875a11a\ntrs -\u003e 5d8b7c20d9f9213e54c0e63eb5d97da50875a11a\nuk -\u003e 5d8b7c20d9f9213e54c0e63eb5d97da50875a11a\nur -\u003e 5d8b7c20d9f9213e54c0e63eb5d97da50875a11a\nuz -\u003e 5d8b7c20d9f9213e54c0e63eb5d97da50875a11a\nvi -\u003e 5d8b7c20d9f9213e54c0e63eb5d97da50875a11a\nwo -\u003e 5d8b7c20d9f9213e54c0e63eb5d97da50875a11a\nxh -\u003e 5d8b7c20d9f9213e54c0e63eb5d97da50875a11a\nzam -\u003e 5d8b7c20d9f9213e54c0e63eb5d97da50875a11a\nzh-CN -\u003e 5d8b7c20d9f9213e54c0e63eb5d97da50875a11a\nzh-TW -\u003e 5d8b7c20d9f9213e54c0e63eb5d97da50875a11a\n", "files": ["mobile/locales/l10n-changesets.json"], "git_node": "a2bf3038e3856ba532caa146d31a22a1d3a29bd8", "git_parents": ["fc65856c5bbe13608d8a748d6e1acce75894fa81"], "node": "5e4d6cdc98a99e640153deb4107620a9872c0216", "parents": ["5e3872fe0deba817949ccd17c187c7776a324a45"], "tags": []}], "date": 1771059820, "git_changesets": ["fc65856c5bbe13608d8a748d6e1acce75894fa81", "a2bf3038e3856ba532caa146d31a22a1d3a29bd8"], "user": "ffxbld@lando.moz.tools"}, "24720": {"changesets": [{"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1164141 - Handle SIGBUS when fd-\u003emMap is null  a=dmeehan DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D282765\n\nDifferential Revision: https://phabricator.services.mozilla.com/D283372\n", "files": ["mozglue/misc/MmapFaultHandler.cpp", "mozglue/misc/MmapFaultHandler.h"], "git_node": "6e98908d40b8f518f24adf601f0b9aab029c8c2d", "git_parents": ["a2bf3038e3856ba532caa146d31a22a1d3a29bd8"], "node": "84e329bada04a31ca00b8bc5e605427c34259f33", "parents": ["5e4d6cdc98a99e640153deb4107620a9872c0216"], "tags": []}], "date": 1771060931, "git_changesets": ["6e98908d40b8f518f24adf601f0b9aab029c8c2d"], "user": "dmeehan@mozilla.com"}, "24721": {"changesets": [{"author": "Paul Adenot \u003cpaul@paul.cx\u003e", "branch": "default", "desc": "Bug 2014883.  a=dmeehan DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D282414\n\nDifferential Revision: https://phabricator.services.mozilla.com/D283301\n", "files": ["dom/media/webm/WebMDemuxer.cpp"], "git_node": "833b1a19eb8885fc086b246f96d9253818aa5151", "git_parents": ["6e98908d40b8f518f24adf601f0b9aab029c8c2d"], "node": "5f066844155227efb1a8d8b37b4886702e129c8e", "parents": ["84e329bada04a31ca00b8bc5e605427c34259f33"], "tags": []}], "date": 1771062498, "git_changesets": ["833b1a19eb8885fc086b246f96d9253818aa5151"], "user": "dmeehan@mozilla.com"}, "24722": {"changesets": [{"author": "Paul Adenot \u003cpaul@paul.cx\u003e", "branch": "default", "desc": "Bug 2014832 -  a=dmeehan DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D282171\n\nDifferential Revision: https://phabricator.services.mozilla.com/D283305\n", "files": ["dom/media/webaudio/MediaBufferDecoder.cpp"], "git_node": "2f7c633b0e64e64a70edea4904ee1684f0a87f99", "git_parents": ["833b1a19eb8885fc086b246f96d9253818aa5151"], "node": "0d59ba36e81e8ef2af24958733f5fbb6a2dbeb22", "parents": ["5f066844155227efb1a8d8b37b4886702e129c8e"], "tags": []}], "date": 1771062663, "git_changesets": ["2f7c633b0e64e64a70edea4904ee1684f0a87f99"], "user": "dmeehan@mozilla.com"}, "24723": {"changesets": [{"author": "Harveer Singh \u003chsingh@mozilla.com\u003e", "branch": "default", "desc": "Bug 2014550: Reset FileInfoEntry::mSavepointDelta after the rollback.  a=dmeehan DONTBUILD\n\nThis bug exposes an edge case with IDB blob file ref-counting. `FileInfo` manages the blob file at runtime and contains the logic for on-disk file management. It does so by maintaining both an in-memory ref-count and a DB ref-count. `FileInfoEntry` manages the DB ref-counting side of things during an active transaction and pushes the effective delta to the DB ref-count after the transaction commits (via `FileInfoEntry::MaybeUpdateDBRefs`), i.e., at the end of the transaction's lifetime.\n\nThe test case in question (as attached to the bug) opens an IDB database and stores 3 records that each reference the same blob, giving the underlying blob file a DB ref-count of 3. It then starts a new read-write transaction and attempts to add 3 more records that intentionally violate a unique index constraint. Each failed `add()` raises a `ConstraintError`, and the error handler calls `e.preventDefault()` to keep the transaction alive rather than allowing it to abort. Internally, each individual IDB operation runs inside a Auotsavepoint. When an operation fails, the savepoint is rolled back, but the transaction itself continues normally to the next operation.\n\n`FileInfoEntry` has two fields for tracking ref-count changes: `mDelta` and `mSavepointDelta`. `mDelta` accumulates the total ref-count change for the entire transaction and is the value that ultimately gets applied to `FileInfo`'s DB ref-count at commit time. `mSavepointDelta` tracks the ref-count changes made within the current savepoint, so that if the savepoint is rolled back, those changes can be subtracted from `mDelta` to restore it to its pre-savepoint value.\n\nThe issue is that even though we are calculating mDelta after every rollback but it's not correct as the mSavepointDelta was never reset after the rollback and on the next rollback attempt, it would still has the stale value from the last savepoint.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D282624\n\nDifferential Revision: https://phabricator.services.mozilla.com/D283294\n", "files": ["dom/indexedDB/ActorsParent.cpp"], "git_node": "2f212fe9e0db790593194cb075c2a20dd115214c", "git_parents": ["2f7c633b0e64e64a70edea4904ee1684f0a87f99"], "node": "cea5080d009802ca346fec06161d0af3291e9c80", "parents": ["0d59ba36e81e8ef2af24958733f5fbb6a2dbeb22"], "tags": []}], "date": 1771062728, "git_changesets": ["2f212fe9e0db790593194cb075c2a20dd115214c"], "us