ager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/blocklists/addons.json"], "git_node": null, "git_parents": [null], "node": "8c503b7c7ebe8afcabb8fec0f0870ccc170e3282", "parents": ["cc418f03e3199d2cc5b1ec5ad1e6e0123732db72"], "tags": []}, {"author": "Lars T Hansen \u003clhansen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1524692 - Additional ARM register constraints for 64-bit wasm atomics. r=nbp, a=lizzard\n\nThe 64-bit wasm atomic ops have particularly stringent register\nconstraints on many platforms.  These constraints were not expressed\nwell at the lowering stage, and in the case of cmpxchg and rmw on ARM\na constraint that the input value must be in registers distinct from\nother values and the output was missing; gvn would therefore be\nallowed to common values that should have been considered distinct.", "files": ["js/src/jit/arm/Assembler-arm.h", "js/src/jit/arm/Lowering-arm.cpp"], "git_node": null, "git_parents": [null], "node": "909f45bf0ed36b79e7f8dc4e8583458341950586", "parents": ["8c503b7c7ebe8afcabb8fec0f0870ccc170e3282"], "tags": []}, {"author": "Tooru Fujisawa \u003carai_a@mac.com\u003e", "branch": "default", "desc": "Bug 1524755 - Use ptrdiff_t instead in RangedPtr. r=jwalden, a=RyanVM", "files": ["mfbt/RangedPtr.h"], "git_node": null, "git_parents": [null], "node": "2b77d6958f310d832164971626a3686d8826cd40", "parents": ["909f45bf0ed36b79e7f8dc4e8583458341950586"], "tags": []}, {"author": "Dragana Damjanovic \u003cdd.mozilla@gmail.com\u003e", "branch": "default", "desc": "Bug 1520483 - Return proper error if the nss layer encounters an error on the http tunnel. r=valentin,kershaw, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17952", "files": ["netwerk/protocol/http/TunnelUtils.cpp", "netwerk/protocol/http/TunnelUtils.h", "netwerk/protocol/http/nsHttpConnection.cpp"], "git_node": null, "git_parents": [null], "node": "81b95ee7a2f3a2e09ac4428bafe6957f5942781a", "