"node": "6ccd730174ffc3433f50aad28b540da0f58f9357", "parents": ["41ac42ce006f22502c0498fffaf6228c36a424d2"], "tags": []}, {"author": "Rob Lemley \u003crob@thunderbird.net\u003e", "branch": "default", "desc": "Bug 1517298 - Add comm mozharness configs to mozharness test archive. r=firefox-build-system-reviewers,mshal\n\nFirst step in moving Thunderbird mozharness unittest configurations out of\nM-C. This merges the comm/mozharness directory into the mozharness test\narchive's mozharness/configs/ so that the comm config files can be accessed\nlater by desktop_unittest.py. This inclusion is conditional and will only happen\nwhen building Thunderbird; there are no changes to the mozharness.zip file when\nbuilding Firefox.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16374", "files": ["python/mozbuild/mozbuild/action/test_archive.py"], "git_node": null, "git_parents": [null], "node": "8431bedf934c736cea962c692006ddcf0901eab0", "parents": ["6ccd730174ffc3433f50aad28b540da0f58f9357"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1516228 - Add a configure check for llvm-objdump. r=firefox-build-system-reviewers,mshal\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17462", "files": ["build/moz.configure/init.configure", "moz.configure"], "git_node": null, "git_parents": [null], "node": "8456feb780f7a4b44dc879268e6390aa4f4ce0b1", "parents": ["8431bedf934c736cea962c692006ddcf0901eab0"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1516228 - Use llvm-objdump instead of objdump in old-configure. r=firefox-build-system-reviewers,mshal\n\nDepends on D17462\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17463", "files": ["build/autoconf/compiler-opts.m4", "moz.configure"], "git_node": null, "git_parents": [null], "node": "09ee05a4cc30121554f352e9e98d818deb9f8407", "parents": ["8456feb780f7a4b44dc879268e6390aa4f4ce0b1"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1516228 - Use llvm-objdump exclusively for windows in dependentlibs.py. r=firefox-build-system-reviewers,mshal\n\nDepends on D17463\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17464", "files": ["toolkit/library/dependentlibs.py"], "git_node": null, "git_parents": [null], "node": "2e6bec87c9f38d8621c9fbf5b2099df2c6558ddb", "parents": ["09ee05a4cc30121554f352e9e98d818deb9f8407"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1516228 - Use llvm-objdump for mac in dependentlibs.py, too. r=firefox-build-system-reviewers,mshal\n\nDepends on D17464\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17465", "files": ["toolkit/library/dependentlibs.py"], "git_node": null, "git_parents": [null], "node": "4f53ede3351741395c132fbbcfb03a06926b7113", "parents": ["2e6bec87c9f38d8621c9fbf5b2099df2c6558ddb"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1516228 - Use llvm-objdump for ELF in dependentlibs.py, too. r=firefox-build-system-reviewers,mshal\n\nDepends on D17465\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17466", "files": ["toolkit/library/dependentlibs.py"], "git_node": null, "git_parents": [null], "node": "53d93ee3ad847b03120d3159e2b8b2caace7a370", "parents": ["4f53ede3351741395c132fbbcfb03a06926b7113"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1516228 - Use llvm-objdump for symbol related tests in check_binary.py. r=firefox-build-system-reviewers,mshal\n\nDepends on D17466\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17467", "files": ["python/mozbuild/mozbuild/action/check_binary.py"], "git_node": null, "git_parents": [null], "node": "24ebb52d21fa602df6aa29c88921c0b8b487bf5c", "parents": ["53d93ee3ad847b03120d3159e2b8b2caace7a370"], "tags": []}, {"author": "Daniel Holbert \u003cdholbert@cs.stanford.edu\u003e", "branch": "default", "desc": "Bug 1522208: Clean up nsCOMPtr.h includes in dom/svg. r=longsonr\n\nA lot of files include nsCOMPtr without really needing it in dom/svg. (And a\nfew files use the nsCOMPtr type without including its header.)\n\nFor this patch, I found candidate files by just searching for files that only\nhad a single line that contained \"nsCOMPtr\", and I took the following actions:\n - If the match is an #include, then remove it (replacing it with the include\n   for RefPtr or AlreadyAddrefed if the file uses those types instead).\n - If the match is a usage of the type, then add an #include for nsCOMPtr (as\n   well as one for RefPtr, if the file uses that type).\n\n(And in a few cases, I moved an adjacent #include, to get the #include list\ncloser to sortedness.)\n\nI verified that the dom/svg directory continues to build successfully in\nnon-unified mode (i.e. if I remove UNIFIED_ from its moz.build file).  So, I'm\nnot removing any includes that files are now inadvertantly leaning on other\ncompilation units to provide.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17422", "files": ["dom/svg/DOMSVGAnimatedLengthList.cpp", "dom/svg/DOMSVGAnimatedLengthList.h", "dom/svg/DOMSVGAnimatedNumberList.cpp", "dom/svg/DOMSVGAnimatedNumberList.h", "dom/svg/DOMSVGAnimatedTransformList.h", "dom/svg/DOMSVGNumber.h", "dom/svg/DOMSVGNumberList.cpp", "dom/svg/DOMSVGNumberList.h", "dom/svg/DOMSVGPathSegList.cpp", "dom/svg/DOMSVGPathSegList.h", "dom/svg/DOMSVGPoint.cpp", "dom/svg/DOMSVGPointList.h", "dom/svg/DOMSVGStringList.h", "dom/svg/SVGAngle.h", "dom/svg/SVGBoolean.h", "dom/svg/SVGElement.h", "dom/svg/SVGFilterElement.cpp", "dom/svg/SVGForeignObjectElement.cpp", "dom/svg/SVGGeometryElement.cpp", "dom/svg/SVGGradientElement.cpp", "dom/svg/SVGMarkerElement.cpp", "dom/svg/SVGMaskElement.cpp", "dom/svg/SVGPathElement.cpp", "dom/svg/SVGPatternElement.cpp", "dom/svg/SVGRect.h", "dom/svg/SVGScriptElement.h", "dom/svg/SVGStyleElement.cpp", "dom/svg/SVGSwitchElement.h", "dom/svg/SVGTests.h", "dom/svg/SVGUseElement.h", "dom/svg/SVGViewportElement.cpp"], "git_node": null, "git_parents": [null], "node": "62d37f1cbdbd2d579414d36e6c9284ecfd8063cb", "parents": ["24ebb52d21fa602df6aa29c88921c0b8b487bf5c"], "tags": []}, {"author": "Jeff Gilbert \u003cjgilbert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1521992 - Fix incomplete-fb error for webgl.getParameter. r=lsalzman\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17306", "files": ["dom/canvas/WebGLContext.cpp", "dom/canvas/WebGLContext.h", "dom/canvas/WebGLContextState.cpp", "dom/canvas/WebGLContextUtils.cpp", "dom/canvas/WebGLFramebuffer.cpp", "dom/canvas/WebGLFramebuffer.h"], "git_node": null, "git_parents": [null], "node": "4b17b7e5bd5a582ddb9d1b9e1bb1ed56d41d3cc2", "parents": ["62d37f1cbdbd2d579414d36e6c9284ecfd8063cb"], "tags": []}, {"author": "Glenn Watson \u003cgithub@intuitionlibrary.com\u003e", "branch": "default", "desc": "Bug 1522395 - Fix double inflation of text shadow bounds. r=kvark\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17468", "files": ["gfx/wr/webrender/src/display_list_flattener.rs", "gfx/wr/webrender/src/picture.rs", "gfx/wr/webrender_api/src/display_item.rs", "gfx/wr/wrench/reftests/text/shadow-transforms.png", "gfx/wr/wrench/src/rawtest.rs", "gfx/wr/wrench/src/yaml_frame_reader.rs", "layout/base/nsLayoutUtils.cpp", "layout/generic/nsTextFrame.cpp", "layout/reftests/text-overflow/reftest.list"], "git_node": null, "git_parents": [null], "node": "63049c1db4fc9be3bfd673920dfa1a801da7a56d", "parents": ["4b17b7e5bd5a582ddb9d1b9e1bb1ed56d41d3cc2"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1315829 - Re-enable test_ext_runtime_onInstalled_and_onStartup.js r=aswan\n\nDifferential Revision