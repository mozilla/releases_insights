3f314b322edfd1ce11a19416dcb78bbf67fb", "parents": ["5bd55cb9bdd7fd6bf946ab6694c16fab4b053e66"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1519095 - Allow changing the text of an existing notification. r=jaws a=lizzard\n\nThis fixes the notification bar that shows how many popup windows have been blocked.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17152", "files": ["browser/base/content/test/popups/browser_popup_blocker.js", "toolkit/content/widgets/notificationbox.js"], "git_node": null, "git_parents": [null], "node": "f965e1e246ea02ca771fbca870717c51fb83ed1e", "parents": ["5da23f314b322edfd1ce11a19416dcb78bbf67fb"], "tags": []}, {"author": "Akshay Kumar \u003cakshay.sonu@gmail.com\u003e", "branch": "default", "desc": "Bug 1522077 - Crash using FIDO U2F on Windows 10 insider build 1100+ r=keeler a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D18756", "files": ["dom/webauthn/WinWebAuthnManager.cpp"], "git_node": null, "git_parents": [null], "node": "59b12aa8fa46fad2911c433412013364350682cf", "parents": ["f965e1e246ea02ca771fbca870717c51fb83ed1e"], "tags": []}, {"author": "Mark Hammond \u003cmhammond@skippinet.com.au\u003e", "branch": "default", "desc": "Bug 1522381 - don't rely on Services.startup.getStartupInfo().main for telemetry session start. r=tcsc a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D19098", "files": ["services/sync/modules/telemetry.js"], "git_node": null, "git_parents": [null], "node": "401c1404f3b02496738992409eb2710944c7b25c", "parents": ["59b12aa8fa46fad2911c433412013364350682cf"], "tags": []}], "date": 1550105295, "git_changesets": [null, null, null, null], "user": "nbeleuzu@mozilla.com"}, "10697": {"changesets": [{"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1522839 - Cache permanentKey in case it changes during navigateAndRestore. r=qdot a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D19402", "files": ["browser/components/sessionstore/SessionStore.jsm"], "git_node": null, "git_parents": [null], "node": "a5083352550a76554d07a493a477fdca2c9733fc", "parents": ["401c1404f3b02496738992409eb2710944c7b25c"], "tags": []}, {"author": "Daniel Holbert \u003cdholbert@cs.stanford.edu\u003e", "branch": "default", "desc": "Bug 1522898: Account for box-sizing (add border & padding) when setting a main-size property value override on a flex item (which it uses for aspect ratio calculations). r=mats a=lizzard\n\nFor elements that have box-sizing:border-box specified, the aspect ratio\ncalculation code subtracts out border & padding from any specified property\nvalues.\n\nSo, when we create a fake \"override\" specified property value for a flex item\nwhose main size has been resolved, we need to add in the border and padding to\naccount for the fact that they're going to be subtracted out later.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17712", "files": ["layout/generic/nsFlexContainerFrame.cpp", "layout/reftests/w3c-css/submitted/flexbox/flexbox-intrinsic-ratio-007-ref.html", "layout/reftests/w3c-css/submitted/flexbox/flexbox-intrinsic-ratio-007.html", "layout/reftests/w3c-css/submitted/flexbox/flexbox-intrinsic-ratio-007v.html", "layout/reftests/w3c-css/submitted/flexbox/reftest.list"], "git_node": null, "git_parents": [null], "node": "2af5915230367200773998d200ccde66772fc901", "parents": ["a5083352550a76554d07a493a477fdca2c9733fc"], "tags": []}, {"author": "Haik Aftandilian \u003chaftandilian@mozilla.com\u003e", "branch": "default", "desc": "Bug 1525625 - [Mac] Flash plugin can not save settings r=Alex_Gaynor a=lizzard\n\nAllow file-write-unlink in ~/Library/Preferences/Macromedia/Flash Player to allow changes made in the Flash Global Settings panel to persist.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D19217", "files": ["security/sandbox/mac/SandboxPolicies.h"], "git_node": null, "git_parents": [null], "node": "cea43c1728b90b48d131016636df357f7883522d", "parents": ["2af5915230367200773998d200ccde66772fc901"], "tags": []}, {"author": "Glenn Watson \u003cgithub@intuitionlibrary.com\u003e", "branch": "default", "desc": "Bug 1526504 - border-style is not drawn with double r=emilio a=lizzard\n\nThe WR double style border shader has a condition to check if the\nwidths of the edges are too small to apply the style, in which case\nit draws the border segment as solid. However, the check was\nincorrectly skipping when the width of the inner / outer edge\nwas exactly one pixel.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D19440", "files": ["gfx/wr/webrender/res/cs_border_segment.glsl", "gfx/wr/wrench/reftests/border/border-double-1px-ref.yaml", "gfx/wr/wrench/reftests/border/border-double-1px.yaml", "gfx/wr/wrench/reftests/border/reftest.list"], "git_node": null, "git_parents": [null], "node": "ad3595c3b64e5a35ae3902000da04d04158decd6", "parents": ["cea43c1728b90b48d131016636df357f7883522d"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1526793 - always prompt for restart when toggling permanent private browsing mode, r=jaws a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D19313", "files": ["browser/components/preferences/in-content/privacy.js", "browser/components/preferences/in-content/tests/browser.ini", "browser/components/preferences/in-content/tests/browser_warning_permanent_private_browsing.js"], "git_node": null, "git_parents": [null], "node": "f47db91d62e1bac39e1e6ba658dd10f64bdc232d", "parents": ["ad3595c3b64e5a35ae3902000da04d04158decd6"], "tags": []}], "date": 1550107542, "git_changesets": [null, null, null, null, null], "user": "nbeleuzu@mozilla.com"}, "10698": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc