5add3d0"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1522555 - Tweak a bit the fuzzy range of border-suite-2 since automation generates a slightly different image. r=bustage a=Aryx", "files": ["gfx/wr/wrench/reftests/border/reftest.list"], "git_node": null, "git_parents": [null], "node": "cdb9aa894138d831002974b80e7d7dbb6efcc0ba", "parents": ["fa81629b009aebec457ef311088aa0508976be4e"], "tags": []}, {"author": "Lars T Hansen \u003clhansen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1521780 - Rename memory.drop and table.drop.  r=jseward\n\nStraight renaming job, no functional changes anywhere, except that the text of some\nerror messages changed slightly.", "files": ["js/src/jit-test/tests/wasm/passive-segs-boundary.js", "js/src/jit-test/tests/wasm/passive-segs-nonboundary.js", "js/src/wasm/WasmAST.h", "js/src/wasm/WasmBaselineCompile.cpp", "js/src/wasm/WasmBuiltins.cpp", "js/src/wasm/WasmConstants.h", "js/src/wasm/WasmFrameIter.cpp", "js/src/wasm/WasmInstance.cpp", "js/src/wasm/WasmInstance.h", "js/src/wasm/WasmIonCompile.cpp", "js/src/wasm/WasmOpIter.cpp", "js/src/wasm/WasmOpIter.h", "js/src/wasm/WasmTextToBinary.cpp", "js/src/wasm/WasmTypes.h", "js/src/wasm/WasmValidate.cpp"], "git_node": null, "git_parents": [null], "node": "7b9d92a7c779fbbcdb481760bb946910186eef80", "parents": ["cdb9aa894138d831002974b80e7d7dbb6efcc0ba"], "tags": []}, {"author": "Lars T Hansen \u003clhansen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1522081 - Update instruction encodings for memory.init / table.init. r=jseward\n\nThe new encodings for these have the segment prefix preceding the\nindex of the target table / memory, and there is no flag field - the\nindices are present unconditionally.\n\nAlso do not call \"targetTable()\" on AstMemOrTableInit if the entity\nbeing held is a memory.", "files": ["js/src/wasm/WasmAST.h", "js/src/wasm/WasmOpIter.h", "js/src/wasm/WasmTextToBinary.cpp"], "git_node": null, "git_parents": [null], "node": "f632c68b2052a051634bc6780b3b0e3e5c2dd973", "parents": ["7b9d92a7c779fbbcdb481760bb946910186eef80"], "tags": []}, {"author": "Lars T Hansen \u003clhansen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1522082 - make encoding of memory.fill standard-compliant.  r=jseward", "files": ["js/src/wasm/WasmOpIter.h", "js/src/wasm/WasmTextToBinary.cpp"], "git_node": null, "git_parents": [null], "node": "38a05200341417ac22705ad7c309ddd33b2ff6f8", "parents": ["f632c68b2052a051634bc6780b3b0e3e5c2dd973"], "tags": []}, {"author": "Lars T Hansen \u003clhansen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1513499 - Update encodings for table.copy and memory.copy.  r=jseward", "files": ["js/src/jit-test/tests/wasm/passive-segs-nonboundary.js", "js/src/wasm/WasmAST.h", "js/src/wasm/WasmOpIter.h", "js/src/wasm/WasmTextToBinary.cpp"], "git_node": null, "git_parents": [null], "node": "5e914b7f1c0961f2707fc8c5694c9b0fa014dd58", "parents": ["38a05200341417ac22705ad7c309ddd33b2ff6f8"], "tags": []}, {"author": "Lars T Hansen \u003clhansen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1502035 - DataCount section. r=luke\n\nWe now require the presence of a DataCount section to forward-declare\nthe number of data segments if the code uses memory.init or data.drop.\nThose instructions may only reference segments in the range\n[0..dataCount-1].\n\nIf there is a DataCount section then the number of forward-declared\nsegments must match the actual count of segments.\n\nWe no longer need the deferred validation state, so we can remove it.\nThat's pretty mechanical and comprises the bulk of the patch.\n\ntext-\u003ebinary translation will insert a DataCount section if\nmemory.init or data.drop is used and the DataCount section is not\npresent in the text (this will be the common case); however, if the\nsection is present in the text then translation will just encode\nwhatever the text contains.  The section is not synthesized if it is\nnot needed.\n\nAlso: test cases for all of this.\n\nAlso: drive-by fix the passive-segments test cases: do not duplicate\nfunctionality from wasm-binary.js, and use opcode names when possible.", "files": ["js/src/jit-test/lib/wasm-binary.js", "js/src/jit-test/tests/wasm/passive-segs-boundary.js", "js/src/jit-test/tests/wasm/passive-segs-nonboundary.js", "js/src/vm/MutexIDs.h", "js/src/wasm/WasmAST.h", "js/src/wasm/WasmBaselineCompile.cpp", "js/src/wasm/WasmBaselineCompile.h", "js/src/wasm/WasmCompile.cpp", "js/src/wasm/WasmConstants.h", "js/src/wasm/WasmCraneliftCompile.cpp", "js/src/wasm/WasmCraneliftCompile.h", "js/src/wasm/WasmGenerator.cpp", "js/src/wasm/WasmGenerator.h", "js/src/wasm/WasmIonCompile.cpp", "js/src/wasm/WasmIonCompile.h", "js/src/wasm/WasmOpIter.h", "js/src/wasm/WasmTextToBinary.cpp", "js/src/wasm/WasmValidate.cpp", "js/src/wasm/WasmValidate.h"], "git_node": null, "git_parents": [null], "node": "426bafe23415b19d83dc3e084f66f71f156d53c7", "parents": ["5e914b7f1c0961f2707fc8c5694c9b0fa014dd58"], "tags": []}, {"author": "Lars T Hansen \u003clhansen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1502037 - Better error messages when accessing dropped data/elem segments. r=jseward", "files": ["js/src/jit-test/tests/wasm/passive-segs-boundary.js", "js/src/js.msg", "js/src/wasm/WasmInstance.cpp"], "git_node": null, "git_parents": [null], "node": "83097742e871e019732638bcdc8eeb36fc0c0c89", "parents": ["426bafe23415b19d83dc3e084f66f71f156d53c7"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1514480 - Print more information when verfiying weakmap marking r=sfink", "files": ["js/src/gc/Verifier.cpp"], "git_node": null, "git_parents": [null], "node": "3a520fdd3a245f6efd3b9f9b3d60a82b4a895810", "parents": ["83097742e871e019732638bcdc8eeb36fc0c0c89"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1522481 - Tidy individual store buffer classes by giving them a back pointer to the owning StoreBuffer r=sfink", "files": ["js/src/gc/Marking.cpp", "js/src/gc/StoreBuffer.cpp", "js/src/gc/StoreBuffer.h"], "git_node": null, "git_parents": [null], "node": "0eb75deea9d3afcae9d3173c243c6aba7865d34b", "parents": ["3a520fdd3a245f6efd3b9f9b3d60a82b4a895810"], "tags": []}, {"author": "Csoregi Natalia \u003cncsoregi@mozilla.com\u003e", "branch": "default", "desc": "Backed out 2 changesets (bug 1518512) for devtools failures on devtools/client/inspector/changes/test/browser_changes_rule_selector.js. CLOSED TREE\n\nBacked out changeset c8f0d19844f6 (bug 1518512)\nBacked out changeset 3c03e2282b4f (bug 1518512)", "files": ["devtools/client/inspector/changes/ChangesContextMenu.js", "devtools/client/inspector/changes/ChangesView.js", "devtools/client/inspector/changes/components/CSSDeclaration.js", "devtools/client/inspector/changes/components/ChangesApp.js", "devtools/client/inspector/changes/moz.build", "devtools/client/locales/en-US/changes.properties", "devtools/client/themes/changes.css"], "git_node": null, "git_parents": [null], "node": "a7918210d2f16d02f02f7a322375a358fe710e3a", "parents": ["d4740a86555216ae73ef92a0b1998e0f83c378e3"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1522413 - [marionette] Register event listeners before focusing the new window in WindowManagerMixin.open_chrome_window(). r=ato\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17473", "files": ["testing/marionette/harness/marionette_harness/runner/mixins/window_manager.py"], "git_node": null, "git_parents": [null], "node": "9762341e99f98f4a4a01cbc5a14ba5ecf900d93c", "parents": ["a7918210d2f16d02f02f7a322375a358fe710e3a"], "tags": []}, {"author": "Daisuke Akatsuka \u003cdakatsuka@mozilla.com\u003e", "branch": "default", "desc": "Bug 1515265: Move a place where add contextmenu listener to show the context menu in markup view. r=jdescottes\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17457", "files": ["devtools/client/inspector/inspector.js"], "git_node": null, "git_parents": [null], "node": "e51312da073fe84994b537536d12e639e68cc59e", "parents": ["9762341e99f98f4a4a01cbc5a14ba5ecf900d93c"], "tags": []}, {"author": "Daisuke Akatsuka \u003cdakatsuka@mozilla.com\u003e", "branch": "default", "desc": "Bug 1515265: Call stopPropagation() and preventDefault() at all places where handle contextmenu event and show the popup. r=jdescottes\n\nDepends on D17457\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17458", "files": ["devtools/client/inspector/computed/computed.js", "devtools/client/shared/inplace-editor.js", "devtools/client/shared/widgets/SideMenuWidget.jsm", "devtools/client/shared/widgets/TreeWidget.js"], "git_node": null, "git_parents": [null], "node": "635099091943c0ff81849ec224ac3e1ecc4a768e", "parents": ["e51312da073fe84994b537536d12e639e68cc59e"], "tags": []}, {"author": "Daisuke Akatsuka \u003cdakatsuka@mozilla.com\u003e", "branch": "default", "desc": "Bug 1515265: Add a test for context menu of the markup view in about:devtools-toolbox. r=jdescottes\n\nDepends on D17458\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17597", "files": ["devtools/client/aboutdebugging-new/test/browser/browser.ini", "devtools/client/aboutdebugging-new/test/browser/browser_aboutdebugging_devtoolstoolbox_contextmenu_markupview.js"], "git_node": null, "git_parents": [null], "node": "319ae34add89185fc5cc96e3a8b6ac71592f9b10", "parents": ["635099091943c0ff81849ec224ac3e1ecc4a768e"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1507283 - [geckodriver] Relax deserialization of timeouts parameters. r=ato\n\nIt fixes the regression from the transition to Serde (bug 1396821),\nwhich accidentally denied unknown fields.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17634", "files": ["testing/webdriver/src/command.rs"], "git_node": null, "git_parents": [null], "node": "bec3fe861b0652f81ba635eee4155b8063430d5a", "parents": ["319ae34add89185fc5cc96e3a8b6ac71592f9b10"], "tags": []}, {"author": "Justin Wood \u003cCallek@gmail.com\u003e", "branch": "default", "desc": "Bug 1518570 - Update task cluster configuration for oak. r=tomprince\n\nThe intent is to land this on central, to minimize the merge conflicts on oak\n\nOak is going to be used for Updater testing so needs release keys and such, and does not need android.\nThis approach is different than the previous oak approach in that it amends how we calculate 'trunk' and 'release'\nprojects to include 'oak', and then makes full nightlies produced on each push.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17440", "files": ["taskcluster/ci/balrog/kind.yml", "taskcluster/ci/build/kind.yml", "taskcluster/taskgraph/decision.py", "taskcluster/taskgraph/util/attributes.py", "taskcluster/taskgraph/util/scriptworker.py"], "git_node": null, "git_parents": [null], "node": "871d54b791a3432127ab232eeba07e33d03967af", "parents": ["bec3fe861b0652f81ba635eee4155b8063430d5a"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1522315 - Reduce minimum horizontal padding for panel footer buttons. r=johannh\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17482", "files": ["toolkit/themes/shared/global.inc.css", "toolkit/themes/shared/popupnotification.inc.css"], "git_node": null, "git_parents": [null], "node": "0f54f0a8fc4a1813002ff0a29a342d793864d366", "parents": ["871d54b791a3432127ab232eeba07e33d03967af"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1522791 - Fix PropTypes warning in console; r=Honza.\n\nThis fixes PropTypes warning on MessageContainer\nand ConfirmDialog components.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17636", "files": ["devtools/client/webconsole/components/ConfirmDialog.js", "devtools/client/webconsole/components/ConsoleOutput.js"], "git_node": null, "git_parents": [null], "node": "d6552069b6d952b2e032422d5bd9f46b1b81edb1", "parents": ["0f54f0a8fc4a1813002ff0a29a342d793864d366"], "tags": []}, {"author": "Jamie Nicol \u003cjnicol@mozilla.com\u003e", "branch": "default", "desc": "Bug 1496540 - Handle overlapping border corners in webrender r=gw\n\nWhen some of a border's corners have a border-radius, and that radius\nis larger than the sum of the border width and element size, then it\nresults in the corners of the border overlapping. Webrender draws\nborders by rasterizing each segment individually in to the cache, then\ncompositing them together. In this overlapping case, this has 2\nproblems:\n\na) we composite overlapping segments on top of eachother\nb) corner segments are not correctly clipped to the curve of the\n   overlapping adjacent corners\n\nThis patch allows corner segments to be clipped by their adjacent\ncorners. We provide the outer corner position and radii of the\nadjacent corners to the border shader, which then applies those clips,\nif required, along with the segment's own corner clip when rasterizing\nthe segment.\n\nAs the adjacent corners now affect the result of the cached segment,\nthey are added to the cache key.\n\nWe continue to rasterize the entire segment in to the cache as before,\nbut now modify the local rect and texel rect of the BrushSegment so\nthat it only composites the subportion of the corner segment which\ndoes not overlap with the opposite edges of the border.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16872", "files": ["gfx/wr/webrender/res/cs_border_solid.glsl", "gfx/wr/webrender/src/border.rs", "gfx/wr/wrench/reftests/border/border-overlapping-ref.yaml", "gfx/wr/wrench/reftests/border/border-overlapping.yaml", "gfx/wr/wrench/reftests/border/reftest.list", "layout/reftests/border-radius/reftest.list"], "git_node": null, "git_parents": [null], "node": "f57d14800cbb5cf9f7c135d7e32ea5728fe7b377", "parents": ["d6552069b6d952b2e032422d5bd9f46b1b81edb1"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1522596 - Remove nsIIPCSerializableURI and move its only member to nsIURI; r=valentin\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17531", "files": ["caps/NullPrincipalURI.cpp", "caps/NullPrincipalURI.h", "dom/file/uri/BlobURL.cpp", "dom/file/uri/BlobURL.h", "dom/jsurl/nsJSProtocolHandler.cpp", "dom/jsurl/nsJSProtocolHandler.h", "image/decoders/icon/nsIconURI.cpp", "image/decoders/icon/nsIconURI.h", "ipc/glue/URIUtils.cpp", "ipc/glue/moz.build", "ipc/glue/nsIIPCSerializableURI.h", "modules/libjar/nsJARURI.cpp", "modules/libjar/nsJARURI.h", "netwerk/base/nsIURI.idl", "netwerk/base/nsIURIMutator.idl", "netwerk/base/nsSimpleNestedURI.cpp", "netwerk/base/nsSimpleNestedURI.h", "netwerk/base/nsSimpleURI.cpp", "netwerk/base/nsSimpleURI.h", "netwerk/base/nsStandardURL.cpp", "netwerk/base/nsStandardURL.h"], "git_node": null, "git_parents": [null], "node": "d815471fff914f9482658278838592eaa62052b0", "parents": ["f57d14800cbb5cf9f7c135d7e32ea5728fe7b377"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1522490 - Only get the parent principal URI if logging is enabled; r=baku\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17502", "files": ["toolkit/components/antitracking/AntiTrackingCommon.cpp"], "git_node": null, "git_parents": [null], "node": "1ba76553a3bd9ce2aefc64ebd8ed95b80225353a", "parents": ["d815471fff914f9482658278838592eaa62052b0"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1520879 - Port the onContentBlockingEvent notifications inside WebProgressChild.jsm to C++; r=baku\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17157", "files": ["