: ["88cabcb8f0bcc26cd49e3716466f286417f034e4"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nnl -\u003e fb289177b89b\npt-PT -\u003e 69edd995ad6a", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "d53f7206f8dc01169543c84d14b2b9e8d4c5aa7c", "parents": ["f9ebebe8abecd3a37534860dd187e717b66930e2"], "tags": []}], "date": 1549504827, "git_changesets": [null, null], "user": "ffxbld"}, "10636": {"changesets": [{"author": "Vlad Baicu \u003cvlad.baicu@softvision.ro\u003e", "branch": "default", "desc": "Bug 1516665 - Prevent MediaControlService NPE. r=JanH a=lizzard\n\nUse MediaControlService's context when creating the notification in order to\nprevent a NPE.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17391", "files": ["mobile/android/base/java/org/mozilla/gecko/media/GeckoMediaControlAgent.java", "mobile/android/base/java/org/mozilla/gecko/media/MediaControlService.java"], "git_node": null, "git_parents": [null], "node": "1ce04026e6ebe42dfc1ba8efd2478e33dd8c13cb", "parents": ["d53f7206f8dc01169543c84d14b2b9e8d4c5aa7c"], "tags": []}, {"author": "Vlad Baicu \u003cvlad.baicu@softvision.ro\u003e", "branch": "default", "desc": "Bug 1516665 - Part 2: Cleanup. r=JanH a=lizzard\n\nSome code cleanup.\n\nDepends on D17391\n\nDifferential Revision: https://phabricator.services.mozilla.com/D18115", "files": ["mobile/android/base/java/org/mozilla/gecko/media/GeckoMediaControlAgent.java", "mobile/android/base/java/org/mozilla/gecko/media/MediaControlService.java"], "git_node": null, "git_parents": [null], "node": "be69f7164f217491b3219b0182f331e8209cba5e", "parents": ["1ce04026e6ebe42dfc1ba8efd2478e33dd8c13cb"], "tags": []}, {"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 1522951 - Make ChromiumCDMProxy::mCrashHelper into a strong reference. r=jya a=lizzard\n\nRefcounted objects should be put into refptrs when they are created.\n\nThis patch also moves the crash helper out of the object early in\nInit, to maybe reduce the chance of a leak if it fails early.\n\nThis field is only used to pass in a value to the Init() method. It\ncan't be passed in directly because on Android there are two\nimplementations of CDMProxy, and MediaDrmCDMProxy doesn't take a crash\nhelper.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17707", "files": ["dom/media/gmp/ChromiumCDMProxy.cpp", "dom/media/gmp/ChromiumCDMProxy.h"], "git_node": null, "git_parents": [null], "node": "70ad33dab5d6cdbf3e39bce0eb81142323d077c8", "parents": ["be69f7164f217491b3219b0182f331e8209cba5e"], "tags": []}, {"author": "David Parks \u003cdparks@mozilla.com\u003e", "branch": "default", "desc": "Bug 1514073: Allow Windows plugin process to access Macromedia roaming folder r=bobowen a=lizzard\n\nThe sandbox already permits the process to create/delete the folder and access files in it.  This patch gives is access to the folder itself, namely it allows NtQueryAttributesFile to evaluate it.  For complex reasons, this fixes Flash's ability to store local objects (see AS3's SharedObject API).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D18299", "files": ["security/sandbox/win/src/sandboxbroker/sandboxBroker.cpp"], "git_node": null, "git_parents": [null], "node": "9d24a22bcd5d0abf805100786335d4b2c603a635", "parents": ["70ad33dab5d6cdbf3e39bce0eb81142323d077c8"], "tags": []}, {"author": "Edgar Chen \u003cechen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1521082 - Don't dispatch pointer event if the touch in touchstart event is already registered; r=smaug a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16976", "files": ["dom/events/test/pointerevents/mochitest.ini", "dom/events/test/pointerevents/test_multiple_touches.html", "layout/base/TouchManager.cpp"], "git_node": null, "git_parents": [null], "node": "0d2e173a01fdf528463e8c9d0b6c9844f13babcc", "parents": ["9d24a22bcd5d0abf805100786335d4b2c603a635"], "tags": []}, {"author": "Emanuel Hoogeveen \u003cemanuel.hoogeveen@protonmail.com\u003e", "branch": "default", "desc": "Bug 1520783 - Don't assert if we fail to map a file after reserving the memory. r=sfink a=lizzard", "files": ["js/src/gc/Memory.cpp"], "git_node": null, "git_parents": [null], "node": "161fa6ef84900cc5e34b2c3b247ae772250a0c91", "parents": ["0d2e173a01fdf528463e8c9d0b6c9844f13babcc"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1524119 - Properly get VP9 benchmark value. r=bryce a=lizzard\n\nAnd not the threshold which is always 150.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D18159", "files": ["dom/media/Benchmark.cpp"], "git_node": null, "git_parents": [null], "node": "f1bf2550b912d8f07c9c36cb5e64fd045405af41", "parents": ["161fa6ef84900cc5e34b2c3b247ae772250a0c91"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1523635 - part 1: Rename `maybeHandledAsynchronously` to `probablyHandledAsynchronously` r=m_kato a=RyanVM\n\nNow, we believe that when `maybeHandledAsynchronously` is set to true,\nibus handles the event asynchronously in usual cases.  However, the behavior\nof ibus on password field is unclear.  Currently, on Ubuntu 18.04,\nUbuntu 18.10 and Debian Cinnamon (9.6 / 3.2.7), ibus handles key events\nasynchronously even in password fields even though I confirmed it was not\nso at initial fix.  So, it could be just my mistake, but we need to prepare\nfor both cases here for safer fix.\n\nSo, in the following patch, I need to add another variable for weaker\ndecision, and we treat `maybeHandledAsynchronously` stronger than its\nnuance.  Therefore, this patch renames it to `probablyHandledAsynchronously`.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D18634", "files": ["widget/gtk/IMContextWrapper.cpp"], "git_node": null, "git_parents": [null], "node": "f950041314ee23bac0947f7b6206af80a8179b37", "parents": ["f1bf2550b912d8f07c9c36cb5e64fd045405af41"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1523635 - part 2: Make IMContextWrapper::OnKeyEvent() trust the result of gtk_im_context_filter_keypress() to decide whether handling event causes async event later r=m_kato a=RyanVM\n\nUnfortunately, we're not sure whether ibus always handles non-dead key events\nasynchronously or synchoronously.  Therefore, for safer fix, this patch makes\nIMContextWrapper::OnKeyEvent() decide that with the result of\ngtk_im_context_filter_keypress().  If active IME is ibus and it consumes non-\nsynthesized events on password fields, it adjusts probablyHandledAsynchronously\nvalue.\n\nSo, this patch changes the behavior of only when:\n- active IME is ibus.\n- only when a password field or ime-mode:disabled field has focus.\n- not in dead key sequence.\n- and the key event is consumed by ibus but nothing happend.\n\nThis must be enough safe to uplift.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D18635", "files": ["widget/gtk/IMContextWrapper.cpp"], "git_node": null, "git_parents": [null], "node": "380761f22d52cf4ed9a0a6e79294acfe149babfa", "parents": ["f950041314ee23bac0947f7b6206af80a8179b37"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1521053 - Ensure that the labels we use to display origin names in Trackers/Cookies subpanels are always LTR but their text alignment follows UI directionality; r=johannh a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17876", "files": ["browser/themes/shared/controlcenter/panel.inc.css"], "git_node": null, "git_parents": [null], "node": "6f1e1adbccb026ce89384465c7a425916d159a22", "parents": ["380761f22d52cf4ed9a0a6e79294acfe149babfa"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Bug 1522964 - Re-enable scroll anchoring on Fennec with gofaster intervention. r=dholbert a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17677", "files": ["mobile/android/app/geckoview-prefs.js", "modules/libpref/init/StaticPrefList.h"], "git_node": null, "git_parents": [null], "node": "820fe56860e101a06a9dc6981576f7eb281b1722", "parents": ["6f1e1adbccb026ce89384465c7a425916d159a22"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1516754 - P1. Reset Pending Input Buffer during Reset Parser State Algorithm. r=kinetik a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D18651", "files": ["dom/media/mediasource/TrackBuffersManager.cpp"], "git_node": null, "git_parents": [null], "node": "7d9ca706a2a3c97121801502c8e600db35e6ac2d", "parents": ["820fe56860e101a06a9dc6981576f7eb281b1722"], "tags": []}], "date": 1549508353, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "rgurzau@mozilla.com"}, "10637": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nta -\u003e 8843768a86f3", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "da05fc416eff1b94662c24a37d957381e4475385", "parents": ["7d9ca706a2a3c97121801502c8e600db35e6ac2d"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nfr -\u003e 7e1d4b71b498\nhr -\u003e fab4f372c85b\nit -\u003e 38cdb886de92\nnl -\u003e 093abd5a620f", "files": ["browser/locales/l10n-changesets.json"], "git_nod