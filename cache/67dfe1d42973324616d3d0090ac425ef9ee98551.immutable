ficates. a=bustage-fix", "files": ["security/manager/ssl/tests/unit/test_cert_chains.js"], "git_node": null, "git_parents": [null], "node": "1a64a0b6a58e90ddc62df7310c739396eaa0961d", "parents": ["9689c6dc5590658b87597b4f84af48548fb58dde"], "tags": []}], "date": 1549378467, "git_changesets": [null, null, null, null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "10624": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 02146faf5ac13099a1e6a9d2ef1251f8b6bda0f3 with FENNEC_66_0b5_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "084ca4975bc42f88ff8be1c9971e2d6c0dc696b1", "parents": ["1a64a0b6a58e90ddc62df7310c739396eaa0961d"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release DONTBUILD", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "d3bbd85ce8cfc663b4ca64bc76ee9c7fa3a6cef1", "parents": ["084ca4975bc42f88ff8be1c9971e2d6c0dc696b1"], "tags": []}], "date": 1549382174, "git_changesets": [null, null], "user": "ffxbld"}, "10625": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 02146faf5ac13099a1e6a9d2ef1251f8b6bda0f3 with FIREFOX_66_0b5_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "a0f7de2e4cd1e7a1a2ec89e75b7863b88cc3c8e1", "parents": ["d3bbd85ce8cfc663b4ca64bc76ee9c7fa3a6cef1"], "tags": []}], "date": 1549386753, "git_changesets": [null], "user": "ffxbld"}, "10626": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 02146faf5ac13099a1e6a9d2ef1251f8b6bda0f3 with DEVEDITION_66_0b5_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "b2d57d4ab4907c0ec3b0049240c89b6ef712018b", "parents": ["a0f7de2e4cd1e7a1a2ec89e75b7863b88cc3c8e1"], "tags": []}], "date": 1549386932, "git_changesets": [null], "user": "ffxbld"}, "10627": {"changesets": [{"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1517177: Fix hash verification of downloaded toolchains; r=glandium a=NPOTB\n\nDifferential Revision: https://phabricator.services.mozilla.com/D15961", "files": ["python/mozbuild/mozbuild/mach_commands.py"], "git_node": null, "git_parents": [null], "node": "5c339b75ff92c26d52407984d71c0b6d0bdace76", "parents": ["b2d57d4ab4907c0ec3b0049240c89b6ef712018b"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1247453 - part 1 - request synchronization privileges in kill_pid; r=gbrown a=test-only\n\nWindows documentation indicates that it's invalid to WaitForSingleObject\non a process handle unless you request the SYNCHRONIZE access right.\nAnd indeed, we see errors in the logs like:\n\n09:58:28  WARNING - mozcrash kill_pid(): wait failed (-1) terminating pid 6340: error 5\n\nThat \"error 5\" is an ERROR_ACCESS_DENIED code.  Such errors should go\naway with requesting the proper access rights.  Credit to dmajor for\nnoticing the discrepancy.", "files": ["testing/mozbase/mozcrash/mozcrash/mozcrash.py"], "git_node": null, "git_parents": [null], "node": "89ee93500ac6a518380a6f549f17ec096fab8274", "parents": ["5c339b75ff92c26d52407984d71c0b6d0bdace76"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1247453 - part 2 - be more stringent in checking for live pids; r=gbrown a=test-only\n\nWe're seeing a lot of cases where our \"check for zombie child processes\"\ncheck is finding live processes, but the minidumps that we get from such\nprocesses are nonsense, and don't even feature Firefox symbols.\n\nThe working theory at this point, courtesy of bobowen, is that child\nprocesses that we launch are getting closed during the test runs,\ncompletely normally, and then we are finding other (non-Firefox) live\nprocesses with the PIDs that were used for Firefox child processes at\nthe end of the test run.  This scenario is plausible due to Windows's\naggressive reuse of PIDs.  We don't see the same behavior on our Unix\ntest machines because Linux (and OS X, apparently) are not nearly as\naggressive in reusing PIDs.\n\nSince we should be ensuring that any live processes are actually Firefox\nprocesses anyway, let's add the appropriate check.  If the check works\nto reduce the incidence of zombiecheck failures, that's great!  If not,\nwe've at least made our test runner more robust and can investigate\nother possibilities for these intermittent failures.", "files": ["testing/mochitest/runtests.py"], "git_node": null, "git_parents": [null], "node": "102bb1b114fb4f531d42cd0fe3290ca06047e614", "parents": ["89ee93500ac6a518380a6f549f17ec096fab8274"], "tags": []}, {"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 1523800 - Update LSan whitelist for html/browsers/offline/introduction-4. r=jgraham a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D18127", "files": ["testing/web-platform/meta/html/browsers/offline/introduction-4/__dir__.ini"], "git_node": null, "git_parents": [null], "node": "9d9028c3dd63056e33398b6c7b044c7661e23b3b", "parents": ["102bb1b114fb4f531d42cd0fe3290ca06047e614"], "tags": []}, {"author": "Andreea Pavel \u003capavel@mozilla.com\u003e", "branch": "default", "desc": "Bug 1524340 - land NSS_3_42_1_RTMNSS r=me a=lizzard\nUPGRADE_NSS_RELEASE", "files": ["security/nss/TAG-INFO", "security/nss/coreconf/coreconf.dep", "security/nss/lib/nss/nss.h", "security/nss/lib/smime/cmscinfo.c", "security/nss/lib/smime/cmsdigdata.c", "security/nss/lib/smime/cmsencdata.c", "security/nss/lib/smime/cmsenvdata.c", "security/nss/lib/smime/cmsmessage.c", "security/nss/lib/smime/cmsudf.c", "security/nss/lib/softoken/softkver.h", "security/nss/lib/util/nssutil.h"], "git_node": null, "git_parents": [null], "node": "a72907fa616b169be2c862db878139cef15a2ed8", "parents": ["9d9028c3dd63056e33398b6c7b044c7661e23b3b"], "tags": []}], "date": 1549389154, "git_changesets": [null, null, null, null, null], "user": "apavel@mozilla.com"}, "10628": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nsk -\u003e bc14f684e6de", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "dd0a90b057d028dcd947635b1b5c1c559a3e398a", "parents": ["a72907fa616b169be2c862db878139cef15a2ed8"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nbr -\u003e eae20dcefab2\nda -\u003e 6fd2236c66b1\nes-AR -\u003e e7c32277319a\nsk -\u003e bc14f684e6de", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "818423c82b5fa1e64cc45f7a557e80c545f2de95", "parents": ["dd0a90b057d028dcd947635b1b5c1c559a3e398a"], "tags": []}], "date": 1549393228, "git_changesets": [null, null], "user": "ffxbld"}, "10629": {"changesets": [{"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1524208 - Calculate stride based upon target_width in video_capture_impl.cc; r=pehrsons a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D18270", "files": ["media/webrtc/trunk/webrtc/modules/video_capture/video_capture_impl.cc"], "git_node": null, "git_parents": [null], "node": "e7f9d4cd8d73341f0166a97dc988a6ff4ed6bae0", "parents": ["818423c82b5fa1e64cc45f7a557e80c545f2de95"], "tags": []}, {"author": "Tooru Fujisawa \u003carai_a@mac.com\u003e", "branch": "default", "desc": "Bug 1521696 - Fix PropertyEmitter not to use JSOP_OBJECT when the objest has accessor. r=jorendorff a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17471", "files": ["js/src/frontend/ObjectEmitter.cpp"], "git_node": null, "git_parents": [null], "node": "818b91df49bb72a0ee4a15c920f662d4fb2b2ea5", "parents": ["e7f9d4cd8d73341f0166a97dc988a6ff4ed6bae0"], "tags": []}, {"author": "Chun-Min Chang \u003ccchang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1521214 - r=kinetik a=lizzard", "files": ["dom/media/BufferReader.h"], "git_node": null, "git_parents": [null], "node": "2c323705bd256f820349aca73b5453d6849484fd", "parents": ["818b91df49bb72a0ee4a15c920f662d4fb2b2ea5"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1523160 - Add descriptions for SSL policies r=Felipe,flod a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17873", "files": ["browser/locales/en-US/browser/policies/policies-descriptions.ftl"], "git_node": null, "git_parents": [null], "node": "373e61d5d56f98a293423d7662a4de7a1534ef68", "parents": ["2c323705bd256f820349aca73b5453d6849484fd"], "tags": []}], "date": 1549445642, "git_changesets": [null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "10630": {"changesets": [{"author": "Gabriele Svelto \u003cgsvelto@mozilla.com\u003e", "branch": "default", "desc": "Bug 1518947 - Update breakpad to revision 44384d80b32a5bb361c2ec3bee667f7ccee566d7. r=ted a=lizzard\n\nThis includes some assorted fixes from upstream plus an adaptation of the\npatch in b988fa74ec18de6214b18f723e48331d9a7802ae which includes heap memory\nregions in the minidump. Since our support for that is more extensive than\nupstream breakpad the resulting change reflects this. Last but not least the\nfixes for bug 1489094 and bug 1511140 were split out as patches to be applied\nto the unmodified breakpad sources. They will be reintegrated as soon as we\nfork breakpad for good.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16326", "files": ["toolkit/crashreporter/breakpad-client/linux/handler/exception_handler.cc", "toolkit/crashreporter/breakpad-client/linux/handler/exception_handler.h", "toolkit/crashreporter/breakpad-client/linux/handler/exception_handler_unittest.cc", "toolkit/crashreporter/breakpad-client/windows/common/minidump_callback.cc", "toolkit/crashreporter/breakpad-client/windows/handler/exception_handler.cc", "toolkit/crashreporter/breakpad-patches/01-llvm-windows-symbol-fixup.patch", "toolkit/crashreporter/breakpad-patches/02-define-print-mach-result.patch", "toolkit/crashreporter/breakpad-patches/03-strstr-libc-replacement.patch", "toolkit/crashreporter/google-breakpad/GIT-INFO", "toolkit/crashreporter/google-breakpad/src/common/dwarf_cu_to_module.cc", "toolkit/crashreporter/google-breakpad/src/common/mac/arch_utilities.cc", "toolkit/crashreporter/google-breakpad/src/processor/logging.h", "toolkit/crashreporter/google-breakpad/src/processor/minidump.cc", "toolkit/crashreporter/google-breakpad/src/processor/minidump_processor.cc", "toolkit/crashreporter/google-breakpad/src/processor/minidump_processor_unittest.cc", "toolkit/crashreporter/google-breakpad/src/tools/mac/dump_syms/dump_syms.xcodeproj/project.pbxproj", "toolkit/crashreporter/google-breakpad/src/tools/mac/upload_system_symbols/arch_constants.h", "toolkit/crashreporter/google-breakpad/src/tools/mac/upload_system_symbols/arch_reader.go", "toolkit/crashreporter/update-breakpad.sh"], "git_node": null, "git_parents": [null], "node": "c916c1117a67cae04c6808de1e80824ab5cf13fb", "parents": ["373e61d5d56f98a293423d7662a4de7a1534ef68"], "tags": []}, {"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 1523013 - Clear SamplesWaitingForKey::mProxy in Shutdown(). r=cpearce a=lizzard\n\nThere's a strong cycle of references between SamplesWaitingForKey and\nCDMProxy that does not get cleared unless keys actually come in. This\ncauses a leak. One way to avoid that leak is to clear the proxy\nreference when the things holding the SamplesWaitingForKey is shut\ndown.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17960", "files": ["dom/media/platforms/agnostic/eme/EMEDecoderModule.cpp", "dom/media/platforms/agnostic/eme/SamplesWaitingForKey.cpp", "dom/media/platforms/agnostic/eme/SamplesWaitingForKey.h"], "git_node": null, "git_parents": [null], "node": "1079d285dd4006cf27fd867d29c7e408a7627365", "parents": ["c916c1117a67cae04c6808de1e80824ab5cf13fb"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1523817 - Fix tracks that start at StreamTime t \u003e 0. r=padenot a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D18312", "files": ["dom/media/MediaStreamGraph.cpp"], "git_node": null, "git_parents": [null], "node": "32e42cfd5f75027335205e600bf4cd241d6de773", "parents": ["1079d285dd4006cf27fd867d29c7e408a7627365"], "tags": []}, {"author": "Gabriele Svelto \u003cgsvelto@mozilla.com\u003e", "branch": "default", "desc": "Bug 1524142 - Ensure that MOZ_CRASHREPORTER is properly defined in Windows/AArch64 builds r=glandium a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D18216", "files": ["old-configure.in"], "git_node": null, "git_parents": [null], "node": "da01ba6f951a3f1acdc475c73ba03ed8efc640e7", "parents": ["32e42cfd5f75027335205e600bf4cd241d6de773"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1524500 - P1. Remove partial frames when the starting time falls within the removal interval. r=bryce a=lizzard\n\nPer spec:\nhttps://w3c.github.io/media-source/#sourcebuffer-coded-frame-removal\nStep 3 of the Coded Frame Removal Interval:\n\"Remove all media data, from this track buffer, that contain starting timestamps greater than or equal to start and less than the remove end timestamp. \"\n\nSo to decide if a frame should be removed from a track buffer, its start time is the only information to be used.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D18321", "files": ["dom/media/mediasource/TrackBuffersManager.cpp"], "git_node": null, "git_parents": [null], "node": "6eb6ad4198dab49f5fdde49055c2b97a4bcaf118", "parents": ["da01ba6f951a3f1acdc475c73ba03ed8efc640e7"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1524500 - P2. Simplify logic to break loop early. r=bryce a=lizzard\n\nThe logic was redundant with the next step that will already remove all until the next keyframe.\n\nDepends on D18321\n\nDifferential Revision: https://phabricator.services.mozilla.com/D18322", "files": ["dom/media/mediasource/TrackBuffersManager.cpp"], "git_node": null, "git_parents": [null], "node": "16b643f92fbf41777ed213d1caab4f343ee581ec", "parents": ["6eb6ad4198dab49f5fdde49055c2b97a4bcaf118"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1524565 - Clone ScriptSourceObject just once when cloning a script with inner functions. r=tcampbell a=lizzard\n\nCreating too many SSOs can apparently slow down the debugger and it's just\nwasteful.\n\nThis patch passes the SSO down to the cloning functions. One nice side-effect is\nthat the self-hosting SSO code now lives in SelfHosting.cpp instead of JSScript.cpp\n\nDifferential Revision: https://phabricator.services.mozilla.com/D18347", "files": ["js/src/jsapi.cpp", "js/src/vm/JSFunction-inl.h", "js/src/vm/JSFunction.cpp", "js/src/vm/JSFunction.h", "js/src/vm/JSScript.cpp", "js/src/vm/JSScript.h", "js/src/vm/SelfHosting.cpp"], "git_node": null, "git_parents": [null], "node": "38126f72db7fe9f3d7098cdf73d33db800022a4d", "parents": ["16b643f92fbf41777ed213d1caab4f343ee581ec"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1524674 - Cleanup site data with custom permissions per subdomains - debug messages. r=johannh a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D18496", "files": ["browser/modules/Sanitizer.jsm", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "bf4fec8933af388b2e37a56780dc6895727a8b2d", "parents": ["38126f72db7fe9f3d7098cdf73d33db800022a4d"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1524674 - Cleanup site data with custom permissions per subdomains - check permissions. r=johannh a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D18497", "files": ["browser/modules/Sanitizer.jsm"], "git_node": null, "git_parents": [null], "node": "ea1d5311b285dcdb93b1b1748dc5d9905fda7993", "parents": ["bf4fec8933af388b2e37a56780dc6895727a8b2d"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1524674 - Cleanup site data with custom permissions per subdomains - Tests. r=johannh a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D18498", "files": ["browser/base/content/test/sanitize/browser_cookiePermission.js"], "git_node": null, "git_parents": [null], "node": "6e1b209f1fd83d990cbfff4740579544e9e88fcf", "parents": ["ea1d5311b285dcdb93b1b1748dc5d9905fda7993"], "tags": []}], "date": 1549449879, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "nbeleuzu@mozilla.com"}, "10631": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nfi -\u003e 90a5078796a5\nnn-NO -\u003e 3999397fd3f6\npt-PT -\u003e 1a63869c018e", "fil