of CC_VERSION to python configure. r=chmanchester\n\nwhich, at this point, is only the AC_SUBST, so we don't even need to\ngive it to old-configure anymore.\n\nDepends on D17207\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17208", "files": ["build/moz.configure/toolchain.configure", "js/src/old-configure.in", "old-configure.in"], "git_node": null, "git_parents": [null], "node": "09e1109d23504fbc57c80a8982f88f8d710338bd", "parents": ["cfee3de00f1274a681a39f908e071440613a011b"], "tags": []}, {"author": "David Major \u003cdmajor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1477306 - Point -fcrash-diagnostics-dir at UPLOAD_DIR when compiling with clang in automation r=firefox-build-system-reviewers,chmanchester\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16765", "files": ["build/macosx/cross-mozconfig.common", "build/mozconfig.clang-cl", "build/unix/mozconfig.unix"], "git_node": null, "git_parents": [null], "node": "31a754e0302db5d22a3485f1aef60a762d5507e1", "parents": ["09e1109d23504fbc57c80a8982f88f8d710338bd"], "tags": []}, {"author": "shindli \u003cshindli@mozilla.com\u003e", "branch": "default", "desc": "Backed out 2 changesets (bug 1521691) for bustages in clang-plugin.dll CLOSED TREE\n\nBacked out changeset 09e1109d2350 (bug 1521691)\nBacked out changeset cfee3de00f12 (bug 1521691)", "files": ["build/moz.configure/toolchain.configure", "js/src/old-configure.in", "old-configure.in", "python/mozbuild/mozbuild/action/check_binary.py", "python/mozbuild/mozbuild/frontend/gyp_reader.py"], "git_node": null, "git_parents": [null], "node": "a57c4b40b14f246d0f76bfbd9e6124c9433d8fec", "parents": ["31a754e0302db5d22a3485f1aef60a762d5507e1"], "tags": []}, {"author": "Georg Fritzsche \u003cgeorg.fritzsche@googlemail.com\u003e", "branch": "default", "desc": "Bug 1515973 - Add Telemetry review guidelines to in-tree docs. r=chutten", "files": ["toolkit/components/telemetry/docs/internals/index.rst", "toolkit/components/telemetry/docs/internals/review.rst"], "git_node": null, "git_parents": [null], "node": "4991df58d5842fe5199c9192460ec219a10b7878", "parents": ["02db4035c94cfac1a13c0f7786ca2a258d36a453"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1520473: Don't set the overwritten-bit in TI when initialising global lexicals. r=jandem", "files": ["js/src/vm/Interpreter-inl.h"], "git_node": null, "git_parents": [null], "node": "ae5579e90adeae5737c847a2b7ac5a49b913b555", "parents": ["4991df58d5842fe5199c9192460ec219a10b7878"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1516133 - Avoid extra main-thread jumps during the URL-classification, r=dimi", "files": ["netwerk/url-classifier/AsyncUrlChannelClassifier.cpp", "toolkit/components/url-classifier/nsUrlClassifierDBService.cpp", "toolkit/components/url-classifier/nsUrlClassifierDBService.h"], "git_node": null, "git_parents": [null], "node": "fef99cfead16d68737b741e6579c91d1d09ae395", "parents": ["ae5579e90adeae5737c847a2b7ac5a49b913b555"], "tags": []}, {"author": "Honza Bambas \u003chonzab.moz@firemni.cz\u003e", "branch": "default", "desc": "Bug 1520125 - Don't use origin attributes to distinguish proxy authentication cache entries. r=dragana, r=mixedpuppy", "files": ["netwerk/protocol/http/nsHttpChannelAuthProvider.cpp", "toolkit/components/extensions/test/xpcshell/test_ext_proxy_auth.js", "toolkit/components/extensions/test/xpcshell/test_ext_proxy_onauthrequired.js"], "git_node": null, "git_parents": [null], "node": "7a27f9d0f611a1c0baf420705a83b4258b93c7fe", "parents": ["fef99cfead16d68737b741e6579c91d1d09ae395"], "tags": []}, {"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 1520689 - Implement the class list panel in the new rules view. r=pbro", "files": ["devtools/client/inspector/reducers.js", "devtools/client/inspector/rules/actions/class-list.js", "devtools/client/inspector/rules/actions/index.js", "devtools/client/inspector/rules/actions/moz.build", "devtools/client/inspector/rules/components/ClassListPanel.js", "devtools/client/inspector/rules/components/RulesApp.js", "devtools/client/inspector/rules/components/Toolbar.js", "devtools/client/inspector/rules/models/class-list.js", "devtools/client/inspector/rules/models/moz.build", "devtools/client/inspector/rules/new-rules.js", "devtools/client/inspector/rules/reducers/class-list.js", "devtools/client/inspector/rules/reducers/moz.build", "devtools/client/inspector/rules/types.js", "devtools/client/inspector/rules/views/class-list-previewer.js"], "git_node": null, "git_parents": [null], "node": "2e1923054d3b5103f13e257cd9d416d6679c1460", "parents": ["7a27f9d0f611a1c0baf420705a83b4258b93c7fe"], "tags": []}, {"author": "Ted Campbell \u003ctcampbell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1520366 - Prepend LifoAlloc chunks when transferring them. r=nbp\n\nWhen using LifoAlloc::transferFrom to merge allocators (such as for\ntypes), prepend the chunks to avoid wasted space at end of current last\nchunk. This helps usecases such as TypeInference to behave more\npredictably when merging small allocators.\n\n(Original implementation by :nbp)\n", "files": ["js/src/ds/LifoAlloc.cpp", "js/src/ds/LifoAlloc.h"], "git_node": null, "git_parents": [null], "node": "13e451a690836e7b38a6bdb7677e9247fdbb6fc3", "parents": ["2e1923054d3b5103f13e257cd9d416d6679c1460"], "tags": []}, {"author": "Ted Campbell \u003ctcampbell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1520366 - Update LifoAlloc growth heuristics to track smallAllocsSize. r=nbp\n\n- Replace oversizeSize with smallAllocsSize. This will track sizes of\n  non-transferred small allocation chunks. It excludes unused chunks,\n  oversize chunks and chunks transfered from other LifoAlloc. This new\n  counter is used to determine chunk size growth heuristics. This aims\n  to reduce memory spikes due to transferFrom allocation patterns that\n  we see in the wild.\n- Also fix a pre-existing typo in LifoAlloc::reset\n", "files": ["js/src/ds/LifoAlloc.cpp", "js/src/ds/LifoAlloc.h"], "git_node": null, "git_parents": [null], "node": "acd0dadf80139d92223cf7506618621919418797", "parents": ["13e451a690836e7b38a6bdb7677e9247fdbb6fc3"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1521708, r=johannh\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17244", "files": ["browser/base/content/tabbrowser.js", "browser/components/urlbar/tests/browser/browser.ini", "browser/components/urlbar/tests/browser/browser_urlbar_content_opener.js"], "git_node": null, "git_parents": [null], "node": "e2775f83185e13bc4eb050b8182fd59d00ca7867", "parents": ["acd0dadf80139d92223cf7506618621919418797"], "tags": []}, {"author": "Oana Pop Rus \u003copoprus@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to inbound.  a=merge CLOSED TREE", "files": [], "git_node": null, "git_parents": [null, null], "node": "96d9416e177cb1067d52340f2ced0596e3770e88", "parents": ["e2775f83185e13bc4eb050b8182fd59d00ca7867", "af02238bdfe7b2de724e2bfc073736e095cafaac"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1521708 - follow-up: disable test on debug for leaks, rs=firebot, CLOSED TREE", "files": ["browser/components/urlbar/tests/browser/browser.ini"], "git_node": null, "git_parents": [null], "node": "d1c7d5975a884c86a3c31bdd19049878494d5572", "parents": ["96d9416e177cb1067d52340f2ced0596e3770e88"], "tags": []}, {"author": "Robert Strong \u003crobert.bugzilla@gmail.com\u003e", "branch": "default", "desc": "Bug 1521658 - Remove function binaryToHex since it isn't used. r=mhowell", "files": ["toolkit/mozapps/update/nsUpdateService.js"], "git_node": null, "git_parents": [null], "node": "ce81dcaa53f5b7057b0b59d901f8a4f3412d6b87", "parents": 