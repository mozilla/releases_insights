s/urlbar/tests/unit/test_providerUnifiedComplete.js"], "git_node": null, "git_parents": [null], "node": "539995d20747edf340c4ef77a8660636f88112d4", "parents": ["f83934422518dcba917afb08e9b103aa702cf772"], "tags": []}, {"author": "Patricia Lawless \u003cplawless@mozilla.com\u003e", "branch": "default", "desc": "Bug 1522722 - Added eslint space-in-parens rule and fixed corresponding errors. r=MattN\n\nAdded \"space-in-parens\": [\"error\"] to eslint for passwordmgr, and fixed the 5 errors found.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17697", "files": ["toolkit/components/passwordmgr/.eslintrc.js", "toolkit/components/passwordmgr/nsLoginManager.js", "toolkit/components/passwordmgr/test/mochitest/test_prompt_promptAuth_proxy.html", "toolkit/components/passwordmgr/test/prompt_common.js"], "git_node": null, "git_parents": [null], "node": "2fb0d69739bddfb334c483f7f1054c2b6be735d3", "parents": ["539995d20747edf340c4ef77a8660636f88112d4"], "tags": []}, {"author": "Patricia Lawless \u003cplawless@mozilla.com\u003e", "branch": "default", "desc": "Bug 1517726 - Corrected case of usernameField. r=MattN\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17708", "files": ["toolkit/components/passwordmgr/nsLoginManagerPrompter.js"], "git_node": null, "git_parents": [null], "node": "bb5d37aec5da39e6994de97e0c08b6d20050de43", "parents": ["2fb0d69739bddfb334c483f7f1054c2b6be735d3"], "tags": []}, {"author": "Coroiu Cristina \u003cccoroiu@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset e0034670b26a (bug 1514417) as requested by daoshengmu", "files": ["gfx/vr/gfxVRExternal.cpp", "gfx/vr/gfxVRExternal.h", "gfx/vr/service/VRService.cpp", "gfx/vr/service/VRService.h"], "git_node": null, "git_parents": [null], "node": "6b9d943ecc2affe25094a0046dbc498ff2d1b96c", "parents": ["bb5d37aec5da39e6994de97e0c08b6d20050de43"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1522555 - Remove a lot of dead code. r=kvark\n\nWe can always pull this back from history should we need it, but given\nhow broken the texture caching of pictures was (see the recent text shadow\nstory) I suspect we won't.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17524\n", "files": ["gfx/wr/webrender/src/display_list_flattener.rs", "gfx/wr/webrender/src/lib.rs", "gfx/wr/webrender/src/picture.rs", "gfx/wr/webrender/src/render_task.rs", "gfx/wr/webrender/src/surface.rs", "gfx/wr/wrench/reftests/border/border-suite-2.png"], "git_node": null, "git_parents": [null], "node": "0f8a67bf322646794f0b47427f0b74b289f4a2a7", "parents": ["6b9d943ecc2affe25094a0046dbc498ff2d1b96c"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1521686 - Get rid of unused EnsureSharedSurfaceSize() method r=jmathies\n\nThe method was added by bug 506926, but not sure when this becomes an orphan.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17215", "files": ["widget/windows/nsWindowGfx.cpp"], "git_node": null, "git_parents": [null], "node": "bdf350144ce46d0e5ab7974ca365a034bec09457", "parents": ["0f8a67bf322646794f0b47427f0b74b289f4a2a7"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1521694 - Make DisplaySystemMenu() handle all nsSizeMode value r=jmathies\n\nDisplaySystemMenu() does not handle nsSizeMode_Invalid that causes warning of\nclang.  This patch makes it treat nsSizeMode_Invalid.  When it receives the\nvalue, it will call NS_ASSERTION() to be detectable on debug builds during\nautomated tests.\n\nAdditionally, this adds default case into the switch statement with\nMOZ_ASSERT_UNREACHABLE().  Then, when somebody adds new nsSizeMode, they\ncan detect it with crash in debug build if they forget to change this method.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17217", "files": ["widget/windows/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "3883a443b7f893bb8424c8a57ba376bbd1d3d275", "parents": ["bdf350144ce46d0e5ab7974ca365a034bec09457"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1514806: Point partner repack repackage tasks at partner repackage configs. r=aki\n\nThey were incorrectly pointed at the non-partner configs in 2e27f3f1ebc6f38d98ddd42b6955083f637e2b1b.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17716", "files": ["taskcluster/ci/release-eme-free-repack-repackage/kind.yml", "taskcluster/ci/release-partner-repack-repackage/kind.yml"], "git_node": null, "git_parents": [null], "node": "ad292914ca7eb4d20e9315dc50b1b79a1493a994", "parents": ["3883a443b7f893bb8424c8a57ba376bbd1d3d275"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Backed out 4 changesets (bug 1521191) for causing leaks on multiple tests\n\nBacked out changeset 138e162d2778 (bug 1521191)\nBacked out changeset 3782d011cc9f (bug 1521191)\nBacked out changeset 38d3da4804d7 (bug 1521191)\nBacked out changeset d6ce4b187195 (bug 1521191)", "files": ["js/xpconnect/idl/xpccomponents.idl", "js/xpconnect/src/XPCComponents.cpp", "testing/mochitest/tests/python/files/test_negative_leaks.html", "testing/mochitest/tests/python/files/test_no_leak_log.html", "testing/mochitest/tests/python/test_basic_mochitest_plain.py", "testing/mozbase/mozlog/mozlog/handlers/statushandler.py", "xpcom/base/nsTraceRefcnt.cpp", "xpcom/base/nsTraceRefcnt.h"], "git_node": null, "git_parents": [null], "node": "044a86a4032cf1ab76e4cd43f5d7929fcff0c9a0", "parents": ["ad292914ca7eb4d20e9315dc50b1b79a1493a994"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1522989 - Only compare URI specs against parsed URI specs; r=mossop\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17710", "files": ["browser/components/shell/HeadlessShell.jsm"], "git_node": null, "git_parents": [null], "node": "34e24b0fb7b7296e7a4b928dd217b15d2f0d96ac", "parents": ["044a86a4032cf1ab76e4cd43f5d7929fcff0c9a0"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 34e24b0fb7b7 (bug 1522989) for ESLint failures.", "files": ["browser/components/shell/HeadlessShell.jsm"], "git_node": null, "git_parents": [null], "node": "33ca2ea6b37064d12c0d4fefc81bf689396a5e57", "parents": ["34e24b0fb7b7296e7a4b928dd217b15d2f0d96ac"], "tags": []}, {"author": "Zibi Braniecki \u003czbraniecki@mozilla.com\u003e", "branch": "default", "desc": "Bug 1518252 - Make docl10n tests non-racy. r=Pike\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17333", "files": ["intl/l10n/test/dom/test_docl10n.html", "intl/l10n/test/dom/test_docl10n.xhtml", "intl/l10n/test/dom/test_docl10n.xul"], "git_node": null, "git_parents": [null], "node": "4c5dafe7351892a28095a98f8f161f41126168c6", "parents": ["33ca2ea6b37064d12c0d4fefc81bf689396a5e57"], "tags": []}, {"author": "Zibi Braniecki \u003czbraniecki@mozilla.com\u003e", "branch": "default", "desc": "Bug 1518252 - Block layout on Fluent. r=smaug\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17334", "files": ["dom/base/Document.cpp", "dom/base/Document.h", "dom/base/nsContentSink.cpp", "dom/xml/nsXMLContentSink.cpp", "dom/xml/nsXMLContentSink.h", "dom/xul/XULDocument.cpp", "dom/xul/XULDocument.h", "intl/l10n/DocumentL10n.cpp", "intl/l10n/DocumentL10n.h", "parser/html/nsHtml5TreeOpExecutor.cpp", "parser/html/nsHtml5TreeOpExecutor.h", "parser/htmlparser/nsIContentSink.h"], "git_node": null, "git_parents": [null], "node": "9ae7ae0acee4f8807cffaf64fef4f2e3a614b997", "parents": ["4c5dafe7351892a28095a98f8f161f41126168c6"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1520502 - Set the standard cursor and the custom cursor in the same IPC message. r=jmathies\n\nThis cleans up a bit and allows us to be smarter about which cursors\nshould we allow from content or what not, which will help with bug 1445844 and\nco.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16711\n", "files": ["docshell/base/nsDocShell.cpp", "dom/events/EventStateManager.cpp", "dom/ipc/PBrowser.ipdl", "dom/ipc/TabParent.cpp", "dom/ipc/TabParent.h", "widget/PuppetWidget.cpp", "widget/PuppetWidget.h", "widget/android/nsWindow.h", "widget/cocoa/nsChildView.h", "widget/cocoa/nsChildView.mm", "widget/cocoa/nsCocoaWindow.h", "widget/cocoa/nsCocoaWindow.mm", "widget/gtk/nsWindow.cpp", "widget/gtk/nsWindow.h", "widget/nsBaseWidget.cpp", "widget/nsBaseWidget.h", "widget/nsIWidget.h", "widget/windows/nsWindow.cpp", "widget/windows/nsWindow.h"], "git_node": null, "git_parents": [null], "node": "edfd8a13603c0d5ebb69362dff02bb138f616127", "parents": ["9ae7ae0acee4f8807cffaf64fef4f2e3a614b997"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1514511 - Flush the document, not the shell, in Selection::ScrollIntoView. r=bzbarsky\n\nFlushing just the shell is not quite sound, since it doesn't flush parent\ndocuments, and also doesn't have the side effect of ensuring the shell is not\ndestroying and the document is not in the bfcache.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14687\n", "files": ["dom/base/Selection.cpp"], "git_node": null, "git_parents": [null], "node": "da799f611f33fc367cb49193872709c2cd89fd8a", "parents": ["edfd8a13603c0d5ebb69362dff02bb138f616127"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1514511 - Don't flush if the document is in the bfcache. r=bzbarsky\n\nI think this is slightly better fix given the amount of offenders we have that\ndon't make sure this is the case.\n\nGenerally we get through the flush just fine, but there's code that relies on\nnsIDocument::GetShell to return something meaningful, like the styleset code\nthat gets a pres context.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14689\n", "files": ["layout/base/PresShell.cpp"], "git_node": null, "git_parents": [null], "node": "8f22c3daa581e0f5c89f7ee6a8e74f6a00e3d7fd", "parents": ["da799f611f33fc367cb49193872709c2cd89fd8a"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1522630 - Report content blocking status notifications from the idle event queue; r=baku\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17554\n", "files": ["browser/base/content/test/trackingUI/browser_trackingUI_animation.js", "browser/base/content/test/trackingUI/browser_trackingUI_animation_2.js", "browser/base/content/test/trackingUI/browser_trackingUI_pbmode_exceptions.js", "browser/base/content/test/trackingUI/browser_trackingUI_state.js", "browser/base/content/test/trackingUI/browser_trackingUI_state_all_disabled.js", "dom/base/nsGlobalWindowOuter.cpp"], "git_node": null, "git_parents": [null], "node": "6cdc3830637550efc203c376f4ff1db55898b6d9", "parents": ["fd3b826ffad16e702bffe988c84ab922df1d03c1"], "tags": []}, {"author": "Jeff Walden \u003cjwalden@mit.edu\u003e", "branch": "default", "desc": "Bug 1522846 - Add a missing #include.  r=unified-builds-strike-again", "files": ["js/src/wasm/AsmJS.cpp"], "git_node": null, "git_parents": [null], "node": "754797f49a6123806a7cc24eeb3ea0c317eaa679", "parents": ["6cdc3830637550efc203c376f4ff1db55898b6d9"], "tags": []}, {"author": "Eric Rahm \u003cerahm@mozilla.com\u003e", "branch": "default", "desc": "Bug 1515833 - Remove verbose nsIURIMutator warnings. r=ehsan, valentin", "files": ["netwerk/base/nsIURIMutator.idl"], "git_node": null, "git_parents": [null], "node": "a05c9040d245324e6cb9a2380c1f87a69a8e4d6f", "parents": ["754797f49a6123806a7cc24eeb3ea0c317eaa679"], "tags": []}, {"author"