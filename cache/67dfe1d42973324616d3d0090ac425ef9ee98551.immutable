anch": "default", "desc": "Bug 1529139 - Add proper dependencies for win{32,64}.asm. r=froydnj, a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D20587", "files": ["config/external/ffi/moz.build", "config/external/ffi/preprocess_libffi_asm.py"], "git_node": null, "git_parents": [null], "node": "53e4e8116497537edfee2007838079d437cd1b0f", "parents": ["009f023e478cf643f46136951c78887e578ce02d"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1529139 - Mark .asm GENERATED_FILES as required_for_compile. r=froydnj, a=lizzard\n\nThis will avoid trying to generate them during artifact builds.\n\nDepends on D20587\n\nDifferential Revision: https://phabricator.services.mozilla.com/D20436", "files": ["python/mozbuild/mozbuild/frontend/data.py"], "git_node": null, "git_parents": [null], "node": "d1f8173046a0e34410ae3b9574746a8d26c6102a", "parents": ["53e4e8116497537edfee2007838079d437cd1b0f"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1527471 - part 1 - preprocess aarch64 windows assembly xptcall files; r=dmajor, a=lizzard\n\nWe need to preprocess these files so we can eventually add unwind\ninformation, for which we need to include C headers.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D19819", "files": ["xpcom/reflect/xptcall/md/win32/moz.build", "xpcom/reflect/xptcall/md/win32/preprocess.py"], "git_node": null, "git_parents": [null], "node": "37dca6044dcba5ce00e928ce363f63a0f2118542", "parents": ["d1f8173046a0e34410ae3b9574746a8d26c6102a"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1527471 - part 2 - generate unwind data for xptcall aarch64 windows routines; r=dmajor, a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D19820", "files": ["xpcom/reflect/xptcall/md/win32/xptcinvoke_asm_aarch64.asm", "xpcom/reflect/xptcall/md/win32/xptcstubs_asm_aarch64.asm"], "git_node": null, "git_parents": [null], "node": "8d7fe5194e9399f47dd1a3abe65722c6b03cf78d", "parents": ["37dca6044dcba5ce00e928ce363f63a0f2118542"], "tags": []}, {"author": "Matthew Noorenberghe \u003cmozilla@noorenberghe.ca\u003e", "branch": "default", "desc": "Bug 1439023 - Don't reset autocomplete controller state when autofill fell back to form history. r=jaws, a=lizzard\n\nOtherwise the cached value won't be used for filling by satchel and _fillFromAutocompleteRow won't fill a result that isn't a `autofill-profile` style:\nhttps://searchfox.org/mozilla-central/rev/03ebbdab952409640c6857d835d3040bf6f9e2db/browser/extensions/formautofill/FormAutofillContent.jsm#283,295\n\nDifferential Revision: https://phabricator.services.mozilla.com/D19249", "files": ["browser/extensions/formautofill/FormAutofillContent.jsm", "browser/extensions/formautofill/test/mochitest/test_basic_autocomplete_form.html", "toolkit/content/widgets/autocomplete.xml"], "git_node": null, "git_parents": [null], "node": "c6abdbd324f774a4e3fe0edf7dcb2a5fa03f26eb", "parents": ["8d7fe5194e9399f47dd1a3abe65722c6b03cf78d"], "tags": []}], "date": 1550834315, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null], "user": "jcristau@mozilla.com"}, "10755": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging e0a8013cd9c9723b19427ca24e7202e37822e3ad with DEVEDITION_66_0b10_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "e4171c06f422b19fa9fb2b80a7b7e802395c2daa", "parents": ["c6abdbd324f774a4e3fe0edf7dcb2a5fa03f26eb"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release DONTBUILD", "files": ["browser/config/version_display.txt"], "git_node": null, "git