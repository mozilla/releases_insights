dules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "8dbc1d23274ba19af8a4de8d65e00d78a1c71364", "parents": ["2ef74ac16e16dce976bd815a7db5ab14e5e5b3f1"], "tags": []}, {"author": "Brendan Dahl \u003cbdahl@mozilla.com\u003e", "branch": "default", "desc": "Bug 1524640 - Fix font loading during mozPrintCallback. r=smaug a=lizzard\n\nCopy fonts loaded during a mozPrintCallback into the cloned document,\nso they are available during printing.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D18613", "files": ["dom/base/Document.cpp", "dom/base/Document.h", "layout/base/tests/chrome/chrome.ini", "layout/base/tests/chrome/printpreview_font_mozprintcallback.html", "layout/base/tests/chrome/printpreview_font_mozprintcallback_ref.html", "layout/base/tests/chrome/printpreview_helper.xul", "layout/style/FontFaceSet.cpp"], "git_node": null, "git_parents": [null], "node": "aab4fc980d3cda9ea781c95f4e331d7291ef75ed", "parents": ["8dbc1d23274ba19af8a4de8d65e00d78a1c71364"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1523556 - [Linux/Gtk+] Don't apply titlebar shape mask to maximized windows, r=dao a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D18823", "files": ["widget/gtk/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "2589bf262f6576b3e0bce80179c54691fc28c21e", "parents": ["aab4fc980d3cda9ea781c95f4e331d7291ef75ed"], "tags": []}], "date": 1551103225, "git_changesets": [null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "10770": {"changesets": [{"author": "Bas Schouten \u003cbschouten@mozilla.com\u003e", "branch": "default", "desc": "Bug 1526045: Avoid invalid DrawTargets when not using OMTP. r=rhunt a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D20182", "files": ["gfx/layers/client/ClientPaintedLayer.cpp"], "git_node": null, "git_parents": [null], "node": "91995baa7317a9f8db9ce9e288