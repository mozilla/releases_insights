s.html", "toolkit/components/passwordmgr/test/pwmgr_common.js"], "git_node": null, "git_parents": [null], "node": "44d70ce90650a6b4510702aee24c7a2b360bbde7", "parents": ["138e162d2778d37a1b3cc474aade64647bbc1bd6"], "tags": []}, {"author": "Kirk Steuber \u003cksteuber@mozilla.com\u003e", "branch": "default", "desc": "Bug 1512302 - Indicate on Windows that the App Update setting is installation-specific r=jaws,flod\n\nDifferential Revision: https://phabricator.services.mozilla.com/D15987", "files": ["browser/components/preferences/in-content/main.js", "browser/components/preferences/in-content/main.xul", "browser/locales/en-US/browser/preferences/preferences.ftl", "browser/themes/shared/incontentprefs/preferences.inc.css"], "git_node": null, "git_parents": [null], "node": "84c61304b73d777e097faad48719a7aef96763f8", "parents": ["44d70ce90650a6b4510702aee24c7a2b360bbde7"], "tags": []}, {"author": "Justin Wood \u003cCallek@gmail.com\u003e", "branch": "default", "desc": "Bug 1518570 - Missed followup item, no need to mark oak as a trunk project. r=tomprince\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17685", "files": ["taskcluster/taskgraph/util/attributes.py"], "git_node": null, "git_parents": [null], "node": "4c4c607eebde77c96daaf1cef857af71e35482b3", "parents": ["84c61304b73d777e097faad48719a7aef96763f8"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 49b9a79baf65 (bug 1483701) for brwoser-chrome failures in browser/components/extensions/test/browser/browser_ext_browserAction_popup_resize.js. CLOSED TREE", "files": ["browser/components/extensions/test/browser/browser-common.ini", "browser/components/extensions/test/browser/browser_ext_browserAction_popup_resize.js", "browser/components/extensions/test/browser/browser_ext_browserAction_popup_resize_bottom.js", "browser/components/extensions/test/browser/head.js", "browser/components/extensions/test/browser/head_browserAction.js"], "git_node": null, "git_parents": [null], "node": "f0e2ba567625f319225324410315ed9bd07ce1f4", "parents": ["4c4c607eebde77c96daaf1cef857af71e35482b3"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1514007 - Annotate \u003cscript\u003e evaluation profiler labels with async/defer. r=smaug\n\nThis also moves the label from ScriptLoader::ProcessScriptElement to\nScriptLoader::EvaluateScript so that it also kicks in for scripts that are run\nfrom NotifyOffThreadScriptLoadCompletedRunnable::Run.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14924", "files": ["dom/script/ScriptLoader.cpp"], "git_node": null, "git_parents": [null], "node": "bf7da92f820b53dac3eb98a313f976203cfc59b6", "parents": ["f0e2ba567625f319225324410315ed9bd07ce1f4"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1521837 - Fix margin-inline-end on about:addons options button r=dao\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17592", "files": ["toolkit/themes/shared/extensions/extensions.inc.css"], "git_node": null, "git_parents": [null], "node": "29af553e9ff2e0c5e162d510655486b786fba68d", "parents": ["bf7da92f820b53dac3eb98a313f976203cfc59b6"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1522417 - Add diagnostics. r=jwatt\n\nI haven't managed to find a way stuff should unexpectedly die around these\nfunctions, so add a few diagnostics to catch this hopefully, before papering\nover the bug / backing out / adding a kungfudeathgrip.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17514", "files": ["layout/style/nsFontFaceLoader.cpp", "layout/style/nsFontFaceLoader.h"], "git_node": null, "git_parents": [null], "node": "0fc47438d8372975cc9d75740e6a0f7a3723ed2d", "parents": ["29af553e9ff2e0c5e162d510655486b786fba68d"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1521881 - Back button for about:addons shortcuts and details views r=mixedpuppy,flod\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17673", "files": ["toolkit/locales/en-US/toolkit/about/aboutAddons.ftl", "toolkit/mozapps/extensions/content/extensions.js", "toolkit/mozapps/extensions/content/extensions.xul", "toolkit/themes/shared/extensions/extensions.inc.css"], "git_node": null, "git_parents": [null], "node": "a6797d9a2e80369f6f4c098200a7b0016c49cf46", "parents": ["0fc47438d8372975cc9d75740e6a0f7a3723ed2d"], "tags": []}, {"author": "Dave Townsend \u003cdtownsend@oxymoronical.com\u003e", "branch": "default", "desc": "Backing out bug 1518799 since it was a feature only required for a short period and there is no need for it to exist anymore. r=backout", "files": ["browser/branding/nightly/pref/firefox-branding.js", "browser/components/nsBrowserContentHandler.js"], "git_node": null, "git_parents": [null], "node": "c2738c6922b7a35e1890e5f11204613df5a1af7d", "parents": ["41ef0bc87fd631b29287edb0a1b711bf2d9143fd"], "tags": []}, {"author": "Jeff Walden \u003cjwalden@mit.edu\u003e", "branch": "default", "desc": "Bug 1522710 - Assert |!mod-\u003eisZero()| in bigint code where such is not entirely obvious unless you think about it.  r=terpri", "files": ["js/src/vm/BigIntType.cpp"], "git_node": null, "git_parents": [null], "node": "fd3b826ffad16e702bffe988c84ab922df1d03c1", "parents": ["c2738c6922b7a35e1890e5f11204613df5a1af7d"], "tags": []}, {"author": "Coroiu Cristina \u003cccoroiu@mozilla.com\u003e", "branch": "default", "desc": "Merge inbound to mozilla-central a=merge", "files": ["browser/app/profile/firefox.js", "js/src/vm/BigIntType.cpp", "toolkit/components/antitracking/AntiTrackingCommon.cpp"], "git_node": null, "git_parents": [null, null], "node": "e4b9b1084292686d3eb50ba0cadd85950824c955", "parents": ["88a48f21fa684c6172a23fc150eb5c5571285004", "fd3b826ffad16e702