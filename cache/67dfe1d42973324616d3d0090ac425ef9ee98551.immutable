ad636fc9ec9010dd605f72fdc47b94", "parents": ["ba9f9c0ce2561b72c6dedd0bf5817ba452bb4638"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1514164 - Enable running some of the urlbar tests against QuantumBar. r=mak\n\nAlthough these tests are all able to pass individually, some still fail when run together. Bug 1521490 will address those.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17111", "files": ["browser/components/urlbar/tests/browser/browser.ini"], "git_node": null, "git_parents": [null], "node": "3ee7a4b57a9a955db8ba8d8f961754c4db638ebc", "parents": ["306a66424aad636fc9ec9010dd605f72fdc47b94"], "tags": []}, {"author": "Michael Ratcliffe \u003cmratcliffe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1521026 - Flex highlighter shouldn't scroll for position:fixed elements r=gl\n\nThis fixes the issue but because of our virtual canvas implementation and the\nfact that reflow events are batched there is quite a bit of flicker and some\ndrag (see attached video).\n\nUnfortunately, until bug 1509071 is implemented (full screen canvas using\n`position:fixed`) we can't really do anything about the flicker... I suppose we\ncould stop batching reflow events but that would make all of our highlighters\nunusably slow.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16988", "files": ["devtools/server/actors/highlighters/flexbox.js", "devtools/shared/layout/utils.js"], "git_node": null, "git_parents": [null], "node": "dc8bd111db7000fdc8c3c8a448771e8a5900339c", "parents": ["3ee7a4b57a9a955db8ba8d8f961754c4db638ebc"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 901059 - Clean up old unused mobile/android package-manifest.in references. r=agi,froydnj\n\nI'm taking an old ticket number just to close it.  The files removed\nno longer exist in the tree; the NSS option exists and probably\nshouldn't -- but that's for another day, so let's just make it not\nwarn for now.\n\nDepends on D15016\n\nDifferential Revision: https://phabricator.services.mozilla.com/D15017", "files": ["mobile/android/installer/Makefile.in", "mobile/android/installer/package-manifest.in"], "git_node": null, "git_parents": [null], "node": "2717febc588c1e7145af3a68cb0f932fa0cb6f81", "parents": ["dc8bd111db7000fdc8c3c8a448771e8a5900339c"], "tags": []}, {"author": "Sylvestre Ledru \u003csledru@mozilla.com\u003e", "branch": "default", "desc": "Bug 1521391 - Use the old code path with gcc to fix a build issue with gcc-8 r=bas\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17083", "files": ["gfx/2d/PathHelpers.h"], "git_node": null, "git_parents": [null], "node": "67b3cbf805e1820721d162dd497aef10ed9eabea", "parents": ["2717febc588c1e7145af3a68cb0f932fa0cb6f81"], "tags": []}, {"author": "Sylvestre Ledru \u003csledru@mozilla.com\u003e", "branch": "default", "desc": "Bug 1519636 - Ride along: remove unbreakable spaces r=Ehsan\n\nDepends on D17063\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17064", "files": [".git-blame-ignore-revs"], "git_node": null, "git_parents": [null], "node": "2307fb1cfa80a5d4cf05c404917344510a982194", "parents": ["67b3cbf805e1820721d162dd497aef10ed9eabea"], "tags": []}, {"author": "Ricky Rosario \u003crickyrosario@gmail.com\u003e", "branch": "default", "desc": "Bug 1508364 - New UI for Private Browsing with Search r=andreio\n\nMozReview-Commit-ID: 4WSGpL5Gvde\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16854", "files": ["browser/app/profile/firefox.js", "browser/components/about/AboutPrivateBrowsingHandler.jsm", "browser/components/nsBrowserGlue.js", "browser/components/privatebrowsing/content/aboutPrivateBrowsing.css", "browser/components/privatebrowsing/content/aboutPrivateBrowsing.js", "browser/components/privatebrowsing/content/aboutPrivateBrowsing.xhtml", "browser/components/privatebrowsing/test/browser/browser_privatebrowsing_about.js", "browser/themes/shared/privatebrowsing/aboutPrivateBrowsing.css", "toolkit/components/remotepagemanager/MessagePort.jsm"], "git_node": null, "git_parents": [null], "node": "13f379946829814f44e8e7b192ac4dd4e93d6959", "parents": ["2307fb1cfa80a5d4cf05c404917344510a982194"], "tags": []}, {"author": "Razvan Maries \u003crmaries@mozilla.com\u003e", "branch": "default", "desc": "Merge autoland to mozilla-central a=merge", "files": [], "git_node": null, "git_parents": [null, null], "node": "4977d02e11915a93c6c80a51f3e7bdc99d5e2f08", "parents": ["e43944736829dc575bb12821f0e28bf1bc02c285", "d536f45f5b166c4b9562caf0c41991cb5df831cc"], "tags": []}, {"author": "Razvan Maries \u003crmaries@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-inbound to mozilla-central a=merge", "files": ["dom/base/nsGlobalWindowOuter.cpp", "dom/script/ScriptLoader.cpp", "dom/smil/nsSMILInterval.cpp", "dom/smil/nsSMILInterval.h", "dom/smil/nsSMILRepeatCount.cpp", "dom/smil/nsSMILRepeatCount.h", "js/src/gc/GC.cpp", "js/src/gc/Statistics.cpp", "js/src/gc/Statistics.h", "js/src/jit/arm/AtomicOperations-arm.h", "js/src/jit/arm64/AtomicOperations-arm64-gcc.h", "js/src/jit/arm64/AtomicOperations-arm64-msvc.h", "js/src/jit/none/AtomicOperations-feeling-lucky.h", "js/src/jit/x86-shared/AtomicOperations-x86-shared-gcc.h", "js/src/jit/x86-shared/AtomicOperations-x86-shared-msvc.h", "js/src/jsapi.cpp"], "git_node": null, "git_parents": [null, null], "node": "44369796f148630ff496be99f77a5eeea41c7d23", "parents": ["4977d02e11915a93c6c80a51f3e7bdc99d5e2f08", "b1f8fe42b1a80800368724ebbff8e5097e632511"], "tags": []}, {"author": "Razvan Maries \u003crmaries@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland. a=merge on a CLOSED TREE", "files": ["dom/smil/nsSMILInterval.cpp", "dom/smil/nsSMILInterval.h", "dom/smil/nsSMILRepeatCount.cpp", "dom/smil/nsSMILRepeatCount.h"], "git_node": null, "git_parents": [null, null], "node": "f851b150476a2259413390d4510f27ed62a1d1c2", "parents": ["13f379946829814f44e8e7b192ac4dd4e93d6959", "44369796f148630ff496be99f77a5eeea41c7d23"], "tags": []}, {"author": "Michael Ratcliffe \u003cmratcliffe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1521547 - Add container getter to flexbox highlighter to make the code easier to understand r=pbro\n\nThis is simply to make the code easier to read (it simply adds a `get container =\u003e this.currentNode` to make things easier to read) so it doesn't require any familiarity with the code itself.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17135", "files": ["devtools/server/actors/highlighters/flexbox.js"], "git_node": null, "git_parents": [null], "node": "53d1b01b992467d1ab77ab9023444098280ba7a6", "parents": ["f851b150476a2259413390d4510f27ed62a1d1c2"], "tags": []}, {"author": "Barret Rennie \u003cbarret@brennie.ca\u003e", "branch": "default", "desc": "Bug 1444447 - While recording profile screenshots, create a full-window render target and buffer all draws to it r=mstange\n\nOn some platforms we do not always have a DrawTarget that is the size of the\nentire window, so we will be unable to record the contents into screenshots in\nthe profiler output. Now we create an additional DrawTarget that will contain\nthe contents of the entire window so that we can record it for screenshots.\nThis only adds the overhead of allocation while profiling and only when\nscreenshots are requested.\n\nThe initial screenshots end up blank but then the following screenshots are\nrendered correctly.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14874", "files": ["gfx/layers/basic/BasicCompositor.cpp", "gfx/layers/basic/BasicCompositor.h"], "git_node": null, "git_parents": [null], "node": "a115176a8faa34bb59da329fc5d458f5ab7f9267", "parents": ["53d1b01b992467d1ab77ab9023444098280ba7a6"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1444447 - Implement AsyncReadbackBuffer Compositor APIs for BasicCompositor r=mstange\n\nDepends on D14874\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14875", "files": ["gfx/layers/basic/BasicCompositor.cpp", "gfx/layers/basic/BasicCompositor.h"], "git_node": null, "git_parents": [null], "node": "28e336f7b9da63ef319650a7bd698289574a4f11", "parents": ["a115176a8faa34bb59da329fc5d458f5ab7f9267"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1444447 - Implement Compositor::BlitRenderTarget for BasicCompositor r=mstange\n\nDepends on D14875\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14876", "files": ["gfx/layers/basic/BasicCompositor.cpp", "gfx/layers/basic/BasicCompositor.h"], "git_node": null, "git_parents": [null], "node": "a70ed4f3086ae9e117c3e46f99fd40122bc07dc6", "parents": ["28e336f7b9da63ef319650a7bd698289574a4f11"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1513458 - Add more specific MOZ_DIAGNOSTIC_ASSERTS to TransportSecurityInfo::Read in order to pinpoint crashes r=mayhemer\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16828", "files": ["security/manager/ssl/TransportSecurityInfo.cpp"], "git_node": null, "git_parents": [null], "node": "243733368484c9c41548d6acef5b6273be5f7948", "parents": ["a70ed4f3086ae9e117c3e46f99fd40122bc07dc6"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1521527 - [marionette] Don't raise timeout errors for all window manipulation commands. r=ato\n\nMarionette should do its best to get the browser into the requested\nwindow state, but if it is not possible to do so, it shouldn't raise\na timeout error. This is mostly the case when running tests under\nxvfb with no window manager running. Instead we just log the\nmessage for further investigation.\n\nFurther the timeout value has to be set to a value which wouldn't\ncause the commands to inappropriately fail due to animations, or\na slow machine.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17144", "files": ["testing/marionette/driver.js"], "git_node": null, "git_parents": [null], "node": "4aafc1f415adc5a3ab80630b94291968b3a84eb2", "parents": ["243733368484c9c41548d6acef5b6273be5f7948"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1520509.  Remove the unused support for CrossOriginWritable=InterfaceName in Web IDL.  r=qdot\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16712", "files": ["dom/bindings/Codegen.py", "dom/bindings/parser/WebIDL.py"], "git_node": null, "git_parents": [null], "node": "fcef3b13bb1c0ea091dc09a07e35ad758e0a56f2", "parents": ["4aafc1f415adc5a3ab80630b94291968b3a84eb2"], "tags": []}, {"author": "Razvan Caliman \u003crcaliman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1507103 - Account for empty circle() and ellipse() in Shape Path Editor. r=gl\n\nThis patch handles empty circle() and ellipse() basic shape definitions.\n\nTheir computed values will hold default values for center and radius.\n\nFor circle(), it is just a case of treating identifiers like \"center\"\nas unitless to allow falling back to computed sizes and pixels.\nFor ellipse(), the solution is identical, but the issue is compounded\nby an incomplete computed style value tracked in Bug 1521508 which is\nmissing the default values for x and y radii.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D17129", "files": ["devtools/server/actors/highlighters/shapes.js"], "git_node": null, "git_parents": [null], "node": "e25a1ed32b5347b86843580e66b344bf11dcceba", "parents": ["fcef3b13bb1c0ea091dc09a07e35ad758e0a56f2"], "tags": []}, {"author": "arthur.iakab \u003caiakab@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 13f379946829 (bug 1508364) for functional ui test