33c0c95178d0066db\nwpt-pr: 14559\n", "files": ["testing/web-platform/tests/tools/wpt/run.py", "testing/web-platform/tests/tools/wpt/testfiles.py"], "git_node": null, "git_parents": [null], "node": "f06683d150faab1d3bd554d6a8dae13276d4b270", "parents": ["ff9fa16f3af38e3521bc304e5700b84d5dcbb696"], "tags": []}, {"author": "pyup.io bot \u003cgithub-bot@pyup.io\u003e", "branch": "default", "desc": "Bug 1514450 [wpt PR 14534] - Update requests to 2.21.0, a=testonly\n\nAutomatic update from web-platform-tests\nUpdate requests from 2.20.1 to 2.21.0 (#14534)\n\n--\n\nwpt-commits: 10945ec5f18b7ff0fd43f0bd6737764e357930a5\nwpt-pr: 14534\n", "files": ["testing/web-platform/tests/tools/wpt/requirements.txt"], "git_node": null, "git_parents": [null], "node": "d5198e02a8cbd1f5a8eaf3a72694e19247b05c61", "parents": ["f06683d150faab1d3bd554d6a8dae13276d4b270"], "tags": []}, {"author": "Florian Rivoal \u003cgit@florian.rivoal.net\u003e", "branch": "default", "desc": "Bug 1514663 [wpt PR 14551] - [css-text] Correct test metadata, a=testonly\n\nAutomatic update from web-platform-tests\n[css-text] Correct test metadata (#14551)\n\nThe section title is out of date and unneeded. Deleting it.\n\nThe link is broken. Fixing it.\n--\n\nwpt-commits: eb97f99b6065746b50ce41d313908acd06dbe600\nwpt-pr: 14551\n", "files": ["testing/web-platform/tests/css/css-text/overflow-wrap/overflow-wrap-001.html", "testing/web-platform/tests/css/css-text/overflow-wrap/overflow-wrap-002.html", "testing/web-platform/tests/css/css-text/overflow-wrap/overflow-wrap-004.html", "testing/web-platform/tests/css/css-text/overflow-wrap/word-wrap-001.html", "testing/web-platform/tests/css/css-text/overflow-wrap/word-wrap-002.html", "testing/web-platform/tests/css/css-text/overflow-wrap/word-wrap-004.html"], "git_node": null, "git_parents": [null], "node": "55d30d5085f4ac1a626a48a98a7a6fb4825cab07", "parents": ["d5198e02a8cbd1f5a8eaf3a72694e19247b05c61"], "tags": []}, {"author": "Geoffrey Sneddon \u003cme@gsnedders.com\u003e", "branch": "default", "desc": "Bug 1514743 [wpt PR 14563] - Remove support for testharness/reftest tests in IE, a=testonly\n\nAutomatic update from web-platform-tests\nRemove support for testharness/reftest tests in IE\n\nIn reality, all that's been run for a long time is WebDriver tests,\nand the testharness/reftest automation scripts almost certainly don't\nwork in any version of IE.\n\n--\n\nwpt-commits: 05f3782ecc4b912a2dea73f2243edcfaa6eab32c\nwpt-pr: 14563\n", "files": ["testing/web-platform/tests/tools/wptrunner/wptrunner/browsers/ie.py"], "git_node": null, "git_parents": [null], "node": "7dd3897db7501f652d35669100b325a3cf683e9d", "parents": ["55d30d5085f4ac1a626a48a98a7a6fb4825cab07"], "tags": []}, {"author": "Mike West \u003cmike@mikewest.org\u003e", "branch": "default", "desc": "Bug 1514685 [wpt PR 14557] - Ship strict MIME checks for 'importScripts()', a=testonly\n\nAutomatic update from web-platform-tests\nShip strict MIME checks for 'importScripts()' (#14557)\n\nSupporting https://github.com/whatwg/html/pull/4001.\n--\n\nwpt-commits: cac03f7400d61442996918e051671b2267ef2409\nwpt-pr: 14557\n", "files": ["testing/web-platform/tests/workers/importscripts_mime.any.js", "testing/web-platform/tests/workers/importscripts_mime.tentative.any.js"], "git_node": null, "git_parents": [null], "node": "d9ab60a2ad83c0c45666f6f988f92efe6297d0c8", "parents": ["7dd3897db7501f652d35669100b325a3cf683e9d"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1514685 [wpt PR 14557] - Update wpt metadata, a=testonly\n\nwpt-pr: 14557\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/workers/importscripts_mime.any.js.ini", "testing/web-platform/meta/workers/importscripts_mime.tentative.any.js.ini"], "git_node": null, "git_parents": [null], "node": "c31c529da3777d96406507681f84fc1b1b960e79", "parents": ["d9ab60a2ad83c0c45666f6f988f92efe6297d0c8"], "tags": []}, {"author": "Manuel Rego Casasnovas \u003crego@igalia.com\u003e", "branch": "default", "desc": "Bug 1514838 [wpt PR 14567] - [css-contain] Layout containment suppress baseline, a=testonly\n\nAutomatic update from web-platform-tests\n[css-contain] Layout containment suppress baseline\n\nWe were not suppressing baseline in all the cases.\nThis patch fixes the bug detected by Mozilla test\ncontain-layout-suppress-baseline-002.html.\nAt the same time it adds a new test for more elements,\nhowever it's not passing yet due to a different bug crbug.com/671132.\n\nBUG=909599\nTEST=external/wpt/css/css-contain/contain-layout-baseline-005.html\nTEST=external/wpt/css/vendor-imports/mozilla/mozilla-central-reftests/contain/contain-layout-suppress-baseline-002.html\n\nChange-Id: Id1b984aae1f2a21f655b9c1e42a54115d0a4659c\nReviewed-on: https://chromium-review.googlesource.com/c/1380033\nReviewed-by: Emil A Eklund \u003ceae@chromium.org\u003e\nReviewed-by: Morten Stenshorne \u003cmstensho@chromium.org\u003e\nCommit-Queue: Manuel Rego \u003crego@igalia.com\u003e\nCr-Commit-Position: refs/heads/master@{#617195}\n\n--\n\nwpt-commits: 3cdc983b76e09616fbb19077acb8c19ca617dd98\nwpt-pr: 14567\n", "files": ["testing/web-platform/tests/css/css-contain/contain-layout-baseline-005.html", "testing/web-platform/tests/css/css-contain/reference/contain-layout-baseline-005-ref.html"], "git_node": null, "git_parents": [null], "node": "321a70c6ebd2ee4a6a4043942f0ecb39f53b777e", "parents": ["c31c529da3777d96406507681f84fc1b1b960e79"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1514838 [wpt PR 14567] - Update wpt metadata, a=testonly\n\nwpt-pr: 14567\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/css/css-contain/contain-layout-baseline-005.html.ini"], "git_node": null, "git_parents": [null], "node": "05f3afea910e6291eec9ce5a1b395f2ad290c276", "parents": ["321a70c6ebd2ee4a6a4043942f0ecb39f53b777e"], "tags": []}, {"author": "Joshua Bell \u003cjsbell@chromium.org\u003e", "branch": "default", "desc": "Bug 1514091 [wpt PR 14509] - TextDecoder: previous failure should not stick around, a=testonly\n\nAutomatic update from web-platform-tests\nTextDecoder: previous failure should not stick around\n\nWhen the {fatal:true} option is used, the decode() calls throw rather\nthan generating U+FFFD on bad data. Subsequent decode() calls should\nwork as the codec state should be flushed (unless {stream:true} was\nspecified).\n\nBlink was not flushing the codec state, so subsequent calls would\nthrow. Fix by flushing the codec state (instantiating a new codec),\nand align the implementation's code flow/state more closely with the\nspec. Also added a new WPT test case, based on the bug report.\n\nBug: 910292\nChange-Id: Ia47b902b69a4b469341e272ed42bb6b05248c1d8\nReviewed-on: https://chromium-review.googlesource.com/c/1376656\nReviewed-by: Adam Rice \u003cricea@chromium.org\u003e\nCommit-Queue: Joshua Bell \u003cjsbell@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#617215}\n\n--\n\nwpt-commits: a093a659ed118112138f8a1ffba97a66c1ea8235\nwpt-pr: 14509\n", "files": ["testing/web-platform/tests/encoding/textdecoder-fatal.any.js"], "git_node": null, "git_parents": [null], "node": "8131e0336d28bc61a7da2dd9645887b8ec68c2e6", "parents": ["05f3afea910e6291eec9ce5a1b395f2ad290c276"], "tags": []}, {"author": "Florian Rivoal \u003cgit@florian.rivoal.net\u003e", "branch": "default", "desc": "Bug 1514952 [wpt PR 14574] - [css-text] Improve metadata, a=testonly\n\nAutomatic update from web-platform-tests\n[css-text] Improve metadata\n\nFix rel=help link, and rephrase assert.\n\n--\n\nwpt-commits: 209cda5499c72e49d4ad1a52816e9aaf1d9085e4\nwpt-pr: 14574\n", "files": ["testing/web-platform/tests/css/css-text/overflow-wrap/overflow-wrap-break-word-fit-content-001.html"], "git_node": null, "git_parents": [null], "node": "de2be76ffd366e3db6374657e3146a9ca2d30c87", "parents": ["8131e0336d28bc61a7da2dd9645887b8ec68c2e6"], "tags": []}, {"author": "Florian Rivoal \u003cgit@florian.rivoal.net\u003e", "branch": "default", "desc": "Bug 1514953 [wpt PR 14575] - [css-text] Remove \"exploratory\" comment for test backed up by the spec, a=testonly\n\nAutomatic update from web-platform-tests\n[css-text] Remove \"exploratory\" comment for test backed up by the spec\n\nThe comment about this test being exploratory is wrong.\nAssuming that the claim that\n  \u201cpeople using indic scripts expect the user agent\n  to keep the orthographic syllable as a single unit\u201d\nis true, the spec definition's of typographic character/letter unit\nare sufficient to justify the test.\n\n--\n\nwpt-commits: 691e737caf050c5aac0f9675409d73238a3f55d2\nwpt-pr: 14575\n", "files": ["testing/web-platform/tests/css/css-text/word-break/word-break-break-all-008.html"], "git_node": null, "git_parents": [null], "node": "e9b3326a79050b49c12fb0f9effea94222f8808d", "parents": ["de2be76ffd366e3db6374657e3146a9ca2d30c87"], "tags": []}, {"author": "Florian Rivoal \u003cgit@florian.rivoal.net\u003e", "branch": "default", "desc": "Bug 1514956 [wpt PR 14576] - [css-text] Fix typo in value name, a=testonly\n\nAutomatic update from web-platform-tests\n[css-text] Fix typo in value name\n\n--\n\nwpt-commits: c022477503a2df44cd5b233e5d04a437dadd8395\nwpt-pr: 14576\n", "files": ["testing/web-platform/tests/css/css-text/white-space/pre-wrap-015.html"], "git_node": null, "git_parents": [null], "node": "7d14383c78ae5b9198665389f33390fe2ddeafc3", "parents": ["e9b3326a79050b49c12fb0f9effea94222f8808d"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1515043 - [wpt-sync] Update web-platform-tests to 8506febdb9bdce487ef7e4ff91e9b70853019b38, a=testonly\n\nwpt-head: 8506febdb9bdce487ef7e4ff91e9b70853019b38\nwpt-type: landing\n", "files": ["testing/web-platform/meta/2dcontext/drawing-text-to-the-canvas/2d.text.draw.fontface.notinpage.html.ini", "testing/web-platform/meta/FileAPI/url/multi-global-origin-serialization.sub.ht