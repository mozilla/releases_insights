], "git_node": null, "git_parents": [null], "node": "9b0e6c52f47096884e540f069194135a4ac56a34", "parents": ["7fb6548db01e2bd66521f7b012adda5acd65049e"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1511232 - Additional test expectation adjustments for test_window_define_nonconfigurable.html for non-Trunk trees. a=test-only", "files": ["dom/base/test/test_window_define_nonconfigurable.html"], "git_node": null, "git_parents": [null], "node": "a13db67049a28292318e12077d448f8a1a70b2a1", "parents": ["9b0e6c52f47096884e540f069194135a4ac56a34"], "tags": []}], "date": 1544640932, "git_changesets": [null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "10327": {"changesets": [{"author": "Noemi Erli \u003cnerli@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset ac3f8e63166b (bug 1512037) for causing Android build bustages", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoSystemStateListener.java"], "git_node": null, "git_parents": [null], "node": "b0e263db0edfe55fb69c5dd6015f73d6b52a2d23", "parents": ["a13db67049a28292318e12077d448f8a1a70b2a1"], "tags": []}], "date": 1544641993, "git_changesets": [null], "user": "nerli@mozilla.com"}, "10328": {"changesets": [{"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1512037 - Bail out from prefersReducedMotion() if the target device is Android 4.1 or older. r=snorp a=jcristau\n\nSettings.Global can't be used on such devices.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14226", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoSystemStateListener.java"], "git_node": null, "git_parents": [null], "node": "022e5d97749fbc7d6dc167eebe302610d9f75edc", "parents": ["b0e263db0edfe55fb69c5dd6015f73d6b52a2d23"], "tags": []}], "date": 1544643938, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "10329": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging b1216967cdd01665e807bea431a7b18d9ac169e2 with DEVEDITION_65_0b4_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "ba961685a318cb2665cc65154e305ca01ef7c615", "parents": ["022e5d97749fbc7d6dc167eebe302610d9f75edc"], "tags": []}], "date": 1544708009, "git_changesets": [null], "user": "ffxbld"}, "10330": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging b1216967cdd01665e807bea431a7b18d9ac169e2 with FIREFOX_65_0b4_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "94c27acdfa83bd789b9b3c61945b1126dd23d17a", "parents": ["ba961685a318cb2665cc65154e305ca01ef7c615"], "tags": []}], "date": 1544708241, "git_changesets": [null], "user": "ffxbld"}, "10331": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP blocklist remote-settings - a=repo-update r=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14413", "files": ["browser/app/blocklist.xml", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/blocklists/addons.json"], "git_node": null, "git_parents": [null], "node": "058ec15bdf179e254b223bf7e8d57e9c53a53d07", "parents": ["94c27acdfa83bd789b9b3c61945b1126dd23d17a"], "tags": []}, {"author": "Stephen A Pohl \u003cspohl.mozilla.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 469990: Backout cset 7bd4fa70b728 for causing a large number of regressions (bug 1513341, bug 1513328, bug 1513335, bug 1513336). r=me, a=ryanvm", "files": ["toolkit/xre/nsNativeAppSupportCocoa.mm"], "git_node": null, "git_parents": [null], "node": "978402f68f3cb038f168299ed40d8c591f827a80", "parents": ["058ec15bdf179e254b223bf7e8d57e9c53a53d07"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1484884 - Fix async zoom transform computation for layout viewport. r=kats, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14020", "files": ["gfx/layers/apz/src/AsyncPanZoomController.cpp", "layout/reftests/async-scrolling/reftest.list"], "git_node": null, "git_parents": [null], "node": "663b56166037bd6b1b066e8e95f9818d8746fd18", "parents": ["978402f68f3cb038f168299ed40d8c591f827a80"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1510485 - Properly handle errors in nsFind when returning a range. r=bzbarsky, a=RyanVM\n\nBug 1505887 changed the behavior here from content calling into nsFind via\nwindow.find(), by making the SetStart and SetEnd calls here fail instead of\nsucceed for NAC (like the text in textareas).\n\nThis patch makes us handle that error gracefully moving on to the next match,\ninstead of trying to preserve the previous behavior.\n\nThis means that we'll fail to highlight textarea content and such from\nwindow.find, which Chromium does, looks like. Though Chromium doesn't expose\nthe ranges as selection either. In any case I don't think that this is a very\ncommon thing given bugs like bug 1442466, which this bug fixes.\n\nI haven't found anything close to a spec for what window.find() should do... If\nwe decide to go with this patch then I'll add a crashtest for this and a test\nfor bug 1442466 as well. Otherwise I'll add a way to skip the security check in\nnsFind somehow for NAC, or relax the security restrictions in SetStart /\nSetEnd, I guess.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14013", "files": ["layout/base/crashtests/1510485.html", "layout/base/crashtests/crashtests.list", "toolkit/components/find/nsFind.cpp"], "git_node": null, "git_parents": [null], "node": "3a8a5011f5bf8bd3dcfe84af64c459fef20d49a2", "parents": ["663b56166037bd6b1b066e8e95f9818d8746fd18"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1512706 - Update minidump_stackwalk used for tests. r+a=RyanVM\n\nThe minidump_stackwalk used for tests ifs picked up from tooltool, and\nit looks like the tooltool manifests haven't been updated in 2 years.\n\nAs it turns out, this old version is not capable of, at least, stack\nwalk over crashes originated in LTOed rust code on Windows, while\nbreakpad trunk, as well as the slightly oldest version we have in-tree\ndo.\n\nWhile ideally, we'd go with building minidump_stackwalk as a taskcluster\ntoolchain artifact, or during the build, but that involves significantly\nmore work, while we should fix the stack traces of crashes that  people\n_do_ get as early as possible.\n\nThe tooltool artifacts linked in the updated manifests were generated\nthe following way:\n- Revert the last two changes that happened to minidump_stackwalk.cc\n  between 2016 and now (they don't matter for functionality and get in\n  the way of the rest below).\n- Apply the changes betwen the version of minidump_stackwalk.cc from\n  2016 and\nhttps://hg.mozilla.org/users/tmielczarek_mozilla.com/stackwalk-http/raw-file/51e4725ffad4/stackwalk.cc\n- Pick the http_symbol_supplier.cc and http_symbol_supplier.h files from\n  the same repo as stackwalk.cc above.\n- Add the necessary build system bits to build it off the Gecko tree,\n  along with the in-tree breakpad code.\n- Build it for linux, linux64, macosx64, win32-mingw.\n\nThe patch doing all the above is:\nhttps://hg.mozilla.org/try/rev/64491336dc7fca7a1c00ae8c66619b01563bbe4e\nThe push to build it on the aforementioned platforms:\nhttps://hg.mozilla.org/try/rev/4b621a67ca0bd6cf8954566e180d23e1ba8a9f83\n\nA win64-mingw variant was also built, but is not being used, keeping\nthings in line with what we currently are using.  We may want to follow\nup with an update to use that win64 variant on 64-bits testers.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14005", "files": ["browser/config/tooltool-manifests/win32/releng.manifest", "browser/config/tooltool-manifests/win64/aarch64.manifest", "browser/config/tooltool-manifests/win64/releng.manifest", "testing/config/tooltool-manifests/linux32/releng.manifest", "testing/config/tooltool-manifests/linux64/releng.manifest", "testing/config/tooltool-manifests/macosx64/releng.manifest", "testing/config/tooltool-manifests/win32/releng.manifest"], "git_node": null, "git_parents": [null], "node": "60444ade289159d488b7ab144e28e7091946a43c", "parents": ["3a8a5011f5bf8bd3dcfe84af64c459fef20d49a2"], "tags": []}, {"author": "WR Updater Bot \u003cgraphics-team@mozilla.staktrace.com\u003e", "branch": "default", "desc": "Bug 1512730 - Update webrender to commit 41c12cabc42228dda6a2d2628c9b24df9aca66b4 (WR PR #3398). r=kats, a=RyanVM\n\nhttps://github.com/servo/webrender/pull/3398\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14121", "files": ["gfx/webrender_bindings/revision.txt", "gfx/wr/webrender/src/render_backend.rs", "gfx/wr/webrender/src/resource_cache.rs", "gfx/wr/webrender/src/scene_builder.rs"], "git_node": null, "git_parents": [null], "node": "86e560ca1e292800a65bf10ad8ec446277c2b2ef", "parents": ["60444ade289159d488b7ab144e28e7091946a43c"], "tags": []}], "date": 1544732453, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10332": {"changesets": [{"author": "matthias \u003cmatthias@kammueller.eu\u003e", "branch": "default", "desc": "Bug 1512842 - Adjusted Button Background colour according to photon spec. r=ntim,dao, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14117", "files": ["toolkit/themes/shared/in-content/common.inc.css"], "git_node": null, "git_parents": [null], "node": "ca8fd2a3447af7049cd4666d8a533ffeb64e365a", "parents": ["86e560ca1e292800a65bf10ad8ec446277c2b2ef"], "tags": []}, {"author": "Lina Cambridge \u003clina@yakshaving.ninja\u003e", "branch": "default", "desc": "Bug 1512867 - Always update or upload synced bookmarks that only exist on one side. r=tcsc, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14034", "files": ["toolkit/components/places/SyncedBookmarksMirror.jsm", "toolkit/components/places/tests/sync/head_sync.js", "toolkit/components/places/tests/sync/test_bookmark_corruption.js", "toolkit/components/places/tests/sync/test_bookmark_observer_recorder.js"], "git_node": null, "git_parents": [null], "node": "067a6752b18069ab91d3d46521a9bbeff962390e", "parents": ["ca8fd2a3447af7049cd4666d8a533ffeb64e365a"], "tags": []}, {"author": "matthias \u003cmatthias@kammueller.eu\u003e", "branch": "default", "desc": "Bug 1513035 - Remove text-align: center; from common.css buttons r=ewright,dao, a=RyanVM\n\nThis is already part of the button default styling, common.css does not need to set this again, especially since it breaks the menulist text alignment.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14119", "files": ["toolkit/themes/shared/in-content/common.inc.css"], "git_node": null, "git_parents": [null], "node": "b5a033723f0e3f52688564e5b817b19fd1e8de91", "parents": ["067a6752b18069ab91d3d46521a9bbeff962390e"], "tags": []}, {"author": "Michael Froman \u003cmfroman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1513101 - Re-add L section for HANDLES_DUP_BROKER to RDD Win sanbox to fix mochitest crashes. r=bobowen, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14109", "files": ["security/sandbox/win/src/sandboxbroker/sandboxBroker.cpp"], "git_node": null, "git_parents": [null], "node": "1ad308897e69c198246e75507d5252b8e6146725", "parents": ["b5a033723f0e3f52688564e5b817b19fd1e8de91"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "des