l, "git_parents": [null], "node": "1f6ce017121d550726ffa75b9880e3ba76009205", "parents": ["002917d5ac549e47ab8f7f9a10e5b4e3f57dd007"], "tags": []}], "date": 1543952797, "git_changesets": [null, null], "user": "ffxbld"}, "10301": {"changesets": [{"author": "Edgar Chen \u003cechen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1507543 - Spellchecker for contenteditable/design-mode should not run without focus; r=m_kato\n\nDifferential Revision: https://phabricator.services.mozilla.com/D12875", "files": ["editor/libeditor/tests/test_bug366682.html", "editor/reftests/reftest.list", "editor/reftests/spellcheck-contenteditable-nofocus-1.html", "editor/reftests/spellcheck-contenteditable-nofocus-2.html", "editor/reftests/spellcheck-contenteditable-nofocus.html", "editor/spellchecker/EditorSpellCheck.cpp"], "git_node": null, "git_parents": [null], "node": "5e2fad03c885961363aa136290e69df9009f4726", "parents": ["01d0813d8203d78613fc33a3e8e32627c1300b50"], "tags": []}, {"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, taskcluster/docker/funsize-update-generator pipfile-update. r=sfraser\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13667", "files": ["taskcluster/docker/funsize-update-generator/Pipfile.lock"], "git_node": null, "git_parents": [null], "node": "147a524d090bd96e16642c53062908bc8ab039f6", "parents": ["5e2fad03c885961363aa136290e69df9009f4726"], "tags": []}, {"author": "Axel Hecht \u003caxel@pike.org\u003e", "branch": "default", "desc": "Bug 1492070, update l10n python libraries, r=stas\n\nupdate fluent.syntax to 0.9.0\nupdate compare-locales to 5.0.2\nupdate fluent.migrate to https://hg.mozilla.org/l10n/fluent-migration/rev/3877312dc1f4\nThis includes migration-specific fixes for bugs 1491591, 1491833, 1491859, 1496127\n\nAll of these changes have been reviewed before in their respective upstream\nrepositories.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D11861", "files": [