: [null, null], "user": "ffxbld"}, "10456": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nda -\u003e e92ff79e10b8", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "051284735966726931c994868cfbf4a7465b8deb", "parents": ["96f4576ced6db8129d2596e2fcd2e1d559d40c0a"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nda -\u003e e92ff79e10b8", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "77b11bad2da130a618be6574d861ee158fd601eb", "parents": ["051284735966726931c994868cfbf4a7465b8deb"], "tags": []}], "date": 1546866024, "git_changesets": [null, null], "user": "ffxbld"}, "10457": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP remote-settings - a=repo-update r=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D15821", "files": ["security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc"], "git_node": null, "git_parents": [null], "node": "57bcf1f66de4bf38078f00e87208996e238c6249", "parents": ["77b11bad2da130a618be6574d861ee158fd601eb"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1513973 - Remove check for `false`. r=jib, a=RyanVM\n\nThe microphone source is no longer shared so this check is moot.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D15192", "files": ["dom/media/webrtc/MediaEngineWebRTCAudio.cpp"], "git_node": null, "git_parents": [null], "node": "962f5d3b5330da93a74f344f5c1c4523b54bf72d", "parents": ["57bcf1f66de4bf38078f00e87208996e238c6249"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1513973 - Make MediaEngineSource::SetTrack return void. r=jib, a=RyanVM", "files": ["dom/media/MediaManager.cpp", "dom/media/MediaManager.h", "dom/media/webrtc/MediaEngineDefault.cpp", "dom/media/webrtc/MediaEngineDefault.h", "dom/media/webrtc/MediaEngineRemoteVideoSource.cpp", "dom/media/webrtc/MediaEngineRemoteVideoSource.h", "dom/media/webrtc/MediaEngineSource.h", "dom/media/webrtc/MediaEngineTabVideoSource.cpp", "dom/media/webrtc/MediaEngineTabVideoSource.h", "dom/media/webrtc/MediaEngineWebRTCAudio.cpp", "dom/media/webrtc/MediaEngineWebRTCAudio.h"], "git_node": null, "git_parents": [null], "node": "59f2b329c3a1a189cb830443c0410e3bf54bec44", "parents": ["962f5d3b5330da93a74f344f5c1c4523b54bf72d"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1513973 - Enable pulling at the same time as starting audio sources. r=jib, a=RyanVM", "files": ["dom/media/MediaManager.cpp", "dom/media/webrtc/MediaEngineDefault.cpp", "dom/media/webrtc/MediaEngineSource.h", "dom/media/webrtc/MediaEngineWebRTCAudio.cpp"], "git_node": null, "git_parents": [null], "node": "1a2283b8f8c9cc85c8d3ba4e5624b76bb365cb26", "parents": ["59f2b329c3a1a189cb830443c0410e3bf54bec44"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1513973 - Log NotifyPull per track instead of per stream. r=jib, a=RyanVM\n\nThis better reflects the actual pulling that we do.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D15195", "files": ["dom/media/MediaStreamGraph.cpp"], "git_node": null, "git_parents": [null], "node": "7fcc850b0e9ee55583626e9a40ea830bfdb72307", "parents": ["1a2283b8f8c9cc85c8d3ba4e5624b76bb365cb26"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1513973 - Remove mutable keyword from MediaEngineWebRTCMicrophoneSource runnables. r=jib, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D15220", "files": ["dom/media/webrtc/MediaEngineWebRTCAudio.cpp"], "git_node": null, "git_parents": [null], "node": "61fc844e1f4848cdc47c8056f8d9e76795cecaca", "parents": ["7fcc850b0e9ee55583626e9a40ea830bfdb72307"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1517710 - Avoid calling SetPullingEnabled on a destroyed MediaStream. r=padenot, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D15798", "files": ["dom/media/webrtc/MediaEngineWebRTCAudio.cpp"], "git_node": null, "git_parents": [null], "node": "dac16eb67fd6c9fc34d50269a064c8c9a9dbca76", "parents": ["61fc844e1f4848cdc47c8056f8d9e76795cecaca"], "tags": []}], "date": 1546874637, "git_changesets": [null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10458": {"changesets": [{"author": "Tarek Ziad\u00e9 \u003ctarek@mozilla.com\u003e", "branch": "default", "desc": "Bug 1513304 - Check that the nsIURI pointer is not null. r=baku, a=RyanVM\n\nVerify that the script URI is not null before using it.\nIf it's the case, we can't really continue because that url\nidentifies the worker in the metrics.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D15187", "files": ["dom/workers/WorkerDebugger.cpp"], "git_node": null, "git_parents": [null], "node": "467d52576809bb88da1bc38d74ffc88671088c04", "parents": ["dac16eb67fd6c9fc34d50269a064c8c9a9dbca76"], "tags": []}, {"author": "Olli Pettay \u003cOlli.Pettay@helsinki.fi\u003e", "branch": "default", "desc": "Bug 1517221 - Explicitly break down pending mutation record list. r=mccr8, a=RyanVM", "files": ["dom/base/nsDOMMutationObserver.h"], "git_node": null, "git_parents": [null], "node": "7751d966a700459e772c29432209eb0085a77824", "parents": ["467d52576809bb88da1bc38d74ffc88671088c04"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1517275 - Add a null check before trying to use a controller. r=botond, a=RyanVM\n\nIn test code (which is where this codepath is mostly exercised), the\ncontroller should never be null here. However this codepath is sadly\nalso used in production code on Android, and there we might experience a\npage navigation or a similarly destructive action while the flush is\ninflight. That can result in a null pointer dereference.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D15597", "files": ["gfx/layers/apz/src/APZCTreeManager.cpp"], "git_node": null, "git_parents": [null], "node": "662cf99f3994de6e70e01b1df85bb78b94b7174c", "parents": ["7751d966a700459e772c29432209eb0085a77824"], "tags": []}, {"author": "Olli Pettay \u003cOlli.Pettay@helsinki.fi\u003e", "branch": "default", "desc": "Bug 1515463 - MessageBroadcaster.getChildAt should be out-of-bounds safe. r=peterv, a=RyanVM", "files": ["dom/chrome-webidl/MessageManager.webidl"], "git_node": null, "git_parents": [null], "node": "5c4518a4eb1f7f32da81477d094872bfdf87d698", "parents": ["662cf99f3994de6e70e01b1df85bb78b94b7174c"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1515658 - ChannelMediaResource should use the BlobURLs' length when known. r=jya, a=RyanVM", "files": ["dom/media/BaseMediaResource.cpp", "dom/media/ChannelMediaResource.cpp", "dom/media/ChannelMediaResource.h"], "git_node": null, "git_parents": [null], "node": "47a7517154c06dc94d13bdcd18daedeb90cc1c97", "parents": ["5c4518a4eb1f7f32da81477d094872bfdf87d698"], "tags": []}], "date": 1546880360, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10459": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\neu -\u003e f4c1a2bcd498\ngn -\u003e 