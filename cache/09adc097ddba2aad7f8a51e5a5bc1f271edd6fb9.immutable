dism.org\u003e", "branch": "default", "desc": "Bug 1374012 - Update to Expat 2.2.1. Part 15: ifdef some constants so they are only defined when used. r=erahm, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14454", "files": ["parser/expat/lib/xmlrole.c"], "git_node": null, "git_parents": [null], "node": "f2dfa6584638ef4b4230e6a954fa3862dad61d08", "parents": ["9cffa19a9cf339e974ef7313776bbf9589d80e6e"], "tags": []}, {"author": "Peter Van der Beken \u003cpeterv@propagandism.org\u003e", "branch": "default", "desc": "Bug 1374012 - Update to Expat 2.2.1. Part 16: fix some issues with various compilers. r=erahm, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14455", "files": ["parser/expat/lib/xmlparse.c"], "git_node": null, "git_parents": [null], "node": "f5e9f1fe8f6090736c6fd302bda4dfa147cae4ec", "parents": ["f2dfa6584638ef4b4230e6a954fa3862dad61d08"], "tags": []}, {"author": "Peter Van der Beken \u003cpeterv@propagandism.org\u003e", "branch": "default", "desc": "Bug 1374012 - Update to Expat 2.2.1. Part 17: add/change APIs that are not used in Gecko. r=erahm, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14456", "files": ["parser/expat/lib/expat.h", "parser/expat/lib/xmlparse.c"], "git_node": null, "git_parents": [null], "node": "ff6095b3806b6687b9ad549ec1193a498520382b", "parents": ["f5e9f1fe8f6090736c6fd302bda4dfa147cae4ec"], "tags": []}, {"author": "Peter Van der Beken \u003cpeterv@propagandism.org\u003e", "branch": "default", "desc": "Bug 1374012 - Update to Expat 2.2.1. Part 18: various miscellaneous changes. r=erahm, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14457", "files": ["parser/expat/lib/xmlparse.c"], "git_node": null, "git_parents": [null], "node": "8b831ffc1816125b86a7956c1eac069ee865bd3a", "parents": ["ff6095b3806b6687b9ad549ec1193a498520382b"], "tags": []}], "date": 1546265810, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10422": {"changesets": [{"author": "Dylan Roeh \u003cdroeh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1494748 - Stop stumbler service when Fennec is killed. r=snorp, a=RyanVM", "files": ["mobile/android/stumbler/java/org/mozilla/mozstumbler/service/stumblerthread/StumblerService.java"], "git_node": null, "git_parents": [null], "node": "8230dc950f984a38a09c8272a4fa5b0acfb27688", "parents": ["8b831ffc1816125b86a7956c1eac069ee865bd3a"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1515548 - Fix potential divide by zero in DesktopCaptureImpl; r=jib, a=RyanVM\n\nThis clamps requests for FPS that are below 1 to 1. As far as I can tell,\nthe getDisplayMedia specification does not provide any guidance on how to\ninterpret negative or zero FPS constraints, so this seems like a reasonable\nlimitation.\n\nI'm not adding a test here as there will be a wpt test that covers this\nas part of Bug 1321221.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D15105", "files": ["dom/media/systemservices/video_engine/desktop_capture_impl.cc"], "git_node": null, "git_parents": [null], "node": "b41ed6f2639aa4de0250294ed2643212ca411245", "parents": ["8230dc950f984a38a09c8272a4fa5b0acfb27688"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1515461 - Make AVCaptureSession stopRunning synchronous; r=jib, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D15144", "files": ["media/webrtc/trunk/webrtc/modules/video_capture/objc/rtc_video_capture_objc.mm"], "git_node": null, "git_parents": [null], "node": "d85d79f64753dd634667e7398303abacf5ea13bc", "parents": ["b41ed6f2639aa4de0250294ed2643212ca411245"], "tags": []}], "date": 1546269394, "git_changesets": [null, null, null], "user": "ryanvm@gmail.com"}, "10423": {"changesets