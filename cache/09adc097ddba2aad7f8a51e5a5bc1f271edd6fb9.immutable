to the actors. r=mak, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14369", "files": ["browser/components/search/test/browser/browser_searchTelemetry.js"], "git_node": null, "git_parents": [null], "node": "67f8cf76ac89c38cea62938449f487a5ca7c7217", "parents": ["33cfba1a9fbd71f3aaef0e47d1a8ec3b15d34ff4"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1512464 - Remove invalid entries from dom/tests/mochitest/general/chrome.ini; r=smaug, a=test-only", "files": ["dom/tests/mochitest/general/chrome.ini"], "git_node": null, "git_parents": [null], "node": "78e3efa8ba7f58438009a531e33da3266520a681", "parents": ["67f8cf76ac89c38cea62938449f487a5ca7c7217"], "tags": []}, {"author": "matthias \u003cmatthias@kammueller.eu\u003e", "branch": "default", "desc": "Bug 1512889 - Changed button colour to inherit. r=dao, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14116", "files": ["toolkit/themes/shared/in-content/common.inc.css"], "git_node": null, "git_parents": [null], "node": "d0e252ea5c9337f3df5e3d2a8d46582f036a86e1", "parents": ["78e3efa8ba7f58438009a531e33da3266520a681"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1513242 - Queue native calls in GeckoSystemStateListener r=geckoview-reviewers,esawin, a=RyanVM\n\nSometimes Gecko isn't running yet when we get our first notifications.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14178", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoSystemStateListener.java"], "git_node": null, "git_parents": [null], "node": "d48cfac9b2f00460a83549c07980769ee59c742f", "parents": ["d0e252ea5c9337f3df5e3d2a8d46582f036a86e1"], "tags": []}, {"author": "Richard Marti \u003crichard.marti@gmail.com\u003e", "branch": "default", "desc": "Bug 1512857 - Remove the additional padding in .button-box/.menulist-label-box from common.css buttons/menulists. r=dao, a=RyanVM", "files": ["toolkit/themes/shared/in-content/common.inc.css", "toolkit/themes/windows/global/button.css", "toolkit/themes/windows/global/in-content/common.css"], "git_node": null, "git_parents": [null], "node": "405ee85a224774b173f440cf225f37108073c0ac", "parents": ["d48cfac9b2f00460a83549c07980769ee59c742f"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1434888 - Set accessibility panel command key to Shift + F10. r=gl, a=RyanVM, l10n=flod\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14095", "files": ["devtools/client/definitions.js", "devtools/client/locales/en-US/startup.properties", "devtools/startup/devtools-startup.js", "devtools/startup/locales/en-US/key-shortcuts.properties"], "git_node": null, "git_parents": [null], "node": "4a9792ce63e3011e473b9d33afdc686bdf47dec0", "parents": ["405ee85a224774b173f440cf225f37108073c0ac"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1434888 - Update accessibility panel command key from Shift + F10 to Shift + F12. r=gl,flod, a=RyanVM, l10n=flod\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14261", "files": ["devtools/client/definitions.js", "devtools/startup/devtools-startup.js", "devtools/startup/locales/en-US/key-shortcuts.properties"], "git_node": null, "git_parents": [null], "node": "aea4a31fb8bb43243c5e6eaa891958b1d803d95a", "parents": ["4a9792ce63e3011e473b9d33afdc686bdf47dec0"], "tags": []}], "date": 1544743324, "git_changesets": [null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10334": {"changesets": [{"author": "Mats Palmgren \u003cmats@mozilla.com\u003e", "branch": "default", "desc": "Bug 1512066 - Make \u003cinput type=range\u003e min-content size the same as its max-content size (not zero). r=jwatt, a=RyanVM", "files": ["layout/base/nsLayoutUtils.cpp", "layout/forms/nsRangeFrame.cpp", "testing/web-platform/tests/html/semantics/forms/the-input-element/range-intrinsic-size-ref.html", "testing/web-platform/tests/html/semantics/forms/the-input-element/range-intrinsic-size.html"], "git_node": null, "git_parents": [null], "node": "8ed79de6c5baccc9271815a8a4dd19dcd82e2e29", "parents": ["aea4a31fb8bb43243c5e6eaa891958b1d803d95a"], "tags": []}, {"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1513177 - Override #tabsToggle background-color from common.css. r=dao, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14212", "files": ["browser/themes/shared/aboutSessionRestore.css"], "git_node": null, "git_parents": [null], "node": "d3b7ef91735725f77a62d36f47b26d1499ac0ecb", "parents": ["8ed79de6c5baccc9271815a8a4dd19dcd82e2e29"], "tags": []}, {"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1513349 - Remove now erroneous tree cell editing styles. r=dao, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14189", "files": ["toolkit/themes/shared/tree.inc.css"], "git_node": null, "git_parents": [null], "node": "eed9d1166b691a3abc8e8214badbc9e40150b1c7", "parents": ["d3b7ef91735725f77a62d36f47b26d1499ac0ecb"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1507947 - Be more careful when unbinding child process services. r=geckoview-reviewers,esawin, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14065", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/process/GeckoProcessManager.java"], "git_node": null, "git_parents": [null], "node": "d5f982689c717bba98621154f5dde808319eaa91", "parents": ["eed9d1166b691a3abc8e8214badbc9e40150b1c7"], "tags": []}], "date": 1544747157, "git_changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "10335": {"changesets": [{"author": "Michael Froman \u003cmfroman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1452146 - flip av1 and rdd on for Win. r=drno a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13482", "files": ["modules/libpref/init/StaticPrefList.h", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "d9d17041ca841fc9b80dc40eb926e376fd58a903", "parents": ["d5f982689c717bba98621154f5dde808319eaa91"], "tags": []}, {"author": "Jan-Erik Rediger \u003cjrediger@mozilla.com\u003e", "branch": "default", "desc": "Bug 1505991 - Add new preference to disable ping throttling r=Dexter a=RyanVM\n\nMarionette tests have a hard time properly overwriting the module's\nPolicies that handle this in xpcshell tests currently.\n\nA preference on the other hand can be easily set from the outside, is\npersistent across restarts of the test instance and easily checked.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14458", "files": ["toolkit/components/telemetry/app/TelemetrySend.jsm", "toolkit/components/telemetry/app/TelemetryUtils.jsm", "toolkit/components/telemetry/docs/internals/preferences.rst"], "git_node": null, "git_parents": [null], "node": "34ce66233646020c044a3229ec905c236556ed81", "parents": ["d9d17041ca841fc9b80dc40eb926e376fd58a903"], "tags": []}, {"author": "Jan-Erik Rediger \u003cjrediger@mozilla.com\u003e", "branch": "default", "desc": "Bug 1505991 - Set new testing-only preference to disable Telemetry throttling r=raphael a=RyanVM\n\nDepends on D14458\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14459", "files": ["toolkit/components/telemetry/tests/marionette/harness/telemetry_harness/testcase.py"], "git_node": null, "git_parents": [null], "node": "e72979e80a1c63f5fc1e78c4619123edf0295dfa", "parents": ["34ce66233646020c044a3229ec905c236556ed81"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1511818 - Keep track of unique domains with a valid hostname for the purposes of the automatic access grant heuristics of the Storage Access API r=mikedeboer a=RyanVM\n\nThis is an attempt to fix a Talos regression caused by the cost of URL\nparsing.  The approach I'm taking here is to modify the requirements of\nbug 1509047 part 2 slightly so that I can remove the expensive code\nwhich resulted in the Talos regression.\n\nThe change in behaviour is that the automatic access grants for the\nStorage Access API will use the number of unique domains visited in the\nsession as opposed to the number of unique origins visited.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14156", "files": ["browser/modules/BrowserUsageTelemetry.jsm", "browser/modules/PermissionUI.jsm", "browser/modules/test/browser/browser_UsageTelemetry_uniqueOriginsVisitedInPast24Hours.js"], "git_node": null, "git_parents": [null], "node": "2c85064c240cc9e3046fee8b781182a6291d3ee4", "parents": ["e72979e80a1c63f5fc1e78c4619123edf0295dfa"], "tags": []}], "date": 1544821578, "git_changesets": [null, null, null, null], "user": "csabou@mozilla.com"}, "10336": {"changesets": [{"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1513007 - avoid permanently breaking scrolling to background tabs when promiseDocumentFlushed returns synchronously, r=dao a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14086", "files": ["browser/base/content/tabbrowser.xml"], "git_node": null, "git_parents": [null], "node": "d6a0b8b5bccaeb41eade51dcf2d84152f2f65fb2", "parents": ["2c85064c240cc9e3046fee8b781182a6291d3ee4"], "tags": []}, {"author": "Junior Hsu \u003cjuhsu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1513135 - disable flow control of HTTP e10s back pressure r=dragana a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14500", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "7e036d607afaca9bda58e90127bb0064dc966345", "parents": ["d6a0b8b5bccaeb41eade51dcf2d84152f2f65fb2"], "tags": []}, {"author": "Micah Tigley \u003cmtigley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1513500 - Fixed it so getCurrentDisplay also checks if a flex container is actually a flex item. r=pbro a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14312", "files": ["devtools/client/inspector/flexbox/test/browser.ini", "devtools/client/inspector/flexbox/test/browser_flexbox_grand_parent_flex.js", "devtools/server/actors/layout.js"], "git_node": null, "git_parents": [null], "node": "0d66c5be649b285f6881428dc3029d5281c93018", "parents": ["7e036d607afaca9bda58e90127bb0064dc966345"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1513505 - Fix invoke getter on prototype's property; r=jdescottes a=RyanVM\n\nThis lands the fix done in the debugger Reps\nfor ObjectInspector (https://github.com/devtools-html/debugger.html/pull/7484\\),\nand add a test to ensure we don't regress this.\nWe take this as an opportunity to put some\nobject inspector helpers in head.js so we\ndon't repeat ourselves too much.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14240", "files": ["devtools/client/shared/components/reps/reps.js", "devtools/client/webconsole/test/mochitest/browser.ini", "devtools/client/webconsole/test/mochitest/browser_webconsole_object_inspector_getters.js", "devtools/client/webconsole/test/mochitest/browser_webconsole_object_inspector_getters_prototype.js", "devtools/client/webconsole/test/mochitest/head.js"], "git_node": null, "git_parents": [null], "node": "6f8e2bdfd8b61347c2ccd7a29841ef277d055d04", "parents": ["0d66c5be649b285f6881428dc3029d5281c93018"], "tags": []}], "date": 1544822268, "git_changesets": [null, null, null, null], "user": "csabou@mozilla.com"}, "10337": {"changesets": [{"author": "Rob Lemley \u003crob@thunderbird.net\u003e", "branch": "default", "desc": "Bug 1508056 - Create function for determining autographing scope. r=aki a=release\n\nThe deferred mar signing feature in Bug 1501878 has a taskcluster scope\nvalue in mar_signing.py hardcoded to something Firefox specific. This\npatch introduces a new function, get_autograph_format_scope, that will\nproduce the right value for Firefox and Thunderbird.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13567", "files": ["taskcluster/taskgraph/transforms/mar_signing.py", "taskcluster/taskgraph/util/scriptworker.py"], "git_node": null, "git_parents": [null], "node": "9eff0feefcf92ed0cd1232c484686108965f4474", "parents": ["6f8e2bdfd8b61347c2ccd7a29841ef277d055d04"], "tags": []}], "date": 1544826366, "git_changesets": [null], "user": "asasaki@mozilla.com"}, "10338": {"changesets": [{"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 2c85064c240c (bug 1511818) for frequently failing xpc tests in services/sync/tests/unit/. a=backout", "files": ["browser/modules/BrowserUsageTelemetry.jsm", "browser/modules/PermissionUI.jsm", "browser/modules/test/browser/browser_UsageTelemetry_uniqueOriginsVisitedInPast24Hours.js"], "git_node": null, "git_parents": [null], "node": "d2bd2bb0c329208ce96e3c6fcb5e741f88c35227", "parents": ["9eff0feefcf92ed0cd1232c484686108965f4474"], "tags": []}], "date": 1544843194, "git_changesets": [null], "user": "csabou@mozilla.com"}, "10339": {"changesets": [{"author": "Andrew Swan \u003caswan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1508664 - Avoid importing Extension.jsm too early r=kmag a=test-only\n\nThe test failure from this bug was due to code that reads Services.appinfo\nrunning too early before our test code that overrides appinfo got a chance\nto run.\n\nAddon Manager test code could use a more thorough cleanup pass, but this\nis a quick-and-dirty fix suitable for uplifting in the short term.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14656", "files": ["toolk