: "86f5a024cd49e9485a91b89a826815fb0de507b1", "parents": ["2ea881a24d05154d0a048e06045f5b5e5ba08481"], "tags": []}], "date": 1547666047, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10534": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP blocklist remote-settings - a=repo-update r=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16818", "files": ["browser/app/blocklist.xml", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/blocklists/plugins.json"], "git_node": null, "git_parents": [null], "node": "ba59016735faa489660bb10bfae3e75b24537b3a", "parents": ["86f5a024cd49e9485a91b89a826815fb0de507b1"], "tags": []}, {"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1485127 - Add an exception for the AwesomeBar dropmarker sometimes disappearing in a flicker test. r=florian, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16509", "files": ["browser/base/content/test/performance/browser_tabstrip_overflow_underflow.js"], "git_node": null, "git_parents": [null], "node": "9299c74c0459c8faeb2ebaab093db8a9a12ee11b", "parents": ["ba59016735faa489660bb10bfae3e75b24537b3a"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1507322 - Mark implicit edges via mark stack instead of eagerly. r=jonco, a=RyanVM", "files": ["js/src/gc/GCMarker.h", "js/src/gc/Marking.cpp", "js/src/vm/JSScript.cpp"], "git_node": null, "git_parents": [null], "node": "e758e8df7f9a1cd53bc6ca5b670e9c1fa23e6b4c", "parents": ["9299c74c0459c8faeb2ebaab093db8a9a12ee11b"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1507322 - Test deeply recursive weakmaps. r=jonco, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16738", "files": ["js/src/tests/non262/regress/regress-1507322-deep-weakmap.js"], "git_node": null, "git_parents": [null], "node": "69143a6c191dd9d8742568548fcf7981a0ceb91d", "parents": ["e758e8df7f9a1cd53bc6ca5b670e9c1fa23e6b4c"], "tags": []}, {"author": "Tom Tung \u003cshes050117@gmail.com\u003e", "branch": "default", "desc": "Bug 1432133 - Returning an error when FileInfo is missing as a short-term fix. r=asuth, data-review=chutten, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16045", "files": ["dom/indexedDB/ActorsParent.cpp", "toolkit/components/telemetry/Scalars.yaml"], "git_node": null, "git_parents": [null], "node": "73101717e0676ee8ead22272dc3df324db94b87a", "parents": ["69143a6c191dd9d8742568548fcf7981a0ceb91d"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1516768 - Put a border on add-on cards in high contrast mode. r=dao, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16520", "files": ["toolkit/themes/shared/extensions/extensions.inc.css", "toolkit/themes/shared/in-content/common.inc.css"], "git_node": null, "git_parents": [null], "node": "21ebd471d7a645f5b501abbb194f4696195dae63", "parents": ["73101717e0676ee8ead22272dc3df324db94b87a"], "tags": []}], "date": 1547734948, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10535": {"changesets": [{"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1520756 - Disable Window.event, Event.returnValue and setting keyCode and charCode of \"keypress\" events to same value. r=smaug, a=RyanVM\n\nIn bug 1496288, we decided to ship the following new features:\n- Windows.event\n- Setting keyCode and charCode of \"keypress\" events to same value\n- Stop dispatching non-printable \"keypress\" events\n- Start to dispatch \"keydown\" and \"keyup\" events even during composition\n\nHowever, the 2nd change breaks editor of Confluence.  For making the shipment\nof 65 safer, we should cancel shipping the 2nd change.\n\nThen, we need to disable Window.event and Event.returnValue too because\nthey are blocked by the 2nd (bug 1479964 and bug 1478102).\n\nOn the other hand, perhaps, we should ship the last 2 changes as planned\nbecause web apps cannot detect these changes from any API and also we've\nalready introduced these changes.  So, some web apps have already started\nto check version number of Firefox.  We shouldn't break such web apps.", "files": ["dom/base/DOMPrefsInternal.h", "dom/webidl/Event.webidl", "modules/libpref/init/StaticPrefList.h", "modules/libpref/init/all.js", "testing/web-platform/meta/dom/events/AddEventListenerOptions-passive.html.ini", "testing/web-platform/meta/dom/events/Event-constructors.html.ini", "testing/web-platform/meta/dom/events/Event-defaultPrevented-after-dispatch.html.ini", "testing/web-platform/meta/dom/events/Event-defaultPrevented.html.ini", "testing/web-platform/meta/dom/events/Event-initEvent.html.ini", "testing/web-platform/meta/dom/events/Event-returnValue.html.ini", "testing/web-platform/meta/dom/events/EventTarget-dispatchEvent-returnvalue.html.ini", "testing/web-platform/meta/dom/interfaces.html.ini"], "git_node": null, "git_parents": [null], "node": "6881825b5cd71efff043f4dbb0e56339e93b3ad7", "parents": ["21ebd471d7a645f5b501abbb194f4696195dae63"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1495363 - Abort the previous request, if a form is submitted twice. r=nika, a=RyanVM", "files": ["uriloader/base/nsDocLoader.cpp"], "git_node": null, "git_parents": [null], "node": "1790d083bb5766db07a44f891bf786173d60da02", "parents": ["6881825b5cd71efff043f4dbb0e56339e93b3ad7"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1495363 - Abort the previous request, if a form is submitted twice - tests. r=smaug, a=RyanVM", "files": ["dom/html/test/forms/file_bug1495363.html", "dom/html/test/forms/file_bug1495363.sjs", "dom/html/test/forms/mochitest.ini", "dom/html/test/forms/test_bug1495363.html"], "git_node": null, "git_parents": [null], "node": "f69157ba349ee9c70f1a05571541a8011872a126", "parents": ["1790d083bb5766db07a44f891bf786173d60da02"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1520138 - Fix border-style conflict resolution in border-collapsed tables. r=dholbert, a=RyanVM\n\nBug 1509717 removed Gecko's definition of StyleBorderStyle to use the Rust one.\n\nThe Rust version was ordered in a different way, and the table code relied on\nthe order in order to build the mapping for border conflict resolution.\n\nSimplify this mapping now that border constants are ordered in terms of\npriority, see the comment on top of `enum BorderStyle`.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16565", "files": ["layout/tables/nsTableFrame.cpp", "testing/web-platform/tests/css/css-tables/border-conflict-resolution-ref.html", "testing/web-platform/tests/css/css-tables/border-conflict-resolution.html"], "git_node": null, "git_parents": [null], "node": "01bd5daff7e0667df22541e13dc1c8b125124d66", "parents": ["f69157ba349ee9c70f1a05571541a8011872a126"], "tags": []}, {"author": "Dragana Damjanovic \u003cdd.mozilla@gmail.com\u003e", "branch": "default", "desc": "Bug 1520260 - Collect *_KBREAD_PER_CONN on release as well. r=valentin, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16616", "files": ["netwerk/protocol/http/nsHttpConnection.cpp", "toolkit/components/telemetry/Histograms.json", "toolkit/components/telemetry/histogram-whitelists.json"], "git_node": null, "git_parents": [null], "node": "e71504cbe594bbda84395ce67c323adc0b855b23", "parents": ["01bd5daff7e0667df22541e13dc1c8b125124d66"], "tags": []}], "date": 1547746383, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10536": {"changesets": [{"author": "Mihai Tabara \u003cmtabara@mozilla.com\u003e", "branch": "default", "desc": "Bug 1518236: Update WNP with locales for 65; r=flod a=release", "files": ["browser/config/whats_new_page.yml"], "git_node": null, "git_parents": [null], "node": "5e7a2d9c3127712f4d5191d9c800a94d123f2fab", "parents": ["e71504cbe594bbda84395ce67c323adc0b855b23"], "tags": []}], "date": 1547748278, "git_changesets": [null], "user": "mtabara@mozilla.com"}, "10537": {"changesets": [{"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1518786 - Wait until Fluent strings have been applied before sizing the window to content. r=Gijs, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16866", "files": ["security/manager/pki/resources/content/exceptionDialog.js", "security/manager/pki/resources/content/exceptionDialog.xul"], "git_node": null, "git_parents": [null], "node": "f0f24bd868b57c3ea1fad5e691b5196f590ec7f5", "parents": ["5e7a2d9c3127712f4d5191d9c800a94d123f2fab"], "tags": []}, {"author": "Shane Caraveo \u003cscaraveo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1489531 - Expose telemetry client_id header to about:addons. r=aswan, a=RyanVM\n\nTest Plan:\nManual testing\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16857", "files": ["toolkit/content/widgets/browser.xml", "toolkit/mozapps/extensions/content/extensions.js"], "git_node": null, "git_parents": [null], "node": "8f904ee0cae1a2252b79534dee93d814d297e231", "parents": ["f0f24bd868b57c3ea1fad5e691b5196f590ec7f5"], "tags": []}, {"author": "Nils Ohlmeier [:drno] \u003cdrno@ohlmeier.org\u003e", "branch": "default", "desc": "Bug 1510487 - Allow DTLS connection w/o SRTP extension. r=bwc, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14692", "files": ["media/mtransport/test/transport_unittests.cpp", "media/mtransport/transportlayerdtls.cpp", "media/mtransport/transportlayersrtp.cpp", "media/webrtc/signaling/src/peerconnection/MediaTransportHandler.cpp"], "git_node": null, "git_parents": [null], "node": "435e0e27532d79d15538cd8376ea0f6d706065ca", "parents": ["8f904ee0cae1a2252b79534dee93d814d297e231"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1518440 - Use CheckedInt in JSON Quote function. r=jwalden, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16534", "files": ["js/src/builtin/JSON.cpp"], "git_node": null, "git_parents": [null], "node": "d850ab97f26b8824425de7d88a8603265de6e3ae", "parents": ["435e0e27532d79d15538cd8376ea0f6d706065ca"], "tags": []}], "date": 1547764214, "git_changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "10538": {"changesets": [{"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1520791 - Ensure initial browser's docshell is marked as active in the parent. r=mconley, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16862", "files": ["browser/base/content/tabbrowser.js"], "git_node": null, "git_parents": [null], "node": "9e5bf16f07c4103f751a6efbed31030716f93a82", "parents": ["d850ab97f26b8824425de7d88a8603265de6e3ae"], "tags": []}, {"author": "Jim Blandy \u003cjimb@mozilla.com\u003e", "branch": "default", "desc": "Bug 1516514: Clear the hasCachedSavedFrame bit on frames on compartment mismatch. r=jorendorff, a=abillings\n\nThe code that manages the LiveSavedFrameCache would very much like to assert\nthat, if a frame has its hasCachedSavedFrame bit set, then it actually does have\nan entry in the LiveSavedFrameCache. However, in the presence of compartment\nmismatches, this becomes temporarily untrue, and OOMs can make 'temporarily'\nlonger than expected.\n\nThis patch more aggressively clears frames' hasCachedSavedFrame bits, so that\nwhen we do purge the cache for a compartment mismatch, all frames get their bits\ncleared before we start repopulating the cache.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16661", "files": ["js/src/jit-test/tests/saved-stacks/oom-in-save-stack-02.js", "js/src/vm/SavedStacks.cpp", "js/src/vm/Stack.h"], "git_node": null, "git_parents": [null], "node": "666a44dfa6eb44515da1a8c9747224a95f45a3c0", "parents": ["9e5bf16f07c4103f751a6efbed31030716f93a82"], "tags": ["DEVEDITION_65_0b12_BUILD1", "DEVEDITION_65_0b12_RELEASE", "FENNEC_65_0b12_BUILD1", "FENNEC_65_0b12_RELEASE", "FIREFOX_65_0b12_BUILD1", "FIREFOX_65_0b12_RELEASE"]}], "date": 1547767467, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "10539": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 666a44dfa6eb44515da1a8c9747224a95f45a3c0 with FENNEC_65_0b12_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "e8897f842c74a16a053b6893ad99ab3287c2fbbf", "parents": ["666a44dfa6eb44515da1a8c9747224a95f45a3c0"], "tags": []}], "date": 1547770306, "git_changesets": [null], "user": "ffxbld"}, "10540": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 666a44dfa6eb44515da1a8c9747224a95f45a3c0 with DEVEDITION_65_0b12_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "02a265cec94c5fb56d5b1b5bb4b01a2414daf681", "parents": ["e8897f842c74a16a053b6893ad99ab3287c2fbbf"], "tags": []}], "date": 1547770608, "git_changesets": [null], "user": "ffxbld"}, "10541": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 666a44dfa6eb44515da1a8c9747224a95f45a3c0 with FIREFOX_65_0b12_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "78f13eacbff823811491d6aee88ceed13c094289", "parents": ["02a265cec94c5fb56d5b1b5bb4b01a2414daf681"], "tags": []}], "date": 1547770907, "git_changesets": [null], "user": "ffxbld"}, "10542": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 666a44dfa6eb44515da1a8c9747224a95f45a3c0 with FIREFOX_65_0b12_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "dd34ca4b8782e5699f332a1a661a2c5e73225aa5", "parents": ["78f13eacbff823811491d6aee88ceed13c094289"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release DONTBUILD", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "850222243af3abdc894089614e895803289129f7", "parents": ["dd34ca4b8782e5699f332a1a661a2c5e73225aa5"], "tags": []}], "date": 1547823793, "git_changesets": [null, null], "user": "ffxbld"}, "10543": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 666a44dfa6eb44515da1a8c9747224a95f45a3c0 with DEVEDITION_65_0b12_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "b912b2ee4e7632a53194f18642b8ab1cdcb31616", "parents": ["850222243af3abdc894089614e895803289129f7"], "tags": []}], "date": 1547823968, "git_changesets": [null], "user": "ffxbld"}, "10544": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 666a44dfa6eb44515da1a8c9747224a95f45a3c0 with FENNEC_65_0b12_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "b8f22a0436f50dcccb33512eae05f686c1ef5153", "parents": ["b912b2ee4e7632a53194f18642b8ab1cdcb31616"], "tags": []}], "date": 1547824220, "git_changesets": [null], "user": "ffxbld"}, "10545": {"changesets": [{"author": "alwu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442399 - Refactor seamless-looping test. r=padenot, a=test-only\n\nTo make it output more debug information which is helpful to debug intermittent fail and refactor the test flow.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16924", "files": ["dom/media/test/test_seamless_looping.html"], "git_node": null, "git_parents": [null], "node": "758854cfeb6f85f5be2ee834ab1f2387dd038754", "parents": ["b8f22a0436f50dcccb33512eae05f686c1ef5153"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1495715 - Fix intermittent on browser_jsterm_await_paused. r=Honza, a=test-only\n\nLooking at the logs and the screenshots, it seems that the test fails\nbecause the debugger is not paused anymore when evluating the await\nexpression, meaning that `foo` is undefined.\nHere we try to wait for a small bit to give more time for the server\nto evaluate before resuming.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16554", "files": ["devtools/client/webconsole/test/mochitest/browser_jsterm_await_paused.js"], "git_node": null, "git_parents": [null], "node": "738a754442a780d6fb8c84ce6405e9ba350f0284", "parents": ["758854cfeb6f85f5be2ee834ab1f2387dd038754"], "tags": []}, {"author": "Timothy Guan-tin Chien \u003ctimdream@gmail.com\u003e", "branch": "default", "desc": "Bug 1515970 - Don't access creditCards store in _updateSavedFieldNames unless it is enabled. r=MattN, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D15393", "files": ["browser/extensions/formautofill/FormAutofillParent.jsm"], "git_node": null, "git_parents": [null], "node": "99b68e9d4a7c2aad92a4a7c64e96c71702b37e64", "parents": ["738a754442a780d6fb8c84ce6405e9ba350f0284"], "tags": []}, {"author": "Andrew Swan \u003caswan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1519762 - Fix a regression with browser.downloads.search(). r=kmag, a=RyanVM\n\nThe fixes in bug 1503760 inadvertently broke searches of downloads that\nhave not yet started receiving data (which have a value of -1 for the\ntotalBytes property).  That regression is fixed here.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16889", "files": ["toolkit/components/extensions/parent/ext-downloads.js", "toolkit/components/extensions/schemas/downloads.json", "toolkit/components/extensions/test/xpcshell/test_ext_downloads_search.js"], "git_node": null, "git_parents": [null], "node": "32f1e101f51434bb7419d30e94b4a31193cf11f8", "parents": ["99b68e9d4a7c2aad92a4a7c64e96c71702b37e64"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1518002 - Update selection cache when initializing editor. r=masayuki, a=RyanVM\n\nGitLab's comment calls scrollTop on input event handler. The scollTop may cause\nreflow.  When causing reflow, editor is destroyed and initialized again. Then\nnsTextEditorState will set current value to editor.  But this is failure.\n\nBy bug 1465702, selection is cached in edit action. When initializing editor,\nselection controller is updated, so selection into cache becomes invalid. It\nmeans that all selection methods will return error since document is different.\n\nSo we should update selection cache when initializing editor.\n\nAlso, I cannot create test case for this situation since we have to cause reflow\nin input and/or composition event. Do you have any idea?\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16944", "files": ["editor/libeditor/EditorBase.cpp", "editor/libeditor/EditorBase.h"], "git_node": null, "git_parents": [null], "node": "ff8f2153265d685e8486211e391a2fdc09185453", "parents": ["32f1e101f51434bb7419d30e94b4a31193cf11f8"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1521066 - Fix double border rendering of border-collapsed tables. r=jrmuizel, a=RyanVM\n\nGotta love C++... I missed the `break;` for that branch so we were always\nfalling back to the solid border rendering path (which we use if the border is\ntoo small).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16977", "files": ["layout/painting/nsCSSRendering.cpp", "testing/web-platform/tests/css/css-tables/border-collapse-double-border-notref.html", "testing/web-platform/tests/css/css-tables/border-collapse-double-border.html"], "git_node": null, "git_parents": [null], "node": "a95de98740380133be0ae2e6368170cf413c021c", "parents": ["ff8f2153265d685e8486211e391a2fdc09185453"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1517937 - Move JhengHei to the end of zh-TW sans-serif font prefs on late-beta/release so that previous default of PMingLiu will take precedence for now. r=m_kato, a=RyanVM", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "9876a3bd6201164969f035266bb64ec983b286c6", "parents": ["a95de98740380133be0ae2e6368170cf413c021c"], "tags": ["FENNEC_65_0b13_BUILD1", "FENNEC_65_0b13_RELEASE", "FIREFOX_RELEASE_65_BASE"]}], "date": 1548013930, "git_changesets": [null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10546": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging mozilla-beta 9876a3bd6201164969f035266bb64ec983b286c6 with FIREFOX_RELEASE_65_BASE a=release DONTBUILD CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "244b5c7ca860d32cfe7dcaf3f16dc9a3d107422d", "parents": ["9876a3bd6201164969f035266bb64ec983b286c6"], "tags": ["FIREFOX_BETA_65_END"]}], "date": 1548071426, "git_changesets": [null], "user": "ffxbld-merge"}}
}";