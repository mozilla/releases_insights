: [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nis -\u003e e900b40750d8", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "75c0204dee04cd88f71a5c7c016d8fcc6efda2fa", "parents": ["26dbdd1fcfd6b8dd58cdfad425c2eca5826cdc3b"], "tags": []}], "date": 1547582423, "git_changesets": [null], "user": "ffxbld"}, "10526": {"changesets": [{"author": "Paul Adenot \u003cpaul@paul.cx\u003e", "branch": "default", "desc": "Bug 1499426 - Align the lifetime of AudioInputProcessing with the lifetime of MediaEngineWebRTCAudio. r=achronop, a=abillings\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16201", "files": ["dom/media/webrtc/MediaEngineWebRTCAudio.cpp"], "git_node": null, "git_parents": [null], "node": "8d48fc5df52513e5d144f1334bad6f188c333916", "parents": ["75c0204dee04cd88f71a5c7c016d8fcc6efda2fa"], "tags": []}, {"author": "sotaro \u003csotaro.ikeda.g@gmail.com\u003e", "branch": "default", "desc": "Bug 1493497 - Clear EGLSurfaceOverride correctly in SharedSurface_ANGLEShareHandle. r=jgilbert, a=RyanVM", "files": ["gfx/gl/SharedSurfaceANGLE.cpp"], "git_node": null, "git_parents": [null], "node": "4b5ae6076e03ae92c5be593491bedea65ca5336c", "parents": ["8d48fc5df52513e5d144f1334bad6f188c333916"], "tags": []}, {"author": "sotaro \u003csotaro.ikeda.g@gmail.com\u003e", "branch": "default", "desc": "Bug 1516787 - Add GLContextEGL::OnMarkDestroyed(). r=jgilbert, a=RyanVM", "files": ["gfx/gl/GLContext.cpp", "gfx/gl/GLContext.h", "gfx/gl/GLContextEGL.h", "gfx/gl/GLContextProviderEGL.cpp", "gfx/gl/SharedSurfaceANGLE.cpp"], "git_node": null, "git_parents": [null], "node": "44fe44a6a340b557bda4467ec632db5f4ac47c02", "parents": ["4b5ae6076e03ae92c5be593491bedea65ca5336c"], "tags": []}, {"author": "Michael Froman \u003cmfroman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1514874 - Start RDD process on-demand. r=jya,jld, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D15775", "files": ["dom/ipc/ContentChild.cpp", "dom/ipc/ContentChild.h", "dom/ipc/ContentParent.cpp", "dom/ipc/ContentParent.h", "dom/ipc/PContent.ipdl", "dom/media/ipc/RemoteDecoderModule.cpp", "dom/media/ipc/RemoteDecoderModule.h", "gfx/thebes/gfxPlatform.cpp", "ipc/ipdl/sync-messages.ini"], "git_node": null, "git_parents": [null], "node": "c10cd6aadb9656703e01212906b77d3232694f3b", "parents": ["44fe44a6a340b557bda4467ec632db5f4ac47c02"], "tags": []}, {"author": "Stephen A Pohl \u003cspohl.mozilla.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1511878 - Start respecting the alpha channel for disabled control text color on macOS to accommodate the way this system color is declared by the OS on macOS 10.14+. r=mstange, a=RyanVM", "files": ["widget/cocoa/nsLookAndFeel.mm"], "git_node": null, "git_parents": [null], "node": "92b23e3b94efeb8093e22cab16828efd5b1cc693", "parents": ["c10cd6aadb9656703e01212906b77d3232694f3b"], "tags": []}], "date": 1547586327, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10527": {"changesets": [{"author": "Nicolas Chevobbe \u003cnchevobbe@users.noreply.github.com\u003e", "branch": "default", "desc": "Bug 1519019 - Uplift fix to CallStack Group with anonymous function. r=jlast, a=RyanVM\n\nThis is the same patch as in Bug 1517572, applied on the beta branch.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16156", "files": ["devtools/client/debugger/new/src/components/SecondaryPanes/Frames/Group.js", "devtools/client/debugger/new/src/utils/pause/frames/displayName.js", "devtools/client/debugger/new/src/utils/pause/frames/index.js", "devtools/client/debugger/new/src/utils/pause/scopes/getScope.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-call-stack.js"], "git_node": null, "git_parents": [null], "node": "0205f0c7abb246a425a40a1af1cae0105c164f0f", "parents": ["92b23e3b94efeb8093e22cab16828efd5b1cc693"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1518619 - Pref on ASR Snippets for 65 Beta and Release. r=k88hudson, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16591", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "f4e3251f788d011661f75841fa6a8a8b5bf4f68e", "parents": ["0205f0c7abb246a425a40a1af1cae0105c164f0f"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1494748 - Ensure GeckoView saved state lives at least as long as the app process. r=snorp, a=RyanVM\n\nThe arguably most interesting bit of state of BrowserApp/GeckoApp, namely the\ncurrently open tabs, are living partly in Gecko and partly in the Tabs\nmanager singleton, the lifetimes of both of which are tied to the lifetime of\nthe app process.\n\nIf the whole process has been killed, things are simple: Neither the Tabs\nmanager nor Gecko know anything about any tabs and we simply restore them\nthrough the session store if enabled.\n\nIf GeckoApp is however being restored into an app process in which it had\nalready executed earlier on, meaning that we have some open tabs, it relies on\nthe savedInstanceState in order to correctly reconnect its GeckoView instance\nwith the correct previous GeckoSession.\n\nWe can however end up in a state where we don't have a savedInstanceState (e.g.\nbecause the user swiped away the BrowserApp activity in the task switcher), but\nthe app process keeps running throughout (if another activity of ours is still\npresent in the task switcher, e.g. a custom tab, or else if a service is active,\nthen standard Android keeps the process running even if the user swipes away an\nactivity).\n\nIn that case, if GeckoApp is subsequently recreated, the Android UI sees all the\nAndroid-side tabs in the Tabs manager, and Gecko in fact still has the Window\nopen that is containing all those tabs, but without the savedInstanceState\nGeckoApp doesn't know anything about that Window and proceeds to open a fresh\nsession instead.\n\nThis means that all previous tabs will appear white and unresponsive, while\nfreshly opened tabs will load, but they won't be correctly saved in the session\nstore, their context menu isn't working, etc., because we're not really\nexpecting to handle multiple Gecko-side Windows.\n\nTo fix this, we disable automatic state-saving for GeckoApp's GeckoView instance\nand instead do it manually, so we can keep another reference to the saved state\nin GeckoApplication, and therefore are able to retrieve it from there for as\nlong as the app process keeps running.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16393", "files": ["mobile/android/base/java/org/mozilla/gecko/GeckoApp.java", "mobile/android/base/java/org/mozilla/gecko/GeckoApplication.java"], "git_node": null, "git_parents": [null], "node": "406819dad2e19149542176bcdabc76dee49175cc", "parents": ["f4e3251f788d011661f75841fa6a8a8b5bf4f68e"], "tags": []}, {"author": "Matt Brubeck \u003cmbrubeck@mozilla.com\u003e", "branch": "default", "desc": "Bug 1493980 - Don't pass indefinite screen orientations to Gecko. r=snorp, a=RyanVM\n\nThis eliminates one potential source of crashes from passing bad orientation\nvalues to onOrientationChange.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D16207", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoScreenOrientation.java"], "git_node": null, "git_parents": [null], "node": "1cf642fe06ab408e19b34471d75d55753b148f13", "parents": ["406819dad2e19149542176bcdabc76dee49175cc"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1518514 - Correctly read and parse list.json in search engine manager. r=nalexander, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D15992", "files": ["mobile/android/base/java/org/mozilla/gecko/search/SearchEngineManager.java"], "git_node": null, "git_parents": [null], "node": "21f066e22f2a7ee0f218386922ee17135234b521", "parents": ["1cf642fe06ab408e19b34471d75d55753b148f13"], "tags": []}], "date": 1547593745, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10528": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nfr -\u003e c57794aeb4e2\nit -\u003e a37d2b75f8c4\nnl -\u003e dabf5a2a6c6a\npt-BR -\u003e 9174733ea658\ntr -\u003e 1dee6d8c008e", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "4cd18b066d5ea82a1c4ba991c886bc484c3be216", "parents": ["21f066e22f2a7ee0f218386922ee17135234b521"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nfr -\u003e c57794aeb4e2\ngu-IN -\u003e 0e5d9c61a3ec\nit -\u003e a37d2b75f8c4\npt-BR -\u003e 9174733ea658\nth -\u003e 6b2f5b8f9e6f\ntr -\u003e 1dee6d8c008e", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "f78c353eafb1740d924ae9dc2868f6ae4b48c1fe", "parents": ["4cd18b066d5ea82a1c4ba991c886bc484c3be216"], "tags": []}], "date": 1547629228, "git_changesets": [null, null], "user": "ffxbld"}, "10529": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nde -\u003e c88c019af7d9\nfr -\u003e 03cce8938e38", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "7453ee4ce39059bdcdcd42ff15231d5557d4a060", "parents": ["f78c353eafb1740d924ae9dc2868f6ae4b48c1fe"], "tags": [