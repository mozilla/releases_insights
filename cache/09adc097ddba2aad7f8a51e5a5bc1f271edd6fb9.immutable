7beed623", "parents": ["40f0bbdcd856b0302f984e3b07589f567abd9f99"], "tags": []}], "date": 1547042426, "git_changesets": [null, null], "user": "ffxbld"}, "10476": {"changesets": [{"author": "Karl Tomlinson \u003ckarlt+@karlt.net\u003e", "branch": "default", "desc": "Bug 1512737 - Assign HRTF to panningModel attribute instead of adding type property. r=padenot, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14494", "files": ["dom/media/webaudio/test/test_pannerNodeHRTFSymmetry.html", "dom/media/webaudio/test/test_pannerNodeTail.html"], "git_node": null, "git_parents": [null], "node": "39fe709c6cf8de41c2a739ad456877eb5fa1e7c3", "parents": ["0f838be24568f673a5bea33acfd9cce27beed623"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1495207 - Properly set and reset the animate attribute on the content blocking shield. r=ewright, a=RyanVM\n\nPreviously this code was using webProgress.isTopLevel to set and reset the shield animation,\nwhich is just plain nonsense and was based on false assumptions about it being something like\nwebProgress.isLoadingDocument. In reality this attribute just reflects whether the source of the\nevent is the top-level window or a frame, not the load type.\n\nThe new code uses the \"blocking\" state to set and reset the animation and uses the \"active\" attribute\nas a guard to ensure that we only set the \"animate\" attribute once per page. This works because\nthe \"active\" attribute is guaranteed to be reset on a top-level document load.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D15654", "files": ["browser/base/content/browser-contentblocking.js"], "git_node": null, "git_parents": [null], "node": "c777b4b5cd07b6575bacf5a2309b384c0c7c9c6f", "parents": ["39fe709c6cf8de41c2a739ad456877eb5fa1e7c3"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1502448 - Work around principal issues with pdfjs and saving local files. r=jkt,jaws, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D15568", "files": ["toolkit/content/contentAreaUtils.js"], "git_node": null, "git_parents": [null], "node": "274d224478736b7ff659c3d1f38dc8c2b2285a8a", "parents": ["c777b4b5cd07b6575bacf5a2309b384c0c7c9c6f"], "tags": []}, {"author": "Timothy Guan-tin Chien \u003ctimdream@gmail.com\u003e", "branch": "default", "desc": "Bug 1516292 - Use isSameNode() to compare mozFullScreenElement and the video host element. r=edgar, a=RyanVM\n\nThis does what's done in bug 1505547 but in a different way. For some reason, access\nshadowRoot.host in the function can trigger an assertion.\n\nthis.video is a Proxy so it cannot be compared, but all its methods are proxied.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D15767", "files": ["dom/media/tests/crashtests/1516292.html", "dom/media/tests/crashtests/crashtests.list", "toolkit/content/widgets/videocontrols.js"], "git_node": null, "git_parents": [null], "node": "2046aa36055220d9187f968fca3ab070d2de7665", "parents": ["274d224478736b7ff659c3d1f38dc8c2b2285a8a"], "tags": []}, {"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1514112 - Listen for font setting changes even if DWrite is not used. r=jrmuizel, a=RyanVM", "files": ["gfx/thebes/gfxWindowsPlatform.cpp"], "git_node": null, "git_parents": [null], "node": "7755fe5f3b0a84cc095b37a10a67d3488bf9cb1a", "parents": ["2046aa36055220d9187f968fca3ab070d2de7665"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1517711 - Check for a destroyed MediaStream on the right thread. r=padenot, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D15892", "files": ["dom/media/webrtc/MediaEngineWebRTCAudio.cpp"], "git_node": null, "git_parents": [null], "node": "d902ac21513900909c9673423827f16f76b12ada", "parent