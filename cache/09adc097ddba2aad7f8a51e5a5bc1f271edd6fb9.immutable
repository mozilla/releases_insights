rents": [null], "node": "f038d9fa2026c01bc7a76ba799c9a1fcc16e67ae", "parents": ["f713c586d397c53c3d3dc403638d7609f3da4e56"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1511811 - Remove useless GECKO_BORROWED_TYPE_MUT.\n\nThis causes a typedef mozilla::ServoElementSnapshot ServoElementSnapshot; to be\ncreated, which we rely on bindgen not generating.\n\nBut bindgen will start (correctly) generating it in:\n\n  https://github.com/rust-lang/rust-bindgen/pull/1436\n\nSo easiest fix is just to remove this typedef, since it's just used by one FFI\nfunction.\n", "files": ["layout/style/BorrowedTypeList.h", "layout/style/GeckoBindings.h"], "git_node": null, "git_parents": [null], "node": "79cd08c08d39dbaba7641d69ef906d887ff1310a", "parents": ["f038d9fa2026c01bc7a76ba799c9a1fcc16e67ae"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1511811 - Make page-break-* Gecko-only.\n\nServo doesn't support it.\n", "files": ["servo/components/style/properties/shorthands/box.mako.rs"], "git_node": null, "git_parents": [null], "node": "1ae60a036ccaeb642f90260969f6b7625e87a0ad", "parents": ["79cd08c08d39dbaba7641d69ef906d887ff1310a"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1511811 - Rustfmt new changes to ensure Servo-tidy doesn't complain.\n", "files": ["servo/components/style/gecko/conversions.rs", "servo/components/style/values/animated/mod.rs", "servo/components/style/values/animated/transform.rs", "servo/components/style/values/generics/transform.rs", "servo/components/style/values/specified/box.rs"], "git_node": null, "git_parents": [null], "node": "2c5cf5f741b890fb71bf0c27c743e4f0e3a1dbed", "parents": ["1ae60a036ccaeb642f90260969f6b7625e87a0ad"], "tags": []}, {"author": "Paul Rouget \u003cme@paulrouget.com\u003e", "branch": "default", "desc": "Bug 1511811 - Update mozjs and enable 'init_once' feature for Android.\n\nCherry-picks https://github.com/servo/servo/pull/22200\n", "files": ["servo/components/malloc_size_of/Cargo.toml"], "git_node": null, "git_parents": [null], "node": "4a9fe235c6b0f2255880fe8c914b6f57f929232c", "parents": ["2c5cf5f741b890fb71bf0c27c743e4f0e3a1dbed"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1511811 - Update Servo's version of encoding_rs.\n", "files": ["servo/components/style/Cargo.toml"], "git_node": null, "git_parents": [null], "node": "7a36832beb552ab97cb7a723a8cad888ed318dd4", "parents": ["4a9fe235c6b0f2255880fe8c914b6f57f929232c"], "tags": []}, {"author": "Bastien Orivel \u003ceijebong@bananium.fr\u003e", "branch": "default", "desc": "Bug 1511811 - Update crossbeam-channel to 0.3.\n\nCherry-picks https://github.com/servo/servo/pull/22142\n", "files": ["servo/components/malloc_size_of/Cargo.toml", "servo/components/malloc_size_of/lib.rs", "servo/components/style/Cargo.toml", "servo/components/style/animation.rs", "servo/components/style/context.rs", "servo/components/style/lib.rs"], "git_node": null, "git_parents": [null], "node": "eeef84fe603dacc8421c14ac951cffe569c8c815", "parents": ["7a36832beb552ab97cb7a723a8cad888ed318dd4"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1511811 - Minor build fixup after the Servo crossbeam_channel update.\n", "files": ["servo/components/style/animation.rs"], "git_node": null, "git_parents": [null], "node": "bc9324a80fac8d94452ee278c2332f23ce04fbdf", "parents": ["eeef84fe603dacc8421c14ac951cffe569c8c815"], "tags": []}, {"author": "Vincent R \u003cgrosbouddha@gmail.com\u003e", "branch": "default", "desc": "Bug 1503175 - Restore the previous inspector layout when reopening. r=gl", "files": ["devtools/client/inspector/inspector.js", "devtools/client/inspector/test/browser.ini", "devtools/client/inspector/test/browser_inspector_pane_state_restore.js"], "git_node": null, "git_parents": [null], "node": "decb54eeaa7db1b065fb92eede8ac43c3edb5199", "parents": ["bc9324a80fac8d94452ee278c2332f23ce04fbdf"], "tags": []}, {"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1505063 - Only flip remoteness in RDM if we're switching from the privileged content process. r=ochameau\n\nThis means that for the File URI content process, we end up closing RDM if the page\nnavigates. This appears to be an acceptable trade-off, as this is the behaviour we've\nbeen shipping since bug 1453519 landed (Firefox 61).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13331", "files": ["devtools/client/responsive.html/browser/swap.js"], "git_node": null, "git_parents": [null], "node": "cac01bf337321891bb372357235494c760f28cb5", "parents": ["1a6f9251c41f32feca557aa9f9ace21070bf803e"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1511496 - Let the autohiding menu bar match the tab bar's height. r=mconley\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13595", "files": ["browser/themes/windows/browser.css"], "git_node": null, "git_parents": [null], "node": "e4e25a7e681f9574874c7bf947c7d60e1219cd9b", "parents": ["cac01bf337321891bb372357235494c760f28cb5"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1062128 - set tooltiptext for new tab button directly for a11y reasons, r=johannh\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13406", "files": ["browser/base/content/browser.js", "browser/base/content/tabbrowser.xml"], "git_node": null, "git_parents": [null], "node": "a002d2b3408bf9ac543f723c50818e8bfdb27fea", "parents": ["e4e25a7e681f9574874c7bf947c7d60e1219cd9b"], "tags": []}, {"author": "Patrick Brosset \u003cpbrosset@mozilla.com\u003e", "branch": "default", "desc": "Bug 1505747 - Reset flex overlay colors before testing them; r=gl\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13680", "files": ["devtools/client/inspector/flexbox/test/browser_flexbox_highlighter_color_picker_on_ESC.js", "devtools/client/inspector/flexbox/test/browser_flexbox_highlighter_color_picker_on_RETURN.js"], "git_node": null, "git_parents": [null], "node": "7d3b17b7130955d9afbc9c10a188bb6fd39a2370", "parents": ["a002d2b3408bf9ac543f723c50818e8bfdb27fea"], "tags": []}, {"author": "Razvan Caliman \u003crcaliman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1506170 - Clear the changes stored on the actor upon page refresh/navigate; r=bradwerth\n\nUntil we implement intentional persistence of changes between page refreshes, the Changes actor should clear its stack of changes to avoid polluting the next DevTools session.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13618", "files": ["devtools/server/actors/changes.js"], "git_node": null, "git_parents": [null], "node": "0f02ec66af19136b49ecbcb4a21596b8330b1f1c", "parents": ["7d3b17b7130955d9afbc9c10a188bb6fd39a2370"], "tags": []}, {"author": "Razvan Caliman \u003crcaliman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1506455 - Enforce LTR code on RTL layout in Changes panel r=pbro\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13617", "files": ["devtools/client/themes/changes.css"], "git_node": null, "git_parents": [null], "node": "215654db940b23c34d3360a8d348709eef52d157", "parents": ["0f02ec66af19136b49ecbcb4a21596b8330b1f1c"], "tags": []}, {"author": "Razvan Caliman \u003crcaliman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1491887 - Enable tracking CSS changes and the Changes panel for all release channels; r=gl\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13620", "files": ["devtools/client/preferences/devtools-client.js"], "git_node": null, "git_parents": [null], "node": "98462e66f4d3c513be641a4c6bdfa8fc6f28a621", "parents": ["215654db940b23c34d3360a8d348709eef52d157"], "tags": []}, {"author": "Bogdan Tara \u003cbtara@mozilla.com\u003e", "branch": "default", "desc": "Merge autoland to mozilla-central.  a=merge", "files": ["editor/reftests/spellcheck-contenteditable-nofocus.html", "third_party/python/compare-locales/compare_locales/compare.py", "third_party/python/compare-locales/compare_locales/paths.py", "third_party/python/compare-locales/compare_locales/tests/test_paths.py", "third_party/python/fluent/fluent/syntax/ftlstream.py"], "git_node": null, "git_parents": [null, null], "node": "77f852e2fb222a1b3647c9c01cb380810592a8ac", "parents": ["60b122ce38e6f529db79fd61db75ee8a8c6f3011", "a002d2b3408bf9ac543f723c50818e8bfdb27fea"], "tags": []}, {"author": "Bogdan Tara \u003cbtara@mozilla.com\u003e", "branch": "default", "desc": "Merge inbound to mozilla-central. a=merge", "files": ["third_party/rust/darling_core/src/ast.rs", "third_party/rust/darling_core/src/codegen/fmi_impl.rs", "third_party/rust/darling_core/src/from_meta_item.rs", "third_party/rust/darling_core/src/macros.rs", "third_party/rust/darling_core/src/options/from_meta_item.rs", "third_party/rust/synstructure-0.8.1/.cargo-checksum.json", "third_party/rust/synstructure-0.8.1/Cargo.toml", "third_party/rust/synstructure-0.8.1/README.md", "third_party/rust/synstructure-0.8.1/src/lib.rs", "third_party/rust/synstructure-0.8.1/src/macros.rs"], "git_node": null, "git_parents": [null, null], "node": "df64b0b461fd66616049654d4a4b7d136ab770c8", "parents": ["77f852e2fb222a1b3647c9c01cb380810592a8ac", "decb54eeaa7db1b065fb92eede8ac43c3edb5199"], "tags": []}, {"author": "Bogdan Tara \u003cbtara@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland.  a=merge CLOSED TREE", "files": [], "git_node": null, "git_parents": [null, null], "node": "215d850888f9c5f04c98cf05cb4ea70444058db4", "parents": ["98462e66f4d3c513be641a4c6bdfa8fc6f28a621", "df64b0b461fd66616049654d4a4b7d136ab770c8"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1511752 - Make IMContextWrapper::OnKeyEvent() treat GDK_KEY_PRESS event without any key information in a dead key sequence as synthesized by current keyboard layout for asynchronous handling r=m_kato\n\nSome keyboard layouts which have dead keys may handle dead key composition\nasynchronously.  In this case, they don't rely on IME like iBus/Fcitx.\n\nAs far as I've tested, German (QWERTY) keyboard layout is one of such\nkeyboard layout.  This returns true when gtk_im_context_filter_keypress()\nis called for a base character input (like \"a\").  Then, it synthesizes\nGDK_KEY_PRESS event without any key information such as:\n\u003e { type=GDK_KEY_PRESS, keyval=(null), unicode=0x0, state=, time=0,\n\u003e   hardware_keycode=0, group=0 }\nSo, this is not marked as IBUS_IGNORED_MASK nor FcitxKeyState_IgnoredMask\nby IME, but we should ignore this event since we should've already dispatched\n\"keydown\" event for the preceding \"a\" key event, and anyway \"keydown\" event\nfor the synthesized event does not make sense for any web apps.\n\nThis patch makes IMContextWrapper::OnKeyEvent() ignore such key event, i.e.,\nwhen it's in a dead key sequence, and GDK_KEY_PRESS does not have enough\ninformation, e.g., hardware_keycode shouldn't be 0 especially for printable\nkeys.  Therefore, this patch make it check only hardware_keycode value and\ngdk_keyval_to_unicode(aEvent-\u003ekeyval) value.\n\nIf some keyboard layouts would send the original key event as is, we would\nneed to do more, but currently, this is enough and safe to land this timing.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13656", "files": ["widget/gtk/IMContextWrapper.cpp"], "git_node": null, "git_parents": [null], "node": "f7fafed0e4a9c1d8e1895ddaf0b21f6a6a160c0e", "parents": ["215d850888f9c5f04c98cf05cb4ea70444058db4"], "tags": []}, {"author": "Cameron McCormack \u003ccam@mcc.id.au\u003e", "branch": "default", "desc": "Bug 1511842 - Remove unused nsLayoutStaticsRef. r=TYLin\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13684", "files": ["layout/build/nsLayoutStatics.h"], "git_node": null, "git_parents": [null], "node": "b118f8ec47f530ab3cf08d0bc6c9af7e1ffe4af8", "parents": ["f7fafed0e4a9c1d8e1895ddaf0b21f6a6a160c0e"], "tags": []}, {"author": "Gurzau Raul \u003crgurzau@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset b118f8ec47f5 (bug 1511842) for web platform failures due to the python package not being installed on a CLOSED TREE", "files": ["layout/build/nsLayoutStatics.h"], "git_node": null, "git_parents": [null], "node": "5e260e3fd46fae7b38bb699a74fe499fa8d3d033", "parents": ["b118f8ec47f530ab3cf08d0bc6c9af7e1ffe4af8"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1510909 - Bypass calling nsContentUtils::IsThirdPartyWindowOrChannel() for BEHAVIOR_REJECT_TRACKER r=baku\n\nCalling this function is just a waste of time since we will check\nthird-partiness a few statements further down.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13500", "files": ["toolkit/components/antitracking/AntiTrackingCommon.cpp"], "git_node": null, "git_parents": [null], "node": "0e09be458b461ca2c238148bd81cd1f9e851a68a", "parents": ["5e260e3fd46fae7b38bb699a74fe499fa8d3d033"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1511501 - Add information about the tree-wide clang-format to .git-blame-ignore-revs r=kats\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13584", "files": [".git-blame-ignore-revs"], "git_node": null, "git_parents": [null], "node": "3211507c19bf6a67ba39553df86f4796006b8958", "parents": ["0e09be458b461ca2c238148bd81cd1f9e851a68a"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1511340 - fix another typo to restore align=center to the devedition sync box, r=zbraniecki\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13540", "files": ["browser/components/preferences/in-content/main.xul"], "git_node": null, "git_parents": [null], "node": "4798ffe0bfd3dbdcee941fdf76b4fffe2112e655", "parents": ["3211507c19bf6a67ba39553df86f4796006b8958"], "tags": []}, {"author": "Razvan Caliman \u003crcaliman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1499994 - Revert test instrumentation for Changes panel telemetry. r=pbro\n\nThis removes the instrumentation to test the basic telemetry for the Changes panel (open count, time opened).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13691", "files": ["devtools/client/shared/test/browser_telemetry_sidebar.js"], "git_node": null, "git_parents": [null], "node": "05e7fea07c8d4ac68741ae706a35d8905985785d", "parents": ["4798ffe0bfd3dbdcee941fdf76b4fffe2112e655"], "tags": []}, {"author": "Razvan Caliman \u003crcaliman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1508748 - Avoid duplicate tracking of the same removed CSS declaration. r=pbro\n\nWhen a declaration is disabled, it is tracked as removed in the Changes panel.\nWhen deleting a disabled declaration, we take care not track it as removed again.\n\nIncludes stricter checks when matching previously tracked added and removed declarations.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13616", "files": ["devtools/client/inspector/changes/reducers/changes.js", "devtools/client/inspector/changes/test/browser.ini", "devtools/client/inspector/changes/test/browser_changes_declaration_remove_disabled.js"], "git_node": null, "git_parents": [null], "node": "9d1eeceace1b9b954791a2554c4e497c6fe8ab46", "parents": ["05e7fea07c8d4ac68741ae706a35d8905985785d"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1511903 - r=johannh\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13714", "files": ["browser/base/content/browser.js", "browser/modules/FaviconLoader.jsm"], "git_node": null, "git_parents": [null], "node": "5516f3e7b817f0ec3543d0fa6295c01e4363238b", "parents": ["9d1eeceace1b9b954791a2554c4e497c6fe8ab46"], "tags": []}, {"author": "WR Updater Bot \u003cgraphics-team@mozilla.staktrace.com\u003e", "branch": "default", "desc": "Bug 1511814 - Update webrender to commit add1538234a214a371e471bff67734afd7c3ca95 (WR PR #3381). r=kats\n\nhttps://github.com/servo/webrender/pull/3381\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13724", "files": ["gfx/webrender_bindings/revision.txt", "gfx/wr/webrender/src/batch.rs", "gfx/wr/webrender/src/prim_store.rs"], "git_node": null, "git_parents": [null], "node": "8f21a826a2b69e2778948de40d505bf4a24a5200", "parents": ["5516f3e7b817f0ec3543d0fa6295c01e4363238b"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 5516f3e7b817 (bug 1511903) for browser-chrome failures in browser/components/sessionstore/test/browser_attributes.js. CLOSED TREE", "files": ["browser/base/content/browser.js", "browser/modules/FaviconLoader.jsm"], "git_node": null, "git_parents": [null], "node": "f3c5235419537c434139d62f9bbebc1165c806b7", "parents": ["8f21a826a2b69e2778948de40d505bf4a24a5200"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1511778 - Remove skip if verify for test_addon_reload and test_addons_actor;r=ochameau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13665", "files": ["devtools/server/tests/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "2cc09eeb4898c1245d9ae01c95b8ce5d622c8122", "parents": ["f3c5235419537c434139d62f9bbebc1165c806b7"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1505719 - Try harder when computing breakpad IDs for Android system libraries. r=ted\n\nDifferential Revision: https://phabricator.services.mozilla.com/D12836", "files": ["Cargo.lock", "tools/profiler/rust-helper/Cargo.toml", "tools/profiler/rust-helper/src/elf.rs", "tools/profiler/rust-helper/src/lib.rs"], "git_node": null, "git_parents": [null], "node": "1f38344436a918241109ca2a5c4e939d1c33cde3", "parents": ["2cc09eeb4898c1245d9ae01c95b8ce5d622c8122"], "tags": []}, {"author": "Patrick Brosset \u003cpbrosset@mozilla.com\u003e", "branch": "default", "desc": "Bug 1507723 - Don't inline only-child short text nodes that are also flex items; r=gl\n\nThis change cleans up a lot of the getCurrentDisplay's logic which was unnecessarily\ncomplex, it seems.\nIt also extracts the logic to walk up the DOM to find flex/grid containers to a\nreusable functions.\nFinally, this new extracted function is now used in the walker to determine if a text\nnode can be inlined in its parent element or not.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13677", "files": ["devtools/client/inspector/flexbox/test/browser.ini", "devtools/client/inspector/flexbox/test/browser_flexbox_text_nodes_are_not_inlined.js", "devtools/client/inspector/flexbox/test/doc_flexbox_text_nodes.html", "devtools/server/actors/inspector/walker.js", "devtools/server/actors/layout.js"], "git_node": null, "git_parents": [null], "node": "55d27d4a5f7981c40c6b6fd26dcfcce29d56b510", "parents": ["1f38344436a918241109ca2a5c4e939d1c33cde3"], "tags": []}, {"author": "Erica Wright \u003cewright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1510734 - Content Blocking strict setting now uses network.cookie.cookieBehavior=4. r=johannh,flod\n\nThe strict category should block third-party tracking cookies instead of all third-party cookies. This changes the requirements to match that category, so existing strict users will be moved to custom.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13325", "files": ["browser/components/nsBrowserGlue.js", "browser/components/preferences/in-content/privacy.xul"], "git_node": null, "git_parents": [null], "node": "a5acc276890597b2314106398a1955870db63a65", "parents": ["55d27d4a5f7981c40c6b6fd26dcfcce29d56b510"], "tags": []}, {"author": "Andi-Bogdan Postelnicu \u003cbpostelnicu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1511827 - Download clang based static-analysis during bootstrap after every other dependency is downloaded. r=nalexander\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13678", "files": ["python/mozboot/mozboot/bootstrap.py"], "git_node": null, "git_parents": [null], "node": "44c791154e7cb7108749362de3340ee69e4f9bb0", "parents": ["a5acc276890597b2314106398a1955870db63a65"], "tags": []}, {"author": "Ciure Andrei \u003caciure@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset a5acc2768905 (bug 1510734) for browser_contentblocking.js failures CLOSED TREE", "files": ["browser/components/nsBrowserGlue.js", "browser/components/preferences/in-content/privacy.xul"], "git_node": null, "git_parents": [null], "node": "88d980f9a84e6d1dd5bc82f259a2ebf3e792ba4d", "parents": ["44c791154e7cb7108749362de3340ee69e4f9bb0"], "tags": []}, {"author": "Haik Aftandilian \u003chaftandilian@mozilla.com\u003e", "branch": "default", "desc": "Bug 1511376 - Firefox crashes during startup when executed from tempdir r=Alex_Gaynor\n\nChange nsMacUtilsImpl::GetAppPath() to not depend on the app bundle ending in \".app\".\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13682", "files": ["xpcom/base/nsMacUtilsImpl.cpp"], "git_node": null, "git_parents": [null], "node": "4021b54225626c9b2e52db192b30d94d833be924", "parents": ["88d980f9a84e6d1dd5bc82f259a2ebf3e792ba4d"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1503756 - Inherit from working desktop1604-test image to work around non-deterministic rebuilding; r=dustin\n\nThe desktop1604-test image doesn't build deterministically, primarily\ndue to not pinning APT package indices. Rebuilding it from scratch\ntoday results in at least 2 problems causing test failures. One has\nto do with a renamed media device. Another is not yet determined but\nis causing the Android emulator to fail.\n\nVarious people have spent several hours trying to debug the failures.\nThere are some leads. But no obvious solution is in sight. Various\ncode landings are blocked on this.\n\nEnough is enough.\n\nThis commit modifies desktop1604-test so it inherits from a base image\nthat contains the last good build of the image. Other minimal\nmodifications were made to enable the image to build with a populated\nbase image.\n\nThis is a gross hack. It is equivalent to sweeping dust under the rug.\nBut it gets the job done. It should unblock various code landings.\n\nThe base image was imported from task K-qJkvIqQQ-EFK8-4zg_nA.\n\nThe intent is to undo this hack ASAP by fixing the base image. This is\ntracked by bug 1511527.\n\nAs part of developing this patch, I ran into at least two different\nissues building the Docker image using the last known good image as a\nbase.\n\nOn my desktop machine using btrfs for Docker storage, the image failed to\nbuild due to a \"failed to export image: failed to create image: failed\nto get layer XXX: layer does not exist\" error.\n\nIn CI, I ran into separate issues where some `rm` invocations didn't\nwork. Why, I have no clue.\n\nI ran a `docker export | docker import` of a running container with\nthe good image to produce a new Docker image with just the filesystem\ncontents. This had the effect of squashing the original Docker image\ninto a single layer. For reasons I can't explain, this made the image\nbuild in CI. Welcome to the wonderful world of Docker bugs, everyone.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13600", "files": ["taskcluster/docker/desktop1604-test/Dockerfile"], "git_node": null, "git_parents": [null], "node": "12750da9341c19c43c322eb28db4a7d347bd78ce", "parents": ["4021b54225626c9b2e52db192b30d94d833be924"], "tags": []}, {"author": "sreeise \u003creeisesean@gmail.com\u003e", "branch": "default", "desc": "Bug 1476289 Added event.stopPropagation to snapshot onClick delete function to prevent selected snapshot from being cleared from view r=julienw\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13117", "files": ["devtools/client/memory/components/SnapshotListItem.js", "devtools/client/memory/test/browser/browser_memory_clear_snapshots.js"], "git_node": null, "git_parents": [null], "node": "c9a3e8cf52603bce8be325693b284f7bed93e9f2", "parents": ["12750da9341c19c43c322eb28db4a7d347bd78ce"], "tags": []}, {"author": "Mike Shal \u003cmshal@mozilla.com\u003e", "branch": "default", "desc": "Bug 1476604 - update sccache; r=firefox-build-system-reviewers,nalexander,ted\n\nThis change updates sccache to this revision:\nhttps://github.com/mozilla/sccache/commit/8f295c09cfdd4cff4f4a0c6f0e057979eeb8842d\n\nPrimarily to pick up the changes for handling -Xclang: https://github.com/mozilla/sccache/pull/332\n\nMozReview-Commit-ID: GHinVG4XNDg\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13288", "files": ["taskcluster/ci/toolchain/linux.yml", "taskcluster/scripts/misc/build-sccache.sh"], "git_node": null, "git_parents": [null], "node": "77b100d5fe369ba2cc7ae86c66ee5c4bd9a6519a", "parents": ["c9a3e8cf52603bce8be325693b284f7bed93e9f2"], "tags": []}, {"author": "Matthew Gaudet \u003cmgaudet@mozilla.com\u003e", "branch": "default", "desc": "Bug 1511168: Mark low-level memory management comment with SMDOC r=tcampbell DONTBUILD\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13733", "files": ["js/public/Utility.h"], "git_node": null, "git_parents": [null], "node": "5556b6a018243b63071959430e5c496e5c9e2c94", "parents": ["77b100d5fe369ba2cc7ae86c66ee5c4bd9a6519a"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1508726 - Prevent application updates when Marionette is enabled. r=bytesized\n\nMarionette is a remote protocol which allows to automate the\napplication. Because it is not only run in CI automation but\nalso by users outside of the tree, the flag \"Cu.isInAutomation\"\ncannot be used to determine if updates can be downloaded and\ninstalled.\n\nBut it can b achieved by relying on the \"running\" state as\nexposed by Marionette through the nsIMarionette interface.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13515", "files": ["toolkit/mozapps/update/nsUpdateService.js"], "git_node": null, "git_parents": [null], "node": "ffc42da8138efd66299329615945c433bcafc2da", "parents": ["5556b6a018243b63071959430e5c496e5c9e2c94"], "tags": []}, {"author": "Toby Ward \u003ctobyfrederickward@gmail.com\u003e", "branch": "default", "desc": "Bug 1435562 - browser.tabs.warnOnOpen is now respected when opening multiple items from the library. r=Standard8\n\n- Unified openContainerNodeInTabs and openURINodesInTabs in PlacesUIUtils into openMultipleLinksInTabs\n- Users are now warned when the amount of links to be opened is equal to or exceeds browser.tabs.maxOpenBeforeWarn\n\nDifferential Revision: https://phabricator.services.mozilla.com/D12983", "files": ["browser/base/content/browser-places.js", "browser/components/places/PlacesUIUtils.jsm", "browser/components/places/content/controller.js", "browser/components/places/content/places.js", "browser/components/places/tests/browser/browser.ini", "browser/components/places/tests/browser/browser_library_warnOnOpen.js", "browser/components/places/tests/browser/head.js"], "git_node": null, "git_parents": [null], "node": "81a6b32f2a8bf8e8579ecc6ae81ae7f0d12f0d91", "parents": ["ffc42da8138efd66299329615945c433bcafc2da"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1508726 - [geckodriver] Use \"app.update.disabledForTesting\" to disable application updates. r=ato\n\nUntil Firefox 64 the preference \"app.update.auto\" controlled if updates\ncan be downloaded and applied. This changed in Firefox 65, and now the\npreference \"app.update.disabledForTesting\" controls it.\n\nDepends on D13515\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13516", "files": ["testing/geckodriver/src/prefs.rs", "testing/marionette/components/marionette.js"], "git_node": null, "git_parents": [null], "node": "766ba8a6c8754a0ed46567040023a9e4051353fe", "parents": ["81a6b32f2a8bf8e8579ecc6ae81ae7f0d12f0d91"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1508726 - [marionette] Use \"app.update.disabledForTesting\" to disable application updates. r=ato\n\nUntil Firefox 64 the preference \"app.update.auto\" controlled if updates\ncan be downloaded and applied. This changed in Firefox 65, and now the\npreference \"app.update.disabledForTesting\" controls it.\n\nDepends on D13516\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13517", "files": ["testing/firefox-ui/tests/puppeteer/test_software_update.py", "testing/marionette/client/marionette_driver/geckoinstance.py", "testing/marionette/harness/marionette_harness/tests/unit/test_marionette.py"], "git_node": null, "git_parents": [null], "node": "5c59407599f6c59d1a50ea850cb43384c71ab529", "parents": ["766ba8a6c8754a0ed46567040023a9e4051353fe"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1497660 - Add new hg.mo fingerprint to run-task fallback; r=dustin\n\nWe duplicate the hg.mo fingerprints in run-task so we can fall\nback to known good values in case secrets retrieval fails.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D10090", "files": ["taskcluster/scripts/run-task"], "git_node": null, "git_parents": [null], "node": "81f34990a2041b10f1d872a25f82bc3a8a44146d", "parents": ["5c59407599f6c59d1a50ea850cb43384c71ab529"], "tags": []}, {"author": "Dustin J. Mitchell \u003cdustin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1498640 - deploy latest image_builder image r=glandium\n\nThis uses the latest image_builder image (on docker hub) to build even the\nimage_builder image.\n\nThe change to `docker.py` handles a new API response (`aux`) from the Docker\ndaemon.  It's unclear what this key means, but displaying it is simple.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8441", "files": ["taskcluster/docker/image_builder/VERSION", "taskcluster/docs/docker-images.rst", "taskcluster/taskgraph/transforms/docker_image.py", "taskcluster/taskgraph/util/docker.py"], "git_node": null, "git_parents": [null], "node": "cadb8d9fd21b3465cd28ac9c2b1968c700a43012", "parents": ["81f34990a2041b10f1d872a25f82bc3a8a44146d"], "tags": []}, {"author": "Bob Clary \u003cbclary@bclary.com\u003e", "branch": "default", "desc": "Bug 1501802 - Update tooltool.py fetch_file to log.info exceptions instead of log.debug, r=garbas", "files": ["python/mozbuild/mozbuild/action/tooltool.py", "testing/mozharness/external_tools/tooltool.py"], "git_node": null, "git_parents": [null], "node": "9a627c7442337edade33176949a2565bee988666", "parents": ["cadb8d9fd21b3465cd28ac9c2b1968c700a43012"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1505579 - Upgrade to latest robustcheckout; r=sheehan\n\nVendored robustcheckout extension from the version-control-tools\nrepository revision d78e5c52a0228c3dc8ed03fe43bf749c8e68bd20 without\nmodifications.\n\nThis is needed to support Mercurial 4.8.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D11398", "files": ["testing/mozharness/external_tools/robustcheckout.py"], "git_node": null, "git_parents": [null], "node": "60e0ab5a32d0fa44b5d4089d15888bf023ef1d38", "parents": ["9a627c7442337edade33176949a2565bee988666"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1505579 - Upgrade Docker images to Mercurial 4.8; r=sheehan\n\nWe need to run Mercurial 4.8 so we can start using SQLite storage\nand wire protocol version 2 for partial clones.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D11399", "files": ["taskcluster/ci/packages/kind.yml", "taskcluster/docker/recipes/install-mercurial.sh"], "git_node": null, "git_parents": [null], "node": "5c22ecb14543f7aebae1435416f8b127fd6f51df", "parents": ["60e0ab5a32d0fa44b5d4089d15888bf023ef1d38"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1511745 - Make \"Unrecognized urlbar event\" exceptions more specific and provide an Error object. r=Standard8\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13654", "files": ["browser/components/urlbar/UrlbarInput.jsm", "browser/components/urlbar/UrlbarView.jsm"], "git_node": null, "git_parents": [null], "node": "5ef83bfaf2bb736224682ae84dbe7a8c60ca5fb6", "parents": ["5c22ecb14543f7aebae1435416f8b127fd6f51df"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1511744 - Move UrlbarView overflow and underflow handlers from the class constructor to dedicated methods. r=Standard8\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13653", "files": ["browser/components/urlbar/UrlbarView.jsm"], "git_node": null, "git_parents": [null], "node": "0e2e18a54e1c8b0e04d4aa62f9fe0cec65fa74d4", "parents": ["5ef83bfaf2bb736224682ae84dbe7a8c60ca5fb6"], "tags": []}, {"author": "Dana Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "bug 1507012 - set up and start gnome-keyring-daemon so libsecret works in Firefox in our test environment r=dustin\n\nCounterintuitively, gnome-keyring-daemon needs its capabilities removed in order for it to run in\ndocker (doing so means that it can't lock secrets in memory, but since this is for tests and we\naren't storing any actually sensitive secrets, this should be fine).\n\nThis patch also makes sure gnome-keyring-daemon is running with an unlocked keychain before the\ntests are run.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13020", "files": ["taskcluster/docker/desktop1604-test/Dockerfile", "taskcluster/scripts/tester/test-linux.sh"], "git_node": null, "git_parents": [null], "node": "c6135d5825bbfc19dfd4400a807bbbfaa16a22b1", "parents": ["0e2e18a54e1c8b0e04d4aa62f9fe0cec65fa74d4"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414804 - Fix test for expired certificate \"helpful\" messaging to users with broken system clocks. r=Gijs\n\nWe initially thought we would need a new test certificate to be able to test\nclock skew, but I found that we can reliably produce the clock skew page by\nmaking Firefox believe that the validity range of the cert used by\nexpired.example.com is the correct date. How we do that is described in\nmore detail in the test comments.\n\nThis patch also updates the formatter for the new clock skew page to not\nshow hours and minutes, as it did previously on the old clock skew warnings.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13690", "files": ["browser/actors/NetErrorChild.jsm", "browser/base/content/test/about/browser.ini", "browser/base/content/test/about/browser_aboutCertError.js", "browser/base/content/test/about/browser_aboutCertError_clockSkew.js"], "git_node": null, "git_parents": [null], "node": "4002b751596ed32ace109b4e14145b0720065184", "parents": ["c6135d5825bbfc19dfd4400a807bbbfaa16a22b1"], "tags": []}, {"author": "Dennis Schubert \u003cdschubert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1511600 - Disable WebCompat Reporter in some tests.  a=testonly\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13739", "files": ["browser/modules/test/browser/head.js", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "24a3e091070c0f89b34760a110e2d794ad923bcf", "parents": ["4002b751596ed32ace109b4e14145b0720065184"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1511856 - Ensure the URL bar isn't hovered when starting browser_UrlbarInput_tooltip.js. r=mak\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13685", "files": ["browser/components/urlbar/tests/browser/browser_UrlbarInput_tooltip.js"], "git_node": null, "git_parents": [null], "node": "94582b9363c6d7759a996ad49ce92d52fd62eba8", "parents": ["24a3e091070c0f89b34760a110e2d794ad923bcf"], "tags": []}, {"author": "Ciure Andrei \u003caciure@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 5c22ecb14543 (bug 1505579) for docker image bustages CLOSED TREE", "files": ["taskcluster/ci/packages/kind.yml", "taskcluster/docker/recipes/install-mercurial.sh"], "git_node": null, "git_parents": [null], "node": "5dca9c949ba4b969ba486d5926a79c7dba8e15c8", "parents": ["94582b9363c6d7759a996ad49ce92d52fd62eba8"], "tags": []}, {"author": "Paul Adenot \u003cpaul@paul.cx\u003e", "branch": "default", "desc": "Bug 1145816 - Reenbable test_mediaElementAudioSourceNodePassThrough.html on Android. r=pehrsons\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13430", "files": ["dom/media/webaudio/test/mochitest.ini"], "git_node": null, "git_parents": [null], "node": "a1761acdc3a3cf2cf60b9edeffcf815f503fecca", "parents": ["5dca9c949ba4b969ba486d5926a79c7dba8e15c8"], "tags": []}, {"author": "Erica Wright \u003cewright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1507981 - Content Blocking UI Fallback. r=johannh\n\nIf blocking third-party tracking cookies does not get turned on by default, this will be the UI we will use instead. The standard category only includes tracking protection in private windows, the standard section no longer expands.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D12686", "files": ["browser/components/preferences/in-content/privacy.js", "browser/components/preferences/in-content/privacy.xul", "browser/themes/shared/incontentprefs/privacy.css"], "git_node": null, "git_parents": [null], "node": "d56cf7c8212addbc9a209f15f30331bb24a7af7d", "parents": ["a1761acdc3a3cf2cf60b9edeffcf815f503fecca"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1511837 - Simplify JSOP_SUPERFUN and JSOP_SUPERBASE by factoring out the callee lookup. r=arai\n\nWe now emit JSOP_CALLEE or JSOP_ENVCALLEE (a new op) to load the callee.\nJSOP_SUPERFUN and JSOP_SUPERBASE no longer have to walk the scope/environment\nchain.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13688", "files": ["js/src/frontend/BytecodeEmitter.cpp", "js/src/frontend/BytecodeEmitter.h", "js/src/frontend/CallOrNewEmitter.cpp", "js/src/frontend/ElemOpEmitter.cpp", "js/src/frontend/PropOpEmitter.cpp", "js/src/jit-test/tests/class/super-in-nested-eval.js", "js/src/jit/BaselineCompiler.cpp", "js/src/jit/BaselineCompiler.h", "js/src/jit/IonBuilder.cpp", "js/src/jit/IonBuilder.h", "js/src/vm/BytecodeUtil.cpp", "js/src/vm/Interpreter.cpp", "js/src/vm/Opcodes.h"], "git_node": null, "git_parents": [null], "node": "5555defbbd01b3629496097dc8f403c9c4de60f8", "parents": ["d56cf7c8212addbc9a209f15f30331bb24a7af7d"], "tags": []}, {"author": "Jason Orendorff \u003cjorendorff@mozilla.com\u003e", "branch": "default", "desc": "Bug 1510598 - Handle uncatchable errors in RejectPromiseWithPendingError. r=jonco\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13434", "files": ["js/src/builtin/Promise.cpp", "js/src/jit-test/tests/modules/bug-1510598.js"], "git_node": null, "git_parents": [null], "node": "0b3de1c4a2ae2fcdf37817366c8557ad1861437a", "parents": ["5555defbbd01b3629496097dc8f403c9c4de60f8"], "tags": []}, {"autho