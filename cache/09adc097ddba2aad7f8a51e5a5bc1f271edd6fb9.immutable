ile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "775e75514d19afba0e135cdde102b5e6a25cc79e", "parents": ["ddfa7da474cd125dfcb185c94750c8a4ae35b158"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\ndsb -\u003e 5ff6b72d4eb3\nhsb -\u003e ffb8761411ab\nsv-SE -\u003e 510e45669256\ntr -\u003e 5104a5f93e3d\nzh-CN -\u003e 9f39a02979db\nzh-TW -\u003e b3bbd96ccd0f", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "3a65e8f5cc415e1ec6ec512a5a9903ddfa59a4a3", "parents": ["775e75514d19afba0e135cdde102b5e6a25cc79e"], "tags": []}], "date": 1545224423, "git_changesets": [null, null], "user": "ffxbld"}, "10366": {"changesets": [{"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1315887 - Re-enable browser_locationBarExternalLoad.js by making it less race-y. r=mak, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14192", "files": ["browser/base/content/test/urlbar/browser.ini", "browser/base/content/test/urlbar/browser_locationBarExternalLoad.js"], "git_node": null, "git_parents": [null], "node": "355458563690fccb7de382a1167d696539380178", "parents": ["3a65e8f5cc415e1ec6ec512a5a9903ddfa59a4a3"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1509434 - Part 1: Wait for AudioFocusAgent to be initialized before starting testAudioFocus. r=JanH, a=test-only\n\nThere is a small race between actually starting the test after Gecko:Ready and\nhaving the AudioFocusAgent that the tests depend on initialized, which is also\ndone after Gecko:Ready.\n\nTo avoid this situation we will wait for Gecko:Ready and then for\nAudioFocusAgent to complete it's initialization.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14417", "files": ["mobile/android/base/java/org/mozilla/gecko/media/AudioFocusAgent.java", "mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/MediaPlaybackTest.java", "mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/testAudioFocus.java"], "git_node": null, "git_parents": [null], "node": "4d21abcabd2a368991e9ceb28432eb5b632f6110", "parents": ["355458563690fccb7de382a1167d696539380178"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1509434 - Part 2: Wait for AudioFocusAgent to be initialized before starting testMediaControl. r=JanH, a=test-only\n\nInside the tests from testMediaControl audio focus is not immediately checked\nas for the tests from testAudioFocus but nonetheless we should make sure\nAudioFocusAgent is initialized before proceeding with the media tests.\n\nDepends on D14417\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14418", "files": ["mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/testMediaControl.java"], "git_node": null, "git_parents": [null], "node": "73c6129bfe7902bc37f19afe917360bc82cca301", "parents": ["4d21abcabd2a368991e9ceb28432eb5b632f6110"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1355207 - Improve test_host.js and add diagnostic info to figure out where it times out. r=kershaw, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14055", "files": ["netwerk/test/httpserver/test/head_utils.js", "netwerk/test/httpserver/test/test_host.js"], "git_node": null, "git_parents": [null], "node": "1e8a7d7842cbc04c4b8fa3c408e01a5f7e815d76", "parents": ["73c6129bfe7902bc37f19afe917360bc82cca301"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1355207 - Wait for http server shutdown and disable test_host.js on OSX. r=dragana, a=test-only\n\nThe test intermittently fails on OSX. For some reason start(PORT) doesn't always fail when PORT is in use, so we timeout because the handler is never called. I suspect it's because of how SO_REUSEADDR and SO_REUSEPORT are handled on sockets sever-side on OSX. Since httpd is used for unit tests, there is little risk in disabling the test on OSX.\nThe alternative is to check for a timeout, and in that case switch to another port - which is cumbersome, and not the purpose of the test.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14756", "files": ["netwerk/test/httpserver/test/test_host.js", "netwerk/test/httpserver/test/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "df270c166d44b24581befe5128f650832296381e", "parents": ["1e8a7d7842cbc04c4b8fa3c408e01a5f7e815d76"], "tags": []}, {"author": "Matthew Gregan \u003ckinetik@flim.org\u003e", "branch": "default", "desc": "Bug 1512450 - Clean up reslicing of audio buffers in AudioIPC's server data callback. r=chunmin, a=abillings", "files": ["media/audioipc/server/src/server.rs"], "git_node": null, "git_parents": [null], "node": "46828493249a63eccefa3ec6bbe4c0c94df4d650", "parents": ["df270c166d44b24581befe5128f650832296381e"], "tags": []}, {"author": "Jed Davis \u003cjld@mozilla.com\u003e", "branch": "default", "desc": "Bug 1510934 - Change ContentParent's alive/dead tracking to launching/alive/dead. r=mrbkap, a=RyanVM\n\nWe need content processes that are created but not finished launching\n(not \"alive\" yet) to be treated differently from ones that have exited\n(no longer \"alive\"), so the boolean mIsAlive is expanded to a 3-state\nenumeration, which could be expanded more in the future if needed.\n\n(This is similar to GeckoChildProcessHost::mProcessState, but it's\nsynchronized with the rest of the ContentParent's state, which can lag\nthe GeckoChildProcessHost state due to runnable dispatch.)\n\nThis patch also removes mIsAvailable/IsAvailable/MarkAsTroubled, which\nare unused as of bug 1459212.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14089", "files": ["dom/ipc/ContentParent.cpp", "dom/ipc/ContentParent.h"], "git_node": null, "git_parents": [null], "node": "ad653a697179ac2d603c30d3c4db9dea7e5e7929", "parents": ["46828493249a63eccefa3ec6bbe4c0c94df4d650"], "tags": []}, {"author": "Jed Davis \u003cjld@mozilla.com\u003e", "branch": "default", "desc": "Bug 1510934 - Ensure that pref changes during content process launch are delivered to the process. r=njn, a=RyanVM\n\nSome prefs need to be available before IPC is started, so we serialize a\nsnapshot when we start launching the process, and then stream further\nchanges over IPC messages.  However, async launch introduces a window\nbetween the snapshot and when the parent can start sending messages,\nduring which other code can run on the main thread and change prefs.\n\nIn order to not lose those updates, they're queued and sent when the\nlaunch is complete.\n\nDepends on D14089\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14090", "files": ["dom/ipc/ContentParent.cpp", "dom/ipc/ContentParent.h"], "git_node": null, "git_parents": [null], "node": "097f70517f666382f7606678ab018570f99de907", "parents": ["ad653a697179ac2d603c30d3c4db9dea7e5e7929"], "tags": []}], "date": 1545231143, "git_changesets": [null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10367": {"changesets": [{"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1513511 - P1. Use new FFmpeg decode API with recent FFmpeg version. r=bryce, a=lizzard\n\nIn libavcodec 58 and later, the old avcodec_decode_video2 is broken and only return the first visible frame found after a VP9 super-frame.\n\nThis resulted in some YouTube videos for about 10% of the frames to never be returned.\n\nOnly the new API properly behaves so we upgrade our code to use it.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14682", "files": ["dom/media/platforms/ffmpeg/FFmpegDataDecoder.cpp", "dom/media/platforms/ffmpeg/FFmpegLibWrapper.cpp", "dom/media/platforms/ffmpeg/FFmpegLibWrapper.h", "dom/media/platforms/ffmpeg/FFmpegVideoDecoder.cpp", "dom/media/platforms/ffmpeg/FFmpegVideoDecoder.h", "media/ffvpx/libavcodec/avcodec.symbols"], "git_node": null, "git_parents": [null], "node": "c94560ceb417fb956ef76b80cf5a993f0273d362", "parents": ["097f70517f666382f7606678ab018570f99de907"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1513511 - P2. Ensure all frames are decoded. r=bryce, a=lizzard\n\nvp9 streams contains superframes. Ensure they are all properly handled.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14699", "files": ["dom/media/test/mochitest.ini", "dom/media/test/test_vp9_superframes.html", "dom/media/test/vp9-superframes.webm", "dom/media/test/vp9-superframes.webm^headers^"], "git_node": null, "git_parents": [null], "node": "a475f96d74721bf5bfd62ef33dd2c4b186faea03", "parents": ["c94560ceb417fb956ef76b80cf5a993f0273d362"], "tags": []}, {"author": "Daniel Stenberg \u003cdaniel@haxx.se\u003e", "branch": "default", "desc": "Bug 1503393 - Never let \"localhost\" get sent to a proxy. r=mayhemer, a=RyanVM", "files": ["netwerk/base/nsProtocolProxyService.cpp"], "git_node": null, "git_parents": [null], "node": "08b14d60d0fcbe836971c0cd3378f4e67e357334", "parents": ["a475f96d74721bf5bfd62ef33dd2c4b186faea03"], "tags": []}, {"author": "Daniel Stenberg \u003cdaniel@haxx.se\u003e", "branch": "default", "desc": "Bug 1503393 - Verify default localhost not-proxied with PAC. r=mayhemer, a=RyanVM", "files": ["netwerk/test/unit/test_protocolproxyservice.js"], "git_node": null, "git_parents": [null], "node": "005811564dc5e60f72bd43ca09408d9b01968d90", "parents": ["08b14d60d0fcbe836971c0cd3378f4e67e357334"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1503393 - Make 'no proxy' field editable. r=jaws, a=RyanVM", "files": ["browser/components/preferences/connection.js", "browser/components/preferences/in-content/tests/browser_extension_controlled.js"], "git_node": null, "git_parents": [null], "node": "b380a84b065d4afbb7d42a229616afcbd7c4ff9c", "parents": ["005811564dc5e60f72bd43ca09408d9b01968d90"], "tags": []}, {"author": "Daniel Stenberg \u003cdaniel@haxx.se\u003e", "branch": "default", "desc": "Bug 1503393 - Adjust tests for localhost proxying. r=mayhemer, a=RyanVM", "files": ["browser/base/content/test/siteIdentity/browser_insecureLoginForms.js", "browser/components/originattributes/test/browser/browser_firstPartyIsolation.js", "browser/modules/test/browser/browser_UsageTelemetry_uniqueOriginsVisitedInPast24Hours.js", "dom/security/test/csp/test_upgrade_insecure_loopback.html", "dom/tests/mochitest/dom-level0/test_setting_document.domain_to_shortened_ipaddr.html", "dom/u2f/tests/browser/browser_appid_localhost.js", "extensions/cookie/test/test_same_base_domain_6.html", "netwerk/test/unit/test_proxy-failover_canceled.js", "toolkit/components/passwordmgr/test/browser/browser_insecurePasswordConsoleWarning.js"], "git_node": null, "git_parents": [null], "node": "794b2e929584de6e99cd5a0b971c1202d42b8ab8", "parents": ["b380a84b065d4afbb7d42a229616afcbd7c4ff9c"], "tags": []}, {"author": "Henri Sivonen \u003chsivonen@hsivonen.fi\u003e", "branch": "default", "desc": "Bug 1510114. r=bzbarsky, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13679", "files": ["parser/html/nsHtml5TreeOpExecutor.cpp"], "git_node": null, "git_parents": [null], "node": "c717fd7ff8853e8accd5c4fe0072ee8c666aa972", "parents": ["794b2e929584de6e99cd5a0b971c1202d42b8ab8"], "tags": []}, {"author": "Bob Owen \u003cbobowencode@gmail.com\u003e", "branch": "default", "desc": "Bug 1497749: Get hello message from channel ID when pipe handle passed. r=jld, a=RyanVM", "files": ["ipc/chromium/src/chrome/common/ipc_channel_win.cc"], "git_node": null, "git_parents": [null], "node": "a6d805438104ac92b2defb7c1c771070b88c0367", "parents": ["c717fd7ff8853e8accd5c4fe0072ee8c666aa972"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Bug 1496413 - Pass texture clients to paint thread when we discard them. r=nical, a=RyanVM", "files": ["gfx/layers/client/SingleTiledContentClient.cpp"], "git_node": null, "git_parents": [null], "node": "774f84eedb224d5ceec2723af9c9d53a5f622c7a", "parents": ["a6d805438104ac92b2defb7c1c771070b88c0367"], "tags": []}], "date": 1545251545, "git_changesets": [null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10368": {"changesets": [{"author": "Jason Laster \u003cjlaster@mozilla.com\u003e", "branch": "default", "desc": "Bug 1513737 -  Stop using Array.shift when mapping pause points. r=dwalsh, a=ritu\n\nReviewers: davidwalsh\n\nReviewed By: davidwalsh\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14346", "files": ["devtools/client/debugger/new/src/actions/ast/setPausePoints.js", "devtools/client/debugger/new/src/utils/pause/pausePoints.js"], "git_node": null, "git_parents": [null], "node": "f0978d33730c3a9b4b99ed623f25e352beb3ee5b", "parents": ["774f84eedb224d5ceec2723af9c9d53a5f622c7a"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1512589 - [Wayland] Map mozcontainer from map-event signal. r=jhorak, a=RyanVM\n\nIt's not quaranteed that we have a valid wl_surface at GtkWidget::map event.\nIn that case create it at GtkWidget::map-event handler which is called after\nwidget show.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13979", "files": ["widget/gtk/mozcontainer.cpp"], "git_node": null, "git_parents": [null], "node": "37e58b34932fe6e1d5246412c94e31af2c3a41e6", "parents": ["f0978d33730c3a9b4b99ed623f25e352beb3ee5b"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1508252 - Set temporary range when replacement range is available. r=masayuki, a=RyanVM\n\nThis issue is e10s only.\n\nEven if calling SetSelection, it doesn't reset selection cache in\nTextInputHandler.  Since selection cache is updated by OnSelectionChange\nasynchronous, we should set temporary range when having replacement range.\n\nAlso, even if marking dirty doesn't fix this issue. Content cache may return\nother range such as caret position instead of replacement range by SetSelection.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14002", "files": ["widget/cocoa/TextInputHandler.mm"], "git_node": null, "git_parents": [null], "node": "49a93d8ec9f9a1e9d4b3322bfbb77d86be5d71a8", "parents": ["37e58b34932fe6e1d5246412c94e31af2c3a41e6"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1514762 - Delay modifying the observer list until we hit the event loop. r=smaug, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14830", "files": ["dom/base/nsGlobalWindowOuter.cpp"], "git_node": null, "git_parents": [null], "node": "34be2a107bd4c664f179518ef9f11036cd00418f", "parents": ["49a93d8ec9f9a1e9d4b3322bfbb77d86be5d71a8"], "tags": []}, {"author": "Edouard Oger \u003ceoger@fastmail.com\u003e", "branch": "default", "desc": "Bug 1513781 - Use cached keys in FxA commands registration. r=vladikoff,rfkelly, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14782", "files": ["services/fxaccounts/FxAccountsCommands.js"], "git_node": null, "git_parents": [null], "node": "e78a2c5fe344989e9711c204ff38370cbf06d49c", "parents": ["34be2a107bd4c664f179518ef9f11036cd00418f"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1511359 - Backout bug 1477432 due to nsJSID compartment concerns. r=bholley, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14979", "files": ["browser/modules/Sanitizer.jsm", "dom/base/ChromeUtils.h", "dom/base/CustomElementRegistry.cpp", "dom/base/MozQueryInterface.cpp", "dom/base/MozQueryInterface.h", "dom/base/nsGlobalWindowInner.cpp", "dom/base/nsGlobalWindowInner.h", "dom/base/nsGlobalWindowOuter.h", "dom/base/nsJSEnvironment.cpp", "dom/bindings/BindingUtils.cpp", "dom/bindings/BindingUtils.h", "dom/bindings/Bindings.conf", "dom/bindings/Codegen.py", "dom/chrome-webidl/ChromeUtils.webidl", "dom/webidl/LegacyQueryInterface.webidl", "dom/webidl/WebComponents.webidl", "dom/webidl/Window.webidl", "dom/webidl/XMLHttpRequest.webidl", "dom/xhr/XMLHttpRequest.h", "dom/xhr/XMLHttpRequestMainThread.cpp", "dom/xhr/XMLHttpRequestMainThread.h", "dom/xhr/XMLHttpRequestWorker.h", "editor/composer/test/test_bug1266815.html", "js/ipc/JavaScriptShared.cpp", "js/ipc/WrapperOwner.cpp", "js/xpconnect/idl/moz.build", "js/xpconnect/idl/xpccomponents.idl", "js/xpconnect/idl/xpcjsid.idl", "js/xpconnect/src/XPCComponents.cpp", "js/xpconnect/src/XPCConvert.cpp", "js/xpconnect/src/XPCForwards.h", "js/xpconnect/src/XPCJSID.cpp", "js/xpconnect/src/XPCJSRuntime.cpp", "js/xpconnect/src/XPCModule.cpp", "js/xpconnect/src/XPCModule.h", "js/xpconnect/src/XPCVariant.cpp", "js/xpconnect/src/XPCWrappedJSClass.cpp", "js/xpconnect/src/XPCWrappedNative.cpp", "js/xpconnect/src/XPCWrappedNativeScope.cpp", "js/xpconnect/src/xpcprivate.h", "js/xpconnect/src/xpcpublic.h", "js/xpconnect/tests/unit/test_bug677864.js", "js/xpconnect/tests/unit/test_classesByID_instanceof.js", "js/xpconnect/tests/unit/test_generateQI.js", "js/xpconnect/tests/unit/test_import.js", "js/xpconnect/tests/unit/xpcshell.ini", "testing/modules/AppInfo.jsm", "toolkit/components/satchel/FormHistoryStartup.js", "toolkit/components/search/tests/xpcshell/head_search.js", "xpcom/ds/nsArray.cpp", "xpcom/ds/nsIArray.idl", "xpcom/tests/unit/test_bug656331.js"], "git_node": null, "git_parents": [null], "node": "61e24e70a0e77079408ec4264a05235885345324", "parents": ["e78a2c5fe344989e9711c204ff38370cbf06d49c"], "tags": []}], "date": 1545266573, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10369": {"changesets": [{"author": "WR Updater Bot \u003cgraphics-team@mozilla.staktrace.com\u003e", "branch": "default", "desc": "Bug 1496019 - Cherry-pick webrender commit a07226140e2bbf2038302737b2e0f1b9707f2d6c (WR PR #3421). r=kats, a=RyanVM\n\nhttps://github.com/servo/webrender/pull/3421", "files": ["gfx/webrender_bindings/revision.txt", "gfx/wr/webrender/src/batch.rs", "gfx/wr/wrench/reftests/filters/filter-drop-shadow-clip.png", "gfx/wr/wrench/reftests/filters/filter-drop-shadow-clip.yaml", "gfx/wr/wrench/reftests/filters/reftest.list"], "git_node": null, "git_parents": [null], "node": "22ff661549d4a69467bcdcb6a9376fb09906a011", "parents": ["61e24e70a0e77079408ec4264a05235885345324"], "tags": []}, {"author": "WR Updater Bot \u003cgraphics-team@mozilla.staktrace.com\u003e", "branch": "default", "desc": "Bug 1496019 - Update WPT annotations for changes in WR PR 3421. r=kats, a=RyanVM", "files": ["testing/web-platform/meta/css/css-masking/clip/clip-filter-order.html.ini"], "git_node": null, "git_parents": [null], "node": "ef02c82614389826dd6e9246a0b965afacf68168", "parents": ["22ff661549d4a69467bcdcb6a9376fb09906a011"], "tags": []}, {"author": "Edgar Chen \u003cechen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1500273 - Ensure backward focus navigation works in Shadow DOM. r=smaug, a=RyanVM\n\nWhen entering into a Shadow DOM in backward navigation, the frame still points\nto the last frame in Shadow DOM which could be a non-focusable frame, so move\nthe handling of backward navigation for Shadow DOM upward.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14069", "files": ["dom/base/nsFocusManager.cpp", "dom/base/test/file_bug1453693.html"], "git_node": null, "git_parents": [null], "node": "a931bf550f3399a4fd3e91edec59676b75b5d6ff", "parents": ["ef02c82614389826dd6e9246a0b965afacf68168"], "tags": []}, {"author": "Erica Wright \u003cewright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1512187 - Update preferences spotlight color. r=jaws, a=RyanVM\n\nChange the coloring of the spotlight, and add a fadeout\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13822", "files": ["browser/themes/shared/incontentprefs/preferences.inc.css", "toolkit/themes/shared/in-content/common.inc.css"], "git_node": null, "git_parents": [null], "node": "2fe74b55dfcc2a1837af0f5c45b2ce1efd3f97e2", "parents": ["a931bf550f3399a4fd3e91edec59676b75b5d6ff"], "tags": []}, {"author": "Patrick Brosset \u003cpbrosset@mozilla.com\u003e", "branch": "default", "desc": "Bug 1500921 - Tunnel the pagestyle message through RDM. r=gl, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14256", "files": ["devtools/client/responsive.html/browser/tunnel.js", "devtools/client/responsive.html/test/browser/browser.ini", "devtools/client/responsive.html/test/browser/browser_page_style.js"], "git_node": null, "git_parents": [null], "node": "f77371a128ae6e098e2bd4c482ec705b4eac2b6c", "parents": ["2fe74b55dfcc2a1837af0f5c45b2ce1efd3f97e2"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1512026 - Handle nested slots correctly in slotted matching and invalidation. r=heycam, a=RyanVM\n\nThe patch and test should be pretty much self-descriptive.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14063", "files": ["servo/components/selectors/matching.rs", "servo/components/selectors/tree.rs", "servo/components/style/invalidation/element/invalidator.rs", "testing/web-platform/tests/css/css-scoping/slotted-nested.html"], "git_node": null, "git_parents": [null], "node": "da461fa0a394f281b886840bd768f7dc8a1f25d0", "parents": ["f77371a128ae6e098e2bd4c482ec705b4eac2b6c"], "tags": []}, {"author": "Timothy Guan-tin Chien \u003ctimdream@gmail.com\u003e", "branch": "default", "desc": "Bug 1511130 - Part I, Backed out changeset faacbb32e16a (Bug 1511130). r=bgrins, a=RyanVM\n\nMy approach in bug 1505957 turned out to be flawed.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13607", "files": ["toolkit/actors/UAWidgetsChild.jsm"], "git_node": null, "git_parents": [null], "node": "17a1d1be96f474b846b1bdbb82786c3238407b53", "parents": ["da461fa0a394f281b886840bd768f7dc8a1f25d0"], "tags": []}, {"author": "Timothy Guan-tin Chien \u003ctimdream@gmail.com\u003e", "branch": "default", "desc": "Bug 1511130 - Part II, Allow UAWidgetsChild to destruct widgets even if it throws during construction. r=bgrins, a=RyanVM\n\nThis patch move the actual widget construction to a onsetup method, allow UAWidgetsChild to hold the reference of the widget instance even if the actual setup (happens in the onsetup call) throws. With the reference of the widget kept, UAWidgetsChild will finally able to call its destructor later on.\n\nDepends on D13607\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13608", "files": ["dom/media/tests/crashtests/1505957.html", "dom/media/tests/crashtests/1511130.html", "dom/media/tests/crashtests/crashtests.list", "toolkit/actors/UAWidgetsChild.jsm", "toolkit/content/widgets/datetimebox.js", "toolkit/content/widgets/docs/ua_widget.rst", "toolkit/content/widgets/marquee.js", "toolkit/content/widgets/pluginProblem.js", "toolkit/content/widgets/videocontrols.js"], "git_node": null, "git_parents": [null], "node": "c41c18787e43e3ce0d9008226f21810eb19c634b", "parents": ["17a1d1be96f474b846b1bdbb82786c3238407b53"], "tags": []}], "date": 1545271760, "git_changesets": [null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10370": {"changesets": [{"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1492706 - Part 1: Catch OOM during startup session restore. r=nalexander, a=lizzard\n\nWe just treat this like a defective session store file and first fall back to\nthe backup (although if the OOM is caused by a too-large file, it is likely that\nthe backup will be too large as well) and then turn off session restoring\ncompletely.\n\nWe don't plug those failures into the session restore telemetry, though, because\nthat is supposed to only cover truly defective files.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D12962", "files": ["mobile/android/base/java/org/mozilla/gecko/GeckoApp.java"], "git_node": null, "git_parents": [null], "node": "325595e085d7acfdd80ea333a9f3dba85cd3b1e6", "parents": ["c41c18787e43e3ce0d9008226f21810eb19c634b"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1492706 - Part 2: Cover common OOM causes in the Recent tabs panel. r=nalexander, a=lizzard\n\nLooking at Crash Stats, the most common causes of OOMs involving the RecentTabs-\nAdapter happen while reading the previous session store file into memory for\nparsing, respectively while stringifying the parsed data back into a flat String\nfor further storage.\n\nIn the former case, we give up completely, because there's nothing we can do\nshort of switching to a streaming JSON parser (which is out of scope for this\nbug), while in the latter case, we only skip the affected tab in the hope that\nat least some tabs might be small enough to not cause an OOM.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D12963", "files": ["mobile/android/base/java/org/mozilla/gecko/home/RecentTabsAdapter.java"], "git_node": null, "git_parents": [null], "node": "0337b9cc8e0fec27445f6ebb59c144dc6eef1b51", "parents": ["325595e085d7acfdd80ea333a9f3dba85cd3b1e6"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1512625 - Ensure that the allow-mode argument in the PContent::FirstPartyStorageAccessGrantedForOrigin() IPC call doesn't get converted down to 0/1. r=baku, a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14478", "files": ["dom/ipc/ContentParent.cpp", "dom/ipc/ContentParent.h", "dom/ipc/PContent.ipdl", "toolkit/components/antitracking/test/browser/browser_storageAccessDoorHanger.js"], "git_node": null, "git_parents": [null], "node": "292715b59677a10385e02e268571930744852588", "parents": ["0337b9cc8e0fec27445f6ebb59c144dc6eef1b51"], "tags": []}, {"author": "Andrew Swan \u003caswan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1508777 - Skip updates for LWTs with no updateURL. r=kmag, a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14931", "files": ["toolkit/mozapps/extensions/LightweightThemeManager.jsm"], "git_node": null, "git_parents": [null], "node": "fb3197004db503cbbb1cda1c0fbacd21f364dc47", "parents": ["292715b59677a10385e02e268571930744852588"], "tags": []}, {"author": "Timothy Guan-tin Chien \u003ctimdream@gmail.com\u003e", "branch": "default", "desc": "Bug 1510848 - Do not unattach UA Widget Shadow Root if the element is already re-attached to the tree. r=emilio,smaug, a=RyanVM\n\nThis patch moves all UA Widget calls to helper functions in Element.cpp. The helper function AttachAndSetUAShadowRoot sets the shadow root in a runnable, so that it is in the same order of NotifyUAWidget* runnables.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D13479", "files": ["dom/base/Element.cpp", "dom/base/Element.h", "dom/base/nsObjectLoadingContent.cpp", "dom/html/HTMLInputElement.cpp", "dom/html/HTMLMarqueeElement.cpp", "dom/html/HTMLMediaElement.cpp", "dom/html/nsGenericHTMLElement.cpp", "dom/html/nsGenericHTMLElement.h", "dom/media/tests/crashtests/1510848.html", "dom/media/tests/crashtests/crashtests.list", "layout/base/nsCSSFrameConstructor.cpp", "mobile/android/chrome/geckoview/GeckoViewMediaChild.js", "toolkit/actors/UAWidgetsChild.jsm", "toolkit/content/widgets/docs/ua_widget.rst", "toolkit/modules/ActorManagerParent.jsm"], "git_node": null, "git_parents": [null], "node": "1a45a417a33af7317ff0be891363dacdbdf98b36", "parents": ["fb3197004db503cbbb1cda1c0fbacd21f364dc47"], "tags": []}, {"author": "Timothy Guan-tin Chien \u003ctimdream@gmail.com\u003e", "branch": "default", "desc": "Bug 1513600 - Use elementFromPoint() to measure isMouseOverVideo. r=jaws, a=RyanVM\n\nThe checkEventWithin method is broken by two bugs:\n\nThe first one is bug 1493525 because we ended up pass the proxy instance, instead of the element reference, as the parent node to compare.\nThe second one is unknown and happened sometime after that bug. The |relatedTarget| of the mouse event is always \u003cvideo\u003e, instead of the element within Shadow DOM that the cursor is moving out to.\n\nInstead of identify the second bug in the DOM, this patch employs a simpler fix by using elementFromPoint() to identify the cursor position.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14342", "files": ["toolkit/content/widgets/videocontrols.js"], "git_node": null, "git_parents": [null], "node": "dd09f113cb8a6936dd8d92b7b5a425eb43019af0", "parents": ["1a45a417a33af7317ff0be891363dacdbdf98b36"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1513920 - Make \u003cuse\u003e shadow trees lookup keyframe rules in the containing tree. r=heycam, a=RyanVM\n\nThe same thing we do for rule matching.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14548", "files": ["servo/components/style/rule_collector.rs", "servo/components/style/stylist.rs", "testing/web-platform/tests/svg/linking/reftests/use-keyframes-ref.html", "testing/web-platform/tests/svg/linking/reftests/use-keyframes.html"], "git_node": null, "git_parents": [null], "node": "b3837d6171d2c848d82fc7de31c0e84d9eacff14", "parents": ["dd09f113cb8a6936dd8d92b7b5a425eb43019af0"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1502346 - Retrieve ::slotted rules in InspectorUtils getCSSStyleRules. r=emilio, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14759", "files": ["devtools/client/inspector/rules/test/browser_rules_shadowdom_slot_rules.js", "devtools/shared/inspector/css-logic.js", "layout/inspector/InspectorUtils.cpp", "layout/inspector/tests/mochitest.ini", "layout/inspector/tests/test_getCSSStyleRules_slotted.html"], "git_node": null, "git_parents": [null], "node": "fde04f5ec92099bf5cd7d1328f0f09e3d5ff610a", "parents": ["b3837d6171d2c848d82fc7de31c0e84d9eacff14"], "tags": []}], "date": 1545274890, "git_changesets": [null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10371": {"changesets": [{"author": "Chris H-C \u003cchutten@mozilla.com\u003e", "branch": "default", "desc": "bug 1512503 - Instrument about:telemetry for pageloads. r=janerik, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14266", "files": ["toolkit/components/telemetry/Scalars.yaml", "toolkit/content/aboutTelemetry.js"], "git_node": null, "git_parents": [null], "node": "6003743fd8fd999ec1334b180efd04784a47a050", "parents": ["fde04f5ec92099bf5cd7d1328f0f09e3d5ff610a"], "tags": []}, {"author": "Jason Laster \u003cjlaster@mozilla.com\u003e", "branch": "default", "desc": "Bug 1514760 - Debugger variables cannot be expanded when re-paused. r=nchevobbe, a=RyanVM", "files": ["devtools/client/debugger/new/test/mochitest/browser_dbg-expressions.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-scopes.js", "devtools/client/shared/components/reps/reps.js"], "git_node": null, "git_parents": [null], "node": "c35977a3c5a3d1c6eb3ac66582143d7e9ef07665", "parents": ["6003743fd8fd999ec1334b180efd04784a47a050"], "tags": []}, {"author": "Henri Sivonen \u003chsivonen@hsivonen.fi\u003e", "branch": "default", "desc": "Bug 1513473 - Re-enable the Text Encoding menu telemetry probes on the release channel. datareview=chu