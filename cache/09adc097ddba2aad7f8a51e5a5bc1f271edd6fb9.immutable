n: https://phabricator.services.mozilla.com/D14205", "files": ["gfx/layers/apz/test/mochitest/apz_test_utils.js", "gfx/layers/apz/test/mochitest/helper_bug1151663.html"], "git_node": null, "git_parents": [null], "node": "e4724d2e607659d3bbc77afd6aa1516628d347d9", "parents": ["8865b5aa95101018bbbff23f9fb2e096e8594517"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1499655 - Ensure we forceLayerTreeToComposite in tests where we read the compositor APZ test data at the start of the test. r=botond, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14206", "files": ["gfx/layers/apz/test/mochitest/helper_bug982141.html", "gfx/layers/apz/test/mochitest/helper_key_scroll.html"], "git_node": null, "git_parents": [null], "node": "e6014768f6cd449b54372774b68b09fe18af9372", "parents": ["e4724d2e607659d3bbc77afd6aa1516628d347d9"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1485616 - [Wayland] Wait with drawing until mozcontainer init is finished. r=jhorak, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14070", "files": ["widget/gtk/mozcontainer.cpp", "widget/gtk/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "4c0ab314be9af3ed0e57b59ca1bf3c76442796ee", "parents": ["e6014768f6cd449b54372774b68b09fe18af9372"], "tags": []}, {"author": "Alex Gaynor \u003cagaynor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1513201 - Handle pasted data of certain types with an odd length. r=mats, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14150", "files": ["widget/windows/nsClipboard.cpp"], "git_node": null, "git_parents": [null], "node": "3ebfb70bbd0bd65cb4ab8b7ed1bb3a4e43af3fa6", "parents": ["4c0ab314be9af3ed0e57b59ca1bf3c76442796ee"], "tags": []}, {"author": "Marco Zehe \u003cmzehe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1512411 - Don't expose broken label children accessibles on a XUL toolbarbutton which specifies the label attribute. r=Jamie, a=RyanVM\n\nIn bug 1507365, we introduced the ability of nested label children of toolbar buttons to provide the accessible name for a xul:toolbarbutton element. However, the XBL of xul:toolbarbutton causes the creation of a label accessible even if no xul:label child is present, and only the label attribute is being used. The nsIAccessibleText interface on such labels is, however, completely broken. This causes NVDA's mouse tracking, which always uses the deepest nested child, to fail. As a result, when hovering over Hamburger menu items, the announcement would be wrong, e. g., lag one behind the actual button the mouse is hovering over.\n\nTo fix this, we only accept xul:label children if they come from real XUL markup, not from the label attribute and the XBL creating the label. This means that some of the test changes from bug 1507365 have to be reverted to accommodate the new old behavior. But the new test for an actual label child still passes.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14469", "files": ["accessible/tests/mochitest/tree/test_button.xul", "accessible/tests/mochitest/tree/test_formctrl.xul", "accessible/tests/mochitest/treeupdate/test_menubutton.xul", "accessible/xul/XULFormControlAccessible.cpp"], "git_node": null, "git_parents": [null], "node": "d2c26e2f11646f98fa28c8047b9d98b0e97b7399", "parents": ["3ebfb70bbd0bd65cb4ab8b7ed1bb3a4e43af3fa6"], "tags": []}], "date": 1545059406, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10353": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\ncs -\u003e c4d1d3e6cf21\nes-AR -\u003e 288a19dd06a3\nes-MX -\u003e b94c2effa8df\nvi -\u003e 02e51fe3e6cb", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "5cf22fd4b3c0109d9e4f17081f9ee13e0a8025ad", "parents": ["d2c26e2f11646f98fa28c8047b9d98b0e97b7399"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\ncs -\u003e fea3c8eae446\nes-AR -\u003e 288a19dd06a3\nes-MX -\u003e b94c2effa8df\nia -\u003e ebe4bbaaa1b8\nvi -\u003e 02e51fe3e6cb", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "309f7755407e1bed1b2b976659e7f5f4f91ce2ab", "parents": ["5cf22fd4b3c0109d9e4f17081f9ee13e0a8025ad"], "tags": []}], "date": 1545066035, "git_changesets": [null, null], "user": "ffxbld"}, "10354": {"changesets": [{"author": "Nico Grunbaum \u003cna-g@nostrum.com\u003e", "branch": "default", "desc": "Bug 1495446 - Fix timestamp of WebRTC RTCP stats. r=jib, a=RyanVM\n\nThe RTCP timestamps have different timebases and reporting sources, this makes the source and timebase the same for all RTCP stats\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7354", "files": ["dom/media/tests/mochitest/pc.js", "dom/media/tests/mochitest/test_peerConnection_stats.html", "media/webrtc/signaling/src/media-conduit/AudioConduit.cpp", "media/webrtc/signaling/src/media-conduit/AudioConduit.h", "media/webrtc/signaling/src/media-conduit/MediaConduitInterface.h", "media/webrtc/signaling/src/media-conduit/VideoConduit.cpp", "media/webrtc/signaling/src/media-conduit/VideoConduit.h", "media/webrtc/signaling/src/peerconnection/PeerConnectionImpl.cpp"], "git_node": null, "git_parents": [null], "node": "97d55c66f8eeac0d8fa22e8338d4181b30dfccd3", "parents": ["309f7755407e1bed1b2b976659e7f5f4f91ce2ab"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1511701 - Apply a band-aid null check for crashes happening in the wild. r=botond, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14621", "files": ["gfx/layers/apz/src/APZCTreeManager.cpp"], "git_node": null, "git_parents": [null], "node": "d55ede8c39ff502e2e54cac78ef4be87256dd84c", "parents": ["97d55c66f8eeac0d8fa22e8338d4181b30dfccd3"], "tags": []}, {"author": "P Kausthubh S \u003cspkausthubh@gmail.com\u003e", "branch": "default", "desc": "Bug 1362841 - Mirror the theme icons in customize mode in RTL to match the UI. r=gijs, a=RyanVM", "files": ["browser/themes/shared/customizableui/customizeMode.inc.css"], "git_node": null, "git_parents": [null], "node": "3df85c62c1d86e1f515f23f1b06268bdc14cfcda", "parents": ["d55ede8c39ff502e2e54cac78ef4be87256dd84c"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1514086 - The 'all' property is not animatable. r=hiro, a=RyanVM\n\nSince it allows to animate display, which is not good.\n\nThis is a regression from:\n\n  https://hg.mozilla.org/mozilla-central/rev/6884ba750aa3\n\nActually I wonder if the logic shouldn't be the other way around, i.e., a\nshorthand is animatable if all the longhands are, not if just one.\n\nIn any case this rolls back to the previous behavior, should we do that, it\nshould be another bug.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14632", "files": ["layout/style/crashtests/1514086.html", "layout/style/crashtests/crashtests.list", "servo/components/style/properties/data.py"], "git_node": null, "git_parents": [null], "node": "887995c16f49c22033058c978a6fe6f940e50bf4", "parents": ["3df85c62c1d86e1f515f23f1b06268bdc14cfcda"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1511477 - Ensure that the GeckoView API always reports the URI and type of all blocked trackers. r=esawin, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14607", "files": ["dom/base/nsGlobalWindowOuter.cpp"], "git_node": null, "git_parents": [null], "node": "6ee21f3f0592b2522ade70a367b47b7fab5eaa43", "parents": ["887995c16f49c22033058c978a6fe6f940e50bf4"], "tags": []}], "date": 1545069978, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10355": {"changesets": [{"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1513557 - Adding overlapping swatch preview for colour contrast indicator in a11y panel. r=pbro,flod, a=RyanVM, l10n=flod\n\nMozReview-Commit-ID: 9IKGXorA6uS\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14429", "files": ["devtools/server/actors/highlighters.css", "devtools/server/actors/highlighters/utils/accessibility.js", "devtools/server/actors/highlighters/xul-accessible.js", "devtools/server/actors/utils/accessibility.js", "devtools/shared/css/color.js", "devtools/shared/locales/en-US/accessibility.properties"], "git_node": null, "git_parents": [null], "node": "627384d9dfe3a620a8632a30bec4f1a8ab04722f", "parents": ["6ee21f3f0592b2522ade70a367b47b7fab5eaa43"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1513557 - Switch from flexbox to grid for a11y highlighter inforbar to support multi-row. r=pbro, a=RyanVM, l10n=flod\n\nMozReview-Commit-ID: 7AAiOIbCfSF\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14430", "files": ["devtools/server/actors/highlighters.css", "devtools/server/actors/highlighters/xul-accessible.js"], "git_node": null, "git_parents": [null], "node": "dfe78db5e4ae6de6052b22e0e2d7ced375a0110c", "parents": ["627384d9dfe3a620a8632a30bec4f1a8ab04722f"], "tags": ["DEVEDITION_65_0b5_BUILD1", "DEVEDITION_65_0b5_RELEASE", "FENNEC_65_0b5_BUILD1", "FENNEC_65_0b5_RELEASE", "FIREFOX_65_0b5_BUILD1", "FIREFOX_65_0b5_RELEASE"]}], "date": 1545070186, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "10356": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozill