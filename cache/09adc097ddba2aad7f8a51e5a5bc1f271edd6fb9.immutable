t", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nte -\u003e 2f381ea2e1f3", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "bfda1a3d18f09ab04bc33938dd9e418906f6c490", "parents": ["a89754152c2b02d842dbeef6c5c27d1820272bd7"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nte -\u003e 2f381ea2e1f3\nuk -\u003e ff81657bea02", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "31a65adfc1f7e4c2df30b6f94804b852147e374c", "parents": ["bfda1a3d18f09ab04bc33938dd9e418906f6c490"], "tags": []}], "date": 1545912025, "git_changesets": [null, null], "user": "ffxbld"}, "10397": {"changesets": [{"author": "Nico Grunbaum \u003cna-g@nostrum.com\u003e", "branch": "default", "desc": "Bug 1515379 - Initialize frames delivered stat and add test. r=dminor, a=RyanVM\n\nThis initializes a one of the stats that lost its default initialization when it was changed from an Atomic to a plain old int.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14978", "files": ["dom/media/tests/mochitest/test_peerConnection_stats.html", "media/webrtc/signaling/src/media-conduit/VideoConduit.h"], "git_node": null, "git_parents": [null], "node": "a1a1e110ab05397bcd68a405a37d9574fec28aaf", "parents": ["31a65adfc1f7e4c2df30b6f94804b852147e374c"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "Bug 1509585 - Remove some redundant worker shutdown code. r=asuth, a=RyanVM\n\nThis code races with the WeakWorkerRef shutdown code that sets both `mWorkerState` and `mWorkerPrivate` (though on different threads). This patch is based on the observation that except for failure cases, we can't get to `RuntimeServiceWorker::UnregisterWorker` without having already notified the `WorkerRef`s.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D14176", "files": ["dom/workers/RuntimeService.cpp"], "git_node": null, "git_parents": [null], "node": "6e7f4acecc9fa24166718c3bcbd942711569dee9", "parents": ["a1a1e110ab05397bcd68a405a37d9574fec28aaf"], "tags": []}, {"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 1513912 - Null check return from TextToSpeech.getFeatures(). r=agi, a=RyanVM", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/SpeechSynthesisService.java"], "git_node": null, "git_parents": [null], "node": "22da6211feb61217fa832da075ebfd79940dfa52", "parents": ["6e7f4acecc9fa24166718c3bcbd942711569dee9"], "tags": ["DEVEDITION_65_0b7_BUILD1", "DEVEDITION_65_0b7_RELEASE", "FENNEC_65_0b7_BUILD1", "FENNEC_65_0b7_RELEASE", "FIREFOX_65_0b7_BUILD1", "FIREFOX_65_0b7_RELEASE"]}], "date": 1545921842, "git_changesets": [null, null, null], "user": "ryanvm@gmail.com"}, "10398": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 22da6211feb61217fa832da075ebfd79940dfa52 with FENNEC_65_0b7_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "486cd9719c07f79f641cb6861c153dd74c8ffdf5", "parents": ["22da6211feb61217fa832da075ebfd79940dfa52"], "tags": []}], "date": 1545928499, "git_changesets": [null], "user": "ffxbld"}, "10399": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 22da6211feb61217fa832da075ebfd79940dfa52 with DEVEDITION_65_0b7_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "f0c572b695cfe66a9a78321234db183ff46f36ee", "parents": ["486cd9719c07f79f641cb6861c153dd74c8ffdf5"], "tags": []}], "date": 1545928715, "git_changesets": [null], "user": "ffxbld"}, "10400