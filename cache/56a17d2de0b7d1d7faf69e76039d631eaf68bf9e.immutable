ces.mozilla.com/D35946", "files": ["layout/reftests/transform-3d/preserve3d-table-ref.html", "layout/reftests/transform-3d/preserve3d-table.html", "layout/reftests/transform-3d/reftest.list", "layout/style/res/ua.css"], "git_node": null, "git_parents": [null], "node": "d763b1f288a37f783de546ebeb4ce396a9a64cbd", "parents": ["abae727c471025c3a2d1006a401bdb4d70cd7bae"], "tags": []}, {"author": "Eric Rahm \u003cerahm@mozilla.com\u003e", "branch": "default", "desc": "Bug 1555067 - Backed out changeset 0801165e3175. r=jcj a=jcristau\n\nNSS_ALLOW_SSLKEYLOGFILE no longer has issues upstream, we can allow it again.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34915", "files": ["python/mozbuild/mozbuild/frontend/gyp_reader.py"], "git_node": null, "git_parents": [null], "node": "268c9ae41d1f0b30d5f4cd875427f1d3386617de", "parents": ["d763b1f288a37f783de546ebeb4ce396a9a64cbd"], "tags": []}], "date": 1561642711, "git_changesets": [null, null], "user": "dvarga@mozilla.com"}, "11506": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP blocklist remote-settings tld-suffixes - a=repo-update r=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36189", "files": ["browser/app/blocklist.xml", "netwerk/dns/effective_tld_names.dat", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/blocklists/addons.json"], "git_node": null, "git_parents": [null], "node": "673e80300fc06e13b0390a05d98a771bfe96fa47", "parents": ["268c9ae41d1f0b30d5f4cd875427f1d3386617de"], "tags": []}, {"author": "Mark Hammond \u003cmhammond@skippinet.com.au\u003e", "branch": "default", "desc": "Bug 1538015 (part 1) - test only change to tighten up the checks being made. r=tcsc, a=jcristau\n\nThis is a test-only change to make the existing synced prefs tests more\nexplicit about values being checked and moves a couple of prefs around to make\nthings a bit clearer, which should make the test changes in part 2 clearer.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D29774", "files": ["services/sync/tests/unit/test_prefs_store.js"], "git_node": null, "git_parents": [null], "node": "cb236393456baab3546acbe92f397cb48648cd4f", "parents": ["673e80300fc06e13b0390a05d98a771bfe96fa47"], "tags": []}, {"author": "Mark Hammond \u003cmhammond@skippinet.com.au\u003e", "branch": "default", "desc": "Bug 1538015 (part 2) - restrict when incoming synced prefs are applied. r=tcsc,pauljt,Gijs, a=jcristau\n\nSpecifically, a \"control pref\" for a pref must already exist locally, or\na new preference, `services.sync.prefs.dangerously_allow_arbitrary` must\nbe set to true.\n\nThis also removes a few preferences from the set we sync by default based\ndue to potential harm which can be caused syncing inappropriate values.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D29775", "files": ["browser/app/profile/firefox.js", "services/sync/modules/engines/prefs.js", "services/sync/tests/unit/test_engine_changes_during_sync.js", "services/sync/tests/unit/test_prefs_store.js"], "git_node": null, "git_parents": [null], "node": "61169eb427180be0b3b8fbbd9c2ef2e7f185a2ae", "parents": ["cb236393456baab3546acbe92f397cb48648cd4f"], "tags": []}], "date": 1561642927, "git_changesets": [null, null, null], "user": "ryanvm@gmail.com"}, "11507": {"changesets": [{"author": "Naz\u0131m Can Alt\u0131nova \u003ccanaltinova@gmail.com\u003e", "branch": "default", "desc": "Bug 1548694 - Split the profiler page information tests to prevent intermittent timeout. r=julienw, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D29812", "files": ["tools/profiler/tests/browser/browser.ini", "tools/profiler/tests/browser/browser_test_profile_history_page_info.js", "tools/profiler/tests/browser/browser_test_profile_multi_frame_page_info.js", "tools/profiler/tests/browser/browser_test_profile_page_info.js", "tools/profiler/tests/browser/browser_test_profile_pushstate_page_info.js", "tools/profiler/tests/browser/browser_test_profile_replacestate_page_info.js", "tools/profiler/tests/browser/browser_test_profile_single_frame_page_info.js"], "git_node": null, "git_parents": [null], "node": "6a10f43a0e116e3fcb8bb9ec816490f365eed1ce", "parents": ["61169eb427180be0b3b8fbbd9c2ef2e7f185a2ae"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1555255 - Don't require a network connection to produce Javadoc. r=agi, a=npotb\n\nSee https://stackoverflow.com/a/24026735.\n\nAdding the `docs` package requirement is not ideal, but it's not worth\nthe effort to install it only in automation (or in the relevant task),\nand it's not *that* large: 1.0G on my macOS installation.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35834", "files": ["mobile/android/geckoview/build.gradle", "python/mozboot/mozboot/android-packages.txt"], "git_node": null, "git_parents": [null], "node": "fa342b3889f31d94c001674aa190c8890d67582c", "parents": ["6a10f43a0e116e3fcb8bb9ec816490f365eed1ce"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1550634 - Increase telemetry-test-client max-run-time; r=jmaher, a=test-only\n\nAvoid intermittent failures by allowing the task to run a little longer.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34365", "files": ["taskcluster/ci/test/misc.yml"], "git_node": null, "git_parents": [null], "node": "69434884440fcdf4592d0b044b705ed2c229f811", "parents": ["fa342b3889f31d94c001674aa190c8890d67582c"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1558540 - Show report checkbox in uninstall addon dialog only for supported addon types. r=jaws,mstriemer, a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34643", "file