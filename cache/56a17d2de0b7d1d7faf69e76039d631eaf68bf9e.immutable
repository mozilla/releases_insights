zo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1555959 - Split Geckoview publication from the Fennec one r=Callek a=release\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33279", "files": [".cron.yml", "taskcluster/taskgraph/target_tasks.py"], "git_node": null, "git_parents": [null], "node": "367cb19f090ac1cc158765a0bb09fa7a7c4dd909", "parents": ["fcdf8c235e45415a730e6fee64d27eb5f9fe05bf"], "tags": []}], "date": 1559552734, "git_changesets": [null], "user": "jlorenzo@mozilla.com"}, "11356": {"changesets": [{"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1555959 - part 2: Fix flake 8 issue r=me a=bustage DONTBUILD", "files": ["taskcluster/taskgraph/target_tasks.py"], "git_node": null, "git_parents": [null], "node": "a18ba6b81509b2ecfb5fb963ec142e1382badf05", "parents": ["367cb19f090ac1cc158765a0bb09fa7a7c4dd909"], "tags": []}], "date": 1559553331, "git_changesets": [null], "user": "jlorenzo@mozilla.com"}, "11357": {"changesets": [{"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1555959 - part 3: Fix broken \\t in .cron.yml r=me a=bustage DONTBUILD\n\nFixes https://tools.taskcluster.net/groups/Tp1Sxlb9RgufQIbDW-8nBA/tasks/Tp1Sxlb9RgufQIbDW-8nBA/runs/0/logs/public%2Flogs%2Flive.log#L314", "files": [".cron.yml"], "git_node": null, "git_parents": [null], "node": "451c443ad93d89bc6f505824a8fbda602c328ef7", "parents": ["a18ba6b81509b2ecfb5fb963ec142e1382badf05"], "tags": []}], "date": 1559554516, "git_changesets": [null], "user": "jlorenzo@mozilla.com"}, "11358": {"changesets": [{"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1553873 - Add tests to ensure the Baidu search engine is sending the correct codes with the urls. r=daleharvey,a=test-only\n\nDepends on D32296\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32344", "files": ["toolkit/components/search/tests/xpcshell/searchconfigs/head_searchconfig.js", "toolkit/components/search/tests/xpcshell/searchconfigs/test_baidu.js"], "git_node": null, "git_parents": [null], "node": "22d87bbc303279e88bc87934996893a122a29171", "parents": ["451c443ad93d89bc6f505824a8fbda602c328ef7"], "tags": []}], "date": 1559563856, "git_changesets": [null], "user": "mbanner@mozilla.com"}, "11359": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP blocklist remote-settings tld-suffixes - a=repo-update r=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33485", "files": ["browser/app/blocklist.xml", "netwerk/dns/effective_tld_names.dat", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/blocklists/addons.json"], "git_node": null, "git_parents": [null], "node": "8aeedae78bb1b4d6c3bf24eba6ce4d3d522d727f", "parents": ["22d87bbc303279e88bc87934996893a122a29171"], "tags": []}], "date": 1559567388, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "11360": {"changesets": [{"author": "Emily Toop \u003cetoop@mozilla.com\u003e", "branch": "default", "desc": "Bug 1549633 - Enable listening for `recording-device-events`. r=esawin,geckoview-reviewers,snorp a=jcristau\n\nThis is to allow us to detect the enabling and disabling of recording so that we can notify the embedding application of the change in status.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31072", "files": ["mobile/android/components/geckoview/GeckoView.manifest", "mobile/android/components/geckoview/GeckoViewStartup.js", "mobile/android/geckoview/api.txt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/MediaDelegateTest.kt", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSession.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/doc-files/CHANGELOG.md", "mobile/android/geckoview_example/src/main/java/org/mozilla/geckoview_example/GeckoViewActivity.java", "mobile/android/modules/geckoview/GeckoViewMedia.jsm"], "git_node": null, "git_parents": [null], "node": "36fc5c4b157bd06adc11353f7431c7146317f8ef", "parents": ["8aeedae78bb1b4d6c3bf24eba6ce4d3d522d727f"], "tags": []}, {"author": "Emily Toop \u003cetoop@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554778 - Fetch dispatcher at the beginning of `handleRecordingDeviceEvents`. r=geckoview-reviewers,snorp a=jcristau\n\nThis is because in some circumstances, when navigating away from a page, the dispatcher is no longer present when trying to send the `GeckoView:MediaRecordingStatusChanged` causing the message not to be sent. Fetching the dispatcher earlier ensures that it is present at the point of message sending.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32830", "files": ["mobile/android/modules/geckoview/GeckoViewMedia.jsm"], "git_node": null, "git_parents": [null], "node": "75a98a0225b3c38bfd789e019b66e87a4b6c1199", "parents": ["36fc5c4b157bd06adc11353f7431c7146317f8ef"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1551183: Part 1 - Add SCOPE_APPLICATION to enabledScopes for Fennec. r=aswan a=jcristau\n\nThis scope now controls add-ons bundled in omni.ja as well as those in the app\ndirectory, so we need to enable it on Fennec in order for the default theme to\nwork.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32223", "files": ["mobile/android/app/mobile.js", "mobile/android/chrome/content/browser.js"], "git_node": null, "git_parents": [null], "node": "868a040f89c3a5ccb7eca2a7cba219ff4088c4f7", "parents": ["75a98a0225b3c38bfd789e019b66e87a4b6c1199"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1551183: Part 2 - Support enumerating directories in extensions in nested JARs. r=aswan a=jcristau\n\nOn Android, omni.ja is bundled inside an API, and therefore loaded as a nested\nJAR. That means that its resource URIs resolve to something resembling\n\"jar:jar:...!/omni.ja!/...\". Our current enumeration code assumes no nesting\nof jar: URIs, and therefore can't handle this.\n\nThis patch changes our enumeration helpers to accept URIs rather than nsIFile\ninstances, and to correctly handle resolving the ZipReaders for those nested\nJARs. It also moves the path filter generation into the native helper to make\nthings easier for other callers which may need this behavior.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32224", "files": ["toolkit/components/extensions/Extension.jsm", "toolkit/mozapps/extensions/AddonManagerStartup.cpp", "toolkit/mozapps/extensions/amIAddonManagerStartup.idl"], "git_node": null, "git_parents": [null], "node": "1878395be29ab4deace5ca3d3bdaee2cac1aa908", "parents": ["868a040f89c3a5ccb7eca2a7cba219ff4088c4f7"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1551183: Part 3 - Add a test to sanity check the default theme on all platforms. r=aswan a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32225", "files": ["toolkit/mozapps/extensions/internal/XPIDatabase.jsm", "toolkit/mozapps/extensions/test/mochitest/chrome.ini", "toolkit/mozapps/extensions/test/mochitest/test_default_theme.html", "toolkit/mozapps/extensions/test/moz.build"], "git_node": null, "git_parents": [null], "node": "d31cfde1fa7b466aa2d4fd14a5740e430ab588c4", "parents": ["1878395be29ab4deace5ca3d3bdaee2cac1aa908"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1551563 - Move shortcut test to own file r=mstriemer,mixedpuppy a=jcristau\n\nIn bug 1522757, a new test was added to verify that extensions without\nshortcuts were hidden in the shortcut view, and shown in a list of\nextensions without shortcuts.\n\nThe test was inserted in an existing test that did not have anything to\ndo with the change. In the next patch, I am going to add similar tests,\nso the test logic was moved to a separate file.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31794", "files": ["toolkit/mozapps/extensions/test/browser/browser.ini", "toolkit/mozapps/extensions/test/browser/browser_manage_shortcuts.js", "toolkit/mozapps/extensions/test/browser/browser_manage_shortcuts_hidden.js"], "git_node": null, "git_parents": [null], "node": "fe605c689819fc0ca9aa629f1557d796b0c979b8", "parents": ["d31cfde1fa7b466aa2d4fd14a5740e430ab588c4"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1551563 - Hide hidden/builtin extensions in shortcuts view r=mstriemer,mixedpuppy,kmag a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31795", "files": ["toolkit/mozapps/extensions/content/shortcuts.js", "toolkit/mozapps/extensions/test/browser/browser_manage_shortcuts_hidden.js"], "git_node": null, "git_parents": [null], "node": "5532b4c4315e32dcdef0f656db1fffc4cfad4367", "parents": ["fe605c689819fc0ca9aa629f1557d796b0c979b8"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1553214 - add fallback value for pageError.cssSelectors r=pbro a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33069", "files": ["devtools/client/webconsole/utils/messages.js"], "git_node": null, "git_parents": [null], "node": "e87602ae8d9f91280a079e72d47cedd9a394abcb", "parents": ["5532b4c4315e32dcdef0f656db1fffc4cfad4367"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554167 - Remove pending shutdown sanitization immediately after shutdown sanitization finishes. r=mak,baku a=jcristau\n\nIn https://hg.mozilla.org/mozilla-central/rev/25397a6f8c4f#l1.35 we added an early return to\nthe SanitizeOnShutdown function to avoid cleaning principals by permission if the user had\nset their preferences to clear all storage on shutdown anyway. This unfortunately ended\nthe function execution before it would call `removePendingSanitization(\"shutdown\");` later on\nand thus remove the pending shutdown sanitization (which, in fact, had completed successfully earlier).\n\nThe result is that the shutdown sanitization would be left dangling and run again on next startup,\nwhere, for reasons I don't fully understand, it would race and conflict with loading the home page,\nif that home page was from web content.\n\nThe solution is to remove the pending shutdown sanitization immediately after the sanitization is done.\n\nAs far as I can see there was never really a point in having it happen after session principal\ncleanup finished, since in case of a crash it would not run the principal cleanup again next startup,\njust the shutdown cleanup.\n\nFor good measure I also moved the new tab container sanitization to happen earlier in this function,\nto prevent it from dangling as well.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33087", "files": ["browser/modules/Sanitizer.jsm"], "git_node": null, "git_parents": [null], "node": "736e8d1c1c44873cbd829ef9b97f890111700b51", "parents": ["e87602ae8d9f91280a079e72d47cedd9a394abcb"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1554744 - make button state in browser language dialog correct when there's no available languages, r=johannh a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33273", "files": ["browser/components/preferences/browserLanguages.js"], "git_node": null, "git_parents": [null], "node": "fa85a070d83364097722aeb109b110eba62b51f8", "parents": ["736e8d1c1c44873cbd829ef9b97f890111700b51"], "tags": []}], "date": 1559572407, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "malexandru@mozilla.com"}, "11361": {"changesets": [{"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Bug 1555688 - Force httpResponseProcessSelection on for browser_oopProcessSwap.js r=nika a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33256", "files": ["toolkit/components/remotebrowserutils/tests/browser/browser_oopProcessSwap.js"], "git_node": null, "git_parents": [null], "node": "a6afed16db75cd107adb3157413cdfafb75894fa", "parents": ["fa85a070d83364097722aeb109b110eba62b51f8"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1554217 - Disable HTTPResponseProcessSelection on Beta, r=farre a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32489", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "0d8fa616dda8cb1c5552e77cf917221c13b435da", "parents": ["a6afed16db75cd107adb3157413cdfafb75894fa"], "tags": []}, {"author": "Haik Aftandilian \u003chaftandilian@mozilla.com\u003e", "branch": "default", "desc": "Bug 1555168 - Disable RDD Sandbox Early Start in Beta/68 r?jmathies a=jcristau\n\nDisable starting the RDD Mac sandbox early (landed with bug 1525086) during RDD process startup in Beta.\n\nThis reverts parts of bug 1525086 so that the RDD Mac sandbox is started later after the IPC event loop is up.\n\nDifferential Revision: https://phabricator.services.mozilla.com//D33240", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "4f71238da5e9fb86062a8a9374ef3e16359a4f67", "parents": ["0d8fa616dda8cb1c5552e77cf917221c13b435da"], "tags": []}, {"author": "YUKI \"Piro\" Hiroshi \u003cyuki@clear-code.com\u003e", "branch": "default", "desc": "Bug 1555584 - SearchSuggestEnabled policy should affect to the separate search bar r=mkaply a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33132", "files": ["browser/components/enterprisepolicies/Policies.jsm", "browser/components/enterprisepolicies/tests/xpcshell/test_simple_pref_policies.js"], "git_node": null, "git_parents": [null], "node": "2a5542ec36280ebfd0d699f8494977822e66b2c0", "parents": ["4f71238da5e9fb86062a8a9374ef3e16359a4f67"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1555661 - Fix client code inclusion in Google urls. r=daleharvey a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33157", "files": ["CLOBBER", "browser/components/search/extensions/google/_locales/2018/messages.json", "browser/components/search/extensions/google/_locales/b-1-d/messages.json", "browser/components/search/extensions/google/_locales/b-1-e/messages.json", "browser/components/search/extensions/google/_locales/b-d/messages.json", "browser/components/search/extensions/google/_locales/b-e/messages.json", "browser/components/search/extensions/google/_locales/en/messages.json", "browser/components/search/extensions/google/manifest.json", "toolkit/components/search/tests/xpcshell/searchconfigs/head_searchconfig.js"], "git_node": null, "git_parents": [null], "node": "3d9d20f173e3c76e1f4adfa703d2c3b09ddff7d8", "parents": ["2a5542ec36280ebfd0d699f8494977822e66b2c0"], "tags": []}, {"author": "Chris H-C \u003cchutten@mozilla.com\u003e", "branch": "default", "desc": "Bug 1555798 - Use a scalar name copy instead of a &BaseScalarInfo r=Dexter a=jcristau\n\nReferences to ScalarInfo objects are stable for all scalars registered\nat compile-time, but not for those registered at runtime.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33274", "files": ["toolkit/components/telemetry/core/TelemetryScalar.cpp"], "git_node": null, "git_parents": [null], "node": "c18af2278a4d3027bdbfc07454e99c6611862377", "parents": ["3d9d20f173e3c76e1f4adfa703d2c3b09ddff7d8"], "tags": []}, {"author": "Chris H-C \u003cchutten@mozilla.com\u003e", "branch": "default", "desc": "Bug 155