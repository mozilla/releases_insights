2fe0f\nhsb -\u003e 3496d2a6b2dd\nhu -\u003e 86ba899038e0\nid -\u003e 5f8d32d9605e\nit -\u003e fef0e2b64bd5\nka -\u003e 24fffa7c333a\nlij -\u003e 672b3525fa77\nlt -\u003e 1c32ca655cd5\nnl -\u003e 2c6a90555328\nnn-NO -\u003e c83c459c1e03\npa-IN -\u003e 1f8cdce20402\npl -\u003e 7fd6ad565a10\npt-BR -\u003e cdf38ea39c69\npt-PT -\u003e 03d99b787301\nrm -\u003e 577841517f94\nro -\u003e cd1b52b3f8d2\nru -\u003e 37780b0d96a4\nsq -\u003e a3838117fc3a\nsv-SE -\u003e 670598183769\nte -\u003e 7730e9096da9\nth -\u003e 432fafbbe5bd\ntr -\u003e d7a8c90070e7\nur -\u003e 3fdab93fe432\nvi -\u003e 9361306f074a\nzh-CN -\u003e 45fae879f666", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "f37bb25ff66a244cc734cda70456cfb374c4067e", "parents": ["39520fe84be8fa798a6b8f89784f58f0c5b9a689"], "tags": []}], "date": 1558936833, "git_changesets": [null, null], "user": "ffxbld"}, "11312": {"changesets": [{"author": "Dale Harvey \u003cdale@arandomurl.com\u003e", "branch": "default", "desc": "Bug 1551554 - Fix broken webextension localisation keys. r=Standard8 a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31545", "files": ["browser/components/search/extensions/google/manifest.json", "browser/components/search/extensions/yandex/manifest.json"], "git_node": null, "git_parents": [null], "node": "e2e26a62422c58f789934eb79faa6e07d6d3f974", "parents": ["f37bb25ff66a244cc734cda70456cfb374c4067e"], "tags": []}, {"author": "Miko Mynttinen \u003cmikokm@gmail.com\u003e", "branch": "default", "desc": "Bug 1552789 - Check NS_FRAME_FORCE_DISPLAY_LIST_DESCEND_INTO flag for every line r=mattwoodrow a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31865", "files": ["layout/generic/nsBlockFrame.cpp", "layout/reftests/bugs/1552789-1.html", "layout/reftests/bugs/1552789-ref-1.html", "layout/reftests/bugs/reftest.list"], "git_node": null, "git_parents": [null], "node": "413832ca33c270cc97114acf252dab4ce2ec6d0a", "parents": ["e2e26a62422c58f789934eb79faa6e07d6d3f974"], "tags": []}, {"author": "Dylan Roeh \u003cdroeh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1543387 - Ignore initial about:blank load when restoring scroll position. r=snorp a=jcristau\n\nWhen restoreState is called early in a GeckoSession's life, the scroll position restore code can catch the pageshow event for the initial about:blank load rather than for the page being restored, resulting in a failure to restore scroll position.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32163", "files": ["mobile/android/chrome/geckoview/GeckoViewContentChild.js"], "git_node": null, "git_parents": [null], "node": "dbf2d7493d851d2a1f57b3a9d414ca5bb99ed31f", "parents": ["413832ca33c270cc97114acf252dab4ce2ec6d0a"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Bug 1543387 - Ignore initial about:blank load when restoring scroll position: add missing semicolon. r=snorp a=jcristau", "files": ["mobile/android/chrome/geckoview/GeckoViewContentChild.js"], "git_node": null, "git_parents": [null], "node": "d37e9d3c46d7babf800258e696687c18370c22df", "parents": ["dbf2d7493d851d2a1f57b3a9d414ca5bb99ed31f"], "tags": []}, {"author": "Robert Strong \u003crobert.bugzilla@gmail.com\u003e", "branch": "default", "desc": "Bug 1552853 - Fix the update UI so it displays restart when it should when update staging fails. r=mhowell a=jcristau\n\nFixes the case reported where disabling the maintenance service caused the UI to display Applying due to the update staging failure.\nAdded new error codes for the two cases where pending was written to the update.status file when staging failed.\nAdded code to UpdateService.jsm to set the update.status to pending when either of the two new error codes are in the update.status file.\nAdded two new tests that verify the UI and simulate the failure condition in updater.cpp.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32177", "files": ["toolkit/mozapps/update/UpdateService.jsm", "toolkit/mozapps/update/common/updatererrors.h", "toolkit/mozapps/update/tests/browser/browser.bits.ini", "toolkit/mozapps/update/tests/browser/browser.ini", "toolkit/mozapps/update/tests/browser/browser_aboutDialog_bc_downloaded_stagingFailure.js", "toolkit/mozapps/update/tests/browser/browser_aboutPrefs_bc_downloaded_stagingFailure.js", "toolkit/mozapps/update/tests/browser/head.js", "toolkit/mozapps/update/updater/updater.cpp"], "git_node": null, "git_parents": [null], "node": "b03b23d73d3c50e43c7afe75705ca8fa2e711385", "parents": ["d37e9d3c46d7babf800258e696687c18370c22df"], "tags": []}, {"author": "Jonathan Watt \u003cjwatt@jwatt.org\u003e", "branch": "default", "desc": "Bug 1550531. Fix -moz-element memory leak and related shutdown hangs. r=emilio a=jcristau", "files": ["layout/svg/SVGObserverUtils.cpp", "layout/svg/SVGObserverUtils.h"], "git_node": null, "git_parents": [null], "node": "03bd600d3313f126b24f2e09d8360b92eb89692e", "parents": ["b03b23d73d3c50e43c7afe75705ca8fa2e711385"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1551282 and bug 1553436.  Allow pages to override window.u2f but not the \"sign\" and \"register\" properties on the U2F object.  r=jcj,smaug a=jcristau\n\nThere are two related problems this patch is trying to address.  The first, and\nsimpler, one is bug 1553436: there are websites that use existing variables and\nfunctions named \"u2f\" and adding a non-replaceable readonly property with that\nname on Window breaks them.  The fix for this is straightforward: mark the\nproperty [Replaceable].\n\nThe second problem, covered by bug 1551282, involves sites that use the Google\nU2F polyfill.  The relevant parts of that polyfill look like this:\n\n  'use strict';\n  var u2f = u2f || {};\n  u2f.register = some_function_that_only_works_right_in_Chrome;\n  u2f.sign = some_function_that_only_works_right_in_Chrome;\n\nThe failure mode for that code before this fix is that the assignment to \"u2f\"\nthrows because it's a readonly property and we're in strict mode, so any code\nthe page concatenates in the same file after the polyfill does not get run.\nThat's what bug 1551282 is about.  The [Replaceable] annotation fixes that\nissue, because now the polyfill gets the value of window.u2f and then redefines\nthe property (via the [Replaceable] setter) to be a value property with that\nvalue.  So far, so good.\n\nBut then we need to prevent the sets of u2f.register\nand u2f.sign from taking effect, because if they are allowed to happen, the\nactual sign/register functionality on the page will not work in Firefox.  We\ncan't just make the properties readonly, because then the sets will throw due\nto being in strict mode, and we still have bug 1551282.  The proposed fix is to\nmake these accessor properties with a no-op setter, which is exactly what\n[LenientSetter] gives us.\n\nThe rest of the patch is just setting up infrastructure for generating the\nnormal bits we would generate if \"sign\" and \"register\" were methods and using\nthat to create the JSFunctions at the point when the getter is called.  The\nJSFunctions then get cached on the u2f instance object.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32357", "files": ["dom/bindings/Codegen.py", "dom/bindings/parser/WebIDL.py", "dom/u2f/U2F.cpp", "dom/u2f/U2F.h", "dom/u2f/tests/mochitest.ini", "dom/u2f/tests/test_bind.html", "dom/u2f/tests/test_polyfill_interaction.html", "dom/u2f/tests/test_u2f_replaceable.html", "dom/webidl/U2F.webidl"], "git_node": null, "git_parents": [null], "node": "cad154da3d81263133d3658a59de631addcf4cee", "parents": ["03bd600d3313f126b24f2e09d8360b92eb89692e"], "tags": []}, {"author": "Dale Harvey \u003cdale@arandomurl.com\u003e", "branch": "default", "desc": "Bug 1552193 - Restore engine shortName to pre webextensions value. r=Standard8 a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31876", "files": ["browser/components/search/test/marionette/test_engines_on_restart.py", "toolkit/components/search/SearchEngine.jsm", "toolkit/components/search/SearchService.jsm", "toolkit/components/search/tests/xpcshell/searchconfigs/head_searchconfig.js"], "git_node": null, "git_parents": [null], "node": "2b5515b4274ba0ff95a539cbc7f9d0b72dd9e6ca", "parents": ["cad154da3d81263133d3658a59de631addcf4cee"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1471698 - Remove our binutils-corruption-avoiding workaround for mingw-clang r=froydnj a=jcristau\n\nDepends on D31347\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31349", "files": ["browser/config/mozconfigs/win32/mingwclang", "browser/config/mozconfigs/win64/mingwclang", "taskcluster/scripts/misc/build-clang-8-mingw.sh"], "git_node": null, "git_parents": [null], "node": "aaeda42f9fbf3c791ef428fd53afbd122ce92bd8", "parents": ["2b5515b4274ba0ff95a539cbc7f9d0b72dd9e6ca"], "tags": []}, {"author": "Dale Harvey \u003cdale@arandomurl.com\u003e", "branch": "default", "desc": "Bug 1541415 - Add test to ensure engines send correct code. r=Standard8 a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31546", "files": ["browser/components/search/test/browser/browser_google.js", "toolkit/components/search/tests/xpcshell/searchconfigs/head_searchconfig.js", "toolkit/components/search/tests/xpcshell/searchconfigs/test_amazon.js", "toolkit/components/search/tests/xpcshell/searchconfigs/test_baidu.js", "toolkit/components/search/tests/xpcshell/searchconfigs/test_bing.js", "toolkit/components/search/tests/xpcshell/searchconfigs/test_duckduckgo.js", "toolkit/components/search/tests/xpcshell/searchconfigs/test_ebay.js", "toolkit/components/search/tests/xpcshell/searchconfigs/test_google.js", "toolkit/components/search/tests/xpcshell/searchconfigs/test_yandex.js"], "git_node": null, "git_parents": [null], "node": "fbf66e32c2c215cdcc9fecaafbdda27fb0dd7132", "parents": ["aaeda42f9fbf3c791ef428fd53afbd122ce92bd8"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1554354.  Fix new u2f tests on Android.  r=smaug a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32555", "files": ["dom/u2f/tests/test_bind.html", "dom/u2f/tests/test_polyfill_interaction.html"], "git_node": null, "git_parents": [null], "node": "617d77613a30d7feab1621cd36cf6d29d8e08544", "parents": ["fbf66e32c2c215cdcc9fecaafbdda27fb0dd7132"], "tags": []}], "date": 1558949651, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null], "user": "nbeleuzu@mozilla.com"}, "11313": {"changesets": [{"author": "Jan Odvarko \u003codvarko@gmail.com\u003e", "branch": "default", "desc": "Bug 1552110 - Properly render values in the Security panel r=fvsch a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32324", "files": ["devtools/client/netmonitor/src/components/SecurityPanel.js", "devtools/client/netmonitor/test/browser_net_security-details.js"], "git_node": null, "git_parents": [null], "node": "3455989277dc4d6c8d5fb6303d6076f333af624c", "parents": ["617d77613a30d7feab1621cd36cf6d29d8e08544"], "tags": []}, {"author": "Agi Sferro \u003cagi@sferro.dev\u003e", "branch": "default", "desc": "Bug 1553371 - Load chrome frameScripts when switching processes. r=snorp a=jcristau\n\nWhenever we switch processes in GeckoView we didn't inject frameScripts.\n\nThis change adds a new method `loadInitFrameScript` that is called whenever a\nmodule's new browser is attached to a window so that the frame script is loaded\ncorrectly into the new browser.\n\nThis fixes a bug in WebExtension pages where the WebExtension Process Script\nwould never be notified of a new WebExtension page window, breaking privileged\nAPIs.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32148", "files": ["mobile/android/chrome/geckoview/geckoview.js", "mobile/android/geckoview/src/androidTest/assets/web_extensions/extension-page-update/tab-script.js", "mobile/android/geckoview/src/androidTest/assets/web_extensions/extension-page-update/tab.html", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/WebExtensionTest.kt"], "git_node": null, "git_parents": [null], "node": "fb23d87ad492d731511d436db7e446afea90b4ef", "parents": ["3455989277dc4d6c8d5fb6303d6076f333af624c"], "tags": []}, {"author": "Agi Sferro \u003cagi@sferro.dev\u003e", "branch": "default", "desc": "Bug 1553371 - Load moz-extension pages in extension principal. r=snorp a=jcristau\n\nWebExtension can always open their respective WebExtension pages even when the\nWebExtension page is not content accessible.\n\nHowever, this is not true for `tabs.update`, which couldn't link to\nWebExtension pages at all.\n\nSimilarly, a user should be able to open a WebExtension page directly by typing\nthe URL.\n\nTo fix the above problems we pass the correct `triggeringPrincipal` when\nloading such URIs. This change also makes URI typed by the user not use the\n`systemPrincipal` anymore but a more restrictive codebase principal local to\nthe page that's being typed to avoid unintended side-effects. This also makes\nthe triggering URI always the page for these privileged pages, so we need to\nadjust some tests to account for that by loading unprivileged `http` pages\ninstead.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32149", "files": ["mobile/android/components/extensions/ext-tabs.js", "mobile/android/geckoview/src/androidTest/assets/web_extensions/extension-page-update/manifest.json", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/NavigationDelegateTest.kt", "mobile/android/modules/geckoview/GeckoViewNavigation.jsm"], "git_node": null, "git_parents": [null], "node": "c6df1fc8a2a17b2bbbf1c2dca6a391d0df67f449", "parents": ["fb23d87ad492d731511d436db7e446afea90b4ef"], "tags": []}, {"author": "Julien Cristau \u003cjcristau@mozilla.com\u003e", "branch": "default", "desc": "Bug 1516767 - Backed out changeset 2d54ea3f6208 (bug 1541062) for causing bug 1553737. a=backout", "files": ["modules/libpref/init/all.js", "toolkit/mozapps/update/content/updates.js", "toolkit/mozapps/update/content/updates.xul"], "git_node": null, "git_parents": [null], "node": "8a9ead04803465749d2cb41a9ca00cc72a050815", "parents": ["c6df1fc8a2a17b2bbbf1c2dca6a391d0df67f449"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1520456 - test_CF_HTML_clipboard.html should skip non-mac platform instead of detecting platform in html file. r=masayuki a=test-only\n\ntest_CF_HTML_clipboard.html does nothing if platform isn't mac. But according\nto intermittent failure log, this is often failure on Android.\n\nI guess that this is infra issue, but we should use skip-if to avoid this\nfailure instead.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32413", "files": ["editor/libeditor/tests/mochitest.ini", "editor/libeditor/tests/test_CF_HTML_clipboard.html"], "git_node": null, "git_parents": [null], "node": "7f83ca2147b8a9f3b7e5e6c6c5daae76be1c82a8", "parents": ["8a9ead04803465749d2cb41a9ca00cc72a050815"], "tags": ["DEVEDITION_68_0b5_BUILD1", "DEVEDITION_68_0b5_RELEASE", "FENNEC_68_0b5_BUILD1", "FENNEC_68_0b5_RELEASE", "FIREFOX_68_0b5_BUILD1", "FIREFOX_68_0b5_RELEASE"]}], "date": 1558953177, "git_changesets": [null, null, null, null, null], "user": "nbeleuzu@mozilla.com"}, "11314": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\ncy -\u003e 37fad25fb15e\nvi -\u003e 39d652b5c537\nzh-CN -\u003e d9f70f0e6589", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "ad152a2a5739fa05cc834d41236a6efb5ef8f187", "parents": ["7f83ca2147b8a9f3b7e5e6c6c5daae76be1c82a8"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\ncy -\u003e 37fad25fb15e\nvi -\u003e 39d652b5c537\nzh-CN -\u003e d9f70f0e6589", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "dc28babd8428789a862c8025a63be4254d419257", "parents": ["ad152a2a5739fa05cc834d41236a6efb5ef8f187"], "tags": []}], "date": 1558958433, "git_changesets": [null, null], "user": "ffxbld"}, "11315": {"changesets": [{"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Bug 1509673 - Bump the timeout for Windows opt builds to 3hr to match other PGO-enabled builds. r=me, a=release DONTBUILD\n\nSimilar to bug 1500274.", "files": ["taskcluster/ci/build/windows.yml"], "git_node": null, "git_parents": [null], "node": "5bd868ce2fd08433b06a727c679ab7fd3918274d", "parents": ["dc28babd8428789a862c8025a63be4254d419257"], "tags": []}], "date": 1558962676, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "11316": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 7f83ca2147b8a9f3b7e5e6c6c5daae76be1c82a8 with FENNEC_68_0b5_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "c278b7b94a12a988dd7d03f5a36d4691e282ae1e", "parents": ["5bd868ce2fd08433b06a727c679ab7fd3918274d"], "tags": []}], "date": 1558969026, "git_changesets": [null], "user": "ffxbld"}, "11317": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\ncy -\u003e 2067018b3526\nda -\u003e 4a7b3a178edc\nro -\u003e 1e2c016e1b6a", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "799b3e488f4891e411a75bb9b48cee076928ea1c", "parents": ["c278b7b94a12a988dd7d03f5a36d4691e282ae1e"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\ncy -\u003e 2067018b3526\nda -\u003e 4a7b3a178edc\nro -\u003e 1e2c016e1b6a", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "a3c3024d9cd5b81f73cb9ef02b9055579e2bf5c5", "parents": ["799b3e488f4891e411a75bb9b48cee076928ea1c"], "tags": []}], "date": 1558969237, "git_changesets": [null, null], "user": "ffxbld"}, "11318": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 7f83ca2147b8a9f3b7e5e6c6c5daae76be1c82a8 with DEVEDITION_68_0b5_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "b07f121a2ad4ec4103dd5b21e1079280ff370e44", "parents": ["a3c3024d9cd5b81f73cb9ef02b9055579e2bf5c5"], "tags": []}], "date": 1558969586, "git_changesets": [null], "user": "ffxbld"}, "11319": {"changesets": [{"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1548629 - Set contentDuration for gizmo-short.mp4. r=jya a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32107", "files": ["dom/media/test/manifest.js"], "git_node": null, "git_parents": [null], "node": "d32cf703d5665f0c9818289c1fab5e3bc0cfa1d6", "parents": ["b07f121a2ad4ec4103dd5b21e1079280ff370e44"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1548629 - Separate logic for media data with gaps and overlaps. r=jya a=jcristau\n\nIf we end up taking the gap branch of the if in the patch, and the media file\nin the future from the point we branched at contains no gaps or overlaps, we'll\nstill end up taking the gap branch until the end. This is because it only\nappends up to the start of the current frame, but not the frame itself. I.e.,\nwhen the next frame gets processed, there's still a gap in appended data.\n\nDepends on D32107\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32108", "files": ["dom/media/mediasink/DecodedStream.cpp"], "git_node": null, "git_parents": [null], "node": "67d20a416452bedd1df182229de370b3e32e4212", "parents": ["d32cf703d5665f0c9818289c1fab5e3bc0cfa1d6"], "tags": []}, {"author": "Gurzau Raul \u003crgurzau@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 8a9ead048034 (bug 1516767) for setting wrong bug number. a=backout", "files": ["modules/libpref/init/all.js", "toolkit/mozapps/update/content/updates.js", "toolkit/mozapps/update/content/updates.xul"], "git_node": null, "git_parents": [null], "node": "97158e94fd0a16e451db9720d64bdfc7df4c685e", "parents": ["67d20a416452bedd1df182229de370b3e32e4212"], "tags": []}, {"author": "Julien Cristau \u003cjcristau@mozilla.com\u003e", "branch": "default", "desc": "Bug 1553737 - Backed out changeset 2d54ea3f6208 (bug 1541062) for causing bug 1553737. a=backout", "files": ["modules/libpref/init/all.js", "toolkit/mozapps/update/content/updates.js", "toolkit/mozapps/update/content/updates.xul"], "git_node": null, "git_parents": [null], "node": "6ec3cb391f03a3d02c47e3cb4525fe9eb6abd242", "parents": ["97158e94fd0a16e451db9720d64bdfc7df4c685e"], "tags": []}], "date": 1559001240, "git_changesets": [null, null, null, null], "user": "rgurzau@mozilla.com"}, "11320": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 7f83ca2147b8a9f3b7e5e6c6c5daae76be1c82a8 with FIREFOX_68_0b5_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "35528f5b95dd34aeba73f14641aeb0d8b53dea86", "parents": ["6ec3cb391f03a3d02c47e3cb4525fe9eb6abd242"], "tags": []}], "date": 1559023907, "git_changesets": [null], "user": "ffxbld"}, "11321": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nar -\u003e 84fc5012c0e7\ncak -\u003e e75641a6a3c5\neo -\u003e 3c9fbf8e954a\neu -\u003e 2f70eded3795\nhsb -\u003e bf7aba899f1e\nnn-NO -\u003e cc6e3cc767a4\nsl -\u003e af493a798289", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "3ef9eb7fdd705da8c6fd2b56e06fb2857d6cdfc7", "parents": ["35528f5b95dd34aeba73f14641aeb0d8b53dea86"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nar -\u003e 84fc5012c0e7\ncak -\u003e e75641a6a3c5\neo -\u003e 3c9fbf8e954a\neu -\u003e 2f70eded3795\nhsb -\u003e bf7aba899f1e\nnn-NO -\u003e cc6e3cc767a4\nsl -\u003e af493a798289", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "c246934cd0fa26c9ed4cee40b07d4c5c7c32bc4d", "parents": ["3ef9eb7fdd705da8c6fd2b56e06fb2857d6cdfc7"], "tags": []}], "date": 1559030430, "git_changesets": [null, null], "user": "ffxbld"}, "11322": {"changesets": [{"author": "Ran Xu \u003crxu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1547184 - Remove taobao in android search plugins r=mkaply a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D28945", "files": ["mobile/android/components/search/searchplugins/list.json", "mobile/android/components/search/searchplugins/taobao.xml"], "git_node": null, "git_parents": [null], "node": "0221c97747ac3eebad8c9761a13c4d875c1ed45a", "parents": ["c246934cd0fa26c9ed4cee40b07d4c5c7c32bc4d"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1550401 - Report OOM size when StringParam::GetString is failure. r=geckoview-reviewers,snorp a=jcristau\n\nActually, all JNI Exceptions with `java.lang.OutOfMemoryError` call\n`NS_ABORT_OOM(0)`. But `JNIEnv::NewString` in `StringParam::GetString` can know\nOOM size when returning `nullptr`. So call `NS_ABORT_OOM` directly when\n`NewString` is failure.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31026", "files": ["widget/android/jni/Refs.h"], "git_node": null, "git_parents": [null], "node": "eeb4df23fecc835b765264d55032173c96e0db47", "parents": ["0221c97747ac3eebad8c9761a13c4d875c1ed45a"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1551185 - Make nsImageFrame::ShouldDisplaySelection() check whether resizer target element is its content or not r=smaug a=jcristau\n\nCurrently, `nsISelectionDisplay::DISPLAY_ALL` is used only by `HTMLEditor`.\nAnd only when it's set, `nsImageFrame::ShouldDisplaySelection()` returns `false`\nif only its `mContent` is selected.  However, this is based on an assumption,\nthat is, when only one `\u003cimg\u003e` is selected in an HTML editor, it's target of\nresizers.  However, this is completely wrong.  Web apps can disable resizers\nwith `document.execCommand(\"enableObjectResizing\", false, false)` and now,\nit's disabled by default.\n\nTherefore, this patch makes the method check whether its `mContent` is\ntarget of resizers at the moment.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32449", "files": ["editor/libeditor/HTMLEditor.h", "layout/generic/nsImageFrame.cpp", "layout/generic/test/mochitest.ini", "layout/generic/test/test_image_selection.html", "layout/generic/test/test_image_selection_in_contenteditable.html"], "git_node": null, "git_parents": [null], "node": "09b6c96b16ca7a5f05c26a0560a678716a5cdaff", "parents": ["eeb4df23fecc835b765264d55032173c96e0db47"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1551582 - Re-clamp the composited scroll offset if the scrollable rect changes. r=kats a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32248", "files": ["gfx/layers/apz/src/AsyncPanZoomController.cpp", "gfx/layers/apz/src/AsyncPanZoomController.h"], "git_node": null, "git_parents": [null], "node": "0b1967c23650b9e3629b565e645d6d63dfc4df04", "parents": ["09b6c96b16ca7a5f05c26a0560a678716a5cdaff"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1551582 - Add a gtest. r=kats a=jcristau\n\nDepends on D32248\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32249", "files": ["gfx/layers/apz/test/gtest/APZCTreeManagerTester.h", "gfx/layers/apz/test/gtest/APZTestCommon.h", "gfx/layers/apz/test/gtest/TestTreeManager.cpp"], "git_node": null, "git_parents": [null], "node": "4504c4d2ec6515faf75f6053b63dcded6d85313b", "parents": ["0b1967c23650b9e3629b565e645d6d63dfc4df04"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1552780 - Add missing --grey-90-a60 variable r=jaws a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32127", "files": ["toolkit/themes/shared/in-content/common.inc.css"], "git_node": null, "git_parents": [null], "node": "92ad835777649859d789da848c78e9f73d5d0716", "parents": ["4504c4d2ec6515faf75f6053b63dcded6d85313b"], "tags": []}, {"author": "Michal Novotny \u003cmichal.novotny@gmail.com\u003e", "branch": "default", "desc": "Bug 1553166 - Android browser.cache.disk.max_entry_size is too restrictive, r=valentin a=jcristau\n\nWe no longer use small cache on mobile, so such small max_entry_size is inadequate.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32104", "files": ["mobile/android/app/mobile.js"], "git_node": null, "git_parents": [null], "node": "884c684970a24cb564377b8a18beef4373e7babf", "parents": ["92ad835777649859d789da848c78e9f73d5d0716"], "tags": []}, {"author": "dlee \u003cdlee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1553963 - Fix Safe Browsing doesn't cache the gethash result for V4 tables. r=gcp a=jcristau\n\nWe use \".pset\" to find active tables, but in Bug 1353956, v4 prefix files\nare renamed to \".vlpset\".\n\nThis patches include both 'pset' and 'vlpset' to ScanStoreDir.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32433", "files": ["toolkit/components/url-classifier/Classifier.cpp"], "git_node": null, "git_parents": [null], "node": "bc9fed12c6e8f969337d00af730585d5590ce302", "parents": ["884c684970a24cb564377b8a18beef4373e7babf"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1554664 - Work-around broken border-radius caching. r=mattwoodrow a=jcristau\n\nThis is just a super-low-risk work-around for bug 1554755 that we can uplift to\nbeta, I'll follow-up in a bit in there with a fix and a test.\n\nThe reason my patch breaks this is because my patch stopped making images\nreframe.\n\nThe reframe was of course a very expensive way of invalidating that bit ;)\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32749", "files": ["layout/generic/nsImageFrame.cpp"], "git_node": null, "git_parents": [null], "node": "0a91cbfe3b3fa04f0af0adcaff33c8dc3b4a345d", "parents": ["bc9fed12c6e8f969337d00af730585d5590ce302"], "tags": []}], "date": 1559043579, "git_changesets": [null, null, null, null, null, null, null, null, null], "user": "malexandru@mozilla.com"}, "11323": {"changesets": [{"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1547924 - Ensure Leanplum Onboarding falls back to the new Onboarding UX; r=VladBaicu a=pascalc\n\nSummary:\n- Added the `LAST_PRIVACY` case for when the user is already signed into Firefox;\n- Use the new default onboarding strings and images. If they are localized.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D29347", "files": ["mobile/android/base/java/org/mozilla/gecko/mma/LeanplumVariables.java", "mobile/android/base/java/org/mozilla/gecko/mma/MmaLeanplumImp.java"], "git_node": null, "git_parents": [null], "node": "54457d76cd8cc055a48a4955822e937511e1b460", "parents": ["0a91cbfe3b3fa04f0af0adcaff33c8dc3b4a345d"], "tags": []}, {"author": "Barret Rennie \u003cbarret@brennie.ca\u003e", "branch": "default", "desc": "Bug 1547472 - Ref count the ProfilerScreenshots structure r=gerald,jesup a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32524", "files": ["gfx/layers/ProfilerScreenshots.cpp", "gfx/layers/ProfilerScreenshots.h", "gfx/layers/composite/CompositorScreenshotGrabber.cpp", "gfx/layers/mlgpu/MLGPUScreenshotGrabber.cpp", "gfx/webrender_bindings/RendererScreenshotGrabber.cpp", "gfx/webrender_bindings/RendererScreenshotGrabber.h"], "git_node": null, "git_parents": [null], "node": "d674f0f91eb487be6b23ea00f607da8843d079b4", "parents": ["54457d76cd8cc055a48a4955822e937511e1b460"], "tags": []}], "date": 1559047486, "git_changesets": [null, null], "user": "archaeopteryx@coole-files.de"}, "11324": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 7f83ca2147b8a9f3b7e5e6c6c5daae76be1c82a8 with DEVEDITION_68_0b5_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "21c421820c7cf589615a9fd52085d62ae128eae2", "parents": ["d674f0f91eb487be6b23ea00f607da8843d079b4"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release DONTBUILD", "files": ["browser/config/version_display.txt"], "git_node": null, "g