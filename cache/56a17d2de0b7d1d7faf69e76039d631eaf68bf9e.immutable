 "git_parents": [null], "node": "03e5d1efd942fdf0676da8a4ebf5173e24b5c4eb", "parents": ["e1a8f62a1d418cad1cf4cf13fd79e19b23e0a5c1"], "tags": []}], "date": 1561742692, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "11517": {"changesets": [{"author": "Julien Cristau \u003cjcristau@mozilla.com\u003e", "branch": "default", "desc": "Bug 1561994 - Fix browser_aboutCertError_mitm.js so it passes when security.enterprise_roots.enabled is enabled by default. r=keeler, a=test-only\n\nTurn off security.enterprise_roots.enabled for this test since that's\nwhat it expects.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36334", "files": ["browser/base/content/test/about/browser_aboutCertError_mitm.js"], "git_node": null, "git_parents": [null], "node": "736e0cd202d566907831f240ab0c434b0a2b21ca", "parents": ["03e5d1efd942fdf0676da8a4ebf5173e24b5c4eb"], "tags": []}, {"author": "Julien Cristau \u003cjcristau@mozilla.com\u003e", "branch": "default", "desc": "Bug 1561994 - Fix test_enterprise_roots.js so it passes when security.enterprise_roots.enabled is enabled by default. r=keeler, a=test-only\n\nAvoid race between off-main-thread loading of roots and flipping the\npref by making sure initialization is done.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36348", "files": ["security/manager/ssl/tests/unit/test_enterprise_roots.js"], "git_node": null, "git_parents": [null], "node": "e1fc478056d6b08a5c74c4ba94bf45ad9a00daa6", "parents": ["736e0cd202d566907831f240ab0c434b0a2b21ca"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1526659 - Use the default 3 chunks instead of 2 for Windows debug/ASan jsreftests to avoid time-outs. r=jmaher, a=test-only\n\nTests are imported from test262 upstream so this test suite is expected to become slower over time.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36295", "files": ["taskcluster/ci/test/reftest.yml"], "git_node": null, "git_parents": [null], "node": "c406e385f95d1451a36fba34f80733a663ee45d1", "parents": ["e1fc478056d6b08a5c74c4ba94bf45ad9a00daa6"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1553889 - Apply the AAT 'trak' table to macOS fonts regardless of whether we shaped using CoreText or HarfBuzz. r=jrmuizel, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32447", "files": ["gfx/thebes/gfxMacFont.cpp", "layout/reftests/forms/input/file/reftest.list"], "git_node": null, "git_parents": [null], "node": "147acf01a4dc7a53267c5fb4e7dddaae953939a0", "parents": ["c406e385f95d1451a36fba34f80733a663ee45d1"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1549052 - Avoid using CGEventPost for synthesizing wheel events on macOS. r=mstange, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34889", "files": ["widget/cocoa/nsChildView.mm"], "git_node": null, "git_parents": [null], "node": "e106f30c1f95336718ecefb4e565f97f5f11c274", "parents": ["147acf01a4dc7a53267c5fb4e7dddaae953939a0"], "tags": []}, {"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1560582 - Limit Skia glyph batch sizes. r=jrmuizel, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36148", "files": ["gfx/2d/DrawTargetSkia.cpp"], "git_node": null, "git_parents": [null], "node": "48a056813b7d4ccec53ec8ebcc0c6c93fcb06f06", "parents": ["e106f30c1f95336718ecefb4e565f97f5f11c274"], "tags": []}, {"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 1561950 - Lock fission.autostart on beta and release. r=nika,njn, a=RyanVM\n\nIt isn't ready to be enabled yet, and right now it can cause URIs to\nbe leaked to telemetry.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36228", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "6d5726d8218286096bd1b47a2edb99d57ed4ce16", "parents": ["48a056813b7d4ccec53ec8ebcc0c6c93fcb06f06"], "tags": []}], "date": 1561757772, "git_changesets": [null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "11518": {"changesets": [{"author": "Andy Wingo \u003cwingo@igalia.com\u003e", "branch": "default", "desc": "Bug 1556220 - Don't add CacheIR entries for typed bigint array access. r=mgaudet, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33459", "files": ["js/src/jit/CacheIR.cpp"], "git_node": null, "git_parents": [null], "node": "49b397671d0f6ed01b98acfc89493b2c70a849de", "parents": ["6d5726d8218286096bd1b47a2edb99d57ed4ce16"], "tags": []}, {"author": "Andy Wingo \u003cwingo@igalia.com\u003e", "branch": "default", "desc": "Bug 1557655 - Fix size_t/uint64_t mismatch for StringToBigInt on 32-bit. r=jwalden, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35022", "files": ["js/src/vm/BigIntType.cpp"], "git_node": null, "git_parents": [null], "node": "12c9d3b85c14cefe91e938b72c63e79f4f722e5d", "parents": ["49b397671d0f6ed01b98acfc89493b2c70a849de"], "tags": []}, {"author": "Kershaw Chang \u003ckershaw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1555322 - Make sure WebSocketImpl is deleted on the right thread. r=smaug, a=RyanVM\n\nI think the root cause of the crash is that WebSocketImpl is not deleted on the target thread. When this happens, there is a race between setting WebSocket::mImpl to nullptr and accessubg mImpl.\nIf WebSocketImpl is always deleted on the target thread, WebSocketImpl::Disconnect should be called in ~WebSocketImpl when mDisconnectingOrDisconnected is false.\nSo, this patch checks the ref counter in WebSocketImpl::Release and make sure to delete WebSocketImpl on the right thread.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34320", "files": ["dom/websocket/WebSocket.cpp"], "git_node": null, "git_parents": [null], "node": "1df87d06a827fb2989f3467da5ce59e155b34d18", "parents": ["12c9d3b85c14cefe91e938b72c63e79f4f722e5d"], "tags": []}, {"author": "Jeff Gilbert \u003cjgilbert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1507696 - Cherry-pick CopyTexImage3D fixes. r=lsalzman, a=RyanVM", "files": ["gfx/angle/checkout/out/gen/angle/id/commit.h", "gfx/angle/checkout/src/libANGLE/Context.cpp", "gfx/angle/checkout/src/libANGLE/Texture.cpp", "gfx/angle/checkout/src/libANGLE/Texture.h", "gfx/angle/cherry_picks.txt"], "git_node": null, "git_parents": [null], "node": "f8c40b71fcb16f6d1713563182c456b6201f7939", "parents": ["1df87d06a827fb2989f3467da5ce59e155b34d18"], "tags": []}], "date": 1561759067, "git_changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "11519": {"changesets": [{"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1533084 - [marionette] Skip test_set_orientation_portrait_secondary on Android for Fennec failures. r=webdriver-reviewers,ato a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33493", "files": ["testing/marionette/harness/marionette_harness/tests/unit/test_screen_orientation.py"], "git_node": null, "git_parents": [null], "node": "cefe5d9092d6c41fc85c2164ed76fa2f0c8b82d2", "parents": ["f8c40b71fcb16f6d1713563182c456b6201f7939"], "tags": []}], "date": 1561881877, "git_changesets": [null], "user": "apavel@mozilla.com"}, "11520": {"changesets": [{"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1551738: [partner] Add partner-config repositories for esr68; r=nthomas\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31184", "files": ["taskcluster/ci/config.yml"], "git_node": null, "git_parents": [null], "node": "e9d7e63b780b4009fb8a421ab4d279b11311605a", "parents": ["cefe5d9092d6c41fc85c2164ed76fa2f0c8b82d2"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "br