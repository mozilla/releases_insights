update/tests/data/xpcshellUtilsAUS.js"], "git_node": null, "git_parents": [null], "node": "958825ce740165cc1afe064deed6bb8d0be6864c", "parents": ["4a8ed8b764d0cad9d0c833abd17d167ed84c6281"], "tags": []}, {"author": "Robert Strong \u003crobert.bugzilla@gmail.com\u003e", "branch": "default", "desc": "Bug 1552657 (xpcshell test only) - Fix app update xpcshell tests so it is possible to run them locally. r=bytesized, a=testonly\n\nSpecify a profile when running marAppApply* xpcshell tests to prevent the application from trying to display the profile manager\nDon't unset LD_LIBRARY_PATH when running the tests on Linux so startup dependencies can be found\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31740", "files": ["toolkit/mozapps/update/tests/data/xpcshellUtilsAUS.js"], "git_node": null, "git_parents": [null], "node": "e9d9035e11e58302276689eeda113513ab1165de", "parents": ["958825ce740165cc1afe064deed6bb8d0be6864c"], "tags": []}], "date": 1558459894, "git_changesets": [null, null], "user": "rstrong@mozilla.com"}, "11289": {"changesets": [{"author": "Jan Beich \u003cjbeich@FreeBSD.org\u003e", "branch": "default", "desc": "Bug 1552652 - Unbreak building tests on Tier3 after bug 1545079. r=padenot a=NPOTB\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31756", "files": ["dom/media/gtest/MockCubeb.h"], "git_node": null, "git_parents": [null], "node": "93b9f438f63997e94a1e2b395d8a1fe7297d3965", "parents": ["e9d9035e11e58302276689eeda113513ab1165de"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Bug 1552345 - Disable dom/smil/test/test_smilConditionalProcessing.html on Android 7.0 for frequent failures. r=jmaher a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com//D32046", "files": ["dom/smil/test/mochitest.ini"], "git_node": null, "git_parents": [null], "node": "893d67d512c29acc46ec422fa0b8d348fae02bd8", "parents": ["93b9f438f63997e94a1e2b395d8a1fe7