ntent-src/lib/clamp-total-lines.js", "browser/components/newtab/content-src/styles/_mixins.scss", "browser/components/newtab/css/activity-stream-linux.css", "browser/components/newtab/css/activity-stream-mac.css", "browser/components/newtab/css/activity-stream-windows.css", "browser/components/newtab/data/content/activity-stream.bundle.js", "browser/components/newtab/test/unit/content-src/lib/clamp-total-lines.test.js"], "git_node": null, "git_parents": [null], "node": "23e2a740c60f3c90d0242cc21f0025bc0b26debe", "parents": ["1468b59c257087317384bee06b4a8250faa26a58"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1550858 - Update final final final final final actions or urls a=jcristau\n\nReviewers: k88hudson, r1cky\n\nReviewed By: r1cky\n\nBug #: 1550858\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34003", "files": ["browser/components/newtab/lib/OnboardingMessageProvider.jsm"], "git_node": null, "git_parents": [null], "node": "c6cf0c6f2c8933b53f6112865be891feb549b301", "parents": ["23e2a740c60f3c90d0242cc21f0025bc0b26debe"], "tags": []}, {"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1558574 - Re-add support for clickSelectsAll attribute on search-textbox. r=bgrins a=jcristau\n\nReviewers: bgrins\n\nReviewed By: bgrins\n\nBug #: 1558574\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34906", "files": ["toolkit/content/widgets/search-textbox.js"], "git_node": null, "git_parents": [null], "node": "e61f8c9dad77696aacec8206ac567d98de3ba6f5", "parents": ["c6cf0c6f2c8933b53f6112865be891feb549b301"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1559301 - Straighten up C/C++ standard compiler flags. a=jcristau\n\nSummary:\n- `info.type in ('clang-cl', 'clang', 'gcc')` is always true since MSVC\nsupport was removed.\n- For some reason, we didn't enforce C++14 on GCC.\n\nReviewers: nalexander\n\nReviewed By: nalexander\n\nSubscribers: nalexander\n\nBug #: 1559301\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34990", "files": ["build/moz.configure/toolchain.configure"], "git_node": null, "git_parents": [null], "node": "193e4087e4c1d2d7a27c3bf4c932a97d03a5b2d3", "parents": ["e61f8c9dad77696aacec8206ac567d98de3ba6f5"], "tags": []}, {"author": "Dave Townsend \u003cdtownsend@oxymoronical.com\u003e", "branch": "default", "desc": "Bug 1553929: Make some attempt to correctly match default profiles after profiles.ini has been manually edited by the user. r=froydnj a=jcristau\n\nReviewers: froydnj\n\nReviewed By: froydnj\n\nSubscribers: reviewbot\n\nBug #: 1553929\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34038", "files": ["toolkit/profile/nsToolkitProfileService.cpp", "toolkit/profile/xpcshell/test_invalid_descriptor.js", "toolkit/profile/xpcshell/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "907ea719f870dd254afaba4ce8fe17ff12b3d9e1", "parents": ["193e4087e4c1d2d7a27c3bf4c932a97d03a5b2d3"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1549290 - Set AbuseReport addon_signature as \"curated\" in AbuseReport on recommended addon. r=robwu a=jcristau\n\nReviewers: robwu, aswan\n\nReviewed By: robwu, aswan\n\nBug #: 1549290\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34849", "files": ["toolkit/mozapps/extensions/AbuseReporter.jsm", "toolkit/mozapps/extensions/test/xpcshell/test_AbuseReporter.js"], "git_node": null, "git_parents": [null], "node": "f0aba1f30d061247e15506c1d792c1713f3b769f", "parents": ["907ea719f870dd254afaba4ce8fe17ff12b3d9e1"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1540253 - Define an isRecommended property for add-ons a=jcristau\n\nReviewers: rpl, mstriemer, aswan\n\nReviewed By: aswan\n\nSubscribers: aswan\n\nBug #: 1540253\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34667", "files": ["toolkit/mozapps/extensions/internal/XPIDatabase.jsm", "toolkit/mozapps/extensions/internal/XPIInstall.jsm", "toolkit/mozapps/extensions/test/xpcshell/test_recommendations.js", "toolkit/mozapps/extensions/test/xpcshell/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "51db6334c288ee26368ad74eabea4ab4f2e14104", "parents": ["f0aba1f30d061247e15506c1d792c1713f3b769f"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1539699 - Show a recommended badge for recommended add-ons (HTML) a=jcristau\n\nReviewers: jaws, mixedpuppy\n\nReviewed By: mixedpuppy\n\nSubscribers: robwu, rpl\n\nBug #: 1539699\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34780", "files": ["toolkit/mozapps/extensions/content/aboutaddons.css", "toolkit/mozapps/extensions/content/aboutaddons.html", "toolkit/mozapps/extensions/content/aboutaddons.js", "toolkit/mozapps/extensions/test/browser/browser.ini", "toolkit/mozapps/extensions/test/browser/browser_html_recommendations.js", "toolkit/themes/shared/extensions/recommended.svg", "toolkit/themes/shared/in-content/common.inc.css", "toolkit/themes/shared/mozapps.inc.mn"], "git_node": null, "git_parents": [null], "node": "255b632c9f90cd1c8235eaf7346b5489c8c96afa", "parents": ["51db6334c288ee26368ad74eabea4ab4f2e14104"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1559112 - Do not check recommendations for builtin addons a=jcristau\n\nReviewers: aswan\n\nReviewed By: aswan\n\nBug #: 1559112\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34862", "files": ["toolkit/mozapps/extensions/internal/XPIInstall.jsm", "toolkit/mozapps/extensions/test/xpcshell/test_recommendations.js"], "git_node": null, "git_parents": [null], "node": "19b174fe464eaa7e3e1bc5455883ab7fd8c7d12d", "parents": ["255b632c9f90cd1c8235eaf7346b5489c8c96afa"], "tags": []}], "date": 1560789633, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null], "user": "dluca@mozilla.com"}, "11462": {"changesets": [{"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1559375 - Allow qualified AMD devices to get WR in late beta and release. r=jrmuizel a=jcristau\n", "files": ["gfx/thebes/gfxPlatform.cpp"], "git_node": null, "git_parents": [null], "node": "4b218aa16867e650450a8700fa45333b1903811c", "parents": ["19b174fe464eaa7e3e1bc5455883ab7fd8c7d12d"], "tags": []}], "date": 1560791920, "git_changesets": [null], "user": "kgupta@mozilla.com"}, "11463": {"changesets": [{"author": "Chris Manchester \u003ccmanchester@mozilla.com\u003e", "branch": "default", "desc": "Bug 1557019 - Package the d3d compiler dll during artifact builds. r=dmajor, a=npotb\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35069", "files": ["browser/installer/package-manifest.in"], "git_node": null, "git_parents": [null], "node": "303f3cf416022ae7f952d5ef778b93947742d114", "parents": ["4b218aa16867e650450a8700fa45333b1903811c"], "tags": []}, {"author": "Tarek Ziad\u00e9 \u003ctarek@mozilla.com\u003e", "branch": "default", "desc": "Bug 1558882 - Fixed intermittent on ThreadMetrics.CollectMetrics. r=erahm, a=test-only\n\nThe first test does not really need to check that we spend less than\n200ms, and we can give more time to the scheduler in the second\ntest, as long as we check that is less than the recursive dispatched\nevent\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34988", "files": ["xpcom/tests/gtest/TestThreadMetrics.cpp"], "git_node": null, "git_parents": [null], "node": "52dbf56c513ce3c74033a3b8d0d47483dd868df5", "parents": ["303f3cf416022ae7f952d5ef778b93947742d114"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1559131 - Add skip-if=require_signing to test_recommendations.js. r=rpl, a=test-only\n\ntest_recommendations.js has one test that verifies that an unsigned\nadd-on is not recommended. In order to load an unsigned add-on, it\nneeds to disable signing. Signing can however not be disabled when\nMOZ_REQUIRE_SIGNING=1. So skip the test if require_signing is set.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34891", "files": ["toolkit/mozapps/extensions/test/xpcshell/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "60f0c79f0f53fcbe5941d01423e6409f8ea1df0f", "parents": ["52dbf56c513ce3c74033a3b8d0d47483dd868df5"], "tags": ["DEVEDITION_68_0b11_BUILD1", "DEVEDITION_68_0b11_RELEASE", "FENNEC_68_0b11_BUILD1", "FENNEC_68_0b11_RELEASE", "FIREFOX_68_0b11_BUILD1", "FIREFOX_68_0b11_RELEASE"]}], "date": 1560792518, "git_changesets": [null, null, null], "user": "jcristau@mozilla.com"}, "11464": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 60f0c79f0f53fcbe5941d01423e6409f8ea1df0f with DEVEDITION_68_0b11_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "fd938072ebb4457c6c597815b2deb7065877a992", "parents": ["60f0c79f0f53fcbe5941d01423e6409f8ea1df0f"], "tags": []}], "date": 1560829819, "git_changesets": [null], "user": "ffxbld"}, "11465": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 60f0c79f0f53fcbe5941d01423e6409f8ea1df0f with FIREFOX_68_0b11_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "a3c823cb659ea8434259702250971af32d183ed9", "parents": ["fd938072ebb4457c6c597815b2deb7065877a992"], "tags": []}], "date": 1560830135, "git_changesets": [null], "user": "ffxbld"}, "11466": {"changesets": [{"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1552787 - Log a more verbose error message in the console when a abuse report fails for a client or server submission error. r=mixedpuppy a=jcristau\n\nThis patch includes the response status and response text for the abuse report submission failures in the AbuseReportError message, to make it easier to investigate report submission errors.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32812", "files": ["toolkit/mozapps/extensions/AbuseReporter.jsm", "toolkit/mozapps/extensions/test/xpcshell/test_AbuseReporter.js"], "git_node": null, "git_parents": [null], "node": "5e6fd9ff0ec3083625275592007b2cce020abd6d", "parents": ["a3c823cb659ea8434259702250971af32d183ed9"], "tags": []}], "date": 1560867107, "git_changesets": [null], "user": "aiakab@mozilla.com"}, "11467": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 60f0c79f0f53fcbe5941d01423e6409f8ea1df0f with DEVEDITION_68_0b11_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "c8ad95271ea253f31e66bf7c96120e07650f7816", "parents": ["5e6fd9ff0ec3083625275592007b2cce020abd6d"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release DONTBUILD", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "8cfb79a8c2f3e77f197a9ed8f078f629fbde6fc8", "parents": ["c8ad95271ea253f31e66bf7c96120e07650f7816"], "tags": []}], "date": 1560872977, "git_changesets": [null, null], "user": "ffxbld"}, "11468": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 60f0c79f0f53fcbe5941d01423e6409f8ea1df0f with FIREFOX_68_0b11_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "3ca23a52980d68e3c95abce99fb9027874c697b7", "parents": ["8cfb79a8c2f3e77f197a9ed8f078f629fbde6fc8"], "tags": []}], "date": 1560873174, "git_changesets": [null], "user": "ffxbld"}, "11469": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 60f0c79f0f53fcbe5941d01423e6409f8ea1df0f with FENNEC_68_0b11_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "4fa4f8ba3728ac6bf6813be800880f0f0dca5288", "parents": ["60f0c79f0f53fcbe5941d01423e6409f8ea1df0f"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 60f0c79f0f53fcbe5941d01423e6409f8ea1df0f with FENNEC_68_0b11_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "ad2449b9ca65b0895af275bf1bbbb47375aca159", "parents": ["4fa4f8ba3728ac6bf6813be800880f0f0dca5288"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release DONTBUILD", "files": ["mobile/android/config/version-files/beta/version_display.txt"], "git_node": null, "git_parents": [null], "node": "96b1f2bd1216551d43684a42e0d2c32b16ff2e5a", "parents": ["ad2449b9ca65b0895af275bf1bbbb47375aca159"], "tags": []}, {"author": "Julien Cristau \u003cjcristau@mozilla.com\u003e", "branch": "default", "desc": "Merge esr68 to beta. a=merge", "files": [".hgtags"], "git_node": null, "git_parents": [null, null], "node": "28211890081f39faa8b11d5432bb2dd2346e747a", "parents": ["3ca23a52980d68e3c95abce99fb9027874c697b7", "96b1f2bd1216551d43684a42e0d2c32b16ff2e5a"], "tags": []}, {"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP blocklist remote-settings - r=jcristau, a=repo-update\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35182", "files": ["browser/app/blocklist.xml", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/blocklists/addons.json", "services/settings/dumps/main/hijack-blocklists.json"], "git_node": null, "git_parents": [null], "node": "080ef15620cf31461faf8ad853561c49c3dfe373", "parents": ["28211890081f39faa8b11d5432bb2dd2346e747a"], "tags": []}], "date": 1560881789, "git_changesets": [null, null, null, null, null], "user": "jcristau@mozilla.com"}, "11470": {"changesets": [{"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1555565 - Export correct user's preference for dark theme by prefers-color-scheme media query, r=mats a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33133", "files": ["widget/gtk/nsLookAndFeel.cpp", "widget/gtk/nsLookAndFeel.h"], "git_node": null, "git_parents": [null], "node": "2edcae33cd6a9755aee477a868ccd4dff299eb35", "parents": ["080ef15620cf31461faf8ad853561c49c3dfe373"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1527048 - [Linux/GTK] Fallback to Adwaita light GTK theme for content when system theme has no light variant, r=karlt a=jcristau\n\nWe previously disabled system dark themes for Firefox chrome and content by gtk-application-prefer-dark-theme settings.\nThat option is no longer preferred by gnome project and was removed from tweaks tools. Theme makers are encouraged to use\na different name for the dark theme variants, like Adwaita-dark, Yaru-dark and so on. This option also does not\nwork when the GTK theme is missing the light variant completely.\n\nTo address that, this patch implements heuristics based on https://www.w3.org/TR/AERT/#color-contrast\nto check if the system GTK theme has good contrast/visibility with default HTML colors\n(white background and black text).\n\nIf widget.content.gtk-theme-override is empty and the system theme fails the test with gtk-application-prefer-dark-theme set to false, then Adwaita:light theme is used.\n\nThis patch was tested with some distro default light themes (Ambiance, Radiance, Yaru - Ubuntu, Arc - KDE, Menta - MATE)\nand dark/light themes are recognized correctly.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D29823", "files": ["widget/gtk/nsLookAndFeel.cpp"], "git_node": null, "git_parents": [null], "node": "ca5607bbcad3ed768cd576cebcc6b1f69b3e624c", "parents": ["2edcae33cd6a9755aee477a868ccd4dff299eb35"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1527048 - [Linux/Gtk] Remove MOZ_ALLOW_GTK_DARK_THEME and widget.chrome.allow-gtk-dark-theme configuration keys, r=karlt a=jcristau\n\nUse standard Gtk/Gnome way to set Firefox Gtk theme. Gtk theme of web content can be still configured\nby widget.content.allow-gtk-dark-theme and widget.content.gtk-theme-override.\n\nDepends on D29823\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30919", "files": ["modules/libpref/init/all.js", "widget/gtk/nsLookAndFeel.cpp"], "git_node": null, "git_parents": [null], "node": "8dd6c8c8a610719913e9738daae139e003b45d1d", "parents": ["ca5607bbcad3ed768cd576cebcc6b1f69b3e624c"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1558917 - Referrer no longer sent for new tab links r=thecount a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35073", "files": ["browser/components/newtab/lib/PlacesFeed.jsm", "browser/components/newtab/test/unit/lib/PlacesFeed.test.js", "browser/components/newtab/test/unit/unit-entry.js"], "git_node": null, "git_parents": [null], "node": "a78204125055376cc805fdfb330dfb2ad35bd411", "parents": ["8dd6c8c8a610719913e9738daae139e003b45d1d"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1559184 - Fix the damage caused by clang-format to DOMMatrix.h; r=bzbarsky a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34929", "files": ["dom/base/DOMMatrix.h"], "git_node": null, "git_parents": [null], "node": "e43bd705a68157592c615ab408d00c02076d993d", "parents": ["a78204125055376cc805fdfb330dfb2ad35bd411"], "tags": []}], "date": 1560897951, "git_changesets": [null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "11471": {"changesets": [{"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "No bug: Fix snap repackage dependencies; r=jlorenzo\n\nWhen snaps started being packaged on archive.mozilla.org, the `build_platform`\nof the snap repackge task changed, causing the beetmover dependencies to be\ndropped. Switch the platform back so that the dependencies are restored.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31585", "files": ["taskcluster/ci/release-snap-repackage/kind.yml"], "git_node": null, "git_parents": [null], "node": "9710df79dc09caef51323ebac30d437893eed9b7", "parents": ["e43bd705a68157592c615ab408d00c02076d993d"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1551738: [declarative-artifacts] Filter out artifacts that aren't generated; r=mtabara\n\nStub installers aren't generated on esr branches; the repackage task includes\nmetadata indicating this. Use this information to filter out upstream artifacts\nwhen use declarative artifacts.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31586", "files": ["taskcluster/taskgraph/util/scriptworker.py"], "git_node": null, "git_parents": [null], "node": "7d9a79e529ad9c01cef909ecf84a017890c4836c", "parents": ["9710df79dc09caef51323ebac30d437893eed9b7"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "No bug: [release] Release candidates generate stub installers; r=bhearsum\n\nWhen the logic was switched to be by release-type, rc's were accidentally\nexcluded.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31587", "files": ["taskcluster/ci/build/windows.yml"], "git_node": null, "git_parents": [null], "node": "a428cfd1149b6203e9c433ab617880cd8b24ed1d", "parents": ["7d9a79e529ad9c01cef909ecf84a017890c4836c"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1551738: [declarative-artifacts] Select artifact map by release-type, instead of by project; r=mtabara\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31646", "files": ["taskcluster/ci/beetmover-checksums/kind.yml", "taskcluster/ci/beetmover-repackage/kind.yml", "taskcluster/taskgraph/util/scriptworker.py"], "git_node": null, "git_parents": [null], "node": "63940d06f468175a53ebf06f0bbe8b59c872d0d8", "parents": ["a428cfd1149b6203e9c433ab617880cd8b24ed1d"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1551738: Add esr68 support to bouncer tasks; r=bhearsum\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31651", "files": ["taskcluster/ci/cron-bouncer-check/kind.yml", "taskcluster/ci/release-bouncer-aliases/kind.yml", "taskcluster/ci/release-bouncer-check/kind.yml", "taskcluster/ci/release-bouncer-sub/kind.yml", "taskcluster/taskgraph/transforms/bouncer_submission.py", "testing/mozharness/configs/releases/bouncer_firefox_esr.py"], "git_node": null, "git_parents": [null], "node": "017e76e98bc8cd90f425eefa831b3d7be1a8087f", "parents": ["63940d06f468175a53ebf06f0bbe8b59c872d0d8"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1551738: Generate bz2 update mars on esr68; r=bhearsum\n\nESR 68.2 is going to be the watershed for bz2 updates, so generate them for the\nmoment.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31652", "files": ["taskcluster/ci/repackage-l10n/kind.yml", "taskcluster/ci/repackage/kind.yml", "taskcluster/taskgraph/manifests/firefox_candidates.yml"], "git_node": null, "git_parents": [null], "node": "87bc55a17789cebb5d45d6ccc1823f13454126b1", "parents": ["017e76e98bc8cd90f425eefa831b3d7be1a8087f"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1551738: Add balrog and update-verify support for esr68; r=bhearsum\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31653", "files": ["taskcluster/ci/release-balrog-scheduling/kind.yml", "taskcluster/ci/release-balrog-submit-toplevel/kind.yml", "taskcluster/ci/release-update-verify-config/kind.yml"], "git_node": null, "git_parents": [null], "node": "d35c2dc40e91166a8e2a377933d6374708276473", "parents": ["87bc55a17789cebb5d45d6ccc1823f13454126b1"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1551738: Add update tests for update testing from the previous ESR release; r=bhearsum a=tomprince\n\nThis adds a new set of update tasks and channels for testing updates from the\nprevious ESR release, before we make the new release generally available as an\nupdate.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31654", "files": ["taskcluster/ci/release-balrog-submit-toplevel/kind.yml", "taskcluster/ci/release-update-verify-config-next/kind.yml", "taskcluster/ci/release-update-verify-next/kind.yml", "taskcluster/docs/kinds.rst", "taskcluster/taskgraph/transforms/update_verify.py", "taskcluster/taskgraph/transforms/update_verify_config.py"], "git_node": null, "git_parents": [null], "node": "3affb65b59d4b6b40edb99c480e6330d6b08b2f1", "parents": ["d35c2dc40e91166a8e2a377933d6374708276473"], "tags": []}], "date": 1560899154, "git_changesets": [null, null, null, null, null, null, null, null], "user": "mozilla@hocat.ca"}, "11472": {"changesets": [{"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "br