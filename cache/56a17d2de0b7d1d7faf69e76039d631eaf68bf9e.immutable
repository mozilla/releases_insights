/test/browser.ini"], "git_node": null, "git_parents": [null], "node": "22dba7347176f6885c4ee3f978aa13a35fc7862e", "parents": ["1b7aa4ccb45fed7631a62bace49cd6da0ac7d32b"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1528236 - [raptor] Refactor handling of remote profiles. r=perftest-reviewers,rwood\n\nDifferential Revision: https://phabricator.services.mozilla.com/D29329", "files": ["testing/raptor/raptor/raptor.py"], "git_node": null, "git_parents": [null], "node": "c6cccc4ebfcc08826c689102546ea05d7ddc660c", "parents": ["22dba7347176f6885c4ee3f978aa13a35fc7862e"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1528236 - [raptor] Remove test root folder during clean-up. r=perftest-reviewers,rwood\n\nDifferential Revision: https://phabricator.services.mozilla.com/D29330", "files": ["testing/raptor/raptor/raptor.py"], "git_node": null, "git_parents": [null], "node": "9eb4d019ee371b8b4d37c6e3f2f6ad582038c1dc", "parents": ["c6cccc4ebfcc08826c689102546ea05d7ddc660c"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1528236 - [raptor] Allow Raptor to run the tests all at once. r=perftest-reviewers,stephendonner,rwood\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31047", "files": ["testing/raptor/raptor/raptor.py"], "git_node": null, "git_parents": [null], "node": "e8d6d453337d96fb354184b2045e6b5b456a97b7", "parents": ["9eb4d019ee371b8b4d37c6e3f2f6ad582038c1dc"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1528236 - [raptor] Use constructor for initialization of raptor instances. r=perftest-reviewers,rwood\n\nThe patch tries to reduce the amount of initialization code\nto call when creating a new Raptor class.\n\nInitializing the ADBDevice already in the constructor of the\nRaptorAndroid class is currently not possible because it would\nmean that a device is immediately created but the \"adb\" binary\nis not available for python test jobs. This has to be fixed later.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D29331", "files": ["testing/raptor/raptor/raptor.py", "testing/raptor/test/conftest.py", "testing/raptor/test/test_raptor.py"], "git_node": null, "git_parents": [null], "node": "09eea8c87cd551a490ac92ebdc99cbb2041f07ee", "parents": ["e8d6d453337d96fb354184b2045e6b5b456a97b7"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1528236 - [raptor] Update profile building code to align with mochitests. r=perftest-reviewers,rwood\n\nDifferential Revision: https://phabricator.services.mozilla.com/D29332", "files": ["testing/raptor/raptor/raptor.py"], "git_node": null, "git_parents": [null], "node": "ed679c1e266d2beb10cd491f710fb6021e37c158", "parents": ["09eea8c87cd551a490ac92ebdc99cbb2041f07ee"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1528236 - [raptor] Environment variables should not be set via extra args. r=perftest-reviewers,rwood\n\nDifferential Revision: https://phabricator.services.mozilla.com/D29333", "files": ["testing/raptor/raptor/raptor.py"], "git_node": null, "git_parents": [null], "node": "90a51dbd6ee1126091052281424dfd8fb46fb119", "parents": ["ed679c1e266d2beb10cd491f710fb6021e37c158"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1528236 - [raptor] Fix root permission failures for device tuning. r=perftest-reviewers,stephendonner\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30922", "files": ["testing/raptor/raptor/raptor.py"], "git_node": null, "git_parents": [null], "node": "d12eb6d840fc2dbbf0746b3dbbbd0ca34352ca75", "parents": ["90a51dbd6ee1126091052281424dfd8fb46fb119"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1528236 - [raptor] Use opt-out mechanism for setting test specific preferences. r=perftest-reviewers,stephendonner\n\nDue to missing class abstractions for Gecko- and non-Gecko based\nbrowsers it's currently sub-optimal to define when preferences\nas defined by tests will be set.\n\nGiven that by default we run Gecko-based applications other\nbrowsers should opt-out from setting test preferences.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30923", "files": ["testing/raptor/raptor/raptor.py"], "git_node": null, "git_parents": [null], "node": "0d0a4250902b027df34308763f167bc84f3be8d9", "parents": ["d12eb6d840fc2dbbf0746b3dbbbd0ca34352ca75"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1550866 - Support try syntax '-p foo,bar,bob -u all[all]' to run Tier 2 tests on all platforms specified r=catlee\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30720", "files": ["taskcluster/taskgraph/try_option_syntax.py"], "git_node": null, "git_parents": [null], "node": "e3640e306c198fecaeb1725ad9810d0d062c82e1", "parents": ["0d0a4250902b027df34308763f167bc84f3be8d9"], "tags": []}, {"author": "Sean Stangl \u003csean.stangl@gmail.com\u003e", "branch": "default", "desc": "Bug 1551339 - Update VIXL to recent Utils and Globals files. r=nbp\n\nThis is preliminary work to allowing encoding of JSCVTFP, the instruction that exists on new AArch64 devices that greatly speeds up websites that use floating-point math.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30997", "files": ["js/src/jit/arm64/vixl/Assembler-vixl.cpp", "js/src/jit/arm64/vixl/Assembler-vixl.h", "js/src/jit/arm64/vixl/Cpu-vixl.h", "js/src/jit/arm64/vixl/Globals-vixl.h", "js/src/jit/arm64/vixl/Instructions-vixl.cpp", "js/src/jit/arm64/vixl/Instructions-vixl.h", "js/src/jit/arm64/vixl/Logic-vixl.cpp", "js/src/jit/arm64/vixl/MacroAssembler-vixl.cpp", "js/src/jit/arm64/vix