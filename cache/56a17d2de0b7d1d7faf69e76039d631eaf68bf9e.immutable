e/TCBCvartext.sam", "security/nss/tests/fips/cavs_samples/TDES/sample/TECBMMT2.sam", "security/nss/tests/fips/cavs_samples/TDES/sample/TECBMMT3.sam", "security/nss/tests/fips/cavs_samples/TDES/sample/TECBMonte2.sam", "security/nss/tests/fips/cavs_samples/TDES/sample/TECBMonte3.sam", "security/nss/tests/fips/cavs_samples/TDES/sample/TECBinvperm.sam", "security/nss/tests/fips/cavs_samples/TDES/sample/TECBpermop.sam", "security/nss/tests/fips/cavs_samples/TDES/sample/TECBsubtab.sam", "security/nss/tests/fips/cavs_samples/TDES/sample/TECBvarkey.sam", "security/nss/tests/fips/cavs_samples/TDES/sample/TECBvartext.sam", "security/nss/tests/fips/cavs_scripts/README", "security/nss/tests/fips/cavs_scripts/aes.sh", "security/nss/tests/fips/cavs_scripts/aesgcm.sh", "security/nss/tests/fips/cavs_scripts/dsa.sh", "security/nss/tests/fips/cavs_scripts/ecdsa.sh", "security/nss/tests/fips/cavs_scripts/hmac.sh", "security/nss/tests/fips/cavs_scripts/ike.sh", "security/nss/tests/fips/cavs_scripts/kas.sh", "security/nss/tests/fips/cavs_scripts/rng.sh", "security/nss/tests/fips/cavs_scripts/rsa.sh", "security/nss/tests/fips/cavs_scripts/runtest.sh", "security/nss/tests/fips/cavs_scripts/sha.sh", "security/nss/tests/fips/cavs_scripts/tdea.sh", "security/nss/tests/fips/cavs_scripts/tls.sh", "security/nss/tests/fips/cavs_scripts/validate.sh", "security/nss/tests/fips/cavs_scripts/validate1.sh", "security/nss/tests/fips/fips.sh"], "git_node": null, "git_parents": [null], "node": "fd384ae3e04ea04fada7a72d9b2362862c0a3898", "parents": ["2bee7577b5a687ef6da1cd27852da85d28af2395"], "tags": []}, {"author": "Michal Novotny \u003cmichal.novotny@gmail.com\u003e", "branch": "default", "desc": "Bug 1547266 - Make sure Http2PushedStream is used only on socket thread. r=dragana, a=ritu\n\nRaw pointer to Http2PushedStream is passed to nsHttpChannel and nsHttpTransaction to get it back to a new Http2Stream in the Http2Session. As a result Http2PushedStream's methods can be called on a wrong thread and possibly on already freed object. This patch uses Http2PushedStreamWrapper instead, which takes care about thread safety and checks if the object is still alive.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33511", "files": ["netwerk/protocol/http/Http2Push.cpp", "netwerk/protocol/http/Http2Push.h", "netwerk/protocol/http/Http2Session.cpp", "netwerk/protocol/http/Http2Stream.cpp", "netwerk/protocol/http/nsHttpChannel.cpp", "netwerk/protocol/http/nsHttpChannel.h", "netwerk/protocol/http/nsHttpConnectionMgr.cpp", "netwerk/protocol/http/nsHttpTransaction.h"], "git_node": null, "git_parents": [null], "node": "4174d76d91945a7261f81d7666eee4b2b35cb027", "parents": ["fd384ae3e04ea04fada7a72d9b2362862c0a3898"], "tags": []}, {"author": "Michal Novotny \u003cmichal.novotny@gmail.com\u003e", "branch": "default", "desc": "Bug 1528481 - Possible use after free in Http2Session::RecvPushPromise() if we have a usable entry in the cache for the resource. r=dragana, a=ritu\n\nIf we find a usable cache entry, the stream is closed and release in CachePushCheckCallback::OnCacheEntryCheck(). This patch converts raw pointer to a weak pointer, so we can simply check if the object still exists after AsyncOpenURI() finishes.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33945", "files": ["netwerk/protocol/http/Http2Session.cpp"], "git_node": null, "git_parents": [null], "node": "3d562db5d1ed358a18da5bbe160c1da4864ef6c0", "parents": ["4174d76d91945a7261f81d7666eee4b2b35cb027"], "tags": []}], "date": 1561363820, "git_changesets": [null, null, null], "user": "jcristau@mozilla.com"}, "11489": {"changesets": [{"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1559264 - Quantumbar: Don't call setValueFromResult when opening the history popup. r=dao a=ritu\n\nThe problem is that on switching back to the first tab (see the bug), userTypedValue is non-null when URLBarSetURI is called. Therefore the proxy state can't be valid. Something about bug 1529931 caused userTypedValue to go from null to non-null in this case. Details below, but the summary is that we shouldn't be calling UrlbarInput.setValueFromResult when opening the history popup, because setValueFromResult sets userTypedValue.\n\nBefore bug 1529931, result.autofill would always be undefined for the first result in the history popup, because we didn't allow UnifiedComplete to return an autofill result for the search triggered by the history popup. After that bug, UnifiedComplete could return an autofill result in that case -- and it likely would since the first result in the history popup has a very high frecency, which also makes it eligible for autofill.\n\nThe problem with having an autofill result in the history popup is that it triggers the input.setValueFromResult() call in UrlbarController.receiveResults [1], and setValueFromResult sets userTypedValue. So when the user opens the history popup, userTypedValue gets set to a non-null value (input._lastSearchString).\n\nThe fix is to not allow autofill for the history popup. After making that fix on revision https://hg.mozilla.org/mozilla-central/rev/5e2a3b886e64, the bug went away.\n\nHowever, after I made that fix on a fresh tree, the bug still happened. It turns out that input.setValueFromResult still ends up getting called, by UrlbarView._selectItem [2], which is called when results are received [3]. The fix for this afaict is just to pass `updateInput: false` to _selectItem.\n\nThe autofill-related fix doesn't seem to be necessary at all anymore (likely due to the substantial changes to autofill since that bug landed), but I left it in anyway since it seems right to not allow autofill results for the history popup.\n\nOne other useful bit of info is that userTypedValue is set to null by tabbrowser on page load [4], so that's how userTypedValue has a null value when the bug manifests and it goes from null to non-null.\n\n[1] https://hg.mozilla.org/mozilla-central/file/5e2a3b886e647af1968b9e52a6672bdeee2a0d6f/browser/components/urlbar/UrlbarController.jsm#l150\n[2] https://searchfox.org/mozilla-central/rev/da14c413ef663eb1ba246799e94a240f81c42488/browser/components/urlbar/UrlbarView.jsm#685\n[3] https://searchfox.org/mozilla-central/rev/da14c413ef663eb1ba246799e94a240f81c42488/browser/components/urlbar/UrlbarView.jsm#220\n[4] https://searchfox.org/mozilla-central/rev/da14c413ef663eb1ba246799e94a240f81c42488/browser/base/content/tabbrowser.js#5118\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35505", "files": ["browser/components/urlbar/UrlbarInput.jsm", "browser/components/urlbar/UrlbarView.jsm", "browser/components/urlbar/tests/browser/browser_dropmarker.js"], "git_node": null, "git_parents": [null], "node": "60e8af0747b4ae12b440b3e406ffedd4ccc71d5f", "parents": ["3d562db5d1ed358a18da5bbe160c1da4864ef6c0"], "tags": []}, {"author": "Tooru Fujisawa \u003carai_a@mac.com\u003e", "branch": "default", "desc": "Bug 1557056 - Use extended function only for self-hosted function that needs to store canonical name in extended slot. r=jandem a=ritu\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34983", "files": ["dom/bindings/Codegen.py", "js/src/builtin/Array.cpp", "js/src/builtin/Array.js", "js/src/builtin/Map.js", "js/src/builtin/MapObject.cpp", "js/src/builtin/Module.js", "js/src/builtin/RegExp.cpp", "js/src/builtin/RegExp.js", "js/src/builtin/SelfHostingDefines.h", "js/src/builtin/Set.js", "js/src/builtin/TypedArray.js", "js/src/builtin/intl/Collator.cpp", "js/src/builtin/intl/Collator.js", "js/src/builtin/intl/DateTimeFormat.cpp", "js/src/builtin/intl/DateTimeFormat.js", "js/src/builtin/intl/NumberFormat.cpp", "js/src/builtin/intl/NumberFormat.js", "js/src/frontend/Parser.cpp", "js/src/jit/IonAnalysis.cpp", "js/src/jit/MIR.cpp", "js/src/jit/MIR.h", "js/src/vm/ArrayBufferObject.cpp", "js/src/vm/CommonPropertyNames.h", "js/src/vm/JSFunction.cpp", "js/src/vm/JSFunction.h", "js/src/vm/SelfHosting.cpp", "js/src/vm/SelfHosting.h", "js/src/vm/SharedArrayObject.cpp", "js/src/vm/TypedArrayObject.cpp"], "git_node": null, "git_parents": [null], "node": "8fb74fcbc12c83a230f700196e83193e6749d740", "parents": ["60e8af0747b4ae12b440b3e406ffedd4ccc71d5f"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1559094 - Restore old behavior for background-size: cover + zero-sized background positioning area. r=dholbert a=ritu\n\nThis restores our previous and per-spec behavior. Comparing only ratios was not\ncorrect in the case one of the dimensions was zero and thus not scaled.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35571", "files": ["layout/generic/AspectRatio.h", "layout/painting/nsImageRenderer.cpp", "testing/web-platform/tests/css/css-backgrounds/background-size-cover-003-ref.html", "testing/web-platform/tests/css/css-backgrounds/background-size-cover-003.html"], "git_node": null, "git_parents": [null], "node": "edc925e0821a1066f0b354a486cfffe34b40e4f2", "parents": ["8fb74fcbc12c83a230f700196e83193e6749d740"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1559316 - ensure badge background does not turn white when tbody gets focus on :active. r=mtigley a=ritu\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35065", "files": ["devtools/client/accessibility/accessibility.css"], "git_node": null, "git_parents": [null], "node": "902d1b155d7bdbaeb3b08e3a2a06721aeb18d4c3", "parents": ["edc925e0821a1066f0b354a486cfffe34b40e4f2"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1559317 - ensure outline is not visible when tbody gets focus on :active. r=mtigley a=ritu\n\nDepends on D35065\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35066", "files": ["devtools/client/accessibility/accessibility.css"], "git_node": null, "git_parents": [null], "node": "c369003558cb91db6e7828c4e0c74ff32da47ff1", "parents": ["902d1b155d7bdbaeb3b08e3a2a06721aeb18d4c3"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1555627 - Set a learn more link on net error pages. r=prathiksha a=ritu\n\nBug 1284835 removed the hard-coded learn more link on cert and net error pages, which worked\nfor cert error pages because they explicitly set their own learn more links, but net error\npages were relying on the default href to be set. This wasn't revealed until bug 1530348\nmade about:neterror part of the new error pages.\n\nThe solution is simply to explicitly set the correct learn more link to net error pages.\n\nNote that in the case of PR_END_OF_FILE errors, we were not previously showing a \"learn more\"\nlink. That was not intentional, as far as I can tell, but was caused by the bug fixed in bug 1477875.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35163", "files": ["browser/actors/NetErrorChild.jsm", "browser/base/content/test/about/browser_aboutNetError.js"], "git_node": null, "git_parents": [null], "node": "da9f01df3bef6c8e34104875b4c5453b59e63155", "parents": ["c369003558cb91db6e7828c4e0c74ff32da47ff1"], "tags": ["DEVEDITION_68_0b13_BUILD1", "DEVEDITION_68_0b13_RELEASE", "FIREFOX_68_0b13_BUILD1", "FIREFOX_68_0b13_RELEASE"]}], "date": 1561383334, "git_changesets": [null, null, null, null, null, null], "user": "malexandru@mozilla.com"}, "11490": {"changesets": [{"author": "Julien Cristau \u003cjcristau@mozilla.com\u003e", "branch": "default", "desc": "No bug - Manually bump the Fennec Beta version number. a=release", "files": ["mobile/android/config/version-files/beta/version_display.txt"], "git_node": null, "git_parents": [null], "node": "dead08d3f55c81b333abee35ff42e5856904aebe", "parents": ["da9f01df3bef6c8e34104875b4c5453b59e63155"], "tags": ["FENNEC_68_0b13_BUILD1", "FENNEC_68_0b13_RELEASE"]}], "date": 1561395895, "git_changesets": [null], "user": "jcristau@mozilla.com"}, "11491": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging da9f01df3bef6c8e34104875b4c5453b59e63155 with DEVEDITION_68_0b13_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "5a248051d252bf6152f8b32834294c4fa5cff491", "parents": ["dead08d3f55c81b333abee35ff42e5856904aebe"], "tags": []}], "date": 1561396552, "git_changesets": [null], "user": "ffxbld"}, "11492": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging da9f01df3bef6c8e34104875b4c5453b59e63155 with FIREFOX_68_0b13_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "abc1d64c569b3ea3ffa0a00b441fea94884fa60f", "parents": ["5a248051d252bf6152f8b32834294c4fa5cff491"], "tags": []}], "date": 1561396940, "git_changesets": [null], "user": "ffxbld"}, "11493": {"changesets": [{"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1560600 - Don't allow WebRender for AMD on non-nightly for non-Windows platforms. r=kats a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35569", "files": ["gfx/thebes/gfxPlatform.cpp"], "git_node": null, "git_parents": [null], "node": "1d577a6a7cd16bfa7f25c02dcfef10e32aa3bfc0", "parents": ["abc1d64c569b3ea3ffa0a00b441fea94884fa60f"], "tags": []}, {"author": "Dave Townsend \u003cdtownsend@oxymoronical.com\u003e", "branch": "default", "desc": "Bug 1528082: Add an environment variable to disable dedicated profiles for enterprise use. r=froydnj a=jcristau\n\nIn some situations dedicated profile support does not work well. This includes a\nhandful of linux distributions which always install different application\nversions to different locations, some application sandboxing systems as well as\nenterprise deployments. This environment variable provides a way to opt out of\ndedicated profiles for these cases.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35249", "files": ["toolkit/profile/nsToolkitProfileService.cpp", "toolkit/profile/nsToolkitProfileService.h", "toolkit/profile/xpcshell/head.js", "toolkit/profile/xpcshell/test_legacy_empty.js", "toolkit/profile/xpcshell/test_legacy_select.js", "toolkit/profile/xpcshell/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "5c9288e6d56a6f27610ceca5e418431fca93119f", "parents": ["1d577a6a7cd16bfa7f25c02dcfef10e32aa3bfc0"], "tags": []}, {"author": "Honza Bambas \u003chonzab.moz@firemni.cz\u003e", "branch": "default", "desc": "Bug 1545421 - New nsresult error codes for 407, 502 and 504 http response codes returned by proxies + test, r=dragana a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32817", "files": ["docshell/base/nsDocShell.cpp", "dom/push/test/xpcshell/head-http2.js", "js/xpconnect/src/xpc.msg", "netwerk/protocol/http/Http2Stream.cpp", "netwerk/protocol/http/Http2Stream.h", "netwerk/protocol/http/TunnelUtils.cpp", "netwerk/protocol/http/TunnelUtils.h", "netwerk/protocol/http/nsHttpChannel.cpp", "netwerk/test/unit/test_http1-proxy.js", "netwerk/test/unit/test_http2-proxy.js", "netwerk/test/unit/test_proxy-authorization-via-proxyinfo.js", "netwerk/test/unit/xpcshell.ini", "testing/xpcshell/moz-http2/moz-http2.js", "testing/xpcshell/runxpcshelltests.py", "xpcom/base/ErrorList.py"], "git_node": null, "git_parents": [null], "node": "66f621aa4cfa7d3edb7a410a8c98c9b3d8c8a13c", "parents": ["5c9288e6d56a6f27610ceca5e418431fca93119f"], "tags": []}], "date": 1561475403, "git_changesets": [null, null, null], "user": "rmaries@mozilla.com"}, "11494": {"changesets": [{"author": "Razvan Maries \u003crmaries@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 1d577a6a7cd1 (bug 1560600) for build bustages. a=backout", "files": ["gfx/thebes/gfxPlatform.cpp"], "git_node": null, "git_parents": [null], "node": "90725f025a3b433f0bf0d69359905b51c3711d6a", "parents": ["66f621aa4cfa7d3edb7a410a8c98c9b3d8c8a13c"], "tags": []}], "date": 1561477197, "git_changesets": [null], "user": "rmaries@mozilla.com"}, "11495": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging da9f01df3bef6c8e34104875b4c5453b59e63155 with DEVEDITION_68_0b13_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "67ec891b1eb55525ddd854ca644fa75e5b42b451", "parents": ["90725f025a3b433f0bf0d69359905b51c3711d6a"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release DONTBUILD", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "434044962936fa918851e5ef924ceaa291ff6d13", "parents": ["67ec891b1eb55525ddd854ca644fa75e5b42b451"], "tags": []}], "date": 1561482470, "git_changesets": [null, null], "user": "ffxbld"}, "11496": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging da9f01df3bef6c8e34104875b4c5453b59e63155 with FIREFOX_68_0b13_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "12c0bcb999c5a37827726d4f373f7073597cfaa4", "parents": ["434044962936fa918851e5ef924ceaa291ff6d13"], "tags": []}], "date": 1561482668, "git_changesets": [null], "user": "ffxbld"}, "11497": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nbe -\u003e a7b895a610b8\nbn -\u003e 3ec0ef1ed685\ncs -\u003e 3c50db528527\nda -\u003e 6d5111c773d1\nde -\u003e 9815376b1116\neo -\u003e a5aad3ac227b\net -\u003e 08b5c171a842\neu -\u003e f1c75294ff2f\nfi -\u003e 908e9a6d9473\nfr -\u003e 67595a57d831\ngn -\u003e fcf0f98962c3\nhi-IN -\u003e 9543b38f9f11\nid -\u003e 8716389a5063\nis -\u003e 05776085158e\nit -\u003e b4f976f51043\nja -\u003e b362c42d6963\nka -\u003e 821b1290f578\nkab -\u003e 04252d7305aa\nkk -\u003e 333d143d524f\nko -\u003e c80216856b31\nlo -\u003e c3a37fc5682b\nnb-NO -\u003e d75c0bb81fac\nnl -\u003e 62b5e5894454\nnn-NO -\u003e a0edc259dd68\noc -\u003e caa3cebc09b5\npt-BR -\u003e a79b96f6e05d\nro -\u003e c12c336fa521\nsl -\u003e ee8e0ff66300\nsq -\u003e fc654a093500\nth -\u003e c2255a706fe0\ntr -\u003e 756c48113ac4", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "d07c9d6e74d12603ea83be3dc39665f1fd44a39f", "parents": ["12c0bcb999c5a37827726d4f373f7073597cfaa4"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nbe -\u003e a7b895a610b8\nbn -\u003e 3ec0ef1ed685\ncs -\u003e 3c50db528527\nda -\u003e 6d5111c773d1\nde -\u003e 9815376b1116\neo -\u003e a5aad3ac227b\net -\u003e 08b5c171a842\neu -\u003e f1c75294ff2f\nfi -\u003e 908e9a6d9473\nfr -\u003e 67595a57d831\ngn -\u003e fcf0f98962c3\nhi-IN -\u003e 9543b38f9f11\nid -\u003e 8716389a5063\nis -\u003e 05776085158e\nit -\u003e b4f976f51043\nja -\u003e b362c42d6963\nja-JP-mac -\u003e 946c255c788a\nka -\u003e 821b1290f578\nkab -\u003e 04252d7305aa\nkk -\u003e 333d143d524f\nko -\u003e c80216856b31\nnb-NO -\u003e d75c0bb81fac\nnl -\u003e 62b5e5894454\nnn-NO -\u003e a0edc259dd68\noc -\u003e caa3cebc09b5\npt-BR -\u003e a79b96f6e05d\nro -\u003e c12c336fa521\nsl -\u003e ee8e0ff66300\nsq -\u003e fc654a093500\nth -\u003e c2255a706fe0\ntr -\u003e 756c48113ac4", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "1d1f44e16b8ac54b14a32a2ce170b4022f9a6e43", "parents": ["d07c9d6e74d12603ea83be3dc39665f1fd44a39f"], "tags": []}], "date": 1561532428, "git_changesets": [null, null], "user": "ffxbld"}, "11498": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging dead08d3f55c81b333abee35ff42e5856904aebe with FENNEC_68_0b13_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "a750ad1d8a32187ec886bbadfc3b3d6d96ad2625", "parents": ["dead08d3f55c81b333abee35ff42e5856904aebe"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging dead08d3f55c81b333abee35ff42e5856904aebe with FENNEC_68_0b13_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "2527e40dd06412c58a2cf3cd8ba7406ff0b12299", "parents": ["a750ad1d8a32187ec886bbadfc3b3d6d96ad2625"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release DONTBUILD", "files": ["mobile/android/config/version-files/beta/version_display.txt"], "git_node": null, "git_parents": [null], "node": "dcee1aa734bd6e94a505def0fd1ab1b8fbdbe1cb", "parents": ["2527e40dd06412c58a2cf3cd8ba7406ff0b12299"], "tags": []}, {"author": "Julien Cristau \u003cjcristau@mozilla.com\u003e", "branch": "default", "desc": "Merge esr68 to beta. a=merge", "files": [".hgtags"], "git_node": null, "git_parents": [null, null], "node": "92aff78a68254a6aa5adcdad692d04e12c8cafb8", "parents": ["1d1f44e16b8ac54b14a32a2ce170b4022f9a6e43", "dcee1aa734bd6e94a505def0fd1ab1b8fbdbe1cb"], "tags": []}, {"author": "Andrei Lazar \u003candrei.a.lazar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1551458 Back button won't go back in history (Pixel 3 XL(Android 9)). r=VladBaicu, a=jcristau\n\nCreated an exception in the key event suppression mechanism for the back button KEYCODE.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33950", "files": ["mobile/android/base/java/org/mozilla/gecko/BrowserApp.java"], "git_node": null, "git_parents": [null], "node": "e2c7cdfea423496e97071cd8791cc5d9f060e22c", "parents": ["92aff78a68254a6aa5adcdad692d04e12c8cafb8"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1561245 - Add a null check for the received Intent; r=VladBaicu, a=jcristau\n\nAccording to the documentation -\nhttps://developer.android.com/reference/android/app/Service.html\n\"The Intent supplied to Context.startService(Intent) may be null if the service\nis being restarted after its process has gone away, and it had previously\nreturned anything except START_STICKY_COMPATIBILITY.\"\n\nWe will ignore the case when the system restarts our Service as we only expect\nit to be properly started by us, in the event of a crash.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35790", "files": ["mobile/android/base/java/org/mozilla/gecko/CrashHandlerService.java"], "git_node": null, "git_parents": [null], "node": "7d0117af32b0b354696f1510a772c2e43d338968", "parents": ["e2c7cdfea423496e97071cd8791cc5d9f060e22c"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1560587 - Remove incorrect event redirection. r=tnikkel, a=jcristau\n\nIn this codepath, the parent process may be sending an event to a particular\ncontent process. The last-saved mouse target might be stale, and using that\nto redirect the event can result in the event getting sent to the wront content\nprocess. Deleting this erroneous change restores correct behaviour.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35697", "files": ["layout/base/PresShell.cpp"], "git_node": null, "git_parents": [null], "node": "a9beb454bd6cfd5bb1045d5d255e07bc54acd5d2", "parents": ["7d0117af32b0b354696f1510a772c2e43d338968"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1547624 - Update mScaledHitRegionBounds when we add hit-test info to a Layer from within an inactive Layer. r=miko a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32260", "files": ["layout/painting/FrameLayerBuilder.cpp"], "git_node": null, "git_parents": [null], "node": "00c027a75c1cb7eff3d58b029f6764019abbb8ac", "parents": ["a9beb454bd6cfd5bb1045d5d255e07bc54acd5d2"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1547624 - Start inactive Layer building during ProcessDisplayItems so that any contained hit-test info gets propagated to the outer Layer before we add the next item. r=miko a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32261", "files": ["layout/painting/FrameLayerBuilder.cpp", "layout/painting/FrameLayerBuilder.h"], "git_node": null, "git_parents": [null], "node": "af24c9d1390f50ef1e5eff3ade5fcc7ca633b440", "parents": ["00c027a75c1cb7eff3d58b029f6764019abbb8ac"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1348503 - Retrieve the FrameLayerBuilder pointer from the LayerManager when we need it. r=tnikkel, a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34772", "files": ["layout/painting/FrameLayerBuilder.cpp", "layout/painting/FrameLayerBuilder.h"], "git_node": null, "git_parents": [null], "node": "4ae8f7ba99880f6693f5281c76dbb8e41bab11ff", "parents": ["af24c9d1390f50ef1e5eff3ade5fcc7ca633b440"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1530660: Fix registration for nsSafeFileOutputStream. r=erahm, a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35490", "files": ["netwerk/build/components.conf"], "git_node": null, "git_parents": [null], "node": "d996ccc0aa7eab043a8b926c3dffcd7d899530b6", "parents": ["4ae8f7ba99880f6693f5281c76dbb8e41bab11ff"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1558393 - Don't keep top level scope owner when going backwards. r=smaug, a=jcristau\n\nWhen going backwards the host is the last thing of the scope we see, not the\nfirst, so we need to make sure to properly switch to the document scope.\n\nTo be clear, the order this is happening when bogusly going backwards from\n`second` to `first` is:\n\n * We're doing frame traversal so start off the \u003cdiv\u003e.\n * The text is the first frame in preorder we find, we figure out that the\n   current top-level owner is the host. But it's not focusable so we carry on.\n * Now we go to the next frame and find the \u003cspan\u003e. `oldTopLevelScopeOwner` is\n   still the span itself, and we don't change it (that's what my patch fixes),\n   so we go into the \"We're within non-document scope, continue\", and thus skip\n   trying to focus the host.\n\nWith this fix we actually realize that the current top level scope owner has\nchanged and thus don't skip it and try to focus the slot properly.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35585", "files": ["dom/base/nsFocusManager.cpp", "dom/base/test/file_bug1453693.html"], "git_node": null, "git_parents": [null], "node": "f4a9a2f7f1d49ee2cafb3b7f959bf5fe3039e830", "parents": ["d996ccc0aa7eab043a8b926c3dffcd7d899530b6"], "tags": []}, {"author": "Kenny Levinsen \u003ckl@kl.wtf\u003e", "branch": "default", "desc": "Bug 1519940 - Use keyboard_handle_keymap instead of keys-changed on wayland. r=stransky, a=jcristau\n\nIf OnKeysChanged was called after keyboard_handle_keymap, then our newly configured keymap would be immediately cleared again. In order to avoid such scenario, use only keyboard_handle_keymap on wayland.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32599", "files": ["widget/gtk/nsGtkKeyUtils.cpp", "widget/gtk/nsGtkKeyUtils.h"], "git_node": null, "git_parents": [null], "node": "ab3fb204627cc68b1a3d0b4ec2b2405a84ae772d", "parents": ["f4a9a2f7f1d49ee2cafb3b7f959bf5fe3039e830"], "tags": []}, {"author": "Andrei Oprea \u003candrei.br92@gmail.com\u003e", "branch": "default", "desc": "Bug 1559946 - The CFR FxA Bookmark Panel Message has incorrect dimensions in some locales. r=r1cky, a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35676", "files": ["browser/themes/shared/places/editBookmarkPanel.inc.css"], "git_node": null, "git_parents": [null], "node": "56231826b1c88b76e8f808cc517845b9cd8223a7", "parents": ["ab3fb204627cc68b1a3d0b4ec2b2405a84ae772d"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1561465 - Avoid being too verbose after bug 1560527. r=nalexander, a=jcristau\n\nBug 1560527 was not supposed to change verbosity for mach build, but it\nturns out it did, because the ifeq it copied from one place to another\nwas wrong in the first place.\n\nWhile here, replace a ifeq that did work with the now equivalent\nBUILD_VERBOSE_LOG.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35966", "files": ["config/config.mk", "config/rules.mk"], "git_node": null, "git_parents": [null], "node": "15ee689ef0fc7022bd205e833b130430a61d8895", "parents": ["56231826b1c88b76e8f808cc517845b9cd8223a7"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1561465 - Remove ELOG. r=nalexander, a=jcristau\n\nThe condition that enabled ELOG to do something has been broken since\nbug 279212 landed two years ago, because MAKEFLAGS doesn't contain the\ndash for flags, so looking for \"-s\" never did anything.\n\nBug 1560527 changed the condition to !BUILD_VERBOSE_LOG, which as of the\nprevious commit, does work. This would restore the old behavior, at the\nexpense of build time, since it involves wrapping in a shell script,\nwhich is not necessarily desirable (and hasn't been done for two years\nnow)\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35967", "files": ["build/unix/print-failed-commands.sh", "config/rules.mk"], "git_node": null, "git_parents": [null], "node": "6249480cfc319a863f2bf954d67ef40e26d4158d", "parents": ["15ee689ef0fc7022bd205e833b130430a61d8895"], "tags": []}], "date": 1561539839, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "jcristau@mozilla.com"}, "11499": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nde -\u003e 48f9aa837852\nfr -\u003e cbb307cd8871\nfy-NL -\u003e 147aad05c3c2\nta -\u003e 6244d1aa6dbf", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "b6fce56b180b3a8f106025c9c3df6dd58b49814c", "parents": ["6249480cfc319a863f2bf954d67ef40e26d4158d"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nde -\u003e 48f9aa837852\nfr -\u003e cbb307cd8871\nfy-NL -\u003e 147aad05c3c2\nta -\u003e 6244d1aa6dbf", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "a37c82a84d84a740b6f02f829604b64a7f7bbf8f", "parents": ["b6fce56b180b3a8f106025c9c3df6dd58b49814c"], "tags": []}], "date": 1561546826, "git_changesets": [null, null], "user": "ffxbld"}, "11500": {"changesets": [{"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1555051 - Use GeckoJarReader to read the theme image; r=VladBaicu, a=jcristau\n\nIf the theme is persisted as an xpi we'll use GeckoJarReader to read get the\nimage from inside the archive otherwise read it directly.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35808", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/util/BitmapUtils.java"], "git_node": null, "git_parents": [null], "node": "2638b73811db33a1360300fa5b501fc8b5c84297", "parents": ["a37c82a84d84a740b6f02f829604b64a7f7bbf8f"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1556083 - Resolve deadlock by using just one lock, not two; r=VladBaicu, a=jcristau\n\nClassic deadlock situation possible because getDatabaseHelperForProfile(..)\nwould lock on [PerProfileDatabase] and then try to on [GeckoProfile] while at\nthe same time it would be possible for another thread which already had the\n[GeckoProfile] lock to call this method and so try to acquire the\n[PerProfileDatabase] lock.\n\nThe simplest solution to resolve this and the one I went with is to ensure that\none of those threads will not need both locks and it turns out that the\ngetDatabaseHelperForProfile method can easily be refactored to use only the\nGeckoProfile lock, change which would not significantly increase the block of\ncode synchronized with the same key.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35646", "files": ["mobile/android/base/java/org/mozilla/gecko/db/PerProfileDatabases.java"], "git_node": null, "git_parents": [null], "node": "186a6085f0bc20970bf9ded561a2844b1d176ab1", "parents": ["2638b73811db33a1360300fa5b501fc8b5c84297"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1557792 - Show missing private browsing rows in about:addons. r=mixedpuppy,mstriemer, a=jcristau\n\nFor parity with the XUL about:addons page, this commit adds missing rows\nto the details view:\n\n- Bug 1557792 - incognito not_allowed should show \"Not Allowed in Private Windows\"\n\n- Bug 1551947 - extensions with locked private browsing flag should not\n  show inputs to control the flag, but \"Requires Access to Private Windows\"\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34936", "files": ["toolkit/mozapps/extensions/content/aboutaddons.html", "toolkit/mozapps/extensions/content/aboutaddons.js", "toolkit/mozapps/extensions/test/browser/browser_webext_incognito.js"], "git_node": null, "git_parents": [null], "node": "1c3f96c23a841c7a6e368d73b9ee5b9573d943a3", "parents": ["186a6085f0bc20970bf9ded561a2844b1d176ab1"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1551515 - Fix Library button focused/unfocused when clicking on a abuse report panel's radio button. r=mstriemer, a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31600", "files": ["toolkit/mozapps/extensions/content/abuse-report-frame.html", "toolkit/mozapps/extensions/content/abuse-report-frame.js", "toolkit/mozapps/extensions/content/abuse-report-panel.js"], "git_node": null, "git_parents": [null], "node": "2b7fc852c4c72321cebc915201b419ffc388bdd9", "parents": ["1c3f96c23a841c7a6e368d73b9ee5b9573d943a3"], "tags": []}], "date": 1561551478, "git_changesets": [null, null, null, null], "user": "jcristau@mozilla.com"}, "11501": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nid -\u003e c49c41d03e8c", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "565911b99d854c1cc735862ea14c99f829d5b907", "parents": ["2b7fc852c4c72321cebc915201b419ffc388bdd9"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nid -\u003e c49c41d03e8c"