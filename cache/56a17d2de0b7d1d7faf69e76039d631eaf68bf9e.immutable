zbuild/mozpack/test/test_packager.py", "python/mozbuild/mozpack/test/test_packager_formats.py", "python/mozbuild/mozpack/test/test_packager_l10n.py", "python/mozbuild/mozpack/test/test_packager_unpack.py", "python/mozbuild/mozpack/test/test_path.py"], "git_node": null, "git_parents": [null], "node": "5f3c10562df335827c80fd866a1eba8f256540d2", "parents": ["70fbe1a158ae2cc7a6730ba47a04b426ab803f0a"], "tags": []}, {"author": "Justin Wood \u003cCallek@gmail.com\u003e", "branch": "default", "desc": "Bug 1547730 - Add six to path when running configure. r=#build\n\nThis is necessary for any attempt at @import('six') or doing any similar py2+py3 work\nin the configure sandbox.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D29604", "files": ["configure.py"], "git_node": null, "git_parents": [null], "node": "b4e024474194a21d9ade565abfd8340e93aed07c", "parents": ["5f3c10562df335827c80fd866a1eba8f256540d2"], "tags": []}, {"author": "Justin Wood \u003cCallek@gmail.com\u003e", "branch": "default", "desc": "Bug 1547730 - Do dict.iteritems() via six to support py3. r=#build\n\nshellutil.py needed special handling since it is invoked earlier than the\nvendor directory adding we do, so it does not have six available.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D28096", "files": ["python/mozbuild/mozbuild/configure/__init__.py", "python/mozbuild/mozbuild/configure/options.py", "python/mozbuild/mozbuild/preprocessor.py", "python/mozbuild/mozbuild/shellutil.py", "python/mozbuild/mozbuild/util.py", "python/mozbuild/mozpack/chrome/flags.py", "python/mozbuild/mozpack/copier.py", "python/mozbuild/mozpack/files.py", "python/mozbuild/mozpack/mozjar.py", "python/mozbuild/mozpack/packager/__init__.py", "python/mozbuild/mozpack/packager/l10n.py", "python/mozbuild/mozpack/test/test_copier.py", "python/mozbuild/mozpack/test/test_packager_formats.py", "python/mozbuild/mozpack/test/test_packager_l10n.py"], "git_node": null, "git_parents": [null], "node": 