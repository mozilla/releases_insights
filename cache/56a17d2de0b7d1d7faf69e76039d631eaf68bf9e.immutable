-issue/test/browser/webcompat.html", "mobile/android/extensions/report-site-issue/background.js"], "git_node": null, "git_parents": [null], "node": "87f1246a1c3dbac25673d8b84ca55ec70932b5b8", "parents": ["ac99437a9c7a2b334e8201098170b7766c10bd13"], "tags": []}], "date": 1560987390, "git_changesets": [null, null, null, null, null, null, null], "user": "jcristau@mozilla.com"}, "11476": {"changesets": [{"author": "sotaro \u003csotaro.ikeda.g@gmail.com\u003e", "branch": "default", "desc": "Bug 1547760 - Ensuring UiCompositorControllerChild::mWidget alive when it is used. r=kats, a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35166", "files": ["gfx/layers/ipc/UiCompositorControllerChild.cpp", "gfx/layers/ipc/UiCompositorControllerChild.h"], "git_node": null, "git_parents": [null], "node": "01f0e8d1402c59cd01a65ae644f380081d8a0b36", "parents": ["87f1246a1c3dbac25673d8b84ca55ec70932b5b8"], "tags": []}, {"author": "sotaro \u003csotaro.ikeda.g@gmail.com\u003e", "branch": "default", "desc": "Bug 1559859 - Always release mWidget in UiCompositorControllerChild::Destroy(). r=kats, a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35210", "files": ["gfx/layers/ipc/UiCompositorControllerChild.cpp"], "git_node": null, "git_parents": [null], "node": "c5a64922e1a1ed68fb97489e86bda6f48b695288", "parents": ["01f0e8d1402c59cd01a65ae644f380081d8a0b36"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1552280 - Update default 68+ about:welcome experience including cards for return-to-AMO. r=k88hudson, a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35287", "files": ["browser/app/profile/firefox.js", "browser/components/newtab/lib/ASRouter.jsm"], "git_node": null, "git_parents": [null], "node": "492b330e047c1d1e502a9267e27068c15c3cbbef", "parents": ["c5a64922e1a1ed68fb97489e86bda6f48b695288"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1554843 - Make PuppetWidget::NotifyIMEOfFocusChange() notify TextEventDispatcher of IME notification requests change. r=m_kato, a=jcristau\n\nWhen user moves focus to an editable content in a content process, it posts\nIME-focus notification to the main process. Then, when the main process\nprepares IME/keyboard handling in editable content, it posts back IME\nnotification requests to the content process. Then, the content process's\n`PuppetWidget` modifies its IME notification requests, but **not** modifying\ncache of IME notification requests in its `TextEventDispatcher`. Therefore,\n`IMEContentObserver` keep referring older IME notification requests which are\ninitialized without IME-focus.  Note that `IMEContentObserver` caches the\n*reference* of cached IME notification requests in `TextEventDispatcher`.\nSo, we need to refresh only the cache of IME notification requests in\n`TextEventDispatcher`.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32821", "files": ["widget/PuppetWidget.cpp", "widget/TextEventDispatcher.h"], "git_node": null, "git_parents": [null], "node": "8165ade66edf77295dd97e5e2f7a69532bab2bcf", "parents": ["492b330e047c1d1e502a9267e27068c15c3cbbef"], "tags": []}, {"author": "Henri Sivonen \u003chsivonen@hsivonen.fi\u003e", "branch": "default", "desc": "Bug 1549930 - Avoid popping BrowserParent in response to window lowering. r=masayuki, a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30873", "files": ["dom/base/nsFocusManager.cpp", "dom/base/nsFrameLoader.cpp", "dom/ipc/BrowserBridgeChild.cpp", "dom/ipc/BrowserBridgeChild.h", "dom/ipc/BrowserBridgeParent.cpp", "dom/ipc/BrowserBridgeParent.h", "dom/ipc/BrowserParent.cpp", "dom/ipc/BrowserParent.h", "dom/ipc/PBrowserBridge.ipdl"], "git_node": null, "git_parents": [null], "node": "382204429011c89910e360eb3f889b371c020cd5", "parents": ["8165ade66edf77295dd97e5e2f7a69532bab2bcf"], "tags": []}, {"author": "Henri Sivonen \u003chsivonen@hsivonen.fi\u003e", "branch": "default", "desc": "Bug 1549930 addendum - Notify widgets of IME blur on quit (on non-Android). r=masayuki, a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34992", "files": ["dom/events/IMEStateManager.cpp", "dom/events/IMEStateManager.h", "widget/nsBaseWidget.cpp", "widget/nsBaseWidget.h"], "git_node": null, "git_parents": [null], "node": "f0a9bc62b3840bb3da69b86c6e8e6751289053f3", "parents": ["382204429011c89910e360eb3f889b371c020cd5"], "tags": []}, {"author": "Henri Sivonen \u003chsivonen@hsivonen.fi\u003e", "branch": "default", "desc": "Bug 1549930 test adjustment - Disable browser_privatebrowsing_about.js due to perma-orange. r=r1cky, a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34993", "files": ["browser/components/privatebrowsing/test/browser/browser.ini"], "git_node": null, "git_parents": [null], "node": "046390a25abdb3ebf0acc861e543a85b4359637c", "parents": ["f0a9bc62b3840bb3da69b86c6e8e6751289053f3"], "tags": ["DEVEDITION_68_0b12_BUILD1", "DEVEDITION_68_0b12_RELEASE", "FIREFOX_68_0b12_BUILD1", "FIREFOX_68_0b12_RELEASE"]}], "date": 1560988050, "git_changesets": [null, null, null, null, null, null, null], "user": "jcristau@mozilla.com"}, "11477": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 046390a25abdb3ebf0acc861e543a85b4359637c with DEVEDITION_68_0b12_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "734b19780bfe29a929a8e07c084be82b511de9a6", "parents": ["046390a25abdb3ebf0acc861e543a85b4359637c"], "tags": []}], "date": 1560992622, "git_changesets": [null], "user": "ffxbld"}, "11478": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 046390a25abdb3ebf0acc861e543a85b4