, "parents": ["8c05f190b30533cb587af38bcf382bac5e0cf36e"], "tags": []}], "date": 1559919628, "git_changesets": [null, null], "user": "ffxbld"}, "11397": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging b25d2ea5cf47fc4e0c01214acad7c30162b1b1d8 with DEVEDITION_68_0b8_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "d73b8b5065579c511e79a1b17408aafc9a8c190e", "parents": ["b898a92874bbf9e924a368dea7ff5c8d28bf5b46"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release DONTBUILD", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "c418c00f28210106335aa36a222092b0b0607a0a", "parents": ["d73b8b5065579c511e79a1b17408aafc9a8c190e"], "tags": []}], "date": 1559927138, "git_changesets": [null, null], "user": "ffxbld"}, "11398": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging b25d2ea5cf47fc4e0c01214acad7c30162b1b1d8 with FIREFOX_68_0b8_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "96a837ab06b6477ca3a7fc4fd3ec7bc95aa5d9da", "parents": ["c418c00f28210106335aa36a222092b0b0607a0a"], "tags": []}], "date": 1559927325, "git_changesets": [null], "user": "ffxbld"}, "11399": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nvi -\u003e a5eb2b5346e9", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "67638379e313bd9ab0b9f396fb08880c74928f66", "parents": ["96a837ab06b6477ca3a7fc4fd3ec7bc95aa5d9da"], "tags": []}], "date": 1559930426, "git_changesets": [null], "user": "ffxbld"}, "11400": {"changesets": [{"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1551183: Part 1 - Add SCOPE_APPLICATION to enabledScopes for Fennec. r=aswan a=jcristau\n\nThis scope now controls add-ons bundled in omni.ja as well as those in the app\ndirectory, so we need to enable it on Fennec in order for the default theme to\nwork.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32223", "files": ["mobile/android/app/mobile.js", "mobile/android/chrome/content/browser.js"], "git_node": null, "git_parents": [null], "node": "9b79e08b7ac02dd5c6dd703e64942d09829efc69", "parents": ["67638379e313bd9ab0b9f396fb08880c74928f66"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1551183: Part 2 - Support enumerating directories in extensions in nested JARs. r=aswan a=jcristau\n\nOn Android, omni.ja is bundled inside an API, and therefore loaded as a nested\nJAR. That means that its resource URIs resolve to something resembling\n\"jar:jar:...!/omni.ja!/...\". Our current enumeration code assumes no nesting\nof jar: URIs, and therefore can't handle this.\n\nThis patch changes our enumeration helpers to accept URIs rather than nsIFile\ninstances, and to correctly handle resolving the ZipReaders for those nested\nJARs. It also moves the path filter generation into the native helper to make\nthings easier for other callers which may need this behavior.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32224", "files": ["toolkit/components/extensions/Extension.jsm", "toolkit/mozapps/extensions/AddonManagerStartup.cpp", "toolkit/mozapps/extensions/amIAddonManagerStartup.idl"], "git_node": null, "git_parents": [null], "node": "1118e4a2eb8b0e64e0dd11ca223e411e684540f8", "parents": ["9b79e08b7ac02dd5c6dd703e64942d09829efc69"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1551183: Part 3 - Add a test to sanity check the default theme on all platforms. r=aswan a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32225", "files": ["toolkit/mozapps/extensions/internal/XPIDatabase.jsm", "toolkit/mozapps/extensions/test/mochitest/chrome.ini", "toolkit/mozapps/extensions/test/mochitest/test_default_theme.html", "toolkit/mozapps/extensions/test/moz.build"], "git_node": null, "git_parents": [null], "node": "09624608fc97fc4b52a317f965a75aebf29073c9", "parents": ["1118e4a2eb8b0e64e0dd11ca223e411e684540f8"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1551183: Follow-up: Disable app-scoped add-ons in cert_storage test. r=me a=test-only", "files": ["security/manager/ssl/tests/unit/test_cert_storage.js"], "git_node": null, "git_parents": [null], "node": "49a329216f65a28acdcaa77729030d7b22fadfb5", "parents": ["09624608fc97fc4b52a317f965a75aebf29073c9"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1555389: Expect default theme to be inactive on dev edition. r=aswan a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33056", "files": ["toolkit/mozapps/extensions/test/mochitest/test_default_theme.html"], "git_node": null, "git_parents": [null], "node": "5126c82f6b389f2c33b21188a9574585c20afba7", "parents": ["49a329216f65a28acdcaa77729030d7b22fadfb5"], "tags": []}], "date": 1559930647, "git_changesets": [null, null, null, null, null], "user": "maglione.k@gmail.com"}, "11401": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nbs -\u003e 10ca6ba59b87\nen-CA -\u003e 20442e4d57f8\neo -\u003e 8615e046a2f5\nes-AR -\u003e 036094fdd3b5\ngn -\u003e 0e0e587f0eac\nnn-NO -\u003e d487d8d95e6c