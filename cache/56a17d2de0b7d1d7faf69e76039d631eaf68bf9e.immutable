/client/netmonitor/src/components/RequestListContent.js", "devtools/client/netmonitor/src/widgets/RequestListContextMenu.js"], "git_node": null, "git_parents": [null], "node": "f6b2a8d526cdeff38133e8048d3d9a8796d46080", "parents": ["e8341f537323e62da5a165e1fd914367ff0576ec"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1539366 - Use SetCoord to restore mPIStartBorderData's coord so that it also set mValid. r=mats a=jcristau\n\nWithout this the restore doesn't have any effect as the next frame sees that coord has mIsValid=false\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26648", "files": ["layout/painting/nsCSSRendering.cpp"], "git_node": null, "git_parents": [null], "node": "d2388f832a7d352a8e97b1474518521b1e3c6523", "parents": ["f6b2a8d526cdeff38133e8048d3d9a8796d46080"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1539366 - Use a temporary object to compute the mPIStartBorderData coords so that we don't clobber the regular state. r=mats a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26649", "files": ["layout/painting/nsCSSRendering.cpp"], "git_node": null, "git_parents": [null], "node": "43f54f4b1e2aa7cc51a8dc003951672f12bcc89e", "parents": ["d2388f832a7d352a8e97b1474518521b1e3c6523"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1539366 - Avoid calling AreOnSameLine once we know we've already changed lines since it can be expensive to compute. r=mats a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26650", "files": ["layout/painting/nsCSSRendering.cpp"], "git_node": null, "git_parents": [null], "node": "17b33cebec207345fbd4408eee75f8b6af239c42", "parents": ["43f54f4b1e2aa7cc51a8dc003951672f12bcc89e"], "tags": []}, {"author": "Tomislav Jovanovic \u003ctomica@gmail.com\u003e", "branch": "default"