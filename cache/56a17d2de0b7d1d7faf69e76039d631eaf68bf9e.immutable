-SE -\u003e 1a76076bea04\nth -\u003e 031dec2e2ae2\nuk -\u003e 8cce8571c192\nzh-CN -\u003e 05aef21e1032", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "e05e7980cd03fb7465c4092e22cb8a286616aafa", "parents": ["d92988e2d2b616d7948bb86a49f6f31e1c93d7cf"], "tags": []}], "date": 1560150091, "git_changesets": [null, null], "user": "ffxbld"}, "11406": {"changesets": [{"author": "Nick Thomas \u003cnthomas@mozilla.com\u003e", "branch": "default", "desc": "Bug 1557461 - limit locales for partner/EME-free repacks to overlap of requested and enabled locales, r=sfraser, a=release\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34304", "files": ["taskcluster/ci/release-eme-free-repack/kind.yml", "taskcluster/ci/release-partner-repack/kind.yml", "taskcluster/taskgraph/transforms/partner_repack.py"], "git_node": null, "git_parents": [null], "node": "039662b2b76c2d7c0ae4ca537d4501a107c4b2f7", "parents": ["e05e7980cd03fb7465c4092e22cb8a286616aafa"], "tags": []}], "date": 1560162416, "git_changesets": [null], "user": "nthomas@mozilla.com"}, "11407": {"changesets": [{"author": "Kestrel \u003cke5trel@protonmail.com\u003e", "branch": "default", "desc": "Bug 1539379 - Ensure light/dark theme uses correct tab text color for Windows 7 classic theme r=dao a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32673", "files": ["browser/themes/windows/compacttheme.css"], "git_node": null, "git_parents": [null], "node": "46f0e514450cd34e77ecb0c337cda47305a6273e", "parents": ["039662b2b76c2d7c0ae4ca537d4501a107c4b2f7"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1532724 - Part 1: Inline options browser for HTML about:addons details r=rpl,kmag a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D29787", "files": ["dom/base/nsFrameLoader.cpp", "modules/libpref/init/all.js", "toolkit/mozapps/extensions/content/aboutaddons.css", "toolkit/mozapps/extensions/content/aboutaddons.html", "toolkit/mozapps/extensions/content/aboutaddons.js", "toolkit/mozapps/extensions/content/aboutaddonsCommon.js", "toolkit/mozapps/extensions/content/extensions.js", "toolkit/mozapps/extensions/test/browser/browser.ini", "toolkit/mozapps/extensions/test/browser/browser_html_options_ui.js"], "git_node": null, "git_parents": [null], "node": "341cf2990acb03ec601d64db134bcf3243961cd4", "parents": ["46f0e514450cd34e77ecb0c337cda47305a6273e"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1532724 - Part 2: Handle HTML about:addons options page in APIs r=kmag a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30731", "files": ["browser/components/extensions/parent/ext-browser.js", "browser/components/extensions/test/browser/browser_ext_runtime_openOptionsPage.js", "toolkit/components/extensions/ExtensionParent.jsm"], "git_node": null, "git_parents": [null], "node": "ec06ba3131eeb34a1c9a8e7753ebcbb389e28879", "parents": ["341cf2990acb03ec601d64db134bcf3243961cd4"], "tags": []}, {"author": "Magnus Melin \u003cmkmelin+mozilla@iki.fi\u003e", "branch": "default", "desc": "Bug 1557286 - should preventDefault the event after showing an input field contextmenu to avoid other context menus showing. r=Gijs a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33935", "files": ["toolkit/content/editMenuOverlay.js", "toolkit/content/tests/chrome/file_edit_contextmenu.xul", "toolkit/content/tests/chrome/test_edit_contextmenu.html"], "git_node": null, "git_parents": [null], "node": "0b36ffd23e0d21c4d681f418d240e18f646b13de", "parents": ["ec06ba3131eeb34a1c9a8e7753ebcbb389e28879"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1557229 - Add `-d16` as a target_feature along `+neon` for rust code. r=nalexander a=jcristau\n\nWhen enabling neon (--with-fpu=neon, or when the C++ compiler defaults\nto use neon), we pass +neon as a target feature to the rust compiler.\nThat enables neon in rust, which is the default with the\nthumbv7neon-linux-gnueabihf rust target, but not the default for the\narmv7-unknown-linux-gnueabihf rust target.\n\nARM processors may have various different FPUs, with different number of\nregisters. On ARMv7, there are FPUs with 16 registers and FPUs with 32\nregisters. NEON requires 32 registers.\n\nBecause the common denominator for ARMv7 is 16 registers, the\narmv7-unknown-linux-gnueabihf rust target defaults to 16 registers,\nalthough by enabling neon, we're guaranteed the processor will have 32.\n\nBut while the rust compiler keeps limited to 16 registers, it also hits\na wall while compiling the hyper crate, where it finds it doesn't have\nenough registers (which in itself can be considered a bug).\n\nSince enabling neon means there are 32 registers available, it makes\nsense to tell the compiler to lift the restricted use of FPU registers,\nand that's what the `-d16` target feature does.\n\nThat's the default for the thumbv7neon-linux-gnueabihf rust target, so\nnothing is changed, there, and fixes things for the\narmv7-unknown-linux-gnueabihf rust target.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33907", "files": ["config/makefiles/rust.mk"], "git_node": null, "git_parents": [null], "node": "08677012f38a518182681e55151f31706c018449", "parents": ["0b36ffd23e0d21c4d681f418d240e18f646b13de"], "tags": []}, {"author": "Dzmitry Malyshau \u003cdmalyshau@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554502 - Configurable lookback count r=gw a=jcristau\n\nWe've had a constant of 10 hard-coded there since early days.\nTurning it into a configurable number allows us to easier tune it and\ndebug related issues.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32761", "files": ["gfx/wr/webrender/src/batch.rs", "gfx/wr/webrender/src/frame_builder.rs", "gfx/wr/webrender/src/renderer.rs", "gfx/wr/webrender/src/tiling.rs"], "git_node": null, "git_parents": [null], "node": "4ab0defb9012f8377cc29b5ee6da821699f2d16f", "parents": ["08677012f38a518182681e55151f31706c018449"], "tags": []}, {"author": "Dzmitry Malyshau \u003cdmalyshau@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554502 - Track the reference frame of batched bounding boxes and enforce it in WR r=gw a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33343", "files": ["gfx/wr/webrender/src/batch.rs", "gfx/wr/webrender/src/clip.rs", "gfx/wr/webrender/src/frame_builder.rs", "gfx/wr/webrender/src/picture.rs", "gfx/wr/webrender/src/render_task.rs", "gfx/wr/webrender/src/tiling.rs"], "git_node": null, "git_parents": [null], "node": "e4b071df2c1c3359916ca49ad964817ec9e724ff", "parents": ["4ab0defb9012f8377cc29b5ee6da821699f2d16f"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1523162 - Remove WebRtc_GetCPUFeaturesARM from cpu_features.cc; r=glandium a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33484", "files": ["media/webrtc/trunk/webrtc/system_wrappers/source/cpu_features.cc"], "git_node": null, "git_parents": [null], "node": "83a7e2cc78fd964f6cc6562ed31cb879a23735db", "parents": ["e4b071df2c1c3359916ca49ad964817ec9e724ff"], "tags": []}, {"author": "Masatoshi Kimura \u003cVYV03354@nifty.ne.jp\u003e", "branch": "default", "desc": "Bug 1501277 - Don't remove non-placeholder if placeholder is expected. r=mak a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33162", "files": ["toolkit/components/downloads/DownloadCore.jsm", "toolkit/components/downloads/test/unit/common_test_Download.js"], "git_node": null, "git_parents": [null], "node": "aeea3bdffd87f9523a02250383d5a8366e781e44", "parents": ["83a7e2cc78fd964f6cc6562ed31cb879a23735db"], "tags": []}, {"author": "Gian-Carlo Pascutto \u003cgcp@mozilla.com\u003e", "branch": "default", "desc": "Bug 1555589  - Include sys/prctl.h not linux/prctl.h. r=jld a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33517", "files": ["security/sandbox/linux/SandboxFilter.cpp"], "git_node": null, "git_parents": [null], "node": "121bb815438386f3f7b31a39da9aa3f29bc96f18", "parents": ["aeea3bdffd87f9523a02250383d5a8366e781e44"], "tags": []}], "date": 1560169838, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "opoprus@mozilla.com"}, "11408": {"changesets": [{"author": "Oana Pop Rus \u003copoprus@mozilla.com\u003e", "branch": "default", "desc": "Backed out 2 changesets (bug 1554502) for causing build bustages. a=backout\n\nBacked out changeset e4b071df2c1c (bug 1554502)\nBacked out changeset 4ab0defb9012 (bug 1554502)", "files": ["gfx/wr/webrender/src/batch.rs", "gfx/wr/webrender/src/clip.rs", "gfx/wr/webrender/src/frame_builder.rs", "gfx/wr/webrender/src/picture.rs", "gfx/wr/webrender/src/render_task.rs", "gfx/wr/webrender/src/renderer.rs", "gfx/wr/webrender/src/tiling.rs"], "git_node": null, "git_parents": [null], "node": "73ae511ea89559d9c1b848a8d27cfe1fb6b2e034", "parents": ["121bb815438386f3f7b31a39da9aa3f29bc96f18"], "tags": []}], "date": 1560171592, "git_changesets": [null], "user": "opoprus@mozilla.com"}, "11409": {"changesets": [{"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1549548 - update browser tests for plugin blocking, r=mconley a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31346", "files": ["browser/base/content/test/plugins/blockNoPlugins-plugins.json", "browser/base/content/test/plugins/blockPluginHard-plugins.json", "browser/base/content/test/plugins/blockPluginInfoURL-plugins.json", "browser/base/content/test/plugins/blockPluginVulnerableNoUpdate-plugins.json", "browser/base/content/test/plugins/blockPluginVulnerableUpdatable-plugins.json", "browser/base/content/test/plugins/browser-rs-blocklist.ini", "browser/base/content/test/plugins/browser.ini", "browser/base/content/test/plugins/browser_blocking.js", "browser/base/content/test/plugins/browser_blocklist_content.js", "browser/base/content/test/plugins/browser_bug743421.js", "browser/base/content/test/plugins/browser_bug812562.js", "browser/base/content/test/plugins/browser_plugin_reloading.js", "browser/base/content/test/plugins/browser_pluginnotification.js", "browser/base/content/test/plugins/head.js", "browser/base/content/test/plugins/plugin_clickToPlayAllow.html", "browser/base/content/test/plugins/plugin_clickToPlayDeny.html", "browser/base/content/test/plugins/plugin_test3.html", "browser/base/moz.build", "dom/base/test/chrome/blockNoPlugins.xml", "dom/base/test/chrome/blockPluginHard.xml", "dom/base/test/chrome/chrome.ini", "toolkit/mozapps/extensions/test/browser/browser_CTP_plugins.js"], "git_node": null, "git_parents": [null], "node": "7619b650e72a615fd8681df1d6d945070f547cd2", "parents": ["73ae511ea89559d9c1b848a8d27cfe1fb6b2e034"], "tags": []}, {"author": "Alessio Placitelli \u003calessio.placitelli@gmail.com\u003e", "branch": "default", "desc": "Bug 1547331 - Don't initialize legacy telemetry in GeckoView. r=chutten,kmag a=jcristau\n\nThis changes the registration code so that categories are\nstill registered in the manifest (and thus not registered\nin GeckoView), but the component is still always shipped.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33478", "files": ["browser/installer/package-manifest.in", "mobile/android/installer/package-manifest.in", "toolkit/components/telemetry/TelemetryStartup.manifest", "toolkit/components/telemetry/components.conf", "toolkit/components/telemetry/moz.build"], "git_node": null, "git_parents": [null], "node": "39f91a7407ab3b54d714b2385f9e81c5e9a21c82", "parents": ["7619b650e72a615fd8681df1d6d945070f547cd2"], "tags": []}, {"author": "Bryce Van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1552717 - P1: Refactor test_eme_pssh_in_moof mochitest so it's easier to add further test media. r=cpearce a=jcristau\n\ntest_eme_pssh_in_moof tests if our key rotation works correctly. It currently\ndoes so by using a single video with an audio and video track. This patch\nrefactors the test so that it does the same thing (all going well), but in a\nmore extensible way.\n\nThe changes in this patch seek to lean more heavily on test harness\nfunctionality in manifest.js and eme.js where possible. This cuts down on some\nboilerplate, but means we have to make some concessions in a more verbose\nexpression of our test media list so the eme.js functions work with it.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32750", "files": ["dom/media/test/test_eme_pssh_in_moof.html"], "git_node": null, "git_parents": [null], "node": "a6f7233484a044e74ebb6ddef80ea03957d689f4", "parents": ["39f91a7407ab3b54d714b2385f9e81c5e9a21c82"], "tags": []}, {"author": "Bryce Van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1552717 - P2: Add test media for key rotation with a clear lead. r=cpearce a=jcristau\n\nAdd another test case for the mp4 key rotation (pssh in fragments) test. In this\ncase, the test file has a clear (unencrypted) lead. This test seeks to ensure we\ndon't regress surfacing of init info even if we encounter it for fragments that\nstart with unencrypted samples.\n\nAdd a further check to the key rotation test to ensure that the initDataType is\nbeing surfaced correctly on the encrypted event.\n\nMedia files created with shaka packager via:\n```\npackager-win.exe\nin=bipbop.mp4,stream=audio,out=bipbop-clearkey-keyrotation-clear-lead-audio.mp4\nin=bipbop.mp4,stream=video,out=bipbop-clearkey-keyrotation-clear-lead-video.mp4\n--enable_raw_key_encryption --keys\nlabel=:key_id=00112233445566778899AABBCCDDEEFF:key=00112233445566778899AABBCCDDEEFF\n--crypto_period_duration 5 --fragment_duration 5 --clear_lead 3\n```\n\nNote that the way shaka packager handles key rotation in this case is just to\nleft shift the key id and the key. In this case, where crypto_period_duration ==\nfragment_duration, a left shift of 1 will take place each time the keys rotate.\nThis happens once in the test file leaving us with 2 key ids + keys.\n\nDepends on D32750\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32751", "files": ["dom/media/test/bipbop-clearkey-keyrotation-clear-lead-audio.mp4", "dom/media/test/bipbop-clearkey-keyrotation-clear-lead-audio.mp4^headers^", "dom/media/test/bipbop-clearkey-keyrotation-clear-lead-video.mp4", "dom/media/test/bipbop-clearkey-keyrotation-clear-lead-video.mp4^headers^", "dom/media/test/mochitest.ini", "dom/media/test/test_eme_pssh_in_moof.html"], "git_node": null, "git_parents": [null], "node": "4bf11a9d5633083a474caba9e0c5353f3a078882", "parents": ["a6f7233484a044e74ebb6ddef80ea03957d689f4"], "tags": []}, {"author": "Bryce Van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1552717 - P3: Set mInitDataType on sample info regardless of if the sample is encrypted. r=cpearce a=jcristau\n\nUnencrypted samples can carry init data and thus we should set the init data\ntype regardless of if the sample itself is encrypted (otherwise the init data\ninfo is incomplete for unencrypted samples).\n\nDepends on D32751\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32752", "files": ["dom/media/mp4/Index.cpp"], "git_node": null, "git_parents": [null], "node": "9f479818871fec638fc21e91ad10a946e4769bfd", "parents": ["4bf11a9d5633083a474caba9e0c5353f3a078882"], "tags": []}, {"author": "Dylan Roeh \u003cdroeh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1555447 - Throw exceptions rather than returning 0 from GeckoProcessManager.java r=rbarker a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33705", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/process/GeckoProcessManager.java"], "git_node": null, "git_parents": [null], "node": "6ae0224335ee46e0427743b6424b9df97ba6c31e", "parents": ["9f479818871fec638fc21e91ad10a946e4769bfd"], "tags": []}, {"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1539835 - Flip pref on for LSNG for (non-early) Beta and Release; r=asuth a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33989", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "504624a04c7641044d0c8edc4c3e66ed7e4e4fab", "parents": ["6ae0224335ee46e0427743b6424b9df97ba6c31e"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1553650 - AddonList onUninstalling handler should check the addon type and pending operations. r=mstriemer,robwu\n a=jcristau\nDifferential Revision: https://phabricator.services.mozilla.com/D32369", "files": ["toolkit/mozapps/extensions/content/aboutaddons.js", "toolkit/mozapps/extensions/test/browser/browser_html_list_view.js"], "git_node": null, "git_parents": [null], "node": "59eee64bf66de9d38de28e93a132e8b3f07d349e", "parents": ["504624a04c7641044d0c8edc4c3e66ed7e4e4fab"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1555645 - Make PresShell::EventHandler::MaybeFlushThrottledStyles() stop handling it when the PresShell does not have root PreShell nor Document r=smaug a=jcristau\n\nThe crash reports just tell us that the crash occur due to referring around\naddress 0 in `PresShell::EventHandler::MaybeFlushThrottledStyles()`.\nTherefore, I'm not sure which is the actual reason of the crashes though,\nthis patch makes it null-check root `PresShell` and its `Document` before\naccessing the latter.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33735", "files": ["layout/base/PresShell.cpp"], "git_node": null, "git_parents": [null], "node": "16500a22225b64acab9dc01c328cb5927883d5b9", "parents": ["59eee64bf66de9d38de28e93a132e8b3f07d349e"], "tags": []}, {"author": "Vlad Baicu \u003cvlad.baicu@softvision.ro\u003e", "branch": "default", "desc": "Bug 1556383 - Mobile activation ping documentation.r=petru a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33775", "files": ["toolkit/components/telemetry/docs/data/activation-ping.rst"], "git_node": null, "git_parents": [null], "node": "6197f444f018e47e09a0ecc566dbf26b1f771363", "parents": ["16500a22225b64acab9dc01c328cb5927883d5b9"], "tags": []}], "date": 1560176626, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "rmaries@mozilla.com"}, "11410": {"changesets": [{"author": "Julien Cristau \u003cjcristau@mozilla.com\u003e", "branch": "default", "desc": "No bug - Unset EARLY_BETA_OR_EARLIER. a=me", "files": ["build/defines.sh"], "git_node": null, "git_parents": [null], "node": "98cc1b12c5a749f5d210f92372bc9270575e57df", "parents": ["6197f444f018e47e09a0ecc566dbf26b1f771363"], "tags": []}, {"author": "Dzmitry Malyshau \u003cdmalyshau@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554502 - Track the reference frame of batched bounding boxes and enforce it in WR r=gw a=jcristau\n\nCombined patch to apply on 68\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32761\nDifferential Revision: https://phabricator.services.mozilla.com/D33343", "files": ["gfx/wr/webrender/src/batch.rs", "gfx/wr/webrender/src/clip.rs", "gfx/wr/webrender/src/frame_builder.rs", "gfx/wr/webrender/src/picture.rs", "gfx/wr/webrender/src/render_task.rs", "gfx/wr/webrender/src/renderer.rs", "gfx/wr/webrender/src/tiling.rs"], "git_node": null, "git_parents": [null], "node": "016c1fb63aaff9fbf32a999701d9dbefd9f30bbd", "parents": ["98cc1b12c5a749f5d210f92372bc9270575e57df"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1556726 - Ensure #userContext-label doesn't increase the height of the address bar. r=jkt, a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33941", "files": ["browser/components/contextualidentity/content/usercontext.css"], "git_node": null, "git_parents": [null], "node": "12ee297149424a925bb820705b417d28ae57ce06", "parents": ["016c1fb63aaff9fbf32a999701d9dbefd9f30bbd"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1548306 - Do not allow the ^ character to appear in the hostname. r=mayhemer, a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32895", "files": ["dom/quota/test/unit/test_originWithCaret.js", "netwerk/base/nsStandardURL.cpp"], "git_node": null, "git_parents": [null], "node": "33d0d344ea16b9219b36d922fe45549c29326e6a", "parents": ["12ee297149424a925bb820705b417d28ae57ce06"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1531338 - [Linux/Gtk] Get and use Gtk theme text color for active/pressed button, r=dao,emilio, a=jcristau\n\n- Follow Gtk and get theme button text color directly from \"button\" CSS node instead of \"button label\"\n- Provide new -moz-gtk-buttonactivetext color for active/pressed button text color\n- Replace ButtonText color with -moz-gtk-buttonactivetext when it's appropriate\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30566", "files": ["browser/themes/linux/places/organizer.css", "layout/style/res/forms.css", "servo/components/style/properties/longhands/color.mako.rs", "toolkit/themes/linux/global/button.css", "widget/LookAndFeel.h", "widget/gtk/nsLookAndFeel.cpp", "widget/gtk/nsLookAndFeel.h", "widget/nsXPLookAndFeel.cpp"], "git_node": null, "git_parents": [null], "node": "1176df94118f3b4957e4f0851995e34bbb137774", "parents": ["33d0d344ea16b9219b36d922fe45549c29326e6a"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1554433 - Move system colors to values::specified::color. r=xidorn, a=jcristau\n\nThis should be an idempotent patch. The way to come up with this patch has been:\n\n * Run the first script attached to the bug and pipe it to xclip, then paste it\n   in color.rs\n * Add the relevant #[derive] annotations and remove the color.mako.rs\n   definition.\n * Reorder the values to match the ColorID definition, on which some widget\n   prefs and caching stuff relies on.\n * Manually port some documentation from nsLookAndFeel.h\n * Run `rg 'eColorID_' | cut -d : -f 1 | sort | uniq \u003efiles`\n * Run the second script attached to the bug.\n * Manually fix usage of `LAST_COLOR` (adding the `End` variant), and adding\n   casts to integer as needed.\n * Add an static assert so that people remember to update the prefs, rather than\n   a comment on the definition :)\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32610", "files": ["layout/forms/nsListControlFrame.cpp", "layout/generic/nsFrame.cpp", "layout/generic/nsFrameSetFrame.cpp", "layout/generic/nsTextFrame.cpp", "layout/mathml/nsMathMLChar.cpp", "layout/style/PreferenceSheet.cpp", "layout/style/ServoBindings.toml", "layout/tables/nsTableCellFrame.cpp", "servo/components/style/properties/longhands/color.mako.rs", "servo/components/style/values/specified/color.rs", "servo/ports/geckolib/cbindgen.toml", "toolkit/components/browser/nsWebBrowser.cpp", "widget/LookAndFeel.h", "widget/android/nsLookAndFeel.cpp", "widget/cocoa/nsLookAndFeel.mm", "widget/gtk/IMContextWrapper.cpp", "widget/gtk/nsLookAndFeel.cpp", "widget/gtk/nsNativeThemeGTK.cpp", "widget/headless/HeadlessLookAndFeelGTK.cpp", "widget/nsXPLookAndFeel.cpp", "widget/nsXPLookAndFeel.h", "widget/uikit/nsLookAndFeel.mm", "widget/windows/nsLookAndFeel.cpp"], "git_node": null, "git_parents": [null], "node": "570065ea87fc4409718c9fd7f950863696fb8518", "parents": ["1176df94118f3b4957e4f0851995e34bbb137774"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1554433 - Hide -moz-gtk-buttonactivetext from content. r=stransky, a=jcristau\n\nThis prevents exposing the value to web content.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32611", "files": ["browser/base/content/test/static/browser_parsable_css.js", "layout/style/test/test_non_content_accessible_values.html", "servo/components/style/values/specified/color.rs"], "git_node": null, "git_parents": [null], "node": "82341a825fbc89e41510a73db6880fbc7b4dde1c", "parents": ["570065ea87fc4409718c9fd7f950863696fb8518"], "tags": []}, {"author": "Kyle Machulis \u003ckyle@nonpolynomial.com\u003e", "branch": "default", "desc": "Bug 1543804 - Don't allow cross-origin POST redirects on 308 codes; r=jmathies, a=jcristau\n\nWe already don't allow cross origin POST redirects on 307 redirects,\nthis adds extra guards to make sure we don't allow them on 308s\neither.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D28927", "files": ["dom/plugins/base/nsPluginStreamListenerPeer.cpp"], "git_node": null, "git_parents": [null], "node": "2fb5251ef5f1e4067935d3ad3f908facea2d296f", "parents": ["82341a825fbc89e41510a73db6880fbc7b4dde1c"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1544386 part 1 - Call ElementAccessHasExtraIndexedProperty instead of ArrayPrototypeHasIndexedProperty when inlining array natives. r=tcampbell, a=jcristau\n\nThis simplifies the code a bit because ElementAccessHasExtraIndexedProperty\nchecks for length-overflow and sparse-indexes so the callers don't have to\ndo that anymore.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D29486", "files": ["js/src/jit/MCallOptimize.cpp", "js/src/jit/MIR.cpp", "js/src/jit/MIR.h"], "git_node": null, "git_parents": [null], "node": "109cefe117fbdd1764097e06796960082f4fee4e", "parents": ["2fb5251ef5f1e4067935d3ad3f908facea2d296f"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1556559 - make about:license non-web-linkable again. r=valentin, a=jcristau\n\nThis ensures that links in about:license to about:rights and about:buildconfig actually work.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34136", "files": ["docshell/base/nsAboutRedirector.cpp", "toolkit/content/tests/browser/browser.ini", "toolkit/content/tests/browser/browser_license_links.js"], "git_node": null, "git_parents": [null], "node": "732bf9cb9670737b61a49011701a334e44a85d9e", "parents": ["109cefe117fbdd1764097e06796960082f4fee4e"], "tags": []}, {"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP blocklist remote-settings - a=repo-update\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34343", "files": ["browser/app/blocklist.xml", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/blocklists/addons.json", "services/settings/dumps/security-state/intermediates.json"], "git_node": null, "git_parents": [null], "node": "5024a81eed1428e346a0b727223cfc92b7410c32", "parents": ["732bf9cb9670737b61a49011701a334e44a85d9e"], "tags": []}, {"author": "diana.iacos \u003cdiana.iacos@softvision.ro\u003e", "branch": "default", "desc": "Bug 1487013 - The new folder created doesn't have any title; r=petru, a=jcristau, l10n=flod\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33786", "files": ["mobile/android/base/java/org/mozilla/gecko/bookmarks/CreateFolderFragment.java", "mobile/android/base/locales/en-US/android_strings.dtd", "mobile/android/base/strings.xml.in"], "git_node": null, "git_parents": [null], "node": "78928eb0791ef5074dab80bfeac2d96490d7267d", "parents": ["5024a81eed1428e346a0b727223cfc92b7410c32"], "tags": []}], "date": 1560179114, "git_changesets": [null, null, null, n