sha-1/src/consts.rs", "third_party/rust/sha-1/src/lib.rs", "third_party/rust/sha-1/src/utils.rs", "third_party/rust/sha-1/tests/data/one_million_a.bin", "third_party/rust/sha-1/tests/data/sha1.blb", "third_party/rust/sha-1/tests/lib.rs", "third_party/rust/ws/examples/html_chat.rs"], "git_node": null, "git_parents": [null, null], "node": "4ba247673bf95aac3619129bd4f79e999820a220", "parents": ["8df2d171f7fd925474dedb797ac46b21a135e496", "30817917ace8ef05f5badd1522f7f1adac64d1e5"], "tags": []}, {"author": "arthur.iakab \u003caiakab@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to mozilla-inbound", "files": [], "git_node": null, "git_parents": [null, null], "node": "3edc4e3973b2fb85ad78ab499115de094a8b8ceb", "parents": ["4ba247673bf95aac3619129bd4f79e999820a220", "db99095ae0b53c30927add34be3dc20a7bdcb52e"], "tags": []}, {"author": "Jonathan Watt \u003cjwatt@jwatt.org\u003e", "branch": "default", "desc": "Bug 1551333. Rename nsIPrintingPromptService methods to make them more searchable. r=bobowen\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30996", "files": ["layout/printing/nsPrintJob.cpp", "toolkit/components/browser/nsIPrintingPromptService.idl", "toolkit/components/printing/content/printUtils.js", "toolkit/components/printingui/ipc/PrintingParent.cpp", "toolkit/components/printingui/ipc/nsPrintingProxy.cpp", "toolkit/components/printingui/nsPrintingPromptService.cpp"], "git_node": null, "git_parents": [null], "node": "1327c28c7bd14cf2b4e8de9e6e33b19d7514a7f7", "parents": ["3edc4e3973b2fb85ad78ab499115de094a8b8ceb"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-inbound to mozilla-central. a=merge", "files": [], "git_node": null, "git_parents": [null, null], "node": "b0645d43f221993cd1810a50c27abbf3a34f3055", "parents": ["230016dbba05b36ecc1ccada9abdc2d5370a0ae7", "1327c28c7bd14cf2b4e8de9e6e33b19d7514a7f7"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland.", "files": [], "git_node": null, "git_parents": [null, null], "node": "2659abca52029881f180395cc0edb45b5292d25d", "parents": ["f2177d43f7d9c4953915d8cd8db019824832ea05", "b0645d43f221993cd1810a50c27abbf3a34f3055"], "tags": []}, {"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1508626 - add assertions to diagnose why the font loader is running after shutdown. r=jfkthame\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30979", "files": ["gfx/thebes/gfxFontInfoLoader.cpp"], "git_node": null, "git_parents": [null], "node": "c8fc7c4dc43c27a9c094b38de983425c1a06f43c", "parents": ["2659abca52029881f180395cc0edb45b5292d25d"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1547196 - remove rustup wrapper from `rustc` as well as `cargo`; r=glandium\n\nHaving `rustc` be `rustup`'s wrapper for `rustc` means that we may\nsilently honor `rustup`'s override mechanisms.  We noticed this first on\nOS X, where we use the \"real\" `cargo` but `rustup`'s `rustc` wrapper,\nand problems ensued when `cargo` thought it was using one version of\n`rustc`, but actually wound up using something different.\n\nIt seems better to avoid silently interposing `rustup`'s toolchain\noverride mechanisms everywhere, rather than having to special-case OS\nX.  So let's factor out a general mechanism for removing the wrappers\n`rustup` provides and use that for both `rustc` and `cargo`.  The tests\nneed adjusting because we weren't triggering the unwrapping cases\nbefore; we don't yet test the case where we really do need to unwrap.\nThat test can be left for a future patch.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D29531", "files": ["build/moz.configure/rust.configure", "python/mozbuild/mozbuild/test/configure/test_toolchain_configure.py"], "git_node": null, "git_parents": [null], "node": "c9f1a1db8fa2190a88c09eb624b321a07da6c3e1", "parents": ["c8fc7c4dc43c27a9c094b38de983425c1a06f43c"], "tags": []}, {"author": "Christoph Walcher \u003cchristoph-wa@gmx.de\u003e", "branch": "default", "desc": "Bug 1530138 - Added resend option in WebConsole r=nchevobbe,Honza\n\nAdded resend option in WebConsole\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30779", "files": ["devtools/client/locales/en-US/webconsole.properties", "devtools/client/netmonitor/src/actions/batching.js", "devtools/client/netmonitor/src/actions/requests.js", "devtools/client/netmonitor/src/api.js", "devtools/client/netmonitor/src/constants.js", "devtools/client/netmonitor/src/middleware/batching.js", "devtools/client/webconsole/components/message-types/NetworkEventMessage.js", "devtools/client/webconsole/test/fixtures/serviceContainer.js", "devtools/client/webconsole/test/mochitest/browser.ini", "devtools/client/webconsole/test/mochitest/browser_webconsole_network_messages_resend_request.js", "devtools/client/webconsole/utils/context-menu.js", "devtools/client/webconsole/webconsole-wrapper.js"], "git_node": null, "git_parents": [null], "node": "dc20a50efcf1d6343019ab8cabe882698f2823fd", "parents": ["c9f1a1db8fa2190a88c09eb624b321a07da6c3e1"], "tags": []}, {"author": "Sean Feng \u003csefeng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1531917 - Add Telemetry for how pages use bfcache r=jesup,bdekoz,smaug\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30211", "files": ["docshell/base/nsDocShell.cpp", "docshell/base/nsDocShell.h", "dom/base/Document.cpp", "dom/base/Document.h", "dom/html/PluginDocument.cpp", "toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "e80a258b4aed3eb6599967b22a12e2b6314482d2", "parents": ["dc20a50efcf1d6343019ab8cabe882698f2823fd"], "tags": []}, {"author": "Sean Feng \u003csefeng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1531917 - Add Telemetry for bfcache hit and miss r=bdekoz,smaug\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30212", "files": ["docshell/base/nsDocShell.cpp", "toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "fd66f241a8bda8a748dfe741802a4fecf7040c10", "parents": ["e80a258b4aed3eb6599967b22a12e2b6314482d2"], "tags": []}, {"author": "Tom Tung \u003cshes050117@gmail.com\u003e", "branch": "default", "desc": "Bug 1535298 - Capture and ignore the exception for not having a host from a principal URI; r=janv,johannh\n\nProtocols, likes about:, moz-extension, ... etc, don't have a host. Thus, an\nexception will be returned if they are accessed. To avoid from that, this patch\ncatches this bug a try-catch.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D29821", "files": ["toolkit/components/cleardata/ClearDataService.jsm"], "git_node": null, "git_parents": [null], "node": "9437ce7f56f17a5f38e3c64f165005845a50fc69", "parents": ["fd66f241a8bda8a748dfe741802a4fecf7040c10"], "tags": []}, {"author": "Nihanth Subramanya \u003cnhnt11@gmail.com\u003e", "branch": "default", "desc": "Bug 1551206 - Introduce new Protections Panel behind a pref. r=johannh\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30921", "files": ["browser/app/profile/firefox.js", "browser/base/content/browser-siteIdentity.js", "browser/base/content/browser-siteProtections.js", "browser/base/content/browser.js", "browser/base/content/browser.xul", "browser/base/jar.mn", "browser/components/controlcenter/content/identityPanel.inc.xul", "browser/components/controlcenter/content/panel.inc.xul", "browser/components/controlcenter/content/protectionsPanel.inc.xul"], "git_node": null, "git_parents": [null], "node": "e1437ba34a4afff6cee82968503144f15e9e1949", "parents": ["9437ce7f56f17a5f38e3c64f165005845a50fc69"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1550521 - Remove private browsing help message with settings hidden r=jaws\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30747", "files": ["toolkit/mozapps/extensions/content/aboutaddons.css", "toolkit/mozapps/extensions/content/aboutaddons.html", "toolkit/mozapps/extensions/content/aboutaddons.js", "toolkit/mozapps/extensions/test/browser/browser_html_detail_view.js"], "git_node": null, "git_parents": [null], "node": "01fcbba06f1c5a79a6881c4a4378b0bd2476e22e", "parents": ["e1437ba34a4afff6cee82968503144f15e9e1949"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1545968 - Update repack_rust.py to include rust stdlib src and analysis data. r=glandium\n\nThis makes the rust toolchain artifacts contain the rust stdlib as well,\nfor use by searchfox. It does bring up the size of the toolchain\nartifact slightly - rustc.tar.xz file for the Linux/rust 1.34 job for\nexample goes from 270483672 bytes to 273803148 bytes (1.23% larger) and\nthe equivalent android tarball goes from 230503888 to 235698736 bytes\n(2.25% larger).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D28282", "files": ["taskcluster/scripts/misc/repack_rust.py"], "git_node": null, "git_parents": [null], "node": "f1ace2853a4c8e42c77eea943f2938147a111118", "parents": ["01fcbba06f1c5a79a6881c4a4378b0bd2476e22e"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1545968 - Produce artifacts with the rust stdlib src and analysis data for consumption by searchfox. r=glandium\n\nDifferential Revision: https://phabricator.services.mozilla.com/D28283", "files": ["toolkit/mozapps/installer/package-name.mk", "toolkit/mozapps/installer/packager.mk", "toolkit/mozapps/installer/upload-files.mk"], "git_node": null, "git_parents": [null], "node": "f17162f343b657c6ac2f57937ff49a1840465a6b", "parents": ["f1ace2853a4c8e42c77eea943f2938147a111118"], "tags": []}, {"author": "Bo