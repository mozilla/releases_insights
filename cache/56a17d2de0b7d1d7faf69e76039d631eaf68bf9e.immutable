nes-ES -\u003e e0c815dc8cf7\ngn -\u003e 46bf2d387585\nhsb -\u003e e37828382703\nhu -\u003e b61c27fbe914\nhy-AM -\u003e b0ef60df37e8\nia -\u003e a6610e065d5e\nka -\u003e 776ee9988713\nnl -\u003e 3dc74cf1f4cf\nnn-NO -\u003e 289e08768d73\npt-BR -\u003e 6525a2d75d4b\npt-PT -\u003e fa3038d944e8\nsv-SE -\u003e b1ae0a002c77\nvi -\u003e d40e2e0094da\nzh-CN -\u003e a4ee6af24713\nzh-TW -\u003e 13a8790dea4d", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "d9dd2157f38a15d0c00a549a2233595c90315eed", "parents": ["3ece51f7971af10d94a1fa335b676f37feabb5ce"], "tags": []}], "date": 1559235632, "git_changesets": [null, null], "user": "ffxbld"}, "11339": {"changesets": [{"author": "Nick Thomas \u003cnthomas@mozilla.com\u003e", "branch": "default", "desc": "Bug 1543932 - partner repacks bustage in 68.0, r=tomprince, a=release\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33124", "files": ["testing/mozharness/scripts/desktop_partner_repacks.py"], "git_node": null, "git_parents": [null], "node": "28959f2fdc81ab4ed3a089db71eec4f3e8c183af", "parents": ["d9dd2157f38a15d0c00a549a2233595c90315eed"], "tags": []}], "date": 1559256570, "git_changesets": [null], "user": "nthomas@mozilla.com"}, "11340": {"changesets": [{"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1553877 - push-apk: Provide default values for -nightly and -beta jobs r=Callek a=release\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32832", "files": ["taskcluster/ci/push-apk/kind.yml", "taskcluster/taskgraph/transforms/push_apk.py"], "git_node": null, "git_parents": [null], "node": "0c64a9593a32dd26649acf4c8b82419178efb24e", "parents": ["28959f2fdc81ab4ed3a089db71eec4f3e8c183af"], "tags": []}, {"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1553880 - Remove google-play-strings transform r=Callek a=release\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32818", "files": ["taskcluster/ci/google-play-strings/kind.yml", "taskcluster/taskgraph/transforms/google_play_strings.py"], "git_node": null, "git_parents": [null], "node": "bb0c230ab42a5f7c625aa0667bc01636ed1d925e", "parents": ["0c64a9593a32dd26649acf4c8b82419178efb24e"], "tags": []}, {"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554046 - Bump new Fennec beta/release version file r=Callek a=release\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32705", "files": ["taskcluster/ci/release-version-bump/kind.yml"], "git_node": null, "git_parents": [null], "node": "4edb4581e79d36cbdfb40c36cf4bfba8527d4095", "parents": ["bb0c230ab42a5f7c625aa0667bc01636ed1d925e"], "tags": []}, {"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554100 - Rename \"google-play-strings-google-play-strings-nightly\" job r=Callek a=release\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32816", "files": ["taskcluster/ci/google-play-strings/kind.yml"], "git_node": null, "git_parents": [null], "node": "e4479a15794fd72700049fcf0689af07c97de96e", "parents": ["4edb4581e79d36cbdfb40c36cf4bfba8527d4095"], "tags": []}, {"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1552573 - nightly_fennec (68 train): Use task.kind instead of task.label r=tomprince a=release\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32850", "files": ["taskcluster/taskgraph/target_tasks.py"], "git_node": null, "git_parents": [null], "node": "c27cd14cd5ec9c8b2840a12768a062249426b0c7", "parents": ["e4479a15794fd72700049fcf0689af07c97de96e"], "tags": []}], "date": 1559294733, "git_changesets": [null, null, null, null, null], "user": "jlorenzo@mozilla.com"}, "11341": {"changesets": [{"author": "Adam Orban \u003cadam.orban@softvision.ro\u003e", "branch": "default", "desc": "Bug 1179266 - [Tablet] Fix Android L \"share\" list item in long press context menu; r=petru a=jcristau\n\nFix padding for mdpi tablets\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32661", "files": ["mobile/android/app/src/main/res/values-sw600dp-v21/dimens.xml", "mobile/android/app/src/main/res/values-sw600dp/dimens.xml", "mobile/android/app/src/main/res/values-sw720dp-v21/dimens.xml", "mobile/android/app/src/main/res/values-sw720dp/dimens.xml"], "git_node": null, "git_parents": [null], "node": "8a7a40a3e59fea2d5046926f727249eebfc1e003", "parents": ["c27cd14cd5ec9c8b2840a12768a062249426b0c7"], "tags": []}, {"author": "Andrei Lazar \u003candrei.a.lazar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1371618 Pop-ups not displayed if never show checkbox left unmarked r=johannh,petru a=jcristau\n\nAdded the missing data to the UpdateBlockedPopups event fired from PopupBlockingChild component.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31228", "files": ["mobile/android/chrome/content/browser.js"], "git_node": null, "git_parents": [null], "node": "250fc068195338d7430f2c82483bbda726f44421", "parents": ["8a7a40a3e59fea2d5046926f727249eebfc1e003"], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1524280 - Part 1. Ensure we always post when freeing SharedUserData. r=jrmuizel a=jcristau\n\nWe now also post the releasing of the shared surface image keys and\nexternal image ID to the main thread. This allows the current\ntransaction to complete before freeing the surface, which guards against\ncases where the surface is referenced and released somehow in the space\nof the same transaction.\n\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32861", "files": ["gfx/layers/ipc/SharedSurfacesChild.cpp", "gfx/layers/ipc/SharedSurfacesChild.h"], "git_node": null, "git_parents": [null], "node": "ead433b4f740d1de53ab55b9196900eba788b1f1", "parents": ["250fc068195338d7430f2c82483bbda726f44421"], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1524280 - Part 2. Store the blob image reference to each shared surface in BlobItemData. r=jrmuizel a=jcristau\n\nWhen a blob image invalidates, it doesn't always repaint the entire\nblob. When we stored the shared surface references in the DIGroup, it\nwould incorrectly forgot about images referenced by items that were not\ninvalidated when it repainted. As such, it could free them too early and\ncause a crash when rasterizing the blob in the compositor process.\n\nThis did not crash most of the time because the image cache would bail\nus out. It takes a full minute for the image cache to expire, but the\nissue was more readily reproducible when that timeout was shortened.\n\nWe now store the references in BlobItemData, on a per display item\nbasis. This ensures that when any given item is invalidated, it will\ncontinue referencing any resources that it needs.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32820", "files": ["gfx/layers/wr/WebRenderCommandBuilder.cpp"], "git_node": null, "git_parents": [null], "node": "dfe3f74cba935f205a6b160bd0084eaf584e2cc6", "parents": ["ead433b4f740d1de53ab55b9196900eba788b1f1"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1535835 - Remove global weak ref to BrowsingContext within Unlink(), r=farre a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30683", "files": ["docshell/base/BrowsingContext.cpp", "docshell/base/BrowsingContext.h"], "git_node": null, "git_parents": [null], "node": "ab126e9e64632ac6ee92b9ee819cfdc9ec3abd51", "parents": ["dfe3f74cba935f205a6b160bd0084eaf584e2cc6"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1545247 - Fix crash in MouseCursorMonitorX11::CaptureCursor() on linux32; r=ng a=jcristau\n\nThis is a cherry pick of upstream commit c1187ab34bdf836bd33f7f050d525184eba4cd20.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32826", "files": ["media/webrtc/trunk/webrtc/modules/desktop_capture/linux/mouse_cursor_monitor_x11.cc"], "git_node": null, "git_parents": [null], "node": "4738da99fbc88df4ba50b494b58342d44fa3575b", "parents": ["ab126e9e64632ac6ee92b9ee819cfdc9ec3abd51"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1545410 - part 1: Forcibly disable new keyCode/charCode value of keypress events if the document is Office Online Server r=smaug a=jcristau\n\nSimilar to bug 1514940, we need to use \"split model\" keypres events on\nOffice Online Server since they can be installed into user own servers.\n\nMicrosoft said it's safe to check whether there is an element whose id is\n\"WACViewPanel_EditingElement\":\nhttps://bugzilla.mozilla.org/show_bug.cgi?id=1545410#c17\n\nAdditionally, they'll add new class to the element after fixing the bug in\ntheir side:\nhttps://bugzilla.mozilla.org/show_bug.cgi?id=1545410#c17\nhttps://bugzilla.mozilla.org/show_bug.cgi?id=1545410#c20\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32287", "files": ["dom/events/test/mochitest.ini", "dom/events/test/test_use_conflated_keypress_event_model_on_newer_Office_Online_Server.html", "dom/events/test/test_use_split_keypress_event_model_on_old_Office_Online_Server.html", "toolkit/actors/KeyPressEventModelCheckerChild.jsm"], "git_node": null, "git_parents": [null], "node": "b9d57ba2bf45a07a5348473a354931c49b580e3f", "parents": ["4738da99fbc88df4ba50b494b58342d44fa3575b"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1546655 - Re-enable tests. r=jya a=jcristau\n\nDepends on D32108\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32109", "files": ["dom/media/test/test_streams_element_capture.html"], "git_node": null, "git_parents": [null], "node": "083d8b196e64e7d0b4b67272abc4788630ef0f47", "parents": ["b9d57ba2bf45a07a5348473a354931c49b580e3f"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1546655 - Switch to NullableTimeUnit where applicable in DecodedStream. r=jya a=jcristau\n\nDecodedStream is already using this for mStartTime.\n\nDepends on D32109\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32110", "files": ["dom/media/mediasink/DecodedStream.cpp"], "git_node": null, "git_parents": [null], "node": "2a54b1e72baea2b593c2e46722ab97629fec8e2a", "parents": ["083d8b196e64e7d0b4b67272abc4788630ef0f47"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1546655 - Add AudioQueue info to DecodedStream's debug info. r=jya a=jcristau\n\nDepends on D32110\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32111", "files": ["dom/media/mediasink/DecodedStream.cpp"], "git_node": null, "git_parents": [null], "node": "facb1c6c89a56ef8d71602a4e8a9b8553e771223", "parents": ["2a54b1e72baea2b593c2e46722ab97629fec8e2a"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1546655 - Call SendData() on SetPlaying(true). r=jya a=jcristau\n\nThe following sequence in DecodedStream could lead to a stall for a captured\nmedia element:\n- MediaDecoder decodes some data, DecodedStream sends it out\n- MediaDecoder pauses for buffering, DecodedStream sees SetPlaying(false)\n- MediaDecoder decodes until the end, DecodedStream doesn't send since it's\n  not playing\n- MediaDecoder starts playing again, DecodedStream sees SetPlaying(true)\n\nAt the last step above, SetPlaying(true) doesn't trigger SendData() so no data\nis sent out. Since all data has already been decoded, nothing can trigger\nSendData() anymore. This patch fixes this by calling SendData() on SetPlaying().\n\nDepends on D32111\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32112", "files": ["dom/media/mediasink/DecodedStream.cpp"], "git_node": null, "git_parents": [null], "node": "b53f13005bd356af675fe72ec80f80a9bd8a7ae5", "parents": ["facb1c6c89a56ef8d71602a4e8a9b8553e771223"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1546655 - Remove racy assert. r=jya a=jcristau\n\nThis assert can be racy if the following sequence happens:\nSetPlaying() -- watch manager schedules SendData()\nStop() -- unwatches mPlaying, resets mStartTime\nSendData() -- fails the assert\n\nSendData handles the case where mStartTime is unset at runtime already through the mData check, further making this assert unnecessary.\n\nDepends on D32112\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32113", "files": ["dom/media/mediasink/DecodedStream.cpp"], "git_node": null, "git_parents": [null], "node": "3c9393f08fc69af0b0ba31f1dbba9a02204f6502", "parents": ["b53f13005bd356af675fe72ec80f80a9bd8a7ae5"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1546655 - Modernize test_streams_element_capture.html. r=jib a=jcristau\n\nThis async/await-ifies the test to put checks in logical order.\nIt also, as a drive-by, adds `v.token = token` since this is a cue to the test\nframework in manifest.js to mozDumpDebugInfo() on the right element after\ntimeout of a token.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32114", "files": ["dom/media/test/test_streams_element_capture.html"], "git_node": null, "git_parents": [null], "node": "18e5f48ade65db5526283fa0c54e769f1e970549", "parents": ["3c9393f08fc69af0b0ba31f1dbba9a02204f6502"], "tags": []}], "date": 1559311804, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "malexandru@mozilla.com"}, "11342": {"changesets": [{"author": "Matthew Gregan \u003ckinetik@flim.org\u003e", "branch": "default", "desc": "Bug 1550695 - Avoid duplicating cubeb_init in both arms of MOZ_CUBEB_REMOTING ifdef.  r=achronop a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32654", "files": ["dom/media/CubebUtils.cpp"], "git_node": null, "git_parents": [null], "node": "d68ba2d3844c731135e9fbdf750e727fd8412fea", "parents": ["18e5f48ade65db5526283fa0c54e769f1e970549"], "tags": []}, {"author": "Matthew Gregan \u003ckinetik@flim.org\u003e", "branch": "default", "desc": "Bug 1550695 - Wrap cubeb_init in EnsureMTA to handle being called from threads where COM is uninitialized.  r=achronop a=jcristau\n\nDepends on D32654\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32655", "files": ["dom/media/CubebUtils.cpp"], "git_node": null, "git_parents": [null], "node": "abda154079efcd7fdc78ab5a0ba6e13fc14aa93a", "parents": ["d68ba2d3844c731135e9fbdf750e727fd8412fea"], "tags": []}, {"author": "chrmod \u003cchrmod@chrmod.net\u003e", "branch": "default", "desc": "Bug 1551377 - GeckoView unique tab id r=geckoview-reviewers,snorp a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32824", "files": ["mobile/android/modules/geckoview/GeckoViewTab.jsm"], "git_node": null, "git_parents": [null], "node": "5fb77819e231aad9231f89c33b5a573bb1779f21", "parents": ["abda154079efcd7fdc78ab5a0ba6e13fc14aa93a"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1547830 - Ensure updated WNP is shown in the Trailhead dot release (aka 67.0.5) r=Gijs a=jcristau\n\nReviewers: Gijs\n\nReviewed By: Gijs\n\nSubscribers: tomprince\n\nBug #: 1547830\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31745", "files": ["browser/components/BrowserContentHandler.jsm"], "git_node": null, "git_parents": [null], "node": "6fc87a979fcb6667944d1fb1cdcc9cd8f70acce5", "parents": ["5fb77819e231aad9231f89c33b5a573bb1779f21"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1549889: Add support for displaying WNP conditionally on build-id; r=nthomas a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33039", "files": ["python/mozrelease/mozrelease/balrog.py", "taskcluster/taskgraph/transforms/balrog_toplevel.py"], "git_node": null, "git_parents": [null], "node": "b488a5cc9dfb0751a096461165c5b243a48ee0ad", "parents": ["6fc87a979fcb6667944d1fb1cdcc9cd8f70acce5"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1549889: Display whats-new-page to trailhead locales on updates to beta; r?nthomas a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com//D33040", "files": ["browser/config/whats_new_page.yml"], "git_node": null, "git_parents": [null], "node": "5527500a9cf762bd13bb959849baaeb526b1fd4c", "parents": ["b488a5cc9dfb0751a096461165c5b243a48ee0ad"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1552537 - Include preferences option for plugins r=kmag a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31707", "files": ["toolkit/mozapps/extensions/content/aboutaddons.html", "toolkit/mozapps/extensions/content/aboutaddons.js", "toolkit/mozapps/extensions/test/browser/browser_html_plugins.js"], "git_node": null, "git_parents": [null], "node": "c1641fab48a0bb6cc656222ecc66e0e7669f9b2d", "parents": ["5527500a9cf762bd13bb959849baaeb526b1fd4c"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1553067 - Quantum Bar may not return bookmark tags correctly. r=adw a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32684", "files": ["browser/components/urlbar/UrlbarProviderUnifiedComplete.jsm", "browser/components/urlbar/tests/browser/browser_autocomplete_tag_star_visibility.js", "browser/components/urlbar/tests/unit/test_providerUnifiedComplete.js", "toolkit/components/places/UnifiedComplete.jsm", "toolkit/components/places/tests/unifiedcomplete/test_special_search.js"], "git_node": null, "git_parents": [null], "node": "49da76e97a0250b8dfee9e1f54c7dac3fb896a56", "parents": ["c1641fab48a0bb6cc656222ecc66e0e7669f9b2d"], "tags": []}, {"author": "Barret Rennie \u003cbarret@brennie.ca\u003e", "branch": "default", "desc": "Bug 1553261 - Clean up some of the CompositionPayload infrastructure r=kats a=jcristau\n\nSome time ago (bug 819791), InfallibleTArray and nsTArray become equivalent, so\ncontinuing to use InfallibleTArray here will just lead to confusion.\n\nIn addition, the overloaded `RegisterPayload` could take either a single\npayload or multiple, so I've split it into\n`RegisterPayload(CompositionPayload&)` and\nRegisterPayloads(nsTArray\u003cCompositionPayload\u003e&)`\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32227", "files": ["gfx/layers/Layers.h", "gfx/layers/ipc/CompositorBridgeParent.cpp", "gfx/layers/ipc/CompositorBridgeParent.h", "gfx/layers/ipc/ContentCompositorBridgeParent.cpp", "gfx/layers/ipc/ContentCompositorBridgeParent.h"], "git_node": null, "git_parents": [null], "node": "85c9907686ce71f4a72da448d278444acc11b2a2", "parents": ["49da76e97a0250b8dfee9e1f54c7dac3fb896a56"], "tags": []}, {"author": "Barret Rennie \u003cbarret@brennie.ca\u003e", "branch": "default", "desc": "Bug 1553261 - Register CompositionPayloads with the WebRenderBridge and enable key press telemetry r=kats a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32228", "files": ["gfx/layers/Layers.cpp", "gfx/layers/Layers.h", "gfx/layers/ipc/PWebRenderBridge.ipdl", "gfx/layers/wr/WebRenderBridgeChild.cpp", "gfx/layers/wr/WebRenderBridgeParent.cpp", "gfx/layers/wr/WebRenderBridgeParent.h", "gfx/layers/wr/WebRenderLayerManager.cpp", "gfx/layers/wr/WebRenderLayerManager.h"], "git_node": null, "git_parents": [null], "node": "40889c3aad8af453045feef6aef3f4a74276879d", "parents": ["85c9907686ce71f4a72da448d278444acc11b2a2"], "tags": []}, {"author": "Alexis Beingessner \u003ca.beingessner@gmail.com\u003e", "branch": "default", "desc": "Bug 1553295 - let masks be active in blobs. r=jrmuizel a=jcristau\n\nThere doesn't seem to be a reason *not* to do this (merely an omission),\nand the results we get without it are messing up somewhere with invalidation\nand image cache management.\n\nThis is likely just a bandaid over a more serious issue, but if we never observe\nthat issue, does it exist..?\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32833", "files": ["gfx/layers/wr/WebRenderCommandBuilder.cpp"], "git_node": null, "git_parents": [null], "node": "0be946c9a8d8634914882a561249f15603091f3f", "parents": ["40889c3aad8af453045feef6aef3f4a74276879d"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1553448 - Improve appearance of card menu at about:addons r=mstriemer,jaws a=jcristau\n\n- Render \"hidden\" appearance via opacity. This fixes the reported\n  regression, and also results in a desired fading of the icon (if any).\n- Set cursor to \"default\" avoid \"pointer\" cursor in menu items.\n- Let the \"checked\" icon adapt the color of the style sheet (e.g. to\n  account for dark themes) instead of using the default black color.\n- Prevent clicks on non-button elements in the menu from expanding the\n  card, e.g. when the user clicks on the triangle or separator.\n- Render menu item icon at the right in RTL locales.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32145", "files": ["toolkit/mozapps/extensions/content/aboutaddons.js", "toolkit/mozapps/extensions/content/panel-item.css", "toolkit/mozapps/extensions/content/panel-list.css"], "git_node": null, "git_parents": [null], "node": "e02a84026ffda1838ebef5370593b97d0280e900", "parents": ["0be946c9a8d8634914882a561249f15603091f3f"], "tags": []}], "date": 1559314700, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "malexandru@mozilla.com"}, "11343": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 104b25c67fb01d01383b86a77b5e0cd89e3b1a7f with FIREFOX_68_0b6_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "cffb585dac48a6d9ce1143e81f035fc4178c0a30", "parents": ["e02a84026ffda1838ebef5370593b97d0280e900"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release DONTBUILD", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "b7a9b3972edc7b3c2c350b30f7493e502296ff98", "parents": ["cffb585dac48a6d9ce1143e81f035fc4178c0a30"], "tags": []}], "date": 1559315449, "git_changesets": [null, null], "user": "ffxbld"}, "11344": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 104b25c67fb01d01383b86a77b5e0cd89e3b1a7f with DEVEDITION_68_0b6_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "6e7e411cedf41bdcb9f65d6d3af9589208bb7e28", "parents": ["b7a9b3972edc7b3c2c350b30f7493e502296ff98"], "tags": []}], "date": 1559315637, "git_changesets": [null], "user": "ffxbld"}, "11345": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1554271 - Make Fennec Beta/Release tests pick up the correct default tier. r=jlorenzo, a=release\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32544", "files": ["taskcluster/taskgraph/transforms/tests.py"], "git_node": null, "git_parents": [null], "node": "2479a128266282a03e6cdf3c23c7a72e6ecea97b", "parents": ["6e7e411cedf41bdcb9f65d6d3af9589208bb7e28"], "tags": []}, {"author": "Rob Wood \u003crwood@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554308 - Raptor tests on Beta are running on both opt & pgo builds. r=jmaher, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33177", "files": ["taskcluster/ci/test/raptor.yml"], "git_node": null, "git_parents": [null], "node": "8877cfc4f1087be21bc4c856d2c1646952955e8b", "parents": ["2479a128266282a03e6cdf3c23c7a72e6ecea97b"], "tags": []}], "date": 1559317800, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "11346": {"changesets": [{"author": "diana.iacos \u003cdiana.iacos@softvision.ro\u003e", "branch": "default", "desc": "Bug 1553474 - \"Remove bookmark\" option is displayed for pages that were not bookmarked; r=petru a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32664", "files": ["mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/stream/TopPanelRow.java"], "git_node": null, "git_parents": [null], "node": "e996cd24ede06d7c8c2a822092a7437ba9cfea15", "parents": ["8877cfc4f1087be21bc4c856d2c1646952955e8b"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554038 - Make UrlbarInput::pickResult and UrlbarController::recordSelectedResult take a UrlbarResult instead of an index and remove UrlbarView::getResult. r=adw a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32708", "files": ["browser/components/urlbar/UrlbarController.jsm", "browser/components/urlbar/UrlbarInput.jsm", "browser/components/urlbar/UrlbarResult.jsm", "browser/components/urlbar/UrlbarView.jsm"], "git_node": null, "git_parents": [null], "node": "8536ebb1c16ffc0ae48a1efb51770744db176fe5", "parents": ["e996cd24ede06d7c8c2a822092a7437ba9cfea15"], "tags": []}, {"author": "Matt Howell \u003cmhowell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554141 - Use installs.ini to find per-install profiles. r=agashlin a=jcristau\n\nThis should be more reliable than exclusively using profiles.ini, which doesn't\nalways get rewritten to include path hashes for the per-install profiles.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32884", "files": ["browser/installer/windows/nsis/stub.nsi"], "git_node": null, "git_parents": [null], "node": "e26b8629b145879a5a5949e799f9dc02bf7a3f3e", "parents": ["8536ebb1c16ffc0ae48a1efb51770744db176fe5"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1554217 - Disable HTTPResponseProcessSelection on Beta, r=farre a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32489", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "607ce840d7977d086a69f5937db83522b47f1270", "parents": ["e26b8629b145879a5a5949e799f9dc02bf7a3f3e"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554256 - Read GeckoView configuration file in release builds when package is the current Android \"debug-app\". r=geckoview-reviewers,snorp a=jcristau\n\nBug 1533385 taught GeckoView to read configuration from a file. But\nright now, release APKs don't read that configuration: see the\ndocumentation at See\nhttps://mozilla.github.io/geckoview/tutorials/automation.html#enabling-reading-configuration-from-a-file-for-release-builds.\nHowever, Android has a flag -- the \"debug_app\" flag -- that Chrome\nuses to control this configuration file behaviour, and this commit\nmakes GeckoView uses that flag as well.\n\nTo use this, invoke `adb shell am set-debug-app --persistent PACKAGE`\n(see https://developer.android.com/studio/command-line/adb).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32511", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/util/ContextUtils.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoRuntime.java"], "git_node": null, "git_parents": [null], "node": "bf08990ed4aadab5ca2759db26d72e6b260e7e40", "parents": ["607ce840d7977d086a69f5937db83522b47f1270"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554317 - String for showing add-on recommendations r=rpl,flod a=jcristau\n\nThis string will be used as the alt and title text for the recommended icon\nin about:addons. The patch to add the image will follow, once we have a way\nof identifying add-ons that were recommended.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32542", "files": ["toolkit/locales/en-US/toolkit/about/aboutAddons.ftl"], "git_node": null, "git_parents": [null], "node": "18270856aca64b956756fe307e9a2bfeea313f30", "parents": ["bf08990ed4aadab5ca2759db26d72e6b260e7e40"], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554540 - Expose window protocol (X11, Wayland) in nsIGfxInfo and about:support. r=kats,stransky,flod a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32651", "files": ["toolkit/content/aboutSupport.js", "toolkit/crashreporter/CrashAnnotations.yaml", "toolkit/locales/en-US/toolkit/about/aboutSupport.ftl", "toolkit/modules/Troubleshoot.jsm", "widget/GfxInfoX11.cpp", "widget/GfxInfoX11.h", "widget/android/GfxInfo.cpp", "widget/android/GfxInfo.h", "widget/cocoa/GfxInfo.h", "widget/cocoa/GfxInfo.mm", "widget/moz.build", "widget/nsIGfxInfo.idl", "widget/windows/GfxInfo.cpp", "widget/windows/GfxInfo.h"], "git_node": null, "git_parents": [null], "node": "4e5980a74c9c5023f5f64741a4bee1c1055af24c", "parents": ["18270856aca64b956756fe307e9a2bfeea313f30"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554998 - Fix the handling of numeric characters by word-break:break-all. r=masayuki a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32969", "files": ["intl/lwbrk/LineBreaker.cpp"], "git_node": null, "git_parents": [null], "node": "f787bc6258149666dd364f2d559c032a4b1a07e2", "parents": ["4e5980a74c9c5023f5f64741a4bee1c1055af24c"], "tags": []}, {"author": "Dana Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "bug 1555110 - Backed out changeset a187487af38a to disable cert_storage on non-nightly builds r=jcj,froydnj a=jcristau\n\nThere are ongoing lmdb issues we need to sort out before we can ship\ncert_storage (see e.g. bug 1538541 and bug 1550174).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32885", "files": ["old-configure.in", "security/manager/ssl/security-prefs.js", "toolkit/moz.configure"], "git_node": null, "git_parents": [null], "node": "44ec76478317fdc6fba90c55771f6514c32e388b", "parents": ["f787bc6258149666dd364f2d559c032a4b1a07e2"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1555640 - Check if `aPointAfterInsertedString` is nullptr when `WSRunObject::InsertText()` sets its value r=m_kato a=jcristau\n\n`aPointAfterInsertedString` of `WSRunObject::InsertText()` is optional (i.e.,\nmay be nullptr).  However, the fix for bug 1534394 makes it always set to\noriginal insertion point when `InsertTextWithTransaction()` is failed.\n\nThis patch just make it check if `aPointAfterInsertedString` is nullptr before\nsetting its value.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33144", "files": ["editor/libeditor/WSRunObject.cpp"], "git_node": null, "git_parents": [null], "node": "72e634f9360acbc01148c18bad4fbbb4defb3238", "parents": ["44ec76478317fdc6fba90c55771f6514c32e388b"], "tags": []}], "date": 1559319331, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "malexandru@mozilla.com"}, "11347": {"changesets": [{"author": "Julien Cristau \u003cjcristau@mozilla.com\u003e", "branch": "de