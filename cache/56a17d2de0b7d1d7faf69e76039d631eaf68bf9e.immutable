rents": ["59e67467da702a3b571d4733c4bd468a9f71ad56"], "tags": []}, {"author": "Jeff Gilbert \u003cjgilbert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1515052 - Use WeakPtr for extension parent pointer. r=lsalzman a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31942", "files": ["dom/canvas/WebGLContext.h", "dom/canvas/WebGLExtensionCompressedTextureASTC.cpp", "dom/canvas/WebGLExtensionDebugShaders.cpp", "dom/canvas/WebGLExtensionDisjointTimerQuery.cpp", "dom/canvas/WebGLExtensionDrawBuffers.cpp", "dom/canvas/WebGLExtensionInstancedArrays.cpp", "dom/canvas/WebGLExtensionLoseContext.cpp", "dom/canvas/WebGLExtensionMOZDebug.cpp", "dom/canvas/WebGLExtensionVertexArray.cpp", "dom/canvas/WebGLObjectModel.h"], "git_node": null, "git_parents": [null], "node": "88114c48b1eeac094cd9bc707f0029dd8dc8e857", "parents": ["9b3c45bd2e778ae1ab2da8d4a79d3771619d626b"], "tags": []}, {"author": "Daniel Varga \u003cdvarga@mozilla.com\u003e", "branch": "default", "desc": "Bug 1532404 - Disable org.mozilla.geckoview.test.MediaElementTest.webmPlayMediaFromScript on pgo and debug for frequent failures. r=jmaher a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33128", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/MediaElementTest.kt"], "git_node": null, "git_parents": [null], "node": "0b0766cf7b2232d80f73710b3a1bfa4fb9a4864f", "parents": ["88114c48b1eeac094cd9bc707f0029dd8dc8e857"], "tags": []}], "date": 1559758960, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "11382": {"changesets": [{"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1557164 - Don't use integrated assembler with clang on mips*. r=froydnj a=jcristau\n\nReviewers: froydnj\n\nReviewed By: froydnj\n\nBug #: 1557164\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33865", "files": ["xpcom/reflect/xptcall/md/unix/moz.build"], "git_node": null, "git_parents": [null], "node": "e74c38d7d3f3236d555e61206e0e7e4b62e8ed12", "parents": ["0b0766cf7b2232d80f73710b3a1bfa4fb9a4864f"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1557051 - Enable QuantumBar for release users. r=dao,adw a=jcristau\n\nReviewers: dao, adw\n\nReviewed By: dao, adw\n\nBug #: 1557051\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33799", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "88f51f844ca55a0dcf21450b14b41a0c9ec7ca38", "parents": ["e74c38d7d3f3236d555e61206e0e7e4b62e8ed12"], "tags": []}, {"author": "Mike Hommey \u003cmh@glandium.org\u003e", "branch": "default", "desc": "Bug 997353 - Make powerpc not use static page sizes in mozjemalloc. r=njn a=jcristau\n\nSummary: __powerpc__ covers powerpc and powerpc64.\n\nReviewers: njn\n\nReviewed By: njn\n\nBug #: 997353\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33750", "files": ["memory/build/mozjemalloc.cpp"], "git_node": null, "git_parents": [null], "node": "236675dcbcab341c475e85e0f6999df67eec3e22", "parents": ["88f51f844ca55a0dcf21450b14b41a0c9ec7ca38"], "tags": []}, {"author": "Haik Aftandilian \u003chaftandilian@mozilla.com\u003e", "branch": "default", "desc": "Bug 1551990 - Firefox hangs on wake up from OS X Power Nap r=spohl a=jcristau\n\nDisable App Nap in Firefox to avoid macOS App Nap'ing the parent process while child processes continue to run normally.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33130", "files": ["toolkit/xre/MacApplicationDelegate.h", "toolkit/xre/MacApplicationDelegate.mm", "toolkit/xre/nsAppRunner.cpp"], "git_node": null, "git_parents": [null], "node": "9337bf07777d1a004af086c50cb201f91466f0bb", "parents": ["236675dcbcab341c475e85e0f6999df67eec3e22"], "tags": []}, {"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1556730 - QM: Add IsShuttingDown checks to temporary storage initialization; r=asuth a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33636", "files": ["dom/quota/ActorsParent.cpp", "dom/quota/QuotaCommon.h"], "git_node": null, "git_parents": [null], "node": "f60cd8f26e67f81dfcaf5b943e6e289650d09d79", "parents": ["9337bf07777d1a004af086c50cb201f91466f0bb"], "tags": []}, {"author": "Razvan Caliman \u003crcaliman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1550794 - Add telemetry probe to count number of node selections. r=gl a=jcristau\n\nAdds a new permanent telemetry probe (scalar) to count the number of times a node selection is made in the Inspector. This count will be correlated with other existing probes (open count, duration open) to establish a more accurate baseline for Inspector usage and correct for accidental usage.\n\nWhen opening the Inspector via the context menu (\"Inspect Element\"), the selection is counted twice: once when automatically selecting the `\u003cbody\u003e` to build the dom tree and once more for selecting the actual target node. This side-effect does not pollute our data. We assign a higher weight to the behavior of \"Inspect Element\" as being intentional usage of the Inspector so the higher node selection count works in our favor.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31231", "files": ["devtools/client/inspector/inspector.js", "toolkit/components/telemetry/Scalars.yaml"], "git_node": null, "git_parents": [null], "node": "078edca81820d384a4cb0412377caa5131dec20c", "parents": ["f60cd8f26e67f81dfcaf5b943e6e289650d09d79"], "tags": []}, {"author": "Timothy Nikkel \u003ctnikkel@gmail.com\u003e", "branch": "default", "desc": "Bug 1556076. Restore checking the return value of MakeInputStream in nsIconChannel on mac. r=aosmond a=jcristau\n\nSummary: Bug 1520868 accidentally removed this check.\n\nReviewers: aosmond\n\nReviewed By: aosmond\n\nBug #: 1556076\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33892", "files": ["image/decoders/icon/mac/nsIconChannelCocoa.mm"], "git_node": null, "git_parents": [null], "node": "223180843523d3463d030bf81603b1f0125424a7", "parents": ["078edca81820d384a4cb0412377caa5131dec20c"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1542561 - TRR: Don't return NS_ERROR_UNKNOWN_HOST when a AAAA response comes back first, but the second A response is NXDOMAIN r=dragana a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33471", "files": ["netwerk/dns/nsHostResolver.cpp"], "git_node": null, "git_parents": [null], "node": "d147de264bb9067c4815c36d1e8ccd7642eee3ee", "parents": ["223180843523d3463d030bf81603b1f0125424a7"], "tags": []}, {"author": "Dave Townsend \u003cdtownsend@oxymoronical.com\u003e", "branch": "default", "desc": "Bug 1556612: Hardcode considering this an upgrade if the last build to run was run in safe mode. r=froydnj a=jcristau\n\nWhen safe mode runs it writes out \"Safe Mode\" as the compatibility version (bug\n1556831). Due to bug 1556832 and bug 1556829 this makes us think that the next\nrun is a downgrade.\n\nThis is the simplest possible fix that should be totally safe to upload to\nrelease.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33698", "files": ["toolkit/xre/nsAppRunner.cpp", "toolkit/xre/test/gtest/TestCompatVersionCompare.cpp"], "git_node": null, "git_parents": [null], "node": "f78bcf6d473ed6a6c9828fc9e37a07e9e6886f81", "parents": ["d147de264bb9067c4815c36d1e8ccd7642eee3ee"], "tags": []}], "date": 1559815501, "git_changesets": [null, null, null, null, null, null, null, null, null], "user": "cbrindusan@mozilla.com"}, "11383": {"changesets": [{"author": "Byron Campen [:bwc] \u003cdocfaraday@gmail.com\u003e", "branch": "default", "desc": "Bug 1551836: Ensure that we clean up PeerConnectionMedia properly when PeerConnectionImpl::Initialize fails. r=mjf, a=abillings\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33071", "files": ["media/webrtc/signaling/src/peerconnection/PeerConnectionImpl.cpp"], "git_node": null, "git_parents": [null], "node": "b25d2ea5cf47fc4e0c01214acad7c30162b1b1d8", "parents": ["f78bcf6d473ed6a6c9828fc9e37a07e9e6886f81"], "tags": ["DEVEDITION_68_0b8_BUILD1", "DEVEDITION_68_0b8_RELEASE", "FIREFOX_68_0b8_BUILD1", "FIREFOX_68_0b8_RELEASE"]}], "date": 1559816062, "git_changesets": [null], "user": "jcristau@mozilla.com"}, "11384": {"changesets": [{"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1556784 - Rename `{promote,ship}_fennec` into `{promote,ship}_fennec_beta` r=rail a=release\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33657", "files": ["taskcluster/ci/config.yml", "taskcluster/taskgraph/target_tasks.py"], "git_node": null, "git_parents": [null], "node": "243b742b3659867ba2abbc89bac87977e143fd7d", "parents": ["b25d2ea5cf47fc4e0c01214acad7c30162b1b1d8"], "tags": ["FENNEC_68_0b8_BUILD1"]}], "date": 1559823372, "git_changesets": [null], "user": "jlorenzo@mozilla.com"}, "11385": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging b25d2ea5cf47fc4e0c01214acad7c30162b1b1d8 with DEVEDITION_68_0b8_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "7d39052299fb527d62b2af41e743e613504629f9", "parents": ["243b742b3659867ba2abbc89bac87977e143fd7d"], "tags": []}], "date": 1559829116, "git_changesets": [null], "user": "ffxbld"}, "11386": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging b25d2ea5cf47fc4e0c01214acad7c30162b1b1d8 with FIREFOX_68_0b8_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "64bf7a9931c0487e38ba1eed25e5a289b98035b9", "parents": ["7d39052299fb527d62b2af41e743e613504629f9"], "tags": []}], "date": 1559829426, "git_changesets": [null], "user": "ffxbld"}, "11387": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 243b742b3659867ba2abbc89bac87977e143fd7d with FENNEC_68_0b8_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "7013a17c8a72b6d4b2d0437c6236bdd32f8dcfbb", "parents": ["64bf7a9931c0487e38ba1eed25e5a289b98035b9"], "tags": []}], "date": 1559832031, "git_changesets": [null], "user": "ffxbld"}, "11388": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP blocklist remote-settings - a=repo-update r=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33947", "files": ["browser/app/blocklist.xml", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/blocklists/addons.json", "services/settings/dumps/blocklists/plugins.json", "services/settings/dumps/main/hijack-blocklists.json", "services/settings/dumps/security-state/intermediates.json"], "git_node": null, "git_parents": [null], "node": "1b0a57ff0b87323ff2111198b18e7725f956de2b", "parents": ["7013a17c8a72b6d4b2d0437c6236bdd32f8dcfbb"], "tags": []}, {"author": "Daniel Holbert \u003cdholbert@cs.stanford.edu\u003e", "branch": "default", "desc": "Bug 1473859: Change expectation for reftest unit-vh-vw-overflow-auto.html. rs=emilio, a=test-only\n\nThe \"-auto\" and \"-scroll\" variants of this test used to be expected to mismatch\n(\"!=\"), but our behavior changed with stylo such that they started matching, so\nit was marked as \"fails !=\".  But now we've decided that the post-stylo\nmatching behvavior is actually correct, so this patch is changing the manifest\nline to \"==\" so that the expectation is that they match.", "files": ["layout/reftests/css-valuesandunits/reftest.list"], "git_node": null, "git_parents": [null], "node": "e19858be0819cda92c46220fa8818996adb8b20e", "parents": ["1b0a57ff0b87323ff2111198b18e7725f956de2b"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Bug 1538430 - Disable org.mozilla.geckoview.test.RuntimeSettingsTest.automaticFontSize on Android pgo for frequent failures. r=jmaher, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33398", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/RuntimeSettingsTest.kt"], "git_node": null, "git_parents": [null], "node": "a954bf8992bdb680fb1a1b9047f2fcc1177c9e3f", "parents": ["e19858be0819cda92c46220fa8818996adb8b20e"], "tags": []}], "date": 1559832443, "git_changesets": [null, null, null], "user": "ryanvm@gmail.com"}, "11389": {"changesets": [{"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1551183: Part 1 - Add SCOPE_APPLICATION to enabledScopes for Fennec. r=aswan a=jcristau\n\nThis scope now controls add-ons bundled in omni.ja as well as those in the app\ndirectory, so we need to enable it on Fennec in order for the default theme to\nwork.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32223", "files": ["mobile/android/app/mobile.js", "mobile/android/chrome/content/browser.js"], "git_node": null, "git_parents": [null], "node": "ffa52c63ff472d43c6b81170a32dc98b05cc7dde", "parents": ["a954bf8992bdb680fb1a1b9047f2fcc1177c9e3f"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1551183: Part 2 - Support enumerating directories in extensions in nested JARs. r=aswan a=jcristau\n\nOn Android, omni.ja is bundled inside an API, and therefore loaded as a nested\nJAR. That means that its resource URIs resolve to something resembling\n\"jar:jar:...!/omni.ja!/...\". Our current enumeration code assumes no nesting\nof jar: URIs, and therefore can't handle this.\n\nThis patch changes our enumeration helpers to accept URIs rather than nsIFile\ninstances, and to correctly handle resolving the ZipReaders for those nested\nJARs. It also moves the path filter generation into the native helper to make\nthings easier for other callers which may need this behavior.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32224", "files": ["toolkit/components/extensions/Extension.jsm", "toolkit/mozapps/extensions/AddonManagerStartup.cpp", "toolkit/mozapps/extensions/amIAddonManagerStartup.idl"], "git_node": null, "git_parents": [null], "node": "76077274869a12283e79ab53491fff41264efda8", "parents": ["ffa52c63ff472d43c6b81170a32dc98b05cc7dde"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1551183: Part 3 - Add a test to sanity check the default theme on all platforms. r=aswan a=jcristau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D32225", "files": ["toolkit/mozapps/extensions/internal/XPIDatabase.jsm", "toolkit/mozapps/extensions/test/mochitest/chrome.ini", "toolkit/mozapps/extensions/test/mochitest/test_default_theme.html", "toolkit/mozapps/extensions/test/moz.build"], "git_node": null, "git_parents": [null], "node": "259f5bcec259ed020c3612b4278c2ffa184ec77f", "parents": ["76077274869a12283e79ab53491fff41264efda8"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1551183: Follow-up: Disable app-scoped add-ons in cert_storage test. r=me a=test-only", "files": ["security/manager/ssl/tests/unit/test_cert_storage.js"], "git_node": null, "git_parents": [null], "node": "092bef8c0d6e514b3ad85c6d17a7c66531f63749", "parents": ["259f5bcec259ed020c3612b4278c2ffa184ec77f"], "tags": []}], "date": 1559855227, "git_changesets": [null, null, null, null], "user": "maglione.k@gmail.com"}, "11390": {"changesets": [{"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1551738 - Add `mozilla_esr68_tasks` target tasks. r=tomprince, a=release\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33971", "files": ["taskcluster/taskgraph/target_tasks.py"], "git_node": null, "git_parents": [null], "node": "b623b7cc2ae896249b3067fa66b40d04fcd16c6b", "parents": ["092bef8c0d6e514b3ad85c6d17a7c66531f63749"], "tags": []}], "date": 1559856223, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "11391": {"changesets": [{"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1557203 - AndroidQ has final APIs. Update the feature29Plus check; r=VladBaicu a=RyanVM\n\nWith Beta4 AndroidQ now ships with final APIs so the previous check we used,\nVERSION.CODENAME now returns REL instead of Q.\nBut final APIs means AndroidQ will not share API level 28 with AndroidP anymore\nso we can finally check for Build.VERSION.SDK_INT.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33906", "files": ["mobile/android/base/AppConstants.java.in"], "git_node": null, "git_parents": [null], "node": "24e1c29b04c69fc6c6411c43cd9c42e60199c597", "parents": ["b623b7cc2ae896249b3067fa66b40d04fcd16c6b"], "tags": []}, {"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1551870 - Reintroduce netmonitor-toolbar-container in single-toolbar mode so React doesn't re-render the toolbar when switching panels. r=Honza a=jcristau\n\nReviewers: Honza\n\nReviewed By: Honza\n\nSubscribers: reviewbot\n\nBug #: 1551870\n\nDifferential Revision: https://phabricator.services.mozilla.com/D33616", "files": ["devtools/client/netmonitor/src/assets/styles/Toolbar.css", "devtools/client/netmonitor/src/components/Toolbar.js", "devtools/client/netmonitor/test/browser.ini", "devtools/client/netmonitor/test/browser_net_filter-value-preserved.js"], "git_node": null, "git_parents": [null], "node": "5ae78f2863c680529abed3a69bde02e25cafa8ee", "parents": ["24e1c29b04c69fc6c6411c43cd9c42e60199c597"], "tags": []}], "date": 1559862304, "git_changesets": [null, null], "user": "ncsoregi@mozilla.com"}, "11392": {"changesets": [{"author": "Csoregi Natalia \u003cncsoregi@mozilla.com\u003e", "branch": "default", "desc": "Backed out 4 changesets (bug 1551183) for failures on test_default_theme.html. a=backout\n\nBacked out changeset 092bef8c0d6e (bug 1551183)\nBacked out changeset 259f5bcec259 (bug 1551183)\nBacked out changeset 76077274869a (bug 1551183)\nBacked out changeset ffa52c63ff47 (bug 1551183)", "files": ["mobile/android/app/mobile.js", "mobile/android/chrome/content/browser.js", "security/manager/ssl/tests/unit/test_cert_storage.js", "toolkit/components/extensions/Extension.jsm", "toolkit/mozapps/extensions/AddonManagerStartup.cpp", "toolkit/mozapps/extensions/amIAddonManagerStartup.idl", "toolkit/mozapps/extensions/internal/XPIDatabase.jsm", "toolkit/mozapps/extensions/test/mochitest/chrome.ini", "toolkit/mozapps/extensions/test/mochitest/test_default_theme.html", "toolkit/mozapps/extensions/test/moz.build"], "git_node": null, "git_parents": [null], "node": "3b4af55e6edc19cd481737216fd5616d28bb61b0", "parents": ["5ae78f2863c680529abed3a69bde02e25cafa8ee"], "tags": []}], "date": 1559874915, "git_changesets": [null], "user": "ncsoregi@mozilla.com"}, "11393": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nbe -\u003e 8f4dc460df8d\nbn -\u003e 9a98e851fb0c\nbr -\u003e 44f12dfa4f9b\nda -\u003e b25d62ab48f0\neo -\u003e e814491d6c1c\nes-AR -\u003e 546261223e4c\nfr -\u003e c85155f2ca65\ngn -\u003e acf764632d0f\nid -\u003e e70d25a24bde\nit -\u003e a787d8f269ba\nka -\u003e 12756a95eb8a\nlt -\u003e ed2780aa566f\