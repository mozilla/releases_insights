, "third_party/rust/sha-1/LICENSE-MIT", "third_party/rust/sha-1/benches/lib.rs", "third_party/rust/sha-1/examples/sha1sum.rs", "third_party/rust/sha-1/src/consts.rs", "third_party/rust/sha-1/src/lib.rs", "third_party/rust/sha-1/src/utils.rs", "third_party/rust/sha-1/tests/data/one_million_a.bin", "third_party/rust/sha-1/tests/data/sha1.blb", "third_party/rust/sha-1/tests/lib.rs", "third_party/rust/ws/examples/html_chat.rs"], "git_node": null, "git_parents": [null, null], "node": "092e0808f3f8f921164933e96b42100e4bf4192f", "parents": ["f25162fe921d7923006ee4e0cd9467a1962d6f9e", "30817917ace8ef05f5badd1522f7f1adac64d1e5"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1551222 - Fix stacktrace for throwing console evaluated expressions. r=bhackett.\n\nWe now have stacktrace for expressions evaluated in the console\nthat throws, and we are stripping any frames that are devtools\ninternals.\nBut the way we were doing this meant that we were only having\none `debugger eval code` frame, even if the expression in the console\nhad multiple frames.\nAlso, if an expression was throwing without having any `debugger eval\ncode` frame (e.g. expression with SyntaxError), we were sending internal\nframes.\nThis patch should fix those 2 cases and a linux 64 ccov intermittent\ncaused by a different line number for an internal frame in a fixture\npacket.\nTests cases are added to the existing mochitest to ensure this\nworks as expected.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30934", "files": ["devtools/client/webconsole/test/fixtures/stubs/evaluationResult.js", "devtools/client/webconsole/test/mochitest/browser_webconsole_eval_error.js", "devtools/server/actors/webconsole/utils.js"], "git_node": null, "git_parents": [null], "node": "867447201d5d56927638aaed1423fb38370ddfc2", "parents": ["092e0808f3f8f921164933e96b42100e4bf4192f"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1549388 - Render non-string messageText with GripMessageBody. r=bgrins.\n\nSometimes the messageText can be a longString, which was crashing\nthe whole console output since we were always assuming messageText\nwas a plain string.\nWe now render non-string messageText with reps so it handles longStrings.\nA mocha test is added to ensure this works as expected.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30875", "files": ["devtools/client/webconsole/components/message-types/ConsoleApiCall.js", "devtools/client/webconsole/test/components/console-api-call.log-messages.test.js"], "git_node": null, "git_parents": [null], "node": "b90c24bb6358c8ad4b0b56cd312457e0548c26f3", "parents": ["867447201d5d56927638aaed1423fb38370ddfc2"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1548701 - Do no silence curl in `get_and_diffoscope`. r=tomprince\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30137", "files": ["taskcluster/docker/diffoscope/get_and_diffoscope"], "git_node": null, "git_parents": [null], "node": "82c168608de778da5ab22efe0d884b2b283c0edd", "parents": ["b90c24bb6358c8ad4b0b56cd312457e0548c26f3"], "tags": []}, {"author": "Cameron McCormack \u003ccam@mcc.id.au\u003e", "branch": "default", "desc": "Bug 1505908 - Add Gecko profiler labels for when the style threads are doing work. r=emilio\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30869", "files": ["layout/style/GeckoBindings.cpp", "layout/style/GeckoBindings.h", "layout/style/ServoBindings.toml", "servo/components/style/Cargo.toml", "servo/components/style/driver.rs", "servo/components/style/gecko/mod.rs", "servo/components/style/gecko/profiler.rs", "servo/components/style/macros.rs", "servo/components/style/parallel.rs", "servo/ports/geckolib/Cargo.toml", "servo/ports/geckolib/glue.rs", "toolkit/library/rust/shared/Cargo.toml"], "git_node": null, "git_parents": [null], "node": "23396874909ff1d79eb198fa300c81bd66aafa2b", "parents": ["82c168608de778da5ab22efe0d884b2b283c0edd"], "tags": []}, {"author": "Chris Pearce \u003ccpearce@mozilla.com\u003e", "branch": "default", "desc": "Bug 1547892 - Load video element in VideoDocument slightly later during load. r=bzbarsky\n\nCurrently when we create the video inside a VideoDocument, the PresShell isn't\ncreated yet. This means the video element can't access information about the\ncompositor, which means it doesn't know whether it can create a hardware\naccelerated video decoder, and so we end up falling back to using a software\ndecoder.\n\nSo this patch moves the creation of the video element to slightly later in the\nload of a VideoDocument, so that the PresShell is available when we create the\nVideoDocument's video element. This means VideoDocuments's video decoder can be\nhardware accelerated\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30614", "files": ["dom/html/MediaDocument.h", "dom/html/PluginDocument.cpp", "dom/html/VideoDocument.cpp"], "git_node": null, "git_parents": [null], "node": "2d94f58711b3c1b501d72ed05845198fc3aeb6e8", "parents": ["23396874909ff1d79eb198fa300c81bd66aafa2b"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1548994 - Release nsCompleteUpgradeData.mUpgradeListener on the main thread as it is not always threadsafe r=dragana\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30022", "files": ["netwerk/protocol/http/nsHttpConnectionMgr.cpp"], "git_node": null, "git_parents": [null], "node": "aa14d710b4ccd7ff72693f988c006aff700b9183", "parents": ["2d94f58711b3c1b501d72ed05845198fc3aeb6e8"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1551055 - StoragePrincipal should be supported by localStorage - part 1, r=asuth\n\nDifferential Revision: https://phabricator