", "mobile/android/base/java/org/mozilla/gecko/telemetry/pingbuilders/TelemetryActivationPingBuilder.java", "mobile/android/base/java/org/mozilla/gecko/telemetry/pingbuilders/TelemetryPingBuilder.java"], "git_node": null, "git_parents": [null], "node": "91bc05242c6f02a5d30c71557693129303e7067e", "parents": ["9abb460fe84149f3d6e6579a914c70ff50efe7dc"], "tags": []}, {"author": "Ciure Andrei \u003caciure@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 91bc05242c6f (bug 1534451) for causing AdvertisingUtil.java build bustages CLOSED TREE", "files": ["mobile/android/app/build.gradle", "mobile/android/base/java/org/mozilla/gecko/BrowserApp.java", "mobile/android/base/java/org/mozilla/gecko/advertising/AdvertisingUtil.java", "mobile/android/base/java/org/mozilla/gecko/telemetry/TelemetryActivationPingDelegate.java", "mobile/android/base/java/org/mozilla/gecko/telemetry/TelemetryCorePingDelegate.java", "mobile/android/base/java/org/mozilla/gecko/telemetry/TelemetryDispatcher.java", "mobile/android/base/java/org/mozilla/gecko/telemetry/TelemetryUploadService.java", "mobile/android/base/java/org/mozilla/gecko/telemetry/pingbuilders/TelemetryActivationPingBuilder.java", "mobile/android/base/java/org/mozilla/gecko/telemetry/pingbuilders/TelemetryPingBuilder.java"], "git_node": null, "git_parents": [null], "node": "d6e21ffd8ecceee564afa0c7c8b1bcf61fbd6aff", "parents": ["91bc05242c6f02a5d30c71557693129303e7067e"], "tags": []}, {"author": "Wes Kocher \u003cwkocher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1550895 - Disable some additional frequently failing geckoview wpt tests\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30987", "files": ["testing/web-platform/meta/css/css-backgrounds/border-image-width-005.xht.ini", "testing/web-platform/meta/css/css-backgrounds/border-image-width-007.xht.ini", "testing/web-platform/meta/css/css-grid/grid-items/grid-items-sizing-alignment-001.html.ini", "testing/web-platform/meta/html/brow