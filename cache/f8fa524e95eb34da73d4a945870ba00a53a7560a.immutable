"], "tags": []}, {"author": "Bas Schouten \u003cbschouten@mozilla.com\u003e", "branch": "default", "desc": "Bug 1272500: Make cairo-surface-wrapper not double-apply device transform. r=jrmuizel, a=gchang\n\nMozReview-Commit-ID: EkWqiPEidE3", "files": ["gfx/cairo/cairo/src/cairo-surface-wrapper.c"], "git_node": null, "git_parents": [null], "node": "29268ff33b0e01fadae48653a2bd68a8689fd410", "parents": ["07337b29c24dc9a8415b46a32b8679fe3c6d89ed"], "tags": []}, {"author": "Natanael Copa \u003cncopa@alpinelinux.org\u003e", "branch": "default", "desc": "Bug 1274732 - Avoid allocate 128k buffer on stack. r=mcmanus, a=sylvestre\n\nMove the 128k buffer for brotli decompression to the heap instead of stack.\nThis fixes crash with musl libc which provides 80k stack by default.\n\nMozReview-Commit-ID: 9cDlFO5eoi1", "files": ["netwerk/streamconv/converters/nsHTTPCompressConv.cpp"], "git_node": null, "git_parents": [null], "node": "5205b34086e2aa12b8cdd74a32f6756cabab9045", "parents": ["29268ff33b0e01fadae48653a2bd68a8689fd410"], "tags": []}], "date": 1467030290, "git_changesets": [null, null, null, null, null, null, null, null], "user": "cbook@mozilla.com"}, "6112": {"changesets": [{"author": "peter chang \u003cpchang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1201874 - create core text font with correct size. r=lsalzman, a=gchang\n\nMozReview-Commit-ID: GXH7ExjMI2m", "files": ["gfx/cairo/cairo/src/cairo-quartz-font.c"], "git_node": null, "git_parents": [null], "node": "28a5dc1ea7698b92692d9f6062d9924c0f427d25", "parents": ["5205b34086e2aa12b8cdd74a32f6756cabab9045"], "tags": []}, {"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1256314 - Fix twitching of RDM toolbar on startup. r=jryans, a=gchang\n\nMozReview-Commit-ID: GQbdVwfvh1N", "files": ["devtools/client/themes/responsivedesign.inc.css"], "git_node": null, "git_parents": [null], "node": "49ba9e8f7067c35632159a80d3424de29e2528df", "parents": ["28a5dc1ea7698b92692d9f6062