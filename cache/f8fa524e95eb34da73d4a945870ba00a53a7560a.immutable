git_parents": [null], "node": "617e837ee60d0a65f5d814a6e4a2f4f0439fddfa", "parents": ["8a797d7d5d2d5ed4c97b6c06f2dc69972c94ebb6"], "tags": []}, {"author": "Seth Fowler \u003cmark.seth.fowler@gmail.com\u003e", "branch": "default", "desc": "Bug 1284350 - Revert \"Bug 1261554 (Part 1) - Prepare for implementing in-displayport visibility tracking. r=mstange\" on a CLOSED TREE. a=lizzard\n\nThis reverts commit b53279c32e8d23b74b331b9cfc5a1390a2d81aaa.\n", "files": ["dom/base/nsImageLoadingContent.cpp", "layout/base/nsIPresShell.h", "layout/base/nsPresShell.cpp", "layout/base/nsPresShell.h", "layout/generic/Visibility.h", "layout/generic/nsFrame.cpp", "layout/generic/nsIFrame.h", "layout/generic/nsImageFrame.cpp", "layout/svg/SVGFEImageFrame.cpp", "layout/svg/nsSVGImageFrame.cpp"], "git_node": null, "git_parents": [null], "node": "cbacbb7c2c3523d036f737c9dc6c4406d14ade2b", "parents": ["617e837ee60d0a65f5d814a6e4a2f4f0439fddfa"], "tags": []}], "date": 1468015879, "git_changesets": [null, null, null, null], "user": "mfowler@mozilla.com"}, "6191": {"changesets": [{"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1282992 - Improve sync event loop shutdown in workers, r=khuey a=ritu", "files": ["dom/workers/WorkerPrivate.cpp"], "git_node": null, "git_parents": [null], "node": "9fa604a17de720cc70a2dcfb966f4e660d3bfe3f", "parents": ["cbacbb7c2c3523d036f737c9dc6c4406d14ade2b"], "tags": []}, {"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 1266882 - Ensure the return value of CreateBR is addrefed in CopyLastEditableChildStyles. r=masayuki a=lizzard", "files": ["editor/libeditor/nsHTMLEditor.cpp"], "git_node": null, "git_parents": [null], "node": "8e54a7dccda8dfa6d61f45d4804de5c95a205fb7", "parents": ["9fa604a17de720cc70a2dcfb966f4e660d3bfe3f"], "tags": []}], "date": 1468017790, "git_changesets": [null, null], "user": "kwierso@gmail.com"}, "6192": {"changesets": [{"author": "Jorg 