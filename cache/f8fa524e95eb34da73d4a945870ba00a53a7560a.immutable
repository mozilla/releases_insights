d/widgets/filter-widget.css"], "git_node": null, "git_parents": [null], "node": "03b0c9698c91a81d9267cf1774cce1ca04b2533c", "parents": ["b7451fcb457865eff7efb5860cfe267165bd97f1"], "tags": []}], "date": 1467731003, "git_changesets": [null, null], "user": "cbook@mozilla.com"}, "6169": {"changesets": [{"author": "Michael Ratcliffe \u003cmratcliffe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1244584 - Make GCLI tooltip hide after the first run experience r=jwalker, a=gchang", "files": ["devtools/client/shared/developer-toolbar.js", "devtools/shared/gcli/source/lib/gcli/ui/intro.js"], "git_node": null, "git_parents": [null], "node": "f1d263387b33c2f1b90f9b8d73b8f1ca2324a3d2", "parents": ["03b0c9698c91a81d9267cf1774cce1ca04b2533c"], "tags": []}, {"author": "Patrick Brosset \u003cpbrosset@mozilla.com\u003e", "branch": "default", "desc": "Bug 1280121 - Re-enable the font panel by default. a=gchang\n\nMozReview-Commit-ID: Lg7yvfkwqx5", "files": ["devtools/client/preferences/devtools.js"], "git_node": null, "git_parents": [null], "node": "673b03845fd8d259a71784754f47013ebc0440be", "parents": ["f1d263387b33c2f1b90f9b8d73b8f1ca2324a3d2"], "tags": []}, {"author": "aleth \u003caleth@instantbird.org\u003e", "branch": "default", "desc": "Bug 1272322 - Ensure PlacesRemoteTabsAutocompleteProvider doesn't fail when sync isn't built. r=mak, a=gchang", "files": ["toolkit/components/places/PlacesRemoteTabsAutocompleteProvider.jsm"], "git_node": null, "git_parents": [null], "node": "cc80bc0bb6a7e7de308d32c5b7a67ace4d1f6dda", "parents": ["673b03845fd8d259a71784754f47013ebc0440be"], "tags": []}, {"author": "Ralph Giles \u003cgiles@mozilla.com\u003e", "branch": "default", "desc": "Bug 1282214 - Make mp4parse read buffer fallible. r=kinetik, a=gchang\nThe rust mp4parse demuxer allocates a temporary buffer for the\ncontainer header. The size of this buffer is clipped to 1 MB but\nwe've seen some crashes in low memory conditions. Presumedly the\nsystem is too fragmented to allocate the buffer. In that case playing\nthe video is probably impossible, but it's better to return an error\nrather than crash.\n\nReplace the std::vector instance with an nsTArray so we can check\nfor allocation failure.\n\nMozReview-Commit-ID: 23QG28VxkPk", "files": ["media/libstagefright/binding/MP4Metadata.cpp"], "git_node": null, "git_parents": [null], "node": "6ed47505536deec0da00473df5d068a5ea3e6353", "parents": ["cc80bc0bb6a7e7de308d32c5b7a67ace4d1f6dda"], "tags": []}], "date": 1467731268, "git_changesets": [null, null, null, null], "user": "cbook@mozilla.com"}, "6170": {"changesets": [{"author": "Mark Hammond \u003cmhammond@skippinet.com.au\u003e", "branch": "default", "desc": "Bug 1279224 - remove all Sync promotions from doorhangers (beta version). r=adw, a=gchang\nMozReview-Commit-ID: 8QELFxqM6Av", "files": ["browser/base/content/browser.css", "browser/base/content/browser.xul", "browser/base/content/popup-notifications.inc", "browser/base/content/urlbarBindings.xml", "browser/components/nsBrowserGlue.js", "browser/themes/linux/browser.css", "browser/themes/osx/browser.css", "browser/themes/windows/browser-aero.css", "browser/themes/windows/browser.css", "toolkit/content/widgets/popup.xml"], "git_node": null, "git_parents": [null], "node": "274a291aa2c85528ffeb988f0b1b0b61c12136b8", "parents": ["6ed47505536deec0da00473df5d068a5ea3e6353"], "tags": []}], "date": 1467731326, "git_changesets": [null], "user": "cbook@mozilla.com"}, "6171": {"changesets": [{"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1280667 - Don't update the callback transform if the APZ repaint request was rejected by a concurrent main-thread scroll position update. r=botond a=lizzard\n\nMozReview-Commit-ID: 7jCdyN9H6T8", "files": ["gfx/layers/apz/util/APZCCallbackHelper.cpp"], "git_node": null, "git_parents": [null], "node": "6ad50d4d6f7b3c96801a3ecd1afe5464705a0d87", "parents": ["274a291aa2c85528ffeb988f0b1b0b61c12136b8"], "tags": []}], "date": 1467733743, "git_changesets": [null], "user": "kgupta@mozilla.com"}, "6172": {"changesets": [{"author": "Andrew Swan \u003caswan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1283622 Sign devtools test addon r=me a=test-only\n\nMozReview-Commit-ID: 4lGqR7hkrrk", "files": ["devtools/client/debugger/test/mochitest/addon-webext-contentscript.xpi"], "git_node": null, "git_parents": [null], "node": "52fb1d141cc9c18d7b7971d778b8976e43f360dc", "parents": ["6ad50d4d6f7b3c96801a3ecd1afe5464705a0d87"], "tags": []}], "date": 1467746221, "git_changesets": [null], "user": "aswan@mozilla.com"}, "6173": {"changesets": [{"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1283674 P0 Drop cached controlling ServiceWorker ref when ServiceWorkerContainer window is disconnect. r=baku a=lizzard", "files": ["dom/workers/ServiceWorkerContainer.cpp"], "git_node": null, "git_parents": [null], "node": "b41e247f4542e1c024473f4aeb81f1c15f6adbf8", "parents": ["52fb1d141cc9c18d7b7971d778b8976e43f360dc"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1283674 P1 Make ServiceWorkerContainer::GetController() work gracefully when its window is disconnected. r=baku a=lizzard", "files": ["dom/workers/ServiceWorkerContainer.cpp", "dom/workers/ServiceWorkerManager.cpp"], "git_node": null, "git_parents": [null], "node": "9170e8ad0e8039c052c417a9211f2ef2aac34a0a", "parents": ["b41e247f4542e1c024473f4aeb81f1c15f6adbf8"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1283674 P2 Add wpt test verifying serviceWorker.controller behavior on disconnected window. r=baku a=lizzard", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/service-workers/service-worker/controller-on-disconnect.https.html"], "git_node": null, "git_parents": [null], "node": "cda06c358893d526741f3165800d3406111749bc", "parents": ["9170e8ad0e8039c052c417a9211