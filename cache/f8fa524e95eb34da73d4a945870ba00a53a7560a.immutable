l.java", "mobile/android/base/java/org/mozilla/gecko/util/Experiments.java", "mobile/android/base/java/org/mozilla/gecko/util/UnusedResourcesUtil.java", "mobile/android/base/moz.build", "mobile/android/base/resources/drawable-large-hdpi-v11/firstrun_background_coffee.png", "mobile/android/base/resources/drawable-large-xhdpi-v11/firstrun_background_coffee.png", "mobile/android/base/resources/drawable-large-xxhdpi-v11/firstrun_background_coffee.png", "mobile/android/base/resources/drawable-nodpi/firstrun_background_coffee.png", "mobile/android/base/resources/layout/firstrun_welcome_fragment.xml", "mobile/android/base/resources/values-large-v11/dimens.xml", "mobile/android/base/resources/values/dimens.xml", "mobile/android/base/strings.xml.in"], "git_node": null, "git_parents": [null], "node": "1510116bd5e58a9194731e4b3f715008e06625ee", "parents": ["c5411e82e576319387b3cfe45cfcd5ac917d067b"], "tags": []}], "date": 1465531865, "git_changesets": [null], "user": "cbook@mozilla.com"}, "6058": {"changesets": [{"author": "ffxbld", "branch": "default", "desc": "No bug, Automated blocklist update from host bld-linux64-spot-338 - a=blocklist-update", "files": ["browser/app/blocklist.xml"], "git_node": null, "git_parents": [null], "node": "4219592e7c65196a9cf76fa0af060409d730e648", "parents": ["1510116bd5e58a9194731e4b3f715008e06625ee"], "tags": []}], "date": 1465640094, "git_changesets": [null], "user": "ffxbld"}, "6059": {"changesets": [{"author": "David Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "Bug 1278605 - ensure that nsICertOverrideService can be implemented in JS r=Cykesiopkai, a=lizzard\n\nMozReview-Commit-ID: KSVeraWuRPZ", "files": ["security/manager/ssl/nsNSSCallbacks.cpp", "security/manager/ssl/tests/unit/test_js_cert_override_service.js", "security/manager/ssl/tests/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "2539cf53e85d348397cdee353061a34e8b0f11fb", "parents": ["4219592e7c65196a9cf76fa0af060409d730e648"], "tags": []}], "date": 1465804474, "git_changesets": [null], "user": "cbook@mozilla.com"}, "6060": {"changesets": [{"author": "Dave Hunt \u003cdhunt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1271911 - Enable the browser.tabs.remote.force-enable preference when using e10s. r=maja_zf\n\nMozReview-Commit-ID: BWqRrhPx7h8", "files": ["testing/marionette/harness/marionette/runner/base.py", "testing/marionette/harness/session/runner/base.py"], "git_node": null, "git_parents": [null], "node": "b8a9cd794b940f3433b3c89686575656c8d0ac14", "parents": ["2539cf53e85d348397cdee353061a34e8b0f11fb"], "tags": []}, {"author": "Dave Hunt \u003cdhunt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1271911 - Wait for the expected notifications in test_notifications.py to avoid transient popups. r=whimboo, a=test-only\n\nMozReview-Commit-ID: ICsIE1wZctR", "files": ["testing/firefox-ui/tests/puppeteer/test_notifications.py"], "git_node": null, "git_parents": [null], "node": "1dcf48bac87483bef3afb633cfa9856ee047772b", "parents": ["b8a9cd794b940f3433b3c89686575656c8d0ac14"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@mozilla.com\u003e", "branch": "default", "desc": "Bug 1275249 - Update UI tests to get property where applicable; r=whimboo, a=test-only\n\nIn bug 1272653, Get Element Attribute was split into Get Element Attribute\nfor attributes and boolean attributes, and Get Element Property for\nproperties.\n\nThis patch addresses the fallout in the Firefox UI tests caused by\nthose patches.\n\nMozReview-Commit-ID: 9S4epjmpU0o", "files": ["testing/firefox-ui/tests/functional/security/test_enable_privilege.py", "testing/firefox-ui/tests/functional/security/test_ssl_disabled_error_page.py", "testing/firefox-ui/tests/functional/security/test_submit_unencrypted_info_warning.py", "testing/firefox-ui/tests/functional/security/test_unknown_issuer.py"], "git_node": null, "git_parents": [null], "node": "f23397230676818b32efb7baaeac197eac9a283a", "parents": ["1dcf48bac87483bef3afb633cfa9856ee047772b"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@mozilla.com\u003e", "branch": "default", "desc": "Bug 1275311 - Get property when in content in security notification UI test; r=whimboo, a=test-only\n\nMozReview-Commit-ID: 1mIed8b8uXY", "files": ["testing/firefox-ui/tests/functional/security/test_security_notification.py"], "git_node": null, "git_parents": [null], "node": "3e95203b4cab68e55bc906c60f00f39d883d813d", "parents": ["f23397230676818b32efb7baaeac197eac9a283a"], "tags": []}], "date": 1465854420, "git_changesets": [null, null, null, null], "user": "cbook@mozilla.com"}, "6061": {"changesets": [{"author": "Kai Engert \u003ckaie@kuix.de\u003e", "branch": "default", "desc": "Bug 1258375, bump NSS version requirement to 3.24, r=martin.thomson, a=dveditz", "files": ["old-configure.in"], "git_node": null, "git_parents": [null], "node": "773192ea404cb80f87268e17ee8786999cf717e6", "parents": ["3e95203b4cab68e55bc906c60f00f39d883d813d"], "tags": []}], "date": 1465911113, "git_changesets": [null], "user": "kaie@kuix.de"}, "6062": {"changesets": [{"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1275095 - Enable MOZ_ANDROID_CGM for all builds; r=snorp a=lizzard\n\nCurrently, MOZ_ANDROID_CGM is only enabled for Nightly builds. We want\nto enable it for all builds and let it ride the trains through 48.", "files": ["mobile/android/moz.configure"], "git_node": null, "git_parents": [null], "node": "6845cc4241afe9194bc0caf222073de3fbc612d8", "parents": ["773192ea404cb80f87268e17ee8786999cf717e6"], "tags": []}, {"author": "Kit Cambridge \u003ckcambridge@mozilla.com\u003e", "branch": "default", "desc": "Bug 1278435 - Update DOM interface tests to reflect shipping Push on Android. r=baku a=testonly\n\nMozReview-Commit-ID: AvTW8zDPjAY", "files": ["dom/tests/mochitest/general/test_interfaces.html", "dom/workers/test/serviceworkers/test_serviceworker_interfaces.js", "dom/workers/test/test_worker_interfaces.js"], "git_node": null, "git_parents": [null], "node": "e0eca48096b6d8ae32b7bc01cabc66e5990c0729", "parents": ["6845cc4241afe9194bc0caf222073de3fbc612d8"], "tags": []}], "date": 1466007649, "git_changesets": [null, null], "user": "kcambridge@mozilla.com"}, "6063": {"changesets": [{"author": "Kit Cambridge \u003ckcambridge@mozilla.com\u003e", "branch": "default", "desc": "Bug 1278851 - Enable service worker notifications everywhere except for non-release B2G. r=baku a=sylvestre\n\nMozReview-Commit-ID: InG420vpNtA", "files": ["b2g/app/b2g.js", "browser/app/profile/firefox.js", "dom/workers/test/serviceworkers/test_serviceworker_interfaces.js", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "3dda03d4037e84f6a646ceb934e4e5e3afd7ec29", "parents": ["e0eca48096b6d8ae32b7bc01cabc66e5990c0729"], "tags": []}], "date": 1466008422, "git_changesets": [null], "user": "kcambridge@mozilla.com"}, "6064": {"changesets": [{"author": "Jim Mathies \u003cjmathies@mozilla.com\u003e", "branch": "default", "desc": "Bug 1277882 - Disable e10s on Linux when recent accessibility use is detected. r=felipe, a=sylvestre\n\nMozReview-Commit-ID: 6RTPJedwwzh", "files": ["toolkit/xre/nsAppRunner.cpp", "widget/nsBaseWidget.cpp", "widget/nsBaseWidget.h"], "git_node": null, "git_parents": [null], "node": "0c04f1e07ec2163bbbd430a2492ddeeaab32c87b", "parents": ["3dda03d4037e84f6a646ceb934e4e5e3afd7ec29"], "tags": []}, {"author": "Mason Chang \u003cmchang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1276931. Add VsyncSource::Shutdown which shuts down global display. r=jrmuizel, a=sylvestre", "files": ["gfx/thebes/SoftwareVsyncSource.cpp", "gfx/thebes/SoftwareVsyncSource.h", "gfx/thebes/VsyncSource.cpp", "gfx/thebes/VsyncSource.h", "gfx/thebes/gfxAndroidPlatform.cpp", "gfx/thebes/gfxPlatform.cpp", "gfx/thebes/gfxPlatformMac.cpp", "gfx/thebes/gfxWindowsPlatform.cpp"], "git_node": null, "git_parents": [null], "node": "852b4aba1b7a2d3079be7287570214914c143a47", "parents": ["0c04f1e07ec2163bbbd430a2492ddeeaab32c87b"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1276027 - Add a Telemetry probe to track how often Firefox is used as the default handler. r=bsmedberg,rstrong, a=sylvestre\n\nMozReview-Commit-ID: Ar3MaKeUIdz", "files": ["browser/components/nsBrowserContentHandler.js", "toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "3113e731bfd9d3be3f9fb8226694e2256cd70f64", "parents": ["852b4aba1b7a2d3079be7287570214914c143a47"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1275339 - [ffmpeg] Don't assume AVFrame has a constant size. r=cpearce, a=al\n\nAn AVFrame has a different size between FFmpeg 0.10 and LibAV 0.8 though both have the same version number.\n\nForgot to add the fixes (twice now :( )\n\nMozReview-Commit-ID: DR3b3fqSngh", "files": ["dom/media/platforms/ffmpeg/FFmpegDataDecoder.cpp", "dom/media/platforms/ffmpeg/FFmpegLibWrapper.cpp", "dom/media/platforms/ffmpeg/FFmpegLibWrapper.h"], "git_node": null, "git_parents": [null], "node": "58590eb627383ea4df6dcbef985adefcac0dae91", "parents": ["3113e731bfd9d3be3f9fb8226694e2256cd70f64"], "tags": []}], "date": 1466028442, "git_changesets": [null, null, null, null], "user": "cbook@mozilla.com"}, "6065": {"changesets": [{"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1277698, r=bz, a=al\n\nMozReview-Commit-ID: JH5QUu357gc", "files": ["browser/components/feeds/FeedConverter.js"], "git_node": null, "git_parents": [null], "node": "da4a9eed33bdbc5f5bd1002cc07f998a1eb037fa", "parents": ["58590eb627383ea4df6dcbef985adefcac0dae91"], "tags": []}], "date": 1466028801, "git_changesets": [null], "user": "cbook@mozilla.com"}, "6066": {"changesets": [{"author": "Nick Thomas \u003cnthomas@mozilla.com\u003e", "branch": "THUNDERBIRD470b2_2016061601_RELBRANCH", "desc": "bug 1255245: ESR45 generates mar files with the wrong channel ID: Always modify update-settings.ini. r=bhearsum a=rkent", "files": ["tools/update-packaging/common.sh"], "git_node": null, "git_parents": [null], "node": "77c04596623e6a766d30421cc8c20101a18731a7", "parents": ["f2ec5ebc83b3095be413103699271983993b404a"], "tags": ["THUNDERBIRD_47_0b2_BUILD1", "THUNDERBIRD_47_0b2_RELEASE"]}], "date": 1466114438, "git_changesets": [null], "user": "kent@caspia.com"}, "6067": {"changesets": [{"author": "tbirdbld", "branch": "THUNDERBIRD470b2_2016061601_RELBRANCH", "desc": "Added THUNDERBIRD_47_0b2_RELEASE THUNDERBIRD_47_0b2_BUILD1 tag(s) for changeset 77c04596623e. DONTBUILD CLOSED TREE a=release", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "8aaf62bd9c037b23aa1d9a4e68cd5dfdd210a0a2", "parents": ["77c04596623e6a766d30421cc8c20101a18731a7"], "tags": []}, {"author": "tbirdbld", "branch": "default", "desc": "Automated checkin: version bump for thunderbird 47.0b2 release. DONTBUILD CLOSED TREE a=release", "files": ["config/milestone.txt"], "git_node": null, "git_parents": [null], "node": "331c922bff8152bc967e9065a97566f9f712e434", "parents": ["da4a9eed33bdbc5f5bd1002cc07f998a1eb037fa"], "tags": []}], "date": 1466166730, "git_changesets": [null, null], "user": "tbirdbld"}, "6068": {"changesets": [{"author": "Rail Aliiev \u003crail@mozilla.com\u003e", "branch": "default", "desc": "Bug 1280634 - Backed out changeset 331c922bff81 r=me a=release\n\nMozReview-Commit-ID: DW9eoJ42pxZ", "files": ["config/milestone.txt"], "git_node": null, "git_parents": [null], "node": "d9ea8a5c1694f3bb8a6e819c90f97f0fd0565adf", "parents": ["331c922bff8152bc967e9065a97566f9f712e434"], "tags": []}], "date": 1466172819, "git_changesets": [null], "user": "raliiev@mozilla.com"}, "6069": {"changesets": [{"author": "ffxbld", "branch": "default", "desc": "No bug, Automated blocklist update from host bld-linux64-spot-572 - a=blocklist-update", "files": ["browser/app/blocklist.xml"], "git_node": null, "git_parents": [null], "node": "cec857b11eaf51d6c04368f65fef17e017a0f96c", "parents": ["d9ea8a5c1694f3bb8a6e819c90f97f0fd0565adf"], "tags": []}], "date": 1466244917, "git_changesets": [null], "user": "ffxbld"}, "6070": {"changesets": [{"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1279208, r=mak, a=al\n\nMozReview-Commit-ID: KOuTjwn9MSx", "files": ["browser/components/places/PlacesUIUtils.jsm", "toolkit/components/places/FaviconHelpers.cpp"], "git_node": null, "git_parents": [null], "node": "ef99d8fb971d35ec17bf6797a8064bdc6710558f", "parents": ["cec857b11eaf51d6c04368f65fef17e017a0f96c"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1279208, followup, rs=bustage/dao, a=al\n\nMozReview-Commit-ID: BQo5WCM9us3", "files": ["browser/components/places/PlacesUIUtils.jsm"], "git_node": null, "git_parents": [null], "node": "b30c1d73a22ad58da7999d500f411eae5ede6ea2", "parents": ["ef99d8fb971d35ec17bf6797a8064bdc6710558f"], "tags": []}, {"author": "Brian Birtles \u003cbirtles@gmail.com\u003e", "branch": "default", "desc": "Bug 1276688 part 1 - Handle entries arrays where we don't have a property value at the 0.0/1.0 offset; r=heycam, a=lizzard\n\nMozReview-Commit-ID: GCCF4taOC6z", "files": ["dom/animation/KeyframeUtils.cpp"], "git_node": null, "git_parents": [null], "node": "5a99e549fb2de1065d17b8101289c2127beec910", "parents": ["b30c1d73a22ad58da7999d500f411eae5ede6ea2"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1108052 - Remove empty event regions display items because they only slow things down and can add extraneous layers. r=mstange, a=sylvestre\n\nMozReview-Commit-ID: JkXGiudjBpe", "files": ["layout/base/FrameLayerBuilder.cpp", "layout/base/nsDisplayList.cpp", "layout/base/nsDisplayList.h", "layout/generic/nsFrame.cpp"], "git_node": null, "git_parents": [null], "node": "11986e1994456d9d8c4a006caa8e15bd1c8410f1", "parents": ["5a99e549fb2de1065d17b8101289c2127beec910"], "tags": []}], "date": 1466431454, "git_changesets": [null, null, null, null], "user": "cbook@mozilla.com"}, "6071": {"changesets": [{"author": "Michal Novotny \u003cmichal.novotny@gmail.com\u003e", "branch": "default", "desc": "Bug 1267980 - Leak buffers in CacheFileChunk and CacheFileMetadata during shutdown, r=honzab, a=sylvestre", "files": ["netwerk/cache2/CacheFileChunk.cpp", "netwerk/cache2/CacheFileIOManager.cpp", "netwerk/cache2/CacheFileIOManager.h", "netwerk/cache2/CacheFileMetadata.cpp", "netwerk/cache2/CacheFileUtils.cpp", "netwerk/cache2/CacheFileUtils.h", "netwerk/cache2/CacheObserver.cpp", "netwerk/cache2/CacheObserver.h"], "git_node": null, "git_parents": [null], "node": "ec62fd62c9a7abd82517cd0243d166566fa776df", "parents": ["11986e1994456d9d8c4a006caa8e15bd1c8410f1"], "tags": []}], "date": 1466431614, "git_changesets": [null], "user": "cbook@mozilla.com"}, "6072": {"changesets": [{"author": "Eric Rahm \u003cerahm@mozilla.com\u003e", "branch": "default", "desc": "Bug 1274913 - Move PDM log definition to header. r=njn a=sylvestre", "files": ["dom/media/platforms/PlatformDecoderModule.cpp", "dom/media/platforms/PlatformDecoderModule.h", "dom/media/platforms/agnostic/OpusDecoder.cpp", "dom/media/platforms/agnostic/VPXDecoder.cpp", "dom/media/platforms/agnostic/VorbisDecoder.cpp", "dom/media/platforms/apple/AppleATDecoder.cpp", "dom/media/platforms/apple/AppleCMLinker.cpp", "dom/media/platforms/apple/AppleVDADecoder.cpp", "dom/media/platforms/apple/AppleVDALinker.cpp", "dom/media/platforms/apple/AppleVTDecoder.cpp", "dom/media/platforms/apple/AppleVTLinker.cpp", "dom/media/platforms/ffmpeg/FFmpegLog.h", "dom/media/platforms/gonk/GonkAudioDecoderManager.cpp", "dom/media/platforms/gonk/GonkMediaDataDecoder.cpp", "dom/media/platforms/gonk/GonkVideoDecoderManager.cpp", "dom/media/platforms/moz.build", "dom/media/platforms/omx/GonkOmxPlatformLayer.cpp", "dom/media/platforms/omx/OmxDataDecoder.cpp", "dom/media/platforms/omx/OmxPlatformLayer.cpp", "dom/media/platforms/omx/OmxPromiseLayer.cpp", "dom/media/platforms/wmf/MFTDecoder.cpp", "dom/media/platforms/wmf/WMFAudioMFTManager.cpp", "dom/media/platforms/wmf/WMFMediaDataDecoder.cpp", "dom/media/platforms/wmf/WMFVideoMFTManager.cpp"], "git_node": null, "git_parents": [null], "node": "9798772706750302d87a689cbbf056ae04244f80", "parents": ["ec62fd62c9a7abd82517cd0243d166566fa776df"], "tags": ["FIREFOX_48_0b2_BUILD2", "FIREFOX_48_0b2_RELEASE"]}], "date": 1466439279, "git_changesets": [null], "user": "erahm@mozilla.com"}, "6073": {"changesets": [{"author": "ffxbld", "branch": "MOBILE480b2_2016062017_RELBRANCH", "desc": "Automated checkin: version bump for fennec 48.0b2 release. DONTBUILD CLOSED TREE a=release", "files": [], "git_node": null, "git_parents": [null], "node": "a0c00c01650f7e18674d6776d4d090a2d8f67c35", "parents": ["9798772706750302d87a689cbbf056ae04244f80"], "tags": ["FENNEC_48_0b2_BUILD1", "FENNEC_48_0b2_RELEASE"]}, {"author": "ffxbld", "branch": "MOBILE480b2_2016062017_RELBRANCH", "desc": "Added FENNEC_48_0b2_RELEASE FENNEC_48_0b2_BUILD1 tag(s) for changeset a0c00c01650f. DONTBUILD CLOSED TREE a=release", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "90ef247f979e37eace3d4fe67fb998ab5989345f", "parents": ["a0c00c01650f7e18674d6776d4d090a2d8f67c35"], "tags": []}], "date": 1466459014, "git_changesets": [null, null], "user": "ffxbld"}, "6074": {"changesets": [{"author": "Florian Qu\u00e8ze \u003cflorian@queze.net\u003e", "branch": "default", "desc": "Bug 1260820 - Search engine drop down closes when I change search engines by pressing Up/Down, r=Gijs, a=gchang", "files": ["browser/components/preferences/in-content/search.js"], "git_node": null, "git_parents": [null], "node": "35a4e516308e1f9edf72e0d81e8a4739b8d2cacc", "parents": ["9798772706750302d87a689cbbf056ae04244f80"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1265468 - Invalidate all layers when dragging a tab to a new window. r=nical, a=sylvestre", "files": ["gfx/layers/composite/ContainerLayerComposite.h", "gfx/layers/opengl/CompositorOGL.cpp", "layout/ipc/RenderFrameParent.cpp"], "git_node": null, "git_parents": [null], "node": "0d538c5500ce3294b44bf9ae5c5cf64ea7614fe7", "parents": ["35a4e516308e1f9edf72e0d81e8a4739b8d2cacc"], "tags": []}, {"author": "Robert Longson \u003clongsonr@gmail.com\u003e", "branch": "default", "desc": "Bug 1267272 - NULL pointer mozilla::dom::SVGSVGElement::GetIntrinsicHeight. r=seth, a=sylvestre", "files": ["dom/svg/crashtests/1267272-1.svg", "dom/svg/crashtests/crashtests.list", "dom/svg/crashtests/invalid-image.svg", "image/VectorImage.cpp"], "git_node": null, "git_parents": [null], "node": "d5072d52f4ca399349d3d4078eb574ac7941c0b1", "parents": ["0d538c5500ce3294b44bf9ae5c5cf64ea7614fe7"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1268462 - match main popup appearance in bookmarks toolbar submenus, r=dao, a=gchang\n\nMozReview-Commit-ID: OTbdzDGyjr", "files": ["browser/themes/linux/customizableui/panelUIOverlay.css"], "git_node": null, "git_parents": [null], "node": "126e28e88202c405e2f8e3bbec43f54986a61aa8", "parents": ["d5072d52f4ca399349d3d4078eb574ac7941c0b1"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1271574 - Purposefully leak the XUL_APP_FILE string passed to putenv. r=bsmedberg, a=sylvestre\n\nBefore bug 552864, the string was created with PR_smprintf, and\nPR_SetEnv'ed (which, under the hood, just calls putenv). PR_smprintf was\nallocating the string on the heap. Now, it's allocated on the stack, and\nstill putenv'ed.\n\nputenv kind of takes ownership of the strings it's being passed, so\nstack allocated strings are dangerous to use. It looks like we've been\nfairly lucky that it worked, presumably because compilers would keep the\nstack frame with the variable, but that's not guaranteed to happen, and\nin some case, doesn't.\n\nSo we strdup the string and purposefully leak it instead, which matches\nwhat happened before bug 552864, and is the only \"sane\" way to use\nputenv.", "files": ["b2g/app/B2GLoader.cpp", "b2g/app/nsBrowserApp.cpp", "browser/app/nsBrowserApp.cpp"], "git_node": null, "git_parents": [null], "node": "634aedddd904cf6b9004590dbc2f5491fe4474ff", "parents": ["126e28e88202c405e2f8e3bbec43f54986a61aa8"], "tags": []}], "date": 1466492594, "git_changesets": [null, null, null, null, null], "user": "cbook@mozilla.com"}, "6075": {"changesets": [{"author": "Matthew Wein \u003cmwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1271777 - Fix the 'MacCtr' typo in the commands API. r=kmag, a=sylvestre\n\nMozReview-Commit-ID: 2pVcqpfSRKT", "files": ["browser/components/extensions/schemas/commands.json"], "git_node": null, "git_parents": [null], "node": "ff2241804c184482e98b0aa349af13020c7a3b82", "parents": ["634aedddd904cf6b9004590dbc2f5491fe4474ff"], "tags": []}, {"author": "Kumar McMillan \u003ckumar.mcmillan@gmail.com\u003e", "branch": "default", "desc": "Bug 1273229 - auto-generate IDs for temp installs from dir path. r=kmag, a=lizzard\n\nMozReview-Commit-ID: JFuEVUZs2Ci", "files": ["toolkit/mozapps/extensions/internal/XPIProvider.jsm", "toolkit/mozapps/extensions/test/xpcshell/test_webextension_install.js"], "git_node": null, "git_parents": [null], "node": "28760febab263c51627b614a94b4143bbf8f5396", "parents": ["ff2241804c184482e98b0aa349af13020c7a3b82"], "tags": []}, {"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 1275707, part 1 - Factor out a common method for message manager size telemetry. r=billm, a=sylvestre", "files": ["dom/base/nsFrameMessageManager.cpp"], "git_node": null, "git_parents": [null], "node": "55c015d3fd1d9b750cd6d06a319613b142d5c32f", "parents": ["28760febab263c51627b614a94b4143bbf8f5396"], "tags": []}, {"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 1275707, part 2 - Remove numbers from the message manager message names. r=billm, a=sylvestre\n\nThere are a huge number of different message manager messages with\nnames of the form \"ublock0:sb:{N}\", where {N} is some number from 1 to\nover 1000. Having so many different keys seems to cause problems for\ntelemetry and makes it harder to tell how many messages of each type\nthere really are, so this patch combines them by eliminating any\ndigits. It will also help for the webdev tools that use channels with\nnames like \"debug:server1.conn5.child1:packet\". This will create some\nambiguity (eg there are some messages of the form \"ublock:sb:{N}\"),\nbut that should be a minor issue.", "files": ["dom/base/nsFrameMessageManager.cpp"], "git_node": null, "git_parents": [null], "node": "68879201fc65f28ce71eb98408c10e31b5329ad4", "parents": ["55c015d3fd1d9b750cd6d06a319613b142d5c32f"], "tags": []}, {"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 1275707, part 3 - Rename MESSAGE_MANAGER_MESSAGE_SIZE. r=baku, a=sylvestre\n\nNow that digits have been filtered out of the message manager message\nnames to avoid creating thousands of similar keys, we can reenable the\ntelemetry by renaming it. Also, update the description to address\nbsmedberg's comments, and add me to the list of alert emails.", "files": ["dom/base/nsFrameMessageManager.cpp", "toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "b9be098fc46520fae2f79e803284f7ea0fbacdd2", "parents": ["68879201fc65f28ce71eb98408c10e31b5329ad4"], "tags": []}, {"author": "Honza Bambas \u003chonzab.moz@firemni.cz\u003e", "branch": "default", "desc": "Bug 1275898 - Proper about:cache asyncOpen implementation + kill the disk entries loop hard on shutdown, r=michal, a=lizzard\n\nMozReview-Commit-ID: 3Tmvy45Iayu", "files": ["netwerk/cache2/CacheStorageService.cpp", "netwerk/protocol/about/nsAboutCache.cpp", "netwerk/protocol/about/nsAboutCache.h"], "git_node": null, "git_parents": [null], "node": "2a762ba88494113dff67f29216fadbabd9c03097", "parents": ["b9be098fc46520fae2f79e803284f7ea0fbacdd2"], "tags": []}], "date": 1466493093, "git_changesets": [null, null, null, null, null, null], "user": "cbook@mozilla.com"}, "6076": {"changesets": [{"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1277407 - Add Adjust sandbox keyfile to tree. r=sebastian, a=lizzard\n\nAdditionally, we add this file to the tree so it can be used by bug 1277553.\n\nThe following commit will add the docs explaining how to use the file I\nadded.\n\nThe added file contents are slurped directly into\nAdjustConstants.MOZ_INSTALL_TRACKING_ADJUST_SDK_APP_TOKEN. We get the sandbox\ntoken from the previously working value in [1].\n\nAn alternative solution would be to remove the assertion that\n`--with-adjust-sdk-keyfile` is specified and provide a default value if the key\nis not specified. However, after investigating bug 1277553, I dislike this\napproach because we lose the compile-time checks that a key file is specified,\nwhich is dangerous for release/beta builds where the key file may not be valid,\nwe push a release, and we don't get the data we expect.\n\nIdeally, we specify `--with-adjust-sdk-keyfile` for non-MOZILLA_OFFICIAL\nbuilds, but I don't know how to do that.\n\n[1]: https://hg.mozilla.org/mozilla-central/rev/ac75f8f4c01d#l1.26\n\nMozReview-Commit-ID: HPNgiwfzU5p", "files": ["mobile/android/base/adjust-sdk-sandbox.token"], "git_node": null, "git_parents": [null], "node": "3ee14b37d5d4328ba73459506ac632f10cb32eff", "parents": ["2a762ba88494113dff67f29216fadbabd9c03097"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1277407 - Add docs about using adjust sandbox & updating outdated info. r=sebastian, a=lizzard\n\nMozReview-Commit-ID: DW4ZflT8FrZ", "files": ["mobile/android/docs/adjust.rst"], "git_node": null, "git_parents": [null], "node": "599d69a0d339eab3f2d002365744b25afbf1a42b", "parents": ["3ee14b37d5d4328ba73459506ac632f10cb32eff"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1277553 - Specify adjust sandbox token if not beta or release build. r=sebastian, a=lizzard\n\nI didn't include nalexander's MOZ_INSTALL_TRACKING suggestion because my make\nskills are too shaky to make this worthwhile. Specifying a keyfile when\nMOZ_INSTALL_TRACKING is disabled isn't harmful afaik (though it's a little\nspammy).\n\nAlso, added code comment duplicated for emphasis:\n\n# (bug 1277553) In Aurora -\u003e Beta simulation builds, no update channel is\n# specified, causing an assertion to throw that MOZ_INSTALL_TRACKING is\n# specified but the keyfile is not. In this case, we add a default keyfile.\n# This has the disadvantage that if our beta/release checks above ever\n# fail, we'll come to this default case and the compile-time check to\n# specify a valid keyfile will be broken. I don't have any better\n# alternatives.\n\nMozReview-Commit-ID: 7tmemvpDaW8", "files": ["mobile/android/config/mozconfigs/common"], "git_node": null, "git_parents": [null], "node": "2c772eb0a81a6e00ecd86576be81f5dfce78d2d0", "parents": ["599d69a0d339eab3f2d002365744b25afbf1a42b"], "tags": []}], "date": 1466493420, "git_changesets": [null, null, null], "user": "cbook@mozilla.com"}, "6077": {"changesets": [{"author": "Xidorn Quan \u003cquanxunzhen@gmail.com\u003e", "branch": "default", "desc": "Bug 1277937 - Fix SELECTION_URLSTRIKEOUT. r=jfkthame, a=lizzard\n\nMozReview-Commit-ID: LumW94mTX4X", "files": ["layout/generic/nsTextFrame.cpp"], "git_node": null, "git_parents": [null], "node": "7b71e7abae78fafb13e0a5ee657214dd141bea00", "parents": ["2c772eb0a81a6e00ecd86576be81f5dfce78d2d0"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1279465 - Back out changeset 4ca15e44f0b5 to prevent inconsistency with future designs. r=paolo, a=sylvestre\n\nMozReview-Commit-ID: FxSZ9FJO1Xd", "files": ["browser/themes/shared/identity-block/identity-block.inc.css"], "git_node": null, "git_parents": [null], "node": "bef93a95add04ae173138d8391603bf77f9ae666", "parents": ["7b71e7abae78fafb13e0a5ee657214dd141bea00"], "tags": []}], "date": 1466493588, "git_changesets": [null, null], "user": "cbook@mozilla.com"}, "6078": {"changesets": [{"author": "Randell Jesup \u003crjesup@jesup.org\u003e", "branch": "default", "desc": "Bug 1255737 - Backout f31612f8f3bb (Bug 1239873) from beta 48. r=jib, a=gchang", "files": ["dom/media/MediaStreamGraph.cpp", "dom/media/MediaStreamGraphImpl.h"], "git_node": null, "git_parents": [null], "node": "cf6b8e808455f83f837924d278d272bb55b2d115", "parents": ["bef93a95add04ae173138d8391603bf77f9ae666"], "tags": []}, {"author": "Honza Bambas \u003chonzab.moz@firemni.cz\u003e", "branch": "default", "desc": "Bug 1273875 - On shutdown leak HTTP cache entries memory, r=michal, a=sylvestre", "files": ["netwerk/cache2/CacheStorageService.cpp"], "git_node": null, "git_parents": [null], "node": "36122c034b7e22fc28ad41a6ec6ef389fb683ddf", "parents": ["cf6b8e808455f83f837924d278d272bb55b2d115"], "tags": []}, {"author": "Bob Silverberg \u003cbsilverberg@mozilla.com\u003e", "branch": "default", "desc": "Bug 1275363 - Fix ext-notifications.js, line 59: TypeError: this is undefined, r=kmag, a=sylvestre\n\nMozReview-Commit-ID: j6G1dXvoXQ", "files": ["toolkit/components/extensions/ext-notifications.js"], "git_node": null, "git_parents": [null], "node": "473ca9bf2b2f541518aeb35abf2e99d4a57c8ef2", "parents": ["36122c034b7e22fc28ad41a6ec6ef389fb683ddf"], "tags": []}, {"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1276161 - backport fix for dashed paths with SkiaGL. r=mchang, a=gwang", "files": ["gfx/skia/skia/src/gpu/batches/GrAADistanceFieldPathRenderer.cpp"], "git_node": null, "git_parents": [null], "node": "30e28d37807b1a98919c649910d9b2a9c8a2e94e", "parents": ["473ca9bf2b2f541518aeb35abf2e99d4a57c8ef2"], "tags": []}], "date": 1466493636, "git_changesets": [null, null, null, null], "user": "cbook@mozilla.com"}, "6079": {"changesets": [{"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1270985 - Hide mouse cursor in native keydown event handler if Command key isn't pressed. r=m_kato, a=lizzard\n\nCurrently, TextInputHandler::DispatchEvent() isn't used for WidgetKeyboardEvent nor WidgetCompositionEvent since TextEventDispatcher directly uses nsIWidget::DispatchEvent().  Therefore, old code hiding mouse cursor at dispatching eKeyPress event is never run in current mozilla-central since TextInputHandler dispatches eKeyPress events via TextEventDispatcher.\n\nAdditionally, it's not enough to hide mouse cursor only when widget dispatches eKeyPress events because if IME starts composition, eKeyPress event won't be fired until finishing the composition. So, I think that we should hide mouse cursor at receiving native keydown events.  The event handler receives keydown events before IME handles them.  Additionally, modifier key events which won't cause eKeyPress events are not using native keydown event handler, fortunately.  So, I believe that it's the best place to do it.\n\nMozReview-Commit-ID: 9dnpiVEV2Lx", "files": ["widget/cocoa/TextInputHandler.mm"], "git_node": null, "git_parents": [null], "node": "fb2bd3009fd43b84acffa0eb62151e19c3eb4197", "parents": ["30e28d37807b1a98919c649910d9b2a9c8a2e94e"], "tags": []}], "date": 1466493931, "git_changesets": [null], "user": "cbook@mozilla.com"}, "6080": {"changesets": [{"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1277156 - TaskbarPreview::Disable should check whether window is destroyed. r=jimm, a=gchang\n\nTaskbarTabPreview object will be released by GC.  So when Disable method is called, window may already destroyed.  So we should check whether window is destroyed.\n\nMozReview-Commit-ID: MGz3JmDh37", "files": ["widget/windows/TaskbarPreview.cpp"], "git_node": null, "git_parents": [null], "node": "85f8d77a0cb7a4b03bee2e36aaab695f327ea9da", "parents": ["fb2bd3009fd43b84acffa0eb62151e19c3eb4197"], "tags": []}, {"author": "Olli Pettay \u003cOlli.Pettay@helsinki.fi\u003e", "branch": "default", "desc": "Bug 1277358 - xul:browser element kept alive too long if tab is dnd'ed to a new window, r=kats, a=gchang", "files": ["layout/base/ZoomConstraintsClient.cpp"], "git_node": null, "git_parents": [null], "node": "195b5d64869c579957bda22c659b8219456910ec", "parents": ["85f8d77a0cb7a4b03bee2e36aaab695f327ea9da"], "tags": []}], "date": 1466513811, "git_changesets": [null, null], "user": "cbook@mozilla.com"}, "6081": {"changesets": [{"author": "Tooru Fujisawa \u003carai_a@mac.com\u003e", "branch": "default", "desc": "Bug 1279467 - Fix null handling in RegExp character class with unicode flag. r=till, a=gchang", "files": ["js/src/irregexp/RegExpParser.cpp", "js/src/tests/ecma_6/RegExp/class-null.js"], "git_node": null, "git_parents": [null], "node": "2faf0d10a390f94dad6cb574d1e3f7721a8062b3", "parents": ["195b5d64869c579957bda22c659b8219456910ec"], "tags": []}, {"author": "aleth \u003caleth@instantbird.org\u003e", "branch": "default", "desc": "Bug 1232067 - Ensure the libc free() is used if the a.out free() is not available. r=yoric, a=gchang", "files": ["toolkit/components/osfile/modules/osfile_shared_allthreads.jsm", "toolkit/components/osfile/modules/osfile_unix_back.jsm"], "git_node": null, "git_parents": [null], "node": "5f7dcce004111d3e2f78cdae83bafb8551937018", "parents": ["2faf0d10a390f94dad6cb574d1e3f7721a8062b3"], "tags": []}], "date": 1466513917, "git_changesets": [null, null], "user": "cbook@mozilla.com"}, "6082": {"changesets": [{"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1269238 - allow text-links to use origin principals for link opening checks, r=mikedeboer, a=sylvestre\n\nMozReview-Commit-ID: HPWxEyNEsps", "files": ["browser/base/content/aboutDialog.xul", "toolkit/content/widgets/text.xml"], "git_node": null, "git_parents": [null], "node": "fb8483f7bc37750e0bf19549141c922d37262c3d", "parents": ["5f7dcce004111d3e2f78cdae83bafb8551937018"], "tags": []}], "date": 1466521854, "git_changesets": [null], "user": "gijskruitbosch@gmail.com"}, "6083": {"changesets": [{"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1279170 TextInputHandler::InsertText() should set keypress event's .key value property when it replaces specified range with a character r=m_kato, a=sylvestre\n\nTextEventDispatcher::MaybeDispatchKeypressEvents() dispatches keypress events with passed event's mKeyNameIndex and mKeyValue values. I.e., setting mCharCode doesn't make sense in this case. Similarly, mKeyCode value is also ignored (overwritten by 0) if it's printable key's key event (mKeyNameIndex == KEY_NAME_INDEX_USE_STRING).\n\n(This is merged changeset for Beta, the reason of conflict is bug 1254755.)\n\nMozReview-Commit-ID: bdBQOlVKTs", "files": ["widget/cocoa/TextInputHandler.mm"], "git_node": null, "git_parents": [null], "node": "2c01d8986842016a7dd298852e9c86150f81f81e", "parents": ["fb8483f7bc37750e0bf19549141c922d37262c3d"], "tags": []}, {"author": "Mason Chang \u003cmchang\u003e", "branch": "default", "desc": "Bug 1274726. Clamp scaled image before repeating during prescale and repeat on OS X. r=jrmuizel, a=gchang\n* * *\nBug 1274726. Part 2: Reftest for prescale and repeat drawable. r=jrmuizel", "files": ["gfx/thebes/gfxUtils.cpp", "layout/reftests/backgrounds/background-repeat-resampling-ref.html", "layout/reftests/backgrounds/background-repeat-resampling.html", "layout/reftests/backgrounds/grid-large.png", "layout/reftests/backgrounds/reftest.list"], "git_node": null, "git_parents": [null], "node": "9e4f5564086472e77718154e6d636a0eb5053cad", "parents": ["2c01d8986842016a7dd298852e9c86150f81f81e"], "tags": []}, {"author": "philipp \u003cmadperson@gmx.at\u003e", "branch": "default", "desc": "Bug 1277846 - Add various .dlls related to PremierOpinion/RelevantKnowledge to the Windows blocklist. r=aklotz, a=sylvestre", "files": ["mozglue/build/WindowsDllBlocklist.cpp"], "git_node": null, "git_parents": [null], "node": "0bcc9439bf8c9106740ce9e7cb3bb0131487ae67", "parents": ["9e4f5564086472e77718154e6d636a0eb5053cad"], "tags": []}], "date": 1466577558, "git_changesets": [null, null, null], "user": "cbook@mozilla.com"}, "6084": {"changesets": [{"author": "Dragana Damjanovic dd.mozilla@gmail.com", "branch": "default", "desc": "Bug 1277522 - Increase max connection retries to 10.r=mcmanus, a=gchang", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "3d3e03d528e015cb85dd7acf15e65443c0d3d589", "parents": ["0bcc9439bf8c9106740ce9e7cb3bb0131487ae67"], "tags": []}], "date": 1466581839, "git_changesets": [null], "user": "cbook@mozilla.com"}, "6085": {"changesets": [{"author": "Alexander Surkov \u003csurkov.alexander@gmail.com\u003e", "branch": "default", "desc": "Bug 1270218 - keep indexes in parent updated in-the-middle of insertions and removals, r=yzen, a=gchang", "files": ["accessible/base/EventTree.cpp", "accessible/generic/Accessible.cpp", "accessible/tests/mochitest/treeupdate/a11y.ini", "accessible/tests/mochitest/treeupdate/test_general.html"], "git_node": null, "git_parents": [null], "node": "800dc20aca781026226a03c3f43ff132b5cfdc1d", "parents": ["3d3e03d528e015cb85dd7acf15e65443c0d3d589"], "tags": []}], "date": 1466582412, "git_changesets": [null], "user": "cbook@mozilla.com"}, "6086": {"changesets": [{"author": "Justin Wood \u003cbugspam.Callek@gmail.com\u003e", "branch": "default", "desc": "Bug 1276110 - Workaround a wget bug by not performing internationalisation. r=ted a=ritu CLOSED TREE\n\nTaskclusters cloud-mirror sends a url-encoded response as a redirect, which allows it to point at the absolute url to the file in another AWS region and then it fetches and caches it while returning said file to our client (wget in this case)\nWget however is performing ASCII--\u003eUTF8 conversion on the url on windows, while at the same time also performing a urldecodeon the redirected url.\nThis urldecode is breaking Taskclusters cloud-mirror, so we work around that by telling wget not to perform the conversion at all (we don't need charset conversion here)\n\nAlternative option was to set --local-encoding=ASCII, however that option doesn't work on our current linux machines (and likely OSX builders, but untested there) while --no-iri works on all 3 platforms, so we are going with that.\n\nMozReview-Commit-ID: EXmiDpozFNr", "files": ["toolkit/locales/l10n.mk"], "git_node": null, "git_parents": [null], "node": "cd5ecd8ab7a206b268c32330bcced775356904b6", "parents": ["800dc20aca781026226a03c3f43ff132b5cfdc1d"], "tags": []}], "date": 1466615024, "git_changesets": [null], "user": "kwierso@gmail.com"}, "6087": {"changesets": [{"author": "David Rajchenbach-Teller \u003cdteller@mozilla.com\u003e", "branch": "default", "desc": "Bug 1261702 - Make nsPerformanceStatsService::Dispose() idempotent,r=froydnj, a=sylvestre", "files": ["toolkit/components/perfmonitoring/nsPerformanceStats.cpp", "toolkit/components/perfmonitoring/nsPerformanceStats.h"], "git_node": null, "git_parents": [null], "node": "982871ad599a479f6f3e6802c3fe01bd1415e07a", "parents": ["cd5ecd8ab7a206b268c32330bcced775356904b6"], "tags": []}], "date": 1466688941, "git_changesets": [null], "user": "cbook@mozilla.com"}, "6088": {"changesets": [{"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1266260: P1. Fix overflow is speexdsp. r=padenot, r=gerald, a=sylvestre\n\nFix submitted upstream\n\nUpstream version had a partial fix for overflow (though incomplete). I've included that fix here and completed it.\n\nMozReview-Commit-ID: 5RyIMI5qrvC", "files": ["media/libspeex_resampler/fix-overflow.patch", "media/libspeex_resampler/src/resample.c", "media/libspeex_resampler/src/speex_resampler.h", "media/libspeex_resampler/update.sh"], "git_node": null, "git_parents": [null], "node": "b561ed4210c07bf8b9e01e878e8f4640022c7e3e", "parents": ["982871ad599a479f6f3e6802c3fe01bd1415e07a"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1266260: P2. Check for OOM. r=gerald, a=sylvestre\n\nAdditionally, indicate in clearer fashion where setting length can't fail.\n\nMozReview-Commit-ID: LSZtCclqhK1", "files": ["dom/media/AudioConverter.h"], "git_node": null, "git_parents": [null], "node": "fe2528b2f4c4427903876e93590431f2b23bbbbc", "parents": ["b561ed4210c07bf8b9e01e878e8f4640022c7e3e"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1266260: P3. Limit maximum sampling rate to some sane value. r=gerald, a=sylvestre\n\nMozReview-Commit-ID: 5ulAivVkec5", "files": ["dom/media/MediaInfo.h"], "git_node": null, "git_parents": [null], "node": "44f094a357abce33721a9568032094bde85f9c92", "parents": ["fe2528b2f4c4427903876e93590431f2b23bbbbc"], "tags": []}], "date": 1466689183, "git_changesets": [null, null, null], "user": "cbook@mozilla.com"}, "6089": {"changesets": [{"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1277719 - Remove unnecessary duplicated zoom bounds from APZC and make nsViewportInfo have the source of truth for those values. r=rbarker, a=gchang\n\nMozReview-Commit-ID: 4IjgCcufAL0", "files": ["gfx/layers/apz/src/AsyncPanZoomController.cpp"], "git_node": null, "git_parents": [null], "node": "edb9d56123ee7bef023e97a1bff2f551ce706b5b", "parents": ["44f094a357abce33721a9568032094bde85f9c92"], "tags": []}, {"author": "Ralph Giles \u003cgiles@mozilla.com\u003e", "branch": "default", "desc": "Bug 1275189 - Remove thread::JoinHandle panic guard. r=kinetik, a=sylvestre\n\nWe've audited this code, so the calls inside the closure should\nbe panic-free. Meanwhile the thread join() itself seems to be\npanicing on windows. This will at least get us a more obvious\ncrash.\n\nMozReview-Commit-ID: JXoDOOu2x0K", "files": ["media/libstagefright/binding/mp4parse-thread.patch", "media/libstagefright/binding/mp4parse/capi.rs", "media/libstagefright/binding/update-rust.sh"], "git_node": null, "git_parents": [null], "node": "6ecc2a98e8a7cf0513b9af9198111d8a0d7ee47b", "parents": ["edb9d56123ee7bef023e97a1bff2f551ce706b5b"], "tags": []}, {"author": "Randell Jesup \u003crjesup@jesup.org\u003e", "branch": "default", "desc": "Bug 1274083: don't return early from rate changes if we overflow r=jmspeex, a=sylvestre\n\nMozReview-Commit-ID: DVSp3VpiIJw", "files": ["dom/media/webaudio/AudioBufferSourceNode.cpp", "media/libspeex_resampler/src/resample.c"], "git_node": null, "git_parents": [null], "node": "b52a29cf207d80cbc566c5d28063e303f93c2bd5", "parents": ["6ecc2a98e8a7cf0513b9af9198111d8a0d7ee47b"], "tags": []}], "date": 1466689503, "git_changesets": [null, null, null], "user": "cbook@mozilla.com"}, "6090": {"changesets": [{"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1279425 - Remove the unifiedcomplete pref. r=adw, a=sylvestre\n\nMozReview-Commit-ID: IQAkEy9I0Zj", "files": ["browser/app/profile/firefox.js", "browser/base/content/browser.xul", "browser/base/content/tabbrowser.xml", "browser/base/content/test/urlbar/browser.ini", "browser/base/content/test/urlbar/browser_action_keyword.js", "browser/base/content/test/urlbar/browser_action_keyword_override.js", "browser/base/content/test/urlbar/browser_action_searchengine.js", "browser/base/content/test/urlbar/browser_action_searchengine_alias.js", "browser/base/content/test/urlbar/browser_autocomplete_a11y_label.js", "browser/base/