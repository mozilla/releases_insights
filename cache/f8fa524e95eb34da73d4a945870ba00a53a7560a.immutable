parents": [null], "node": "8b6506beee8e4f591a15099cfad20fd27405a94a", "parents": ["f8606cd63ad2230a571df7e8c9260746bf8051b4"], "tags": []}, {"author": "Olli Pettay \u003cOlli.Pettay@helsinki.fi\u003e", "branch": "default", "desc": "Bug 1286183 - Improve SVGEffects' unlinking. r=mstange, a=sylvestre", "files": ["layout/svg/nsSVGEffects.cpp", "layout/svg/nsSVGEffects.h"], "git_node": null, "git_parents": [null], "node": "14933537adf425ecb70af356f29d801a3f12a67a", "parents": ["8b6506beee8e4f591a15099cfad20fd27405a94a"], "tags": []}, {"author": "Randell Jesup \u003crjesup@jesup.org\u003e", "branch": "default", "desc": "Bug 1286644 - cherry-pick AEC fix from Chromium Issue 576624 r=pkerr, a=sylvestre", "files": ["media/webrtc/trunk/webrtc/modules/audio_processing/utility/delay_estimator.c"], "git_node": null, "git_parents": [null], "node": "e29236a2cb1019532749ae35f37266cbbba0c04c", "parents": ["14933537adf425ecb70af356f29d801a3f12a67a"], "tags": []}], "date": 1468833214, "git_changesets": [null, null, null, null, null, null, null, null], "user": "cbook@mozilla.com"}, "6223": {"changesets": [{"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1284921- Hardcode Android version for non-numeric releases. r=nfroyd, a=gchang", "files": ["xpcom/base/nsSystemInfo.cpp"], "git_node": null, "git_parents": [null], "node": "2b7160a603f1f8f1fb5cef64dc73fb87c115bed7", "parents": ["e29236a2cb1019532749ae35f37266cbbba0c04c"], "tags": []}], "date": 1468833740, "git_changesets": [null], "user": "cbook@mozilla.com"}, "6224": {"changesets": [{"author": "Ting-Yu Chou \u003cjanus926@gmail.com\u003e", "branch": "default", "desc": "Bug 1267329 - part 1 - Add a new argument to specify the minidump type to write on Windows. r=ted, a=gchang", "files": ["toolkit/crashreporter/google-breakpad/src/client/windows/handler/exception_handler.cc", "toolkit/crashreporter/google-breakpad/src/client/windows/handler/exception_handler.h"], "git_node": null, "git_parents": [null], "node": "9dc6814ac5ba9eed4d42510988aea834c398f204", "parents": ["2b7160a603f1f8f1fb5cef64dc73fb87c115bed7"], "tags": []}, {"author": "Ting-Yu Chou \u003cjanus926@gmail.com\u003e", "branch": "default", "desc": "Bug 1267329 - part 2 - Record the memory information for the minidumps on Windows. r=ted, a=gchang", "files": ["toolkit/crashreporter/nsExceptionHandler.cpp"], "git_node": null, "git_parents": [null], "node": "85112a93cf1ddde17cc60cb9edd2b6b90218fcaf", "parents": ["9dc6814ac5ba9eed4d42510988aea834c398f204"], "tags": []}], "date": 1468835209, "git_changesets": [null, null], "user": "cbook@mozilla.com"}, "6225": {"changesets": [{"author": "Patrick McManus \u003cmcmanus@ducksong.com\u003e", "branch": "default", "desc": "Bug 1286664 - TLSFilterTransaction::WriteSegments null Connection(). r=hurley, a=sylvestre", "files": ["netwerk/protocol/http/TunnelUtils.cpp"], "git_node": null, "git_parents": [null], "node": "0f4257230dffa106e90cf736df9dbe9859ac5274", "parents": ["85112a93cf1ddde17cc60cb9edd2b6b90218fcaf"], "tags": []}], "date": 1468855689, "git_changesets": [null], "user": "cbook@mozilla.com"}, "6226": {"changesets": [{"author": "Sebastian Kaspari \u003cs.kaspari@gmail.com\u003e", "branch": "default", "desc": "Bug 1261008 - Do not restore tabs pointing to about:home and with no history. r=janh,ahunt, a=sylvestre\n\nIf the browser is set to always restore the session (default) then we will never\nstart with an empty session. Even if the user closes all tabs we will re-create\na new tab pointing to about:home. So we will always at least restore this tab on\nthe next startup. As a consequence we will never open the 'homepage' on app start\nbecause we will never have a non-empty session.\n\nWith this patch we won't restore tabs that point to about:home and do not contain\nany other history. As a result we might restore an empty session and load the\nhomepage or about:home (depending on configuration) in a new tab.\n\nIn case we decide to not restore the currently selected tab, we just select the\nfirst restored tab if there's any.\n\nMozReview-Commit-ID: DuN03M60Gi8", "files": ["mobile/android/base/java/org/mozilla/gecko/GeckoApp.java", "mobile/android/base/java/org/mozilla/gecko/SessionParser.java", "mobile/android/base/java/org/mozilla/gecko/Tabs.java"], "git_node": null, "git_parents": [null], "node": "7955d606935c93b0f0c0d38f8c7aa55b8fcab4e1", "parents": ["0f4257230dffa106e90cf736df9dbe9859ac5274"], "tags": []}], "date": 1468855907, "git_changesets": [null], "user": "cbook@mozilla.com"}, "6227": {"changesets": [{"author": "ffxbld", "branch": "MOBILE480b9_2016071817_RELBRANCH", "desc": "Automated checkin: version bump for fennec 48.0b9 release. DONTBUILD CLOSED TREE a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "0b1c0103e7f48194e51c571658b4f33660b7ed2b", "parents": ["7955d606935c93b0f0c0d38f8c7aa55b8fcab4e1"], "tags": ["FENNEC_48_0b9_BUILD1", "FENNEC_48_0b9_RELEASE"]}, {"author": "ffxbld", "branch": "MOBILE480b9_2016071817_RELBRANCH", "desc": "Added FENNEC_48_0b9_RELEASE FENNEC_48_0b9_BUILD1 tag(s) for changeset 0b1c0103e7f4. DONTBUILD CLOSED TREE a=release", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "8661cbc3d993f06b8c4a1a9ebaefb762e0ca860c", "parents": ["0b1c0103e7f48194e51c571658b4f33660b7ed2b"], "tags": []}], "date": 1468876298, "git_changesets": [null, null], "user": "ffxbld"}, "6228": {"changesets": [{"author": "Rail Aliiev \u003crail@mozilla.com\u003e", "branch": "default", "desc": "Automatic version bump. CLOSED TREE NO BUG a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "d2ab9c39bd1059d74acb3d9ac87dbfbba913427b", "parents": ["7955d606935c93b0f0c0d38f8c7aa55b8fcab4e1"], "tags": ["FIREFOX_48_0b9_BUILD1", "FIREFOX_48_0b9_RELEASE"]}], "date": 1468876890, "git_changesets": [null], "user": "raliiev@mozilla.com"}, "6229": {"changesets": [{"author": "Jordan L