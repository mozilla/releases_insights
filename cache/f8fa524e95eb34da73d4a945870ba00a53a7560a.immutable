h a keyframe we do not have to worry about breaking the previous coded frame group.\n\nMozReview-Commit-ID: G81xGuSa4Y2", "files": ["dom/media/mediasource/TrackBuffersManager.cpp"], "git_node": null, "git_parents": [null], "node": "aa702c6e60ea765053a7a9c95df783e894b0a2ea", "parents": ["ebaf4086c18c2d1e3f0af12ade55840413342bc3"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1276184: [MSE] P2. Remove the need to scan the track buffer when frames are being removed. r=kamidphish, a=gchang\n\nThe index at which we are removing frames is always the one where we will be inserting the next ones.\n\nMozReview-Commit-ID: DHeJDmwiMS9", "files": ["dom/media/mediasource/TrackBuffersManager.cpp", "dom/media/mediasource/TrackBuffersManager.h"], "git_node": null, "git_parents": [null], "node": "3c50c80273897ac7cb6f36509760af3f53871025", "parents": ["aa702c6e60ea765053a7a9c95df783e894b0a2ea"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1276184: [MSE] P3. Be consistent with types when accessing track buffer. r=kamidphish, a=gchang\n\nMozReview-Commit-ID: BJlNeValVxE", "files": ["dom/media/mediasource/TrackBuffersManager.cpp"], "git_node": null, "git_parents": [null], "node": "3e04c4853a8bc95b6b485c42fb7e1e2d7500316b", "parents": ["3c50c80273897ac7cb6f36509760af3f53871025"], "tags": []}], "date": 1467640239, "git_changesets": [null, null, null], "user": "cbook@mozilla.com"}, "6162": {"changesets": [{"author": "Kim Moir \u003ckmoir@mozilla.com\u003e", "branch": "default", "desc": "Bug 1252003 - Add publish to balrog builder r=rail a=release DONTBUILD\n\nMozReview-Commit-ID: CeNwtAd2o6e", "files": ["testing/mozharness/configs/releases/dev_updates_firefox_beta.py", "testing/mozharness/configs/releases/dev_updates_firefox_release.py", "testing/mozharness/configs/releases/updates_firefox_beta.py", "testing/mozharness/configs/releases/updates_firefox_rel