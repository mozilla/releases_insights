s:262713:"{
"lastpushid": 25753,
"pushes": {"6049": {"changesets": [{"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1275384 - Dispatch mousedown, mouseup and click events manually on \u003cselect\u003e for e10s instead of using DOMWindowUtils. r=Felipe, a=sylvestre\n\nWe were using nsIDOMWindowUtils to send mousedown and mouseup events\nto the \u003cselect\u003e input after a selection was made in e10s mode, but\ndoing so causes focus to be pulled back to the \u003cselect\u003e if any input\nor change event handlers tried to shift focus. For example, the\nreviewer input on Bugzilla was having its focus stolen after setting\nthe review flag to r?, which was how this bug was discovered.\n\nWe're going for mostly-Blink parity here, where it seems (at least on\nWindows) a mouseup and click event are dispatched on \u003cselect\u003e\nelements after the dropdown is closed (either by mouse or keyboard).\n\nWe're adding a mousedown just before those, since that seems to make\nthe most sense.\n\nMozReview-Commit-ID: HAThE6ClBWT", "files": ["toolkit/modules/SelectContentHelper.jsm"], "git_node": null, "git_parents": [null], "node": "5fe894994e955cf7f6d85337492beebe562ea6c5", "parents": ["46d72a56c57dafb4dc1061d4741a3e1181ac3d68"], "tags": []}], "date": 1465242786, "git_changesets": [null], "user": "mconley@mozilla.com"}, "6050": {"changesets": [{"author": "Edmund Wong \u003cewong@pw-wspx.org\u003e", "branch": "default", "desc": "Bug 1262760 - Add xpcshell.pth to build/virtualenv_packages.txt, a=lizzard\nCLOSED TREE", "files": ["build/virtualenv_packages.txt"], "git_node": null, "git_parents": [null], "node": "1f9f6bdee31c14fd5a39485e8ae326de2928ef7d", "parents": ["5fe894994e955cf7f6d85337492beebe562ea6c5"], "tags": []}], "date": 1465267403, "git_changesets": [null], "user": "philringnalda@gmail.com"}, "6051": {"changesets": [{"author": "Phil Ringnalda \u003cphilringnalda@gmail.com\u003e", "branch": "default", "desc": "Back out 1f9f6bdee31c (bug 1262760) since the buildbotcustom patch it depends on isn't actually landed, a=backout on a CLOSED TREE", "files": ["build/virtualenv_packages.txt"], "git_node": null, "git_parents": [null], "node": "55124c7343021091a61fdddac9f22628ca09642a", "parents": ["1f9f6bdee31c14fd5a39485e8ae326de2928ef7d"], "tags": ["FIREFOX_48_0b1_BUILD2", "FIREFOX_48_0b1_RELEASE"]}], "date": 1465268690, "git_changesets": [null], "user": "philringnalda@gmail.com"}, "6052": {"changesets": [{"author": "ffxbld", "branch": "MOBILE480b1_2016060722_RELBRANCH", "desc": "Automated checkin: version bump for fennec 48.0b1 release. DONTBUILD CLOSED TREE a=release", "files": [], "git_node": null, "git_parents": [null], "node": "c6290de3ba992f6b64ad0c28684881b1645f0a5b", "parents": ["55124c7343021091a61fdddac9f22628ca09642a"], "tags": ["FENNEC_48_0b1_BUILD1", "FENNEC_48_0b1_RELEASE"]}, {"author": "ffxbld", "branch": "MOBILE480b1_2016060722_RELBRANCH", "desc": "Added FENNEC_48_0b1_RELEASE FENNEC_48_0b1_BUILD1 tag(s) for changeset c6290de3ba99. DONTBUILD CLOSED TREE a=release", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "b280848c0535193603c2761915460f5a2f42f858", "parents": ["c6290de3ba992f6b64ad0c28684881b1645f0a5b"], "tags": []}], "date": 1465352274, "git_changesets": [null, null], "user": "ffxbld"}, "6053": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "Automatic version bump. CLOSED TREE NO BUG a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "4187f127cdd21c4240045f77c18f355ee315bdbd", "parents": ["55124c7343021091a61fdddac9f22628ca09642a"], "tags": []}, {"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging 55124c7343021091a61fdddac9f22628ca09642a with FIREFOX_48_0b1_BUILD2, FIREFOX_48_0b1_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "ec56d351f9a0677f9ef34a6f6cefbf7addf86145", "pa