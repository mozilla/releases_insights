a=gchang\n\nIf a distribution sets \"distribution.read_partner_bookmarks_provider\" (Android preference)\nto 'true' then Fennec will read from Android's PartnerBookmarksProvider [1] and add them\nto the bookmarks panel UI.\n\n[1] https://android.googlesource.com/platform/packages/providers/PartnerBookmarksProvider/+/master/src/com/android/providers/partnerbookmarks/PartnerBookmarksProvider.java", "files": ["mobile/android/base/java/org/mozilla/gecko/db/BrowserContract.java", "mobile/android/base/java/org/mozilla/gecko/distribution/PartnerBookmarksProviderClient.java", "mobile/android/base/java/org/mozilla/gecko/home/BookmarksPanel.java", "mobile/android/base/java/org/mozilla/gecko/preferences/GeckoPreferences.java", "mobile/android/base/moz.build"], "git_node": null, "git_parents": [null], "node": "aa29390cd65d4b0ed609322ec747c6c11a9b3900", "parents": ["730c0603575f93a43d87ce7a81c7ac1b63095634"], "tags": []}], "date": 1469106696, "git_changesets": [null, null, null], "user": "cbook@mozilla.com"}, "6235": {"changesets": [{"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1262731 - Don't use a separate ICU data file on Windows. r=ted, a=gchang\n\nBecause sometimes the file goes missing which prevents Firefox from starting.", "files": ["browser/installer/Makefile.in", "browser/installer/package-manifest.in", "build/autoconf/icu.m4"], "git_node": null, "git_parents": [null], "node": "54bc851c3ba9132ec7a4d44497b9d71b7753f92d", "parents": ["aa29390cd65d4b0ed609322ec747c6c11a9b3900"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1255986 - [moztest] Safe-guard structured logging for exceptions from bad handlers. r=jgraham, a=test-only\n\nAny exception which gets thrown by a log handler while test results are getting generated, should\nnot cause test harnesses to stop immediately. To achive that the exception details are written to\nstderr and not propagated up the stack.\n\nMozReview-Commit-ID: ChyYxApYSGx", "files": ["testing/mozbase/mozlog/mozlog/structuredlog.py"], "git_node": null, "git_parents": [null], "node": "6688064e8ad629276830b941df87681a21b67cdc", "parents": ["54bc851c3ba9132ec7a4d44497b9d71b7753f92d"], "tags": []}], "date": 1469111815, "git_changesets": [null, null], "user": "cbook@mozilla.com"}, "6236": {"changesets": [{"author": "Sebastian Kaspari \u003cs.kaspari@gmail.com\u003e", "branch": "default", "desc": "Bug 1287116 - [workaround] disable audio focus on FF48. r=sebastian a=sylvestre\n\nThis changeset should only be applied to FF48, it's a workaround.", "files": ["mobile/android/base/java/org/mozilla/gecko/media/AudioFocusAgent.java"], "git_node": null, "git_parents": [null], "node": "b8a75eb3cacc7463828dc8d1beba049a5dbb819e", "parents": ["6688064e8ad629276830b941df87681a21b67cdc"], "tags": []}], "date": 1469126854, "git_changesets": [null], "user": "kwierso@gmail.com"}, "6237": {"changesets": [{"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1283826. r=mstange,Bas a=sylvestre\n\nMozReview-Commit-ID: HiwjHBlhmKk", "files": ["gfx/2d/BaseRect.h", "gfx/2d/Rect.h", "gfx/src/TiledRegion.cpp", "gfx/src/TiledRegion.h", "gfx/tests/gtest/TestRegion.cpp"], "git_node": null, "git_parents": [null], "node": "ccf0f9620bdcd4378568c385b9d936f38ce1fb97", "parents": ["b8a75eb3cacc7463828dc8d1beba049a5dbb819e"], "tags": []}], "date": 1469129312, "git_changesets": [null], "user": "kgupta@mozilla.com"}, "6238": {"changesets": [{"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1287245 - Ensure globally unique internal port IDs r=billm a=sylvestre\n\nMozReview-Commit-ID: FXNP5MadlMx", "files": ["toolkit/components/extensions/ExtensionUtils.jsm", "toolkit/components/extensions/test/mochitest/mochitest.ini", "toolkit/components/extensions/test/mochitest/test_ext_runtime_connect_twoway.html"], "git_node": null, "git_parents": [null], "node": "05853bb06a87