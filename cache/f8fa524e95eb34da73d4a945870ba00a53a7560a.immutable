6_BUILD1", "FENNEC_48_0b6_RELEASE"]}, {"author": "ffxbld", "branch": "MOBILE480b6_2016070707_RELBRANCH", "desc": "Added FENNEC_48_0b6_RELEASE FENNEC_48_0b6_BUILD1 tag(s) for changeset 9a6dfad953ef. DONTBUILD CLOSED TREE a=release", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "5460d5f360daecbf5454f2ae2cb84caf690e342a", "parents": ["9a6dfad953efdd0f2a48cbcd738a9761292cc6c3"], "tags": []}], "date": 1467889570, "git_changesets": [null, null], "user": "ffxbld"}, "6182": {"changesets": [{"author": "Brian Birtles \u003cbirtles@gmail.com\u003e", "branch": "default", "desc": "Bug 1279819 - Copy keyframes array before iterating over it. r=hiro, a=lizzard\n\nMozReview-Commit-ID: IbMoysQ7uu", "files": ["dom/animation/KeyframeEffect.cpp"], "git_node": null, "git_parents": [null], "node": "14cd5a377ae1680dff145c4fbda93cf5bdaaab34", "parents": ["d142c49033c015f67272562b37dbe2912cfc7f14"], "tags": []}, {"author": "David Burns \u003cdburns@mozilla.com\u003e", "branch": "default", "desc": "Bug 1281915 - Skip trying to remove a frame script if there no messageManager. r=ato, a=test-only\n\nWhen trying to load or unload FRAME_SCRIPT into a process we should check if we have\nmessageManager available to do the work or error accordingly.\n\nMozReview-Commit-ID: 1xonnY34vI3", "files": ["testing/marionette/driver.js", "testing/marionette/harness/marionette/tests/unit/test_screenshot.py"], "git_node": null, "git_parents": [null], "node": "0c33a13a282b8964e407c9205dd0aeb5fb167c92", "parents": ["14cd5a377ae1680dff145c4fbda93cf5bdaaab34"], "tags": []}, {"author": "Nicolas Chevobbe \u003cchevobbe.nicolas@gmail.com\u003e", "branch": "default", "desc": "Bug 1261714 - Fix dead CPOW intermittent on browser_toolbox_options_disable_js.js. r=jryans, a=test-only\n\nMozReview-Commit-ID: G2De93K0Tgv", "files": ["devtools/client/framework/test/browser_toolbox_options_disable_js.js"], "git_node": null, "git_parents": [null], "node": "db999785bdc56d1dd8cd3c5c26d125ad7a4eb376", "parents": ["0c33a13a282b8964e407c9205dd0aeb5fb167c92"], "tags": []}, {"author": "Sami Jaktholm \u003csjakthol@outlook.com\u003e", "branch": "default", "desc": "Bug 1264434 - Use String.prototype.includes in browser_webconsole_bug_597136_network_requests_from_chrome.js. r=bgrins, a=test-only\n\nString.prototype.contains was removed from Firefox 48 completely after\nit was renamed to String.prototype.includes. The test includes a\ncall to .contains() which is triggered whenever random JavaScript\nerror occurs during the test (hence the intermittency).\n\nMozReview-Commit-ID: 7nbRm94JM7O", "files": ["devtools/client/webconsole/test/browser_webconsole_bug_597136_network_requests_from_chrome.js"], "git_node": null, "git_parents": [null], "node": "289be0902bd1028e9982f0d8b67c80d7b8572e04", "parents": ["db999785bdc56d1dd8cd3c5c26d125ad7a4eb376"], "tags": []}, {"author": "Phil Ringnalda \u003cphilringnalda@gmail.com\u003e", "branch": "default", "desc": "Bug 1260177 - Skip browser_social_chatwindowfocus.js on ASan for constant failures. a=test-only", "files": ["browser/base/content/test/social/browser.ini"], "git_node": null, "git_parents": [null], "node": "ed935d3fe6a4c4004db4ae53f7e8b416dd726e8d", "parents": ["289be0902bd1028e9982f0d8b67c80d7b8572e04"], "tags": []}, {"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 1266882 - Ensure the return value of CreateBR is addrefed in CopyLastEditableChildStyles. r=masayuki, a=lizzard\n\nFailure to increment the refcount to this BR node causes fatal cycle\ncollector assertions, and could lead to all sorts of other crashes.\nThis is a regression from bug 1156062, part 5.", "files": ["editor/libeditor/nsHTMLEditor.cpp"], "git_node": null, "git_parents": [null], "node": "9a8bf5b273623dfe87703014e43fe028485d8be8", "parents": ["ed935d3fe6a4c4004db4ae53f7e8b416dd726e8d"], "tags": []}, {"author": "Boris Chiou \u003cboris.chiou@gmail.com\u003e", "branch": "default", "desc": "Bug 1283625 - Unlink timing object before nullifying it. r=birtles, a=lizzard\n\nMozReview-Commit-ID: 3eIAL77aDLV", "files": ["dom/animation/KeyframeEffect.cpp"], "git_node": null, "git_parents": [null], "node": "2faba7f42667f991105b461a0abb981b4aa9cf3d", "parents": ["9a8bf5b273623dfe87703014e43fe028485d8be8"], "tags": []}], "date": 1467940180, "git_changesets": [null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "6183": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset 9a8bf5b27362 (bug 1266882) for bustage.", "files": ["editor/libeditor/nsHTMLEditor.cpp"], "git_node": null, "git_parents": [null], "node": "b31dfcfb60a5fa6042b04aa96480171f09bd137c", "parents": ["2faba7f42667f991105b461a0abb981b4aa9cf3d"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset 14cd5a377ae1 (bug 1279819) for OSX debug bustage.", "files": ["dom/animation/KeyframeEffect.cpp"], "git_node": null, "git_parents": [null], "node": "f4e161a1dd38df3f4679d7b647371e2388e7eb72", "parents": ["b31dfcfb60a5fa6042b04aa96480171f09bd137c"], "tags": []}], "date": 1467941935, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "6184": {"changesets": [{"author": "Brian Birtles \u003cbirtles@gmail.com\u003e", "branch": "default", "desc": "Bug 1279819 - Copy keyframes array before iterating over it. r=hiro, a=lizzard\n\nMozReview-Commit-ID: IbMoysQ7uu", "files": ["dom/animation/KeyframeEffect.cpp"], "git_node": null, "git_parents": [null], "node": "a8821f681f296183af74f837e00b89ceab8ea81d", "parents": ["f4e161a1dd38df3f4679d7b647371e2388e7eb72"], "tags": []}], "date": 1467950997, "git_changesets": [null], "user": "bbirtles@mozilla.com"}, "6185": {"changesets": [{"author": "Grigory Kruglov \u003cgkruglov@mozilla.com\u003e", "branch": "default", "desc": "Bug 1280409 - Guard against cursor failures while migrating data from HistoryExtensionsDB. r=sebasti