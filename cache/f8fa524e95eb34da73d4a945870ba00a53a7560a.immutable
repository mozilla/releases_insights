hemes/osx/jar.mn", "browser/themes/osx/shared.inc", "browser/themes/osx/tabbrowser/tab-active-middle-yosemite-inactive.png", "browser/themes/osx/tabbrowser/tab-active-middle-yosemite-inactive@2x.png", "browser/themes/osx/tabbrowser/tab-selected-end-yosemite-inactive.svg", "browser/themes/osx/tabbrowser/tab-selected-start-yosemite-inactive.svg", "browser/themes/osx/tabbrowser/tab-stroke-end-yosemite-inactive.png", "browser/themes/osx/tabbrowser/tab-stroke-end-yosemite-inactive@2x.png", "browser/themes/osx/tabbrowser/tab-stroke-start-yosemite-inactive.png", "browser/themes/osx/tabbrowser/tab-stroke-start-yosemite-inactive@2x.png"], "git_node": null, "git_parents": [null], "node": "a209701fec49f110b3e1018247ad3eec446b8194", "parents": ["e2f8b2e421f954c7f3b74f9f7bd7a982aed94d05"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1088763 - Preload yosemite tab images. r=mconley, a=sylvestre\n\nWe need to preload both the inactive and the active images. All our image loads\nneed to be kicked off before the window document's load event fires. While the\nwindow is hidden, it is inactive. So we need the preloading hack to kick off\nthe loads for the active images.\n\nMozReview-Commit-ID: 2dPdJNORwhw", "files": ["browser/themes/osx/browser.css"], "git_node": null, "git_parents": [null], "node": "fd92b3537dd60365d95382388fc361f92255a4db", "parents": ["a209701fec49f110b3e1018247ad3eec446b8194"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1277638 - Only lighten up the toolbox bottom border for inactive windows. r=mconley, a=sylvestre\n\nMozReview-Commit-ID: DBREj8jNsb7", "files": ["browser/themes/osx/browser.css"], "git_node": null, "git_parents": [null], "node": "6a6dc3f2075a2ee976b1728d791e94c1a88e5c8e", "parents": ["fd92b3537dd60365d95382388fc361f92255a4db"], "tags": []}], "date": 1467024632, "git_changesets": [null, null, null], "user": "gijskruitbosch@gmail.com"}, "6109": {"changesets": [{"author": "Kit Cambridge \u003ckcambridge@mozilla.com\u003e", "branch": "default", "desc": "Bug 1279306 - Use the production push server URL on Android. r=margaret a=gchang\n\nMozReview-Commit-ID: Fy347g00Lx0", "files": ["mobile/android/app/mobile.js", "mobile/android/branding/aurora/configure.sh", "mobile/android/branding/beta/configure.sh", "mobile/android/branding/nightly/configure.sh", "mobile/android/branding/official/configure.sh", "mobile/android/branding/unofficial/configure.sh"], "git_node": null, "git_parents": [null], "node": "5fa8da372343b0d92d10f8b06227ba2a86581aa7", "parents": ["6a6dc3f2075a2ee976b1728d791e94c1a88e5c8e"], "tags": []}], "date": 1467025277, "git_changesets": [null], "user": "kcambridge@mozilla.com"}, "6110": {"changesets": [{"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1264705 - Add Qwant search plugin for mobile. r=florian r=flod, a=sylvestre", "files": ["mobile/locales/en-US/searchplugins/qwant.xml"], "git_node": null, "git_parents": [null], "node": "2621672259063d1072c800582d583d6245564167", "parents": ["5fa8da372343b0d92d10f8b06227ba2a86581aa7"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1280799 - Update the state of the 'Clear Downloads' button when download item state changes, even if the item is selected. r=paolo, a=gchang\n\nMozReview-Commit-ID: 2YXLDuBxkTe", "files": ["browser/components/downloads/content/allDownloadsViewOverlay.js"], "git_node": null, "git_parents": [null], "node": "91af310955a7950324ae07a8cbc15ce3adca6695", "parents": ["2621672259063d1072c800582d583d6245564167"], "tags": []}, {"author": "Andrew Swan \u003caswan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1273958 - Fix suppression of search box for disco pane r=kmag,r=rhelmer, a=gchang\n\nHiding the header was causing some problems so instead restructure the\nXUL to put the discovery pane in the top-level deck