bump DONTBUILD\n\nel -\u003e ba887c8f5958", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "04421c47a400f7f3cdb4844a695e7fbc3c52956c", "parents": ["e69825d4e0dccee148a1ca270b681f7815908cc0"], "tags": []}], "date": 1554343222, "git_changesets": [null], "user": "ffxbld"}, "10993": {"changesets": [{"author": "Randall Barker \u003crbarker@mozilla.com\u003e", "branch": "default", "desc": "Bug 1537964 - Call bindService() with BIND_IMPORTANT r=snorp a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24418", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/media/RemoteManager.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/process/GeckoProcessManager.java"], "git_node": null, "git_parents": [null], "node": "251103ed375f19184a5d2c1a5c0b64ed9dbb9307", "parents": ["04421c47a400f7f3cdb4844a695e7fbc3c52956c"], "tags": []}, {"author": "David Walsh \u003cdavidwalsh83@gmail.com\u003e", "branch": "default", "desc": "Bug 1539813 - Uplift Debugger UI improvements. r=dwalsh a=pascalc l10n=flod\n\nBug 1538164 - [release 130] added no sources message in Sources Pane (#7978).\nBug 1538164 - [release 130] [Log Point] Fix log point context menu accelerator (#8115).\nBug 1536216 - Redesign map scopes pane r=jlast\nBug 1536113 - Column Breakpoints have a blue background. r=davidwalsh\nBug 1535095 - Hidden column breakpoints are shown. r=davidwalsh\nBug 1536114 - Update columnn breakpoint colors for debugger r=jlast", "files": ["devtools/client/debugger/new/dist/debugger.css", "devtools/client/debugger/new/src/actions/navigation.js", "devtools/client/debugger/new/src/actions/tests/navigation.spec.js", "devtools/client/debugger/new/src/client/firefox/commands.js", "devtools/client/debugger/new/src/components/Editor/Breakpoints.css", "devtools/client/debugger/new/src/components/Editor/ColumnBreakpoint.js", "devtools/client/debugger/new/src/components/Editor/ColumnBreakpoints.css", "devtools/client/debugger/new/src/components/Editor/ColumnBreakpoints.js", "devtools/client/debugger/new/src/components/Editor/Editor.css", "devtools/client/debugger/new/src/components/Editor/index.js", "devtools/client/debugger/new/src/components/Editor/menus/breakpoints.js", "devtools/client/debugger/new/src/components/PrimaryPanes/SourcesTree.js", "devtools/client/debugger/new/src/components/PrimaryPanes/tests/SourcesTree.spec.js", "devtools/client/debugger/new/src/components/PrimaryPanes/tests/__snapshots__/SourcesTree.spec.js.snap", "devtools/client/debugger/new/src/components/SecondaryPanes/Breakpoints/BreakpointsContextMenu.js", "devtools/client/debugger/new/src/components/SecondaryPanes/Scopes.css", "devtools/client/debugger/new/src/components/SecondaryPanes/Scopes.js", "devtools/client/debugger/new/src/components/SecondaryPanes/index.js", "devtools/client/debugger/new/src/components/ShortcutsModal.js", "devtools/client/debugger/new/src/components/test/__snapshots__/ShortcutsModal.spec.js.snap", "devtools/client/debugger/new/src/selectors/visibleColumnBreakpoints.js", "devtools/client/locales/en-US/debugger.properties"], "git_node": null, "git_parents": [null], "node": "32f822dd45b8c243058756713840819b67b59afd", "parents": ["251103ed375f19184a5d2c1a5c0b64ed9dbb9307"], "tags": []}], "date": 1554346515, "git_changesets": [null, null], "user": "apavel@mozilla.com"}, "10994": {"changesets": [{"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "No bug: [try-staging] Allow staging builds to access staging github ssh key; r=nthomas\n\nThe secret with the ssh key already exists in taskcluster, this tells\nmozharness to try to access it.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25700", "files": ["testing/mozharness/configs/partner_repacks/release_mozilla-release_desktop.py", "testing/mozharness/configs/partner_repacks/release_mozilla-release_desktop_EME-free.py", "testing/mozharness/configs/partner_repacks/staging_release_mozilla-release_desktop.py"], "git_node": null, "git_parents": [null], "node": "0fcf234877a7b52c1427b643386ef56892798991", "parents": ["32f822dd45b8c243058756713840819b67b59afd"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "No bug: [mozharness] Remove unused esr52 partner repack configuration; r=nthomas\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25701", "files": ["testing/mozharness/configs/partner_repacks/release_mozilla-esr52_desktop.py"], "git_node": null, "git_parents": [null], "node": "abbcc11c323095d30f722143cc0ea97ea0d68bc7", "parents": ["0fcf234877a7b52c1427b643386ef56892798991"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1541121: [try-staging] Simplify the logic for getting partial update configration; r=aki\n\nThe original code was converting to json, then comparing against `{}`. This switches things\naround so that json is only generated where it is directly used a json.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24833", "files": ["taskcluster/taskgraph/actions/release_promotion.py"], "git_node": null, "git_parents": [null], "node": "87d235b30747f04673dcc32991748bdc940ced93", "parents": ["abbcc11c323095d30f722143cc0ea97ea0d68bc7"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1541121: [try-staging] Allow staging release to not have partials; r=aki\n\nWe check that partials as a safety check. But we don't need that for staging builds,\nand it is often useful to be able to test things that don't depend on partials.\n\nThe shipit UI currently still requires partials, but that can be worked around using\nthe react dev tools.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24834", "files": ["taskcluster/taskgraph/actions/release_promotion.py"], "git_node": null, "git_parents": [null], "node": "8614b52ff81efe42572a09c98983c51b26b52860", "parents": ["87d235b30747f04673dcc32991748bdc940ced93"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1533589: Support generating update-verify-config for new configuration; r=aki\n\nWhen adding a new platform, the first release will be at the watershed, and\nthere will be no update paths. Rather than failing in this case (requiring the\nupdate-verify setup happen after the first release), generate an empty config\nwhich will allow the later tasks to turn green.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25833", "files": ["testing/mozharness/scripts/release/update-verify-config-creator.py"], "git_node": null, "git_parents": [null], "node": "1243a7e81584512b0f4c45e3f73dab203aa88da0", "parents": ["8614b52ff81efe42572a09c98983c51b26b52860"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1533589: Add win64-aarch64 update verify configuration; r=aki\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25834", "files": ["python/mozrelease/mozrelease/platforms.py", "taskcluster/ci/release-secondary-update-verify-config/kind.yml", "taskcluster/ci/release-secondary-update-verify/kind.yml", "taskcluster/ci/release-update-verify-config/kind.yml", "taskcluster/ci/release-update-verify/kind.yml"], "git_node": null, "git_parents": [null], "node": "eecf9fdd492068670a5bf6da618ec0d14531b776", "parents": ["1243a7e81584512b0f4c45e3f73dab203aa88da0"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1541122: [try-staging] Support bouncer-check in staging; r=aki\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25835", "files": ["taskcluster/ci/cron-bouncer-check/kind.yml", "taskcluster/ci/release-bouncer-check/kind.yml", "taskcluster/taskgraph/transforms/bouncer_check.py", "testing/mozharness/configs/releases/bouncer_fennec.py", "testing/mozharness/configs/releases/bouncer_fennec_beta.py", "testing/mozharness/configs/releases/bouncer_firefox_beta.py", "testing/mozharness/configs/releases/bouncer_firefox_devedition.py", "testing/mozharness/configs/releases/bouncer_firefox_esr.py", "testing/mozharness/configs/releases/bouncer_firefox_release.py", "testing/mozharness/configs/releases/bouncer_thunderbird.py", "testing/mozharness/configs/releases/dev_bouncer_firefox_beta.py", "testing/mozharness/configs/releases/dev_bouncer_firefox_devedition.py", "testing/mozharness/configs/releases/dev_bouncer_firefox_esr.py", "testing/mozharness/scripts/release/bouncer_check.py"], "git_node": null, "git_parents": [null], "node": "6fb4bb5bb70eb18373b25a6d060fdf13fe3658df", "parents": ["eecf9fdd492068670a5bf6da618ec0d14531b776"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1541122: [mozharness] Remove unused bouncer_check config entries; r=mtabara\n\nI beleive these entries date from when bouncer config was handled by mozharness\nrather than bounerscript and are now obsolete.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25836", "files": ["testing/mozharness/configs/releases/bouncer_fennec.py", "testing/mozharness/configs/releases/bouncer_fennec_beta.py", "testing/mozharness/configs/releases/bouncer_firefox_beta.py", "testing/mozharness/configs/releases/bouncer_firefox_devedition.py", "testing/mozharness/configs/releases/bouncer_firefox_esr.py", "testing/mozharness/configs/releases/bouncer_firefox_release.py", "testing/mozharness/configs/releases/bouncer_thunderbird.py"], "git_node": null, "git_parents": [null], "node": "d99da487f0f66bcf1b4b98ce510be0035e595d88", "parents": ["6fb4bb5bb70eb18373b25a6d060fdf13fe3658df"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1541122: [mozharness] Remove unused bouncer configuration for fennect; r=mtabara\n\nFennec doesn't have a bouncer check task, and bouncer is update via bouncerscript.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25837", "files": ["testing/mozharness/configs/releases/bouncer_fennec.py", "testing/mozharness/configs/releases/bouncer_fennec_beta.py"], "git_node": null, "git_parents": [null], "node": "b746cd7942637ec5286703b1b5a5a1f5c24f7133", "parents": ["d99da487f0f66bcf1b4b98ce510be0035e595d88"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1541122: [mozharness] Simplify bouncer-check configuration to not include paths; r=mtabara\n\nThese existed for when bouncer was updated via mozharness, and they are unused in bouncer-check.\nBy removing the paths, we make the configuration easier to read and update.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25838", "files": ["testing/mozharness/configs/releases/bouncer_firefox_beta.py", "testing/mozharness/configs/releases/bouncer_firefox_devedition.py", "testing/mozharness/configs/releases/bouncer_firefox_esr.py", "testing/mozharness/configs/releases/bouncer_firefox_release.py", "testing/mozharness/configs/releases/bouncer_thunderbird.py", "testing/mozharness/scripts/release/bouncer_check.py"], "git_node": null, "git_parents": [null], "node": "043e6648282f068b13f95f8df90ad543149a97dc", "parents": ["b746cd7942637ec5286703b1b5a5a1f5c24f7133"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1541122: Don't create fresh virtualenv for bouncer-check; r=mtabara\n\nIn automation, the script is run with `mach python`, and all the dependencies\nare vendored, so just use them directly.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25839", "files": ["testing/mozharness/scripts/release/bouncer_check.py"], "git_node": null, "git_parents": [null], "node": "52730b61818935abf5ba0e8ce6cce908675c789e", "parents": ["043e6648282f068b13f95f8df90ad543149a97dc"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1533589: [win64-aarch64] Add win64 aarch64 bouner-check configuration; r=mtabara\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25840", "files": ["testing/mozharness/configs/releases/bouncer_firefox_beta.py", "testing/mozharness/configs/releases/bouncer_firefox_release.py"], "git_node": null, "git_parents": [null], "node": "3a1794991ba4fc07a69e5d75101c76826eb1aee7", "parents": ["52730b61818935abf5ba0e8ce6cce908675c789e"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1533589: [win64-aarch64] Point win64-aarch64 stub bounce entries at the correct path; r=mtabara a=tomprince\n\nThere was special case logic to map the win64 platform to win32, for stub\nentries. When win64-aarch64 was added no special case was added for that\nplaform, so they stub entries pointed at the incorrect place.  This changes the\nconfiguration so that all stub entries point at the win32 paths, without\nneeding special case code.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25841", "files": ["taskcluster/taskgraph/transforms/bouncer_submission.py"], "git_node": null, "git_parents": [null], "node": "3e71adc4ab1dfcbabeb559613924b755391e08d1", "parents": ["3a1794991ba4fc07a69e5d75101c76826eb1aee7"], "tags": ["DEVEDITION_67_0b8_BUILD1", "FIREFOX_67_0b8_BUILD1"]}], "date": 1554350483, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "mozilla@hocat.ca"}, "10995": {"changesets": [{"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1531057 - Add a test to check that session history respects the layout scroll range. r=JanH a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23753", "files": ["mobile/android/tests/browser/chrome/browser_scrollPositions_sample_small.html", "mobile/android/tests/browser/chrome/chrome.ini", "mobile/android/tests/browser/chrome/test_session_scroll_position.html"], "git_node": null, "git_parents": [null], "node": "e2f09a8bd87cb38405446b594058104f0c694561", "parents": ["3e71adc4ab1dfcbabeb559613924b755391e08d1"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1531057 - Fix eslint failure due to trailing whitespace (CLOSED TREE). a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25136", "files": ["mobile/android/tests/browser/chrome/test_session_scroll_position.html"], "git_node": null, "git_parents": [null], "node": "086b3323f453fb39d9c965b5f2a2aec018352698", "parents": ["e2f09a8bd87cb38405446b594058104f0c694561"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1538762 - Ensure the Android session store respects the layout scroll range. r=kats a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25144", "files": ["mobile/android/tests/browser/chrome/test_session_scroll_position.html", "toolkit/components/sessionstore/SessionStoreUtils.cpp"], "git_node": null, "git_parents": [null], "node": "d2592c21a5c4c45f87e5bb125a6838e11046e637", "parents": ["086b3323f453fb39d9c965b5f2a2aec018352698"], "tags": []}], "date": 1554366405, "git_changesets": [null, null, null], "user": "archaeopteryx@coole-files.de"}, "10996": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 3e71adc4ab1dfcbabeb559613924b755391e08d1 with DEVEDITION_67_0b8_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "1a763ad07ad3862be61b5a434b9f5ad2a396be9a", "parents": ["d2592c21a5c4c45f87e5bb125a6838e11046e637"], "tags": []}], "date": 1554367020, "git_changesets": [null], "user": "ffxbld"}, "10997": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla