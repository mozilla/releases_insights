onents/preferences/in-content/preferences.js", "browser/components/preferences/in-content/tests/browser.ini", "browser/components/preferences/in-content/tests/browser_sync_disabled.js", "browser/components/preferences/in-content/tests/head.js"], "git_node": null, "git_parents": [null], "node": "32cf4d4997be449f91a22ca0c0155860dd49916d", "parents": ["2f5aedeffed90029e870c65b7ad1c797c380186e"], "tags": []}], "date": 1553615259, "git_changesets": [null, null, null, null], "user": "rgurzau@mozilla.com"}, "10924": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging a89261364728dbfe37351e0de812e906c436a5d4 with DEVEDITION_67_0b5_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "92077cce211c1cbdad31011f563a7b76d3c163b6", "parents": ["32cf4d4997be449f91a22ca0c0155860dd49916d"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release DONTBUILD", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "8242683ef7b320272b77782f1fd2ea1c2231cfcd", "parents": ["92077cce211c1cbdad31011f563a7b76d3c163b6"], "tags": []}], "date": 1553619195, "git_changesets": [null, null], "user": "ffxbld"}, "10925": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging a89261364728dbfe37351e0de812e906c436a5d4 with FIREFOX_67_0b5_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "774092abb7918be9fe68c2e6b00ea04d8e6b87db", "parents": ["8242683ef7b320272b77782f1fd2ea1c2231cfcd"], "tags": []}], "date": 1553619388, "git_changesets": [null], "user": "ffxbld"}, "10926": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging a89261364728dbfe37351e0de812e906c436a5d4 with FENNEC_67_0b5_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "5c56e7ff721af8c44e631224de885e0dc82cfaff", "parents": ["774092abb7918be9fe68c2e6b00ea04d8e6b87db"], "tags": []}], "date": 1553619588, "git_changesets": [null], "user": "ffxbld"}, "10927": {"changesets": [{"author": "Mihai Tabara \u003cmtabara@mozilla.com\u003e", "branch": "default", "desc": "Bug 1535679 - switch Firefox nightlies to declarative artifacts. r=sfraser a=release\n\nLinter fixes.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24214", "files": ["taskcluster/ci/beetmover-repackage/kind.yml", "taskcluster/taskgraph/manifests/fennec_candidates.yml", "taskcluster/taskgraph/manifests/fennec_candidates_checksums.yml", "taskcluster/taskgraph/manifests/fennec_geckoview.yml", "taskcluster/taskgraph/manifests/fennec_nightly.yml", "taskcluster/taskgraph/manifests/fennec_nightly_checksums.yml", "taskcluster/taskgraph/manifests/firefox_nightly.yml", "taskcluster/taskgraph/manifests/firefox_nightly_checksums.yml", "taskcluster/taskgraph/manifests/release_checksums.yml", "taskcluster/taskgraph/manifests/source_checksums.yml", "taskcluster/taskgraph/manifests/source_files.yml", "taskcluster/taskgraph/transforms/beetmover_repackage.py", "taskcluster/taskgraph/transforms/mar_signing.py", "taskcluster/taskgraph/util/partials.py", "taskcluster/taskgraph/util/scriptworker.py"], "git_node": null, "git_parents": [null], "node": "b057c733c95275308b2dde23f1c0fc1ec8e2d12a", "parents": ["5c56e7ff721af8c44e631224de885e0dc82cfaff"], "tags": []}], "date": 1553627030, "git_changesets": [null], "user": "mtabara@mozilla.com"}, "10928": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nbe -\u003e fd068a7a4a95\nes-AR -\u003e c94b44864986\npt-PT -\u003e b3f5215b3e67\nsv-SE -\u003e 5b271c67eaf4\nzh-CN -\u003e 408cb01ed7a3", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "bf53657616690068d1717caf542a60b61ab41eb7", "parents": ["b057c733c95275308b2dde23f1c0fc1ec8e2d12a"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nbe -\u003e fd068a7a4a95\nes-AR -\u003e c94b44864986\nfr -\u003e 227160157a7e\npt-PT -\u003e 6adb789134de\nsv-SE -\u003e 5b271c67eaf4\nzh-CN -\u003e 408cb01ed7a3", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "7bd47d94daba0c54a474f737d5f0f6fd529f4f0e", "parents": ["bf53657616690068d1717caf542a60b61ab41eb7"], "tags": []}], "date": 1553630430, "git_changesets": [null, null], "user": "ffxbld"}, "10929": {"changesets": [{"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1538134: [mozharness] Set repository path in taskcluster; r=aki\n\nTaskcluster has authorative information about the repository being built, so\npass that to mozharness, rather than have mozharness reconstruct it from\nhand-maintained mozharness config.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24561", "files": ["taskcluster/taskgraph/transforms/job/mozharness.py", "testing/mozharness/configs/builds/branch_specifics.py", "testing/mozharness/mozharness/mozilla/building/buildbase.py"], "git_node": null, "git_parents": [null], "node": "bb986fa5395d4cbc0660e401ed62ae5c214023c2", "parents": ["7bd47d94daba0c54a474f737d5f0f6fd529f4f0e"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1538134: [mozharness] Remove explicit setting of branches to use release promotion; r=aki\n\nThe only thing this affects is the default update channel, but for shipping builds, this is set\nexplicitly via taskcluster, and for other branches, defaults to `default`.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24562", "files": ["testing/mozharness/configs/builds/branch_specifics.py", "testing/mozharness/mozharness/mozilla/building/buildbase.py"], "git_node": null, "git_parents": [null], "node": "3c0a452881327cecc40fe36a073c077e0f26f188", "parents": ["bb986fa5395d4cbc0660e401ed62ae5c214023c2"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1538134: [mozharness] Don't override PGO settings per-branch; r=aki\n\nThe release mozconfigs set `MOZ_PGO` and all shipping builds set the `nightly`\nmozharness config, so we don't need to additionaly set PGO based on the branch.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24563", "files": ["testing/mozharness/configs/builds/branch_specifics.py", "testing/mozharness/mozharness/mozilla/building/buildbase.py"], "git_node": null, "git_parents": [null], "node": "5903d728d99a36e4244c608c4fa866a93310cc00", "parents": ["3c0a452881327cecc40fe36a073c077e0f26f188"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1538134: [mozharness] Remove support for unused `builds/branch_specifics.py` config; r=aki a=tomprince\n\nWe have moved per-branch configuration to taskcluster, so we can remove that\nsupport in mozharness.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24564", "files": ["testing/mozharness/configs/builds/branch_specifics.py", "testing/mozharness/mozharness/mozilla/building/buildbase.py"], "git_node": null, "git_parents": [null], "node": "3a81fd4a729b5a850b9ba3ece1ad7625b5f13205", "parents": ["5903d728d99a36e4244c608c4fa866a93310cc00"], "tags": []}], "date": 1553667342, "git_changesets": [null, null, null, null], "user": "mozilla@hocat.ca"}, "10930": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nka -\u003e 3f7da35bf5d1\nko -\u003e 8f15f2b7cd79", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "168a440af6d0b56ef4446b04b71959ab1640b9e4", "parents": ["3a81fd4a729b5a850b9ba3ece1ad7625b5f13205"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\ndsb -\u003e 31db16d3f4bb\nhsb -\u003e a001fcadfcb8\nia -\u003e 1f5439c55310\nit -\u003e c2a7bddf2567\nka -\u003e 3f7da35bf5d1\nko -\u003e 8f15f2b7cd79\npl -\u003e 6136d8c93bea\npt-BR -\u003e ec1ffa911d8a", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "b1d84eac46a001cafa803c661b9cb0f1baeb4911", "parents": ["168a440af6d0b56ef4446b04b71959ab1640b9e4"], "tags": []}], "date": 1553680827, "git_changesets": [null, null], "user": "ffxbld"}, "10931": {"changesets": [{"author": "Nicolas B. Pierron \u003cnicolas.b.pierron@nbp.name\u003e", "branch": "default", "desc": "Bug 1532599 - Branch Pruning: Flag all Phi loops as used. r=jandem, a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23331", "files": ["js/src/jit/IonAnalysis.cpp"], "git_node": null, "git_parents": [null], "node": "fd088f468f864c7328268f7b840ed8cbca1fde4c", "parents": ["b1d84eac46a001cafa803c661b9cb0f1baeb4911"], "tags": []}], "date": 1553693820, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "10932": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nko -\u003e f884d8481492\nrm -\u003e 34a8d4a2cbf0", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "8c0ac909081741acc31bd6a60e114414a35ec1eb", "parents": ["fd088f468f864c7328268f7b840ed8cbca1fde4c"], "tags": []}], "date": 1553695226, "git_changesets": [null], "user": "ffxbld"}, "10933": {"changesets": [{"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 1535701 - Don't clear focus when moving vc away from focused node. r=yzen a=pascalc\n\nThis is more consistent with how it works in GeckoView. We need to give\nup this behavior because it reset the top-level caret position on each\nblur. This interferes with find in page which goes to the next search\nresult past the current caret.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23746", "files": ["accessible/jsat/EventManager.jsm"], "git_node": null, "git_parents": [null], "node": "c6e144b70ff5fb7b8d4a13052dc243670267036d", "parents": ["8c0ac909081741acc31bd6a60e114414a35ec1eb"], "tags": []}, {"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 1535701 - Focus GeckoView when interacting with TalkBack. r=geckoview-reviewers,snorp a=pascalc\n\nWhen TalkBack receives a focus event, it redirects the accessibility focus (the green cursor) to the focused element. This is an important driver for the screen reader experience.\n\nSince the focus mode of the GeckoView is \"focusable in touch\", the focused state of the view is very arbitrary when using TalkBack since the user never directly touches the view. The only way for the view to regain focus is if a control or link in the content is interacted with.\n\nTalkBack user, who is explicitly interacting with the webview/geckoview would expect it to have focus, and to have the accessibility focus redirected in the page in the case of script-driven focus events.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23747", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/geckoview/SessionAccessibility.java"], "git_node": null, "git_parents": [null], "node": "b5979c2fa68fefe151bf3ea1b8d2190beb245d7f", "parents": ["c6e144b70ff5fb7b8d4a13052dc243670267036d"], "tags": []}, {"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 1535701 - Followup to fix checkstyle and eslint. a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24232", "files": ["accessible/jsat/EventManager.jsm", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/SessionAccessibility.java"], "git_node": null, "git_parents": [null], "node": "0ea6b4ddf9c6920e0e88fabadc749f82504a1bbe", "parents": ["b5979c2fa68fefe151bf3ea1b8d2190beb245d7f"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1536427 - Stop calling actions.pauseOnExceptions on Debugger startup;r=jlast a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24160", "files": ["devtools/client/debugger/new/src/client/index.js"], "git_node": null, "git_parents": [null], "node": "c9e5b98d97c973f6d55cea531c776c7dc15c987a", "parents": ["0ea6b4ddf9c6920e0e88fabadc749f82504a1bbe"], "tags": []}, {"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1533789 - LSRequestBase::Finish is not called in some edge cases; r=asuth a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24649", "files": ["dom/localstorage/ActorsParent.cpp"], "git_node": null, "git_parents": [null], "node": "33463766bc34c08473b2acb4a05575174ac868f7", "parents": ["c9e5b98d97c973f6d55cea531c776c7dc15c987a"], "tags": []}, {"author": "Matt Brubeck \u003cmbrubeck@mozilla.com\u003e", "branch": "default", "desc": "Bug 1527778 - Fix reloading of content modules on procses switching. r=snorp a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24102", "files": ["mobile/android/chrome/geckoview/geckoview.js"], "git_node": null, "git_parents": [null], "node": "56567a8607b5cf0e804c737a9fcd03a422e3fdf4", "parents": ["33463766bc34c08473b2acb4a05575174ac868f7"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1531057 - In ScrollToRestoredPosition(), clamp the layout scroll offset being restored to the layout scroll range. r=kats a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23725", "files": ["layout/generic/nsGfxScrollFrame.cpp"], "git_node": null, "git_parents": [null], "node": "d5a9d2da215fe31f734b047cdfdb12fbc5afd732", "parents": ["56567a8607b5cf0e804c737a9fcd03a422e3fdf4"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1537640 - Properly autofill partial IPs in the address bar. r=adw a=pascalc\n\nTrying to autofill as urls breaks our assumptions.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24572", "files": ["browser/components/urlbar/UrlbarTokenizer.jsm", "toolkit/components/places/tests/unifiedcomplete/test_autofill_origins.js"], "git_node": null, "git_parents": [null], "node": "d86ab22b61a1f8bf3cc1484deb69a24f0bef6578", "parents": ["d5a9d2da215fe31f734b047cdfdb12fbc5afd732"], "tags": []}, {"author": "Alex Chronopoulos \u003cachronop@gmail.com\u003e", "branch": "default", "desc": "Bug 1536783 - Use two tile threads in dav1d decoder for performance improvement. r=TD-Linux a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24331", "files": ["dom/media/platforms/agnostic/DAV1DDecoder.cpp", "dom/media/platforms/agnostic/DAV1DDecoder.h"], "git_node": null, "git_parents": [null], "node": "0feaf41d4e517439650f4f751a3df0d234d4971d", "parents": ["d86ab22b61a1f8bf3cc1484deb69a24f0bef6578"], "tags": []}, {"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 1536123 - Move virtual cursor to caret offset. r=yzen a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23911", "files": ["accessible/jsat/EventManager.jsm", "accessible/jsat/Utils.jsm", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/AccessibilityTest.kt"], "git_node": null, "git_parents": [null], "node": "5565a1128640e9a736a42683012506b02ec2cb5b", "parents": ["0feaf41d4e517439650f4f751a3df0d234d4971d"], "tags": []}, {"author": "Vlad Baicu \u003cvlad.baicu@softvision.ro\u003e", "branch": "default", "desc": "Bug 1536866 - Hide enter guest session option from the menu. r=petru a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24212", "files": ["mobile/android/base/java/org/mozilla/gecko/BrowserApp.java"], "git_node": null, "git_parents": [null], "node": "affaab9df5b77f8ff5571748e149d39dfa25e27c", "parents": ["5565a1128640e9a736a42683012506b02ec2cb5b"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1536521: Use a capturing listener for PanelMultiView's keydown handler. r=Gijs a=pascalc\n\nPanelMultiView adds the keydown handler on the window so that it handles key presses when a panel appears but doesn't get focus, as happens when a button to open a panel is clicked with the mouse.\nHowever, this means the listener is on an ancestor of the panel, which means that handlers such as ToolbarKeyboardNavigator are deeper in the tree.\nPreviously, PanelMultiView used a bubbling (default) listener.\nThis meant that ToolbarKeyboardNavigator handled the event first, causing it to interfere when a panel opened within the toolbar; e.g. the Library menu.\nTo fix this, use a capturing listener for PanelMultiView so it gets the event first.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24848", "files": ["browser/base/content/test/keyboard/browser.ini", "browser/base/content/test/keyboard/browser_toolbarButtonKeyPress.js", "browser/base/content/test/keyboard/browser_toolbarKeyNav.js", "browser/base/content/test/keyboard/head.js", "browser/components/customizableui/PanelMultiView.jsm"], "git_node": null, "git_parents": [null], "node": "7b34fc9165b9047186a4bf940d8028aaf0281f3f", "parents": ["affaab9df5b77f8ff5571748e149d39dfa25e27c"], "tags": []}], "date": 1553696601, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "apavel@mozilla.com"}, "10934": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nfi -\u003e 23c5f14d1725\ngn -\u003e 09a8a80e54d6\nnb-NO -\u003e 04f7dddbe6cf", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "d0f88c4218dd9ebd852de9d210175e42f4d6f758", "parents": ["7b34fc9165b9047186a4bf940d8028aaf0281f3f"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nfi -\u003e 0810cd0329f1\ngn -\u003e 09a8a80e54d6\nia -\u003e f8cca6bb28d4\nnb-NO -\u003e 03e730298818\nnl -\u003e 8cab92e5c183\npt-BR -\u003e c32fdc82fe61", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "3cd731100d7ffd0fa1af1c9d97f2bb6472d72641", "parents": ["d0f88c4218dd9ebd852de9d210175e42f4d6f758"], "tags": []}], "date": 1553738426, "git_changesets": [null, null], "user": "ffxbld"}, "10935": {"changesets": [{"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1450019 - Upload snap to archive.m.o r=mtabara a=release\n\nUpload snap to archive.m.o\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24209", "files": ["taskcluster/ci/beetmover-snap/kind.yml", "taskcluster/ci/release-snap-repackage/kind.yml", "taskcluster/docs/kinds.rst", "taskcluster/taskgraph/manifests/firefox_snap.yml", "taskcluster/taskgraph/transforms/beetmover.py", "taskcluster/taskgraph/transforms/beetmover_snap.py", "taskcluster/taskgraph/util/scriptworker.py"], "git_node": null, "git_parents": [null], "node": "84f6aafe5d5c0d9d45b893b48d75064d519e62f6", "parents": ["3cd731100d7ffd0fa1af1c9d97f2bb6472d72641"], "tags": []}], "date": 1553756522, "git_changesets": [null], "user": "jlorenzo@mozilla.com"}, "10936": {"changesets": [{"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1532530 - Avoid loss of upload data by webRequest API r=kmag a=pascalc\n\nWhen an extension requests access to the request body of a request,\n`nsConverterInputStream` is used to parse the input streams that make up\na request body. These input streams are later (re)used to upload the\nform data to the original destination (server).\n\n`nsConverterInputStream`'s destructor does however close the input\nstreams, which results in data loss when the object is garbage-collected\nbefore the upload completes.\n\nThis patch fixes the issue by explicitly nulling the underlying stream\nbefore returning from the form parser.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24539", "files": ["toolkit/modules/addons/WebRequestUpload.jsm"], "git_node": null, "git_parents": [null], "node": "85efc85e2cf3e5d3e26cfdf8a716bbb9ac3551b5", "parents": ["84f6aafe5d5c0d9d45b893b48d75064d519e62f6"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1533150 - Hide 'Run in Private Windows' controls from about:addons for extensions allowed automatically on every extension startup. r=aswan,mixedpuppy a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23663", "files": ["toolkit/mozapps/extensions/AddonManager.jsm", "toolkit/mozapps/extensions/content/extensions.js", "toolkit/mozapps/extensions/internal/XPIDatabase.jsm", "toolkit/mozapps/extensions/test/browser/browser_details.js", "toolkit/mozapps/extensions/test/browser/head.js"], "git_node": null, "git_parents": [null], "node": "acb4a36667140807290d693ab897c98ffb16ea7f", "parents": ["85efc85e2cf3e5d3e26cfdf8a716bbb9ac3551b5"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1533172 - Show post install notification when enabling sideload extensions. r=mixedpuppy,kmag a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D22700", "files": ["browser/base/content/test/webextensions/browser_extension_sideloading.js", "browser/modules/ExtensionsUI.jsm", "toolkit/mozapps/extensions/content/extensions.js", "toolkit/mozapps/extensions/test/browser/browser_extension_sideloading_permission.js"], "git_node": null, "git_parents": [null], "node": "dccd60f0b7bac255d706a50d712e9b839ffe6bb0", "parents": ["acb4a36667140807290d693ab897c98ffb16ea7f"], "tags": []}, {"author": "Mark Hammond \u003cmhammond@skippinet.com.au\u003e", "branch": "default", "desc": "Bug 1534699 - ensure new windows default to 'setup sync' state. r=eoger a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24665", "files": ["browser/base/content/browser-sync.js"], "git_node": null, "git_parents": [null], "node": "db9f6521276f71271f8836b16ba94c3baf401033", "parents": ["dccd60f0b7bac255d706a50d712e9b839ffe6bb0"], "tags": []}, {"author": "David Major \u003cdmajor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1535441 - Update win64 clang-cl to 8.0.0final r=firefox-build-system-reviewers,chmanchester a=pascalc\n\nThis gets us back to using an official release.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24069", "files": ["build/build-clang/clang-win64.json"], "git_node": null, "git_parents": [null], "node": "70c4704cadd562eb821e96dd219d78ced79b4189", "parents": ["db9f6521276f71271f8836b16ba94c3baf401033"], "tags": []}], "date": 1553776060, "git_changesets": [null, null, null, null, null], "user": "cbrindusan@mozilla.com"}, "10937": {"changesets": [{"author": "Dennis Schubert \u003cdschubert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1538970 - Add IBM domains as wildcard exceptions for legacy keyCode and charCode. r=miketaylr a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24948", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "15d5b056cd7d1b3bcf265e1407d2734960931407", "parents": ["70c4704cadd562eb821e96dd219d78ced79b4189"], "tags": []}, {"author": "Bryce Van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1538253 - VPXDecoder::IsCompatible checks subsampling x members for equality. r=jya a=pascalc\n\nWe had a stray `&&` where a `==` should have been.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24526", "files": ["dom/media/platforms/agnostic/VPXDecoder.h"], "git_node": null, "git_parents": [null], "node": "e1be433d057435f00c2126dcbc1a306dbf5c69db", "parents": ["15d5b056cd7d1b3bcf265e1407d2734960931407"], "tags": []}, {"author": "Jason Orendorff \u003cjorendorff@mozilla.com\u003e", "branch": "default", "desc": "Bug 1537609 - Cap the stack size at 2MB on Windows. r=jandem a=pascalc\n\nIn bug 256180, the size of the stack on 64-bit Windows was changed from 2MB to\n8MB, and on 32-bit Windows, from 1MB to 1.5MB. This is so large that it takes\nsignificantly longer for a runaway recursive function to throw \"too much\nrecursion\", which causes terrible performance in scripts obfuscated using\nobfuscator.io.\n\nThis patch leaves the actual stack size as-is, but changes the\nJS-engine-specific stack quota back to 2MB on 64-bit Windows (6MB if ASAN is\nenabled). 32-bit Windows is unaffected by the new cap.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24597", "files": ["js/xpconnect/src/XPCJSContext.cpp"], "git_node": null, "git_parents": [null], "node": "be897c0f03b58b182c8221eefa1238626dc0e132", "parents": ["e1be433d057435f00c2126dcbc1a306dbf5c69db"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1537587 - Add Noto fonts for more languages to Android version of GetCommonFallbackFonts. r=lsalzman a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24292", "files": ["gfx/thebes/gfxAndroidPlatform.cpp"], "git_node": null, "git_parents": [null], "node": "06fcdd66507750c295355a287d9b815a58bb0227", "parents": ["be897c0f03b58b182c8221eefa1238626dc0e132"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1537542 - Hide addon preferences if the addon cannot access the current window. r=aswan a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24534", "files": ["toolkit/mozapps/extensions/content/extensions.js", "toolkit/mozapps/extensions/content/extensions.xml", "toolkit/mozapps/extensions/test/browser/browser_webext_incognito.js"], "git_node": null, "git_parents": [null], "node": "d42c58c97c84eb7c55a6d8776cdd3ac11e66bd27", "parents": ["06fcdd66507750c295355a287d9b815a58bb0227"], "tags": []}], "date": 1553777322, "git_changesets": [null, null, null, null, null], "user": "nbeleuzu@mozilla.com"}, "10938": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP blocklist remote-settings - a=repo-update r=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25211", "files": ["browser/app/blocklist.xml", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/blocklists/addons.json"], "git_node": null, "git_parents": [null], "node": "01fc4edd840ae80b5819054861d3e3e727162d4c", "parents": ["d42c58c97c84eb7c55a6d8776cdd3ac11e66bd27"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1322645.  Fix intermittent test timeout by making sure our prefs are set before we start doing parts of the test.  r=jmaher, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24307", "files": ["dom/xul/test/test_bug757137.xul"], "git_node": null, "git_parents": [null], "node": "af215de02eec43c188bcbe7b3589b39dbefedd1d", "parents": ["01fc4edd840ae80b5819054861d3e3e727162d4c"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1533221 - In Mn test_capabilities.py, compare only the basename of profile paths; r=whimboo, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24377", "files": ["testing/marionette/harness/marionette_harness/tests/unit/test_capabilities.py"], "git_node": null, "git_parents": [null], "node": "086a215d4caadb457a629887524907149cde1c4d", "parents": ["af215de02eec43c188bcbe7b3589b39dbefedd1d"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1532395 - Clear the DNS cache before each TRR test. r=JuniorHsu, a=test-only\n\nIt is likely that the test is flaky because we resolve the same host with a different TRR endpoint and sometimes we use a cached record.\nWe should clear the DNS cache before each test to ensure that we're actually checking the right thing.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24355", "files": ["netwerk/test/unit/test_trr.js"], "git_node": null, "git_parents": [null], "node": "e221b428f081392adf3d082122dfafac86246125", "parents": ["086a215d4caadb457a629887524907149cde1c4d"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1504336 - Avoid race in test_pc_simulcastOddResolution.html. r=jib, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24725", "files": ["dom/media/tests/mochitest/test_peerConnection_simulcastOddResolution.html"], "git_node": null, "git_parents": [null], "node": "8f40010937b5e862caf30954caf17444709b38bb", "parents": ["e221b428f081392adf3d082122dfafac86246125"], "tags": []}, {"author": "danielleleb \u003cdanielleleb12@gmail.com\u003e", "branch": "default", "desc": "Bug 1535865 - Fixes intermittent error caused by hidden security tab. r=johannh, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24969", "files": ["browser/base/content/test/pageinfo/browser_pageinfo_security.js"], "git_node": null, "git_parents": [null], "node": "3c19646ca2d05508dddd236d6ada2611eeecbcad", "parents": ["8f40010937b5e862caf30954caf17444709b38bb"], "tags": []}, {"author": "Matthew Noorenberghe \u003cmozilla@noorenberghe.ca\u003e", "branch": "default", "desc": "Bug 1530603 - Wait for #filter in browser_autocomplete_footer.js. r=intermittent, a=test-only", "files": ["toolkit/components/passwordmgr/test/browser/browser_autocomplete_footer.js", "toolkit/components/passwordmgr/test/browser/browser_openPasswordManager.js", "toolkit/components/passwordmgr/test/browser/head.js"], "git_node": null, "git_parents": [null], "node": "6b273123543412fa98b0c551863efb7d8270bf2e", "parents": ["3c19646ca2d05508dddd236d6ada2611eeecbcad"], "tags": []}], "date": 1553779642, "git_changesets": [null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "10939": {"changesets": [{"author": "Mats Palmgren \u003cmats@mozilla.com\u003e", "branch": "default", "desc": "Bug 1535986 - Skip recomputing the position for frames that have a pending reflow.  r=dholbert a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23971", "files": ["layout/base/RestyleManager.cpp"], "git_node": null, "git_parents": [null], "node": "9b874010673d878cb9772770bc8ba7f6572ee693", "parents": ["6b273123543412fa98b0c551863efb7d8270bf2e"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1527463 - Enable EME on win64-aarch64 nightlies. r=tomprince a=pascalc\n\nBug 1534522 added win64-aarch64-eme/opt builds, which are artifact builds\nthat glue together a win64-aarch64/opt build and a win32/opt build.\n\nThis enables EME on the corresponding nightlies in a slightly different\nway:\n- this adds a no-eme build that corresponds to win64-aarch64/opt.\n- this turns the existing nightly into an artifact build that glues\n  together that no-eme build and the win32 nightly.\n\nThe no-eme build cannot have the nightly attribute set, first because\nthe beetmover transform fails in that case, and because that would imply\nshipping those builds, but they're not meant to be shipped this way.\n\nIt also has run-on-projects set to an empty list so that it doesn't\nappear by default in `mach try fuzzy`, while still being triggered when\nneeded due to being a dependency of the nightly build.\n\nIt is preferable to keep the win64-aarch64{,-eme}/opt builds untouched\nto make things easier for try (the win64-aarch64 ones being the main\nones to try; also, the -eme builds currently fail with --artifacts).\n\nIdeally, like in bug 1534522, we'd add a diffoscope build to ensure\nthe variations between the nightly and its base no-eme build are within\ncontrol, but currently, that would trigger nightlies on every push,\nwhich is not desirable. Ideally, they'd trigger whenever both their\ndependencies are in the target task graph. We leave that to a followup.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23640", "files": ["taskcluster/ci/build/windows.yml"], "git_node": null, "git_parents": [null], "node": "7c3c3ffea0a4fb284e99afecdd15bc37bfeec12c", "parents": ["9b874010673d878cb9772770bc8ba7f6572ee693"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1527463 - Get full artifact build symbols for aarch64 EME builds. r=mshal a=pascalc\n\nWe need to have full symbols uploaded for the upcoming EME-enabled\nwin64-aarch64 nightlies, and the tasks to do that are derived from the\nnightly itself, which is going to be an artifact build. Bug 1527463 took\ncare of adding the option to enable that, and we turn it on for\nEME-enabled builds.\n\nMOZ_ARTIFACT_TASK_WIN32_OPT is not exactly the right thing, but we're\nalready using it to enable EME in\nbrowser/config/mozconfigs/win64-aarch64/common-opt and is only set on\nthose builds.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23639", "files": ["build/mozconfig.artifact"], "git_node": null, "git_parents": [null], "node": "216a721a0b8cda07c6da016c741563e15d19ed14", "parents": ["7c3c3ffea0a4fb284e99afecdd15bc37bfeec12c"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1537707 - Don't use full build symbols artifacts when MOZ_DISABLE_FULL_SYMBOLS is set. r=chmanchester a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24449", "files": ["build/mozconfig.artifact"], "git_node": null, "git_parents": [null], "node": "0e7912ebf4946d6fb185c17e88f81ae6cb871e9e", "parents": ["216a721a0b8cda07c6da016c741563e15d19ed14"], "tags": []}, {"author": "Alastor Wu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1537554 - part1 : add debug logs. r=jya a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24473", "files": ["dom/html/TextTrackManager.cpp"], "git_node": null, "git_parents": [null], "node": "3f25e13283021c46039f566437967260e5cf4e32", "parents": ["0e7912ebf4946d6fb185c17e88f81ae6cb871e9e"], "tags": []}, {"author": "Alastor Wu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1537554 - part2 : let track track handle adding `current cue` and `other cue` if it's not disable. r=jya a=pascalc\n\nAccording to the spec [1], `current cues` and `other cues` should only contain cues from `hidden` or `showing` text tracks.\n\nIn this patch, text track would be responsible to add `current cues` and `other cues` to the cues list by calling `GetCurrentCuesAndOtherCues()`.\n\nIf the text track is disabled, then it won't add any cues to the cues list.\n\nIn addition, in order to reduce the size of `other cues` (as actually we don't need to process all cues in the `other cues`), we use the time interval to only get the cues which are overlapping with the time interval.\n\n[1] https://html.spec.whatwg.org/multipage/media.html#time-marches-on\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24475", "files": ["dom/html/TextTrackManager.cpp", "dom/html/TextTrackManager.h", "dom/media/TextTrack.cpp", "dom/media/TextTrack.h", "dom/media/TextTrackCueList.cpp", "dom/media/TextTrackCueList.h"], "git_node": null, "git_parents": [null], "node": "00a14c57b0ad27c22f5301f8a8a50ed8c274f91f", "parents": ["3f25e13283021c46039f566437967260e5cf4e32"], "tags": []}, {"author": "Alastor Wu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1537554 - part3 : do not collect negative length cue for other cues. r=jya a=pascalc\n\nCue might have negative length because user can set cue's end time via `TextTrackCue`'s API and the spec doesn't have strong restriction that the end time should be equal or larger than the start time of the cue.\n\nAs the negative length cue won't be displayed, we have no need to add it to the `other cues`.\n\n[1] https://html.spec.whatwg.org/multipage/media.html#dom-texttrackcue-endtime\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24857", "files": ["dom/media/TextTrack.cpp", "testing/web-platform/meta/html/semantics/embedded-content/media-elements/track/track-element/track-cues-missed.html.ini", "testing/web-platform/tests/html/semantics/embedded-content/media-elements/track/track-element/track-cues-missed.html"], "git_node": null, "git_parents": [null], "node": "0b745b93a430983cdcd6c748e6e2098d012e1969", "parents": ["00a14c57b0ad27c22f5301f8a8a50ed8c274f91f"], "tags": ["DEVEDITION_67_0b6_BUILD1", "DEVEDITION_67_0b6_RELEASE", "FIREFOX_67_0b6_BUILD1", "FIREFOX_67_0b6_RELEASE"]}], "date": 1553786614, "git_changesets": [null, null, null, null, null, null, null], "user": "cbrindusan@mozilla.com"}, "10940": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 0b745b93a430983cdcd6c748e6e2098d012e1969 with DEVEDITION_67_0b6_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "3122546bfe50ad4dfc2b27673e87d1c93c969570", "parents": ["0b745b93a430983cdcd6c748e6e2098d012e1969"], "tags": []}], "date": 1553799464, "git_changesets": [null], "user": "ffxbld"}, "10941": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 0b745b93a430983cdcd6c748e6e2098d012e1969 with FIREFOX_67_0b6_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "e5a8915abc47dbb7cfdd702d0a8f169e086ca7b6", "parents": ["3122546bfe50ad4dfc2b27673e87d1c93c969570"], "tags": []}], "date": 1553799659, "git_changesets": [null], "user": "ffxbld"}, "10942": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nar -\u003e a0b5e8dcf0f0\nbg -\u003e 3fb429889051\ncs -\u003e 3f96797b36a4\nen-GB -\u003e 9377a94cbc77\ngn -\u003e 7a89f2823fb8\nit -\u003e 3bafbba09c93\nlij -\u003e e84193ebfdd8\npt-BR -\u003e 5d4b5855ef4a\nsr -\u003e f5f199d19832\nth -\u003e 3e42a28cb360\nzh-TW -\u003e cc2397a2b9b8", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "2a61ca8feea89c0ca4a7e1300cdfbb700923394e", "parents": ["e5a8915abc47dbb7cfdd702d0a8f169e086ca7b6"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nach -\u003e 784a1557f571\naf -\u003e e06234e4dcf2\nan -\u003e 9ec7cc385120\nar -\u003e e1708e4fde32\nast -\u003e 0e6740a6077