["toolkit/components/search/tests/xpcshell/test_big_icon.js", "toolkit/components/search/tests/xpcshell/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "dc1994aefb3dfc3e974604f1bef424d7067ad24b", "parents": ["94dc8b2e7cb90e47a172823b3b5f94a0595a35a2"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1532257 - Remove frequently-failing assertion. r=mattwoodrow, a=NPOTB\n\nWe're gonna delete all this code imminently anyway.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25932", "files": ["gfx/layers/mlgpu/LayerManagerMLGPU.cpp"], "git_node": null, "git_parents": [null], "node": "146e15a24ea12ce80060d2fac13aad0f19dbfde0", "parents": ["dc1994aefb3dfc3e974604f1bef424d7067ad24b"], "tags": []}], "date": 1554384756, "git_changesets": [null, null, null], "user": "ryanvm@gmail.com"}, "11000": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 13b7d4d4df59f7f2e50f66644daf655bad40bec8 with DEVEDITION_67_0b8_BUILD2 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "6bc836b1a8589b0048c13dc7abeee7388fd07835", "parents": ["146e15a24ea12ce80060d2fac13aad0f19dbfde0"], "tags": []}], "date": 1554385074, "git_changesets": [null], "user": "ffxbld"}, "11001": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 13b7d4d4df59f7f2e50f66644daf655bad40bec8 with FIREFOX_67_0b8_BUILD2 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "c767d6f524b100d8e008a5fac846943eea3ad579", "parents": ["6bc836b1a8589b0048c13dc7abeee7388fd07835"], "tags": []}], "date": 1554385384, "git_changesets": [null], "user": "ffxbld"}, "11002": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", 