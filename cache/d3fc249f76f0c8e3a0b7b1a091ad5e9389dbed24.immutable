arents": [null], "node": "904ef1e892740b2e0f5fd89df2f71874dc8ce7b6", "parents": ["a43242faedaacc34f505852a701d2e46dd347987"], "tags": []}], "date": 1556539228, "git_changesets": [null, null], "user": "ffxbld"}, "11179": {"changesets": [{"author": "diana.iacos \u003cdiana.iacos@softvision.ro\u003e", "branch": "default", "desc": "Bug 1544589 - Streamline the \"Make Firefox your default browser\" user settings workflow; r=petru a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D28657", "files": ["mobile/android/app/src/main/res/xml-v11/preferences_default_browser_tablet.xml", "mobile/android/app/src/main/res/xml/preferences.xml", "mobile/android/base/java/org/mozilla/gecko/preferences/DefaultBrowserPreference.java", "mobile/android/base/java/org/mozilla/gecko/preferences/GeckoPreferences.java", "mobile/android/base/java/org/mozilla/gecko/preferences/LinkPreference.java", "mobile/android/base/java/org/mozilla/gecko/util/PackageUtil.java", "mobile/android/base/locales/en-US/android_strings.dtd", "mobile/android/base/strings.xml.in"], "git_node": null, "git_parents": [null], "node": "7cd4ca8e9fc719967bb691f241b1d35ce5dcc0d6", "parents": ["904ef1e892740b2e0f5fd89df2f71874dc8ce7b6"], "tags": []}, {"author": "diana.iacos \u003cdiana.iacos@softvision.ro\u003e", "branch": "default", "desc": "Bug 1544589 - Refactor isDefaultBrowser out from MmaDelegate to PackageUtil; r=petru a=pascalc\n\nDepends on D28657\n\nDifferential Revision: https://phabricator.services.mozilla.com/D28673", "files": ["mobile/android/base/java/org/mozilla/gecko/mma/MmaDelegate.java", "mobile/android/base/java/org/mozilla/gecko/preferences/DefaultBrowserPreference.java", "mobile/android/base/java/org/mozilla/gecko/preferences/GeckoPreferences.java", "mobile/android/base/java/org/mozilla/gecko/telemetry/pingbuilders/TelemetryCorePingBuilder.java", "mobile/android/base/java/org/mozilla/gecko/util/PackageUtil.java"], "git_node": null, "git_parents": [null], "node": "ae9abd4300192587cb4e6c1036c907fcfc00c394", "parents": ["7cd4ca8e9fc719967bb691f241b1d35ce5dcc0d6"], "tags": []}, {"author": "diana.iacos \u003cdiana.iacos@softvision.ro\u003e", "branch": "default", "desc": "Bug 1546889 - Update Default Browser toast message; r=petru,flod a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D28831", "files": ["mobile/android/base/locales/en-US/android_strings.dtd"], "git_node": null, "git_parents": [null], "node": "2642b7ac4a2eab9847be12750a68dd570aedfab4", "parents": ["ae9abd4300192587cb4e6c1036c907fcfc00c394"], "tags": []}, {"author": "diana.iacos \u003cdiana.iacos@softvision.ro\u003e", "branch": "default", "desc": "Bug 1546889 - Refresh Settings layout if default browser was changed while in background; r=petru a=pascalc\n\nHandle 2 specific edge-cases:\n- The user presses to change default browser, when he returns to the app the\napp settings button to do so should not be displayed anymore.\n- With the app in background showing the app settings the user changes to a\ndifferent default browser. When resuming the app it should show the option to\nset Fennec as default.\nAll this without otherwise requiring the user to close app settings and opening\nthem again.\n\nDepends on D28831\n\nDifferential Revision: https://phabricator.services.mozilla.com/D28832", "files": ["mobile/android/base/java/org/mozilla/gecko/preferences/GeckoPreferenceFragment.java"], "git_node": null, "git_parents": [null], "node": "d2c409855d1654aec38fbdcee5829a27e0335a4a", "parents": ["2642b7ac4a2eab9847be12750a68dd570aedfab4"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1545805 - Update Fennec Onboarding process; r=VladBaicu a=pascalc\n\nThe new Onboarding process will have updated imagery and strings.\nIt will also not show the \"Customize\" screen anymore.\n\nIt will only be shown if the new Strings are localized;\n\nDifferential Revision: https://phabricator.services.mozilla.c