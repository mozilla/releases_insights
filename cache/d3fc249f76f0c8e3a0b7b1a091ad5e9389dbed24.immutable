ode": null, "git_parents": [null], "node": "b6fab42eef37d0e32441a2dacf91f4bd2277c214", "parents": ["305bb668e9602ae29b4833131f6967393f94de4d"], "tags": []}], "date": 1556897416, "git_changesets": [null, null], "user": "sfraser@mozilla.com"}, "11224": {"changesets": [{"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1539393 - TransactionDatabaseOperationBase::ActorDestroy doesn't check if we are waiting for the Continue message; r=asuth, a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D27429", "files": ["dom/indexedDB/ActorsParent.cpp"], "git_node": null, "git_parents": [null], "node": "76d84e7aeb3ffc34d0d52cc4adc89bd6ddd0c2e7", "parents": ["b6fab42eef37d0e32441a2dacf91f4bd2277c214"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1544792 - Abort on try-catch blocks when doing definite properties analysis. r=nbp, a=pascalc\n\nIon does not compile the catch block so the analysis fails to account for code\nthere.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D29475", "files": ["js/src/jit-test/tests/ion/bug1544792.js", "js/src/jit/IonBuilder.cpp"], "git_node": null, "git_parents": [null], "node": "dbd28ea2e13c17d9566a8a95370b87a6d3341e71", "parents": ["76d84e7aeb3ffc34d0d52cc4adc89bd6ddd0c2e7"], "tags": []}], "date": 1556902937, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "11225": {"changesets": [{"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Backed out changeset 305bb668e960 (Bug 1536665) for being inadvertently uplifted; a=backout", "files": ["browser/config/whats_new_page.yml"], "git_node": null, "git_parents": [null], "node": "ea86833ccce9c01ee09b4377556ae58c68508141", "parents": ["dbd28ea2e13c17d9566a8a95370b87a6d3341e71"], "tags": []}], "date": 1556912929, "git_changesets": [null], "user": "mozilla@hocat.ca"}, "11226": {"changesets": [{"author": "Andrei Teslovan \u003candrei.teslovan@softvision.ro\u003e", "branch": "default", "desc": "Bug 1548000 - Default browser triggers \"Default apps\" screen; r=VladBaicu a=pascalc", "files": ["mobile/android/base/java/org/mozilla/gecko/preferences/DefaultBrowserPreference.java"], "git_node": null, "git_parents": [null], "node": "d6c5478f35e9cc7d184772959017bef94854f72f", "parents": ["ea86833ccce9c01ee09b4377556ae58c68508141"], "tags": []}, {"author": "Bas Schouten \u003cbschouten@mozilla.com\u003e", "branch": "default", "desc": "Bug 1535866: Check if a valid DeviceContext is available before attempting to use it. r=rhunt a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D29106", "files": ["gfx/2d/DrawTargetD2D1.cpp"], "git_node": null, "git_parents": [null], "node": "06f7ac4473b0c5f0e34a784e3f61d174f802a358", "parents": ["d6c5478f35e9cc7d184772959017bef94854f72f"], "tags": []}, {"author": "Bas Schouten \u003cbschouten@mozilla.com\u003e", "branch": "default", "desc": "Bug 1536229: Remove NS_RELEASE_ASSERT that is being tripped and seems to be unnecessary. r=rhunt a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D29105", "files": ["gfx/2d/SourceSurfaceCapture.cpp"], "git_node": null, "git_parents": [null], "node": "a4417ce665b2bac2cf391dac60d0b3deaf38e63f", "parents": ["06f7ac4473b0c5f0e34a784e3f61d174f802a358"], "tags": []}], "date": 1556927358, "git_changesets": [null, null, null], "user": "malexandru@mozilla.com"}, "11227": {"changesets": [{"author": "Dana Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "Bug 1549010 - verify add-on signing certificates at 2019-04-27T02:43:20.000Z r=jcj a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D29928", "files": ["security/apps/AppSignatureVerification.cpp"], "git_node": null, "git_parents": [null], "node": "d716b75b8ac3f4588061e720074c093dae08e43e", "parents": ["a4417ce665b2bac2cf391dac60d0b3deaf38e63f"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1549010: Part 2 - Bump DB schema version to force certificate reverification. r=zombie a=lizzard CLOSED TREE\n\nUsers who are affected by the intermediate add-on signing certificate expiry\nneed their add-on signatures re-verified as soon as possible after updating to\na version containging the fix. A database rebuild includes signature\nreverifications, so a schema version achieves this.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D29930", "files": ["toolkit/mozapps/extensions/internal/XPIProvider.jsm"], "git_node": null, "git_parents": [null], "node": "f272348572e8160a73001b85013f35db51397064", "parents": ["d716b75b8ac3f4588061e720074c093dae08e43e"], "tags": []}], "date": 1556951783, "git_changesets": [null, null], "user": "maglione.k@gmail.com"}, "11228": {"changesets": [{"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Backed out changeset d716b75b8ac3 (bug 1549010). a=sylvestre CLOSED TREE", "files": ["security/apps/AppSignatureVerification.cpp"], "git_node": null, "git_parents": [null], "node": "ebb01d9ac1c94b9ea2a0eee174a2f80d267035c1", "parents": ["f272348572e8160a73001b85013f35db51397064"], "tags": []}], "date": 1556965905, "git_changesets": [null], "user": "mozilla@hocat.ca"}, "11229": {"changesets": [{"author": "Mark Goodwin \u003cmgoodwin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1549061 - Add intermediate certificate [release]. r=kmag a=ritu CLOSED TREE\n\nSummary: This patch relies on a schema bump in a previous commit\n\nReviewers: kmag\n\nReviewed By: kmag\n\nBug #: 1549061\n\nDifferential Revision: https://phabricator.services.mozilla.com/D29949", "files": ["toolkit/mozapps/extensions/internal/XPIProvider.jsm"], "git_node": null, "git_parents": [null], "node": "be8cd9575508ce1a95b971ccbfe3a7ceec59bc0b", "parents": ["ebb01d9ac1c94b9ea2a0eee174a2f80d267035c1"], "tags": ["DEVEDITION_67_0b17_BUILD1", "DEVEDITION_67_0b17_RELEASE", "FENNEC_67_0b17_BUILD2", "FENNEC_67_0b17_RELEASE", "FIREFOX_67_0b17_BUILD2", "FIREFOX_67_0b17_RELEASE"]}], "date": 1557021587, "git_changesets": [null], "user": "nbeleuzu@mozilla.com"}, "11230": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging be8cd9575508ce1a95b971ccbfe3a7ceec59bc0b with FIREFOX_67_0b17_BUILD2 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "47fa9e5132e9cccfac8e95ba2aa3721deaa8bd41", "parents": ["be8cd9575508ce1a95b971ccbfe3a7ceec59bc0b"], "tags": []}], "date": 1557025957, "git_changesets": [null], "user": "ffxbld"}, "11231": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging be8cd9575508ce1a95b971ccbfe3a7ceec59bc0b with DEVEDITION_67_0b17_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "68e64212c431bd1d8b5c66b0907290b15c77a74b", "parents": ["47fa9e5132e9cccfac8e95ba2aa3721deaa8bd41"], "tags": []}], "date": 1557029811, "git_changesets": [null], "user": "ffxbld"}, "11232": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging be8cd9575508ce1a95b971ccbfe3a7ceec59bc0b with FENNEC_67_0b17_BUILD2 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "e5874cef64126cb84c8a119176b4aa0a677f6611", "parents": ["68e64212c431bd1d8b5c66b0907290b15c77a74b"], "tags": []}], "date": 1557033424, "git_changesets": [null], "user": "ffxbld"}, "11233": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP blocklist remote-settings - a=repo-update r=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30019", "files": ["browser/app/blocklist.xml", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/blocklists/addons.json", "services/settings/dumps/blocklists/certificates.json"], "git_node": null, "git_parents": [null], "node": "186cb0d28a8becf0d9dfa0c3979b34f0b1891d5e", "parents": ["e5874cef64126cb84c8a119176b4aa0a677f6611"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1481771 - Fix a race condition in browser_privatebrowsing_favicon.js by ensuring the promises that wait on conditions that happen during opening a tab are created before starting to open the tab; r=baku, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D29717", "files": ["browser/components/privatebrowsing/test/browser/browser_privatebrowsing_favicon.js"], "git_node": null, "git_parents": [null], "node": "d3c4aaf58b19562a3d291dbd020895eb3dd2c141", "parents": ["186cb0d28a8becf0d9dfa0c3979b34f0b1891d5e"], "tags": []}, {"author": "Mike Shal \u003cmshal@mozilla.com\u003e", "branch": "default", "desc": "Bug 1523324 - Add retries to upload_generated_sources.py; r=nalexander, a=release\n\nOccasionally the taskcluster fetches can fail, so make sure the requests\nlibrary automatically retries if possible.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D29914", "files": ["build/upload_generated_sources.py"], "git_node": null, "git_parents": [null], "node": "a78e6aced633fc0f1ca9718af1f044a0b2274b24", "parents": ["d3c4aaf58b19562a3d291dbd020895eb3dd2c141"], "tags": []}], "date": 1557150683, "git_changesets": [null, null, null], "user": "ryanvm@gmail.com"}, "11234": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging be8cd9575508ce1a95b971ccbfe3a7ceec59bc0b with DEVEDITION_67_0b17_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "d6c30fa0365bc13b59d1dd58b34171872e2b51b5", "parents": ["a78e6aced633fc0f1ca9718af1f044a0b2274b24"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release DONTBUILD", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "83c5fbe889d02c6737c2c91c347fb14b75f6855a", "parents": ["d6c30fa0365bc13b59d1dd58b34171872e2b51b5"], "tags": []}], "date": 1557157956, "git_changesets": [null, null], "user": "ffxbld"}, "11235": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging be8cd9575508ce1a95b971ccbfe3a7ceec59bc0b with FIREFOX_67_0b17_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "3a261dbad8a6488cdd7c8a05be267035b488e1a7", "parents": ["83c5fbe889d02c6737c2c91c347fb14b75f6855a"], "tags": []}], "date": 1557158148, "git_changesets": [null], "user": "ffxbld"}, "11236": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging be8cd9575508ce1a95b971ccbfe3a7ceec59bc0b with FENNEC_67_0b17_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "6083df09e9dbefa10a96efbc2fc0b6dc529ad58c", "parents": ["3a261dbad8a6488cdd7c8a05be267035b488e1a7"], "tags": []}], "date": 1557158331, "git_changesets": [null], "user": "ffxbld"}, "11237": {"changesets": [{"author": "Erica Wright \u003cewright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1548626 - Delay showing the Privacy-UI onboarding by 30 min for new users. r=johannh a=pascalc\n\nWait 30 min after a new profile is created before showing the onbording.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D29762", "files": ["browser/app/profile/firefox.js", "browser/base/content/browser-contentblocking.js", "browser/components/uitour/test/browser_contentBlocking.js", "browser/components/uitour/test/browser_trackingProtection.js", "browser/components/uitour/test/browser_trackingProtection_tour.js"], "git_node": null, "git_parents": [null], "node": "0deba92b39fd52160009e0296dd096c18f33830f", "parents": ["6083df09e9dbefa10a96efbc2fc0b6dc529ad58c"], "tags": []}], "date": 1557169540, "git_changesets": [null], "user": "aiakab@mozilla.com"}, "11238": {"changesets": [{"author": "Haik Aftandilian \u003chaftandilian@mozilla.com\u003e", "branch": "default", "desc": "Bug 1546544 - Enable TCSM. r=mccr8,asuth,spohl a=pascalc", "files": ["netwerk/base/ProxyAutoConfig.cpp", "netwerk/base/moz.build", "security/sandbox/mac/SandboxPolicies.h", "toolkit/xre/moz.build", "xpcom/base/CycleCollectedJSRuntime.cpp", "xpcom/base/nsMacUtilsImpl.cpp", "xpcom/base/nsMacUtilsImpl.h"], "git_node": null, "git_parents": [null], "node": "70403bae88b8486cd20c74c693ad85f79a030a00", "parents": ["0deba92b39fd52160009e0296dd096c18f33830f"], "tags": []}], "date": 1557171406, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "11239": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "FIREFOX_ESR_67b18_RELBRANCH", "desc": "Automatic version bump CLOSED TREE NO BUG a=release DONTBUILD", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "f76d9b928c04bc75b61cfe28ae78e6db2182e2a8", "parents": ["be8cd9575508ce1a95b971ccbfe3a7ceec59bc0b"], "tags": []}, {"author": "Dana Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "FIREFOX_ESR_67b18_RELBRANCH", "desc": "bug 1549249 - hard-code new add-on signing intermediate so it's always available r=jcj,kmag a=lizzard\n\nOur previous approach to making this intermediate available relied on being able\nto add it to the user's NSS cert DB. This does work in the majority of cases,\nbut there are some situations where it doesn't work (e.g. if the user's DB is\nset to read only, if they've configured Firefox to run in \"nocertdb\" mode, if\nthey have a master password but forgot it, and so on). This patch compiles the\nintermediate in to Firefox in the same way we incorporate the root, so it should\nalways be available.\n\nAt the same time, this patch reverts the changes from\nbe8cd9575508ce1a95b971ccbfe3a7ceec59bc0b (the patch that implemented the\noriginal approach) because it should no longer be necessary.\n\nThis also bumps the add-on DB schema to trigger add-on revalidation.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30139", "files": ["security/apps/AppTrustDomain.cpp", "security/apps/AppTrustDomain.h", "security/apps/addons-public-intermediate.crt", "security/apps/gen_cert_header.py", "security/apps/moz.build", "toolkit/mozapps/extensions/internal/XPIProvider.jsm"], "git_node": null, "git_parents": [null], "node": "fe6ddfaa325f8e9b57b134cd5ff48753726b8aff", "parents": ["f76d9b928c04bc75b61cfe28ae78e6db2182e2a8"], "tags": ["DEVEDITION_67_0b18_BUILD1", "DEVEDITION_67_0b18_RELEASE", "FENNEC_67_0b18_BUILD1", "FENNEC_67_0b18_RELEASE", "FIREFOX_67_0b18_BUILD1", "FIREFOX_67_0b18_RELEASE"]}], "date": 1557186959, "git_changesets": [null, null], "user": "mozilla@hocat.ca"}, "11240": {"changesets": [{"author": "Dana Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "bug 1549249 - hard-code new add-on signing intermediate so it's always available r=jcj,kmag a=lizzard\n\nOur previous approach to making this intermediate available relied on being able\nto add it to the user's NSS cert DB. This does work in the majority of cases,\nbut there are some situations where it doesn't work (e.g. if the user's DB is\nset to read only, if they've configured Firefox to run in \"nocertdb\" mode, if\nthey have a master password but forgot it, and so on). This patch compiles the\nintermediate in to Firefox in the same way we incorporate the root, so it should\nalways be available.\n\nAt the same time, this patch reverts the changes from\nbe8cd9575508ce1a95b971ccbfe3a7ceec59bc0b (the patch that implemented the\noriginal approach) because it should no longer be necessary.\n\nThis also bumps the add-on DB schema to trigger add-on revalidation.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30139", "files": ["security/apps/AppTrustDomain.cpp", "security/apps/AppTrustDomain.h", "security/apps/addons-public-intermediate.crt", "security/apps/gen_cert_header.py", "security/apps/moz.build", "toolkit/mozapps/extensions/internal/XPIProvider.jsm"], "git_node": null, "git_parents": [null], "node": "8f9fdaef9fc06cd0dda8edcb6e58aa37efbf2ddf", "parents": ["70403bae88b8486cd20c74c693ad85f79a030a00"], "tags": []}], "date": 1557191288, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "11241": {"changesets": [{"author": "Dana Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "bug 1549249 - build bustage follow-up r=mt,dveditz a=tomprince\n\nSECItem uses an unsigned int to indicate its length. We need to cast a size_t\ndown to the appropriate size. This is safe because what we're casting will\nalways fit in an unsigned int on the platforms we're using (it's just the size\nof the intermediate certificate we added).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30144", "files": ["security/apps/AppTrustDomain.cpp"], "git_node": null, "git_parents": [null], "node": "c8de3e36fb00966f1412d7dfddb5bfb08d45b816", "parents": ["8f9fdaef9fc06cd0dda8edcb6e58aa37efbf2ddf"], "tags": []}], "date": 1557192087, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "11242": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging fe6ddfaa325f8e9b57b134cd5ff48753726b8aff with FENNEC_67_0b18_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "1f340ca817e4fa37d67e4f88dfedcb1233f4b22a", "parents": ["c8de3e36fb00966f1412d7dfddb5bfb08d45b816"], "tags": []}], "date": 1557196493, "git_changesets": [null], "user": "ffxbld"}, "11243": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging fe6ddfaa325f8e9b57b134cd5ff48753726b8aff with DEVEDITION_67_0b18_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "fdb6130c37b3d4b289605c5f0fd6863aad404f13", "parents": ["1f340ca817e4fa37d67e4f88dfedcb1233f4b22a"], "tags": []}], "date": 1557196845, "git_changesets": [null], "user": "ffxbld"}, "11244": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging fe6ddfaa325f8e9b57b134cd5ff48753726b8aff with FIREFOX_67_0b18_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "63d0b268c743f7f7c4a4cbec61a5ed53a0adaa6b", "parents": ["fdb6130c37b3d4b289605c5f0fd6863aad404f13"], "tags": []}], "date": 1557197145, "git_changesets": [null], "user": "ffxbld"}, "11245": {"changesets": [{"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 70403bae88b8 (bug 1546544) for causing mochitest-chrome test failures on automation.py. a=backout", "files": ["netwerk/base/ProxyAutoConfig.cpp", "netwerk/base/moz.build", "security/sandbox/mac/SandboxPolicies.h", "toolkit/xre/moz.build", "xpcom/base/CycleCollectedJSRuntime.cpp", "xpcom/base/nsMacUtilsImpl.cpp", "xpcom/base/nsMacUtilsImpl.h"], "git_node": null, "git_parents": [null], "node": "21ec21b79d7721d59a63795c6c50f28690520a35", "parents": ["63d0b268c743f7f7c4a4cbec61a5ed53a0adaa6b"], "tags": []}], "date": 1557198580, "git_changesets": [null], "user": "dluca@mozilla.com"}, "11246": {"changesets": [{"autho