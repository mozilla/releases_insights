sts/addons.json"], "git_node": null, "git_parents": [null], "node": "e25b114202e4c6ac533f1cb17b125cf542e315cf", "parents": ["ba90cabf66d7fed2230a7a1df0ee9719cb0b7e74"], "tags": []}], "date": 1553171922, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "10888": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nbn-BD -\u003e 7bc3f446621a\nhsb -\u003e 20097620449b\nnl -\u003e 53688f70bec8\npt-BR -\u003e e09e3062c050", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "f77fdf2fa43a3ab2976007872f67108d34bee095", "parents": ["e25b114202e4c6ac533f1cb17b125cf542e315cf"], "tags": []}], "date": 1553173223, "git_changesets": [null], "user": "ffxbld"}, "10889": {"changesets": [{"author": "Olivier Tilloy \u003colivier@tilloy.net\u003e", "branch": "default", "desc": "Bug 1473602 - Add u2f-devices plug to snap package. r=jlorenzo a=release\n\nThis allows the confined snap to interact with Universal 2nd Factor devices, such as Yubikeys.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24147", "files": ["taskcluster/docker/firefox-snap/snapcraft.yaml.in"], "git_node": null, "git_parents": [null], "node": "515db7d568340e65ab0eb5925eed4ae434b98923", "parents": ["f77fdf2fa43a3ab2976007872f67108d34bee095"], "tags": []}], "date": 1553177437, "git_changesets": [null], "user": "jlorenzo@mozilla.com"}, "10890": {"changesets": [{"author": "Edouard Oger \u003ceoger@fastmail.com\u003e", "branch": "default", "desc": "Bug 1534290 p1 - Make login item host read-only. r=nalexander a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23233", "files": ["mobile/android/chrome/content/aboutLogins.js", "mobile/android/chrome/content/aboutLogins.xhtml"], "git_node": null, "git_parents": [null], "node": "521bfa11e24897365a5dbe4301afa4038aa08449", "parents": ["515db7d568340e65ab0eb5925eed4ae434b98923"], "tags": []}, {"author": "Edouard Oger \u003ceoger@fastmail.com\u003e", "branch": "default", "desc": "Bug 1534290 p2 - Touch timePasswordChanged on password modification. r=nalexander a=pascalc\n\nDepends on D23233\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23234", "files": ["mobile/android/chrome/content/aboutLogins.js"], "git_node": null, "git_parents": [null], "node": "ca7498a112a57cecf230de625565c7adfad0df2e", "parents": ["521bfa11e24897365a5dbe4301afa4038aa08449"], "tags": []}, {"author": "Edouard Oger \u003ceoger@fastmail.com\u003e", "branch": "default", "desc": "Bug 1534290 p3 - Use correct search criteria to find original login. r=nalexander a=pascalc\n\nDepends on D23234\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23235", "files": ["mobile/android/chrome/content/aboutLogins.js"], "git_node": null, "git_parents": [null], "node": "3abb046ddc034f4c04f59302012acc81154834b6", "parents": ["ca7498a112a57cecf230de625565c7adfad0df2e"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1530706 - IME may be displayed along with the urlbar results panel. r=Standard8 a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23836", "files": ["browser/components/urlbar/UrlbarInput.jsm", "browser/components/urlbar/UrlbarProvidersManager.jsm", "browser/components/urlbar/tests/UrlbarTestUtils.jsm", "browser/components/urlbar/tests/browser/browser.ini", "browser/components/urlbar/tests/browser/browser_UrlbarInput_search.js", "browser/components/urlbar/tests/browser/browser_urlbarSearchFunction.js", "browser/components/urlbar/tests/unit/test_providersManager_filtering.js", "toolkit/components/autocomplete/nsAutoCompleteController.cpp", "toolkit/components/autocomplete/tests/unit/test_stopSearch.js"], "git_node": null, "git_parents": [null], "node": "5aa8eacca7b5501cd8230c607b684c73683c41b3", "parents": ["3abb046ddc034f4c04f59302012acc81154834b6"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1535766 - Handle unaligned buffers in WebrtcGmpVideoCodec::Encoded; r=bwc a=pascalc\n\nThis uses the Endian routines to ensure that reads will match the endianess\nof the current machine, which is the expected behaviour of the openh264\nplugin. The calls to readUint16 and readUint32 memcpy to a properly aligned\nbuffer avoiding any problems with alignment. The memcpy adds some overhead\nbut it seems negligible compared to the amount of work done to packetize and\nsend the encoded data.\n\nThese changes were tested by adding code to create an unaligned buffer and\nmemcopying the received buffer into it.\n\nThis also adds a null check for the received buffer as we have seen a small\nvolume of null pointer crashes.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24030", "files": ["media/webrtc/signaling/src/media-conduit/WebrtcGmpVideoCodec.cpp"], "git_node": null, "git_parents": [null], "node": "475f82f18288433b2a972c4d28a784bf323fe70b", "parents": ["5aa8eacca7b5501cd8230c607b684c73683c41b3"], "tags": []}, {"author": "Ethan Glasser-Camp \u003cethan@betacantrips.com\u003e", "branch": "default", "desc": "Bug 1535962: Introduce a sample rate for reporting uptake telemetry events r=leplatrem a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23814", "files": ["modules/libpref/init/all.js", "services/common/tests/unit/test_uptake_telemetry.js", "services/common/uptake-telemetry.js", "services/settings/RemoteSettingsClient.jsm", "services/settings/remote-settings.js", "toolkit/components/normandy/lib/ActionsManager.jsm", "toolkit/components/normandy/lib/RecipeRunner.jsm", "toolkit/components/normandy/lib/Uptake.jsm", "toolkit/components/normandy/test/browser/browser_Uptake.js", "toolkit/components/telemetry/docs/collection/uptake.rst"], "git_node": null, "git_parents": [null], "node": "327cadd9820c9f7ef6580d229ac4c8ce1ff5f324", "parents": ["475f82f18288433b2a972c4d28a784bf323fe70b"], "tags": []}, {"author": "Barret Rennie \u003cbarret@brennie.ca\u003e", "branch": "default", "desc": "Bug 1536466 - Fix nsTDependentString with non-null-terminated buffer assertion r=bholley a=pascalc\n\n`gecko_profiler_add_text_marker` was being passed a character pointer and a\nlength to construct a `nsDependentCString`. However, these values were coming\nfrom a Rust `&str`, which is not null-terminated, causing an debug assertion to\nbe hit (and possible memory safety issues if mishandle the string). We now\nconstruct an `nsDependentCSubstring` instead.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24032", "files": ["gfx/layers/wr/WebRenderBridgeParent.cpp"], "git_node": null, "git_parents": [null], "node": "2211f0befe5480ceb814f96274e48680b0e7ff0e", "parents": ["327cadd9820c9f7ef6580d229ac4c8ce1ff5f324"], "tags": []}, {"author": "Mellina Yonashiro \u003cyonashiro.mellina@gmail.com\u003e", "branch": "default", "desc": "Bug 1534629 Non-bypassable cert error pages should use Advanced instead of More information r=johannh a=pascalc l10n=flod CLOSED TREE\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23316", "files": ["browser/base/content/aboutNetError-new.xhtml", "browser/base/content/aboutNetError.js", "browser/base/content/aboutNetError.xhtml", "browser/base/content/browser.js", "browser/locales/en-US/chrome/overrides/netError.dtd", "browser/themes/shared/aboutNetError-new.css", "browser/themes/shared/aboutNetError.css"], "git_node": null, "git_parents": [null], "node": "629d26021667fd762f2320fc19dc27cf1f65d502", "parents": ["2211f0befe5480ceb814f96274e48680b0e7ff0e"], "tags": ["DEVEDITION_67_0b4_BUILD1", "FIREFOX_67_0b4_BUILD1"]}], "date": 1553186606, "git_changesets": [null, null, null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "10891": {"changesets": [{"author": "Mozilla Releng Treescript \u003cre