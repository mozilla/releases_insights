d"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release DONTBUILD", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "e8494b855f914099169f12f1035af5312fc0952c", "parents": ["b8c21c3f8e416d055fa2ec1534a904698f9279c7"], "tags": []}], "date": 1554475918, "git_changesets": [null, null], "user": "ffxbld"}, "11008": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 13b7d4d4df59f7f2e50f66644daf655bad40bec8 with DEVEDITION_67_0b8_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "8548d9e738b187536470188f1c675f372c4a0676", "parents": ["e8494b855f914099169f12f1035af5312fc0952c"], "tags": []}], "date": 1554476099, "git_changesets": [null], "user": "ffxbld"}, "11009": {"changesets": [{"author": "Mihai Tabara \u003cmtabara@mozilla.com\u003e", "branch": "default", "desc": "Bug 1538703 - remove try config from declarative artifacts world. r=sfraser a=release", "files": ["taskcluster/ci/beetmover-checksums/kind.yml", "taskcluster/ci/beetmover-repackage/kind.yml", "taskcluster/taskgraph/util/scriptworker.py"], "git_node": null, "git_parents": [null], "node": "df05571b936fe6b87dae764994759adabe383166", "parents": ["8548d9e738b187536470188f1c675f372c4a0676"], "tags": []}], "date": 1554482218, "git_changesets": [null], "user": "mtabara@mozilla.com"}, "11010": {"changesets": [{"author": "Simon Fraser \u003csfraser@mozilla.com\u003e", "branch": "default", "desc": "Bug 1539905 Cache yaml loading with copy of memoized values r=mtabara a=release", "files": ["taskcluster/taskgraph/util/scriptworker.py"], "git_node": null, "git_parents": [null], "node": "864e16abd2f73a5a0d0ef7a887a3a90e0ee22a37", "parents": ["df05571b936fe6b87dae764994759adabe383166"], "tags": []}], "date": 1554486262, "git_changesets": [null], "user": "mtabara@mozilla.com"}, "11011": {"changesets": [{"author": "Dale Harvey \u003cdale@arandomurl.com\u003e", "branch": "default", "desc": "Bug 1532730 - Update engines on reload. r=mikedeboer a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24192", "files": ["toolkit/components/search/SearchService.jsm"], "git_node": null, "git_parents": [null], "node": "3dc7b1a572313386a459b174e7335847e3c1dbb2", "parents": ["864e16abd2f73a5a0d0ef7a887a3a90e0ee22a37"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1539172 - Make nsContentUtils::DispatchInputEvent() notify content of valid state change of input element r=smaug a=pascalc\n\nWhen `nsContentUtils::DispatchInputEvent()` dispatches `input` event, the\neditor's value was changed by somebody.  In this case, it needs to update\nthe valid state **and** notify to update the style.\n\n(Note that I'm not sure whether this is right approach.)\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25029", "files": ["dom/base/nsContentUtils.cpp", "dom/html/HTMLInputElement.cpp", "dom/html/HTMLInputElement.h", "dom/html/test/forms/test_MozEditableElement_setUserInput.html", "toolkit/components/satchel/test/mochitest.ini", "toolkit/components/satchel/test/test_input_valid_state_with_autocomplete.html"], "git_node": null, "git_parents": [null], "node": "985158cfb6950e416e0d4664e1aa9aad83c923ab", "parents": ["3dc7b1a572313386a459b174e7335847e3c1dbb2"], "tags": []}, {"author": "J.C. Jones \u003cjjones@mozilla.com\u003e", "branch": "default", "desc": "Bug 1539541 - Enable FIDO U2F API, and permit registrations for Google Accounts r=keeler,qdot a=pascalc\n\nPer the thread \"Intent-to-Ship: Backward-Compatibility FIDO U2F support for\nGoogle Accounts\" on dev-platform [0], this bug is to:\n\n  1. Enable the security.webauth.u2f by default, to ride the trains\n\n  2. Remove the aOp == U2FOperation::Sign check from EvaluateAppID in\n     WebAuthnUtil.cpp, permitting the Google override to work for Register as\n     well as Sign.\n\nThis would enable Firefox users to use FIDO U2F API on most all sites, subject\nto the algorithm limitations discussed in the section \"Thorny issues in\nenabling our FIDO U2F API implementation\" of that post.\n\n[0] https://groups.google.com/d/msg/mozilla.dev.platform/q5cj38hGTEA/lC834665BQAJ\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25241", "files": ["dom/tests/mochitest/general/test_interfaces.js", "dom/u2f/U2F.cpp", "dom/webauthn/WebAuthnManager.cpp", "dom/webauthn/WebAuthnUtil.cpp", "dom/webauthn/WebAuthnUtil.h", "security/manager/ssl/security-prefs.js"], "git_node": null, "git_parents": [null], "node": "21acdae6bafe5ad41736fec5e14bb787622acb5d", "parents": ["985158cfb6950e416e0d4664e1aa9aad83c923ab"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1479145 - Handle arbitrary strides for WebGL-to-SharedSurface readback on platforms that support it. r=jgilbert a=pascalc\n\nThe only platforms that do not support GL_PACK_ROW_LENGTH are platforms with\nGLES 2. So on those platforms, trying to read back into buffers whose stride is\nnot width * 4 will assert.\nThat's fine because we usually don't encounter buffers with such large strides\non GLES 2 platforms. The only platform that really needs to handle the large\nstrides is macOS, and it always supports GL_PACK_ROW_LENGTH.\nOn macOS, we often run into large strides on surfaces that we intend to upload\nas textures at some point, because large stride alignments are required for\nefficient upload performance on some drivers.\n\nBug 1540209 tracks fixing the general case.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25464", "files": ["gfx/gl/ScopedGLHelpers.cpp", "gfx/gl/ScopedGLHelpers.h", "gfx/gl/SharedSurface.cpp", "gfx/layers/client/CanvasClient.cpp"], "git_node": null, "git_parents": [null], "node": "233aa5cf03be6c45ed388f2a7b3b73563de06e2c", "parents": ["21acdae6bafe5ad41736fec5e14bb787622acb5d"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1479145 - Give RGB textures a 32-byte aligned stride on macOS in order to improve texture upload efficiency on certain drivers. r=mattwoodrow a=pascalc\n\nIn particular, it looks like this alignment is required by the Intel driver on\nmacOS if you want to avoid CPU copies.\n\nIt was already known that the efficiency gains from client storage only\nmaterialize if you follow certain restrictions:\n - The textures need to use the TEXTURE_RECTANGLE_ARB texture target.\n - The textures' format, internalFormat and type need to be chosen from a small\n   list of supported configurations. Unsupported configurations will trigger\n   format conversions on the CPU.\n - The GL_TEXTURE_STORAGE_HINT_APPLE may need to be set to shared or cached.\n - glTextureRangeAPPLE may or may not make a difference.\n\nIt now appears that the stride alignment is another requirement:\n\nWhen uploading textures which otherwise comply with the above requirements, the\nIntel driver will still make copies using the CPU if the texture's stride is not\n32-byte aligned. These CPU copies are reflected in a high CPU usage (as observed\nin Activity Monitor) and they show up in profiles as time spent inside\n_platform_memmove under glrUpdateTexture.\n\nHowever, when uploading 32-byte stride aligned textures which comply with the\nabove requirements, this CPU usage goes away. There might still be hardware\ncopies behind the scenes, but they no longer take up CPU time.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25316", "files": ["gfx/layers/ImageDataSerializer.cpp"], "git_node": null, "git_parents": [null], "node": "f64e6108bdfc6462983667170768450c320efaf7", "parents": ["233aa5cf03be6c45ed388f2a7b3b73563de06e2c"], "tags": []}, {"author": "Matthew Noorenberghe \u003cmozilla@noorenberghe.ca\u003e", "branch": "default", "desc": "Bug 1538952 - Don't automatically open the password autocomplete popup when we only have the footer to show. r=jaws,mak a=pascalc\n\nNormally autocomplete results are cached based upon the search string but to get the desired behaviour we want two different sets of results for the same search string depending on how the autocomplete search was started:\na) Via automatically focusing a password field.\nb) Every other method of starting an autocomplete search.\n\nIn order to not have cached results used, the result code for case (a) [an empty result] will be `RESULT_FAILURE` and I've updated the autocomplete code to not re-use an error result.\n\nIn the coming months we may be rewriting our content autocomplete code but that would be too risky to uplift to 67 so for now I'm tracking when satchel automatically opens the popup upon focus and then using that state in the autocomplete result creation code to know whether to include the footer.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25173", "files": ["toolkit/components/autocomplete/nsAutoCompleteController.cpp", "toolkit/components/passwordmgr/LoginAutoCompleteResult.jsm", "toolkit/components/passwordmgr/test/mochitest/mochitest.ini", "toolkit/components/passwordmgr/test/mochitest/pwmgr_common.js", "toolkit/components/passwordmgr/test/mochitest/test_autocomplete_password_open.html", "toolkit/components/satchel/nsFormFillController.cpp", "toolkit/components/satchel/nsFormFillController.h", "toolkit/components/satchel/nsIFormFillController.idl"], "git_node": null, "git_parents": [null], "node": "81e863ea76d5add70e24fc5134498cc21dd95eb2", "parents": ["f64e6108bdfc6462983667170768450c320efaf7"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1533989 - Make InputEvent.data and InputEvent.dataTransfer not expose clipboard data if user disables clipboard events r=smaug a=pascalc\n\nIf user disables clipboard events, it means that they don't want to expose\nclipboard data to web apps even if web apps cannot handle \"paste\" operation.\nTherefore, they must not want to leak clipboard data with `InputEvent.data`\nand `InputEvent.dataTransfer`.\n\nThis patch makes `InputEvent::GetData()` and `InputEvent::GetDataTransfer()`\nreturns empty string or new `DataTransfer` object which has only empty string\nif:\n- They are called by content JS.\n- The event is a trusted event.\n- `inputType` value is `insertFromPaste` or `insertFromPasteAsQuotation`.\n\nThe reason why we don't return null for both is, Input Events spec declares\n`data` or `dataTransfer` shouldn't be null in the `inputType` values.  And\nthe reason why we don't return empty `DataTransfer` is, web apps may expect\nat least one data is stored in non-null `dataTransfer` value.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25350", "files": ["dom/base/nsCopySupport.cpp", "dom/events/InputEvent.cpp", "dom/events/InputEvent.h", "dom/tests/mochitest/general/test_clipboard_events.html", "dom/webidl/InputEvent.webidl", "editor/libeditor/tests/test_middle_click_paste.html", "modules/libpref/init/StaticPrefList.h", "modules/libpref/init/all.js", "widget/EventForwards.h"], "git_node": null, "git_parents": [null], "node": "78f43d6cbd56ffeff48ddeefb73f0ce7bf2010da", "parents": ["81e863ea76d5add70e24fc5134498cc21dd95eb2"], "tags": []}, {"author": "shindli \u003cshindli@mozilla.com\u003e", "branch": "default", "desc": "Bug 1539208 - P1 - Return an error when the Reponse object is null'd a=pascalc\n\nReviewers: mayhemer, baku\n\nReviewed By: mayhemer\n\nBug #: 1539208\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25228", "files": ["dom/fetch/FetchDriver.cpp"], "git_node": null, "git_parents": [null], "node": "6168e6cc5761ddbf95cc5b7466a339c432a1ba07", "parents": ["78f43d6cbd56ffeff48ddeefb73f0ce7bf2010da"], "tags": []}, {"author": "shindli \u003cshindli@mozilla.com\u003e", "branch": "default", "desc": "Bug 1539208 - P2 - Use RandomNum while failing to get a random number from RandomGenerator a=pascalc\n\nReviewers: asuth, baku\n\nReviewed By: baku\n\nSubscribers: reviewbot\n\nBug #: 1539208\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25104", "files": ["dom/fetch/InternalResponse.cpp"], "git_node": null, "git_parents": [null], "node": "4b57a43c92b979133a21fd1a3b27989e9c048119", "parents": ["6168e6cc5761ddbf95cc5b7466a339c432a1ba07"], "tags": []}, {"author": "Khyati Agarwal \u003cf20160385@hyderabad.bits-pilani.ac.in\u003e", "branch": "default", "desc": "bug 1533290 - Stop using --panel-disabled-color for subviewbutton shortcuts (where the subviewbutton is also a menuitem) r=dao a=pascalc\n\nStop using --panel-disabled-color for subviewbutton shortcuts (where the subviewbutton is also a menuitem)\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25521", "files": ["browser/themes/shared/customizableui/panelUI.inc.css"], "git_node": null, "git_parents": [null], "node": "11a26a76e494aaaaba3db0aec7b33a4e9dfff4bf", "parents": ["4b57a43c92b979133a21fd1a3b27989e9c048119"], "tags": []}, {"author": "Thomas Nguyen \u003ctnguyen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1539408 Pass referrerInfo to gContextMenuContentData in non-remote r=Gijs a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25419", "files": ["browser/actors/ContextMenuChild.jsm", "browser/base/content/utilityOverlay.js"], "git_node": null, "git_parents": [null], "node": "ca218beefd316b68731d8e89c87bfae8c6f92483", "parents": ["11a26a76e494aaaaba3db0aec7b33a4e9dfff4bf"], "tags": []}, {"author": "Alex Chronopoulos \u003cachronop@gmail.com\u003e", "branch": "default", "desc": "Bug 1540231 - Stop dispatching a task to the TaskQueue when we are already in it. r=jya a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25576", "files": ["dom/media/platforms/agnostic/DAV1DDecoder.cpp"], "git_node": null, "git_parents": [null], "node": "7a9bd3d0841234093d06a71516e1e22c4af0d905", "parents": ["ca218beefd316b68731d8e89c87bfae8c6f92483"], "tags": []}], "date": 1554490982, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "dvarga@mozilla.com"}, "11012": {"changesets": [{"author": "Mike de Boer \u003cmdeboer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1537117 - Update the search engine quick-switching functionality to work with an async SearchService API. r=florian a=pascalc\n\nI also updated the logic to properly cycle through the visible search engines list\nand added a unit test that was missing, somehow.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25368", "files": ["browser/components/search/content/searchbar.js", "browser/components/search/test/browser/browser_searchbar_keyboard_navigation.js"], "git_node": null, "git_parents": [null], "node": "73fa8de4eb471cefb70727cf39b4638e86a2437e", "parents": ["7a9bd3d0841234093d06a71516e1e22c4af0d905"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1538218 - Correct REMOVE_DISTRIBUTION_DIR command. r=mhowell a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25681", "files": ["browser/installer/windows/msi/installer.wxs"], "git_node": null, "git_parents": [null], "node": "7a7eda97a8f280c0cfec5a2968d6d81e2b87999c", "parents": ["73fa8de4eb471cefb70727cf39b4638e86a2437e"], "tags": []}, {"author": "Matthew Noorenberghe \u003cmozilla@noorenberghe.ca\u003e", "branch": "default", "desc": "Bug 1540154 - Allow autocomplete=(email|tel|tel-national) to be username fields. r=sfoster a=pascalc\n\nSome sites use `email`, `tel` and `tel-national` values for @autocomplete even when they are used as the username and 'username' would be more appropriate.\n\nWe already allowed type=email / type=tel so allowing the autocomplete equivalents is reasonable.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25883", "files": ["toolkit/components/passwordmgr/LoginHelper.jsm", "toolkit/components/passwordmgr/test/mochitest/test_autofill_autocomplete_types.html", "toolkit/components/passwordmgr/test/unit/test_isUsernameFieldType.js"], "git_node": null, "git_parents": [null], "node": "2c01eafb7bb89195e76f6ea8daf817496b27ec44", "parents": ["7a7eda97a8f280c0cfec5a2968d6d81e2b87999c"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1540944 - Get new group from the correct realm in SetProto. r=luke a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25803", "files": ["js/src/jit-test/tests/realms/basic.js", "js/src/vm/JSObject-inl.h", "js/src/vm/JSObject.cpp"], "git_node": null, "git_parents": [null], "node": "e0f62b77623697545dd2eb5c7e061a65a723f68e", "parents": ["2c01eafb7bb89195e76f6ea8daf817496b27ec44"], "tags": []}, {"author": "Christoph Kerschbaumer \u003cckerschb@christophkerschbaumer.com\u003e", "branch": "default", "desc": "Bug 1541168: Remove remaining newChannelFromURI2 appearances. r=valentin a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25916", "files": ["dom/base/test/chrome/test_bug682305.html", "image/decoders/icon/android/nsIconChannel.cpp", "image/decoders/icon/gtk/nsIconChannel.cpp", "toolkit/components/resistfingerprinting/RFPHelper.jsm", "toolkit/components/search/SearchService.jsm"], "git_node": null, "git_parents": [null], "node": "ad953d1d63f6d9fda6b4483a16632d8938a966f4", "parents": ["e0f62b77623697545dd2eb5c7e061a65a723f68e"], "tags": []}, {"author": "Vijay Budhram \u003cvbudhram@mozilla.com\u003e", "branch": "default", "desc": "Bug 1541314 - Remove animation from choose what to sync svg r=mstange a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25940", "files": ["browser/themes/shared/fxa/choose-what-to-sync-devices.svg"], "git_node": null, "git_parents": [null], "node": "dff20faae9f496959a1a42722e8f9a7e64f0abde", "parents": ["ad953d1d63f6d9fda6b4483a16632d8938a966f4"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1539137 - Fix help link in browser languages dialog r=Gijs a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25998", "files": ["browser/components/preferences/browserLanguages.xul"], "git_node": null, "git_parents": [null], "node": "3ba898f98afad26f0b12d5e63b6c273392376311", "parents": ["dff20faae9f496959a1a42722e8f9a7e64f0abde"], "tags": []}, {"author": "Yuan Cheng \u003cchengy12@msu.edu\u003e", "branch": "default", "desc": "Bug 1528573 - [RTL] The sloth SVG is overlapping the header in about:rights, r=Gijs a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26064", "files": ["toolkit/themes/shared/aboutRights.css"], "git_node": null, "git_parents": [null], "node": "dc02c36e1aa49025f09456b65c4805d337b28a1f", "parents": ["3ba898f98afad26f0b12d5e63b6c273392376311"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1538974 - Ensure that we accept uppercase characters for url-classifier annotation skip URLs; r=johannh a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26019", "files": ["netwerk/url-classifier/UrlClassifierSkipListService.jsm", "toolkit/components/antitracking/test/browser/browser_siteSpecificWorkArounds.js", "toolkit/components/antitracking/test/browser/head.js"], "git_node": null, "git_parents": [null], "node": "1e5ffce08e373e30c219694a9f6c00011fbe6196", "parents": ["dc02c36e1aa49025f09456b65c4805d337b28a1f"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1533589: [win64-aarch64] Simplify logic about unpacking builds in update-verify; r=sfraser a=tomprince\n\nWe always pass in the platform formated as an update platform. Since the only\nvariation in formats is between major platforms, be liberal in parsing\nplatforms, when selecting which unpack logic to use. This makes win64-aarch64\nsupport fall out automatically.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26201", "files": ["tools/update-verify/release/common/unpack.sh"], "git_node": null, "git_parents": [null], "node": "02a85326761d0432d0550adab60ff6ebc858b603", "parents": ["1e5ffce08e373e30c219694a9f6c00011fbe6196"], "tags": []}], "date": 1554493568, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "dvarga@mozilla.com"}, "11013": {"changesets": [{"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1541122: [try-staging] Don't restrict the branch that cron-bouncer-check runs on; r=mtabara a=tomprince\n\nWe only run the cron job on release branches, so it will only get scheduled\nthere. By not otherwise restricting the job, it makes it easier to test the\ncron job on other branches (like try).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26200", "files": ["taskcluster/ci/cron-bouncer-check/kind.yml"], "git_node": null, "git_parents": [null], "node": "1c729b2f5e3eb6f1942b26e13feb927a676d60ed", "parents": ["02a85326761d0432d0550adab60ff6ebc858b603"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1541122: [try-staging] Specify bouncer-prefix in cron bouncer check as well; r=mtabara a=tomprince\n\nThe previous changes only changed the check in the release process. This also\nupdates the periodic check.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26199", "files": ["taskcluster/ci/cron-bouncer-check/kind.yml"], "git_node": null, "git_parents": [null], "node": "8d526e3036bfd9ec91428dd3901416581e3a5c97", "parents": ["1c729b2f5e3eb6f1942b26e13feb927a676d60ed"], "tags": []}], "date": 1554493912, "git_changesets": [null, null], "user": "dvarga@mozilla.com"}, "11014": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nit -\u003e 741944fc3e6e\npl -\u003e 1c2d957fcfde\npt-BR -\u003e 90322ada83c3\npt-PT -\u003e f13eeb844b59\nsv-SE -\u003e 9a537b120e9f\nth -\u003e 302766aaee8d\nvi -\u003e a9c4de774f79", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "6d9648f0c16028c01adf330cc1001d6105199723", "parents": ["8d526e3036bfd9ec91428dd3901416581e3a5c97"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nhsb -\u003e c06d16e4b60e\nit -\u003e 741944fc3e6e\npa-IN -\u003e 8e1381949d05\npl -\u003e 1c2d957fcfde\npt-BR -\u003e 90322ada83c3\npt-PT -\u003e f13eeb844b59\nsv-SE -\u003e 9a537b120e9f\nth -\u003e 302766aaee8d\ntr -\u003e fb261a55c684\nvi -\u003e a9c4de774f79", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "8ba58e404c06b5b5586c2857d6c5d37919c4e835", "parents": ["6d9648f0c16028c01adf330cc1001d6105199723"], "tags": []}], "date": 1554505253, "git_changesets": [null, null], "user": "ffxbld"}, "11015": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nhsb -\u003e c06d16e4b60e", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "6a9cf94424a4804466da33a4898312369f038c84", "parents": ["8ba58e404c06b5b5586c2857d6c5d37919c4e835"], "tags": []}], "date": 1554508824, "git_changesets": [null], "user": "ffxbld"}, "11016": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "bran