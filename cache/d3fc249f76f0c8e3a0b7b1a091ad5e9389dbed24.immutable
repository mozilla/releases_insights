, "testing/xpcshell/moz-http2/moz-http2.js"], "git_node": null, "git_parents": [null], "node": "6db60f4d14eefd1a17451476a178a64286221cf1", "parents": ["08398544a289e4f82028afb47080337a6e8063ee"], "tags": []}], "date": 1553527192, "git_changesets": [null, null], "user": "archaeopteryx@coole-files.de"}, "10912": {"changesets": [{"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 475f82f18288 (bug 1535766) because it shouldn't have landed on beta. a=backout", "files": ["media/webrtc/signaling/src/media-conduit/WebrtcGmpVideoCodec.cpp"], "git_node": null, "git_parents": [null], "node": "1dabaf68f8fe6e50d20202773f1a8bd95dadb4b4", "parents": ["6db60f4d14eefd1a17451476a178a64286221cf1"], "tags": []}], "date": 1553529299, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "10913": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nbr -\u003e 97442f4cb856\ncy -\u003e e341bd1b59ff\ngn -\u003e 876bb38e620e\npl -\u003e ddb6b02d92a3\npt-BR -\u003e c58ef8760a64", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "14e8cc18791dd9bb7c1f0580cf62ab52ecab51aa", "parents": ["1dabaf68f8fe6e50d20202773f1a8bd95dadb4b4"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nbr -\u003e 97442f4cb856\ncy -\u003e e341bd1b59ff\nes-ES -\u003e 84b3ccba09a9\ngn -\u003e 876bb38e620e\npl -\u003e ddb6b02d92a3\npt-BR -\u003e c58ef8760a64\nro -\u003e a51ee2433e58\nvi -\u003e deadec556372", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "6d13db8d177ce4aa6670de115495dca7cb4c2a9d", "parents": ["14e8cc18791dd9bb7c1f0580cf62ab52ecab51aa"], "tags": []}], "date": 1553529650, "git_changesets": [null, null], "user": "ffxbld"}, "10914": {"changesets": [{"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1535766 - Handle unaligned buffers in WebrtcGmpVideoCodec::Encoded; r=bwc a=pascalc\n\nThis uses the Endian routines to ensure that reads will match the endianess\nof the current machine, which is the expected behaviour of the openh264\nplugin. The calls to readUint16 and readUint32 memcpy to a properly aligned\nbuffer avoiding any problems with alignment. The memcpy adds some overhead\nbut it seems negligible compared to the amount of work done to packetize and\nsend the encoded data.\n\nThese changes were tested by adding code to create an unaligned buffer and\nmemcopying the received buffer into it.\n\nThis also adds a null check for the received buffer as we have seen a small\nvolume of null pointer crashes.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24030", "files": ["media/webrtc/signaling/src/media-conduit/WebrtcGmpVideoCodec.cpp"], "git_node": null, "git_parents": [null], "node": "65a648289c8a20cc8ccb57651ece3e32fb77932d", "parents": ["6d13db8d177ce4aa6670de115495dca7cb4c2a9d"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 6db60f4d14ee (bug 1450893) because it should not have landed on beta. a=backout", "files": ["modules/libpref/init/all.js", "netwerk/dns/TRRService.cpp", "netwerk/dns/TRRService.h", "netwerk/test/unit/test_trr.js", "testing/xpcshell/moz-http2/moz-http2.js"], "git_node": null, "git_parents": [null], "node": "994e50d055c0b339a6541a460399189740324a4a", "parents": ["65a648289c8a20cc8ccb57651ece3e32fb77932d"], "tags": []}], "date": 1553530939, "git_changesets": [null, null], "user": "archaeopteryx@coole-files.de"}, "10915": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", 