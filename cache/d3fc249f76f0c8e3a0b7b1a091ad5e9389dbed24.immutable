_node": null, "git_parents": [null], "node": "68efdeb6246962430f930450613bb00292a9d19c", "parents": ["1eacc9101089c9026741631657f25cb2a5e7dfa0"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1524619 - Part 2 - Add tests for notification permission prompts with user interaction. r=Ehsan,lina a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24259", "files": ["browser/base/content/test/permissions/browser.ini", "browser/base/content/test/permissions/browser_permissions_handling_user_input.js", "browser/base/content/test/permissions/dummy.js", "browser/base/content/test/permissions/permissions.html"], "git_node": null, "git_parents": [null], "node": "9df7dbd02a5f46d9c4a149fea1b3e28dfa3f9023", "parents": ["68efdeb6246962430f930450613bb00292a9d19c"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1524619 - Part 3 - Support requiring user gestures for push notifications on Fennec. r=snorp a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23648", "files": ["mobile/android/components/ContentPermissionPrompt.js"], "git_node": null, "git_parents": [null], "node": "eea064bfc1d35f1bfab2d12e2273a63cbc346d5f", "parents": ["9df7dbd02a5f46d9c4a149fea1b3e28dfa3f9023"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1524619 - Part 4 - Set user interaction flag in push notification permission requests. r=lina a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23969", "files": ["dom/push/Push.jsm"], "git_node": null, "git_parents": [null], "node": "fa0ac55df425d5393b8e30ce34cb21bb7da3ff85", "parents": ["eea064bfc1d35f1bfab2d12e2273a63cbc346d5f"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1524619 - Part 5 - Propagate user interaction through APIs that return ServiceWorkerRegistrations. r=Ehsan a=pascalc\n\nThis is done to support requiring user interaction when calling PushManager.subscribe().\nBecause PushManager must usually be accessed with async APIs, this makes for a better\ndeveloper experience and should reduce breakage.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23970", "files": ["dom/serviceworkers/ServiceWorkerContainer.cpp"], "git_node": null, "git_parents": [null], "node": "70f93db9a0817fc666e5551ef0085bad133725f6", "parents": ["fa0ac55df425d5393b8e30ce34cb21bb7da3ff85"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1546500: Avoid dispatching synchronous thread shutdown runnables. r=froydnj a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D28555", "files": ["dom/cache/Manager.cpp", "dom/indexedDB/ActorsParent.cpp", "gfx/layers/ProfilerScreenshots.cpp", "image/DecodePool.cpp", "js/xpconnect/loader/URLPreloader.cpp", "netwerk/sctp/datachannel/DataChannel.cpp"], "git_node": null, "git_parents": [null], "node": "81b2e6c7139d2ace9b70332269e02f8633317c98", "parents": ["70f93db9a0817fc666e5551ef0085bad133725f6"], "tags": []}, {"author": "Brian Hackett \u003cbhackett1024@gmail.com\u003e", "branch": "default", "desc": "Bug 1537589 - Don't leave deformed breakpoints in reducer state, r=loganfsmyth. a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24582", "files": ["devtools/client/debugger/new/src/actions/breakpoints/addBreakpoint.js"], "git_node": null, "git_parents": [null], "node": "5e0fd434e5beaab719a82588712916f60b563b43", "parents": ["81b2e6c7139d2ace9b70332269e02f8633317c98"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1543314 - Cookies should be sent to the content process also for first-party channels when cookieBehavior is set to 2, r=Ehsan a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26859", "files": ["netwerk/cookie/CookieServiceParent.cpp", "toolkit/components/antitracking/test/browser/browser.ini", "toolkit/components/antitracking/test/browser/browser_cookieBetweenTabs.js", "toolkit/components/antitracking/test/browser/empty.html"], "git_node": null, "git_parents": [null], "node": "ee086cda5837f5ad84d6a8e6fb9d9b413a90acdc", "parents": ["5e0fd434e5beaab719a82588712916f60b563b43"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1546415 - Disable target=_blank on a/area elements imply rel=noopener for 67, r=neha a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D28497", "files": ["modules/libpref/init/StaticPrefList.h"], "git_node": null, "git_parents": [null], "node": "34fee7231b147dd5fb2ccc6a7cfc7e5b3495b02b", "parents": ["ee086cda5837f5ad84d6a8e6fb9d9b413a90acdc"], "tags": []}, {"author": "Jared Hirsch \u003cohai@6a68.net\u003e", "branch": "default", "desc": "Bug 1536877 - Correct the 'value' type in 'browser.telemetry.recordEvent'; r?rpl a=pascalc\n\nSummary: MozReview-Commit-ID: EvI2FvsOjDx\n\nReviewers: rpl\n\nReviewed By: rpl\n\nSubscribers: reviewbot\n\nBug #: 1536877\n\nDifferential Revision: https://phabricator.services.mozilla.com/D27404", "files": ["toolkit/components/extensions/schemas/telemetry.json", "toolkit/components/extensions/test/xpcshell/test_ext_telemetry.js", "toolkit/components/telemetry/docs/collection/webextension-api.rst"], "git_node": null, "git_parents": [null], "node": "521037994bf751d45f8acd5f2f32982a85e80947", "parents": ["34fee7231b147dd5fb2ccc6a7cfc7e5b3495b02b"], "tags": []}, {"author": "Jared Hirsch \u003cohai@6a68.net\u003e", "branch": "default", "desc": "Bug 1536877 - Correct telemetry constant for 67 r=chutten a=pascalc l10n=flod\nMozReview-Commit-ID: JKAvUtFXsIb", "files": ["toolkit/components/extensions/test/xpcshell/test_ext_telemetry.js"], "git_node": null, "git_parents": [null], "node": "a08cdd143e57dbd4bc062851b790ef53d82196ed", "parents": ["521037994bf751d45f8acd5f2f32982a85e80947"], "tags": []}], "date": 1556112795, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null], "user": "nerli@mozilla.com"}, "11148": {"changesets": [{"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1508961 - Show a notification icon after automatically dismissing permission prompts. r=MattN a=pascalc\n\nThis adds support for a \"post-prompt\" that appears dismissed (only the icon showing) when\nthe browser decides to automatically deny a permission request from a site (either based on\ninternal heuristics or because the user prefers not to receive permission prompts).\n\nIn order to move quickly and not overload the patch I have only implemented the post-prompting\nfor desktop-notification so far, however, implementing it for other permissions should be\na trivial follow-up.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25415", "files": ["browser/app/profile/firefox.js", "browser/base/content/test/permissions/browser.ini", "browser/base/content/test/permissions/browser_permissions_postPrompt.js", "browser/modules/PermissionUI.jsm", "browser/themes/shared/notification-icons.inc.css"], "git_node": null, "git_parents": [null], "node": "4b5a567ae62d4a2b1d18e7adf37802dc1052d9f6", "parents": ["a08cdd143e57dbd4bc062851b790ef53d82196ed"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1508961 - Don't prematurely check for permissions in pushManager.subscribe() permission requests. r=lina a=pascalc\n\nThis permission checking should be handled by PermissionUI.jsm, to be able to apply custom heuristics\nfor denying the permission and also to be able to \"post-prompt\" after denying automatically.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25416", "files": ["dom/push/Push.jsm"], "git_node": null, "git_parents": [null], "node": "45360f538e3d4c6e1672a2b2c9bd343ba49c61ec", "parents": ["4b5a567ae62d4a2b1d18e7adf37802dc1052d9f6"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1536454 - Part 1 - Add userHadInteractedWithDocument and documentDOMContentLoadedTimestamp attributes to nsIContentPermissionPrompt. r=Ehsan a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26942", "files": ["browser/actors/WebRTCChild.jsm", "browser/modules/test/browser/head.js", "dom/base/nsContentPermissionHelper.cpp", "dom/base/nsContentPermissionHelper.h", "dom/interfaces/base/nsIContentPermissionPrompt.idl", "dom/ipc/ContentChild.cpp", "dom/ipc/ContentChild.h", "dom/ipc/ContentParent.cpp", "dom/ipc/ContentParent.h", "dom/ipc/PContent.ipdl", "dom/push/Push.jsm"], "git_node": null, "git_parents": [null], "node": "f71a18e81a6989dfd853195cb5abd0de7df068fa", "parents": ["45360f538e3d4c6e1672a2b2c9bd343ba49c61ec"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1536454 - Part 2 - Add modificationTime attribute to nsIPermission.idl. r=Ehsan a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26943", "files": ["extensions/cookie/nsPermission.cpp", "extensions/cookie/nsPermission.h", "extensions/cookie/nsPermissionManager.cpp", "extensions/cookie/nsPermissionManager.h", "netwerk/base/nsIPermission.idl", "netwerk/cookie/CookieSettings.cpp"], "git_node": null, "git_parents": [null], "node": "fbe79e8981f7a1894ffcbc24ffa6457e48c24869", "parents": ["f71a18e81a6989dfd853195cb5abd0de7df068fa"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1536454 - Part 3 - Make POPUP_NOTIFICATION_STATS probe collect data on notification removal instead of dismissal. r=MattN a=pascalc\n\nAlmost none of the prompts that we are currently showing still get dismissed, which messes up our\nmeasurements in this probe. Most of them are persistent now, which means that we should record when\nthey get removed instead of dismissed to receive meaningful data. This patch does that.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26944", "files": ["toolkit/components/telemetry/Histograms.json", "toolkit/modules/PopupNotifications.jsm"], "git_node": null, "git_parents": [null], "node": "fe7f1569e8d65649f12ebe8f5e2be87b01ea97c0", "parents": ["fbe79e8981f7a1894ffcbc24ffa6457e48c24869"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1536454 - Part 4 - Add event telemetry for permission prompt studies. r=Ehsan a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26945", "files": ["browser/app/profile/firefox.js", "browser/components/BrowserGlue.jsm", "browser/modules/PermissionUI.jsm", "browser/modules/PermissionUITelemetry.jsm", "browser/modules/moz.build", "toolkit/components/telemetry/Events.yaml"], "git_node": null, "git_parents": [null], "node": "759d4a9a89701264867256be209a42a64e9f5f5f", "parents": ["fe7f1569e8d65649f12ebe8f5e2be87b01ea97c0"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1536454 - Part 5 - Add tests for permission prompt event telemetry. r=Ehsan a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D27907", "files": ["browser/base/content/test/permissions/browser.ini", "browser/base/content/test/permissions/browser_permissions_event_telemetry.js", "testing/mochitest/BrowserTestUtils/ContentTaskUtils.jsm"], "git_node": null, "git_parents": [null], "node": "156dcfca7e317c51910a875ba8838e5d0ed5f5de", "parents": ["759d4a9a89701264867256be209a42a64e9f5f5f"], "tags": []}, {"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1546367 - Clear report textarea when report is submitted. r=bgrins a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D28522", "files": ["browser/base/content/browser-contentblocking.js", "browser/base/content/test/trackingUI/browser_trackingUI_report_breakage.js"], "git_node": null, "git_parents": [null], "node": "9cf0e5a84b2c175c4c866b31c3ee0c7fd564b53f", "parents": ["156dcfca7e317c51910a875ba8838e5d0ed5f5de"], "tags": []}, {"author": "alwu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1544023 - let AudioNode keep the reference of all AudioParams which belong to itself. r=padenot a=pascalc\n\nWhen we suspend or resume the AudioContext, it should affect ALL media streams which belong to or are related to the AudioNode that are created by this AudioContext.\n\nAs AudioNode::OutputParams() can only return the connected AudioParams, it doesn't return the AudioParams which are belong to itself. That means we would miss to apply the suspend/resume operation for those streams, and it would cause imbalancing suspended count.\n\nTherefore, we let AudioNode to keep the reference of all its AudioParam, and return them to AudioContext in order to do the operation for all streams.", "files": ["dom/media/webaudio/AudioBufferSourceNode.cpp", "dom/media/webaudio/AudioContext.cpp", "dom/media/webaudio/AudioNode.cpp", "dom/media/webaudio/AudioNode.h", "dom/media/webaudio/BiquadFilterNode.cpp", "dom/media/webaudio/ConstantSourceNode.cpp", "dom/media/webaudio/DelayNode.cpp", "dom/media/webaudio/DynamicsCompressorNode.cpp", "dom/media/webaudio/GainNode.cpp", "dom/media/webaudio/OscillatorNode.cpp", "dom/media/webaudio/PannerNode.cpp", "dom/media/webaudio/StereoPannerNode.cpp"], "git_node": null, "git_parents": [null], "node": "151cf24aa0fe45af946282b275e30deb908af841", "parents": ["9cf0e5a84b2c175c4c866b31c3ee0c7fd564b53f"], "tags": ["DEVEDITION_67_0b14_BUILD1", "DEVEDITION_67_0b14_RELEASE", "FENNEC_67_0b14_BUILD1", "FENNEC_67_0b14_RELEASE", "FIREFOX_67_0b14_BUILD1", "FIREFOX_67_0b14_RELEASE"]}], "date": 1556114579, "git_ch