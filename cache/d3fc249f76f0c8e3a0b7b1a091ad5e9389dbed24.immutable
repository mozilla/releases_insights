or-tp6m-google-maps.manifest", "testing/raptor/raptor/playback/mitmproxy-recordings-raptor-tp6m-google-restaurants.manifest", "testing/raptor/raptor/raptor.ini", "testing/raptor/raptor/tests/raptor-tp6m-3.ini"], "git_node": null, "git_parents": [null], "node": "a74bd72021706765c0b158bcf0dc05145b9c6b6d", "parents": ["53388cbb2a6d8a7e5234f0299c61168d03ae6408"], "tags": []}, {"author": "Benjamin Bouvier \u003cbenj@benj.me\u003e", "branch": "default", "desc": "Bug 1534958: Fix build when BinAST is disabled; r=arai\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23301", "files": ["js/src/frontend/Parser.cpp"], "git_node": null, "git_parents": [null], "node": "2f9ff29f8920c42346add76531506f0f24496632", "parents": ["a74bd72021706765c0b158bcf0dc05145b9c6b6d"], "tags": []}, {"author": "Brindusan Cristian \u003ccbrindusan@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 5b06a29334b8 (bug 1534830) for bc failures at browser_startup.js. CLOSED TREE", "files": ["browser/components/urlbar/UrlbarUtils.jsm"], "git_node": null, "git_parents": [null], "node": "916f90879f389f7b64b460506acce8f2f1f981bf", "parents": ["2f9ff29f8920c42346add76531506f0f24496632"], "tags": []}, {"author": "Ricky Rosario \u003crickyrosario@gmail.com\u003e", "branch": "default", "desc": "Bug 1533588 - Bookmark confirmation hint panel is missing \"Saved to Library!\" text after landing patch from bug #1528955 r=dao\n\nMozReview-Commit-ID: Ks6TAsIpHFz\n\nDifferential Revision: https://phabricator.services.mozilla.com/D22991", "files": ["browser/base/content/browser.js", "browser/base/content/browser.xul", "browser/themes/shared/customizableui/panelUI.inc.css"], "git_node": null, "git_parents": [null], "node": "3a83232643982f63b5e7c054c67507c411b24d30", "parents": ["916f90879f389f7b64b460506acce8f2f1f981bf"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1466208 - part 45: Rename `aFrame` of `HandleEvent()` to `aFrameForPresShell` r=smaug\n\nNow, other methods taking `aFrame` of `HandleEvent()` names the argument as\n`aFrameForPresShell`.  So, `HandleEvent()`'s `aFrame` should also be renamed.\n\nThis patch renames it and adds MOZ_CAN_RUN_SCRIPT and comment to\n`nsIPresShell::HandleEvent()`.\n\nThis is the final patch for bug 1466208.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D22463", "files": ["layout/base/PresShell.cpp", "layout/base/PresShell.h"], "git_node": null, "git_parents": [null], "node": "4be0480f48d3bede45eb0f18479dc7cd2d686aa8", "parents": ["3a83232643982f63b5e7c054c67507c411b24d30"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1534830 - Fix UrlbarUtils.ICON.DEFAULT. r=mak\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23297", "files": ["browser/components/urlbar/UrlbarUtils.jsm"], "git_node": null, "git_parents": [null], "node": "17c3b29f3b070a129be84a7f2daeb3fc71d871d1", "parents": ["4be0480f48d3bede45eb0f18479dc7cd2d686aa8"], "tags": []}, {"author": "Michal Novotny \u003cmichal.novotny@gmail.com\u003e", "branch": "default", "desc": "Bug 1151815 - Remove expiration time from the cache index, r=mayhemer\n\nDifferential Revision: https://phabricator.services.mozilla.com/D22499", "files": ["netwerk/cache2/CacheFile.cpp", "netwerk/cache2/CacheFileIOManager.cpp", "netwerk/cache2/CacheFileIOManager.h", "netwerk/cache2/CacheIndex.cpp", "netwerk/cache2/CacheIndex.h"], "git_node": null, "git_parents": [null], "node": "7c663cf76b8d561d3334b11314ca41255b7a1b66", "parents": ["17c3b29f3b070a129be84a7f2daeb3fc71d871d1"], "tags": []}, {"author": "Dhruvi Butti \u003cdhruvibutti9477@gmail.com\u003e", "branch": "default", "desc": "Bug 1164195 - Add a resultType param to $x console helper. r=nchevobbe.\n\nThis makes it possible to pass a third parameter which is a XPathResult constant.\nTest cases are added to ensure this works as expected.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23307", "files": ["devtools/client/webconsole/test/mochitest/browser_jsterm_helper_dollar_x.js", "devtools/server/actors/webconsole/utils.js"], "git_node": null, "git_parents": [null], "node": "fcdfe2be33a5fa5a531d18f3f4302aa48df5f3e0", "parents": ["7c663cf76b8d561d3334b11314ca41255b7a1b66"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1526654 - Use xpcshell sequential mode consistently when running a single test; r=bc\n\nIn the harness, sequential mode is set when self.singleFile is set. self.singleFile has\nbeen set correctly when a single test is specified as a test_path (mach xpcshell-test \u003ctest\u003e)\nbut it has not been set correctly if a single test is specified in a manifest (mach test \u003ctest);\nthis patch corrects for that by setting self.singleFile after all test specifications have\nset self.alltests.\n\nAn unintended consequence of the code rearrangement is that the chunk_by_slice filter is\nnow used even when self.singleFile would be set -- but only if totalChunks \u003e 1; this\nsituation seems very unlikely, and the consequences minimal.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23253", "files": ["testing/xpcshell/runxpcshelltests.py"], "git_node": null, "git_parents": [null], "node": "8130ba1701bbd69ec304eca887c0e66e9e1307ef", "parents": ["fcdfe2be33a5fa5a531d18f3f4302aa48df5f3e0"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1534336 - pass fluent IDs directly and pass text nodes in cases where we pass literal strings, r=jaws\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23190", "files": ["toolkit/content/aboutSupport.js"], "git_node": null, "git_parents": [null], "node": "956e0ebc41ad4af3497084bcd03220a65923cf8f", "parents": ["8130ba1701bbd69ec304eca887c0e66e9e1307ef"], "tags": []}, {"author": "Jason Laster \u003cjlaster@mozilla.com\u003e", "branch": "default", "desc": "No bug - Add damp tests to debugger-tests.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23305", "files": ["tools/tryselect/try_presets.yml"], "git_node": null, "git_parents": [null], "node": "c97013ec665b60baf54c30a23352a5185dfdfd56", "parents": ["956e0ebc41ad4af3497084bcd03220a65923cf8f"], "tags": []}, {"author": "Michael Ratcliffe \u003cmratcliffe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1534610 - Switch to React.createRef() in inspector.js to save a few cycles r=rcaliman\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23131", "files": ["devtools/client/inspector/inspector.js", "devtools/client/inspector/test/browser_inspector_pane-toggle-02.js", "devtools/client/inspector/test/browser_inspector_pane-toggle-03.js", "devtools/client/inspector/test/browser_inspector_pane-toggle-04.js", "devtools/client/inspector/test/browser_inspector_pane_state_restore.js"], "git_node": null, "git_parents": [null], "node": "70b39f59687c9d81003ea03345d44563c63fb1dd", "parents": ["c97013ec665b60baf54c30a23352a5185dfdfd56"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1534518.  Change CanRunScriptChecker caller function note to point to the declaration, not the definition.  r=andi\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23082", "files": ["build/clang-plugin/CanRunScriptChecker.cpp", "build/clang-plugin/tests/TestCanRunScript.cpp"], "git_node": null, "git_parents": [null], "node": "b6d239de820fce497fc6e7d5f6a10ad2a1a4122b", "parents": ["70b39f59687c9d81003ea03345d44563c63fb1dd"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1534421.  Fix the CAN_RUN_SCRIPT analysis to treat a deref of an arg as live if it would treat the arg as live.  r=andi\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23071", "files": ["build/clang-plugin/CanRunScriptChecker.cpp", "build/clang-plugin/CustomMatchers.h", "build/clang-plugin/tests/TestCanRunScript.cpp", "dom/events/EventListenerManager.cpp"], "git_node": null, "git_parents": [null], "node": "f65aaa2a97bb8bc7ab61a4fb650db6b356911767", "parents": ["b6d239de820fce497fc6e7d5f6a10ad2a1a4122b"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "bug 1534829: remote: map source code to bug components; r=yulia\n\nDevTools :: Remote Agent was removed in favour of a new product,\nRemote Protocol.  This corrects the file metadata mapping for the\nagent.\n\nThe patch also adds mapping for new domains.  Not all of the\ncomponents exist yet, but this is tracked separately in\nhttps://bugzilla.mozilla.org/show_bug.cgi?id=1534970.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23306", "files": ["remote/moz.build"], "git_node": null, "git_parents": [null], "node": "a710a25b6c5d3274fb80cf22af7fcc50ce306256", "parents": ["f65aaa2a97bb8bc7ab61a4fb650db6b356911767"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "bug 1534827: remote: fix constants in transitionToLoadFlag; r=yulia\n\nThe transitionType is converted into undefined because there is a typo\nin the constants.  These should be \"FLAGS\" rather than \"FLAG\".\n\nThanks-to: Mark Banner \u003cstandard8@mozilla.com\u003e\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23315", "files": ["remote/domains/content/Page.jsm"], "git_node": null, "git_parents": [null], "node": "95f4b83aed87e9d8638987cf30b40f5ac6cd1821", "parents": ["a710a25b6c5d3274fb80cf22af7fcc50ce306256"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1534822 - Increase chunks for linux debug mochitest-devtools, and max-run-time for ccov; r=jmaher\n\nLinux64/debug mochitest-dt chunks are increased to 16 to provide more capacity in\nreasonable run time. For ccov, mochitest-dt-12 sometimes still runs \u003e 90 minutes,\nso ccov max-run-time is increased to 2 hours.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23309", "files": ["taskcluster/ci/test/mochitest.yml"], "git_node": null, "git_parents": [null], "node": "4db925ab7d46346a62bacf3cf7acd03f9fd62f8c", "parents": ["95f4b83aed87e9d8638987cf30b40f5ac6cd1821"], "tags": []}, {"author": "Byron Campen [:bwc] \u003cdocfaraday@gmail.com\u003e", "branch": "default", "desc": "Bug 1531075: Allow offers to be created/set without any transceivers, re-enable some tests, and fix a mochitest. r=jib\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23022", "files": ["dom/media/tests/mochitest/mochitest.ini", "dom/media/tests/mochitest/test_peerConnection_bug1064223.html", "dom/media/tests/mochitest/test_peerConnection_throwInCallbacks.html", "media/webrtc/signaling/gtest/jsep_session_unittest.cpp", "media/webrtc/signaling/src/jsep/JsepSessionImpl.cpp", "testing/web-platform/meta/webrtc/RTCPeerConnection-createOffer.html.ini", "testing/web-platform/meta/webrtc/RTCPeerConnection-setLocalDescription-answer.html.ini", "testing/web-platform/meta/webrtc/RTCPeerConnection-setLocalDescription-rollback.html.ini", "testing/web-platform/meta/webrtc/RTCPeerConnection-setLocalDescription.html.ini", "testing/web-platform/meta/webrtc/RTCPeerConnection-setRemoteDescription-answer.html.ini"], "git_node": null, "git_parents": [null], "node": "add69e4bd9af8b952a29e66b6cf0df33be47f214", "parents": ["4db925ab7d46346a62bacf3cf7acd03f9fd62f8c"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1506510 - add keyboard focus styling for toolbar/urlbar buttons. r=dao\n\nDifferential Revision: https://phabricator.services.mozilla.com/D19958", "files": ["browser/app/profile/firefox.js", "browser/themes/linux/browser.css", "browser/themes/osx/browser.css", "browser/themes/shared/identity-block/identity-block.inc.css", "browser/themes/shared/toolbarbuttons.inc.css", "browser/themes/shared/urlbar-searchbar.inc.css", "browser/themes/windows/browser.css"], "git_node": null, "git_parents": [null], "node": "fffb4b5030daf853ff9d61453f3132c3295a6a3b", "parents": ["add69e4bd9af8b952a29e66b6cf0df33be47f214"], "tags": []}, {"author": "Erica Wright \u003cewright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1526075 - Warn user and provide option to refresh tabs to apply content blocking changes. r=johannh,flod\n\nWhen user changes a content blocking pref, warn them they need to refresh their tabs, and show them a button to do it.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D22600", "files": ["browser/components/preferences/in-content/privacy.js", "browser/components/preferences/in-content/privacy.xul", "browser/components/preferences/in-content/tests/browser_contentblocking.js", "browser/locales/en-US/browser/preferences/preferences.ftl", "browser/themes/shared/incontentprefs/privacy.css"], "git_node": null, "git_parents": [null], "node": "492c2ba4953f52eaa00b35fdf35312f89eceb18f", "parents": ["fffb4b5030daf853ff9d61453f3132c3295a6a3b"], "tags": []}, {"author": "Brian Hackett \u003cbhackett1024@gmail.com\u003e", "branch": "default", "desc": "Bug 1534772 - Evaluate expressions when selecting new threads, r=jlast.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23211", "files": ["devtools/client/debugger/new/src/actions/pause/commands.js", "devtools/client/debugger/new/src/actions/types/index.js", "devtools/client/debugger/new/src/reducers/expressions.js", "devtools/client/debugger/new/src/reducers/pause.js"], "git_node": null, "git_parents": [null], "node": "5dc0ae1f1b48630aeee9ee07c2dcbda345ad3a2b", "parents": ["492c2ba4953f52eaa00b35fdf35312f89eceb18f"], "tags": []}, {"author": "Jeff Muizelaar \u003cjrmuizel@gmail.com\u003e", "branch": "default", "desc": "Bug 1534250. Always paint the entire mask. r=mattwoodrow\n\nPreviously we would only paint the building area but we\nwould not do anything to check that the building area had\nchanged. Since, we're already allocating a surface for the entire\nitem it's better to just paint it and not worry about doing extra\ninvalidations.\n\nOriginally, we used mVisibleRect here. That was changed to GetPaintRect()\nin part 1 of 1460491 and then to GetBuildingRect in part 2. However,\nI think the original code was always wrong and we should've been using\nmBounds the whole time.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23215", "files": ["layout/painting/nsDisplayList.cpp"], "git_node": null, "git_parents": [null], "node": "69f7e56e68bc94a682265731fd503a58597c6be5", "parents": ["5dc0ae1f1b48630aeee9ee07c2dcbda345ad3a2b"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1532435 - Skip junit inputConnection test on debug only, to save lots of time; r=snorp\n\nDisabling inputConnection on debug saves about 15 minutes of time, which helps\nus avoid the timeouts seen in this bug. It continues running on opt, where it\nruns much faster.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23254", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/TextInputDelegateTest.kt"], "git_node": null, "git_parents": [null], "node": "c2beaac7130578945db2e7ee33e8667791017f2d", "parents": ["69f7e56e68bc94a682265731fd503a58597c6be5"], "tags": []}, {"author": "Brindusan Cristian \u003ccbrindusan@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 5dc0ae1f1b48 (bug 1534772) for node-debugger failures. CLOSED TREE", "files": ["devtools/client/debugger/new/src/actions/pause/commands.js", "devtools/client/debugger/new/src/actions/types/index.js", "devtools/client/debugger/new/src/reducers/expressions.js", "devtools/client/debugger/new/src/reducers/pause.js"], "git_node": null, "git_parents": [null], "node": "226ec6ce41c41d599681ea2ecfaa10