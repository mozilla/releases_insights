/src/jit/IonBuilder.cpp"], "git_node": null, "git_parents": [null], "node": "be119fec61f8d4c6692e30dbc5a633749557eb16", "parents": ["54576c33652de024a955671675369ed85cefabe4"], "tags": []}, {"author": "Ted Campbell \u003ctcampbell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1536159 - Crash diagnositic for js::TypeZone::addPendingRecompile. r=jwalden a=pascalc\n\nSummary:\n\nRecord the size of allocation in crashreporter to determine if these are\ngenuine small OOM or if something problematic has happened.\n\nReviewers: jwalden\n\nReviewed By: jwalden\n\nSubscribers: jandem\n\nBug #: 1536159\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25152", "files": ["js/src/vm/TypeInference.cpp"], "git_node": null, "git_parents": [null], "node": "281162c3457183da6eccfb440ad0b4eade84910b", "parents": ["be119fec61f8d4c6692e30dbc5a633749557eb16"], "tags": []}], "date": 1554956012, "git_changesets": [null, null], "user": "dvarga@mozilla.com"}, "11063": {"changesets": [{"author": "Neil Deakin \u003cneil@mozilla.com\u003e", "branch": "default", "desc": "Bug 1507004, get the contentDocument for all iframes, to ensure that the iframe is focusable, r=peterv a=test-only", "files": ["dom/html/test/test_bug430351.html"], "git_node": null, "git_parents": [null], "node": "77f9f813184572c571dec58fec3c6e0d3961fd04", "parents": ["281162c3457183da6eccfb440ad0b4eade84910b"], "tags": []}, {"author": "Junior Hsu \u003cjuhsu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1524154 - Re-enable flow control for media wpt r=kershaw a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25427", "files": ["testing/web-platform/meta/html/semantics/embedded-content/media-elements/playing-the-media-resource/__dir__.ini", "testing/web-platform/meta/html/semantics/embedded-content/media-elements/video_008.htm.ini", "testing/web-platform/meta/html/semantics/embedded-content/the-video-element/video_initially_paused.html.ini"], "git_node": null, "git_parents": [null], "node": "0b4923e63c709ecc0e71d23b3d3656184360d84b", "parents": ["77f9f813184572c571dec58fec3c6e0d3961fd04"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1533477 - check that the number of items in the app list doesn't change, r=jaws a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26751", "files": ["browser/components/preferences/in-content/tests/browser_applications_selection.js"], "git_node": null, "git_parents": [null], "node": "7fe4dd7263634fb16868854059f4f8269e8bb1cc", "parents": ["0b4923e63c709ecc0e71d23b3d3656184360d84b"], "tags": []}], "date": 1554966590, "git_changesets": [null, null, null], "user": "apavel@mozilla.com"}, "11064": {"changesets": [{"author": "Gabriele Svelto \u003cgsvelto@mozilla.com\u003e", "branch": "default", "desc": "Bug 1536850 - Properly detect when the browser is shutting down to avoid taking content process minidumps too late r=Ehsan a=pascalc\n\nThis code was already present but it had two flaws: the first one was that the\nvariable used to prevent minidumps from being taken when shutting down was not\nbeing initialized which caused it to be true most of the time and thus\nprevented captures even in valid scenarios. The second was that we relied on\nthe \"profile-before-change\" change event to detect shutdown but this often\nhappens after we've already started closing tabs and shutting down processes\nthus the minidump generation would often race against it.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24691", "files": ["dom/ipc/ContentParent.cpp", "dom/ipc/ContentParent.h"], "git_node": null, "git_parents": [null], "node": "ea0b308de5c414a253e7d851286dea8d6879a43a", "parents": ["7fe4dd7263634fb16868854059f4f8269e8bb1cc"], "tags": []}, {"author": "alwu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1542921 - turn on block autoplay by default. r=cpearce a=pascalc\n\nAs we have successfully rolled out the feature via Normandy in 66, we should turn the feature on in \u003e= 67 to not have to rely on Normandy going forward any more.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26713", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "778c3da2f7ae901e6cb55115217f8fb32a798bae", "parents": ["ea0b308de5c414a253e7d851286dea8d6879a43a"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1538236 - fix LTO issues with arm xptcstubs; r=mccr8 a=pascalc\n\nARM's xptcstubs use a slightly different setup for PrepareAndDispatch\nthan...well, all of our other stubs.  This difference appears to be\ncausing problems with LTO builds.  Change the setup to be more like our\nother stubs, which additionally gets rid of some of the `asm` nonsense.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26243", "files": ["xpcom/reflect/xptcall/md/unix/xptcstubs_arm.cpp"], "git_node": null, "git_parents": [null], "node": "1cdd3ceab2bc361c4c8a4af20c2baf857e898104", "parents": ["778c3da2f7ae901e6cb55115217f8fb32a798bae"], "tags": []}, {"author": "Jeff Muizelaar \u003cjrmuizel@gmail.com\u003e", "branch": "default", "desc": "Bug 1541920. Handle blend mode activeness properly. r=mstange a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26364", "files": ["gfx/layers/wr/WebRenderCommandBuilder.cpp", "layout/reftests/css-blending/reftest.list", "layout/reftests/svg/active-transform-blend-mode-ref.html", "layout/reftests/svg/active-transform-blend-mode.html", "layout/reftests/svg/reftest.list"], "git_node": null, "git_parents": [null], "node": "7f38f1aed586c262a7b335facf6e6415012b0d2d", "parents": ["1cdd3ceab2bc361c4c8a4af20c2baf857e898104"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1542193 - Fix handling of select's direction in e10s. r=mconley a=pascalc\n\nIn bug 1375476 I fixed one of the places but missed the other. I'll refactor\nthem in a bit.\n\nI wish I could run the select tests locally to extend them properly...\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26517", "files": ["toolkit/content/widgets/browser-custom-element.js"], "git_node": null, "git_parents": [null], "node": "f6f8de091b65274d5d6cf6bd59ff48a04dd77c02", "parents": ["7f38f1aed586c262a7b335facf6e6415012b0d2d"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1542193 - Unify handling of e10s and non-e10s Forms:ShowDropDown messages. r=mconley a=pascalc\n\nI assume this was an artifact of when this was done with XBL.\n\nDepends on D26517\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26518", "files": ["toolkit/content/widgets/browser-custom-element.js"], "git_node": null, "git_parents": [null], "node": "03e1b51654e2255fb61a37bb02ed94a7d0637178", "parents": ["f6f8de091b65274d5d6cf6bd59ff48a04dd77c02"], "tags": ["DEVEDITION_67_0b10_BUILD1", "DEVEDITION_67_0b10_RELEASE", "FIREFOX_67_0b10_BUILD1", "FIREFOX_67_0b10_RELEASE"]}], "date": 1554972363, "git_changesets": [null, null, null, null, null, null], "user": "apavel@mozilla.com"}, "11065": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nes-CL -\u003e dcc4180d13b1\nis -\u003e 257cfba1bf0a\nit -\u003e 4d689e68a8d3\nnl -\u003e 697f6640af8e", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "83812aa57c1dae687aeb0acf6e620d8022fcc7b4", "parents": ["03e1b51654e2255fb61a37bb02ed94a7d0637178"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nda -\u