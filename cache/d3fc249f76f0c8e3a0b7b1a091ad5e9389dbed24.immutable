ode": null, "git_parents": [null], "node": "df44579602741c9317b21b5c207b9241a28f7f6c", "parents": ["60cc54f37123aef35d8c4d59bf87a748fd3d8a04"], "tags": []}], "date": 1556222433, "git_changesets": [null, null], "user": "ffxbld"}, "11162": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 151cf24aa0fe45af946282b275e30deb908af841 with DEVEDITION_67_0b14_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "77101b25d527382e9ab8d22cbc46ad35a1d4ef2f", "parents": ["df44579602741c9317b21b5c207b9241a28f7f6c"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release DONTBUILD", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "784978c4a60390da305acdd07b1f63d69c67558e", "parents": ["77101b25d527382e9ab8d22cbc46ad35a1d4ef2f"], "tags": []}], "date": 1556264402, "git_changesets": [null, null], "user": "ffxbld"}, "11163": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 151cf24aa0fe45af946282b275e30deb908af841 with FENNEC_67_0b14_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "106284d5a4574fcb818f318d3f2c25bb81202c34", "parents": ["784978c4a60390da305acdd07b1f63d69c67558e"], "tags": []}], "date": 1556264588, "git_changesets": [null], "user": "ffxbld"}, "11164": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 151cf24aa0fe45af946282b275e30deb908af841 with FIREFOX_67_0b14_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "b3560451adda14ddc60eddc9fcad06ade1fcd4ca", "parents": ["106284d5a4574fcb818f318d3f2c25bb81202c34"], "tags": []}], "date": 1556264769, "git_changesets": [null], "user": "ffxbld"}, "11165": {"changesets": [{"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1545974 - Disable browser_UrlbarInput_tooltip.js from running in QuantumBar mode on beta due to timeouts (and QuantumBar not shipping in 67). r?mikedeboer,a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D28950", "files": ["browser/components/urlbar/tests/browser/browser.ini"], "git_node": null, "git_parents": [null], "node": "b5794f0035103a7f991c3475b198541b7a22c0bd", "parents": ["b3560451adda14ddc60eddc9fcad06ade1fcd4ca"], "tags": []}], "date": 1556270663, "git_changesets": [null], "user": "mbanner@mozilla.com"}, "11166": {"changesets": [{"author": "Alex Chronopoulos \u003cachronop@gmail.com\u003e", "branch": "default", "desc": "Bug 1543350 - don't shut-down taskqueue early. r=jya,mjf a=pascalc\n\nShutting down the taskqueue early prevents the decoder's tasks to be queued.\n\nA TaskQueue no longer requires to be explicitly shutdown it will shutdown when ref counter drops to zero.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26929", "files": ["dom/media/ipc/RemoteDecoderParent.cpp"], "git_node": null, "git_parents": [null], "node": "66d938a1a824b2bc26bebbf675124fa8275cffe9", "parents": ["b5794f0035103a7f991c3475b198541b7a22c0bd"], "tags": []}, {"author": "Dave Townsend \u003cdtownsend@oxymoronical.com\u003e", "branch": "default", "desc": "Bug 1546326: Correctly detect missing directories on Windows. r=Gijs a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D28514", "files": ["toolkit/content/aboutProfiles.js"], "git_node": null, "git_parents": [null], "node": "9fa4cf7dfb75f9591fd91a76776221af0868a995", "parents": ["66d938a1a824b2bc26bebbf675124fa8275cffe9"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1546139 - Pick up fixed layer margins in AsyncCompositionManager with containerless scrolling. r=kats a=pascalc\n\nSummary:\n\nThis is a fix for the 67 branch only. 68 will require a different fix due to\nbug 1525181 having changed this code since then.\n\nReviewers: kats\n\nReviewed By: kats\n\nBug #: 1546139\n\nDifferential Revision: https://phabricator.services.mozilla.com/D28407", "files": ["gfx/layers/composite/AsyncCompositionManager.cpp"], "git_node": null, "git_parents": [null], "node": "d41af59923c97c57c2c7c22fe47ce6760f1a2029", "parents": ["9fa4cf7dfb75f9591fd91a76776221af0868a995"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1540628 - Don't use restartInput when no composition. r=esawin a=pascalc\n\nSince `restartInput` resets all keyboard state, it isn't good to call this\neverytime. So we should call this when discarding composition only.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D27489", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoEditable.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoInputConnection.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/SessionTextInput.java"], "git_node": null, "git_parents": [null], "node": "37474b32ecd189afb5c50d65b9d208eee94f0639", "parents": ["d41af59923c97c57c2c7c22fe47ce6760f1a2029"], "tags": []}, {"author": "Kenny Levinsen \u003ckl@kl.wtf\u003e", "branch": "default", "desc": "Bug 1546098 - Ensure that nsRefreshDriver is always stopped when not needed. r=emilio a=pascalc\n\nnsRefreshDrivers belonging to fully-loaded documents in content processes\nnow correctly stop their timer when no observers are present.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D28339", "files": ["layout/base/nsRefreshDriver.cpp"], "git_node": null, "git_parents": [null], "node": "454de582d1d68e12cd653b51e78d5ed25858e890", "parents": ["37474b32ecd189afb5c50d65b9d208eee94f0639"], "tags": []}, {"author": "Razvan Caliman \u003crcaliman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1542213 - Track newly added CSS rules in the Changes panel. r=pbro a=pascalc\n\nIntroduces tracking for newly created CSS rules in the PageStyleActor.\n\nAdds a boolean flag, `isNew`, to the tracked rule in the Changes Redux store. Using this flag, render the new rule's selector in the React component as added (plus sign, green background). Ensure selector changes for thew new rule always overwrite the original selector (fix for Bug 1542288) instead of erroneously showing the original selector as removed.\n\nRemoves obsolete documentation for \"changeType\" from the tracked rule in the Changes Redux store. This was never used.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D28215", "files": ["devtools/client/inspector/changes/components/ChangesApp.js", "devtools/client/inspector/changes/reducers/changes.js", "devtools/client/inspector/changes/test/browser.ini", "devtools/client/inspector/changes/test/browser_changes_rule_add.js", "devtools/client/inspector/changes/test/browser_changes_rule_selector.js", "devtools/client/inspector/changes/test/head.js", "devtools/server/actors/styles.js"], "git_node": null, "git_parents": [null], "node": "d461f7c018d3ebfa98b0d59f0b4343c44d5b433e", "parents": ["454de582d1d68e12cd653b51e78d5ed25858e890"], "tags": []}, {"author": "Tom Tung \u003cshes050117@gmail.com\u003e", "branch": "default", "desc": "Bug 1481164 - Dispatch to the Background thread even when the Connection is a nullptr in IdleConnectionRunnable::Run(); r=janv a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D28520", "files": ["dom/indexedDB/ActorsParent.cpp"], "git_node": null, "git_parents": [null], "node": "74af12527bdc09354ae688de5cc6cfa4f191f32d", "parents": ["d461f7c018d3ebfa98b0d59f0b4343c44d5b433e"], "tags": []}, {"author": "Tim D. Smith \u003ctdsmith@mozilla.com\u003e", "branch": "default", "desc": "Bug 1544539 - Collect GEOLOCATION_REQUEST_GRANTED through 2019 r=jdm a=pascalc\n\nThe GEOLOCATION_REQUEST_GRANTED probe expires in the next release.\nWe're using this probe to target a survey, as in bug 1499851;\nnew followup work that we're discussing now will also require the probe.\nSince we've extended collection a few times already, let's turn collection on\nfor the rest of the year.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D27567", "files": ["toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "c18c758f3e31c4a0b4a535fab4006a114c13acaa", "parents": ["74af12527bdc09354ae688de5cc6cfa4f191f32d"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1540251 - Workaround unset NAL size in WebrtcGmpVideoEncoder::Encoded; r=pehrsons a=pascalc\n\nOpenH264 1.8.1 occasionally generates a size of 0x01000000. This is a magic\nvalue in the NAL which should be replaced with a valid size, but for some\nreason this is not always happening. If we return early here, encoding will\ncontinue to work as expected. This workaround can be removed once this issue is\naddressed upstream, although that may require a new release of OpenH264.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25468", "files": ["media/webrtc/signaling/src/media-conduit/WebrtcGmpVideoCodec.cpp"], "git_node": null, "git_parents": [null], "node": "85db0015c02fafc0f57db709783898361b5201ec", "parents": ["c18c758f3e31c4a0b4a535fab4006a114c13acaa"], "tags": []}, {"author": "Grisha Kruglov \u003cgkruglov@mozilla.com\u003e", "branch": "default", "desc": "Bug 1545232 - Add AuthStateProvider r=nalexander,sebastian a=pascalc\n\nSee comments in the patch for details.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D28001", "files": ["mobile/android/base/AndroidManifest.xml.in", "mobile/android/services/src/main/java/org/mozilla/gecko/fxa/AuthStateProvider.java", "mobile/android/services/src/main/java/org/mozilla/gecko/fxa/login/TokensAndKeysState.java"], "git_node": null, "git_parents": [null], "node": "ded211603671be4210c80f5c2f17c0a4a5f9ceb7", "parents": ["85db0015c02fafc0f57db709783898361b5201ec"], "tags": []}], "date": 1556282905, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "apavel@mozilla.com"}, "11167": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nbs -\u003e e296e1f1feeb\ncs -\u003e b938e22f6380\nel -\u003e 6360d5f80113\nfr -\u003e 8f9886d2f3aa\ngd -\u003e 4ce805ebff63\nhr -\u003e 35c3ff7f7d39\nit -\u003e 127ba469b341\nja -\u003e 2f3d981d2f83\nka -\u003e 7d9315320c61\nko -\u003e b39c0d5d02fc\npt-BR -\u003e 1048ac517ad9\npt-PT -\u003e e2647de6e9ac\nsk -\u003e 4238d8bab29a\nsl -\u003e f1c32f990603\nsq -\u003e caf5f4d02a0e\nte -\u003e 1cf4ca9a53e1\nth -\u003e d66d28021b19\ntr -\u003e eb7d0cbd18b7", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "46fb4852e47645628647bfd1bdcf4e610e72e55b", "parents": ["ded211603671be4210c80f5c2f17c0a4a5f9ceb7"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nbe -\u003e 704def8bade6\ncs -\u003e 9f205cf072d4\nel -\u003e 3e5a35e0e4b9\nen-CA -\u003e c2ebd08b1fcd\nfi -\u003e 90d3b876475f\nfr -\u003e 8f9886d2f3aa\ngd -\u003e c3f191828834\nit -\u003e 127ba469b341\nja -\u003e 5fa0b61ea89c\nja-JP-mac -\u003e 33fbb2dbe6ef\nka -\u003e 7d9315320c61\nko -\u003e b39c0d5d02fc\npt-BR -\u003e 1048ac517ad9\nsq -\u003e caf5f4d02a0e\nte -\u003e 8ff422a6ded9\ntr -\u003e 650b105cd711\nvi -\u003e 3146ea93f45b", "files": ["browser/locales/l10n-changesets.json"], "git_n