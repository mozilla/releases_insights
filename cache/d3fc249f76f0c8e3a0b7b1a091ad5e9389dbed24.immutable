de": null, "git_parents": [null], "node": "b8c1398f5a9074d3741997199d3eb2fa568c5469", "parents": ["0a8500467d6df2d175fd64025e998d5a88a39696"], "tags": []}, {"author": "Kriti Singh \u003ckritisingh1.ks@gmail.com\u003e", "branch": "default", "desc": "Bug 1529273 - replaces the current implementation of Profile::new with dedicated Profile::new and Profile::new_from_path. r=ato\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23310", "files": ["testing/geckodriver/src/capabilities.rs", "testing/geckodriver/src/marionette.rs", "testing/mozbase/rust/mozprofile/src/profile.rs"], "git_node": null, "git_parents": [null], "node": "9f0635581b5c3450ad7521c9d1df0538da6e2469", "parents": ["b8c1398f5a9074d3741997199d3eb2fa568c5469"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1534914 - Improve blocked cursor behavior to fall back to next image. r=smaug\n\nRight now we just block the image returned from nsIFrame::GetCursor, which is\nthe first loading cursor image.\n\nI think we should do the same we do when the image fails to load, which is to\nfall back to the next image instead.\n\nThis patch moves all the custom cursor code selection logic to\nEventStateManager, and lets the frame return a CursorKind and whether custom\nimages are allowed.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23289", "files": ["dom/events/EventStateManager.cpp", "layout/forms/nsImageControlFrame.cpp", "layout/generic/nsFrame.cpp", "layout/generic/nsFrame.h", "layout/generic/nsFrameSetFrame.cpp", "layout/generic/nsFrameSetFrame.h", "layout/generic/nsIFrame.h", "layout/generic/nsImageFrame.cpp", "layout/generic/nsImageFrame.h", "layout/generic/nsPluginFrame.cpp", "layout/generic/nsPluginFrame.h", "layout/generic/nsTextFrame.cpp", "layout/generic/nsTextFrame.h", "layout/xul/nsSplitterFrame.cpp", "layout/xul/nsSplitterFrame.h", "layout/xul/tree/nsTreeBodyFrame.cpp", "layout/xul/tree/nsTreeBodyFrame.h"], "git_node": null, "git_parents": [null], "node": "a4d1dd58552d02854ce438e11dc4c97ec885f166", "parents": ["9f0635581b5c3450ad7521c9d1df0538da6e2469"], "tags": []}, {"author": "Glenn Watson \u003cgithub@intuitionlibrary.com\u003e", "branch": "default", "desc": "Bug 1534885 - Change clip mask rendering to not rely on render task data. r=kvark\n\nAs a general principle, we're trying to remove most usage of the\nrender task data that gets stored in a texture (bind_frame_data\nis slow on many platforms, and it's somewhat inflexible with the\namount of data that can be provided).\n\nThis also lays some foundations for possibly drawing clip masks\nwith alternative techniques on mobile / tiled GPU architectures,\nwhere we may not need / want a render task for clip masks.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23271", "files": ["gfx/wr/webrender/res/clip_shared.glsl", "gfx/wr/webrender/res/cs_clip_box_shadow.glsl", "gfx/wr/webrender/res/cs_clip_image.glsl", "gfx/wr/webrender/res/cs_clip_rectangle.glsl", "gfx/wr/webrender/src/batch.rs", "gfx/wr/webrender/src/gpu_types.rs", "gfx/wr/webrender/src/render_task.rs", "gfx/wr/webrender/src/renderer.rs", "gfx/wr/webrender/src/tiling.rs"], "git_node": null, "git_parents": [null], "node": "360f4359ab669cd5d4fcc7b641c0a6dd8fb65341", "parents": ["a4d1dd58552d02854ce438e11dc4c97ec885f166"], "tags": []}, {"author": "Chun-Min Chang \u003cchun.m.chang@gmail.com\u003e", "branch": "default", "desc": "Bug 1535044 - Introduce mozilla namespace in TestGroupId.cpp. r=pehrsons\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23338", "files": ["dom/media/gtest/TestGroupId.cpp"], "git_node": null, "git_parents": [null], "node": "f04779216e2b928707a1c848ccd135a7b9def3c2", "parents": ["360f4359ab669cd5d4fcc7b641c0a6dd8fb65341"], "tags": []}, {"author": "Logan Smyth \u003cloganfsmyth@gmail.com\u003e", "branch": "default", "desc": "Bug 1534085 - Avoid accidentally creating partial source objects. r=bhackett\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23242", "files": ["devtools/client/debugger/new/src/actions/sources/tests/loadSource.spec.js", "devtools/client/debugger/new/src/reducers/sources.js", "devtools/client/debugger/new/src/utils/test-head.js"], "git_node": null, "git_parents": [null], "node": "48003b78de5a22362a6f869ddeb09741d2913576", "parents": ["f04779216e2b928707a1c848ccd135a7b9def3c2"], "tags": []}, {"author": "Mauricio Araujo \u003cmauricio.araujo@protonmail.com\u003e", "branch": "default", "desc": "Inconsistency between \"&\" (ampersand) vs \"and\" in Options (Bug 1530771) r=jaws,flod\n\nBug 1530771 - Replaced instances where \"&\" (ampersand) was used instead of \"and\" to join two words in the preferences menu, and added Oxford comma where appropriate in certain labels to ensure consistency. r?jaws, r?flod\n\nDifferential Revision: https://phabricator.services.mozilla.com/D21472", "files": ["browser/extensions/formautofill/locales/en-US/formautofill.properties", "browser/locales/en-US/browser/preferences/preferences.ftl", "toolkit/locales/en-US/chrome/global/intl.properties"], "git_node": null, "git_parents": [null], "node": "e7cd2f1e7f66665664eea0dde614a6ff6da35311", "parents": ["48003b78de5a22362a6f869ddeb09741d2913576"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1535057: Always re-fetch chromium in cron; r=aki\n\nWe have a cron job to update the chromium, but the tasks were getting optimized\naway. Force the target tasks for the cron job to always run.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23380", "files": [".cron.yml"], "git_node": null, "git_parents": [null], "node": "57387d4ed085fb614820aac402b758d88aa29452", "parents": ["e7cd2f1e7f66665664eea0dde614a6ff6da35311"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1534616 - Add a mochitest for hit-testing content unde