rey out when disabled r=Gijs a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D27065", "files": ["toolkit/content/widgets/checkbox.js"], "git_node": null, "git_parents": [null], "node": "550ae4e7da5df567c7974dc469c16ea66995745c", "parents": ["60105c2264a7f0b153c4dc206b1133b10901eea8"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1543617 - Disallow place: urls in text flavors. r=Standard8 a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D27048", "files": ["toolkit/components/places/PlacesUtils.jsm", "toolkit/components/places/tests/unit/test_PlacesUtils_unwrapNodes_place.js", "toolkit/components/places/tests/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "15baf86bf3179f5760fc7ee88ae5c12a74733197", "parents": ["550ae4e7da5df567c7974dc469c16ea66995745c"], "tags": []}, {"author": "Dana Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "bug 1524478 - don't create JS objects from WebAuthnManager or U2F destructors r=qdot a=pascalc\n\nBefore this patch, the WebAuthnManager/U2F destructors would call MaybeReject on\nexisting transaction promises. Doing this leaks JS objects. If\nWebAuthnManager/U2F are being destructed, though, the window is going away, so\nit shouldn't be necessary to reject any outstanding promises. This patch just\nclears the transactions.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D27346", "files": ["dom/u2f/U2F.cpp", "dom/webauthn/WebAuthnManager.cpp"], "git_node": null, "git_parents": [null], "node": "ef4d0e2f5ebc75f4023e1c2a7e2b7b82211e86dd", "parents": ["15baf86bf3179f5760fc7ee88ae5c12a74733197"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1544065 - fix clicking on \u003cspan\u003e tags inside voice selector in reader mode, r=eeejay a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D27510", "files": ["toolkit/components/narrate/VoiceSelect.jsm"], "git_node": null, "git_parents": [null], "node": "78d63ea6abba287bb83cd68d376d12c08bea4ad3", "parents": ["ef4d0e2f5ebc75f4023e1c2a7e2b7b82211e86dd"], "tags": []}], "date": 1555546640, "git_changesets": [null, null, null, null, null, null, null], "user": "btara@mozilla.com"}, "11106": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\ncs -\u003e 8d4e292bd472\nes-AR -\u003e 90936cf8a40c\nfr -\u003e 43c3fdd78641\ngn -\u003e 19994627ad54\nte -\u003e ac938ed11ba9", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "54e5eaa7cd9cb2f1be19dceee121f9e1832598c9", "parents": ["78d63ea6abba287bb83cd68d376d12c08bea4ad3"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\ncs -\u003e 8d4e292bd472\nes-AR -\u003e 90936cf8a40c\nfr -\u003e 43c3fdd78641\ngd -\u003e 8ff941efd9b2\ngn -\u003e 19994627ad54\nit -\u003e b78c5440fd4d\nkab -\u003e 1b33dff7b694\nkk -\u003e 7d295dfcb1c0\npa-IN -\u003e 608cae760c53\nte -\u003e 525622638ed3", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "f957ff7f5f217589fe09909b431fe88ebbe7c1b6", "parents": ["54e5eaa7cd9cb2f1be19dceee121f9e1832598c9"], "tags": []}], "date": 1555549233, "git_changesets": [null, null], "user": "ffxbld"}, "11107": {"changesets": [{"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1535301 - de-ICF RunnableMethodImpl::Run on Windows for crash disambiguation; r=erahm a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com//D27546", "files": ["xpcom/threads/nsThreadUtils.h"], "git_node": null, "git_parents": [null], "node": "07ddc041094cd26e4970346d78583b887f83afea", "parents": ["f957ff7f5f217589fe09909b431fe88ebbe7c1b6"], "tags": []}, {"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1538619 - TransactionDatabaseOperationBase::SendFailureResult not called if the actor has been destroyed; r=asuth a=abillings\n\nDifferential Revision: https://phabricator.services.mozilla.com/D24744", "files": ["dom/indexedDB/ActorsParent.cpp"], "git_node": null, "git_parents": [null], "node": "7a0993f0f4fb8df971dfb8caa291c31f06707443", "parents": ["07ddc041094cd26e4970346d78583b887f83afea"], "tags": []}, {"author": "Bryce Van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1540136 - P1: Log more info in ChromiumCDMProxy dtor and Shutdown. r=cpearce a=lizzard\n\nAlso remove unneeded MOZ_COUNT_[CTOR|DTOR] macros. We already get similar\nfunctionality from NS_INLINE_DECL_THREADSAFE_REFCOUNTING.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26204", "files": ["dom/media/gmp/ChromiumCDMProxy.cpp"], "git_node": null, "git_parents": [null], "node": "40fb1ced2598f5f2372a29819baaab5c5aab8208", "parents": ["7a0993f0f4fb8df971dfb8caa291c31f06707443"], "tags": []}, {"author": "Bryce Van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1540136 - P2: CDMProxy stores main thread as nsISerialEventTarget, rather than nsIEventTarget. r=cpearce a=lizzard\n\nThis gives us greater flexibility in using the main thread member to run\npromises.\n\nThe site where we obtain the main thread returns a serial event target, so we're\nnot doing much more work here, we're just keeping the serial event target\ninterface, rather than converting to an event target interface.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26205", "files": ["dom/media/eme/CDMProxy.h", "dom/media/eme/MediaKeys.cpp", "dom/media/eme/MediaKeys.h", "dom/media/eme/mediadrm/MediaDrmCDMProxy.cpp", "dom/media/eme/mediadrm/MediaDrmCDMProxy.h", "dom/media/gmp/ChromiumCDMProxy.cpp", "dom/media/gmp/ChromiumCDMProxy.h"], "git_node": null, "git_parents": [null], "node": "48e7d2342ffa2f1bc57853dcd0c3a8e4ca838c42", "parents": ["40fb1ced2598f5f2372a29819baaab5c5aab8208"], "tags": []}, {"author": "Bryce Van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1540136 - P3: ChromiumCDMProxy runs CDM init thennable code on the main thread. r=cpearce a=lizzard\n\nThis code is calling other code that expects to be on the main thread, and\nhaving this on the main thread (now that the main thread is a serial event\ntarget) makes it easier to reason about this and other main thread code. I.e.\nthis cannot be running during other main thread code.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26206", "files": ["dom/media/gmp/ChromiumCDMProxy.cpp"], "git_node": null, "git_parents": [null], "node": "385fde9e64e20795ca20d6cb7db114b0c0bcc8fe", "parents": ["48e7d2342ffa2f1bc57853dcd0c3a8e4ca838c42"], "tags": []}, {"author": "Bryce Van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1540136 - P4: Remove ChromiumCDMParent mMainThread as it is unused. r=cpearce a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26207", "files": ["dom/media/gmp/ChromiumCDMParent.cpp", "dom/media/gmp/ChromiumCDMParent.h"], "git_node": null, "git_parents": [null], "node": "ecb3ee5969c19fe8c52cedb2bd0291edf11dc83c", "parents": ["385fde9e64e20795ca20d6cb7db114b0c0bcc8fe"], "tags": []}, {"author": "Bryce Van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1540136 - P5: Handle if ChromiumCDMProxy is shutdown in the middle of init. r=cpearce a=lizzard\n\n- Watch for if a proxy shuts down during init and if so, shutdown the CDM parent\n  that is being initialized.\n- Make ChromiumCDMParent only store a pointer to a ChromiumCDMProxy when it has\n  successfully initialized. This avoid the lopsided relationship where a if a\n  ChromiumCDMParent fails to initialize it may keep a pointer to a proxy, but\n  the proxy will never have a reference to that CDM parent.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26208", "files": ["dom/media/gmp/ChromiumCDMParent.cpp", "dom/media/gmp/ChromiumCDMProxy.cpp", "dom/media/gmp/ChromiumCDMProxy.h"], "git_node": null, "git_parents": [null], "node": "5710827ee9cf5011b6698590a7d31e922f636cf2", "parents": ["ecb3ee5969c19fe8c52cedb2bd0291edf11dc83c"], "tags": []}, {"author": "Glenn Watson \u003cgithub@intuitionlibrary.com\u003e", "branch": "default", "desc": "Bug 1513019 - Fix plane splitting with complex, axis-aligned transforms. r=emilio,kats a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D27462", "files": ["gfx/wr/webrender/src/picture.rs", "gfx/wr/wrench/reftests/transforms/big-axis-aligned-scale-ref.yaml", "gfx/wr/wrench/reftests/transforms/big-axis-aligned-scale.yaml", "gfx/wr/wrench/reftests/transforms/reftest.list"], "git_node": null, "git_parents": [null], "node": "89768dc13409426b5b0ff972b258a27e2454115a", "parents": ["5710827ee9cf5011b6698590a7d31e922f636cf2"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1539959 - Don't send WindowGlobalChild constructors when parent BrowsingContext has already been closed, r=farre a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D27365", "files": ["dom/ipc/WindowGlobalChild.cpp"], "git_node": null, "git_parents": [null], "node": "efb56840fba5d9bf8a5df33cfc5062faf0d91b60", "parents": ["89768dc13409426b5b0ff972b258a27e2454115a"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1539348 - Write old bitmap format for wallpaper support of Windows 7. r=jmathies a=pascalc\n\nThis is regression by bug 1502772. Windows 7 doesn't support bitmap v4 format\nfor wallpaper. So I revert to previous code to write wallpaper bitmap.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D27465", "files": ["browser/components/shell/nsWindowsShellService.cpp"], "git_node": null, "git_parents": [null], "node": "ca3353d353beef5ba2bdaf31619fe4650ec0c531", "parents": ["efb56840fba5d9bf8a5df33cfc5062faf0d91b60"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1534593 part 1.  Stop special-casing JS::Value initialization, since JS::Value now always initializes itself on construction.  r=qdot,waldo a=abillings", "files": ["dom/bindings/Codegen.py"], "git_node": null, "git_parents": [null], "node": "ef03afcf3cffaabbfd5a8e951315dbcbbd45a004", "parents": ["ca3353d353beef5ba2bdaf31619fe4650ec0c531"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1534593 part 2.  Factor out the \"determine the default initializer\" code from dictionary member init and reuse it for sequence member init.  r=qdot a=abillings\n\nThe other option would be to implement nsTArrayElementTraits for JSObject* and\nnull-initialize there.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D27561", "files": ["dom/bindings/Codegen.py"], "git_node": null, "git_parents": [null], "node": "499c3102dc05f7654036438d2da12fc0565e6ff5", "parents": ["ef03afcf3cffaabbfd5a8e951315dbcbbd45a004"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1534593 part 3.  Initialize JSObject* entries in Record types.  r=qdot a=abillings\n\nDifferential Revision: https://phabricator.services.mozilla.com/D27562", "files": ["dom/bindings/Record.h"], "git_node": null, "git_parents": [null], "node": "cf8b04d3bfcd51a9ad12a4aab9afb84b9dc74fbd", "parents": ["499c3102dc05f7654036438d2da12fc0565e6ff5"], "tags": []}, {"author": "Nicolas B. Pierron \u003cnicolas.b.pierron@nbp.name\u003e", "branch": "default", "desc": "Bug 1543159 - TypeHashSet should use a non-reserved bit for marking elements to be moved. r=jandem a=abillings\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26961", "files": ["js/src/vm/TypeInference-inl.h", "js/src/vm/TypeSet.h"], "git_node": null, "git_parents": [null], "node": "f764410a33268a980b26ee16cdf7c746c332f4e3", "parents": ["cf8b04d3bfcd51a9ad12a4aab9afb84b9dc74fbd"], "tags": []}], "date": 1555603009, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "11108": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP blocklist remote-settings - a=repo-update r=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D28056", "files": ["browser/app/blocklist.xml", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/blocklists/addons.json"], "git_node": null, "git_parents": [null], "node": "f120b37386cb4c3da157a23809bfb04dffe15248", "parents": ["f764410a33268a980b26ee16cdf7c746c332f4e3"], "tags": ["DEVEDITION_67_0b12_BUILD1", "DEVEDITION_67_0b12_RELEASE", "FIREFOX_67_0b12_BUILD1", "FIREFOX_67_0b12_RELEASE"]}], "date": 1555603535, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "11109": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging f120b37386cb4c3da157a23809bfb04dffe15248 with DEVEDITION_67_0b12_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "f86afb67b17177aaa6b6f72b18515fe7332d724e", "parents": ["f120b37386cb4c3da157a23809bfb04dffe15248"], "tags": []}], "date": 1555620902, "git_changesets": [null], "user": "ffxbld"}, "11110": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging f120b37386cb4c