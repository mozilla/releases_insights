t-src/components/ASRouterAdmin.test.jsx", "browser/components/newtab/test/unit/lib/TelemetryFeed.test.js", "browser/components/newtab/test/unit/lib/UTEventReporting.test.js", "browser/components/newtab/test/unit/unit-entry.js", "browser/components/newtab/yamscripts.yml", "browser/locales/en-US/browser/branding/brandings.ftl", "browser/locales/en-US/browser/newtab/onboarding.ftl", "toolkit/components/telemetry/Events.yaml"], "git_node": null, "git_parents": [null], "node": "9c4cd169d5d07b75453e6574e13bf4f912814fb0", "parents": ["306b6635505681131acd230eb8685d2c4c54311c"], "tags": ["DEVEDITION_67_0b19_BUILD1", "DEVEDITION_67_0b19_RELEASE", "FIREFOX_67_0b19_BUILD1", "FIREFOX_67_0b19_RELEASE"]}], "date": 1557427944, "git_changesets": [null, null], "user": "nbeleuzu@mozilla.com"}, "11257": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 9c4cd169d5d07b75453e6574e13bf4f912814fb0 with DEVEDITION_67_0b19_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "c181666e8bfa382f04a2550a0d2a35422a06bbc8", "parents": ["9c4cd169d5d07b75453e6574e13bf4f912814fb0"], "tags": []}], "date": 1557439196, "git_changesets": [null], "user": "ffxbld"}, "11258": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 9c4cd169d5d07b75453e6574e13bf4f912814fb0 with FIREFOX_67_0b19_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "20135b0f707d244b46ffabea91656d4824b668e0", "parents": ["c181666e8bfa382f04a2550a0d2a35422a06bbc8"], "tags": []}], "date": 1557439530, "git_changesets": [null], "user": "ffxbld"}, "11259": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 9c4cd169d5d07b75453e6574e13bf4f912814fb0 with DEVEDITION_67_0b19_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "e42a5fe9531a49241afa33dd064e3c141f06de00", "parents": ["20135b0f707d244b46ffabea91656d4824b668e0"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release DONTBUILD", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "a78aeb74437d2ab08a6b8419ba3ced4a894ffc3e", "parents": ["e42a5fe9531a49241afa33dd064e3c141f06de00"], "tags": []}], "date": 1557500796, "git_changesets": [null, null], "user": "ffxbld"}, "11260": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 9c4cd169d5d07b75453e6574e13bf4f912814fb0 with FIREFOX_67_0b19_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "1f9a5b1354ea840190d60e025c7967d862df0d03", "parents": ["a78aeb74437d2ab08a6b8419ba3ced4a894ffc3e"], "tags": []}], "date": 1557500979, "git_changesets": [null], "user": "ffxbld"}, "11261": {"changesets": [{"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1450012: [taskgraph] Move rerun action to retrigger.py; r=dustin\n\nIn order to prevent retriggers for release tasks, we will cause the `retrigger`\naction to rerun instead, so move the cdoe togehter.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D27205", "files": ["taskcluster/taskgraph/actions/rerun.py", "taskcluster/taskgraph/actions/retrigger.py"], "git_node": null, "git_parents": [null], "node": "3f746debc521a85763df5b1ab043f7849153a00a", "parents": ["1f9a5b1354ea840190d60e025c7967d862df0d03"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1450012: [taskgraph] Disable retrigger action for many tasks; r=dustin\n\nMany tasks (release tasks and cached tasks, in particular) should be re-run rather\nthan retriggered. Disable retrigger action for those tasks by default.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D27206", "files": ["taskcluster/ci/hazard/kind.yml", "taskcluster/ci/mar-signing-autograph-stage/kind.yml", "taskcluster/ci/source-test/kind.yml", "taskcluster/ci/spidermonkey/kind.yml", "taskcluster/ci/static-analysis-autotest/kind.yml", "taskcluster/ci/test/kind.yml", "taskcluster/ci/valgrind/kind.yml", "taskcluster/ci/webrender/kind.yml", "taskcluster/docs/attributes.rst", "taskcluster/taskgraph/actions/registry.py", "taskcluster/taskgraph/actions/retrigger.py", "taskcluster/taskgraph/transforms/task.py"], "git_node": null, "git_parents": [null], "node": "8667f041f6c2f7adffabe2d0e65ef0dfd39c3944", "parents": ["3f746debc521a85763df5b1ab043f7849153a00a"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1450012: [taskgraph] Add an action to retirgger multiple tasks at once; r=dustin\n\nIn Bug 1519599, treeherder switched to using add-new-jobs to retrigger jobs, since\nthere wasn't an action to retrigger multiple jobs. This prevents us from adding logic\nto rerun some jobs instead of retriggering them.\n\nThis adds a new action that takes input like `add-new-jobs`, but that we can add logic\nto handle rerun vs. retrigger in. Additionally, the input it takes is designed\nto make Bug 1521032 easier to implement.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D27207", "files": ["taskcluster/taskgraph/actions/retrigger.py"], "git_node": null, "git_parents": [null], "node": "bb082e4ef0d4431d8f4edebd436d2063835c5873", "parents": ["8667f041f6c2f7adffabe2d0e65ef0dfd39c3944"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1450012:  [taskgraph] Make `retrigger-multiple` action selectively re-run tasks; r=dustin a=tomprince\n\nMany tasks (release tasks and cached tasks, in particular) should be re-run rather\nthan retriggered. Instead, make the `retrigger-multiple` action re-run them instead.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D27208", "files": ["taskcluster/taskgraph/actions/retrigger.py"], "git_node": null, "git_parents": [null], "node": "4649dbd1d133e1900e3232724aec002ce3dd2655", "parents": ["bb082e4ef0d4431d8f4edebd436d2063835c5873"], "tags": []}], "date": 1557524125, "git_changesets": [null, null, null, null], "user": "mozilla@hocat.ca"}, "11262": {"changesets": [{"author": "Jeff Muizelaar \u003cjmuizelaar@mozilla.com\u003e", "branch": "default", "desc": "Bug 1539846. Ensure building rect changes cause invalidations. r=mstange a=pascalc\n\nTypically this would be handled by the visible region of the layer\nchanging. However, since we build the container layer for the filter\nitem directly the visible region doesn't get set or checked. As a\nshortcut to using more of FLB we just ensure the building rect hasn't\nchanged.\n\nThe situations under which this bugs shows up are somewhat rare:\n- The filtered item needs to be in transform so that it's bounds\n  are not changed by scrolling.\n- The filtered item needs to contain items that change their drawing\n  depending on the building rect. In this case an image with downscale\n  on decode.\n- The filter needs to be unsupported by WebRender.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D29879", "files": ["gfx/layers/wr/WebRenderCommandBuilder.cpp", "gfx/layers/wr/WebRenderUserData.h", "layout/reftests/invalidation/jetstream-scroll-ref.html", "layout/reftests/invalidation/jetstream-scroll.html", "layout/reftests/invalidation/reftest.list"], "git_node": null, "git_parents": [null], "node": "f293cecba8fd77bcf3395b6e66449f48851b66fa", "parents": ["4649dbd1d133e1900e3232724aec002ce3dd2655"], "tags": []}, {"author": "Andrew Sutherland \u003casutherland@asutherland.org\u003e", "branch": "default", "desc": "Bug 1535699 - Disable httpResponseProcessSelection on Fx67 for now. r=nika a=pascalc\n\nReviewers: nika\n\nBug #: 1535699\n\nDifferential Revision: https://phabricator.services.mozilla.com/D30685", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "d7e6f0c8a9db25034d5c2766b04be20e47cf4fe1", "parents": ["f293cecba8fd77bcf3395b6e66449f48851b66fa"], "tags": []}], "date": 1557627152, "git_changesets": [null, null], "user": "aiakab@mozilla.com"}, "11263": {"changesets": [{"author": "arthur.iakab \u003caiakab@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset d7e6f0c8a9db (bug 1535699) for failing browser chrome tests on browser_navigation_process_swap.js a=backout", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "133cd6f341f7da663c939c09f26192cd14b8b617", "parents": ["d7e6f0c8a9db25034d5c2766b04be20e47cf4fe1"], "tags": ["FIREFOX_RELEASE_67_BASE"]}], "date": 1557632350, "git_changesets": [null], "user": "aiakab@mozilla.com"}, "11264": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging mozilla-beta 133cd6f341f7da663c939c09f26192cd14b8b617 with FIREFOX_RELEASE_67_BASE a=release DONTBUILD CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "55d4837d25c59b7706dc1f54a44d9e3760746c32", "parents": ["133cd6f341f7da663c939c09f26192cd14b8b617"], "tags": ["FIREFOX_BETA_67_END"]}], "date": 1557739380, "git_changesets": [null], "user": "ffxbld-merge"}}
}";