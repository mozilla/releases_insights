tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1526928 - Don't trigger the testDriver continuation on a mousemove we didn't synthesize. r=botond a=test-only\n\nWe seem to get a spurious mousemove event generated after the mousedown\nfrom somewhere in Gecko. This causes us to trigger the testDriver\ncontinuation an extra time right at the start of the drag, which causes\nthe test to end before it's supposed to. This patch makes it so we drop\nthe spurious mousemove.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26829\n", "files": ["gfx/layers/apz/test/mochitest/helper_drag_scroll.html"], "git_node": null, "git_parents": [null], "node": "8902e572afdbc2a9195ed7dc983e49afd805d631", "parents": ["8be50dfd720e1a51223d3d80e5302a74c06de9db"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1526928 - Check for TabParent destruction before trying to send a message on it. r=botond a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26830\n", "files": ["dom/ipc/TabParent.cpp"], "git_node": null, "git_parents": [null], "node": "2eab15e5f47346689253571aa69966ab25bdc749", "parents": ["8902e572afdbc2a9195ed7dc983e49afd805d631"], "tags": []}], "date": 1554986821, "git_changesets": [null, null, null], "user": "kgupta@mozilla.com"}, "11069": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP blocklist remote-settings - a=repo-update r=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D27058", "files": ["browser/app/blocklist.xml", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/blocklists/addons.json", "services/settings/dumps/blocklists/plugins.json"], "git_node": null, "git_parents": [null], "node": "9edc7979cb5cbf02c84802e12985d4eb7722e556", "