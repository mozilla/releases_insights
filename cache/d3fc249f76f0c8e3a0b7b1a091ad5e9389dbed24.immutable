se\n\nShip-it v1 is going away soon and we won't need to create new releases in Ship-it v1 in parallel with Ship-it v2. It's time to prep patches to remove this functionality.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26044", "files": ["taskcluster/ci/release-mark-as-started/kind.yml", "taskcluster/docs/kinds.rst", "taskcluster/taskgraph/transforms/release_mark_as_started.py", "taskcluster/taskgraph/transforms/task.py", "taskcluster/taskgraph/util/scriptworker.py"], "git_node": null, "git_parents": [null], "node": "2a4306fc8442ba8c07f79b6c168bf0adee4d1341", "parents": ["9bae80c354eb3f200dc5e0e4cf0a01facb18d522"], "tags": []}], "date": 1554774473, "git_changesets": [null], "user": "raliiev@mozilla.com"}, "11045": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nda -\u003e e7137daf908d\nel -\u003e 7e8e2cefcc19\nes-AR -\u003e 9debeec19d50\nnl -\u003e 3d6a6459431c\npt-BR -\u003e bc1d4a10e47a\ntrs -\u003e f76a6ab94c76", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "1ce559b549fc2a07f2dfe80cd793b0cbf4851c73", "parents": ["2a4306fc8442ba8c07f79b6c168bf0adee4d1341"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nda -\u003e e7137daf908d\nel -\u003e 7e8e2cefcc19\nes-AR -\u003e 9debeec19d50\nhsb -\u003e f4d5ee31042b\nia -\u003e a5eb00cf93a3\nnl -\u003e 3d6a6459431c\npl -\u003e 3db6edd571be\npt-BR -\u003e bc1d4a10e47a", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "6f217dc63838d8d79904f285959c126423ff387f", "parents": ["1ce559b549fc2a07f2dfe80cd793b0cbf4851c73"], "tags": []}], "date": 1554793228, "git_changesets": [null, null], "user": "ffxbld"}, "11046": {"changesets": [{"author": "Brian Grinstead \u003cbgrinstead@mozilla.com\u003e", "branch": "default", "desc": "Bug 1540123 - Append menuitems into the menupopup for the certificate nickname menulist in certificate selection dialog UI. r=keeler a=pascalc\n\nReviewers: keeler\n\nReviewed By: keeler\n\nBug #: 1540123\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25825", "files": ["security/manager/pki/resources/content/choosetoken.js", "security/manager/pki/resources/content/clientauthask.js", "security/manager/ssl/tests/mochitest/browser/browser_clientAuth_ui.js"], "git_node": null, "git_parents": [null], "node": "6a2328c57b79a2353103d23138181066f3835d02", "parents": ["6f217dc63838d8d79904f285959c126423ff387f"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1539647: Make the \"Show more bookmarks\" button navigable with the keyboard. r=Gijs a=pascalc\n\nWhen the Bookmarks toolbar overflows, it contains buttons with style visibility: hidden.\nToolbarKeyboardNavigator wasn't checking for this and was trying to focus these buttons, which simply failed.\nWe now skip over these buttons, which means that the Show more bookmarks button can now be reached.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25180", "files": ["browser/base/content/browser-toolbarKeyNav.js", "browser/base/content/test/keyboard/browser_toolbarKeyNav.js"], "git_node": null, "git_parents": [null], "node": "c6091e97fad76956b6bc1576fd28e3083ce3ad3a", "parents": ["6a2328c57b79a2353103d23138181066f3835d02"], "tags": []}, {"author": "Honza Bambas \u003chonzab.moz@firemni.cz\u003e", "branch": "default", "desc": "Bug 1538737 - Don't isolate proxy auth credential cache by origin attributes on all places, r=valentin a=pascalc", "files": ["netwerk/protocol/http/nsHttpChannelAuthProvider.cpp"], "git_node": null, "git_parents": [null], "node": "25c22c51d9ce216261bc35842ef6704b5b678536", "parents": ["c6091e97fad76956b6bc1576fd28e3083ce3ad3a"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Bug 1538583: Themes should not show [ALLOWED IN PRIVATE WINDOWS] notice. r=kmag a=pascalc\n\nSummary: Themes should not show [ALLOWED IN PRIVATE WINDOWS] notice\n\nReviewers: kmag\n\nReviewed By: kmag\n\nSubscribers: mstriemer, mixedpuppy\n\nBug #: 1538583\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25411", "files": ["toolkit/mozapps/extensions/content/extensions.xml", "toolkit/mozapps/extensions/test/browser/browser_theme_previews.js"], "git_node": null, "git_parents": [null], "node": "44282db3178b0ca701b3d4c27dcc08b15fd37fc2", "parents": ["25c22c51d9ce216261bc35842ef6704b5b678536"], "tags": []}, {"author": "Gian-Carlo Pascutto \u003cgcp@mozilla.com\u003e", "branch": "default", "desc": "Bug 1535794 - Allow getrandom() in all sandbox policies. r=jld a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25610", "files": ["security/sandbox/linux/SandboxFilter.cpp"], "git_node": null, "git_parents": [null], "node": "0dfc99259470484235be9779a886ed8e7d95b22f", "parents": ["44282db3178b0ca701b3d4c27dcc08b15fd37fc2"], "tags": []}, {"author": "Dave Townsend \u003cdtownsend@oxymoronical.com\u003e", "branch": "default", "desc": "Bug 1541804: Make profile refresh for non-ascii named profiles work correctly. r=Gijs a=pascalc\n\nSummary:\nThis fixes two bugs. The first is that when the firefox profile migrator doesn't\nknow which profile to migrate it attempts to fall back to another profile. I\nthink this was intended to be the default but in bug 1322797 I ended up making\nit the current profile, which is the profile we're restoring into now. I think\nat this stage the profile directory doesn't even exist so things go wrong.\nChanging to use the actual default works but....\n\nWhen the profile migrator UI doesn't know what profile to migrate from it uses\nthe default profile. So if the profile you're actually trying to restore is not\nthe default we'll effectively throw its data into the archive and replace it\nwith data from the default profile. I'm inclined to say that if the migrator\ndoes not know what profile to migrate from it should error at that point for\nsafety.\n\nWhy would the profile migrator not know what profile to migrate from? Because of\na long-standing text encoding problem. In C++ profile names are encoded in UTF8.\nBut we try to pass them to JS through an IDL parameter of type ACString. This\ndoes no UTF8 decoding and so JS recieves an incorrect name if the name includes\nnon-ascii characters and so can't find the profile.\n\nThis patch fixes the IDL parameter to AUTF8String which does the decoding\ncorrectly and so JS gets the name correctly.\n\nWe should probably think about whether just passing the nsIToolkitProfile object\nto the migrator is a better choice here.\n\nReviewers: Gijs\n\nReviewed By: Gijs\n\nSubscribers: MattN\n\nBug #: 1541804\n\nDifferential Revision: https://phabricator.services.mozilla.com/D26250", "files": ["browser/components/migration/FirefoxProfileMigrator.jsm", "toolkit/profile/nsIProfileMigrator.idl"], "git_node": null, "git_parents": [null], "node": "19e1fc9a203cb2f4c4b9b1ae5a5dfac2bafeb2f2", "parents": ["0dfc99259470484235be9779a886ed8e7d95b22f"], "tags": []}], "date": 1554802248, "git_changesets": [null, null, null, null, null, null], "user": "csabou@mozilla.com"}, "11047": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nhu -\u003e 1942d66f7c6b\nnl -\u003e 42809506942f", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "ee9092819df0f8f67de4e97abfc0d1b216790ec7", "parents": ["19e1fc9a203cb2f4c4b9b1ae5a5dfac2bafeb2f2"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nhu -\u003e 1942d66f7c6b\nit -\u003e 216590926611\nlij -\u003e f44e4fe37f9b\nnl -\u003e 42809506942f\nuk -\u003e ff5d2d06b709", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "25fc50452484b96a4a664c779a4222874f3b21de", "parents": ["ee9092819df0f8f67de4e97abfc0d1b216790ec7"], "tags": []}], "date": 1554811227, "git_changesets": [null, null], "user": "ffxbld"}, "11048": {"changesets": [{"author": "Junior Hsu \u003cjuhsu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1539766 - handle the cancel case for e10s bp r=kershaw a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D25315", "files": ["netwerk/protocol/http/HttpChannelParent.cpp"], "git_node": null, "git_parents": [null], "node": "8f769d5d958c1681bb88ccd8f080a5d617cd9f95", "parents": ["25fc50452484b96a4a664c779a4222874f3b21de"], "tags": []}, {"author": "Dale Harvey \u003cdale@arandomurl.com\u003e", "branch": "default", "desc": "Bug 1534219 - Only clear globally blocked permission on navigation. r=johannh a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23844", "files": ["browser/base/content/test/permissions/browser.ini", "browser/base/content/test/permissions/browser_autoplay_blocked.js", "browser/base/content/test/permissions/browser_autoplay_blocked_slow.sjs", "browser/modules/SitePermissions.jsm"], "git_node": null, "git_parents": [null], "node": "4ec045b28ecc6fb214c80bf8451eced3fc002781", "parents": ["8f769d5d958c1681bb88ccd8f080a5d617cd9f95"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1534340 - Fix a nullptr check in CookieServiceChild::RequireThirdPartyCheck, r=dragana a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23873", "files": ["netwerk/cookie/CookieServiceChild.cpp", "netwerk/cookie/test/mochitest/mochitest.ini