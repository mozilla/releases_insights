oolkit/components/normandy/test/unit/test_NormandyApi.js"], "git_node": null, "git_parents": [null], "node": "ee1ceae6688873b2750e84fa189d030612516e0d", "parents": ["fddb40ccfe5accf8d5039924eacd6abcc49b46cd"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 29b1d70e8032 (bug 1534430) for build bustage. CLOSED TREE", "files": ["js/public/TraceKind.h", "js/src/jit/RematerializedFrame.h", "js/src/jsapi-tests/testGCGrayMarking.cpp", "js/src/jsapi-tests/testGCHeapPostBarriers.cpp", "js/src/vm/Scope.h"], "git_node": null, "git_parents": [null], "node": "0a3a2f8340e311ade4d7776b85ba8214eae74eb1", "parents": ["ee1ceae6688873b2750e84fa189d030612516e0d"], "tags": []}, {"author": "Dzmitry Malyshau \u003cdmalyshau@mozilla.com\u003e", "branch": "default", "desc": "Bug 1532174 - Enable env_logger by default in Wrench r=gw\n\nEnv logger is useful for:\n  1. seeing error! generated by the code (by default). Sometimes it can give us hints on what is wrong with the capture, or a test right away.\n  2. seeing processed shader compile/link errors, which is very useful when changing them\n\nGiven that wrench is the main debugging tool at the moment, enabling the logging output by default should increase our productivity, at the cost of slightly longer build times.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D23000", "files": ["gfx/wr/Cargo.lock", "gfx/wr/wrench/Cargo.toml"], "git_node": null, "git_parents": [null], "node": "662d2392cb0167ea31aa1d078551204f45fe3c5c", "parents": ["0a3a2f8340e311ade4d7776b85ba8214eae74eb1"], "tags": []}, {"author": "Dzmitry Malyshau \u003cdmalyshau@mozilla.com\u003e", "branch": "default", "desc": "Bug 1532174 - Strongly typed vertex data stores in WR r=gw\n\nEstablishes a clear link of TransformData with the shader.\nAssociates a vertex data type permanently, which makes the code cleaner and allow finding the relevant bits quickly with search.\n\nDifferential Revi