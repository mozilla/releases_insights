it_parents": [null], "node": "b9a5aab21d71b786f5196b1c1cbf59890a0c41fc", "parents": ["bc5ab6e2db1039394ef16edc4333e08e8965da56"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1408062 - Show hidden tabs that are playing audio r=dao\n\nMozReview-Commit-ID: FHV3bmXbX9d", "files": ["browser/base/content/browser.xul", "browser/base/content/tabbrowser.js", "browser/base/content/tabbrowser.xml", "browser/base/content/test/general/browser_audioTabIcon.js", "browser/themes/shared/jar.inc.mn", "browser/themes/shared/tabbrowser/badge-audio-playing.svg", "browser/themes/shared/tabs.inc.css"], "git_node": null, "git_parents": [null], "node": "356d8af4a2b9248e445d68019ef91316f3363a3d", "parents": ["b9a5aab21d71b786f5196b1c1cbf59890a0c41fc"], "tags": []}, {"author": "Jan Odvarko \u003codvarko@gmail.com\u003e", "branch": "default", "desc": "Bug 1403530 - HAR export toolbar button; r=davidwalsh\n\nMozReview-Commit-ID: 6rZlTAUSXnL", "files": ["devtools/client/jar.mn", "devtools/client/locales/en-US/netmonitor.properties", "devtools/client/netmonitor/src/assets/icons/drop-down.svg", "devtools/client/netmonitor/src/assets/styles/Toolbar.css", "devtools/client/netmonitor/src/assets/styles/variables.css", "devtools/client/netmonitor/src/components/Toolbar.js", "devtools/client/netmonitor/src/har/har-menu-utils.js", "devtools/client/netmonitor/src/har/moz.build", "devtools/client/netmonitor/src/har/test/browser_net_har_copy_all_as_har.js", "devtools/client/netmonitor/src/har/test/browser_net_har_import.js", "devtools/client/netmonitor/src/har/test/browser_net_har_post_data.js", "devtools/client/netmonitor/src/har/test/browser_net_har_post_data_on_get.js", "devtools/client/netmonitor/src/har/test/browser_net_har_throttle_upload.js", "devtools/client/netmonitor/src/utils/menu.js", "devtools/client/netmonitor/src/widgets/RequestListContextMenu.js", "devtools/client/netmonitor/src/widgets/RequestListHeaderContextMenu.js"], "git_node": null, "git_parents": [null], "node": "d8bb9fa651c6484a07d441109553d80403493aef", "parents": ["356d8af4a2b9248e445d68019ef91316f3363a3d"], "tags": []}, {"author": "Daniel Stenberg \u003cdaniel@haxx.se\u003e", "branch": "default", "desc": "bug 1457005 - TRR: reset confirmation state machine on prefs update r=mcmanus\n\nIf the confirmation state machine has gone into FAILED mode, updated\nprefs is reason enough to try again and possibly get TRR verified\nproper.\n\nMozReview-Commit-ID: ALRbNJdvxdn", "files": ["netwerk/dns/TRRService.cpp"], "git_node": null, "git_parents": [null], "node": "1936e3c9b600639a9e5ce6e5df93f64607d2ddaf", "parents": ["d8bb9fa651c6484a07d441109553d80403493aef"], "tags": []}, {"author": "Timothy Guan-tin Chien \u003ctimdream@gmail.com\u003e", "branch": "default", "desc": "Bug 1450017 - Part I, Package resizer-rtl.png correctly on Linux r=enndeakin+6102\n\nIt was never included in the manifest from file creation in bug 554810.\n\nThe error went undetected for 8 years, because the Linux manifest overwrites\nthe Windows one, and the Windows file goes to the same name (with a similar\nlook) gets packaged.\n\nMozReview-Commit-ID: HXFxD0KmSYA", "files": ["toolkit/themes/linux/global/jar.mn", "toolkit/themes/shared/non-mac.jar.inc.mn", "toolkit/themes/windows/global/jar.mn"], "git_node": null, "git_parents": [null], "node": "dd262c337f19cc60d458d24760637c9fe2d34a2e", "parents": ["1936e3c9b600639a9e5ce6e5df93f64607d2ddaf"], "tags": []}, {"author": "Timothy Guan-tin Chien \u003ctimdream@gmail.com\u003e", "branch": "default", "desc": "Bug 1450017 - Part II, Reftest for non-native-theme resizer r=enndeakin+6102\n\nThis set of tests, copied from native-theme resizer reftests, ensure\nthe style of non-native-theme resizer.\n\nMozReview-Commit-ID: 52miLT8h7Xe", "files": ["layout/reftests/xul/blank-window.xul", "layout/reftests/xul/reftest.list", "layout/reftests/xul/resizer-bottomend-flipped.xul", "layout/reftests/xul/resizer-bottomend-rtl.xul", "layout/reftests/xul/resizer-bottomend.xul", "layout/reftests/xul/resizer-bottomleft.xul", "layout/reftests/xul/resizer-bottomright.xul", "layout/reftests/xul/resizer-bottomstart-rtl.xul", "layout/reftests/xul/resizer-bottomstart.xul", "layout/reftests/xul/resizer-left.xul"], "git_node": null, "git_parents": [null], "node": "2d1c525b54047b1408cae2453375a1a2e315def7", "parents": ["dd262c337f19cc60d458d24760637c9fe2d34a2e"], "tags": []}, {"author": "Timothy Guan-tin Chien \u003ctimdream@gmail.com\u003e", "branch": "default", "desc": "Bug 1450017 - Part III, Replace direction: rtl with localedir=\"rtl\" in resizer reftests r=enndeakin+6102\n\nThis change would bring the tests closer to the real world scenario\n\nMozReview-Commit-ID: 9fslEo8w8Zi", "files": ["layout/reftests/native-theme/resizer-bottomend-rtl.xul", "layout/reftests/native-theme/resizer-bottomstart-rtl.xul", "layout/reftests/xul/resizer-bottomend-rtl.xul", "layout/reftests/xul/resizer-bottomstart-rtl.xul"], "git_node": null, "git_parents": [null], "node": "4ffb62df7a592d892b528ab91d98e85b2a3d8a90", "parents": ["2d1c525b54047b1408cae2453375a1a2e315def7"], "tags": []}, {"author": "Timothy Guan-tin Chien \u003ctimdream@gmail.com\u003e", "branch": "default", "desc": "Bug 1450017 - Part IV, Always set resizer direction explicitly in ScrollFrameHelper::CreateAnonymousContent() r=enndeakin+6102\n\nGiven that we have access to the RTL/writing modes information via\nScrollFrameHelper::IsPhysicalLTR(), set the dir to bottomleft/bottomright\ninstead of context-aware value bottomend.\n\nMozReview-Commit-ID: Lfe053WOsY2", "files": ["layout/generic/nsGfxScrollFrame.cpp"], "git_node": null, "git_parents": [null], "node": "407774fc7c7a3455134bfa3cad5a8c3a6ebe21ac", "parents": ["4ffb62df7a592d892b528ab91d98e85b2a3d8a90"], "tags": []}, {"author": "Timothy Guan-tin Chien \u003ctimdream@gmail.com\u003e", "branch": "default", "desc": "Bug 1450017 - Part V, Remove rtl=\"true\" attribute from resizer r=enndeakin+6102\n\nThis patch changes the direction context the dir=bottomend/bottomstart value\nfrom the CSS direction property value to locale dir, with the help\nfrom :-moz-locale-dir(rtl) selector.\n\nThe change is justified because:\n\n- In the web content, we have since rely on the nsScrollFrame to set the\n  direction explicity.\n- XUL window should always render in the application locale; it should be\n  fine to disregard direction property set in the local document DOM teee,\n  as it is unlikely to be differ than the locale dir.\n\nThis remove the one last bit of JavaScript from the resizer binding.\n\nMozReview-Commit-ID: AweJ5GARNUE", "files": ["layout/xul/test/window_resizer.xul", "toolkit/content/widgets/resizer.xml", "toolkit/themes/osx/global/resizer.css", "toolkit/themes/windows/global/resizer.css"], "git_node": null, "git_parents": [null], "node": "eabdcd541092ef9974ae8ec4fa5802704f4b8722", "parents": ["407774fc7c7a3455134bfa3cad5a8c3a6ebe21ac"], "tags": []}, {"author": "Timothy Guan-tin Chien \u003ctimdream@gmail.com\u003e", "branch": "default", "desc": "Bug 1450017 - Part VI, Remove the resizer binding r=enndeakin+6102\n\nWe unfortunately cannot move the reference of resizer.css to components.css,\nbecause the style is needed in web content.\n\nMozReview-Commit-ID: 80P3hTtQD14", "files": ["toolkit/content/jar.mn", "toolkit/content/minimal-xul.css", "toolkit/content/widgets/resizer.xml"], "git_node": null, "git_parents": [null], "node": "d50230b89a1e8b365d98d51d1f2cefccb124ee42", "parents": ["eabdcd541092ef9974ae8ec4fa5802704f4b8722"], "tags": []}, {"author": "Timothy Guan-tin Chien \u003ctimdream@gmail.com\u003e", "branch": "default", "desc": "Bug 1450017 - Part VII, Remove unused CSS rules in macOS resizer.css r=enndeakin+6102\n\n- There is no longer any resizer[type=\"window] in the tree (was added in\n  bug 556645)\n- min-width/height was added to ensure the minimum dimensions, but\n  intrinsic size of native and non-native resizer widget are already\n  bigger than the size set (and there is no way to overwrite it).\n  See bug 636564 comment 71.\n\nMozReview-Commit-ID: A8uYkwoJiVy", "files": ["toolkit/themes/osx/global/resizer.css"], "git_node": null, "git_parents": [null], "node": "30abf100e11761be2162e1b0a7b42993d9d3b5ae", "parents": ["d50230b89a1e8b365d98d51d1f2cefccb124ee42"], "tags": []}, {"author": "Timothy Guan-tin Chien \u003ctimdream@gmail.com\u003e", "branch": "default", "desc": "Bug 1450017 - Part VIII, Exclude chrome UA style images from use counters r=heycam\n\nGiven that resizer.svg will be loaded in non-chrome documents, we will\nneed to exclude it from the use counter.\n\nMozReview-Commit-ID: 4ZzidKJUfBW", "files": ["dom/base/nsDocument.cpp"], "git_node": null, "git_parents": [null], "node": "7d7480f8fd9e4b89be3d409ef13da4633b840714", "parents": ["30abf100e11761be2162e1b0a7b42993d9d3b5ae"], "tags": []}, {"author": "Timothy Guan-tin Chien \u003ctimdream@gmail.com\u003e", "branch": "default", "desc": "Bug 1450017 - Part IX, Move resizer style rules to minimal-xul.css and unify non-native resizer style r=dao\n\nMozReview-Commit-ID: LEodr0aTPkM", "files": ["browser/base/content/test/performance/browser_startup_images.js", "browser/installer/allowed-dupes.mn", "docshell/test/chrome/test_bug909218.html", "layout/reftests/forms/textarea/resize-background-ref.html", "layout/reftests/xul/reftest.list", "mobile/android/installer/allowed-dupes.mn", "toolkit/content/minimal-xul.css", "toolkit/themes/linux/global/icons/resizer-rtl.png", "toolkit/themes/linux/global/icons/resizer.png", "toolkit/themes/linux/global/jar.mn", "toolkit/themes/mobile/jar.mn", "toolkit/themes/osx/global/icons/resizer-rtl.png", "toolkit/themes/osx/global/icons/resizer-rtl@2x.png", "toolkit/themes/osx/global/icons/resizer.png", "toolkit/themes/osx/global/icons/resizer@2x.png", "toolkit/themes/osx/global/jar.mn", "toolkit/themes/osx/global/resizer.css", "toolkit/themes/shared/icons/resizer-rtl.svg", "toolkit/themes/shared/icons/resizer.svg", "toolkit/themes/sha