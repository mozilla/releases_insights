a8f0f92bb0846b6e2", "parents": ["fa28f84b96b717664e205dd126d7e27c9844f6ba"], "tags": []}, {"author": "Dale Harvey \u003cdale@arandomurl.com\u003e", "branch": "default", "desc": "Bug 1455310 - Add title data and activity to sharing. r=mstange\n\nMozReview-Commit-ID: IL4sqvRwSwu", "files": ["browser/base/content/browser-pageActions.js", "browser/base/content/test/urlbar/browser_page_action_menu_share_mac.js", "widget/cocoa/nsMacSharingService.mm", "widget/nsIMacSharingService.idl", "widget/tests/unit/test_macsharingservice.js"], "git_node": null, "git_parents": [null], "node": "1039c7e0047125d0ae88aefccaa5208000e87e00", "parents": ["51d020e4c2cbf4de620648d7dcded9d78b285ace"], "tags": []}, {"author": "Csoregi Natalia \u003cncsoregi@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland. a=merge CLOSED TREE", "files": [], "git_node": null, "git_parents": [null, null], "node": "8534948d69d4703af5e97e91022b15d4c30c17e8", "parents": ["1039c7e0047125d0ae88aefccaa5208000e87e00", "ba62c1380491f06dd5b37365e4801b9a32ae2f0a"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland", "files": ["js/src/devtools/automation/tsan-sighandlers.txt"], "git_node": null, "git_parents": [null, null], "node": "86d103a429eb2fbb450f05af51e2afe0c5d54bdc", "parents": ["8534948d69d4703af5e97e91022b15d4c30c17e8", "9a2eac450781b026b42c44ca8f0f92bb0846b6e2"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1406552 - Only update max ascent / descent with em ones when ascent and descent are zero. r=jfkthame\n\nThe original code was added in bug 385263 for fixing bug 279032 that a\nsingle font provides zero for max ascent / descent in its HHEA table\nwhich caused Firefox to crash.\n\nUnconditionally picking the maximum of max ascent / descent and their\nem correspondents doesn't seem to be essential for working around that\ncase, so this patch changes it to just use the em ascent / descent when\nboth max ascent and descent are zero.\n\nThis fixes a webcompat problem related to Roboto font on Linux (and\npresumably also Android given it uses FreeType backend as well).\n\nMozReview-Commit-ID: EpKrfiOwnZt", "files": ["gfx/thebes/gfxFT2FontBase.cpp", "layout/reftests/font-face/reftest.list", "testing/web-platform/meta/css/CSS2/margin-padding-clear/padding-em-inherit-001.xht.ini"], "git_node": null, "git_parents": [null], "node": "355a6e3f9bede2598878cf723a085b396846fe20", "parents": ["86d103a429eb2fbb450f05af51e2afe0c5d54bdc"], "tags": []}, {"author": "Kearwood Gilbert \u003ckgilbert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1459362 - Disable WebVR in release on macOS (Backed out changeset 1b24d52edebb) r=smaug\n\nMozReview-Commit-ID: BMuGwXYP750", "files": ["dom/tests/mochitest/general/test_interfaces.js", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "41d06ef57fe6894c4ebd5a2e89b8788b1fd5fd8f", "parents": ["355a6e3f9bede2598878cf723a085b396846fe20"], "tags": []}, {"author": "Mats Palmgren \u003cmats@mozilla.com\u003e", "branch": "default", "desc": "Bug 1452368 part 1 - [css-grid] Fix off-by-1 calculation in line clamping limit for auto-placed items.  r=dholbert", "files": ["layout/generic/nsGridContainerFrame.cpp"], "git_node": null, "git_parents": [null], "node": "19214ffe89a807e3738e4c33e2029ada96ca0edc", "parents": ["9a2eac450781b026b42c44ca8f0f92bb0846b6e2"], "tags": []}, {"author": "Mats Palmgren \u003cmats@mozilla.com\u003e", "branch": "default", "desc": "Bug 1452368 part 2 - [css-grid] Adjust reftests.", "files": ["layout/reftests/css-grid/grid-clamping-001-ref.html", "layout/reftests/css-grid/grid-placement-auto-implicit-001-ref.html"], "git_node": null, "git_parents": [null], "node": "8d79a9d3be10b707f5fc1385c360ade3181cd771", "parents": ["19214ffe89a807e3738e4c33e2029ada96ca0edc"], "tags": []}, {"author": "Mats Palmgren \u003cmats@mozilla.com\u003e", "br