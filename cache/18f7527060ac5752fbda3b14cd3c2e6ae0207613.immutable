IrRfc9tW5hY", "files": ["browser/base/content/test/performance/browser_startup.js"], "git_node": null, "git_parents": [null], "node": "c5751928dac6b8ff8d218a697f573c76f28e484a", "parents": ["74882421049068f3fd220a41187b45b885c67408"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1457652: Fix serialization order of the outline shorthand. r=xidorn\n\nThis is going to be tested in\nhttps://github.com/w3c/web-platform-tests/pull/10700.\n\nMozReview-Commit-ID: 7Oi1it70YFw", "files": ["servo/components/style/properties/shorthand/outline.mako.rs"], "git_node": null, "git_parents": [null], "node": "2a03e9effe84d574a0dfdaaefd9bde2f69df6d0e", "parents": ["c5751928dac6b8ff8d218a697f573c76f28e484a"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457249 - Assert that there is an animation value set by animations when we skip calculation for newly animation value. r=kats\n\nMozReview-Commit-ID: F85nAmKIGCA", "files": ["gfx/layers/composite/AsyncCompositionManager.cpp"], "git_node": null, "git_parents": [null], "node": "1794c5b65d03b1d308777309bcdded55b4366fab", "parents": ["2a03e9effe84d574a0dfdaaefd9bde2f69df6d0e"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457249 - Factor out the function that converts servo's animation value to matrix. r=kats\n\nMozReview-Commit-ID: HpdFYykOkOS", "files": ["gfx/layers/composite/AsyncCompositionManager.cpp"], "git_node": null, "git_parents": [null], "node": "ac3a8c1f0776fa5db9507663b3b6ad987ee3b4dc", "parents": ["1794c5b65d03b1d308777309bcdded55b4366fab"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457249 - Factor out the function that converts transform into device space. r=kats\n\nMozReview-Commit-ID: L7CDcSdIj4D", "files": ["gfx/layers/composite/AsyncCompositionManager.cpp"], "git_node": null, "git_parents": [null], "node": "053966aefdb39c70801e332db20e508e0bc668b0", "parents": ["ac3a8c1f0776fa5db9507663b3b6ad987ee3b4dc"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457249 - Use actually calculated value for the assertion that checks animation value is unchanged when we decided to skip calculation for the animation on debug build. r=kats\n\nBefore this change, the value which was set by SetShadowBaseTransform()\nhas been used for the assertion, but it is possible that the value is changed\nby APZ.  And it's hard to tell whether the value has been changed by APZ or not\nand it's hard to *reverse-calculate* the differences in the past APZ at the\nmoment we want to do the assert.\n\nSo after this patch, on debug build we don't actually skip the calculation for\nunchanged animations and use the newly calculated value for the assertion.\n\nMozReview-Commit-ID: 8fCcvvbUMHe", "files": ["gfx/layers/AnimationHelper.cpp", "gfx/layers/composite/AsyncCompositionManager.cpp"], "git_node": null, "git_parents": [null], "node": "ccef67dba02558dd7a3be26d339c9345efd3dfe6", "parents": ["053966aefdb39c70801e332db20e508e0bc668b0"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 2a03e9effe84 (bug 1457652) for WPT failures on /css/cssom/shorthand-values.html", "files": ["servo/components/style/properties/shorthand/outline.mako.rs"], "git_node": null, "git_parents": [null], "node": "8fc6c9d1bfa207883fd6095189bd722f719f2056", "parents": ["ccef67dba02558dd7a3be26d339c9345efd3dfe6"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1457652: Fix serialization order of the outline shorthand. r=xidorn\n\nThis is going to be tested in\nhttps://github.com/w3c/web-platform-tests/pull/10700.\n\nMozReview-Commit-ID: 7Oi1it70YFw\n", "files": ["servo/components/style/properties/shorthand/outline.mako.rs", "testing/web-platform/meta/css/cssom/shorthand-values.html.ini"], "git_node": null, "git_parents": [null], "node": "807e94988d9a9563504d6b3751562fdbbde13084", "parents": ["8fc6c9d1bfa207883fd6095189bd722f719f2056"], "tags": []}, {"author": "Hector Zhao \u003cbzhao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457423 - Locate android-{findbugs,lint} artifacts with updated filename. r=nalexander\n\nMozReview-Commit-ID: 3sVHQr4toaS", "files": ["mobile/android/gradle.configure", "taskcluster/ci/build/android-stuff.yml"], "git_node": null, "git_parents": [null], "node": "6cf6124bbd25db02658997b21bf9cfdc470fdbca", "parents": ["807e94988d9a9563504d6b3751562fdbbde13084"], "tags": []}, {"author": "Neil Deakin \u003cneil@mozilla.com\u003e", "branch": "default", "desc": "Bug 1446961, remove obsolete calls to showPopup and replace usages of the popup box object with the same methods defined on popups, r=paolo", "files": ["browser/base/content/browser-places.js", "browser/base/content/test/referrer/browser_referrer_open_link_in_container_tab.js", "browser/base/content/test/referrer/browser_referrer_open_link_in_container_tab3.js", "browser/base/content/test/sync/browser_contextmenu_sendpage.js", "browser/components/customizableui/PanelMultiView.jsm", "browser/components/places/content/menu.xml", "browser/components/places/tests/browser/browser_views_liveupdate.js", "browser/components/uitour/test/browser_UITour.js", "browser/components/uitour/test/browser_fxa.js", "browser/components/uitour/test/browser_trackingProtection_tour.js", "browser/components/uitour/test/head.js", "dom/xul/crashtests/384877-1-inner.xul", "layout/xul/crashtests/434458-1.xul", "layout/xul/crashtests/crashtests.list", "toolkit/content/tests/chrome/popup_trigger.js", "toolkit/content/widgets/browser.xml", "toolkit/content/widgets/tree.xml", "widget/tests/native_mouse_mac_window.xul"], "git_node": null, "git_parents": [null], "node": "e872787876a553d1d210a325e31d7e236c4c0857", "parents": ["f846639066aa8f7e5aff7fa363a450885fc887b4"], "tags": []}, {"author": "Neil Deakin \u003cneil@mozilla.com\u003e", "branch": "default", "desc": "Bug 1446961, restructuring to allow nsXULElement to be subclassed. Rename nsXULElement::Create to make it clearer it creates from the prototype element, r=bz", "files": ["dom/base/nsContentUtils.cpp", "dom/bindings/BindingUtils.cpp", "dom/xbl/nsXBLContentSink.cpp", "dom/xbl/nsXBLPrototypeBinding.cpp", "dom/xul/XULDocument.cpp", "dom/xul/nsXULElement.cpp", "dom/xul/nsXULElement.h"], "git_node": null, "git_parents": [null], "node": "5be83a2594fbd2e4e7612d4a779027f03c22b39c", "parents": ["e872787876a553d1d210a325e31d7e236c4c0857"], "tags": []}, {"author": "Neil Deakin \u003cneil@mozilla.com\u003e", "branch": "default", "desc": "Bug 1446961, remove deprecated showPopup method of PopupBoxObject as well as unused GetPopupSetFrame method, and move some methods' positions to group related methods together better, r=paolo,bz", "files": ["dom/webidl/PopupBoxObject.webidl", "layout/xul/PopupBoxObject.cpp", "layout/xul/PopupBoxObject.h", "toolkit/content/widgets/popup.xml"], "git_node": null, "git_parents": [null], "node": "5659ad69e1451dfe2fc9a13b7a0f81526951c6aa", "parents": ["5be83a2594fbd2e4e7612d4a779027f03c22b39c"], "tags": []}, {"author": "Neil Deakin \u003cneil@mozilla.com\u003e", "branch": "default", "desc": "Bug 1446961, remove unused popup frame methods now that showPopup has been removed, r=paolo", "files": ["layout/xul/nsMenuPopupFrame.cpp", "layout/xul/nsMenuPopupFrame.h", "layout/xul/nsXULPopupManager.cpp", "layout/xul/nsXULPopupManager.h"], "git_node": null, "git_parents": [null], "node": "962c081b13149f3d35f1f38bd514697aacd1a82a", "parents": ["5659ad69e1451dfe2fc9a13b7a0f81526951c6aa"], "tags": []}, {"author": "Neil Deakin \u003cneil@mozilla.com\u003e", "branch": "default", "desc": "Bug 1446961, add dictionary second argument directly to PopupBoxObject::OpenPopup as supported in popup.xml#openPopup, r=bz", "files": ["dom/webidl/PopupBoxObject.webidl", "layout/xul/PopupBoxObject.cpp", "layout/xul/PopupBoxObject.h", "toolkit/content/tests/chrome/popup_trigger.js"], "git_node": null, "git_parents": [null], "node": "46d7f3cc71027fd301be83c9d462b94cdcf27f7b", "parents": ["962c081b13149f3d35f1f38bd514697aacd1a82a"], "tags": []}, {"author": "Neil Deakin \u003cneil@mozilla.com\u003e", "branch": "default", "desc": "Bug 1446961, add two special cases in PopupBoxObject as supported in popup.xml, r=paolo,bz\n\n1 - the old showPopup redirects to showMenu when no argument is specified. Support this in openPopup as bookmarks drag code that pops open menus as you drag over them relies on this\n2 - reposition the popup after popup is resized, needed to update the arrow position in the arrow panel", "files": ["layout/xul/PopupBoxObject.cpp", "toolkit/content/tests/chrome/popup_trigger.js"], "git_node": null, "git_parents": [null], "node": "12e768652a88d11b9c09ec63e1a5df00cdab4dc2", "parents": ["46d7f3cc71027fd301be83c9d462b94cdcf27f7b"], "tags": []}, {"author": "Neil Deakin \u003cneil@mozilla.com\u003e", "branch": "default", "desc": "Bug 1446961, move PopupBoxObject to XULPopupElement, a new subclass of XULElement. Remove popup.xml methods, r=paolo,bz\n\nTest changes for removal of PopupBoxObject and popup.xml methods, some reflow tests now have different stacks now that they are not going through popup.xml binding methods, test_popupanchor.xul changes due to need to wait for popuppositioned event after resizing. The old code would just adjust the arrow directly when sizeTo was called, but the new code does this through an asynchronous popuppositioned event. Changes to some places that check for XULElement class.", "files": ["browser/base/content/test/performance/browser_appmenu.js", "browser/base/content/test/performance/browser_urlbar_keyed_search.js", "browser/base/content/test/performance/browser_urlbar_search.js", "devtools/server/actors/inspector/node.js", "devtools/ser