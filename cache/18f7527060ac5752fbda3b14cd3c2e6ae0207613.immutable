ts": ["6efcfbe52329d8df01335c7501d4420c917ac1e2"], "tags": []}], "date": 1526400780, "git_changesets": [null], "user": "ffxbld"}, "9228": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nfr -\u003e aec059af3abc\nhu -\u003e 8164d1ffd8e8\nko -\u003e 8c85e6838883\nsk -\u003e c0856a659054", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "1205e211742d62e33ff0d45b274005e63452f351", "parents": ["1751a2514f63f4105fa1d962aa75d24229beb829"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nda -\u003e 2b7f11f6ca03\nfr -\u003e aec059af3abc\nhu -\u003e 8164d1ffd8e8\nko -\u003e 8c85e6838883\nnl -\u003e 7f53b1ee87b1\nsk -\u003e c0856a659054", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "cb03b9370db6b0cef32360ade0c378dc856f4677", "parents": ["1205e211742d62e33ff0d45b274005e63452f351"], "tags": []}], "date": 1526408578, "git_changesets": [null, null], "user": "ffxbld"}, "9229": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nmr -\u003e 35501c5a592c\noc -\u003e b8cf967786a9\npl -\u003e c75196d90d20\npt-BR -\u003e dd7d2e4d2e36\npt-PT -\u003e 600972cba29d\nsk -\u003e 57dafbe8dce3", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "186313f62a474b0d961c03c369ecfb5f72c85935", "parents": ["cb03b9370db6b0cef32360ade0c378dc856f4677"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nit -\u003e 0dee0a8a59ce\nka -\u003e 12b1f6412ab9\nmr -\u003e 119728c6bf37\npl -\u003e c75196d90d20\npt-BR -\u003e dd7d2e4d2e36\npt-PT -\u003e 600972cba29d\nsk -\u003e 57dafbe8dce3", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "372bc698d60c50ec975a5ae84338edf3db897949", "parents": ["186313f62a474b0d961c03c369ecfb5f72c85935"], "tags": []}], "date": 1526451747, "git_changesets": [null, null], "user": "ffxbld"}, "9230": {"changesets": [{"author": "Jonathan Kingston \u003cjkt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1456704 - Fix CSP empty directive test by ignoring errors that aren't from CSP. r=ckerschb, a=test-only\n\nMozReview-Commit-ID: DOlNKATQSY1", "files": ["dom/security/test/csp/test_empty_directive.html"], "git_node": null, "git_parents": [null], "node": "dd4babc850ff5b3313e11cb8479442c697b6283a", "parents": ["372bc698d60c50ec975a5ae84338edf3db897949"], "tags": []}, {"author": "Aki Sasaki \u003casasaki@mozilla.com\u003e", "branch": "default", "desc": "Bug 1459391 - Fix intermittent OSX vcversioner install error. r=tomprince, a=test-only", "files": ["testing/mozharness/configs/unittests/mac_unittest.py"], "git_node": null, "git_parents": [null], "node": "f13605a00c2b310bc93ad9d44db34b2284d53dbe", "parents": ["dd4babc850ff5b3313e11cb8479442c697b6283a"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1461590 - Lower-case hostnames when adding substitutions. r=smaug, f=dveditz, a=RyanVM\n\nSince URI hostnames are defined to be case-insensitive, we only ever see\nlower-case hostnames when looking up substitutions. That means that\nsubstitutions containing capital letters are inaccessible, which is a footgun\nthat has hit many people.\n\nThe handler should lower-case substitutions when they're added so that\nlook-ups are always case-insensitive.\n\nMozReview-Commit-ID: C936hS2cSyY", "files": ["netwerk/protocol/res/SubstitutingProtocolHandler.cpp", "netwerk/protocol/res/nsISubstitutingProtocolHandler.idl", "netwerk/test/unit/test_substituting_protocol_handler.js", "netwerk/test/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "cb1e3d50463c5b668df56761fa1c41f2425609cb", "parents": ["f13605a00c2b310bc93ad9d44db34b2284d53dbe"], "tags": []}, {"author": "David Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "Bug 1427248 - Avoid changing certificate trust in nsNSSComponent initialization. r=fkiefer, r=jcj, a=RyanVM\n\nIf a user has set a master password on their NSS DB(s), when we try to change\nthe trust of a certificate, we may have to authenticate to the DB. This involves\nbringing up a dialog box, executing javascript, spinning the event loop, etc.\nIn some cases (particularly when antivirus software has injected code into\nFirefox), this can cause the nsNSSComponent to be initialized if it hasn't\nalready been. So, it's a really, really bad idea to attempt to change the trust\nof a certificate while we're initializing nsNSSComponent, because this results\nin a recursive component dependency and everything breaks. To get around this,\nif we need to load 3rd party roots (e.g. enterprise roots or the family safety\nroot), we defer any trust changes to a later event loop tick. In theory this\ncould cause verification failures early in startup. We'll have to see if this\nis an issue in practice.\n\nMozReview-Commit-ID: FvjHP5dTmpP", "files": ["security/manager/ssl/nsNSSComponent.cpp", "security/manager/ssl/nsNSSComponent.h"], "git_node": null, "git_parents": [null], "node": "7c3cfe766b3771262df0256b2bbcd240fa09fe3a", "parents": ["cb1e3d50463c5b668df56761fa1c41f2425609cb"], "tags": []}, {"author": "Daisuke Akatsuka \u003cdakatsuka@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457067 - Part 1: Implement so as to toggle the options panel if click 'Settings' on the meatball menu. r=jdescottes, a=RyanVM\n\nMozReview-Commit-ID: 3ST6EtMuA2F", "files": ["devtools/client/framework/components/toolbox-toolbar.js", "devtools/client/framework/toolbox.js"], "git_node": null, "git_parents": [null], "node": "b3f260301d0e1e4441bb1e6ae9bbb93bc6f487db", "parents": ["7c3cfe766b3771262df0256b2bbcd240fa09fe3a"], "tags": []}, {"author": "Daisuke Akatsuka \u003cdakatsuka@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457067 - Part 2: Add test whether options panel toggled by key event and Settings on the meatball menu. r=jdescottes, a=RyanVM\n\nMozReview-Commit-ID: 4bSeh8kkTx6", "files": ["devtools/client/framework/test/browser.ini", "devtools/client/framework/test/browser_toolbox_options_panel_toggle.js"], "git_node": null, "git_parents": [null], "node": "d7cc3e2fa65b9a59ed4280aa178fa7cf08f004e7", "parents": ["b3f260301d0e1e4441bb1e6ae9bbb93bc6f487db"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candrebargull@googlemail.com\u003e", "branch": "default", "desc": "Bug 1459285 - Update tzdata in ICU data files to 2018e. r=Waldo, a=RyanVM", "files": ["config/external/icu/data/icudt61l.dat", "intl/tzdata/SVN-INFO", "intl/tzdata/source/be/metaZones.res", "intl/tzdata/source/be/zoneinfo64.res", "intl/tzdata/source/ee/metaZones.res", "intl/tzdata/source/ee/zoneinfo64.res", "intl/tzdata/source/le/metaZones.res", "intl/tzdata/source/le/zoneinfo64.res", "intl/tzdata/source/metaZones.txt", "intl/tzdata/source/zoneinfo64.txt", "js/src/builtin/intl/TimeZoneDataGenerated.h", "js/src/tests/non262/Intl/DateTimeFormat/timeZone_backward_links.js", "js/src/tests/non262/Intl/DateTimeFormat/timeZone_backzone.js", "js/src/tests/non262/Intl/DateTimeFormat/timeZone_backzone_links.js", "js/src/tests/non262/Intl/DateTimeFormat/timeZone_notbackward_links.js"], "git_node": null, "git_parents": [null], "node": "9c5f236d1dd40bb2b5478ed69104c9785b7caa1c", "parents": ["d7cc3e2fa65b9a59ed4280aa178fa7cf08f004e7"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1442195 - Don't crash when finding an unexpected default font type. r=xidorn, a=RyanVM\n\nFor now just return sans-serif, though as the FIXME comment indicates we should\nprobably just carry around the font-name instead.\n\nMozReview-Commit-ID: CIPbV3R5Ul", "files": ["servo/components/style/properties/gecko.mako.rs"], "git_node": null, "git_parents": [null], "node": "dee67f5780bf85a02e8ec5b40dac24391dcd018d", "parents": ["9c5f236d1dd40bb2b5478ed69104c9785b7caa1c"], "tags": []}], "date": 1526482469, "git_changesets": [null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9231": {"changesets": [{"author": "Eric Rahm \u003cerahm@mozilla.com\u003e", "branch": "default", "desc": "Bug 1364624 - Part 1: Manually manage locks in MessageChannel::Close. r=froydnj, a=RyanVM\n\nThis switches over to manually managing the locking in MessageChannel::Close\nin order to avoid a deadlock on msvc opt builds. It has the added benefit of\navoid a superfluous lock/unlock pair.", "files": ["ipc/glue/MessageChannel.cpp"], "git_node": null, "git_parents": [null], "node": "9c083d037ce2528c1914c683902c0198afb7cd25", "parents": ["dee67f5780bf85a02e8ec5b40dac24391dcd018d"], "tags": []}, {"author": "Eric Rahm \u003cerahm@mozilla.com\u003e", "branch": "default", "desc": "Bug 1364624 - Part 2: Switch from CRITICALSECTION to SRWLOCK. r=froydnj, a=RyanVM", "files": ["mozglue/misc/ConditionVariable_windows.cpp", "mozglue/misc/MutexPlatformData_windows.h", "mozglue/misc/Mutex_windows.cpp"], "git_node": null, "git_parents": [null], "node": "7a8b8efc8098c0c6a9038e405c3175935e60340d", "parents": ["9c083d037ce2528c1914c683902c0198afb7cd25"], "tags": []}, {"author": "Dylan Roeh \u003cdroeh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1459513 - Handle null uri components gracefully in WebAppManifest. r=snorp, a=RyanVM", "files": ["mobile/android/base/java/org/mozilla/gecko/webapps/WebAppManifest.java"], "git_node": null, "git_parents": [null], "node": "0819f088efec2a36349302ffc450d7f478e2300f", "parents": ["7a8b8efc8098c0c6a9038e405c3175935e60340d"], "tags": []}, {"author": "Tim Taubert \u003cttaubert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1460301 - Web Authentication - Don't use U2F_PING to initialize tokens. r=jcj, a=RyanVM\n\nReviewers: jcj\n\nReviewed By: jcj\n\nBug #: 1460301\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1270", "files": ["dom/webauthn/u2f-hid-rs/src/u2fprotocol.rs"], "git_node": null, "git_parents": [null], "node": "dd12c80cff71af9c113d5919577169538d2bc873", "parents": ["0819f088efec2a36349302ffc450d7f478e2300f"], "tags": []}, {"author": "Mike Cooper \u003cmcooper@mozilla.com\u003e", "branch": "default", "desc": "Bug 1459899 - Reuse previous values when updating an existing rollout. r=Gijs, a=RyanVM\n\nMozReview-Commit-ID: 3kHo7b69vdS", "files": ["toolkit/components/normandy/actions/PreferenceRolloutAction.jsm", "toolkit/components/normandy/test/browser/browser_Normandy.js", "toolkit/components/normandy/test/browser/browser_actions_PreferenceRolloutAction.js"], "git_node": null, "git_parents": [null], "node": "e68716a3b4fe7e1910ab57e539340bd176ab84f5", "parents": ["dd12c80cff71af9c113d5919577169538d2bc873"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1461326 - Add some release assertions to dom/clients/manager code. r=baku, a=RyanVM", "files": ["dom/clients/manager/ClientHandle.cpp", "dom/clients/manager/ClientHandleOpChild.cpp", "dom/clients/manager/ClientManager.cpp", "dom/clients/manager/ClientThing.h"], "git_node": null, "git_parents": [null], "node": "64f47af70eb40d1b170e76498ac8fd0220aeef7a", "parents": ["e68716a3b4fe7e1910ab57e539340bd176ab84f5"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1461696 - Add telemetry for DOMAttrModified event. r=smaug, a=RyanVM\n\nMozReview-Commit-ID: D6cjCJB92ex", "files": ["dom/base/nsDeprecatedOperationList.h", "dom/events/EventListenerManager.cpp"], "git_node": null, "git_parents": [null], "node": "c0246ac14207d82a8f46b0e1679304c06818364a", "parents": ["64f47af70eb40d1b170e76498ac8fd0220aeef7a"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1440865 - Stop overriding tabbrowser-tabpanels' background for [pendingpaint]. r=mconley, a=RyanVM\n\nMozReview-Commit-ID: 42yr3JYMjWJ", "files": ["browser/base/content/tabbrowser.css", "browser/themes/shared/tabbrowser/pendingpaint.png"], "git_node": null, "git_parents": [null], "node": "1b250783a12f4a9c1caee3a1a8f6eeb6f5fb2df0", "parents": ["c0246ac14207d82a8f46b0e1679304c06818364a"], "tags": []}], "date": 1526501540, "git_changesets": [null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9232": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1461750 - Backout blocklist signature verification from Firefox 61. r=leplatrem, a=RyanVM", "files": ["modules/libpref/init/all.js", "services/common/blocklist-clients.js", "services/common/docs/RemoteSettings.rst", "services/common/tests/unit/test_blocklist_clients.js"], "git_node": null, "git_parents": [null], "node": "6247c3de81214476abc9d6f30465db4a4402441f", "parents": ["1b250783a12f4a9c1caee3a1a8f6eeb6f5fb2df0"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1460287 - Use black as a fallback for textcolor and always set lwtheme attribute if theme is active. r=dao, a=RyanVM\n\nMozReview-Commit-ID: 30NKcuz94d", "files": ["toolkit/components/extensions/test/browser/browser_ext_themes_chromeparity.js", "toolkit/components/extensions/test/browser/browser_ext_themes_sanitization.js", "toolkit/modules/LightweightThemeConsumer.jsm"], "git_node": null, "git_parents": [null], "node": "305d61ed533a4e3672d278128322f564dde378d6", "parents": ["6247c3de81214476abc9d6f30465db4a4402441f"], "tags": []}, {"author": "J.C. Jones \u003cjjones@mozilla.com\u003e", "branch": "default", "desc": "Bug 1460767 - Return device ineligible when appropriate for U2F. r=ttaubert, a=RyanVM\n\nSummary:\nFIDO U2F's specification says that when the wrong security key responds to a\nsignature, or when an already-registered key exists, that the UA should return\nerror code 4, DEVICE_INELIGIBLE. We used to do that, but adjusted some things\nfor WebAuthn and now we don't. This changes the soft token to return that at\nthe appropriate times, and updates the expectations of U2F.cpp that it should\nuse InvalidStateError as the signal to reutrn DEVICE_INELIGIBLE.\n\nAlso, note that WebAuthn's specification says that if any authenticator returns\n\"InvalidStateError\" that it should be propagated, as it indicates that the\nauthenticator obtained user consent and failed to complete its job [1].\n\nThis change to the Soft Token affects the WebAuthn tests, but in a good way.\nReading the WebAuthn spec, we should not be returning NotAllowedError when there\nis consent from the user via the token (which the softtoken always deliveres).\n\nAs such, this adjusts the affected WebAuthn tests, and adds a couple useful\nchecks to test_webauthn_get_assertion.html for future purposes.\n\n[1] https://w3c.github.io/webauthn/#createCredential section 5.1.3 \"Create a new\n    credential\", Step 20, Note 2: \"If any authenticator returns an error status\n    equivalent to \"InvalidStateError\"...\"\n\nTest Plan: https://treeherder.mozilla.org/#/jobs?repo=try&revision=f2fc930f7fc8eea69b1ebc96748fe95e150a92a4\n\nReviewers: ttaubert\n\nBug #: 1460767\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1269", "files": ["dom/u2f/U2F.cpp", "dom/webauthn/U2FSoftTokenManager.cpp", "dom/webauthn/tests/browser/browser_fido_appid_extension.js", "dom/webauthn/tests/test_webauthn_authenticator_transports.html", "dom/webauthn/tests/test_webauthn_get_assertion.html", "dom/webauthn/tests/test_webauthn_loopback.html"], "git_node": null, "git_parents": [null], "node": "594d4ff3b55bca69fedc366b0573bf17e204f118", "parents": ["305d61ed533a4e3672d278128322f564dde378d6"], "tags": []}, {"author": "Mantaroh Yoshinaga \u003cmantaroh@gmail.com\u003e", "branch": "default", "desc": "Bug 1455462 - Part 1. Use the toolbox.zoomIn3.key shortcut. r=ochameau, a=RyanVM\n\nThis key will empty string, so we don't use this key now.\nBut we might use this key in the future.", "files": ["devtools/client/shared/zoom-keys.js"], "git_node": null, "git_parents": [null], "node": "d234aa23f84f8c13a301c95787c06f60a4ed8ba0", "parents": ["594d4ff3b55bca69fedc366b0573bf17e204f118"], "tags": []}, {"author": "Mantaroh Yoshinaga \u003cmantaroh@gmail.com\u003e", "branch": "default", "desc": "Bug 1455462 - Part 2. Use the rounded zoom value of devtool panel. r=jdescottes, a=RyanVM\n\nThis patch will use rounded zoom value of dev tool panel.\nThis changes will ensure the zoom value test.", "files": ["devtools/client/shared/zoom-keys.js"], "git_node": null, "git_parents": [null], "node": "69dec209ab576d4c6af7fe85b3fa16cca495a89a", "parents": ["d234aa23f84f8c13a301c95787c06f60a4ed8ba0"], "tags": []}, {"author": "Mantaroh Yoshinaga \u003cmantaroh@gmail.com\u003e", "branch": "default", "desc": "Bug 1455462 - Part 3. Use zoom value when showing popup menu. r=jdescottes, a=RyanVM\n\nThe openPopupAtScreen() use the zoomed css coordinate value as position value,\ndevtools's caller of this function use css pixel value without zoom. So position\nof popup will missaligned if zooming out/in the devtool panel.", "files": ["devtools/client/framework/components/toolbox-tabs.js", "devtools/client/framework/components/toolbox-toolbar.js", "devtools/client/framework/menu.js", "devtools/client/framework/toolbox.js", "devtools/client/shared/components/tabs/TabBar.js"], "git_node": null, "git_parents": [null], "node": "fa0085fa3c49f482d5734aa8800508a5dd3615a1", "parents": ["69dec209ab576d4c6af7fe85b3fa16cca495a89a"], "tags": []}, {"author": "Mantaroh Yoshinaga \u003cmantaroh@gmail.com\u003e", "branch": "default", "desc": "Bug 1455462 - Part 4. Use the async_task in devtool's zoom test. r=jdescottes, a=RyanVM\n\nThis patch will change test to use the async_task before touching this tests and\nuse the first decimal place when checking a result.", "files": ["devtools/client/framework/test/browser_toolbox_zoom.js"], "git_node": null, "git_parents": [null], "node": "181056a15e4ba770b13220a0547e88fc7e69dbf9", "parents": ["fa0085fa3c49f482d5734aa8800508a5dd3615a1"], "tags": []}, {"author": "Mantaroh Yoshinaga \u003cmantaroh@gmail.com\u003e", "branch": "default", "desc": "Bug 1455462 - Part 5. Add toolbox's menu position test. r=jdescottes, a=RyanVM\n\nThis test will check that popup menu of toolbox will be displayed under the\nmenu button. This test tolerates an error since some platform (like macOS)\nwill add the offset value. (i.e. eIntID_ContextMenuOffsetHorizontal and\neIntID_ContextMenuOffsetVertical)\n\nMozReview-Commit-ID: 5TaM5JiNhdk", "files": ["devtools/client/framework/test/browser.ini", "devtools/client/framework/test/browser_toolbox_zoom.js", "devtools/client/framework/test/browser_toolbox_zoom_popup.js"], "git_node": null, "git_parents": [null], "node": "abd62e896138d08e0fcf69542a0b3dec1b2cf11a", "parents": ["181056a15e4ba770b13220a0547e88fc7e69dbf9"], "tags": []}, {"author": "Mantaroh Yoshinaga \u003cmantaroh@gmail.com\u003e", "branch": "default", "desc": "Bug 1455462 - Part 6. Add test of confirming the position of 'all menu' popup. r=jdescottes, a=RyanVM\n\nThe accessing all menu button will be shown to the inspector, so this test will\nuse inspector's this button. This button didn't have an id, so this patch will\nadd id for testing.\n\nMozReview-Commit-ID: 2xFXYKwpQoe", "files": ["devtools/client/framework/test/browser_toolbox_zoom_popup.js"], "git_node": null, "git_parents": [null], "node": "ea0bb21de30467e052dbc8913e6571aae86d241e", "parents": ["abd62e896138d08e0fcf69542a0b3dec1b2cf11a"], "tags": []}], "date": 1526515575, "git_changesets": [null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9233": {"changesets": [{"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1453541 - Part 1: Move more code into ProcessFrame so that we can call it from multiple places. r=mstange, a=RyanVM\n\nMozReview-Commit-ID: AOXPgteSgTL", "files": ["layout/painting/RetainedDisplayListBuilder.cpp", "layout/painting/RetainedDisplayListBuilder.h"], "git_node": null, "git_parents": [null], "node": "f13fb5d37547d5e9d870bf92557f18354446883f", "parents": ["ea0bb21de30467e052dbc8913e6571aae86d241e"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1453541 - Part 2: Look for Out Of Flow frames with modified ancestors during ProcessFrame instead of during display list building. r=mstange, a=RyanVM\n\nMozReview-Commit-ID: KsgrFqr2gVN", "files": ["layout/painting/RetainedDisplayListBuilder.cpp", "layout/painting/nsDisplayList.cpp", "layout/painting/nsDisplayList.h"], "git_node": null, "git_parents": [null], "node": "35c4b04bb305f9f6cdf9c58cc6e3e5ab4ca4ab08", "parents": ["f13fb5d37547d5e9d870bf92557f18354446883f"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1453541 - Part 3: Add reftests. r=mstange, a=RyanVM\n\nMozReview-Commit-ID: 95DOq6UBUnq", "files": ["layout/reftests/display-list/1453541-1.html", "layout/reftests/display-list/1453541-2.html", "layout/reftests/display-list/1453541-ref.html", "layout/reftests/display-list/reftest.list"], "git_node": null, "git_parents": [null], "node": "1d11b6bedc3057a1cfea8762d17874b6567c836b", "parents": ["35c4b04bb305f9f6cdf9c58cc6e3e5ab4ca4ab08"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1452464. r=miko, a=RyanVM", "files": ["layout/painting/nsDisplayList.cpp", "layout/painting/nsDisplayList.h"], "git_node": null, "git_parents": [null], "node": "064b3540e831abdb746ecb36f50c7d8cc01762d0", "parents": ["1d11b6bedc3057a1cfea8762d17874b6567c836b"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1459441 - Make sure we build the full display list when we have blend containers in order to get the correct sorting for them. r=mstange, a=RyanVM\n\nMozReview-Commit-ID: ECTU7enMb1r", "files": ["layout/generic/nsFrame.cpp", "layout/generic/nsIFrame.h", "layout/painting/RetainedDisplayListBuilder.cpp", "layout/painting/nsDisplayList.cpp", "layout/painting/nsDisplayList.h", "layout/reftests/display-list/invalidated-blendmode-sorting-ref.html", "layout/reftests/display-list/invalidated-blendmode-sorting.html", "layout/reftests/display-list/reftest.list"], "git_node": null, "git_parents": [null], "node": "a5b962b8bb3d9a9301430bc47ce975e5279b2043", "parents": ["064b3540e831abdb746ecb36f50c7d8cc01762d0"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1461231 - Don't omit deleted items when constructing the DAG, since we need to record that we made a modification during MergeDisplayLists. r=miko, a=RyanVM\n\nWe can unconditionally delete the item though, and just put a placeholder entry into the DAG.\n\nMozReview-Commit-ID: 7a2UnaByIZu", "files": ["layout/painting/RetainedDisplayListBuilder.cpp", "layout/reftests/display-list/1461231-1.html", "layout/reftests/display-list/reftest.list"], "git_node": null, "git_parents": [null], "node": "2932a4b5f7e77885014ce42d09ae14e3096f37b6", "parents": ["a5b962b8bb3d9a9301430bc47ce975e5279b2043"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1461812 - Make sure we fully cleanup any partially constructed display lists when returning a failure from AttemptPartialUpdate. r=miko, a=RyanVM\n\nMozReview-Commit-ID: DJBG6UFcoyR", "files": ["layout/base/crashtests/1461812.html", "layout/base/crashtests/crashtests.list", "layout/painting/RetainedDisplayListBuilder.cpp", "layout/painting/nsDisplayList.h"], "git_node": null, "git_parents": [null], "node": "909e56123552926e7b3b7f2431604a849d51c36c", "parents": ["2932a4b5f7e77885014ce42d09ae14e3096f37b6"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1460526 - Don't attempt to do a partial rebuild when a sublist DAG gets too complex, always rebuild the whole display list. r=miko, a=RyanVM\n\nMozReview-Commit-ID: 5u3sBSepgJa", "files": ["layout/painting/RetainedDisplayListBuilder.cpp"], "git_node": null, "git_parents": [null], "node": "457462d0bb3d797f68a35ead733bb8fdbb1dd75d", "parents": ["909e56123552926e7b3b7f2431604a849d51c36c"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1459997 - Add much more rigorous assertions for retained-dl assumptions. r=miko, a=RyanVM\n\nThis adds an assertion checking for duplicate items whenever we create an item, and when we merge an item into the final list.\n\nI had to disable tracking for the anonymous inner list for nsDisplayPerspective and nsDisplayTransform (and manually forward RemoveFrame to them), as well as skipping the assertion for multi-page (since we can end up duplicating wrap lists, but isn't a problem, since we don't retain these).\n\nMozReview-Commit-ID: 4n6rx9bQNan", "files": ["layout/generic/nsFrame.cpp", "layout/generic/nsSimplePageSequenceFrame.cpp", "layout/painting/RetainedDisplayListBuilder.cpp", "layout/painting/nsDisplayList.cpp", "layout/painting/nsDisplayList.h"], "git_node": null, "git_parents": [null], "node": "233d36dfd5c9071593c372212c56da1cfc15c6bf", "parents": ["457462d0bb3d797f68a35ead733bb8fdbb1dd75d"], "tags": []}], "date": 1526520363, "git_changesets": [null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9234": {"changesets": [{"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1459162 - Update dimensions early in ClearTarget. r=lsalzman a=abillings", "files": ["dom/canvas/CanvasRenderingContext2D.cpp", "dom/canvas/CanvasRenderingContext2D.h"], "git_node": null, "git_parents": [null], "node": "3b349484f1de921c889850a70f85bbe220893e33", "parents": ["233d36dfd5c9071593c372212c56da1cfc15c6bf"], "tags": []}], "date": 1526547271, "git_changesets": [null], "user": "jkew@mozilla.com"}, "9235": {"changesets": [{"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1461093 - Remove vertical padding from #titlebar-buttonbox. r=stransky, a=RyanVM\n\nMozReview-Commit-ID: 8ptkqHA8wCZ", "files": ["browser/themes/linux/browser.css"], "git_node": null, "git_parents": [null], "node": "e303321bec189ad04d881680cdf19f3973ab6e2a", "parents": ["3b349484f1de921c889850a70f85bbe220893e33"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1452361 - Don't reset to default permissions for cookies in page info. r=nhnt11, a=RyanVM\n\nThis commit makes the page info window treat cookie permissions a little\ndifferently, to reflect that the \"default\" value for cookies is a combination\nof two prefs that doesn't strictly map onto the ALLOW/SESSION/DENY system of\npermissions.\n\nI also added some more general pageinfo permissions tests.\n\nMozReview-Commit-ID: 80vd61Rv867", "files": ["browser/base/content/pageinfo/permissions.js", "browser/base/content/test/pageinfo/browser.ini", "browser/base/content/test/pageinfo/browser_pageinfo_permissions.js", "browser/modules/SitePermissions.jsm"], "git_node": null, "git_parents": [null], "node": "f23b9482597f30e6a252592b1aceaa1f083d0f31", "parents": ["e303321bec189ad04d881680cdf19f3973ab6e2a"], "tags": []}, {"author": "Haik Aftandilian \u003chaftandilian@mozilla.com\u003e", "branch": "default", "desc": "Bug 1460917 - Fonts not displaying with FontExplorer X fonts in Firefox 60. r=handyman, a=RyanVM\n\nAdd back font whitelist rules removed by the fix for bug 1393259\nto workaround font sandbox extensions not being issued automatically\non OS X 10.11 and earlier.\n\nMozReview-Commit-ID: 2hT0BzN3Ggq", "files": ["security/sandbox/mac/SandboxPolicies.h"], "git_node": null, "git_parents": [null], "node": "2bbdeafb0a5813426f9dbe97f4a42f57fde89770", "parents": ["f23b9482597f30e6a252592b1aceaa1f083d0f31"], "tags": []}, {"author": "Patrick Brosset \u003cpbrosset@mozilla.com\u003e", "branch": "default", "desc": "Bug 1460223 - Handle computedStyle.display failures for non-elements. r=gl, a=RyanVM\n\nMozReview-Commit-ID: 9raK8Tkl4GI", "files": ["devtools/server/actors/inspector/node.js", "devtools/shared/fronts/node.js"], "git_node": null, "git_parents": [null], "node": "1c503530315ee29075684a9ad1d634fec6b4094f", "parents": ["2bbdeafb0a5813426f9dbe97f4a42f57fde89770"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1462077 - Part 1: Make ServiceWorkerManager::DispatchFetchEvent() use the new client if we create one for an STS upgrade. r=asuth, a=RyanVM", "files": ["dom/serviceworkers/ServiceWorkerManager.cpp"], "git_node": null, "git_parents": [null], "node": "d5c088330e6b7f03294ba7ce1a6a917e4756f993", "parents": ["1c503530315ee29075684a9ad1d634fec6b4094f"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1462077 - Part 2: Add a release assert in ClientHandle::Control() that enforces same-origin policy. r=asuth, a=RyanVM", "files": ["dom/clients/manager/ClientHandle.cpp"], "git_node": null, "git_parents": [null], "node": "39f739efe10493ee1bc0da6e059bece3d32ae682", "parents": ["d5c088330e6b7f03294ba7ce1a6a917e4756f993"], "tags": []}], "date": 1526564998, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9236": {"changesets": [{"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1456069 - Always show frame button if user is on options panel. r=birtles, r=jryans, a=RyanVM, l10n=flod\n\nMozReview-Commit-ID: CqwcVlxrQMd", "files": ["devtools/client/framework/test/browser.ini", "devtools/client/framework/test/browser_toolbox_options_frames_button.js", "devtools/client/framework/toolbox.js", "devtools/client/locales/en-US/toolbox.properties"], "git_node": null, "git_parents": [null], "node": "0315d341f73f3385f7bf58f0687d66f621fd9316", "parents": ["39f739efe10493ee1bc0da6e059bece3d32ae682"], "tags": ["DEVEDITION_61_0b6_BUILD1", "DEVEDITION_61_0b6_RELEASE", "FIREFOX_61_0b6_BUILD1", "FIREFOX_61_0b6_RELEASE"]}], "date": 1526566440, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "9237": {"changesets": [{"author": "\"Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e\"", "branch": "default", "desc": "No bug - Tagging 0315d341f73f3385f7bf58f0687d66f621fd9316 with FIREFOX_61_0b6_BUILD1, FIREFOX_61_0b6_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "5ae9e6478accc74fa49e5dfd9f8095f5851d7676", "parents": ["0315d341f73f3385f7bf58f0687d66f621fd9316"], "tags": []}, {"author": "\"Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e\"", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "bcfd37212bd945b2fdcdd00f9f2af14b457edbf4", "parents": ["5ae9e6478accc74fa49e5dfd9f8095f5851d7676"], "tags": []}], "date": 1526653687, "git_changesets": [null, null], "user": "ffxbld"}, "9238": {"changesets": [{"author": "\"Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e\"", "branch": "default", "desc": "No bug - Tagging 0315d341f73f3385f7bf58f0687d66f621fd9316 with DEVEDITION_61_0b6_BUILD1, DEVEDITION_61_0b6_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "1c326983d7be1e1d63dad50e7cc4fc5dc1d5476a", "parents": ["bcfd37212bd945b2fdcdd00f9f2af14b457edbf4"], "tags": []}], "date": 1526653851, "git_changesets": [null], "user": "ffxbld"}, "9239": {"changesets": [{"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1458793 - Update flicker conditions to account for bug 1183135. r=mconley, a=test-only\n\nMozReview-Commit-ID: 5xgXzdf68wg", "files": ["browser/base/content/test/performance/browser.ini", "browser/base/content/test/performance/browser_tabclose.js"], "git_node": null, "git_parents": [null], "node": "5d7d7ee1bbd1e6b563375c795f5bd1869f981d69", "parents": ["1c326983d7be1e1d63dad50e7cc4fc5dc1d5476a"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1450448 - Correctly handle non-initialized appCache in site data preferences. r=Gijs, a=RyanVM\n\nMozReview-Commit-ID: IhQGAWNQtR0", "files": ["browser/modules/SiteDataManager.jsm"], "git_node": null, "git_parents": [null], "node": "ab893afd788e58e6b015548b3163fe3e70f2afbe", "parents": ["5d7d7ee1bbd1e6b563375c795f5bd1869f981d69"], "tags": []}, {"author": "Sean Stangl \u003csstangl@mozilla.com\u003e", "branch": "default", "desc": "Bug 1456524 - Maintain MoveResolver invariants. r=jandem, a=RyanVM\n\nThe MoveResolver is a persistent data structure that requires\nstate to not leak between borrowers. An early-exit optimization\nin the case of OOM allows for state to leak, leading to impossible\nmove list inputs, tripping assertions.", "files": ["js/src/jit/MacroAssembler.h", "js/src/jit/MoveResolver.cpp", "js/src/jit/MoveResolver.h", "js/src/jit/arm/MacroAssembler-arm.cpp", "js/src/jit/mips32/MacroAssembler-mips32.cpp", "js/src/jit/mips64/MacroAssembler-mips64.cpp"], "git_node": null, "git_parents": [null], "node": "c3d8e57327695aaa9c47c0ca6bb26b8434634303", "parents": ["ab893afd788e58e6b015548b3163fe3e70f2afbe"], "tags": []}, {"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1453892 - Only use SkJumper's arm64 half-float optimizations with clang. r=rhunt, a=RyanVM\n\nMozReview-Commit-ID: H4ahP6jVdqC", "files": ["gfx/skia/skia/src/jumper/SkJumper_stages.cpp"], "git_node": null, "git_parents": [null], "node": "b6653a9f24fcab91cf5a4bd7b19990879d28f603", "parents": ["c3d8e57327695aaa9c47c0ca6bb26b8434634303"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1460858 - Fix serialization/deserialization of SlantStyle for the Android startupCache, to ensure proper styled face selection. r=jwatt, a=RyanVM", "files": ["gfx/src/FontPropertyTypes.h", "gfx/thebes/gfxFT2FontList.cpp"], "git_node": null, "git_parents": [null], "node": "357d9f00469d5276138a918a64142ac6b158ab79", "parents": ["b6653a9f24fcab91cf5a4bd7b19990879d28f603"], "tags": []}, {"author": "Mike Cooper \u003cmcooper@mozilla.com\u003e", "branch": "default", "desc": "Bug 1450090 - Add study branch to preference study unenroll telemetry event. r=Gijs, a=RyanVM\n\nMozReview-Commit-ID: FSLb8TSQhL2", "files": ["toolkit/components/normandy/lib/PreferenceExperiments.jsm", "toolkit/components/normandy/lib/TelemetryEvents.jsm", "toolkit/components/normandy/test/browser/browser_PreferenceExperiments.js"], "git_node": null, "git_parents": [null], "node": "617990cee57d405cbb21c49996ca035140716aa6", "parents": ["357d9f00469d5276138a918a64142ac6b158ab79"], "tags": []}], "date": 1526656988, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9240": {"changesets": [{"author": "Justin Wood \u003cCallek@gmail.com\u003e", "branch": "default", "desc": "Bug 1455337 - Set min version appropriately for language packs. r=gps a=release\n\nAMO needs to enter the application version for every Firefox release at this time, and in doing so they don't usually enter .sec versions, as these versions are exposed to addon devs in UX where they can specify outside of the xpi what versions of Firefox they are compatible with.\n\nLanguage packs however set min version to things like 59.0.2 which AMO doesn't know about.\n\nAMO will also fail to validate an .xpi with an unknown min version.\n\nThis code logic is slightly compounded by the fact that SeaMonkey uses these codepaths as well, so we need to account for it here.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1112", "files": ["python/mozbuild/mozbuild/action/langpack_manifest.py"], "git_node": null, "git_parents": [null], "node": "4f8ff11754a55d94d3eab2d3419d83c003b1ba97", "parents": ["617990cee57d405cbb21c49996ca035140716aa6"], "tags": []}], "date": 1526697580, "git_changesets": [null], "user": "Callek@gmail.com"}, "9241": {"changesets": [{"author": "k88hudson \u003ck88hudson@gmail.com\u003e", "branch": "default", "desc": "Bug 1462736 - Turn on telemetry, endpoint pref, and button_type option for AS Router experiment. r=Mardak, a=RyanVM\n\nMozReview-Commit-ID: EhIAunrCnqo", "files": ["browser/extensions/activity-stream/css/activity-stream-linux.css", "browser/extensions/activity-stream/css/activity-stream-linux.css.map", "browser/extensions/activity-stream/css/activity-stream-mac.css", "browser/extensions/activity-stream/css/activity-stream-mac.css.map", "browser/extensions/activity-stream/css/activity-stream-windows.css", "browser/extensions/activity-stream/css/activity-stream-windows.css.map", "browser/extensions/activity-stream/data/content/activity-stream.bundle.js", "browser/extensions/activity-stream/data/content/activity-stream.bundle.js.map", "browser/extensions/activity-stream/install.rdf.in", "browser/extensions/activity-stream/lib/ASRouter.jsm", "browser/extensions/activity-stream/lib/ActivityStream.jsm", "browser/extensions/activity-stream/lib/TelemetryFeed.jsm", "browser/extensions/activity-stream/test/schemas/pings.js", "browser/extensions/activity-stream/test/unit/lib/SnippetsFeed.test.js", "browser/extensions/activity-stream/test/unit/lib/TelemetryFeed.test.js"], "git_node": null, "git_parents": [null], "node": "3250ec93398a1e12fa5696abbb0b31707ef57c01", "parents": ["4f8ff11754a55d94d3eab2d3419d83c003b1ba97"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1459890 - Do not clip mask for clip path to bbox of clipped content. r=mstange, a=RyanVM\n\nMozReview-Commit-ID: 9yZ1ziiDAKa", "files": ["layout/generic/nsFrame.cpp", "layout/reftests/svg/blur-inside-clipPath-ref.svg", "layout/reftests/svg/blur-inside-clipPath.svg", "layout/reftests/svg/reftest.list", "layout/svg/nsSVGClipPathFrame.cpp", "layout/svg/nsSVGClipPathFrame.h", "layout/svg/nsSVGUtils.cpp", "layout/svg/nsSVGUtils.h"], "git_node": null, "git_parents": [null], "node": "079c98575706be3a5e378e6cf4c9f11c48856948", "parents": ["3250ec93398a1e12fa5696abbb0b31707ef57c01"], "tags": []}, {"author": "Ted Mielczarek \u003cted@mielczarek.org\u003e", "branch": "default", "desc": "Bug 1459597 - Fix Original Filename display in Windows file version info. r=chmanchester, a=RyanVM\n\nMozReview-Commit-ID: 1JdpRcbS6qN", "files": ["config/version.mk"], "git_node": null, "git_parents": [null], "node": "5cca2364cc58e54bf7b13ef92dbd4ca23ed3cdd4", "parents": ["079c98575706be3a5e378e6cf4c9f11c48856948"], "tags": []}], "date": 1526741955, "git_changesets": [null, null, null], "user": "ryanvm@gmail.com"}, "9242": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nit -\u003e 212046797338", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "b56ae11b513394c795da1c49e081dc3a86135d6b", "parents": ["5cca2364cc58e54bf7b13ef92dbd4ca23ed3cdd4"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nit -\u003e 65da55ce8d60", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "8a1a31fda43d5c5382825fe483b993ccac67e882", "parents": ["b56ae11b513394c795da1c49e081dc3a86135d6b"], "tags": []}], "date": 1526822558, "git_changesets": [null, null], "user": "ffxbld"}, "9243": {"changesets": [{"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1462873 - Link chromium_atomics to webrtc tests. r=froydnj, a=RyanVM\n\nThis redoes bug 1257888 which bug 1393119 undid.", "files": ["media/webrtc/trunk/gtest/moz.build"], "git_node": null, "git_parents": [null], "node": "dd95eb07aa8c45487c6a53b1522bb5d9611da092", "parents": ["8a1a31fda43d5c5382825fe483b993ccac67e882"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1462859 - Add --disable-layoutex when running ICU configure. r=froydnj, a=RyanVM\n\nIn some recent ICU update, --enable-layoutex changed from defaulting to\nthe \"same-as-layout\" to \"yes\", so --disable-layout doesn't imply\n--disable-layoutex anymore, but we removed the layoutex files.", "files": ["intl/icu_sources_data.py"], "git_node": null, "git_parents": [null], "node": "795667aee1ef32dc37a4ca13e5e9762ac698d1c7", "parents": ["dd95eb07aa8c45487c6a53b1522bb5d9611da092"], "tags": []}], "date": 1526844916, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "9244": {"changesets": [{"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457499 - Part 1: Remove unused variable. r=bryce, a=RyanVM\n\nPrevent a compilation warning\n\nMozReview-Commit-ID: HT1UzsFUNXj", "files": ["dom/media/platforms/wmf/DXVA2Manager.cpp"], "git_node": null, "git_parents": [null], "node": "db29a2ec28c50d7cdb390c87c41daa4b3f655a09", "parents": ["795667aee1ef32dc37a4ca13e5e9762ac698d1c7"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457499 - Part 2: Fix compilation warning. r=bryce, a=RyanVM\n\nTaskQueue::Dispatch returns a nsresult which must be checked.\n\nMozReview-Commit-ID: 7Tl7O96rQNt", "files": ["dom/media/platforms/wmf/WMFMediaDataDecoder.cpp"], "git_node": null, "git_parents": [null], "node": "d6500ec9e0e84c531d59ab51f2f201d2988f541b", "parents": ["db29a2ec28c50d7cdb390c87c41daa4b3f655a09"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457499 - Part 3: Query decoded frame size instead of calculating it. r=bryce, a=RyanVM\n\nUnder most cases, the frame decoded height is just the displayed height rounded to the next 16 row aligned value.\nHowever, this doesn't appear to always be the case. So we query the WMF framework for the decoded frame size.\nWe continue to use the displayed sizes as found in the SPS to ensure proper display of non 1:1 aspect ratio.\n\nAdding diagnostic assertion to find potential regressions, we will address those as they come.\n\nMozReview-Commit-ID: L8VowEw6L9F", "files": ["dom/media/platforms/wmf/WMFVideoMFTManager.cpp", "dom/media/platforms/wmf/WMFVideoMFTManager.h"], "git_node": null, "git_parents": [null], "node": "6b7ce6f146aba5250999edf11029ea63cfce4d57", "parents": ["d6500ec9e0e84c531d59ab51f2f201d2988f541b"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1461203 - Use GetScrollbarMetrics() to access scrollbar metrics. r=jhorak, a=RyanVM\n\nMozReview-Commit-ID: 3gnFNfxQJZi", "files": ["widget/gtk/gtk3drawing.cpp"], "git_node": null, "git_parents": [null], "node": "6e890ccae3ab700b89a64e3799eff1d45b6a413f", "parents": ["6b7ce6f146aba5250999edf11029ea63cfce4d57"], "tags": []}, {"author": "Mike de Boer \u003cmdeboer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1434252 - nsICookieService may throw an error in certain circumstances, so let's make SessionCookies::restore infallible. r=dao, a=RyanVM\n\nPlease see bug 1462402 for more details and the root cause.\nSessionCookies.jsm uses nsICookieService::CookieExists and nsICookieService::Add\nto restore session-cookies. These currently throw for hostnames that contain a\nleading '.' and maybe other cases, so we need to wrap the calls in a try..catch\nblock to prevent breakage, leading to an unrestored session.\n\nMozReview-Commit-ID: 9gZ7K6lwcQF", "files": ["browser/components/sessionstore/SessionCookies.jsm"], "git_node": null, "git_parents": [null], "node": "bbb2cb6e0d060048b665ebee80ce299d551087e0", "parents": ["6e890ccae3ab700b89a64e3799eff1d45b6a413f"], "tags": []}, {"author": "Michael Hoffmann \u003cbrennan.brisad@gmail.com\u003e", "branch": "default", "desc": "Bug 1461328 - Handle !important for font-family in inspector correctly. r=pbro, a=RyanVM", "files": ["devtools/client/inspector/rules/test/browser.ini", "devtools/client/inspector/rules/test/browser_rules_font-family-parsing.js", "devtools/client/inspector/rules/test/browser_rules_highlight-used-fonts.js", "devtools/client/shared/output-parser.js"], "git_node": null, "git_parents": [null], "node": "4268240fb6d9b8a56058477017a345f87cae799f", "parents": ["bbb2cb6e0d060048b665ebee80ce299d551087e0"], "tags": ["DEVEDITION_61_0b7_BUILD1", "DEVEDITION_61_0b7_RELEASE", "FENNEC_61_0b7_BUILD1", "FENNEC_61_0b7_RELEASE", "FIREFOX_61_0b7_BUILD1", "FIREFOX_61_0b7_RELEASE"]}], "date": 1526900997, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9245": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\naz -\u003e 31db22c61ee3\nbe -\u003e 844007f6fcb1\nbg -\u003e ebe40e8a8abf\nbr -\u003e 08bbd6a91f6f\nes-ES -\u003e 286713a9b605\nes-MX -\u003e df5f0c885400\nfi -\u003e 5753a363a5d7\ngn -\u003e bce17c1770c0\nhe -\u003e 2002601aa301\nka -\u003e 13885e64c635\nlt -\u003e 3e3a7a213482\nnb-NO -\u003e 187888b72f47\nne-NP -\u003e 