f8450810693ab08e79ab0d4702de6f479e678c"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1451511: Add cross-process function hooking to DLL interceptor; r=handyman", "files": ["ipc/mscom/AgileReference.cpp", "ipc/mscom/DynamicallyLinkedFunctionPtr.h", "mozglue/misc/DynamicallyLinkedFunctionPtr.h", "mozglue/misc/WindowsMapRemoteView.cpp", "mozglue/misc/WindowsMapRemoteView.h", "mozglue/misc/interceptor/MMPolicies.h", "mozglue/misc/interceptor/TargetFunction.h", "mozglue/misc/moz.build", "mozglue/misc/nsWindowsDllInterceptor.h", "mozglue/tests/interceptor/TestDllInterceptorCrossProcess.cpp", "mozglue/tests/interceptor/moz.build"], "git_node": null, "git_parents": [null], "node": "eea27e04c541c8f3f1221764b00a4f95de23ef78", "parents": ["184a937c196ee10f884b5e7f6a94b32783d3fec2"], "tags": []}, {"author": "Nick Thomas \u003cnthomas@mozilla.com\u003e", "branch": "default", "desc": "Bug 1425571 - fixups for release notifications, r=aki\n\nSends 'in the candidates directory', 'pushed to cdntest', etc emails only when the underlying dummy tasks succeed, avoiding false messages when graphs are cancelled or the dummy job fails for infrastructure reasons.\n\nAlso sets the body of the email to be the same string as the subject, as we used to do, to avoid unnecessary information about the dummy task.", "files": ["taskcluster/taskgraph/transforms/release_notifications.py"], "git_node": null, "git_parents": [null], "node": "0247bf6522996220bf123f9d8443986fa71e554d", "parents": ["eea27e04c541c8f3f1221764b00a4f95de23ef78"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457662 - [mozdevice] Use separate file object to read shell output for callback; r=bc", "files": ["testing/mozbase/mozdevice/mozdevice/adb.py"], "git_node": null, "git_parents": [null], "node": "1bfab79dc9a7feb92aea531de3b49efde3f20255", "parents": ["0247bf6522996220bf123f9d8443986fa71e554d"], "tags": []},