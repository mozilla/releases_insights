tform/meta/fetch/api/response/response-static-redirect.html.ini"], "git_node": null, "git_parents": [null], "node": "b08c5435b670792c5c311227daf9d2af7382c18d", "parents": ["d9ac927c0b85220a5183f9e22f3c35affd531a8d"], "tags": []}, {"author": "Marijn Kruisselbrink \u003cmek@chromium.org\u003e", "branch": "default", "desc": "Bug 1456267 [wpt PR 10589] - [FileAPI] Synchronously terminate loader when abort is called()., a=testonly\n\nAutomatic update from web-platform-tests[FileAPI] Synchronously terminate loader when abort is called().\n\nOtherwise loads started right after calling abort() won't work.\n\nAlso simplify the watching logic in MojoBlobReader, to prevent hitting\nDCHECKs in OnResponseBodyStreamReady.\n\nBug: 835928\nChange-Id: I45eec517ccaf5f830101b6a02fce2fdcf696d17b\nReviewed-on: https://chromium-review.googlesource.com/1024315\nCommit-Queue: Marijn Kruisselbrink \u003cmek@chromium.org\u003e\nReviewed-by: Daniel Murphy \u003cdmurph@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#553204}\n\n--\n\nwpt-commits: 672248f7d5f2efbc98ff7299fe281e7d83d888c1\nwpt-pr: 10589\n", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/FileAPI/reading-data-section/FileReader-multiple-reads.html"], "git_node": null, "git_parents": [null], "node": "2c593bcd0ca81f9a0abcc2de6f09e40856e8afb6", "parents": ["b08c5435b670792c5c311227daf9d2af7382c18d"], "tags": []}, {"author": "Raymond Toy \u003crtoy@chromium.org\u003e", "branch": "default", "desc": "Bug 1456579 [wpt PR 10609] - Add AudioParam.automationRate to WebAudio IDL, a=testonly\n\nAutomatic update from web-platform-testsAdd AudioParam.automationRate to WebAudio IDL\n\nUpdate WebAudio interface to include the very recently added\nautomationRate attribute for an AudioParam.\n\nAlso remove idlharness time expectation (suggested by Robert Ma).\n\nAnd this doesn't actually resolve any of failures in the bug, but\nit's a convenient place to update the IDL that should have been\ndone earlier.\n\nBug: 836051\nTest: webaudio/idlharness.https.html\nChange-Id: Icd535ee63f0a5f8772cb3445c762c89154fbda88\nReviewed-on: https://chromium-review.googlesource.com/1026199\nReviewed-by: Hongchan Choi \u003chongchan@chromium.org\u003e\nCommit-Queue: Raymond Toy \u003crtoy@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#553218}\n\n--\n\nwpt-commits: ff863cd77ce29ef52ce62ef0d0393e2dbcdf4cc8\nwpt-pr: 10609\n", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/interfaces/web-audio-api.idl"], "git_node": null, "git_parents": [null], "node": "83b0d6237a70b0ea563068fb28bf77a6efd98b42", "parents": ["2c593bcd0ca81f9a0abcc2de6f09e40856e8afb6"], "tags": []}, {"author": "Simon Pieters \u003czcorpan@gmail.com\u003e", "branch": "default", "desc": "Bug 1456191 [wpt PR 10584] - Add css/vendor-imports/mozilla/mozilla-central-reftests/OWNERS, a=testonly\n\nAutomatic update from web-platform-testsAdd Ms2ger to css/vendor-imports/mozilla/OWNERS (#10584)\n\n--\n\nwpt-commits: a39e0345491427d036bae69488b72661e11057f6\nwpt-pr: 10584\n", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/css/vendor-imports/mozilla/OWNERS"], "git_node": null, "git_parents": [null], "node": "7a41836c4ee2e91cd3f58a77fb39fd896ee31669", "parents": ["83b0d6237a70b0ea563068fb28bf77a6efd98b42"], "tags": []}, {"author": "Florian Rivoal \u003cgit@florian.rivoal.net\u003e", "branch": "default", "desc": "Bug 1455648 [wpt PR 10549] - Css contain, a=testonly\n\nAutomatic update from web-platform-testsMerge pull request #10549 from frivoal/css-contain\n\nCss contain\n--\n\nwpt-commits: 17274893c118dafebec900376933248efb2a3735\nwpt-pr: 10549\n", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/css/css-contain/contain-layout-001.html", "testing/web-platform/tests/css/css-contain/contain-layout-002.html", "testing/web-platform/tests/css/css-contain/contain-layout-003.html", "testing/web-platform/tests/css/css-contain/cont