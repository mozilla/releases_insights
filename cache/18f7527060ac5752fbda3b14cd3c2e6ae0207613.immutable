, "toolkit/system/windowsDHCPClient/tests/gtest/moz.build"], "git_node": null, "git_parents": [null, null], "node": "7ef8450810693ab08e79ab0d4702de6f479e678c", "parents": ["4b248e2264b84f8b357c7149136663dfe8d37866", "da9fc8721d47fe25c26371517829e6d8082cadb0"], "tags": []}, {"author": "Francesco Lodolo (:flod) \u003cflod@lodolo.net\u003e", "branch": "default", "desc": "Bug 1457122 - Remove rounded corners in Wikipedia search plugin icon r=adw\n\nMozReview-Commit-ID: CJAV3kH7G20", "files": ["browser/locales/searchplugins/images/wikipedia.ico"], "git_node": null, "git_parents": [null], "node": "69b516d857ccc0d5963074c50243396601d5935e", "parents": ["8480289cd4393653c55b23b0099347751d01dcd8"], "tags": []}, {"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 1456942, part 1 - Always build the IPDL parser test directory. r=Nika\n\nThe ipc/ipdl/test/cxx/ subdirectory is only built when MOZ_IPDL_TESTS\nis set, because it needs special code to be built into the\nbinary. ipdl/ should always be built, because it does not need special\nsupport. This gating is already done in the ipc/ipdl/test/ directory,\nso it shouldn't be done in ipc/ipdl/, because this stops us from\nbuilding it in a regular build.\n\nMozReview-Commit-ID: Jpp0CeXEenR", "files": ["ipc/ipdl/moz.build"], "git_node": null, "git_parents": [null], "node": "158d57ad6f6a16765d2fe3d030016b66ddd4dfd8", "parents": ["69b516d857ccc0d5963074c50243396601d5935e"], "tags": []}, {"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 1456942, part 2 - Pass in a blank message-metadata file. r=Nika\n\nThe IPDL parser now expects a valid message-metadata to be passed in,\neven though we don't need it for parser tests. Fix this by creating\nand specifying a blank one. This fixes a regression from bug 1348591.\n\nMozReview-Commit-ID: HJ34mqBdUyP", "files": ["ipc/ipdl/test/ipdl/Makefile.in", "ipc/ipdl/test/ipdl/message-metadata.ini"], "git_node": null, "git_parents": [null], "node": "c22df4f27b7034071156e86728a5c148c9952565", "parents": ["158d57ad6f6a16765d2fe3d030016b66ddd4dfd8"], "tags": []}, {"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 1456942, part 3 - Specify the error messages for a few tests. r=Nika\n\nFailing IPDL parser tests require that the error message is specified.\n\nMozReview-Commit-ID: IGNTVAb5r0Q", "files": ["ipc/ipdl/test/ipdl/error/AsyncCtorReturns.ipdl", "ipc/ipdl/test/ipdl/error/AsyncCtorReturnsManagee.ipdl"], "git_node": null, "git_parents": [null], "node": "2edbbd0cd6679e6101e369e664d7c6ee870d93f8", "parents": ["c22df4f27b7034071156e86728a5c148c9952565"], "tags": []}, {"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 1456942, part 4 - Add a new test for |using|. r=Nika\n\nBug 1443954 added some new syntax to using, but I noticed that there\nwas not very much existing test coverage, so I wrote a new test that\ncovers all of the possible cases.\n\nMozReview-Commit-ID: JRgHCtXHDLZ", "files": ["ipc/ipdl/test/ipdl/ok/basicUsing.ipdl"], "git_node": null, "git_parents": [null], "node": "1999835b9144d57a44e5969e76cf885f51eba6e1", "parents": ["2edbbd0cd6679e6101e369e664d7c6ee870d93f8"], "tags": []}, {"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 1456942, part 5 - Add test for inconsistent refcounted types. r=Nika\n\nMozReview-Commit-ID: F8WuWQ5n5yk", "files": ["ipc/ipdl/test/ipdl/error/inconsistentRC.ipdl"], "git_node": null, "git_parents": [null], "node": "4cd650ae1a7a2171d7597bf22bdee832b786ddfa", "parents": ["1999835b9144d57a44e5969e76cf885f51eba6e1"], "tags": []}, {"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 1456942, part 6 - Add a test for ByteBuf. r=Nika\n\nByteBuf is a new IPDL built in type, so I wrote a very basic test for\nit, based on shmem.ipdl. It was added in bug 1379680.\n\nMozReview-Commit-ID: 4tbnljpUqCh", "files": ["ipc/ipdl/test/ipdl/ok/bytebuf.ipdl", "ipc/ipdl/test/ipdl/sync-messages.ini"], "git_node": null, "git_parents": [null], "node": "ee07e4d094bda8282ae724360f835f924ecdecd7", "parents": ["4cd650ae1a7a2171d7597bf22bdee832b786ddfa"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457443 - Don't expect WebRender windows if WebRender isn't built. r=milan\n\nMozReview-Commit-ID: 2i25nGMsvxE", "files": ["dom/base/nsDOMWindowUtils.cpp", "dom/interfaces/base/nsIDOMWindowUtils.idl", "gfx/tests/mochitest/test_acceleration.html"], "git_node": null, "git_parents": [null], "node": "cd4f166ad5704b533b2b97d094ef666b4033faae", "parents": ["ee07e4d094bda8282ae724360f835f924ecdecd7"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1454100 - Move cookies around every X seconds r=Ehsan,mayhemer\n\nMozReview-Commit-ID: Y1zUvbDgDX", "files": ["modules/libpref/init/all.js", "netwerk/cookie/CookieServiceChild.cpp", "netwerk/cookie/CookieServiceChild.h"], "git_node": null, "git_parents": [null], "node": "2ac5ad8824e48eb61644c902f54accad7e1b72bc", "parents": ["cd4f166ad5704b533b2b97d094ef666b4033faae"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1454100 - Add some telemetry for time spent moving cookies r=Ehsan,francois,mayhemer\n\nMozReview-Commit-ID: 1pAiKaSok3J", "files": ["netwerk/cookie/CookieServiceChild.cpp", "toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "83a92ca59b1efb3648f4781d5c3aa95e642b24ff", "parents": ["2ac5ad8824e48eb61644c902f54accad7e1b72bc"], "tags": []}, {"author": "Razvan Caliman \u003crcaliman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1451264 - Refactor shape editor to reuse render code for shape update and shape transform. r=pbro\n\nMozReview-Commit-ID: GfURyGeJ17a