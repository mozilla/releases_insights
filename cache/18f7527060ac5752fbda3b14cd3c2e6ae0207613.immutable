git_parents": [null], "node": "d12eec17c51c340722471421b0e8d8fe9894de03", "parents": ["2f83246cb0b1c71fbd1de8ead7438667b588a33d"], "tags": []}, {"author": "Dave Hunt \u003cdhunt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1437593 - Add support for using Pipfiles for managing virtual environment dependencies; r=ted\n\nMozReview-Commit-ID: GWFJZfYWi5Y", "files": ["python/mozbuild/mozbuild/base.py", "python/mozbuild/mozbuild/pipenv.txt", "python/mozbuild/mozbuild/virtualenv.py"], "git_node": null, "git_parents": [null], "node": "60114a93b6b159e0b15dd93fdb52770099304b67", "parents": ["d12eec17c51c340722471421b0e8d8fe9894de03"], "tags": []}, {"author": "Dave Hunt \u003cdhunt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1437593 - Use pipenv for |mach doc| environment; r=ted\n\nMozReview-Commit-ID: Ek2XnJRsDFI", "files": ["tools/docs/Pipfile", "tools/docs/Pipfile.lock", "tools/docs/mach_commands.py", "tools/docs/requirements.txt"], "git_node": null, "git_parents": [null], "node": "c90a0961f52affb99c18891d4167b38ffc270b0a", "parents": ["60114a93b6b159e0b15dd93fdb52770099304b67"], "tags": []}, {"author": "Dave Hunt \u003cdhunt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1437593 - Move initial virtual environment to _virtualenvs/init; r=ted\n\nMozReview-Commit-ID: LP8NVz3tZZg", "files": ["build/moz.configure/init.configure", "js/src/devtools/automation/autospider.py", "python/mozbuild/mozbuild/base.py"], "git_node": null, "git_parents": [null], "node": "ab27411c53c2284886612cf6d300ec8a61c512ef", "parents": ["c90a0961f52affb99c18891d4167b38ffc270b0a"], "tags": []}, {"author": "Dave Hunt \u003cdhunt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1437593 - Exclude third_party directory from linting; r=ted\n\nMozReview-Commit-ID: DrVaFf9e6tf", "files": ["tools/lint/test-disable.yml"], "git_node": null, "git_parents": [null], "node": "8cb34c11ad455e5887a3346d6b4ac019761a77fc", "parents": ["ab27411c53c2284886612cf6d300ec8a61c512ef"], "tags": []}, {"author": "Dave Hunt \u003cdhunt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1437593 - Patch vendored pipenv to remove unused dependencies; r=ted\n\npipenv does not need requests[security] or ordereddict dependencies on Python 2.7 or later.\n\nMozReview-Commit-ID: JH2BnZc1YPx", "files": ["third_party/python/pipenv/setup.py"], "git_node": null, "git_parents": [null], "node": "e4b2357330b4d5f20b306f57aa34e8f74dd45869", "parents": ["8cb34c11ad455e5887a3346d6b4ac019761a77fc"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1455860 - Limit the diagnostic assert for mismatches between main thread and compositor hit testing to Nightly builds only. r=kats\n\nMozReview-Commit-ID: 87DKkb7KmiC", "files": ["gfx/layers/apz/src/InputBlockState.cpp"], "git_node": null, "git_parents": [null], "node": "57b4b1a4f2e60037a687c753c8f780b1a67d31fb", "parents": ["e4b2357330b4d5f20b306f57aa34e8f74dd45869"], "tags": []}, {"author": "Brad Werth \u003cbwerth@mozilla.com\u003e", "branch": "default", "desc": "Bug 1436431 Part 1: Extend PresShell::GetRectVisibility to consider the target frame's scrollable ancestors. r=bz\n\nMozReview-Commit-ID: JIP8ZRNu7fV", "files": ["layout/base/PresShell.cpp", "layout/base/nsIPresShell.h"], "git_node": null, "git_parents": [null], "node": "a51257921d043d55d40971a0e865c6adb2474f91", "parents": ["57b4b1a4f2e60037a687c753c8f780b1a67d31fb"], "tags": []}, {"author": "Brad Werth \u003cbwerth@mozilla.com\u003e", "branch": "default", "desc": "Bug 1436431 Part 2: Change nsTypeAheadFind::IsRangeVisible to additionally check for visibility of range rects; not just the range's primary frame. r=bz\n\nMozReview-Commit-ID: EQFyRswqy5L\n\nSince a range rect can be considerably smaller than the rect of its\ncontaining frame, this change avoids an unpleasant false-negative for\nfind-in-page. Without this change, if a frame is reported as visible,\nbut none of the range rects are visible, the later call to isRangeRendered\nwill report the text as not findable, even though it could be scrolled\ninto view. With this change, the text in such a case is reported as\nfindable, but just out of view, and the find-in-page logic will scroll\nit into view as needed.", "files": ["toolkit/components/typeaheadfind/nsTypeAheadFind.cpp"], "git_node": null, "git_parents": [null], "node": "6d1b03688ba6a671336e9738c0cb839a55d64047", "parents": ["a51257921d043d55d40971a0e865c6adb2474f91"], "tags": []}, {"author": "Brad Werth \u003cbwerth@mozilla.com\u003e", "branch": "default", "desc": "Bug 1436431 Part 3: Add a test to ensure overflow text in the viewport is findable. r=bz\n\nMozReview-Commit-ID: BaXHJlMBmTE", "files": ["toolkit/modules/tests/browser/browser.ini", "toolkit/modules/tests/browser/browser_Finder_overflowed_onscreen.js"], "git_node": null, "git_parents": [null], "node": "477ef0f2e047e270514c9cfeb9a328c0a99a0797", "parents": ["6d1b03688ba6a671336e9738c0cb839a55d64047"], "tags": []}, {"author": "Zibi Braniecki \u003czbraniecki@mozilla.com\u003e", "branch": "default", "desc": "Bug 1456565 - Fetch fallback locale eagerly in Fluent. r=stas\n\nMozReview-Commit-ID: A9wBGxzdD2m", "files": ["intl/l10n/Localization.jsm", "intl/l10n/l10n.js"], "git_node": null, "git_parents": [null], "node": "7f536b6a56e9a5bde853b6b6b18f1864a3cdeb92", "parents": ["477ef0f2e047e270514c9cfeb9a328c0a99a0797"], "tags": []}, {"author": "Brian Grinstead \u003cbgrinstead@mozilla.com\u003e", "branch": "default", "desc": "Bug 1454445 - Put windowtype/positioning attributes on the webconsole html tag to support opening as top-level;r=mossop\n\nWe currently never open this as a top level window (it gets wrapped in browserconsole.xul),\nbut we are working towards it. Putting these attributes on the \u003chtml\u003e tag works similarly to\nputting them on the \u003cwindow\u003e tag in the XUL document and makes it easier to make progress\non missing features.\n\nMozReview-Commit-ID: x6seka5wyf", "files": ["devtools/client/webconsole/webconsole.html"], "git_node": null, "git_parents": [null], "node": "2adfda24e3cd057e07f98e410453da7bd41ec489", "parents": ["7f536b6a56e9a5bde853b6b6b18f1864a3cdeb92"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1456996 - [wdspec] Get named cookie tests have to use a shared custom get_named_cookie command. r=maja_zf\n\nMozReview-Commit-ID: 7r3Krzrv8Wr", "files": ["testing/web-platform/tests/webdriver/tests/cookies/get_named_cookie.py"], "git_node": null, "git_parents": [null], "node": "d1b7f7e210c6663614c8fd03494929ab90c833e8", "parents": ["2adfda24e3cd057e07f98e410453da7bd41ec489"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1456996 - [wdclient] Add http-only support for setting a cookie. r=maja_zf\n\nMozReview-Commit-ID: ZkiNOXK9Wg", "files": ["testing/web-platform/tests/tools/webdriver/webdriver/client.py"], "git_node": null, "git_parents": [null], "node": "1f4ce46796fc2e003c0fa58391f39f3fdf35a944", "parents": ["d1b7f7e210c6663614c8fd03494929ab90c833e8"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1456996 - [wdspec] Fix test_duplicated_cookie for invalid domain usage. r=maja_zf\n\nMozReview-Commit-ID: 9JDmCxxJvAt", "files": ["testing/web-platform/meta/webdriver/tests/cookies/get_named_cookie.py.ini", "testing/web-platform/tests/webdriver/tests/cookies/get_named_cookie.py"], "git_node": null, "git_parents": [null], "node": "9833513330b4f3468b50ffd9f9ee77a9e5f25449", "parents": ["1f4ce46796fc2e003c0fa58391f39f3fdf35a944"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457192 - Add AS Router, frecency bonus and bug fixes to Activity Stream. r=ursula\n\nMozReview-Commit-ID: KUm67PMMNI1", "files": ["browser/extensions/activity-stream/common/Actions.jsm", "browser/extensions/activity-stream/css/activity-stream-linu