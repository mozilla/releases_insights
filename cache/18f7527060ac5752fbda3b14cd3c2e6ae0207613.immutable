t_parents": [null], "node": "1724d1487c83dcfeedeb1a3b2a57a3d9a75ff4d7", "parents": ["8c0c3874c1ad8b225052a4e31cc7f6e70cf83e8e"], "tags": []}], "date": 1527858693, "git_changesets": [null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9306": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nca -\u003e faf6440adfab", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "d5cafc05874cacb1a423ddda6c598a6db05716b1", "parents": ["1724d1487c83dcfeedeb1a3b2a57a3d9a75ff4d7"], "tags": []}], "date": 1527862939, "git_changesets": [null], "user": "ffxbld"}, "9307": {"changesets": [{"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1466166 - Fix test code for bug 1464872 to work with GC zeal. r=sfink, a=test-only", "files": ["js/src/jit-test/tests/gc/bug-1464872.js"], "git_node": null, "git_parents": [null], "node": "d188896a583d22cda4176c132fdbe96c52310996", "parents": ["d5cafc05874cacb1a423ddda6c598a6db05716b1"], "tags": []}, {"author": "Bas Schouten \u003cbschouten@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457110: Restore behavior of maintaining width/height when one of the two is exactly zero. r=jrmuizel, a=RyanVM\n\nMozReview-Commit-ID: 5OpjfTnJQxe", "files": ["gfx/2d/BaseRect.h", "gfx/src/nsRect.h"], "git_node": null, "git_parents": [null], "node": "26ad4f0fc4f3332b17250e9a44c3ba0cae10c508", "parents": ["d188896a583d22cda4176c132fdbe96c52310996"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1460989 - Check page protection flags again after mprotect(). r=glandium, a=RyanVM\n\nWe are apparently still crashing even after mprotect() with write flag\nreturns successfully. This patch reads the flags again after mprotect()\nreturns, and hopefully the flags will tell the truth of whether the page\nis truly writable or not after calling mprotect().\n\nMozReview-Commit-ID: Jsg8vHKFEvJ", "files": ["mozglue/linker/ElfLoader.cpp"], "git_node": null, "git_parents": [null], "node": "6fafce03df13c69f759abf2931f92e79c4e87b07", "parents": ["26ad4f0fc4f3332b17250e9a44c3ba0cae10c508"], "tags": []}, {"author": "J. Ryan Stinnett \u003cjryans@gmail.com\u003e", "branch": "default", "desc": "Bug 1465941 - Fix RDM toolbar icon appearance. r=birtles, a=RyanVM\n\nSome of the RDM toolbar icons relied on `background-size: cover` from the\noverall DevTools button styles, which was removed recently in bug 1442531.  We\nrestore RDM's appearance by copying this style into RDM styles.\n\nMozReview-Commit-ID: KcZwaRgZUsh", "files": ["devtools/client/responsive.html/index.css"], "git_node": null, "git_parents": [null], "node": "42b6bc4b536c92c6ee4c07bf4e9bb2328b2708c4", "parents": ["6fafce03df13c69f759abf2931f92e79c4e87b07"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457929 - Enable container-based segregation of newtab thumbnails on all channels. r=tanvi, a=RyanVM\n\nMozReview-Commit-ID: IpNBIWu2fXh", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "119d817c5c5063391cf549e56e5f792e52220c97", "parents": ["42b6bc4b536c92c6ee4c07bf4e9bb2328b2708c4"], "tags": []}, {"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1465686 - Validate SkArenaAlloc sizes. r=rhunt, a=RyanVM\n\nMozReview-Commit-ID: Cc4cxKeF4xn", "files": ["gfx/skia/skia/src/core/SkArenaAlloc.h"], "git_node": null, "git_parents": [null], "node": "58b05426aa76ce6e07785635fa172cca53862cec", "parents": ["119d817c5c5063391cf549e56e5f792e52220c97"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1464784 - Hold a strong ref to the document in callers of ConvertNodesOrStringsIntoNode. r=smaug, a=abillings", "files": ["dom/base/nsINode.cpp", "dom/base/nsINode.h"], "git_node": null, "git_parents": [null], "node": "2516557db4bff59d5ba30ac154c5559f895e6d9f", "parents": ["58b05426aa76ce6e07785635fa172cca53862cec"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1450689 - Backport upstream pdf.js commit c8b4e6e. r=bdahl, a=RyanVM", "files": ["browser/extensions/pdfjs/content/web/viewer.js"], "git_node": null, "git_parents": [null], "node": "ea977b52d720b47994eb06f984c303a54a842796", "parents": ["2516557db4bff59d5ba30ac154c5559f895e6d9f"], "tags": []}], "date": 1527985494, "git_changesets": [null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9308": {"changesets": [{"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "THUNDERBIRD_60_VERBRANCH", "desc": "No bug: [release-promotion] Make promote notification depend on generating checksums; r=mtabara\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1480", "files": ["taskcluster/ci/release-notify-promote/kind.yml"], "git_node": null, "git_parents": [null], "node": "1aa5415da223e81c44be812c46f15dba8348246d", "parents": ["0c54bd4cec8a19b63970e70d8f8ee8abf9181665"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "THUNDERBIRD_60_VERBRANCH", "desc": "Bug 1237182: [mozharness] Remove some obsolete solaris related configuration; r=catlee\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1482", "files": ["testing/mozharness/configs/releases/bouncer_thunderbird.py"], "git_node": null, "git_parents": [null], "node": "e7eca864a0b0ebf0bbcc18be67fc067505a76c8a", "parents": ["1aa5415da223e81c44be812c46f15dba8348246d"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "THUNDERBIRD_60_VERBRANCH", "desc": "Bug 1456234: [release-promotion] Show bouncer worker tasks on treeherder; r=aki\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1481", "files": ["taskcluster/ci/release-bouncer-aliases/kind.yml", "taskcluster/ci/release-bouncer-sub/kind.yml"], "git_node": null, "git_parents": [null], "node": "4e461aa774737eabc953dc55eaf88a0c5ceb0d9f", "parents": ["e7eca864a0b0ebf0bbcc18be67fc067505a76c8a"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "THUNDERBIRD_60_VERBRANCH", "desc": "No bug: [release] Remove lint leftovers in update-verify docker image; r=bhearsum\n\nRemove some leftover packages from when update-verify docker image was copied\nfrom the lint docker image.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1485", "files": ["taskcluster/docker/update-verify/Dockerfile", "taskcluster/docker/update-verify/system-setup.sh"], "git_node": null, "git_parents": [null], "node": "2850798423097545a7c48c4fc9738c73ecc0b44b", "parents": ["4e461aa774737eabc953dc55eaf88a0c5ceb0d9f"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "THUNDERBIRD_60_VERBRANCH", "desc": "Bug 1458700: [release] Allow passing  extra-config to bouncer-check from taskcluster; r=jlorenzo\n\nThis allows passing configuration like `bouncer_prefix` per-branch, without\nneeding multiple mozharness configs.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1483", "files": ["taskcluster/taskgraph/transforms/bouncer_check.py"], "git_node": null, "git_parents": [null], "node": "06ba090d24967200eb7f5395be9ecbea0d6eea91", "parents": ["2850798423097545a7c48c4fc9738c73ecc0b44b"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "THUNDERBIRD_60_VERBRANCH", "desc": "Bug 1458700: [release] Don't hard-code firefox in bouncer filenames; r=jlorenzo\n\nThis allows thunderbird to be supported.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1484", "files": ["taskcluster/taskgraph/transforms/bouncer_submission.py"], "git_node": null, "git_parents": [null], "node": "f2f040d650a1ee0cb5f07758848852f071f0c44f", "parents": ["06ba090d24967200eb7f5395be9ecbea0d6eea91"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "THUNDERBIRD_60_VERBRANCH", "desc": "No bug: [source-docs] Log the file being uploaded; r=gps a=tomprince\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1479", "files": ["tools/docs/moztreedocs/upload.py"], "git_node": null, "git_parents": [null], "node": "7452048b5f3bb118a0fcaf98bbad859eabf03a2e", "parents": ["f2f040d650a1ee0cb5f07758848852f071f0c44f"], "tags": []}], "date": 1528056649, "git_changesets": [null, null, null, null, null, null, null], "user": "mozilla@hocat.ca"}, "9309": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1465017 - Revert commit b5415b0216c7 (bug 1452604) for broken \"See Details\" button on the blocked site page. a=RyanVM", "files": ["browser/base/content/blockedSite.js", "browser/base/content/blockedSite.xhtml", "browser/base/jar.mn", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "857f7a31e7b38bdc84fcb9242f25c5c8eb729455", "parents": ["ea977b52d720b47994eb06f984c303a54a842796"], "tags": []}, {"author": "k88hudson \u003ck88hudson@gmail.com\u003e", "branch": "default", "desc": "Bug 1464019 - Turn off asrouter snippets when snippets.feed is is false. r=Mardak, a=RyanVM\n\nMozReview-Commit-ID: 87uWePlBGeN", "files": ["browser/extensions/activity-stream/data/content/activity-stream.bundle.js", "browser/extensions/activity-stream/data/content/activity-stream.bundle.js.map", "browser/extensions/activity-stream/install.rdf.in"], "git_node": null, "git_parents": [null], "node": "72fbfbc22b7b8954d7039506b5d63572bac295a3", "parents": ["857f7a31e7b38bdc84fcb9242f25c5c8eb729455"], "tags": []}], "date": 1528117031, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "9310": {"changesets": [{"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1454630 - P1. Simplify retrieval of current TrackInfo. r=bryce, a=RyanVM\n\nAdding some documentation to clarify on the difference between mInfo and mOriginalInfo\n\nMozReview-Commit-ID: DWBsoi16QKf", "files": ["dom/media/MediaFormatReader.cpp", "dom/media/MediaFormatReader.h"], "git_node": null, "git_parents": [null], "node": "66ccbab3ef0f2b4042d2a89ebf89d5e96e4fbc20", "parents": ["72fbfbc22b7b8954d7039506b5d63572bac295a3"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1454630 - P2. Use new PDMFactory whenever encryption type change. r=bryce, r=cpearce, a=RyanVM\n\nIf the content being played was first non-encrypted, the PDMFactory would have been set without a CDMProxy. As such, it is necessary to use a new PDMFactory when the encryption type changes (from clear to encrypted).\n\nRather than attempting to detect if the encryption status has changed, simply use two PDMFactory, one with CDMProxy set and one without (for clear content)\n\nAlso, never attempt to recycle a decoder if the encryption type changed (used only on Android)\n\nThe TrackBuffersManager would have already handle the dispatching of the encrypted event when parsing the new init segment. As such, nothing more is necessary.\n\nMozReview-Commit-ID: Jn14P2F6N5V", "files": ["dom/media/MediaFormatReader.cpp", "dom/media/MediaFormatReader.h"], "git_node": null, "git_parents": [null], "node": "ed4aa0f2e4e3d0dc6e42be601db945310526d6ec", "parents": ["66ccbab3ef0f2b4042d2a89ebf89d5e96e4fbc20"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1454630 - P3. Always recreate the PDMFactory when CDMProxy change. r=bryce, a=RyanVM\n\nThe code couldn't have worked and didn't do what the comment stated. When the CDMProxy changes, the current PDMFactory for encrypted content can no longer be used.\n\nMozReview-Commit-ID: 7LpcQkK5gLL", "files": ["dom/media/MediaFormatReader.cpp"], "git_node": null, "git_parents": [null], "node": "5326f573aaec25b0842d2f2695cce82757fd52e6", "parents": ["ed4aa0f2e4e3d0dc6e42be601db945310526d6ec"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1454630 - P4. Only wait for CDMProxy if actually needed for the given decoder. r=bryce, a=RyanVM\n\nIf the particular track isn't encrypted, there's no need to wait for a CDMProxy.\n\nMozReview-Commit-ID: DPbvbwsO58N", "files": ["dom/media/MediaFormatReader.cpp"], "git_node": null, "git_parents": [null], "node": "b4d1d4787481751c6809033303d3d8381bc56f5c", "parents": ["5326f573aaec25b0842d2f2695cce82757fd52e6"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457661 - P1. Add mochitest. r=bryce, a=RyanVM\n\nMozReview-Commit-ID: 9YC8MaXRF42", "files": ["dom/media/test/mochitest.ini", "dom/media/test/test_arraybuffer.html"], "git_node": null, "git_parents": [null], "node": "8fefcb80fa929da893039edba7e470fc84a88806", "parents": ["b4d1d4787481751c6809033303d3d8381bc56f5c"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457661 - P2. Ensure we call NotifyDataEnded for local resource once size is known. r=bryce, a=RyanVM\n\nA call to NotifyDataEnded is required even if the size was known when the resource was created. This ensures that the readyState is properly updated and that playback can immediately as no more data can be added once first loaded.\n\nMozReview-Commit-ID: FaJMBxJ9NkM", "files": ["dom/media/FileMediaResource.cpp", "dom/media/FileMediaResource.h"], "git_node": null, "git_parents": [null], "node": "8721ccdef78438e3968b2304d62f980817ac9055", "parents": ["8fefcb80fa929da893039edba7e470fc84a88806"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1465103 - Convert service worker and clients release assertions to diagnostic assertions. r=asuth, a=RyanVM", "files": ["dom/clients/manager/ClientHandle.cpp", "dom/clients/manager/ClientHandleOpChild.cpp", "dom/clients/manager/ClientManager.cpp", "dom/clients/manager/ClientThing.h", "dom/serviceworkers/ServiceWorkerManager.cpp"], "git_node": null, "git_parents": [null], "node": "c13cb09f0c253f11b1612633c4d0e32e2af04856", "parents": ["8721ccdef78438e3968b2304d62f980817ac9055"], "tags": ["DEVEDITION_61_0b11_BUILD1", "DEVEDITION_61_0b11_RELEASE", "FENNEC_61_0b11_BUILD1", "FENNEC_61_0b11_RELEASE", "FIREFOX_61_0b11_BUILD1", "FIREFOX_61_0b11_RELEASE"]}], "date": 1528122703, "git_changesets": [null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9311": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nca -\u003e bfb33bbc97d5\ncak -\u003e 7bd01fc5894b\ncs -\u003e 5a046b01a430\nes-AR -\u003e 3aa3d1954e21\net -\u003e ade861d2870d\nfi -\u003e 69194e73981e\ngu-IN -\u003e 791f3705c97e\nhe -\u003e f066187573ec\nid -\u003e 3fdad0304a26\nka -\u003e 3971b7f866ba\nkab -\u003e fa2ed33e9944\nlv -\u003e 739be2c79557\nnn-NO -\u003e f9a82ebc7be6\npt-BR -\u003e 9d5fc47edc48\nru -\u003e 53e1d254c790\nte -\u003e 4a765546993c\nth -\u003e bddc12be55e3\nzh-CN -\u003e 29024efcec08\nzh-TW -\u003e 5a87911919ae", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "aa9a2162fe05e38133728abbab213a8c1e9a8eb1", "parents": ["c13cb09f0c253f11b1612633c4d0e32e2af04856"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\naz -\u003e 543a90e76c47\nbr -\u003e a4dca492d97f\nca -\u003e bfb33bbc97d5\ncak -\u003e 73ff56d32398\ncs -\u003e a76a8882a3a7\nel -\u003e 2c617a1403be\nes-AR -\u003e 3aa3d1954e21\nes-ES -\u003e 33113e95d1b0\nfa -\u003e 5d07e8