s.py"], "git_node": null, "git_parents": [null], "node": "fac7359cd0ada8b6ae5fd5a61854793444f76bf6", "parents": ["c05faf09f5e0502cdba95c591b2a195ccd5d0676"], "tags": []}], "date": 1527243280, "git_changesets": [null, null], "user": "jlorenzo@mozilla.com"}, "9263": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nfi -\u003e 49e1d2dfa8a3", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "5b8d08bc42eb2cbe6d16c3fd5449be06ea60f421", "parents": ["fac7359cd0ada8b6ae5fd5a61854793444f76bf6"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nach -\u003e 3a541b8c294c\nfi -\u003e 49e1d2dfa8a3\nit -\u003e ad879768aecc", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "9daae27e0e231f19ee01555972d8d06f682ccd74", "parents": ["5b8d08bc42eb2cbe6d16c3fd5449be06ea60f421"], "tags": []}], "date": 1527243734, "git_changesets": [null, null], "user": "ffxbld"}, "9264": {"changesets": [{"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1459737 - Add missing package dependencies to google-play-strings Dockerfile; r=nalexander a=release\n\nThis Dockerfile downloads non-deterministic remote content (by cloning a\nGit repo) and then executes code from it. Part of that code is\nexecuting Python package installs.\n\nSince this Docker image was generated, it appears the remote code\nrequires new build dependencies. This commit adds those package\ndependencies.\n\nNot having deterministic Docker image builds is a bug. I'll file a\nfollow-up so we pin the Git commit used for building so this type\nof failure doesn't occur again.", "files": ["taskcluster/docker/google-play-strings/Dockerfile"], "git_node": null, "git_parents": [null], "node": "52f364abcc85336cf3e4fd8f928d570cc4f409a3", "parents": ["9daae27e0e231f19ee01555972d8d06f682ccd74"], "tags": []}], "date": 1527255527, "git_changesets": [null], "user": "jlorenzo@mozilla.com"}, "9265": {"changesets": [{"author": "\"Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e\"", "branch": "default", "desc": "No bug - Tagging 0f95c023462e4de617ebdd77cbe90ec523efad10 with FIREFOX_61_0b8_BUILD1, FIREFOX_61_0b8_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "29b8049f595aec37153495ff4118335051282160", "parents": ["52f364abcc85336cf3e4fd8f928d570cc4f409a3"], "tags": []}, {"author": "\"Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e\"", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "ab22bc7b40a630a5889c82e41802c2eff5b71b00", "parents": ["29b8049f595aec37153495ff4118335051282160"], "tags": []}], "date": 1527260542, "git_changesets": [null, null], "user": "ffxbld"}, "9266": {"changesets": [{"author": "\"Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e\"", "branch": "default", "desc": "No bug - Tagging 0f95c023462e4de617ebdd77cbe90ec523efad10 with DEVEDITION_61_0b8_BUILD1, DEVEDITION_61_0b8_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "35045ad33c886816a1d2d0bf476f0f5e6adfd1f7", "parents": ["ab22bc7b40a630a5889c82e41802c2eff5b71b00"], "tags": []}], "date": 1527260710, "git_changesets": [null], "user": "ffxbld"}, "9267": {"changesets": [{"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1443092 - Crashtest. r=jwatt, a=test-only", "files": ["layout/svg/crashtests/1443092-helper.svg", "layout/svg/crashtests/1443092.html", "layout/svg/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "5ca94fe53b3cb94aad078c4f9ac5e92afdaaa225", "parents": ["35045ad33c886816a1d2d0bf476f0f5e6adfd1f7"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1452653 - [wpt-reftests] Restart after audio_has_no_subtitles.html for false positive. r=jgraham, a=test-only\n\nRestart Firefox after audio_has_no_subtitles.html to prevent a false\npositive for basic.html due to bug 1463844.\n\nMozReview-Commit-ID: 2aNPb1jk2rK", "files": ["testing/web-platform/meta/webvtt/rendering/cues-with-video/processing-model/audio_has_no_subtitles.html.ini"], "git_node": null, "git_parents": [null], "node": "55860ae6ceae12159476a90cf78e8b8823f74e2e", "parents": ["5ca94fe53b3cb94aad078c4f9ac5e92afdaaa225"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1452653 - [marionette] Fix race condition for closing a browser and chrome window. r=ato, a=test-only\n\nUntil now Marionette assumed that the events `TabClose` and `unload`\nindicate that a top-level browsing context or chrome window has been\nclosed. But both events are fired when the browsing context or chrome\nwindow is about to close. As such a race condition can be seen for\nslow running builds.\n\nTo clearly wait until the top-level browsing context or chrome window\nhas been closed, the appropriate message manager needs to be observed\nfor its destroyed state.\n\nMozReview-Commit-ID: DCdaIiULqey", "files": ["testing/marionette/browser.js", "testing/marionette/proxy.js", "testing/marionette/sync.js"], "git_node": null, "git_parents": [null], "node": "e5056e8f46927ecc903ff80d5f08850650c30d09", "parents": ["55860ae6ceae12159476a90cf78e8b8823f74e2e"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1462571 - Check dbus name by dbus_validate_bus_name() before use. r=jhorak, a=RyanVM\n\nMozReview-Commit-ID: AxQp79oyRlm", "files": ["toolkit/components/remote/nsDBusRemoteService.cpp", "widget/xremoteclient/DBusRemoteClient.cpp"], "git_node": null, "git_parents": [null], "node": "a46bd94230c78f0fd9ccb048fbd993901934fcd7", "parents": ["e5056e8f46927ecc903ff80d5f08850650c30d09"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1462497 - Add assertions to try diagnose which wrapper item went away. r=mstange, a=RyanVM\n\nMozReview-Commit-ID: BkU5tTlgFum", "files": ["layout/painting/RetainedDisplayListBuilder.cpp", "layout/painting/RetainedDisplayListBuilder.h", "layout/painting/nsDisplayList.h"], "git_node": null, "git_parents": [null], "node": "4b2b5c188e2ed608af1cafad23e0bf3cd49b2f62", "parents": ["a46bd94230c78f0fd9ccb048fbd993901934fcd7"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1462497 - Part 1: Don't crash if we find an item from the wrong list, and keep looking instead. r=miko, a=RyanVM\n\nWe will still crash in Nightly/DevEdition builds (so that we can fix the bug), but we'll just accept the possible duplication of items (and maybe minor rendering issues) for releases.\n\nMozReview-Commit-ID: LNzjO8vJjGp", "files": ["layout/painting/RetainedDisplayListBuilder.cpp", "layout/painting/nsDisplayList.h"], "git_node": null, "git_parents": [null], "node": "352f0eb7324c06128a648ad94273ca5cb3a19332", "parents": ["4b2b5c188e2ed608af1cafad23e0bf3cd49b2f62"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1462497 - Part 2: Invalidate the new caret frame in subdocuments, since it will result in a new nsDisplayWrapList being created. r=miko, r=mstange, a=RyanVM\n\nnsDisplayListBuilder::DisplayCaret returning true means that we set canSkipWrapList to true, and then we build an nsDisplayWrapList.\nWe need to make sure we're invalidated for this changing in nesting level to be handled.\n\nMozReview-Commit-ID: 4j3WIJDcHtI", "files": ["layout/generic/nsSubDocumentFrame.cpp"], "git_node": null, "git_parents": [null], "node": "cf8f2940def1269022f5b766f3d19bf2c074a658", "parents": ["352f0eb7324c06128a648ad94273ca5cb3a19332"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1462497 - Part 3: Don't condition useOpacity on values that might change silently between paints (HasAnimationsForCompositor, and the will-change budget). r=hiro, a=RyanVM\n\nMozReview-Commit-ID: Kry5YIAIAHt", "files": ["layout/generic/nsFrame.cpp", "layout/painting/nsDisplayList.cpp", "layout/painting/nsDisplayList.h"], "git_node": null, "git_parents": [null], "node": "e33f5999721855e2552b127ab5030ddd7771dda7", "parents": ["cf8f2940def1269022f5b766f3d19bf2c074a658"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1462497 - Part 4: Only use the MayHaveAnimation variants when computing useOpacity in case the more accurate version changes results between paints. r=hiro, a=RyanVM\n\nI don't think this part is necessary, but putting the patch up in case we decide we want to take it.\n\nMozReview-Commit-ID: G0JTNddvZma", "files": ["layout/base/nsLayoutUtils.cpp", "layout/base/nsLayoutUtils.h", "layout/painting/ActiveLayerTracker.cpp", "layout/svg/nsSVGUtils.cpp"], "git_node": null, "git_parents": [null], "node": "3b746f7885d7a1567658cb38207dd2efc87a6785", "parents": ["e33f5999721855e2552b127ab5030ddd7771dda7"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1462497 - Follow-up to fix code that was accidentally inside a MOZ_DIAGNOSTIC_ASSERT_ENABLED block. a=RyanVM", "files": ["layout/painting/nsDisplayList.h"], "git_node": null, "git_parents": [null], "node": "bb4d7af3e4ab0ff4e327bc9975d1671009e9d6c5", "parents": ["3b746f7885d7a1567658cb38207dd2efc87a6785"], "tags": []}], "date": 1527264503, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9268": {"changesets": [{"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1461635 - Enforce a minimum widget size of 1x1 for toolbar separators. r=spohl, a=RyanVM\n\nMozReview-Commit-ID: Gc5TC5DGUI", "files": ["widget/cocoa/nsNativeThemeCocoa.mm"], "git_node": null, "git_parents": [null], "node": "37d3889a39a9672bf365b7ea04c34f6d2fd269ba", "parents": ["bb4d7af3e4ab0ff4e327bc9975d1671009e9d6c5"], "tags": []}, {"author": "Matthew Gaudet \u003cmgaudet@mozilla.com\u003e", "branch": "default", "desc": "Bug 1438556 - Part 1: Use shape guards on the prototype chain for cross-compartment ICs. r=tcampbell, a=RyanVM\n\nThis patch unshares some of the property access code between regular and\ncross-compartment cases, allowing us to use a series of shape-guards on the\nprotochain instead of the previous shape-teleporting checks, that would\nend up baking in a cross-compartment pointer.\n\nThis also attempts to clarify the compartment membership situation while\ndoing the cross-compartment IC.", "files": ["js/src/jit/CacheIR.cpp"], "git_node": null, "git_parents": [null], "node": "df95dfb226bc11073ae15883729aeb39e7fffade", "parents": ["37d3889a39a9672bf365b7ea04c34f6d2fd269ba"], "tags": []}, {"author": "Matthew Gaudet \u003cmgaudet@mozilla.com\u003e", "branch": "default", "desc": "Bug 1438556 - Part 2: Verify global wrapper not nuked. r=tcampbell, a=RyanVM", "files": ["js/src/jit/BaselineCacheIRCompiler.cpp", "js/src/jit/IonCacheIRCompiler.cpp"], "git_node": null, "git_parents": [null], "node": "e5ddad5f46fa12e89a71718ef0a51b068e6f9d58", "parents": ["df95dfb226bc11073ae15883729aeb39e7fffade"], "tags": []}, {"author": "Matthew Gaudet \u003cmgaudet@mozilla.com\u003e", "branch": "default", "desc": "Bug 1438556 - Part 3: Assert same compartment in a number of CacheIR helpers. r=tcampbell, a=RyanVM", "files": ["js/src/jit/CacheIR.cpp", "js/src/jit/CacheIR.h"], "git_node": null, "git_parents": [null], "node": "4f9016111872947597bf2f27afcdeb6af023a7cb", "parents": ["e5ddad5f46fa12e89a71718ef0a51b068e6f9d58"], "tags": []}, {"author": "Mark Hammond \u003cmhammond@skippinet.com.au\u003e", "branch": "default", "desc": "Bug 1463624 - Ensure sync knows there is a valid user on signin. r=eoger, a=RyanVM\n\nMozReview-Commit-ID: 8hGU8eLYZKx", "files": ["services/sync/modules/browserid_identity.js", "services/sync/tests/unit/test_browserid_identity.js"], "git_node": null, "git_parents": [null], "node": "b9105675615d663775ae9e0e18c0a845a7a303e1", "parents": ["4f9016111872947597bf2f27afcdeb6af023a7cb"], "tags": []}, {"author": "Harry Twyford \u003chtwyford@mozilla.com\u003e", "branch": "default", "desc": "Bug 1455950 - Increased contrast on dark theme UI text links. r=dao, a=RyanVM\n\nMozReview-Commit-ID: Kg4opEGVR4H", "files": ["browser/themes/shared/browser.inc.css"], "git_node": null, "git_parents": [null], "node": "5ff34e06b8e60b5a9b31dd0f06023db0538fc905", "parents": ["b9105675615d663775ae9e0e18c0a845a7a303e1"], "tags": []}], "date": 1527266046, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9269": {"changesets": [{"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1451297. r=nical, a=RyanVM", "files": ["gfx/layers/ImageDataSerializer.cpp", "gfx/layers/ImageDataSerializer.h", "gfx/layers/composite/TextureHost.cpp"], "git_node": null, "git_parents": [null], "node": "a341ae7a49c05df8fd382e619f1ceb8958dffba9", "parents": ["5ff34e06b8e60b5a9b31dd0f06023db0538fc905"], "tags": []}, {"author": "Carol Ng \u003ccng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1424100 - Make sidebar text color consistent with panel UI. r=dao, r=eoger, a=RyanVM\n\nMozReview-Commit-ID: 1nWICvZ01q7", "files": ["browser/themes/shared/syncedtabs/sidebar.inc.css"], "git_node": null, "git_parents": [null], "node": "e796c301b3ba87ea1a36bbc2f18d2bb442405fae", "parents": ["a341ae7a49c05df8fd382e619f1ceb8958dffba9"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1461268 - P1. Disable AMD VP9 decoder. r=bryce, a=RyanVM\n\nIt has greatly regressed with recent AMD drivers, providing worse performance than the software decoder under most circumstances.\n\nMozReview-Commit-ID: Jtabi1qhoYF", "files": ["gfx/thebes/gfxPrefs.h", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "eb7e7404aa6de7b0c0541ba98e172fc7f8ce1d99", "parents": ["e796c301b3ba87ea1a36bbc2f18d2bb442405fae"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1461268 - P2. Bump benchmark version ID. r=bryce, a=RyanVM\n\nThis will force the benchmark to be re-run, following de-activation of the AMD VP9 decoder.\n\nMozReview-Commit-ID: KwwoQNfSJ4t", "files": ["dom/media/Benchmark.cpp"], "git_node": null, "git_parents": [null], "node": "d962ee45b396289bc0a528b9584a4e063e8bae7a", "parents": ["eb7e7404aa6de7b0c0541ba98e172fc7f8ce1d99"], "tags": []}, {"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1463244 - Cleanup of swizzle stride calculations. r=rhunt, a=RyanVM\n\nMozReview-Commit-ID: GMXRKnu8zHB", "files": ["gfx/2d/DataSurfaceHelpers.cpp", "gfx/2d/Swizzle.cpp"], "git_node": null, "git_parents": [null], "node": "2e14f2af3e3cfa933e9074bdd9c700a9084f5a2b", "parents": ["d962ee45b396289bc0a528b9584a4e063e8bae7a"], "tags": []}, {"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1462682 - Skia path bounds rounding fix. r=rhunt, a=RyanVM\n\nMozReview-Commit-ID: Lm0XhyLLCCV", "files": ["gfx/skia/skia/src/core/SkScan_Path.cpp"], "git_node": null, "git_parents": [null], "node": "c6e1ff27803d6ff30cb97359748e7ee2d5f3a43f", "parents": ["2e14f2af3e3cfa933e9074bdd9c700a9084f5a2b"], "tags": []}], "date": 1527280941, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9270": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nlv -\u003e 4087dd23898f", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "9c288798bef69a83fdafd8d91508cf72bbd530e0", "parents": ["c6e1ff27803d6ff30cb97359748e7ee2d5f3a43f"], "tags": []}], "date": 1527358860, "git_changesets": [null], "user": "ffxbld"}, "9271": {"changesets": [{"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401842 - Speed up a debugger OOM test. r=jandem, a=test-only", "files": ["js/src/jit-test/tests/debug/bug1370905.js"], "git_node": null, "git_parents": [null], "node": "434606d455734b3815e1a875d28177e8fdf8531e", "parents": ["9c288798bef69a83fdafd8d91508cf72bbd530e0"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1464092 - Speed up some more oomTests that may be taking a long time. r=jandem, a=test-only", "files": ["js/src/jit-test/tests/coverage/bug1214548.js", "js/src/jit-test/tests/debug/bug-1248162.js", "js/src/jit-test/tests/debug/bug-1260725.js", "js/src/jit-test/tests/debug/bug1251919.js", "js/src/jit-test/tests/debug/bug1254123.js", "js/src/jit-test/tests/debug/bug1254190.js", "js/src/jit-test/tests/debug/bug1254578.js", "js/src/jit-test/tests/debug/bug1264961.js", "js/src/jit-test/tests/debug/bug1272908.js", "js/src/jit-test/tests/gc/bug-1226896.js", "js/src/jit-test/tests/gc/bug-1292564.js", "js/src/jit-test/tests/gc/bug-1303015.js", "js/src/jit-test/tests/wasm/regress/oom-eval.js"], "git_node": null, "git_parents": [null], "node": "351490aa7cd0d8aca60a519be06b3b0e2b9b5fd8", "parents": ["434606d455734b3815e1a875d28177e8fdf8531e"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1464368 - Mark a few Atomics tests as \"random\" to avoid frequent intermittents. r=sfink, a=test-only", "files": ["js/src/tests/jstests.list"], "git_node": null, "git_parents": [null], "node": "0d07a98841eb42aa31e19c8d6a8cac0e2a9adbd7", "parents": ["351490aa7cd0d8aca60a519be06b3b0e2b9b5fd8"], "tags": []}, {"author": "Vinothkumar Nagasayanan \u003ccegvinoth@gmail.com\u003e", "branch": "default", "desc": "Bug 1453396 - Tests splitted into two to fix intermittent test timed out. r=ckerschb, a=test-only", "files": ["dom/base/test/mochitest.ini", "dom/base/test/test_bug704320-1.html", "dom/base/test/test_bug704320-2.html", "dom/base/test/test_bug704320.html"], "git_node": null, "git_parents": [null], "node": "f94fff29d17cf53aa1390df917de4f5e428a1a3f", "parents": ["0d07a98841eb42aa31e19c8d6a8cac0e2a9adbd7"], "tags": []}, {"author": "Nils Ohlmeier [:drno] \u003cdrno@ohlmeier.org\u003e", "branch": "default", "desc": "Bug 1439236 - Exit early if m_copym gets called with null ptr. r=dminor, a=RyanVM\n\nCheery-picked upstream commit:\nhttps://github.com/sctplab/usrsctp/commit/d89882d04900c80860874b5eb389b3ed3a0bca3d\n\nMozReview-Commit-ID: 36bYbfIaqEz", "files": ["netwerk/sctp/src/user_mbuf.c"], "git_node": null, "git_parents": [null], "node": "84df66c7e5457a1e93b9b92a9f1987494c0148bb", "parents": ["f94fff29d17cf53aa1390df917de4f5e428a1a3f"], "tags": []}, {"author": "Randell Jesup \u003crjesup@jesup.org\u003e", "branch": "default", "desc": "Bug 1425930 - Handle Broadcast()-\u003eNotify() calling RemoveObserver(). r=froydnj, a=abillings", "files": ["xpcom/ds/Observer.h"], "git_node": null, "git_parents": [null], "node": "9f007f15b9cf5d98308f0a9f1e1356733dc78c11", "parents": ["84df66c7e5457a1e93b9b92a9f1987494c0148bb"], "tags": []}, {"author": "Randell Jesup \u003crjesup@jesup.org\u003e", "branch": "default", "desc": "Bug 1463494 - Delete the sensor observerlist array in a deferred manner. r=froydnj, r=jchen, a=abillings\n\nClean up sensorlist if Dispatch fails.", "files": ["hal/Hal.cpp"], "git_node": null, "git_parents": [null], "node": "2f803318f71f2aa6c3f4ef2edc00305f52f86e38", "parents": ["9f007f15b9cf5d98308f0a9f1e1356733dc78c11"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1449547 - Make subviewbuttons override the toolkit default color for checked toolbarbuttons. r=jaws, a=RyanVM\n\nMozReview-Commit-ID: BMgiyc8wefe", "files": ["browser/themes/shared/customizableui/panelUI.inc.css"], "git_node": null, "git_parents": [null], "node": "abead84db088ec34d6fbb6bfa649d290491d786c", "parents": ["2f803318f71f2aa6c3f4ef2edc00305f52f86e38"], "tags": []}], "date": 1527440108, "git_changesets": [null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9272": {"changesets": [{"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1462635 - Fix disabled text color in webext theme styled popups. r=ntim, a=RyanVM", "files": ["browser/components/nsBrowserGlue.js", "browser/modules/ThemeVariableMap.jsm", "browser/themes/shared/customizableui/panelUI.inc.css", "browser/themes/shared/searchbar.inc.css", "browser/themes/shared/urlbar-autocomplete.inc.css", "toolkit/components/extensions/test/browser/browser_ext_themes_autocomplete_popup.js", "toolkit/modules/LightweightThemeConsumer.jsm", "toolkit/themes/linux/global/global.css", "toolkit/themes/osx/global/global.css", "toolkit/themes/windows/global/global.css"], "git_node": null, "git_parents": [null], "node": "042445c33dc3549e23ab24260b41557c17045bf3", "parents": ["abead84db088ec34d6fbb6bfa649d290491d786c"], "tags": []}], "date": 1527444405, "git_changesets": [null], "user": "ntim.bugs@gmail.com"}, "9273": {"changesets": [{"author": "Brian Birtles \u003cbirtles@gmail.com\u003e", "branch": "default", "desc": "Bug 1463026 - Avoid unnecesarily setting the toolbox buttons when reloading the page; r=jryans a=RyanVM\n\nChangeset https://hg.mozilla.org/mozilla-central/rev/00c968ee4e0c from\nbug 1451592 introduced a DAMP regression on several reload tests. This is\nbecause upon reloading a page we get a series of frame-update messages which\ntell us that we no longer have any iframes only to then tell us we do have\niframes after all. As a result we update the toolbar buttons to remove the\nframes button only to re-add it again. This causes unnecessary updates and\nflicker.\n\nThis patch mitigates this problem by introducing debouncing during\nreloading/navigating so that we only update the toolbar buttons after some\ntimeout of inactivity if there has been a change in the frames button's state.\n\nMozReview-Commit-ID: 3CpEjLfNjbC", "files": ["devtools/client/framework/toolbox.js"], "git_node": null, "git_parents": [null], "node": "1092f6f0d08d1d2450861a6de4770e73f3f9c6e8", "parents": ["042445c33dc3549e23ab24260b41557c17045bf3"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1459352 - Fix disabled text color in webext theme styled control center. r=ntim a=RyanVM\n\nMozReview-Commit-ID: LjXHocbRcXb", "files": ["browser/themes/shared/controlcenter/panel.inc.css"], "git_node": null, "git_parents": [null], "node": "17fdd7dd7ba3a4c25de8adb311b4c3305389d12d", "parents": ["1092f6f0d08d1d2450861a6de4770e73f3f9c6e8"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1464288 - Make sure PreProcessDisplayLists logic for switching AGRs matches what ComputeRebuildRegion uses. r=miko a=RyanVM\n\nMozReview-Commit-ID: F6N0XLCpuEe", "files": ["layout/painting/RetainedDisplayListBuilder.cpp", "layout/reftests/display-list/1464288-1.html", "layout/reftests/display-list/1464288-ref.html", "layout/reftests/display-list/reftest.list"], "git_node": null, "git_parents": [null], "node": "fd2dd9452ccd7b0b22656a4566a136a8c1eb27af", "parents": ["17fdd7dd7ba3a4c25de8adb311b4c3305389d12d"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1451827 - In dark popups styled by webext themes, set --urlbar-popup-url-color and .text-link color to the same value. r=jaws a=RyanVM\n\nMozReview-Commit-ID: 20dLQ4bIBgu", "files": ["browser/themes/shared/browser.inc.css", "browser/themes/shared/urlbar-autocomplete.inc.css", "toolkit/components/extensions/test/browser/browser_ext_themes_autocomplete_popup.js"], "git_node": null, "git_parents": [null], "node": "d81b581fbd2cdb5fcfd982c7d2d3222204192725", "parents": ["fd2dd9452ccd7b0b22656a4566a136a8c1eb27af"], "tags": ["DEVEDITION_61_0b9_BUILD1", "DEVEDITION_61_0b9_RELEASE", "FENNEC_61_0b9_BUILD1", "FENNEC_61_0b9_RELEASE", "FIREFOX_61_0b9_BUILD1", "FIREFOX_61_0b9_RELEASE"]}], "date": 1527498914, "git_changesets": [null, null, null, null], "user": "aiakab@mozilla.com"}, "9274": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\naz -\u003e d45a5ed73982\nbs -\u003e f5655c366a65\nca -\u003e 196c423b351b\ncy -\u003e 77e8f840e0f4\nel -\u003e 2c983e068682\nes-CL -\u003e 8326d1cd0164\nes-ES -\u003e 8e5a8922f299\nes-MX -\u003e 3ddb78cbe04f\nfr -\u003e 180623055631\nfy-NL -\u003e 5de68c695b5a\nhe -\u003e 4fe6810fa6b9\nhi-IN -\u003e 0f2c150a0dff\nhsb -\u003e bad47c3afe74\nhu -\u003e 4032f81b4d62\nka -\u003e c26e3bd0a5b6\nkab -\u003e 90fc724d7754\nlt -\u003e e0ed4b9ef6f4\nms -\u003e c6c28e7376de\nnb-NO -\u003e 87a27edf400f\nne-NP -\u003e 60a0b9d3d5dd\nnn-NO -\u003e 57c3ff9aef56", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "26aca693aff8c81f07c6f3cb69df5768140e7929", "parents": ["d81b581fbd2cdb5fcfd982c7d2d3222204192725"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nach -\u003e 46979926811c\naf -\u003e 7ccf494ff9c7\nan -\u0