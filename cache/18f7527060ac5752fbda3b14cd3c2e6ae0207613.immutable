ack out the first patch in bug 1458063 (propagate wheel event modifiers in APZInputBridge::ReceiveInputEvent). r=kats\n\nThe patch in question is not strictly necessary to fix bug 1458063, and was\ncausing intermittent failures.\n\nMozReview-Commit-ID: 1llW2BkmcXn", "files": ["gfx/layers/apz/src/APZInputBridge.cpp"], "git_node": null, "git_parents": [null], "node": "1120a82a5604c63951f175cce5614702f892a50b", "parents": ["2fe7f347fbbd0d5fd91b918324c85b19bc10e6cf"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1459284 - Ensure GeckoView context menus work with ShadowDOM. r=snorp\n\nMozReview-Commit-ID: 5XrGRgSvh0g", "files": ["mobile/android/chrome/geckoview/GeckoViewContent.js", "mobile/android/components/geckoview/GeckoViewPrompt.js"], "git_node": null, "git_parents": [null], "node": "ff52610ee7b510df332983b02811eedcb299ba21", "parents": ["1120a82a5604c63951f175cce5614702f892a50b"], "tags": []}, {"author": "Thomas Wisniewski \u003cwisniewskit@gmail.com\u003e", "branch": "default", "desc": "Bug 1405552 - Do not expose FileReaderSync to serviceworkers, to match the spec; r=baku,bkelly\n\nMozReview-Commit-ID: 1EJbrt8TXiq", "files": ["dom/serviceworkers/test/test_serviceworker_interfaces.js", "dom/webidl/FileReaderSync.webidl", "testing/web-platform/meta/FileAPI/historical.https.html.ini"], "git_node": null, "git_parents": [null], "node": "82f4604be112cd1f90101218489327d3784b08a9", "parents": ["ff52610ee7b510df332983b02811eedcb299ba21"], "tags": []}, {"author": "Olli Pettay \u003cOlli.Pettay@helsinki.fi\u003e", "branch": "default", "desc": "Bug 1458694 - (android) ensure context menu works with ShadowDOM, r=JanH", "files": ["mobile/android/chrome/content/browser.js"], "git_node": null, "git_parents": [null], "node": "4065e9400f2bdf7715ac87e5721829abfe83e51e", "parents": ["f529be04c5a759773485245b38d75d50a358710c"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to inbound. a=merge CLOSED TREE", "files": ["devtools/client/inspector/inspector.js", "devtools/client/inspector/test/browser_inspector_menu-02-copy-items.js", "devtools/client/shared/webpack/shims/unicode-url-stub.js", "devtools/shared/old-event-emitter.js", "devtools/shared/tests/mochitest/test_eventemitter_basic.html", "devtools/shared/tests/unit/test_old_eventemitter_basic.js", "dom/media/test/file_autoplay_policy_key_blacklist.html", "dom/media/test/test_autoplay_policy_key_blacklist.html", "taskcluster/ci/release-bouncer-aliases/kind.yml", "taskcluster/ci/release-sign-and-push-langpacks/kind.yml", "taskcluster/taskgraph/transforms/job/buildbot.py", "taskcluster/taskgraph/util/bbb_validation.py", "testing/profiles/common/user.js", "testing/profiles/prefs_general.js"], "git_node": null, "git_parents": [null, null], "node": "7ba78b394fcbafc82a925ef3ca8b0ba3ef272b47", "parents": ["4065e9400f2bdf7715ac87e5721829abfe83e51e", "a91ca6e5ca820b53fad9bb98b256934353f5217a"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442893 - disable ts_paint_heavy on osx due to length of time to unpack profile. r=rwood", "files": ["taskcluster/ci/test/test-sets.yml"], "git_node": null, "git_parents": [null], "node": "64703ce328eaa651f03f8ae7346c671a796c3207", "parents": ["7ba78b394fcbafc82a925ef3ca8b0ba3ef272b47"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1455316 - sometimes when test-verify finds a failure, all future tests are marked as failing also. r=gbrown", "files": ["layout/tools/reftest/selftest/test_reftest_output.py", "testing/mochitest/tests/python/test_basic_mochitest_plain.py", "testing/mozharness/mozharness/mozilla/structuredlog.py", "testing/mozharness/mozharness/mozilla/testing/firefox_ui_tests.py", "testing/mozharness/mozharness/mozilla/testing/unittest.py", "testing/mozharness/scripts/android_emulator_unittest.py", "testing/mozharness/scripts/awsy_script.py", "testing/mozharness/scripts/desktop_unittest.py", "testing/mozharness/scripts/marionette.py", "testing/mozharness/scripts/web_platform_tests.py"], "git_node": null, "git_parents": [null], "node": "f124a57ef00abf098b3198c8e8958b982a4d2ef2", "parents": ["64703ce328eaa651f03f8ae7346c671a796c3207"], "tags": []}, {"author": "Brindusan Cristian \u003ccbrindusan@mozilla.com\u003e", "branch": "default", "desc": "Merge inbound to mozilla-central.  a=merge", "files": ["testing/mozharness/configs/releases/bouncer_fennec.py", "testing/mozharness/configs/releases/bouncer_fennec_beta.py", "testing/mozharness/configs/releases/bouncer_firefox_beta.py", "testing/mozharness/configs/releases/bouncer_firefox_devedition.py", "testing/mozharness/configs/releases/bouncer_firefox_esr.py", "testing/mozharness/configs/releases/bouncer_firefox_release.py", "testing/mozharness/configs/releases/dev_bouncer_firefox_beta.py", "testing/mozharness/configs/releases/dev_bouncer_firefox_devedition.py", "testing/mozharness/configs/releases/dev_bouncer_firefox_esr.py"], "git_node": null, "git_parents": [null, null], "node": "5207b1392b11db534550a5eb801302e6dbb58f95", "parents": ["82f4604be112cd1f90101218489327d3784b08a9", "f124a57ef00abf098b3198c8e8958b982a4d2ef2"], "tags": []}, {"author": "Jan Keromnes \u003cjanx@linux.com\u003e", "branch": "default", "desc": "Bug 1458615 - Fix unofficial Android build on systems where $USER is not set. r=nalexander\n\nWhen `--enable-official-branding` isn't set in mozconfig, `./mach configure` executes\nmobile/android/branding/unofficial/configure.sh via `/bin/sh`. The `${USER:-unknown}`\nsyntax is POSIX, so this fix should work across all platforms.\n\nMozReview-Commit-ID: C8T0ZgOFWgV", "files": ["mobile/android/branding/unofficial/configure.sh"], "git_node": null, "git_parents": [null], "node": "1c17442fd10d5a872f330f52c4d0bf4f04ed7edd", "parents": ["82f4604be112cd1f90101218489327d3784b08a9"], "tags": []}, {"author": "Mathieu Leplatre \u003cmathieu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1458827 - Add more information about RemoteSettings for developers r=Gijs,glasserc\n\nMozReview-Commit-ID: 7LEZa6ICBB5", "files": ["services/common/docs/RemoteSettings.rst"], "git_node": null, "git_parents": [null], "node": "a9c753c1bb5d88dcbb666a9eb0a3ad2e2499c72e", "parents": ["1c17442fd10d5a872f330f52c4d0bf4f04ed7edd"], "tags": []}, {"author": "Alex Gaynor \u003cagaynor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1459270 - fixed a regression where IPC was not correctly checking for transitions to actors being dead; r=froydnj\n\nMozReview-Commit-ID: HzhUna0mVpB", "files": ["ipc/ipdl/ipdl/lower.py"], "git_node": null, "git_parents": [null], "node": "abb42d44a7242dc32cb94d955962100305e586ed", "parents": ["a9c753c1bb5d88dcbb666a9eb0a3ad2e2499c72e"], "tags": []}, {"author": "Francois Marier \u003cfrancois@mozilla.com\u003e", "branch": "default", "desc": "Bug 1452445 - Promote MOZ_LOG calls to NS_WARNING in LookupCacheV4. r=gcp\n\nThis should help narrow down which of the code paths is responsible\nfor the intermittent failures we are seeing.\n\nMozReview-Commit-ID: JHVZzixpOg6", "files": ["toolkit/components/url-classifier/LookupCacheV4.cpp"], "git_node": null, "git_parents": [null], "node": "a761c0e32512b44c1bc250bae308bc44a2480294", "parents": ["abb42d44a7242dc32cb94d955962100305e586ed"], "tags": []}, {"author": "Andrew Swan \u003caswan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457209 Manually copy properties for mozAddonManager.getAddonByID results r=zombie\n\nMozReview-Commit-ID: 2lEzGhqlzd1", "files": ["toolkit/mozapps/extensions/AddonManager.jsm"], "git_node": null, "git_parents": [null], "node": "01c0c18cd35571131a5f2a13837cb5c3aaaa23f6", "parents": ["a761c0e32512b44c1bc250bae308bc44a2480294"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1459077 - Install known working pip and virtualenv; r=ted\n\nPreviously, we installed the latest version of pip and virtualenv.\n\nThis commit pins the pip and virtualenv version so we install known\nworking versions (pip 10 breaks the image build for some reason).\n\nMozReview-Commit-ID: hOAMencdcr", "files": ["taskcluster/docker/recipes/ubuntu1604-test-system-setup.sh"], "git_node": null, "git_parents": [null], "node": "2fe749c5c97f074b2cd78dde6c3bb53c0077c21b", "parents": ["01c0c18cd35571131a5f2a13837cb5c3aaaa23f6"], "tags": []}, {"author": "Vlad Baicu \u003cvlad.baicu@softvision.ro\u003e", "branch": "default", "desc": "Bug 1425669 - Move StumblerService location permission check after the intent&scan enabled checks. r=mcomella\n\nOn Android 7.0.0, the OS would start the StumblerService and without having given fennec the location permission the intent and scan enabled checks would've been skipped - which ensure that the Stumbler Service does not run in unadequate scenarios.\n\nMozReview-Commit-ID: AGU67ytE4ff", "files": ["mobile/android/stumbler/java/org/mozilla/mozstumbler/service/stumblerthread/StumblerService.java"], "git_node": null, "git_parents": [null], "node": "bd60840b26cb0b47d40af1a7ec1c7a6f83482b68", "parents": ["2fe749c5c97f074b2cd78dde6c3bb53c0077c21b"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1459293 - Enable new Android fling physics on the Nightly channel. r=kats\n\nMozReview-Commit-ID: EHwhzClIICz", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "49805b8273d6cfdd3168d948ad276b372015d91d", "parents": ["bd60840b26cb0b47d40af1a7ec1c7a6f83482b68"], "tags": []}, {"author": "Gabriele Svelto \u003cgsvelto@mozilla.com\u003e", "branch": "default", "desc": "Bug 1458643 - Use 'Android' as the OS name for Fennec crash pings; r=jchen\n\nMozReview-Commit-ID: 4yPsDbmt1sZ", "files": ["mobile/android/base/java/org/mozilla/gecko/telemetry/pingbuilders/TelemetryCorePingBuilder.java", "mobile/android/base/java/org/mozilla/gecko/telemetry/pingbuilders/TelemetryCrashPingBuilder.java", "mobile/android/base/java/org/mozilla/gecko/telemetry/pingbuilders/TelemetryPingBuilder.java"], "git_node": null, "git_parents": [null], "node": "3c6468b1512e940fca8e8d8076485a42414b0637", "parents": ["49805b8273d6cfdd3168d948ad276b372015d91d"], "tags": []}, {"author": "Brindusan Cristian \u003ccbrindusan@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland. a=merge CLOSED TREE", "files": ["testing/mozharness/configs/releases/bouncer_fennec.py", "testing/mozharness/configs/releases/bouncer_fennec_beta.py", "testing/mozharness/configs/releases/bouncer_firefox_beta.py", "testing/mozharness/configs/releases/bouncer_firefox_devedition.py", "testing/mozharness/configs/releases/bouncer_firefox_esr.py", "testing/mozharness/configs/releases/bouncer_firefox_release.py", "testing/mozharness/configs/releases/dev_bouncer_firefox_beta.py", "testing/mozharness/configs/releases/dev_bouncer_firefox_devedition.py", "testing/mozharness/configs/releases/dev_bouncer_firefox_esr.py"], "git_node": null, "git_parents": [null, null], "node": "031ea9aeb00655ba825df029569d70dbc41f761e", "parents": ["3c6468b1512e940fca8e8d8076485a42414b0637", "5207b1392b11db534550a5eb801302e6dbb58f95"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1454088 - Remove use of google-nocodes. r=adw\n\nMozReview-Commit-ID: 2UYxI0tZNsX", "files": ["browser/components/search/moz.build", "browser/components/search/test/browser_google_behavior.js", "browser/components/search/test/google_nocodes/browser.ini", "browser/locales/search/list.json", "browser/locales/searchplugins/google-nocodes.xml", "mobile/locales/search/list.json", "mobile/locales/searchplugins/google-nocodes.xml", "toolkit/components/telemetry/docs/data/core-ping.rst"], "git_node": null, "git_parents": [null], "node": "4f8e54f8415ee62d60484a4be74a9e3f0df61dbf", "parents": ["031ea9aeb00655ba825df029569d70dbc41f761e"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1458742 - Correct marionette.log.level docs for case insensitivity. r=maja_zf\n\nThe marionette.log.level value is case insensitive and this commit\npoints that out in the documentation associated with the preference.\n\nMozReview-Commit-ID: KZGFE9feFRl", "files": ["testing/geckodriver/README.md", "testing/marionette/prefs/marionette.js"], "git_node": null, "git_parents": [null], "node": "169687fc666d12c9dac44f8ef1ad091bae62f7b5", "parents": ["4f8e54f8415ee62d60484a4be74a9e3f0df61dbf"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1458742 - Add documentation for marionette.* prefs. r=maja_zf\n\nMozReview-Commit-ID: HRWkFQtlsEv", "files": ["testing/marionette/doc/Prefs.md", "testing/marionette/doc/index.rst"], "git_node": null, "git_parents": [null], "node": "e8fb1c6b25972542dcbf9afb16a4cc9fc4cb6a09", "parents": ["169687fc666d12c9dac44f8ef1ad091bae62f7b5"], "tags": []}, {"author": "Panos Astithas \u003cpast@mozilla.com\u003e", "branch": "default", "desc": "Bug 1458760 - Set browser.startup.blankWindow to false on Linux in release versions. r=mconley\n\nMozReview-Commit-ID: 7mKJh3KIHKM", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "c5980d2f915f2999b051fac21f859c769df2b98b", "parents": ["e8fb1c6b25972542dcbf9afb16a4cc9fc4cb6a09"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1457524 part 1 - Use a list for rust tests. r=froydnj\n\nMozReview-Commit-ID: 6A0hHClXDUE", "files": ["build/templates.mozbuild", "config/rules.mk", "python/mozbuild/mozbuild/backend/recursivemake.py", "python/mozbuild/mozbuild/frontend/context.py", "python/mozbuild/mozbuild/frontend/data.py", "python/mozbuild/mozbuild/frontend/emitter.py", "testing/geckodriver/moz.build", "toolkit/library/rust/moz.build"], "git_node": null, "git_parents": [null], "node": "619efecc323332781743562873290a894ee6bd29", "parents": ["c5980d2f915f2999b051fac21f859c769df2b98b"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1457524 part 2 - Run all rust tests regardless of failures. r=froydnj\n\nMozReview-Commit-ID: K4ZhFOWd6gd", "files": ["config/rules.mk"], "git_node": null, "git_parents": [null], "node": "e8616e9830d785506c79ed0280dc8486067c9d46", "parents": ["619efecc323332781743562873290a894ee6bd29"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1457524 part 3 - Check rustdoc for rust tests. r=froydnj\n\nMozReview-Commit-ID: 4qRccUcXq6O", "files": ["build/moz.configure/rust.configure", "build/mozconfig.rust", "config/rules.mk"], "git_node": null, "git_parents": [null], "node": "4340083e6691e1d2aaec806461fd8d355fcf451b", "parents": ["e8616e9830d785506c79ed0280dc8486067c9d46"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1457524 part 4 - Allow 16% false positives in test bloom::create_and_insert_some_stuff. r=heycam\n\nIt seems that the result of hash algorithm used in bloom filter depends\non the pointer length. On 64bit platforms, there are 135 false positives\nin the first part of that test, and 8 in the second part. However, on\n32bit platforms, the numbers become 157 and 16 correspondingly.\n\n16 is still less than 20% in the second part, so all fine, but 157 is\nslightly larger than 15% in the test assertion. Given it is what we are\nshipping, we probably should just accept this and loosen the assertion.\n\nMozReview-Commit-ID: 9kFXBzLFAzE", "files": ["servo/components/selectors/bloom.rs"], "git_node": null, "git_parents": [null], "node": "904aaf73eb3a620cb2ea3f44ee35243e0b385ca9", "parents": ["4340083e6691e1d2aaec806461fd8d355fcf451b"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1457524 part 5 - Add crates with tests into the list of RUST_TESTS. r=froydnj,heycam\n\nMozReview-Commit-ID: AaENV1xKKTg", "files": ["toolkit/library/rust/moz.build"], "git_node": null, "git_parents": [null], "node": "b4ac7ba11da57b93a53df945a1dae2bf21b214d2", "parents": ["904aaf73eb3a620cb2ea3f44ee35243e0b385ca9"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1457524 followup - Unset RUSTDOC for no-compile environment and add it to mozconfigs.", "files": ["browser/config/mozconfigs/linux64/plain-opt", "browser/config/mozconfigs/win64/plain-opt", "build/mozconfig.no-compile"], "git_node": null, "git_parents": [null], "node": "a5832837830da61ee3ccd851d068b28a36951b0b", "parents": ["b4ac7ba11da57b93a53df945a1dae2bf21b214d2"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1458327 - 1. Pass init-data instead of settings to Window; r=esawin\n\nInstead of passing a live settings object to the native Window, pass a\nstatic initialization data bundle to the Window. The bundle contains\nsettings at the time of creation. All changes to settings after creation\nare updated through events, rather than the live object.\n\nUsing a live object between Gecko and UI threads has some drawbacks,\nincluding the need to lock the object, and the fact it won't work with\nremote runtimes across processes.\n\nMozReview-Commit-ID: 1DngLfJ0Fnc", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSession.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSessionSettings.java", "widget/android/EventDispatcher.cpp", "widget/android/nsIAndroidBridge.idl", "widget/android/nsWindow.cpp", "widget/android/nsWindow.h"], "git_node": null, "git_parents": [null], "node": "7a9d7817a640aeec9a48eb37063b6a5c6e7e422b", "parents": ["a5832837830da61ee3ccd851d068b28a36951b0b"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1458327 - 2. Let ModuleManager manage more aspects of modules; r=esawin\n\nLet ModuleManager keep the current settings and enabled states for\nmodules. It initializes settings and module states from the window\ninit-data, and then listens to changes in them.\n\nHaving ModuleManager manage these states helps keeping things\nconsistent, and makes it possible for future optimizations like\ndelay-loading modules.\n\nMozReview-Commit-ID: AM6lAxnUGhd", "files": ["mobile/android/chrome/geckoview/geckoview.js", "mobile/android/modules/geckoview/GeckoViewModule.jsm", "mobile/android/modules/geckoview/GeckoViewNavigation.jsm"], "git_node": null, "git_parents": [null], "node": "f37d7d18d8e740bbb6d556385e94fa884719c217", "parents": ["7a9d7817a640aeec9a48eb37063b6a5c6e7e422b"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1458327 - 3. Make GeckoSessionHandler and GeckoSessionSettings work with init-data; r=esawin\n\nMake GeckoSessionHandler and GeckoSessionSettings use the updated\n\"GeckoView:EnableModule\" and \"GeckoView:UpdateSettings\" events.\n\nAlso, send events for updating settings only while the session is open.\nDon't send events while the session is closed, because when opening the\nsession, we will send settings in one batch in the init-data.\n\nMozReview-Commit-ID: Kytx8Ak4A5p", "files": ["mobile/android/chrome/geckoview/geckoview.js", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSession.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSessionHandler.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSessionSettings.java"], "git_node": null, "git_parents": [null], "node": "5ab8f1a1eb577852a578f643958b8008921da806", "parents": ["f37d7d18d8e740bbb6d556385e94fa884719c217"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1458327 - 4. Always register some events / frame scripts; r=esawin\n\nThe problem is we rely on some events / frame scripts for session calls\nthat should still work even if we don't have a delegate assigned, so we\nshould always register these events / frame scripts.\n\nMozReview-Commit-ID: 6TvvMhc7qOf", "files": ["mobile/android/chrome/geckoview/GeckoViewContent.js", "mobile/android/chrome/geckoview/GeckoViewNavigationContent.js", "mobile/android/modules/geckoview/GeckoViewContent.jsm", "mobile/android/modules/geckoview/GeckoViewContentModule.jsm"], "git_node": null, "git_parents": [null], "node": "3647f62ed6b6f4a45120208a4a1423791ce672e6", "parents": ["5ab8f1a1eb577852a578f643958b8008921da806"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1458327 - 5. Fix some comments; r=jchen\n\nMozReview-Commit-ID: LAgmyGXPPOL", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSession.java"], "git_node": null, "git_parents": [null], "node": "3e1d4faf82ad10e52917fa47a61fc6b67537c27e", "parents": ["3647f62ed6b6f4a45120208a4a1423791ce672e6"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1459296 - Add router snippets, router impression and bug fixes to Activity Stream. r=k88hudson\n\nMozReview-Commit-ID: 58N6MbF4f0z", "files": ["browser/extensions/activity-stream/css/activity-stream-linux.css", "browser/extensions/activity-stream/css/activity-stream-linux.css.map", "browser/extensions/activity-stream/css/activity-stream-mac.css", "browser/extensions/activity-stream/css/activity-stream-mac.css.map", "browser/extensions/activity-stream/css/activity-stream-windows.css", "browser/extensions/activity-stream/css/activity-stream-windows.css.map", "browser/extensions/activity-stream/data/content/activity-stream.bundle.js", "browser/extensions/activity-stream/data/content/activity-stream.bundle.js.map", "browser/extensions/activity-stream/install.rdf.in", "browser/extensions/activity-stream/lib/ASRouter.jsm", "br