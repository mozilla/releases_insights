ls.jsm", "browser/components/places/content/browserPlacesViews.js", "devtools/client/accessibility/test/head.js", "devtools/client/dom/test/head.js", "devtools/client/shared/developer-toolbar.js", "devtools/client/shared/test/shared-head.js", "devtools/client/webconsole/components/JSTerm.js", "devtools/client/webconsole/hudservice.js", "devtools/client/webconsole/test/mochitest/head.js", "devtools/client/webconsole/utils.js", "devtools/server/actors/inspector/css-logic.js", "devtools/server/actors/object/previewers.js", "devtools/server/actors/webbrowser.js", "devtools/server/actors/webconsole/utils.js", "devtools/server/main.js", "devtools/shared/async-utils.js", "devtools/shared/builtin-modules.js", "devtools/shared/webconsole/network-helper.js", "dom/base/test/unit/head_xml.js", "dom/base/test/unit/test_nodelist.js", "dom/base/test/unit/test_range.js", "dom/base/test/unit/test_xml_parser.js", "dom/html/test/test_bug389797.html", "testing/modules/TestUtils.jsm", "toolkit/components/narrate/Narrator.jsm", "toolkit/modules/Console.jsm", "toolkit/mozapps/extensions/AddonManager.jsm", "toolkit/mozapps/extensions/Blocklist.jsm", "toolkit/mozapps/update/nsUpdateService.js"], "git_node": null, "git_parents": [null], "node": "c75434fd510099f93604cd97f1fc9b84f920f314", "parents": ["c29505c32af15fec6c054b3ffe767664feb05c83"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1455674 part 20.  Get rid of nsIDOMElement.  r=qdot", "files": ["dom/base/nsAttrAndChildArray.cpp", "dom/html/nsGenericHTMLElement.cpp", "dom/html/nsGenericHTMLElement.h", "dom/interfaces/base/domstubs.idl", "dom/interfaces/core/moz.build", "dom/interfaces/core/nsIDOMElement.idl", "dom/mathml/nsMathMLElement.cpp", "dom/mathml/nsMathMLElement.h", "dom/svg/DOMSVGLength.h", "dom/svg/SVGAElement.cpp", "dom/svg/SVGFEImageElement.cpp", "dom/svg/SVGImageElement.cpp", "dom/svg/SVGMPathElement.cpp", "dom/svg/SVGSVGElement.cpp", "dom/svg/SVGScriptElement.cpp", "dom/svg/SVGSymbolElement.cpp", "dom/svg/SVGTitleElement.cpp", "dom/svg/nsSVGElement.cpp", "dom/svg/nsSVGElement.h", "dom/svg/nsSVGFilters.h", "dom/xbl/XBLChildrenElement.cpp", "dom/xbl/XBLChildrenElement.h", "dom/xml/nsXMLElement.cpp", "dom/xml/nsXMLElement.h", "dom/xul/nsXULElement.cpp", "dom/xul/nsXULElement.h"], "git_node": null, "git_parents": [null], "node": "2d80f0cc731f75bd8e99382a96ee7f10d6849f17", "parents": ["c75434fd510099f93604cd97f1fc9b84f920f314"], "tags": []}, {"author": "Julian Seward \u003cjseward@acm.org\u003e", "branch": "default", "desc": "Bug 1456382 - LUL: Convert mAdminThreadId check to MOZ_RELEASE_ASSERT.  r=njn.\n\nLUL::mAdminThreadId is used only to assert that certain calls into the LUL\nobject are made on the correct thread.  Because those assertions are done\nusing MOZ_ASSERT, some compilers spot that LUL::mAdminThreadId is unused in\nnon-debug builds, emit a warning to that effect, and then cause the build to\nfail due to the presence of -Werror.\n\nGiven that (1) it's unlikely that people will use the profiler in debug\nbuilds, (2) failure of these assertions is likely to lead to deadlocking or\ncrashing in the profiler, and (3) they don't occur on high-frequency paths,\na good solution seems to be to convert them to MOZ_RELEASE_ASSERTs, hence\ncausing LUL::mAdminThreadId to be used in even in non-debug builds.\n\nIn some cases, related MOZ_ASSERTs relating to LUL::mAdminMode have also\nbeen upgraded to MOZ_RELEASE_ASSERTs, for consistency with the\nLUL::mAdminThreadId changes.", "files": ["tools/profiler/lul/LulMain.cpp"], "git_node": null, "git_parents": [null], "node": "a4538b8ecce8a2fa8a4953dc3f95f19b0b84dd3e", "parents": ["2d80f0cc731f75bd8e99382a96ee7f10d6849f17"], "tags": []}, {"author": "Robert Longson \u003clongsonr@gmail.com\u003e", "branch": "default", "desc": "Bug 1457351 - color attribute should apply to filters. r=heycam", "files": ["dom/svg/SVGFEFloodElement.cpp", "dom/svg/SVGFilterElement.cpp", "dom/svg/nsSVGFilters.cpp", "layout/reftests/svg/filters/feFlood-color-01.svg", "layout/reftests/svg/filters/reftest.list"], "git_node": null, "git_parents": [null], "node": "4b0e963b050b63441999b49a23cc03b6e4406cd5", "parents": ["a4538b8ecce8a2fa8a4953dc3f95f19b0b84dd3e"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Merge inbound to mozilla-central. a=merge", "files": ["dom/base/nsDocument.cpp", "dom/base/nsFocusManager.cpp", "dom/html/nsHTMLDocument.cpp", "dom/interfaces/core/nsIDOMElement.idl", "extensions/spellcheck/hunspell/src/filemgr.cxx", "gfx/layers/moz.build", "gfx/skia/skia/src/core/SkDeviceLooper.cpp", "gfx/skia/skia/src/core/SkDeviceLooper.h", "layout/base/PresShell.cpp", "toolkit/components/extensions/Extension.jsm", "toolkit/components/typeaheadfind/nsTypeAheadFind.cpp", "toolkit/mozapps/extensions/internal/XPIProvider.jsm", "widget/cocoa/nsCocoaWindow.mm"], "git_node": null, "git_parents": [null, null], "node": "d2d518b1f8730eb61554df7179ef9a2aeed4d843", "parents": ["8229360171458d5e2a36fd562e9ba1da6af9b6ba", "4b0e963b050b63441999b49a23cc03b6e4406cd5"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1421062: Enable production beetmoving on comm-central branches; r=aki a=me\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1060", "files": ["taskcluster/taskgraph/util/scriptworker.py"], "git_node": null, "git_parents": [null], "node": "a90bf0a31015017868527c8f11a79a1cdc83c537", "parents": ["d2d518b1f8730eb61554df7179ef9a2aeed4d843"], "tags": []}, {"author": "Jan Odvarko \u003codvarko@gmail.com\u003e", "branch": "default", "desc": "Bug 1456129 - Extend HAR toolbar with import; r=davidwalsh\n\nMozReview-Commit-ID: 2g5sVon7xpk", "files": ["devtools/client/locales/en-US/netmonitor.properties", "devtools/client/netmonitor/src/components/App.js", "devtools/client/netmonitor/src/components/DropHarHandler.js", "devtools/client/netmonitor/src/components/Mon