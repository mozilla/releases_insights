 "default", "desc": "Bug 1455695 P2 Remove ServiceWorkerRegistration::Inner::GetPushManager(). r=baku", "files": ["dom/serviceworkers/ServiceWorkerRegistration.cpp", "dom/serviceworkers/ServiceWorkerRegistration.h", "dom/serviceworkers/ServiceWorkerRegistrationImpl.cpp", "dom/serviceworkers/ServiceWorkerRegistrationImpl.h"], "git_node": null, "git_parents": [null], "node": "8f25c38c4fd68b8b424e020eaeba1b7c780c790b", "parents": ["cd48fe9eb3dd3cc05b5662e9a5d861846ae47f89"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1455695 P3 Remove ServiceWorkerRegistration::Inner::ShowNotification(). r=baku", "files": ["dom/serviceworkers/ServiceWorkerRegistration.cpp", "dom/serviceworkers/ServiceWorkerRegistration.h", "dom/serviceworkers/ServiceWorkerRegistrationImpl.cpp", "dom/serviceworkers/ServiceWorkerRegistrationImpl.h"], "git_node": null, "git_parents": [null], "node": "c21114e606e2d492a2477c9461619ee66f8d8987", "parents": ["8f25c38c4fd68b8b424e020eaeba1b7c780c790b"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1455695 P4 Remove ServiceWorkerRegistration::Inner::GetNotifications(). r=baku", "files": ["dom/serviceworkers/ServiceWorkerRegistration.cpp", "dom/serviceworkers/ServiceWorkerRegistration.h", "dom/serviceworkers/ServiceWorkerRegistrationImpl.cpp", "dom/serviceworkers/ServiceWorkerRegistrationImpl.h"], "git_node": null, "git_parents": [null], "node": "b31ab5129bfc21a90519bc62bfa54b9d913134fa", "parents": ["c21114e606e2d492a2477c9461619ee66f8d8987"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1455695 P5 Remove unused ErrorResult argument from ServiceWorkerRegistration::Inner::Update(). r=baku", "files": ["dom/serviceworkers/ServiceWorkerRegistration.cpp", "dom/serviceworkers/ServiceWorkerRegistration.h", "dom/serviceworkers/ServiceWorkerRegistrationImpl.cpp", "dom/serviceworkers/ServiceWorkerRegistrationImpl.h"], "git_node": null, "git_parents": [null], "node": "d28c827d1e8538b7dd7c957edd927212c32cbcad", "parents": ["b31ab5129bfc21a90519bc62bfa54b9d913134fa"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Bug 1454978 - Move MOZ_ASSERT(mIsMapped) into mChangeMutex. r=bas\n\nWe must check mIsMapped inside mChangeMutex or else we could run into a race condition where\nthe source surface is subsequently mapped again before the function terminates. This was\nbeing hit on try.\n\nMozReview-Commit-ID: 1eot3DVW8VD", "files": ["gfx/2d/SourceSurfaceSkia.cpp"], "git_node": null, "git_parents": [null], "node": "4317518ef41593bd479e7a6e035325a719edc0ce", "parents": ["d28c827d1e8538b7dd7c957edd927212c32cbcad"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Bug 1454978 - Cleanup tiling prefs in all.js. r=bas\n\nThis moves all the tiling prefs into one spot and organizes them a bit. It also fixes a common issue\nwith `edge-padding` being enabled on windows because it wouldn't be defined in all.js and defaulting\nto enabled. Note that `worker-threads` is switched to `-1` by default here instead of just for OSX.\nThis should have no affect because we don't actually create the threads unless we are tiling, which\nonly happens right now on OSX.\n\nMozReview-Commit-ID: D8HOs3yv7w0", "files": ["gfx/thebes/gfxPrefs.h", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "0caaa2b6f3a01295ecc663e16258863a5d64d43b", "parents": ["4317518ef41593bd479e7a6e035325a719edc0ce"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Bug 1454978 - Make OMTP feature detection not depend on tiling. r=bas\n\nThere's a circular dependency between `UsesTiling` and `InitOMTPConfig` because\nwe try to disable OMTP if we will be using tiling and edge padding is enabled.\nNow that edge padding is disabled everywhere except android it should be safe\nto assume that if edge padding is enabled then we'll be using tiling as well\nand should disable OMTP.\n\nThis commit also removes a check on `UsesTiling` from CalculateWorkerCount\nas it is redundant.\n\nMozReview-Commit-ID: 1ruWPwXfLwO", "files": ["gfx/layers/PaintThread.cpp", "gfx/thebes/gfxPlatform.cpp"], "git_node": null, "git_parents": [null], "node": "2ba500ed529be48c75e68b896ae1739f801fed80", "parents": ["0caaa2b6f3a01295ecc663e16258863a5d64d43b"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Bug 1454978 - Enable tiled parallel OMTP when we are using skia on windows on nightly. r=bas\n\nMozReview-Commit-ID: 4zwhIWFMCqv", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "a9f8c9c32b958b0bb963ce529332cb0b3634d86f", "parents": ["2ba500ed529be48c75e68b896ae1739f801fed80"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Bug 1454978 - Update test fuzziness. r=bas\n\nMozReview-Commit-ID: DFDwOo8VsdQ", "files": ["layout/reftests/bugs/reftest.list", "layout/reftests/text-stroke/reftest.list"], "git_node": null, "git_parents": [null], "node": "c460245ddcff73d4a9b24a5f6fb47bb288ca2746", "parents": ["a9f8c9c32b958b0bb963ce529332cb0b3634d86f"], "tags": []}, {"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 1453529 - Update box model diagram in dark theme with new darker colors. r=jdescottes", "files": ["devtools/client/themes/boxmodel.css"], "git_node": null, "git_parents": [null], "node": "74e374831d1c1979235af111ee6d652473a535c5", "parents": ["c460245ddcff73d4a9b24a5f6fb47bb288ca2746"], "tags": []}, {"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 1452206 - Tweak spacing and alignment of items in the Inspector Layout panel. r=jdescottes", "files": ["devtools/client/inspector/layout/components/Accordion.css", "devtools/client/themes/boxmodel.css", "devtools/client/themes/common.css", "devtools/client/themes/layout.css"], "git_node": null, "git_parents": [null], "node": "76f94d0c7c677390f809bf9a3084a3fa3fc5c096", "parents": ["74e374831d1c1979235af111ee6d652473a535c5"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1421062: Enable production nightly balrog update on comm-central branches; r=me a=me", "files": ["taskcluster/taskgraph/util/scriptworker.py"], "git_node": null, "git_parents": [null], "node": "2bbe101d3eda4a50dd3f670ec32cde81ce84aca9", "parents": ["63519bfd42ee379f597c0357af2e712ec3cd9f50"], "tags": []}, {"author": "Jan Odvarko \u003codvarko@gmail.com\u003e", "branch": "default", "desc": "Bug 1456430 - Fix search box focus ring; r=davidwalsh\n\nMozReview-Commit-ID: 8sGrn29wq1s", "files": ["devtools/client/netmonitor/src/assets/styles/Toolbar.css"], "git_node": null, "git_parents": [null], "node": "d256e50b2bf8c3d51142970aa55f65aef914f4c7", "parents": ["f01311ae4951f5ffb0e26a5a30c48527697e5583"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1456755 - Enable ESLint rule no-undef for devtools/{client/scratchpad/,shared/tests/unit}. r=jdescottes\n\nMozReview-Commit-ID: 1GdQdf1y0gc", "files": ["devtools/.eslintrc.js", "devtools/client/scratchpad/scratchpad.js", "devtools/shared/tests/unit/head_devtools.js"], "git_node": null, "git_parents": [null], "node": "4e512b622d80c276bed56fdb45fd573fc7639a92", "parents": ["d256e50b2bf8c3d51142970aa55f65aef914f4c7"], "tags": []}, {"author": "Tiberius Oros \u003ctoros@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland. a=merge CLOSED TREE", "files": [], "git_node": null, "git_parents": [null, null], "node": "951b5d2844931ba037eb7d2b21ba4d7af0d82d3f", "parents": ["4e512b622d80c276bed56fdb45fd573fc7639a92", "63519bfd42ee379f597c0357af2e712ec3cd9f50"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1445728 - fix new tab button adjacency logic to deal with titlebar placeholders and/or indicators appearing in the middle, r=johannh\n\nMozReview-Commit-ID: J0Pc9afJI5X", "files": ["browser/base/content/tabbrowser.xml"], "git_node": null, "git_parents": [null], "node": "dc916a5c4dc81b31f7906df23762e43bca76feef", "parents": ["951b5d2844931ba037eb7d2b21ba4d7af0d82d3f"], "tags": []}, {"author": "Razvan Caliman \u003crcaliman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457838 - Shape editor: account for scrollbars when dragging markers to the edges of the viewport. r=pbro\n\nMozReview-Commit-ID: HsoLfpxZWrh", "files": ["devtools/server/actors/highlighters/shapes.js"], "git_node": null, "git_parents": [null], "node": "f2e2f5d4f04574ca9838d86a2a70be7ccb709db2", "parents": ["dc916a5c4dc81b31f7906df23762e43bca76feef"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400491 - Set up mutation observer before synthesizing composition. r=mikedeboer,ursula\nUndisable test for mac opt and linux32 opt.\n\nMozReview-Commit-ID: 74IZ6VkPdER", "files": ["browser/base/content/test/about/browser.ini", "browser/base/content/test/about/browser_aboutHome_search_composing.js"], "git_node": null, "git_parents": [null], "node": "9306053288b663041576285ae1a0e4c83c52447e", "parents": ["f2e2f5d4f04574ca9838d86a2a70be7ccb709db2"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1450247 - avoid warning spew in browser_findbar.js, r=mikedeboer\n\nMozReview-Commit-ID: DLd4oAKruN1", "files": ["toolkit/content/tests/browser/browser_findbar.js", "toolkit/modules/RemoteFinder.jsm"], "git_node": null, "git_parents": [null], "node": "9cf25c9e5c4608f716998c0ab4b71c3ee40b6301", "parents": ["9306053288b663041576285ae1a0e4c83c52447e"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457255 - 1. Translate kotlin warning/error messages for treeherder; r=nalexander\n\nkotlinc emits its warning/error messages as \"w: \u003cmsg\u003e\" and \"e: \u003cmsg\u003e\",\nwhich Treeherder is unable to pick up. Rather than changing Treeherder,\nit's best to make the change as close to the source of the message as\npossible. I looked at changing mach to redirect the output of gradle and\nmake adjustments as necessary, but for some reason gradle doesn't want\nto work with the pipes that mach sets up. So that leaves changing the\ngradle build script itself.\n\nThis patch adds some code to detect the kotlin messages, and output an\nadjusted version as necessary. It has the benefit of only dealing with\nkotlinc output, so output from other tools should not be inadvertently\nchanged. However, due to the way it is implemented, it does duplicate\nevery warning/error output; for example, an error would now look like\nthis in the terminal:\n\n    \u003cfile\u003e: error: \u003cmsg\u003e\n    e: \u003cfile\u003e: \u003cmsg\u003e\n\nI think this is an acceptable drawback.\n\nMozReview-Commit-ID: 2T0lGsIAcPF", "files": ["mobile/android/geckoview/build.gradle"], "git_node": null, "git_parents": [null], "node": "f179720d3440eec20ab72e35bb7c4fc479fe4b51", "parents": ["9cf25c9e5c4608f716998c0ab4b71c3ee40b6301"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457255 - 2. Fix Java warnings; r=nalexander\n\nFix all Java warnings in the Android codebase except deprecation and\nserial warnings, and warnings in third-party code.\n\nThere is one required change to exoplayer2 code under thirdparty,\nbecause that code is included directly in the geckoview project, instead\nof the thirdparty project. I think I'll just make a pull-request to\nupstream the change, instead of separating exoplayer2 into a\ngv-thirdparty project.\n\nMozReview-Commit-ID: 1JFOO3H7PE6", "files": ["mobile/android/base/java/org/mozilla/gecko/BrowserApp.java", "mobile/android/base/java/org/mozilla/gecko/Tabs.java", "mobile/android/base/java/org/mozilla/gecko/activitystream/ActivityStreamTelemetry.java", "mobile/android/base/java/org/mozilla/gecko/db/BrowserProvider.java", "mobile/android/base/java/org/mozilla/gecko/db/TabsProvider.java", "mobile/android/base/java/org/mozilla/gecko/dlc/BaseAction.java", "mobile/android/base/java/org/mozilla/gecko/dlc/DownloadAction.java", "mobile/android/base/java/org/mozilla/gecko/tabs/TabStrip.java", "mobile/android/base/java/org/mozilla/gecko/toolbar/BrowserToolbar.java", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/rule/GeckoSessionTestRule.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoAppShell.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/gfx/PanZoomController.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSessionSettings.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/SessionAccessibility.java", "mobile/android/geckoview/src/thirdparty/java/com/google/android/exoplayer2/extractor/ogg/DefaultOggSeeker.java", "mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/BaseRobocopTest.java", "mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/MediaPlaybackTest.java", "mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/SessionTest.java", "mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/StringHelper.java", "mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/helpers/WaitHelper.java", "mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/testAudioFocus.java"], "git_node": null, "git_parents": [null], "node": "ed06c8833608c41c9962e11af663f852c4f20833", "parents": ["f179720d3440eec20ab72e35bb7c4fc479fe4b51"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457255 - 3. Turn Java warnings into errors; r=nalexander\n\nTurn Java warnings into errors except for the deprecation and serial\nwarnings. This is done for all Gradle projects except the thirdparty\nproject.\n\nMozReview-Commit-ID: 7bFOPoBmtsc", "files": ["build.gradle"], "git_node": null, "git_parents": [null], "node": "d486c0db4626d70c909bbc57a9dc013b222a7163", "parents": ["ed06c8833608c41c9962e11af663f852c4f20833"], "tags": []}, {"author": "Gurzau Raul \u003crgurzau@mozilla.com\u003e", "branch": "default", "desc": "Backed out 3 changesets (bug 1457255) for bustage on Android builds on a CLOSED TREE\n\nBacked out changeset d486c0db4626 (bug 1457255)\nBacked out changeset ed06c8833608 (bug 1457255)\nBacked out changeset f179720d3440 (bug 1457255)", "files": ["build.gradle", "mobile/android/base/java/org/mozilla/gecko/BrowserApp.java", "mobile/android/base/java/org/mozilla/gecko/Tabs.java", "mobile/android/base/java/org/mozilla/gecko/activitystream/ActivityStreamTelemetry.java", "mobile/android/base/java/org/mozilla/gecko/db/BrowserProvider.java", "mobile/android/base/java/org/mozilla/gecko/db/TabsProvider.java", "mobile/android/base/java/org/mozilla/gecko/dlc/BaseAction.java", "mobile/android/base/java/org/mozilla/gecko/dlc/DownloadAction.java", "mobile/android/base/java/org/mozilla/gecko/tabs/TabStrip.java", "mobile/android/base/java/org/mozilla/gecko/toolbar/BrowserToolbar.java", "mobile/android/geckoview/build.gradle", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/rule/GeckoSessionTestRule.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoAppShell.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/gfx/PanZoomController.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSessionSettings.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/SessionAccessibility.java", "mobile/android/geckoview/src/thirdparty/java/com/google/android/exoplayer2/extractor/ogg/DefaultOggSeeker.java", "mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/BaseRobocopTest.java", "mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/MediaPlaybackTest.java", "mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/SessionTest.java", "mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/StringHelper.java", "mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/helpers/WaitHelper.java", "mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/testAudioFocus.java"], "git_node": null, "git_parents": [null], "node": "076e2b91083973a1fb8c8a79bc36b7c5f3cc4bca", "parents": ["d486c0db4626d70c909bbc57a9dc013b222a7163"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1453360 - Rename NotifyDidCompositeToPipeline to NotifyPipelineRendered. r=nical\n\nThis also rearranges the method implementation slightly to make the next\npatch easier to read. This patch should have zero functional changes,\nit's just refactoring.\n\nMozReview-Commit-ID: 53StJ0TH3IT", "files": ["gfx/layers/ipc/CompositorBridgeParent.cpp", "gfx/layers/ipc/CompositorBridgeParent.h", "gfx/webrender_bindings/RenderThread.cpp"], "git_node": null, "git_parents": [null], "node": "59f4e493272fbd3d4029bb8e58f641e7d4cb8e27", "parents": ["076e2b91083973a1fb8c8a79bc36b7c5f3cc4bca"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1453360 - Store the compositor animation ids to delete until the epoch is rendered. r=nical\n\nWith async scene building, we might get the message to delete certain\ncompositor animation ids while we are still building and rendering\nscenes that have those compositor animations. This patch associates\nthose ids with the epoch at which they are safe to delete, and only does\nthe deletion once we have rendered that epoch.\n\nMozReview-Commit-ID: Jetfcdtwt1q", "files": ["gfx/layers/ipc/CompositorBridgeParent.cpp", "gfx/layers/wr/WebRenderBridgeParent.cpp", "gfx/layer