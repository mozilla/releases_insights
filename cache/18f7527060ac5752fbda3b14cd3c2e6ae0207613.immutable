mozilla.com\u003e", "branch": "default", "desc": "Bug 1457863 - 2. Use kotlin array literals; r=nalexander\n\nUse the new array literal syntax from kotlin 1.2.\n\nMozReview-Commit-ID: CaiG9aSD2T6", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/GeckoSessionTestRuleTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/NavigationDelegateTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/ProgressDelegateTest.kt"], "git_node": null, "git_parents": [null], "node": "fd6be860e5427ee31108bc5d0bdb2e0444af5f85", "parents": ["65c4d7d9eab2db87d540189aa15dc881052e468c"], "tags": []}, {"author": "Brian Grinstead \u003cbgrinstead@mozilla.com\u003e", "branch": "default", "desc": "Bug 1458588 - Create objdir/tmp if it doesn't exist during mach run;r=ahal\n\nThis fixes `./mach run --temp-profile` after a clobber.\n\nMozReview-Commit-ID: 7xoH5RCSpXx", "files": ["python/mozbuild/mozbuild/mach_commands.py"], "git_node": null, "git_parents": [null], "node": "a0f7e5f1bea6466277ba96a2bd22eee6f72930c3", "parents": ["fd6be860e5427ee31108bc5d0bdb2e0444af5f85"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1456234: [release] Use release platforms in generate-checksums tasks; r=aki\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1019", "files": ["taskcluster/ci/release-generate-checksums/kind.yml"], "git_node": null, "git_parents": [null], "node": "c3bb57a157aa91a41f45222bba7db46d90d501f2", "parents": ["bb5befa3fdbaeffe67b145455146f8e8e7c1b6e0"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1456234: [release] Don't use toolchains in source tasks; r=aki\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1053", "files": ["taskcluster/ci/release-source/kind.yml"], "git_node": null, "git_parents": [null], "node": "42f219e3b576d888d37dab87db32ddc28affbdd0", "parents": ["c3bb57a157aa91a41f45222bba7db46d90d501f2"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1456234: [release] Unsplit definition of release-source tasks; r=aki\n\nThe previous definitions are split across to files, but the task are complex\nenough to warrant it.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1054", "files": ["taskcluster/ci/release-source/kind.yml", "taskcluster/ci/release-source/source.yml"], "git_node": null, "git_parents": [null], "node": "3dfd48b02ee08ec1a99f8a31c462de7653fc2bbd", "parents": ["42f219e3b576d888d37dab87db32ddc28affbdd0"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1456234: [release] Use release platforms for source; r=aki\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1055", "files": ["taskcluster/ci/release-source-signing/kind.yml", "taskcluster/ci/release-source/kind.yml", "taskcluster/taskgraph/transforms/beetmover.py", "taskcluster/taskgraph/util/scriptworker.py"], "git_node": null, "git_parents": [null], "node": "3f75f5a447e6309007809b0443f455bf36f89304", "parents": ["3dfd48b02ee08ec1a99f8a31c462de7653fc2bbd"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1456234: Fix yamllint errors; rs=bustage-fix CLOSED TREE", "files": ["taskcluster/ci/release-source/kind.yml"], "git_node": null, "git_parents": [null], "node": "b5e19b4c405849b77d148e5c5486eee27d11cbf4", "parents": ["3f75f5a447e6309007809b0443f455bf36f89304"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1458320 - Ignore Indexed DB stored scopes, as they can now be multiple incorrect values and we no longer need them for anything, r=jorendorff", "files": ["js/src/vm/StructuredClone.cpp"], "git_node": null, "git_parents": [null], "node": "04e165cb504fe603c1b61e1b59342bc0556a25dd", "parents": ["b5e19b4c405849b77d148e5c5486eee27d11cbf4"], "tags": []}, {"author": "Gurzau Raul \u003crgurzau@mozilla.com\u003e", "branch": "default", "desc": "Merge inbound to mozilla-central.  a=merge", "files": ["taskcluster/ci/release-source/source.yml"], "git_node": null, "git_parents": [null, null], "node": "2d83e1843241d869a2fc5cf06f96d3af44c70e70", "parents": ["a0f7e5f1bea6466277ba96a2bd22eee6f72930c3", "04e165cb504fe603c1b61e1b59342bc0556a25dd"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1451143 - Check that the card is updated before proceeding with test. r=MattN\n\nMozReview-Commit-ID: Kh7I9Jc0uQV", "files": ["browser/components/payments/test/browser/browser_card_edit.js"], "git_node": null, "git_parents": [null], "node": "18718bb58de42a44f461e41e1d8fe7922d83f68d", "parents": ["a0f7e5f1bea6466277ba96a2bd22eee6f72930c3"], "tags": []}, {"author": "Rail Aliiev \u003crail@mozilla.com\u003e", "branch": "default", "desc": "Bug 1434889 - Enable release promotion on esr60. r=jlorenzo\nCLOSED TREE", "files": ["taskcluster/taskgraph/util/attributes.py"], "git_node": null, "git_parents": [null], "node": "aa5c4afe0acb45067fe6985bd94f407138f323e0", "parents": ["18718bb58de42a44f461e41e1d8fe7922d83f68d"], "tags": []}, {"author": "Gurzau Raul \u003crgurzau@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland. a=merge CLOSED TREE", "files": ["taskcluster/ci/release-source/source.yml"], "git_node": null, "git_parents": [null, null], "node": "4cd21995f6d93788eeb72e5f62f59dd2861a0a2f", "parents": ["aa5c4afe0acb45067fe6985bd94f407138f323e0", "2d83e1843241d869a2fc5cf06f96d3af44c70e70"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1458591 - Use most recent chrome window for DevTools link helper;r=jryans\n\nMozReview-Commit-ID: 8n5tT8qbAiU", "files": ["devtools/client/framework/components/toolbox-toolbar.js", "devtools/client/performance-new/components/Description.js", "devtools/client/shared/link.js", "devtools/client/shared/test/browser.ini", "devtools/client/shared/test/browser_link.js"], "git_node": null, "git_parents": [null], "node": "5da4a0c6ba28e6ba399624085195cf6c09df170b", "parents": ["4cd21995f6d93788eeb72e5f62f59dd2861a0a2f"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1458591 - remove unused toolbar propType;r=jryans\n\nMozReview-Commit-ID: 8e85Fw4PLNQ", "files": ["devtools/client/framework/components/toolbox-toolbar.js"], "git_node": null, "git_parents": [null], "node": "5be595f4f1d910e7b3a94ff3891924456c30ed00", "parents": ["5da4a0c6ba28e6ba399624085195cf6c09df170b"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1456391 - Part 1: Move nsISessionStoreUtils to Toolkit. r=Nika\n\nWe want to use forEachNonDynamicChildFrame() on Android as well.\n\nMozReview-Commit-ID: E4sJa6gbyuq", "files": ["browser/components/build/nsModule.cpp", "browser/components/sessionstore/moz.build", "browser/components/sessionstore/nsISessionStoreUtils.idl", "browser/components/sessionstore/nsSessionStoreUtils.cpp", "browser/components/sessionstore/nsSessionStoreUtils.h", "toolkit/components/build/nsToolkitCompsModule.cpp", "toolkit/components/moz.build", "toolkit/components/sessionstore/moz.build", "toolkit/components/sessionstore/nsISessionStoreUtils.idl", "toolkit/components/sessionstore/nsSessionStoreUtils.cpp", "toolkit/components/sessionstore/nsSessionStoreUtils.h"], "git_node": null, "git_parents": [null], "node": "1877b11a8fb6e62e88bbc7cb31517a74fae8f6e9", "parents": ["5be595f4f1d910e7b3a94ff3891924456c30ed00"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1456391 - Part 2: Add mapFrameTree to sessionstore's Utils.jsm. r=mikedeboer\n\nGeckoView has already started using a slightly modified version of mapFrameTree,\nand since ssu.forEachNonDynamicChildFrame() has vastly simplified the process of\ncorrectly using FormData/ScrollPosition.collect() for *all* (non-dynamic) child\nframes, we want to use mapFrameTree for Fennec's session store as well.\n\nTherefore, to avoid further duplication of code, we add a common version to the\nsession store's Utils.jsm module.\nWe base the code on the GeckoView implementation of mapFrameTree, which has\ngained the ability to use callback *arrays*, however we still use ssu.forEach-\nNonDynamicChildFrame() like Desktop currently does, instead of simply iterating\nover *all* frames.\n\nMozReview-Commit-ID: 3ilEgNSeCEv", "files": ["toolkit/modules/sessionstore/Utils.jsm"], "git_node": null, "git_parents": [null], "node": "f7e91391e09ff508f807c548cd5f4555c7dbf69a", "parents": ["1877b11a8fb6e62e88bbc7cb31517a74fae8f6e9"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1456391 - Part 3: Use new mapFrameTree version on Desktop. r=mikedeboer\n\nMozReview-Commit-ID: AUQXLPnO1CH", "files": ["browser/components/sessionstore/content/content-sessionStore.js"], "git_node": null, "git_parents": [null], "node": "2f83ddb62a8cad47a45c766917a23f1a3d3bb2bd", "parents": ["f7e91391e09ff508f807c548cd5f4555c7dbf69a"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1456391 - Part 4: Use new mapFrameTree version for GeckoView. r=snorp\n\nThe copy-pasted description of mapFrameTree in GeckoView already claims to only\nrun the callback for *non*-dynamic child frames. With this patch we make\nGeckoView actually do that and unify the behaviour with Desktop.\n\nMozReview-Commit-ID: 6967vUcgB2r", "files": ["mobile/android/chrome/geckoview/GeckoViewContent.js"], "git_node": null, "git_parents": [null], "node": "f36be672c53cc6f42c456c6517c8d4fcbe92b27c", "parents": ["2f83ddb62a8cad47a45c766917a23f1a3d3bb2bd"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1456391 - Part 5: Fix zoom level saving in GeckoView. r=snorp\n\nWhen the scroll position is \"0,0\" or suchlike, the scrolldata ends up as null.\nWe still need something to store the zoom data on, though, so we add a fallback.\n\nMozReview-Commit-ID: FE8BYB9nn25", "files": ["mobile/android/chrome/geckoview/GeckoViewContent.js"], "git_node": null, "git_parents": [null], "node": "f1118e7d03cac87f4121be9c31ae1ddcd0b2b247", "parents": ["f36be672c53cc6f42c456c6517c8d4fcbe92b27c"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1456391 - Part 6: Switch mobile session store to use defineLazyModuleGetters. r=esawin\n\nMozReview-Commit-ID: ElrFACJVbRN", "files": ["mobile/android/components/SessionStore.js"], "git_node": null, "git_parents": [null], "node": "7319a011fac03ca0b823e320db2659178526fc0f", "parents": ["f1118e7d03cac87f4121be9c31ae1ddcd0b2b247"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1456391 - Part 7: Move PrivacyFilter to Toolkit. r=mikedeboer\n\nSince we want to start collecting all form data through mapFrameTree on Fennec,\ntoo, we need to change our filtering strategy for form data.\nWe can no longer bail out directly during the data collection loop and instead\nhave to filter the data after having collected all of it.\n\nThe easiest way to do that is to start using PrivacyFilter.filterFormData() on\nAndroid as well.\n\nMozReview-Commit-ID: GBos4Zn3l2U", "files": ["browser/components/sessionstore/PrivacyFilter.jsm", "browser/components/sessionstore/SessionSaver.jsm", "browser/components/sessionstore/SessionStore.jsm", "browser/components/sessionstore/TabState.jsm", "browser/components/sessionstore/moz.build", "toolkit/modules/moz.build", "toolkit/modules/sessionstore/PrivacyFilter.jsm"], "git_node": null, "git_parents": [null], "node": "8f8e66175fd74c07cbae8f738c8f3ca266288794", "parents": ["7319a011fac03ca0b823e320db2659178526fc0f"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1456391 - Part 8: Use mapFrameTree in Fennec. r=esawin\n\nThis brings us in line with Desktop's session store, in that we can now collect\ndata for arbitrarily nested frame structures.\n\nAt the same time, this also means that we no longer collect data for dynamically\nadded frames, so the corresponding mochitest needs to be adapted accordingly.\n\nMozReview-Commit-ID: DfJ3C2ccUne", "files": ["mobile/android/components/SessionStore.js", "mobile/android/tests/browser/chrome/session_formdata_sample.html"], "git_node": null, "git_parents": [null], "node": "95302e1c0022b11dee5216778b6564de482d947f", "parents": ["8f8e66175fd74c07cbae8f738c8f3ca266288794"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1456391 - Part 9: Support PrivacyLevel form data filtering with GeckoView, too. r=snorp\n\nMozReview-Commit-ID: 9F5ZNWf0lYc", "files": ["mobile/android/chrome/geckoview/GeckoViewContent.js"], "git_node": null, "git_parents": [null], "node": "5969ba522eddc5eeed633ae7f367241f0a503b9d", "parents": ["95302e1c0022b11dee5216778b6564de482d947f"], "tags": []}, {"author": "Jan Odvarko \u003codvarko@gmail.com\u003e", "branch": "default", "desc": "Bug 1429296 - Show MDN link of filter properties when hover the filterbox; r=davidwalsh\n\nMozReview-Commit-ID: H3xmQ95DbiF", "files": ["devtools/client/jar.mn", "devtools/client/locales/en-US/netmonitor.properties", "devtools/client/netmonitor/src/assets/styles/MdnLink.css", "devtools/client/netmonitor/src/assets/styles/Toolbar.css", "devtools/client/netmonitor/src/assets/styles/httpi.css", "devtools/client/netmonitor/src/assets/styles/netmonitor.css", "devtools/client/netmonitor/src/components/HeadersPanel.js", "devtools/client/netmonitor/src/components/MdnLink.js", "devtools/client/netmonitor/src/components/RequestListEmptyNotice.js", "devtools/client/netmonitor/src/components/StatisticsPanel.js", "devtools/client/netmonitor/src/components/TimingsPanel.js", "devtools/client/netmonitor/src/components/Toolbar.js", "devtools/client/netmonitor/src/components/moz.build", "devtools/client/netmonitor/src/utils/mdn-utils.js", "devtools/client/shared/components/MdnLink.css", "devtools/client/shared/components/MdnLink.js", "devtools/client/shared/components/SearchBox.js", "devtools/client/shared/components/moz.build", "devtools/client/themes/common.css"], "git_node": null, "git_parents": [null], "node": "42347190c35aafe874207a55e05ab14cb6f73ddd", "parents": ["5969ba522eddc5eeed633ae7f367241f0a503b9d"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1458566 - Make MediaDecoder::Play() return void. r=bryce\n\nMediaDecoder::Play() cannot fail and was always returning NS_OK\n\nMozReview-Commit-ID: 7OgwZQw569Y", "files": ["dom/html/HTMLMediaElement.cpp", "dom/media/MediaDecoder.cpp", "dom/media/MediaDecoder.h", "dom/media/hls/HLSDecoder.cpp", "dom/media/hls/HLSDecoder.h"], "git_node": null, "git_parents": [null], "node": "d1a03dc50fba506983a294d4a74cee495ff07a73", "parents": ["42347190c35aafe874207a55e05ab14cb6f73ddd"], "tags": []}, {"author": "Kyle Machulis \u003ckyle@nonpolynomial.com\u003e", "branch": "default", "desc": "Bug 1433221 - Revert changes to classid checks for object tags; r=bz\n\nAs part of applet/java plugin removal in bug 1279218, classid checking\nwas removed, as it was not obvious that this was used anywhere other\nthan java plugins. The classid is still a valid attribute on object\ntags (and is sometimes used on tags for flash embedding). We want\nto use a fallback strategy when we find objects with classid\nattributes, as we don't support them, meaning we need to revert our\nprior removal of the check.\n\nMozReview-Commit-ID: BKQ34HGTkvt", "files": ["dom/base/nsObjectLoadingContent.cpp", "dom/base/nsObjectLoadingContent.h", "dom/html/HTMLObjectElement.cpp"], "git_node": null, "git_parents": [null], "node": "66a5836c66b16f6962db7ef0ec7b99d7f7573698", "parents": ["d1a03dc50fba506983a294d4a74cee495ff07a73"], "tags": []}, {"author": "Zibi Braniecki \u003czbraniecki@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457252 - Ensure l10n and initialization are done before sizing the subdialog. r=Gijs\n\nMozReview-Commit-ID: 8YMpRuzz04A", "files": ["browser/components/preferences/applicationManager.js", "browser/components/preferences/applicationManager.xul", "browser/components/preferences/blocklists.js", "browser/components/preferences/clearSiteData.js", "browser/components/preferences/in-content/subdialogs.js"], "git_node": null, "git_parents": [null], "node": "b70479effe0da387e2a00683191411348c9f2c16", "parents": ["66a5836c66b16f6962db7ef0ec7b99d7f7573698"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1380893 - Add CI for plain builds; r=mshal\n\nThis commit adds CI tasks to perform \"plain\" builds. These builds use\nthe same toolchains used by official builds. But that's about it. The\nmozconfig changes are minimal and only set up paths to toolchain\nartifacts. sccache is not used.\n\nThe main goal of these builds is to have a \"reference\" build that\nmatches an out-of-the-box build environment as much as possible. We want\nthis mainly so we have timing and behavior information that matches what\ndevelopers are doing.\n\nThe Windows/generic Taskcluster worker doesn't like it when you specify\nan artifact directory that doesn't exist. So we needed to add a\nmozharness step to ensure UPLOAD_PATH exists to prevent those tasks from\nerroring.\n\nI'm not super thrilled about using mozharness here. We definitely don't\nreally need mozharness. But the main thing it is providing that we care\nabout is the Perfherder metrics data. I don't feel like scope bloating\nto move that out of mozharness at this time.\n\nI only implemented Linux64 and Windows64 because I'm not convinced\ncoverage on 32-bit build variations is useful. Tasks only run on trunk\nbecause they are informational only and we don't need to waste resources\nrunning these on release repos and on Try. They are tier 2 because they\naren't critical to shipping Firefox.\n\nMozReview-Commit-ID: Gl6hGYbFX9b", "files": ["browser/config/mozconfigs/linux64/plain-debug", "browser/config/mozconfigs/linux64/plain-opt", "browser/config/mozconfigs/win64/plain-debug", "browser/config/mozconfigs/win64/plain-opt", "taskcluster/ci/build/linux.yml", "taskcluster/ci/build/windows.yml", "testing/mozharness/configs/builds/releng_sub_linux_configs/64_plain_debug.py", "testing/mozharness/configs/builds/releng_sub_linux_configs/64_plain_opt.py", "testing/mozharness/configs/builds/taskcluster_sub_win64/plain_debug.py", "testing/mozharness/configs/builds/taskcluster_sub_win64/plain_opt.py", "testing/mozharness/mozharness/mozilla/building/buildbase.py", "testing/mozharness/scripts/fx_desktop_build.py"], "git_node": null, "git_parents": [null], "node": "3accdb3ed5074ae1aedd022afc1818725851ce61", "parents": ["b70479effe0da387e2a00683191411348c9f2c16"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457543 - Fix missing Highlights, download position and bug fixes to Activity Stream. r=k88hudson\n\nMozReview-Commit-ID: 3aT0MJ2CJNM", "files": ["browser/components/newtab/aboutNewTabService.js", "browser/extensions/activity-stream/common/PrerenderData.jsm", "browser/extensions/activity-stream/css/activity-stream-linux.css", "browser/extensions/activity-stream/css/activity-stream-linux.css.map", "browser/extensions/activity-stream/css/activity-stream-mac.css", "browser/extensions/activity-stream/css/activity-stream-mac.css.map", "browser/extensions/activity-stream/css/activity-stream-windows.css", "browser/extensions/activity-stream/css/act