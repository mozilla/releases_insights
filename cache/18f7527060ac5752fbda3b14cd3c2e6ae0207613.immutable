vg", "toolkit/themes/shared/findBar.inc.css"], "git_node": null, "git_parents": [null], "node": "a9bd7aeb9874b0c9a9d5788a8b7110dd427321cb", "parents": ["1bd083b09db8a190870b204b61584c1359d89d84"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1392739 - Use CheckedInt in nsStandardURL::Deserialize(). r=mayhemer, a=RyanVM", "files": ["netwerk/base/nsStandardURL.cpp"], "git_node": null, "git_parents": [null], "node": "c8797e136acf3f69a6f9a3c89e9ed6820b002a3e", "parents": ["a9bd7aeb9874b0c9a9d5788a8b7110dd427321cb"], "tags": []}, {"author": "Alex Gaynor \u003cagaynor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1392739 - Add test for faulty nsStandardURL deserialization. r=mayhemer, a=RyanVM", "files": ["netwerk/test/gtest/TestStandardURL.cpp"], "git_node": null, "git_parents": [null], "node": "6c3374416afc7f4d66dc8a33fc55ca693232368b", "parents": ["c8797e136acf3f69a6f9a3c89e9ed6820b002a3e"], "tags": []}, {"author": "Harry Twyford \u003chtwyford@mozilla.com\u003e", "branch": "default", "desc": "Bug 1453722 - Improvements to Dark Theme search bar. r=dao, a=RyanVM\n\nMozReview-Commit-ID: AH3QVBRKymc", "files": ["browser/components/nsBrowserGlue.js", "browser/themes/linux/browser.css", "browser/themes/osx/browser.css", "browser/themes/shared/compacttheme.inc.css", "browser/themes/shared/searchbar.inc.css", "browser/themes/windows/browser.css"], "git_node": null, "git_parents": [null], "node": "2033284fe125e36b725d450863415ab68d7afb9d", "parents": ["6c3374416afc7f4d66dc8a33fc55ca693232368b"], "tags": []}, {"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1457078 - Package default theme icon on Android. r=mcomella, a=RyanVM\n\nMozReview-Commit-ID: 5ewrG6aszUj", "files": ["toolkit/mozapps/extensions/jar.mn"], "git_node": null, "git_parents": [null], "node": "41e0ce725a3b540d6a991eaec5ee101d05baf790", "parents": ["2033284fe125e36b725d450863415ab68d7afb9d"], "tags": []}], "date": 1528248854, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9318": {"changesets": [{"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1463581 - Add browser chrome test. r=johannh, a=RyanVM\n\nMozReview-Commit-ID: JpryAEsiWfN", "files": ["browser/base/content/test/webrtc/browser_devices_get_user_media_paused.js"], "git_node": null, "git_parents": [null], "node": "82d7df6894a7bd76eab313b77bdbfed4c334fcb5", "parents": ["41e0ce725a3b540d6a991eaec5ee101d05baf790"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1463581 - Signal enabled state changes also on UnregisterSink. r=jib, a=RyanVM\n\nMozReview-Commit-ID: FDCO73SdBoL", "files": ["dom/media/MediaStreamTrack.h"], "git_node": null, "git_parents": [null], "node": "32ac9938afd2db7871cc4007d94f64c404599650", "parents": ["82d7df6894a7bd76eab313b77bdbfed4c334fcb5"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1464084 - Don't export std::thread::_M_start_thread symbols with --enable-stdcxx-compat. r=froydnj, a=RyanVM\n\nThis relies on the fact that providing multiple --version-script\ncombines them all, so we effectively create a new symbol version\nthat has no global symbol, but hides the std::thread::_M_start_thread\nsymbols.\n\nThis version script trick happens to work with BFD ld, gold, and lld.\n\nThe downside is that when providing multiple --version-script's, ld\ndoesn't want any of them to have no version at all. So for the libraries\nthat do already have a version script (through SYMBOLS_FILE), we use a\nversion where there used to be none, using the library name as the\nversion. Practically speaking, this binds the libraries a little closer\nthan they used to be, kind of non-flat namespace on OSX (which is the\ndefault there), meaning the dynamic linker will actively want to use\nsymbols from those libraries instead of a system library that might\nhappen to have the same symbol name.", "files": ["build/unix/stdc++compat/hide_std.ld", "build/unix/stdc++compat/moz.build", "python/mozbuild/mozbuild/action/generate_symbols_file.py"], "git_node": null, "git_parents": [null], "node": "4f9a0ee0ac425ba102e553be52a2f7fe1f22ccc9", "parents": ["32ac9938afd2db7871cc4007d94f64c404599650"], "tags": []}, {"author": "Jonathan Kingston \u003cjkt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1465160 - Pass null principal to view image. r=ckerschb, r=Gijs, a=RyanVM", "files": ["browser/base/content/nsContextMenu.js", "browser/extensions/pocket/content/main.js"], "git_node": null, "git_parents": [null], "node": "2d9d187e5b04774262ead862935055387f9d4fa1", "parents": ["4f9a0ee0ac425ba102e553be52a2f7fe1f22ccc9"], "tags": []}, {"author": "Tomislav Jovanovic \u003ctomica@gmail.com\u003e", "branch": "default", "desc": "Bug 1466349 - Part 1: Enable passing addonData flags to embedded WE. r=aswan, a=RyanVM\n\nalso fix permission matcher creation in child process\n\nMozReview-Commit-ID: Ht9rEKwaUsp", "files": ["toolkit/components/extensions/LegacyExtensionsUtils.jsm", "toolkit/components/extensions/extension-process-script.js"], "git_node": null, "git_parents": [null], "node": "68167e946240b461513fbbc3e53b9fbf6f354ba4", "parents": ["2d9d187e5b04774262ead862935055387f9d4fa1"], "tags": []}, {"author": "Tomislav Jovanovic \u003ctomica@gmail.com\u003e", "branch": "default", "desc": "Bug 1466349 - Part 2: Pass addonData to embedded Screenshots WE, add permissions. r=aswan, r=ianbicking, a=RyanVM\n\nMozReview-Commit-ID: GLwjp32sj2i", "files": ["browser/extensions/screenshots/bootstrap.js", "browser/extensions/screenshots/webextension/manifest.json"], "git_node": null, "git_parents": [null], "node": "4a309778103f3906f6963704db8b244b25bf7665", "parents": ["68167e946240b461513fbbc3e53b9fbf6f354ba4"], "tags": []}, {"author": "Tomislav Jovanovic \u003ctomica@gmail.com\u003e", "branch": "default", "desc": "Bug 1466349 - Part 3: Ignore ignorePath for privileged about: MatchPatterns. r=aswan, a=RyanVM\n\nPaths are all about: URIs have, so ignoring them doesn't make sense.\n\nMozReview-Commit-ID: ATwAeI7m61z", "files": ["toolkit/components/extensions/MatchPattern.cpp", "toolkit/components/extensions/test/xpcshell/test_MatchPattern.js"], "git_node": null, "git_parents": [null], "node": "d36c7c1ab6ac171eb4fec4254feaa0132c7da1ed", "parents": ["4a309778103f3906f6963704db8b244b25bf7665"], "tags": []}], "date": 1528249496, "git_changesets": [null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9319": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset 4f9a0ee0ac42 (bug 1464084) for causing SM(pkg) crashes.", "files": ["build/unix/stdc++compat/hide_std.ld", "build/unix/stdc++compat/moz.build", "python/mozbuild/mozbuild/action/generate_symbols_file.py"], "git_node": null, "git_parents": [null], "node": "2e763d5ed8e5eba9cba54780a3142b9365b0cce3", "parents": ["d36c7c1ab6ac171eb4fec4254feaa0132c7da1ed"], "tags": []}], "date": 1528252901, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "9320": {"changesets": [{"author": "Simon Fraser \u003csfraser@mozilla.com\u003e", "branch": "default", "desc": "Bug 1464816 - Run periodic file updates on mozilla-esr60. r=ryanvm, a=release\n\nSummary:\nI've copied the m-c schedule, as the task sometimes\nfails with timeouts. This does add to the releaseduty workload,\nuntil automatic landing is operational.\n\nReviewers: RyanVM\n\nReviewed By: RyanVM\n\nBug #: 1464816\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1438", "files": [".cron.yml"], "git_node": null, "git_parents": [null], "node": "d45bd3bcab72649072fde981062a1b33dd7c65f5", "parents": ["2e763d5ed8e5eba9cba54780a3142b9365b0cce3"], "tags": []}, {"author": "Simon Fraser \u003csfraser@mozilla.com\u003e", "branch": "default", "desc": "Bug 1436369 - Run blocklist updates on mozilla-beta. r=jlorenzo, a=release\n\nSummary:\nthe blocklist and remote-settings changes need to happen on beta,\nbut not the hsts/hpkp updates, so we have to split out the control of what\nruns by project.\n\nReviewers: jlorenzo\n\nReviewed By: jlorenzo\n\nBug #: 1436369\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1487", "files": [".cron.yml", "taskcluster/ci/repo-update/kind.yml", "taskcluster/taskgraph/transforms/repo_update.py"], "git_node": null, "git_parents": [null], "node": "137cbb0160ba4627c2fa672ed691eb63d923279d", "parents": ["d45bd3bcab72649072fde981062a1b33dd7c65f5"], "tags": []}, {"author": "Simon Fraser \u003csfraser@mozilla.com\u003e", "branch": "default", "desc": "Bug 1466552 - Automated file updates for beta/release. r=RyanVM, a=release\n\nEnable blocklist.xml for release, and all updates for beta.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1529", "files": [".cron.yml", "taskcluster/ci/repo-update/kind.yml"], "git_node": null, "git_parents": [null], "node": "51c9cec9f82e55409277981d49a16022991ce449", "parents": ["137cbb0160ba4627c2fa672ed691eb63d923279d"], "tags": []}], "date": 1528292467, "git_changesets": [null, null, null], "user": "ryanvm@gmail.com"}, "9321": {"changesets": [{"author": "qiaopengcheng \u003cqiaopengcheng-hf@loongson.cn\u003e", "branch": "default", "desc": "Bug 1464002 - Implementation error of Atomics.compareExchange on mips. r=lth, a=RyanVM", "files": ["js/src/jit/mips-shared/MacroAssembler-mips-shared.cpp"], "git_node": null, "git_parents": [null], "node": "c7746c6e3a3fca035734cbff097de630358f4454", "parents": ["51c9cec9f82e55409277981d49a16022991ce449"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Bug 1346126 - Use RemoveAllChildren in ~ContainerLayerComposite. r=mattwoodrow, a=RyanVM", "files": ["gfx/layers/composite/ContainerLayerComposite.cpp"], "git_node": null, "git_parents": [null], "node": "f7c7f52e469911753c1a3cfa0efaf44df0f3c846", "parents": ["c7746c6e3a3fca035734cbff097de630358f4454"], "tags": []}, {"author": "Edouard Oger \u003ceoger@fastmail.com\u003e", "branch": "default", "desc": "Bug 1465638 - Do not send capabilities in FxA device registration. r=rfkelly, a=RyanVM\n\nMozReview-Commit-ID: Cf5yk7nSDQE", "files": ["services/fxaccounts/FxAccountsClient.jsm"], "git_node": null, "git_parents": [null], "node": "f44f50d7b7861dc6c768fd269100e80020f33df8", "parents": ["f7c7f52e469911753c1a3cfa0efaf44df0f3c846"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1453127 - Make sure decoder-captured tracks end when changing src. r=jya, a=RyanVM", "files": ["dom/html/HTMLMediaElement.cpp", "dom/html/HTMLMediaElement.h"], "git_node": null, "git_parents": [null], "node": "bfe53eb4206ee42d8df8fe2b91e78c494c1ab771", "parents": ["f44f50d7b7861dc6c768fd269100e80020f33df8"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1453127 - Ensure TrackID uniqueness for captured MediaDecoder. r=jya, a=RyanVM", "files": ["dom/html/HTMLMediaElement.cpp", "dom/html/HTMLMediaElement.h", "dom/media/MediaDecoder.cpp", "dom/media/MediaDecoder.h", "dom/media/MediaDecoderStateMachine.cpp", "dom/media/MediaDecoderStateMachine.h", "dom/media/mediasink/DecodedStream.cpp", "dom/media/mediasink/OutputStreamManager.cpp", "dom/media/mediasink/OutputStreamManager.h"], "git_node": null, "git_parents": [null], "node": "434582a805320135960bb8703486e8a196a011af", "parents": ["bfe53eb4206ee42d8df8fe2b91e78c494c1ab771"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1453127 - Clear output streams on shutdown. r=jya, a=RyanVM", "files": ["dom/media/MediaDecoderStateMachine.cpp", "dom/media/mediasink/OutputStreamManager.cpp", "dom/media/mediasink/OutputStreamManager.h"], "git_node": null, "git_parents": [null], "node": "5218dfec0630b746e33b3fb39553ee248a1fd879", "parents": ["434582a805320135960bb8703486e8a196a011af"], "tags": []}], "date": 1528307668, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9322": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\ndsb -\u003e 2f494c6e7ae0\nfr -\u003e 70b63873b5a2\ngd -\u003e 53e620cf82d4\nit -\u003e 141173523450\nkk -\u003e a34ebee7de2d\nnn-NO -\u003e 14484a01e5ce\noc -\u003e d3ffe75bf187\npt-BR -\u003e 522792e59d98\nsk -\u003e a762e5fe73ff", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "e5fd42fba994e17d38a798a0c6975374f684c1fe", "parents": ["5218dfec0630b746e33b3fb39553ee248a1fd879"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\ncs -\u003e 00c52dfb58b2\nfr -\u003e 9224b04284dd\ngd -\u003e 53e620cf82d4\ngl -\u003e 721a61a3ef3c\nit -\u003e 141173523450\nka -\u003e b6206bfa15fc\nnn-NO -\u003e 41ff2f8d2591\noc -\u003e 50698ad92545\npl -\u003e 3df8d2494962\npt-BR -\u003e 522792e59d98\nsk -\u003e a762e5fe73ff\nsv-SE -\u003e 72301c2df769", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "05c6801d94b997146c6e703cd662b9b0e11e9784", "parents": ["e5fd42fba994e17d38a798a0c6975374f684c1fe"], "tags": []}], "date": 1528309317, "git_changesets": [null, null], "user": "ffxbld"}, "9323": {"changesets": [{"author": "Venkatesh Pitta \u003cvenkateshpitta@gmail.com\u003e", "branch": "default", "desc": "Bug 1348145 - Remove getWindowPosition/setWindowPosition and getWindowSize/setWindowSize. r=whimboo, a=test-only\n\nMozReview-Commit-ID: AUxPhJwOKB6", "files": ["testing/marionette/client/marionette_driver/marionette.py", "testing/marionette/driver.js", "testing/marionette/harness/marionette_harness/tests/unit/test_window_maximize.py", "testing/marionette/harness/marionette_harness/tests/unit/test_window_minimize.py", "testing/marionette/harness/marionette_harness/tests/unit/test_window_rect.py"], "git_node": null, "git_parents": [null], "node": "e4e135dd13f5b95c4f4f0f54c3a6624c93ab498e", "parents": ["05c6801d94b997146c6e703cd662b9b0e11e9784"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1466658 - [geckodriver] Overhaul of user preferences in prefs.rs. r=ato, a=test-only\n\nLots of preferences aren't used anymore, or are safe to set at\nstartup in marionette.js. This also makes them specific to a\nversion of Firefox, and prevents us from keeping fallback\npreferences around in geckodriver.\n\nThis patch bumps the recommended version of Firefox to 57.\n\nMozReview-Commit-ID: Iic6iWFP3Nx", "files": ["testing/geckodriver/CHANGES.md", "testing/geckodriver/README.md", "testing/geckodriver/src/prefs.rs", "testing/marionette/client/marionette_driver/geckoinstance.py", "testing/marionette/components/marionette.js"], "git_node": null, "git_parents": [null], "node": "ebdb496585ab89d5698ff18be74be35c50fe6ff8", "parents": ["e4e135dd13f5b95c4f4f0f54c3a6624c93ab498e"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1321069 - Redirect the end event of a long-tap sequence back to the content window. r=karlt, a=RyanVM\n\nIn the case of a long-tap touch sequence, a new popup window (the\ncontextmenu) is spawned while the sequence is ongoing. The touch-end of\nthe sequence ends up getting delivered to the popup window, instead of\nthe original content window, and that causes the touch-handling\nmachinery state in the content window to get out of sync with reality.\nThis patch detects this scenario and redirects the touch events on the\npopup window back to the original content window.\n\nMozReview-Commit-ID: L2vvKLlogRA", "files": ["widget/gtk/nsWindow.cpp", "widget/gtk/nsWindow.h"], "git_node": null, "git_parents": [null], "node": "9008c3afe6b1c6eee770aa2b853685e0ea89de8e", "parents": ["ebdb496585ab89d5698ff18be74be35c50fe6ff8"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1461023 - Disable the assertion that checks the previous opacity animation value exists when we skip computing opacity animation. r=kats, a=RyanVM\n\nWe are going to re-enable the assertion with a proper fix in bug 1459775.\n\nMozReview-Commit-ID: 2jy6vIImqD", "files": ["gfx/layers/composite/AsyncCompositionManager.cpp"], "git_node": null, "git_parents": [null], "node": "0e891abf73fe0397e6422e7fc1e7f9e0ec46b4a1", "parents": ["9008c3afe6b1c6eee770aa2b853685e0ea89de8e"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1463596 - Ensure that WritableTargetFunction correctly handles changing of protection attributes across regions that straddle page boundaries and have different initial protection attributes. r=handyman, a=RyanVM", "files": ["mozglue/misc/interceptor/TargetFunction.h"], "git_node": null, "git_parents": [null], "node": "ec21a8e58a100227c1180c799753ab5819585e2d", "parents": ["0e891abf73fe0397e6422e7fc1e7f9e0ec46b4a1"], "tags": []}], "date": 1528315529, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9324": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nde -\u003e 854be781b82c\nit -\u003e 58132d496385", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "98ae8291cc7cc8321ee87d0c06aaac3577da8e10", "parents": ["ec21a8e58a100227c1180c799753ab5819585e2d"], "tags": []}], "date": 1528320111, "git_changesets": [null], "user": "ffxbld"}, "9325": {"changesets": [{"author": "Byron Campen [:bwc] \u003cdocfaraday@gmail.com\u003e", "branch": "default", "desc": "Bug 1434983 - Make screenshare and windowshare test one-way, to work around limitations on OS X. r=pehrsons, a=test-only\n\nMozReview-Commit-ID: Ldy7Wb3ZSPQ", "files": ["dom/media/tests/mochitest/test_peerConnection_basicScreenshare.html", "dom/media/tests/mochitest/test_peerConnection_basicWindowshare.html"], "git_node": null, "git_parents": [null], "node": "4395ffa81ea0bb9b8e3b0f40f19b636c9aa183cc", "parents": ["98ae8291cc7cc8321ee87d0c06aaac3577da8e10"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset 6fafce03df13 (bug 1460989) for causing the Galaxy S8 crash rate to spike.", "files": ["mozglue/linker/ElfLoader.cpp"], "git_node": null, "git_parents": [null], "node": "275a429f33cfddd08ad302cbf096740daa793f0b", "parents": ["4395ffa81ea0bb9b8e3b0f40f19b636c9aa183cc"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1464568 - Add an argument to ApplyAsyncProperties() to apply the transform by APZC or not. r=kats, a=RyanVM\n\nIn the next patch, we will introduce a new IPC function to get transform value\nmodified by both animations and APZC.\n\nMozReview-Commit-ID: Uf5UHg5Jm", "files": ["gfx/layers/composite/AsyncCompositionManager.cpp", "gfx/layers/composite/AsyncCompositionManager.h", "gfx/layers/ipc/CompositorBridgeParent.cpp", "gfx/layers/ipc/CompositorBridgeParent.h", "gfx/layers/ipc/CrossProcessCompositorBridgeParent.cpp", "gfx/layers/ipc/CrossProcessCompositorBridgeParent.h", "gfx/layers/ipc/LayerTransactionParent.cpp"], "git_node": null, "git_parents": [null], "node": "503f6513c77449052b85f705023af99ec1b57b9d", "parents": ["275a429f33cfddd08ad302cbf096740daa793f0b"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1464568 - Add an IPC call to get transform value for a given element on the compositor. r=froydnj, r=kats, a=RyanVM\n\nThis function returns the transform value modified by both OMTA and APZC.\nNote that the transform conversion code is almost the same as the code dropped\nin https://hg.mozilla.org/mozilla-central/rev/415811f3804f .\n\nMozReview-Commit-ID: HmsMQp3O4n4", "files": ["gfx/layers/ipc/LayerTransactionParent.cpp", "gfx/layers/ipc/LayerTransactionParent.h", "gfx/layers/ipc/PLayerTransaction.ipdl", "ipc/ipdl/sync-messages.ini"], "git_node": null, "git_parents": [null], "node": "e13452da31b5a79fc85cceb63ac3281c26e02ac3", "parents": ["503f6513c77449052b85f705023af99ec1b57b9d"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1464568 - Add a new function to get transform value on the compositor. r=kats, a=RyanVM\n\nUnlike GetOMTAStyle, this function returns the transform value including both\nof animation and APZ values.  Also this function doesn't work on WebRender.\n\nMozReview-Commit-ID: 4zvxKebD29V", "files": ["dom/base/nsDOMWindowUtils.cpp", "dom/interfaces/base/nsIDOMWindowUtils.idl"], "git_node": null, "git_parents": [null], "node": "8d255e70fccd1b820a2d86b5d080064f0339b580", "parents": ["e13452da31b5a79fc85cceb63ac3281c26e02ac3"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1464568 - Set the shadow base transform for animation explicitly even if the transform value hasn't changed. r=kats, a=RyanVM\n\nThat's because the shadow base transform value might have been changed by APZC.\n\nThe test case in this patch fail without this fix on non-WebRender and the test\ncase is skipped on WebRender since the bug should never happen on WebRender\nbecause WebRender manages animation transform value and APZ transform value\nseparately.\n\nMozReview-Commit-ID: Itgh0QL1su6", "files": ["gfx/layers/apz/test/mochitest/helper_bug1464568_transform.html", "gfx/layers/apz/test/mochitest/mochitest.ini", "gfx/layers/apz/test/mochitest/test_bug1464568.html", "gfx/layers/composite/AsyncCompositionManager.cpp"], "git_node": null, "git_parents": [null], "node": "6c95fd0a106cc788151588f3f478b8fa634ce117", "parents": ["8d255e70fccd1b820a2d86b5d080064f0339b580"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1464568 - Set the shadow base transform value for the case where opacity animations' calculation was skipped. r=kats, a=RyanVM\n\nAnd make DOMWindowUtils.getOMTCTransform work for opacity animations' layer.\n\nMozReview-Commit-ID: 7P99WjYqPr0", "files": ["dom/base/nsDOMWindowUtils.cpp", "gfx/layers/apz/test/mochitest/helper_bug1464568_opacity.html", "gfx/layers/apz/test/mochitest/mochitest.ini", "gfx/layers/apz/test/mochitest/test_bug1464568.html", "gfx/layers/composite/AsyncCompositionManager.cpp"], "git_node": null, "git_parents": [null], "node": "622e8a464432ae5a24c92f78387a0b3a615fd51c", "parents": ["6c95fd0a106cc788151588f3f478b8fa634ce117"], "tags": []}, {"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1466838 - Update --panel-separator-color for dark popups according to spec. r=dao, a=RyanVM\n\nMozReview-Commit-ID: Fc9mhyeX5", "files": ["browser/themes/linux/browser.css", "browser/themes/osx/browser.css", "browser/themes/windows/browser.css"], "git_node": null, "git_parents": [null], "node": "ce1aa76c3226bdedfc8a3f640148afba3621fc3b", "parents": ["622e8a464432ae5a24c92f78387a0b3a615fd51c"], "tags": []}], "date": 1528335316, "git_changesets": [null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9326": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nka -\u003e 0881c4723db9", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "3fb308d1ebcdbe7ea486cbdb05ab90e956c8603f", "parents": ["ce1aa76c3226bdedfc8a3f640148afba3621fc3b"], "tags": []}], "date": 1528348927, "git_changesets": [null], "user": "ffxbld"}, "9327": {"changesets": [{"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1454680 - Skip test_navigation.py to stop crashes for Fennec debug builds. r=jmaher, a=test-only\n\nMozReview-Commit-ID: IUPdjzdoQU9", "files": ["testing/marionette/harness/marionette_harness/tests/unit/unit-tests.ini"], "git_node": null, "git_parents": [null], "node": "0603f248ac4edd6b652d9be67ce31dc83d1666c0", "parents": ["3fb308d1ebcdbe7ea486cbdb05ab90e956c8603f"], "tags": []}, {"author": "Andreas Farre \u003cfarre@mozilla.com\u003e", "branch": "default", "desc": "Bug 1441972 - Add probe for counting docgroups per tabgroup. r=nika, data-review=chutten, a=RyanVM\n\nAdd ACTIVE_DOCGROUPS_PER_TABGROUP and TOTAL_DOCGROUPS_PER_TABGROUP to\ncollect data on how many docgroups a tabgroup has whenever a top level\ncontent document associated with that tabgroup would hide. This gives\na fairly accurate estimate of the number of docgroups a site\nuses. TOTAL_* counts all docgroups while ACTIVE_* only count docgroups\nwith at least one document not in the bfcache.", "files": ["dom/base/DocGroup.cpp", "dom/base/DocGroup.h", "dom/base/TabGroup.cpp", "dom/base/TabGroup.h", "dom/base/nsDocument.cpp", "toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "8c09e327c0f565aa305b877de1b2edd4379fe4a2", "parents": ["0603f248ac4edd6b652d9be67ce31dc83d1666c0"], "tags": []}, {"author": "qiaopengcheng \u003cqiaopengcheng-hf@loongson.cn\u003e", "branch": "default", "desc": "Bug 1465770 - mips64: convertDoubleToInt32 cp1_fcsr error. r=dragan.mladjenovic, a=RyanVM", "files": ["js/src/jit/mips64/MacroAssembler-mips64.cpp"], "git_node": null, "git_parents": [null], "node": "05b0e87031530e7116669074028714e58dec721a", "parents": ["8c09e327c0f565aa305b877de1b2edd4379fe4a2"], "tags": []}, {"author": "qiaopengcheng \u003cqiaopengcheng-hf@loongson.cn\u003e", "branch": "default", "desc": "Bug 1465770 - mips32: convertDoubleToInt32 cp1_fcsr error. r=dragan.mladjenovic, a=RyanVM", "files": ["js/src/jit/mips32/MacroAssembler-mips32.cpp"], "git_node": null, "git_parents": [null], "node": "873262bdac1b9da93249e77d53aefdf2f57d84de", "parents": ["05b0e87031530e7116669074028714e58dec721a"], "tags": ["DEVEDITION_61_0b12_BUILD1", "DEVEDITION_61_0b12_RELEASE", "FENNEC_61_0b12_BUILD1", "FENNEC_61_0b12_RELEASE", "FIREFOX_61_0b12_BUILD1", "FIREFOX_61_0b12_RELEASE"]}], "date": 1528379712, "git_changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "9328": {"changesets": [{"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "THUNDERBIRD_60_VERBRANCH", "desc": "Bug 1421062: [release] Enable production scriptworkers on comm-beta; r=me a=release DONTBUILD", "files": ["taskcluster/taskgraph/util/scriptworker.py"], "git_node": null, "git_parents": [null], "node": "45c948356b4aea2c786eac56d3ca165a2c3d62e0", "parents": ["7452048b5f3bb118a0fcaf98bbad859eabf03a2e"], "tags": []}], "date": 1528388771, "git_changesets": [null], "user": "mozilla@hocat.ca"}, "9329": {"changesets": [{"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "THUNDERBIRD_60_VERBRANCH", "desc": "merge b93eb6ed6167 (FIREFOX_BETA_60_END) to THUNDERBIRD_60_VERBRANCH. a=tomprince DONTBUILD", "files": ["build/pgo/certs/jartests-object.ca", "build/pgo/certs/pgoca.p12", "build/pgo/certs/secmod.db", "build/virtualenv_packages.txt", "taskcluster/taskgraph/decision.py", "taskcluster/taskgraph/target_tasks.py"], "git_node": null, "git_parents": [null, null], "node": "475ee126be734dd153a18e93345026c843ab1634", "parents": ["45c948356b4aea2c786eac56d3ca165a2c3d62e0", "b93eb6ed616746d4744ad9627b92e1e7bae0a689"], "tags": []}], "date": 1528389621, "git_changesets": [null], "user": "mozilla@hocat.ca"}, "9330": {"changesets": [{"author": "L10n Bumper Bot \u003cr