ts": ["2d813a44c44c1c28eeafdf7b43e3149f26d05a46"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1451018 - Convert SymbolActor to protocol.js; r=yulia.\n\nMozReview-Commit-ID: AW2uxeN1tpM", "files": ["devtools/server/actors/object/symbol.js", "devtools/server/tests/unit/test_symbolactor.js", "devtools/shared/specs/index.js", "devtools/shared/specs/moz.build", "devtools/shared/specs/symbol.js"], "git_node": null, "git_parents": [null], "node": "1d4d0038e10aed3211da445f680f1957108b4efa", "parents": ["6e065d127de03d7fee8575a474c5bfaba4f54caf"], "tags": []}, {"author": "Razvan Caliman \u003crcaliman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457206 - Round values for all shape coordinates. r=pbro\n\nMozReview-Commit-ID: H2fspzF5mYz", "files": ["devtools/server/actors/highlighters/shapes.js"], "git_node": null, "git_parents": [null], "node": "4421b373b86a8cb14b4f92dc5c7735f92925f9b1", "parents": ["1d4d0038e10aed3211da445f680f1957108b4efa"], "tags": []}, {"author": "Razvan Caliman \u003crcaliman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1450685 - Ensure correct cursor is shown when rotating a polygon. r=pbro\n\nMozReview-Commit-ID: Jv6uD6T0HmP", "files": ["devtools/server/actors/highlighters/shapes.js"], "git_node": null, "git_parents": [null], "node": "0e1f60508407f11848916a8b881cad85da70b414", "parents": ["4421b373b86a8cb14b4f92dc5c7735f92925f9b1"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1457309 - [Gtk+/CSD] Reset toplevel window offset when it's at maximized/fulscreenstate, r=jhorak\n\nMozReview-Commit-ID: DQTVuquMSXn", "files": ["widget/gtk/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "61ef0409797103377777cdd32f6c6d1b1470b748", "parents": ["0e1f60508407f11848916a8b881cad85da70b414"], "tags": []}, {"author": "Michael Ratcliffe \u003cmratcliffe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1433844 - Storage inspector throws when add item, reload and arrow keys r=pbro\n\nAs far as I am aware, we can't create tests to detect whether an error has been thrown... especially if the error has no side affects.\n\nIf we really need a test for these simple four fixes you can always insist but I don't think we do.\n\nMozReview-Commit-ID: 7j9N1X4jTHY", "files": ["devtools/client/shared/widgets/TableWidget.js", "devtools/client/storage/ui.js"], "git_node": null, "git_parents": [null], "node": "5c04c625cfa622ae45a0fbf8dbf6943b470a9c87", "parents": ["61ef0409797103377777cdd32f6c6d1b1470b748"], "tags": []}, {"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1456327 - Snap: pin desktop-gtk3 dependency for causing start up crash r=sfraser\n\nMozReview-Commit-ID: 4diqZRxNwj3", "files": ["taskcluster/docker/firefox-snap/snapcraft.yaml.in"], "git_node": null, "git_parents": [null], "node": "4bb7dc02d40530cfcd3575268c9dc2aece3c9733", "parents": ["5c04c625cfa622ae45a0fbf8dbf6943b470a9c87"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1456444 - Change \"mensuel.framapad.org/p/\" in the blacklist for avoiding dispatching keypress events strictly to \"*.framapad.org/p/\" r=smaug\n\nframapad.org provides a lot of public Etherpad instances even though only\nmensuel.framapad.org is listed by Etherpad's information.  Therefore, we should\nchange the blacklist for avoiding dispatching keypress events strictly from\n\"mansuel.framapad.org/p/\" to \"*.framapad.org/p/\" to allow any Etherpads in\nthe subdomains work in Nightly builds.\n\nMozReview-Commit-ID: 9H4oIc2PGal", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "2851a62f97a8b5c28ac80a696a2c23b5d30c045a", "parents": ["4bb7dc02d40530cfcd3575268c9dc2aece3c9733"], "tags": []}, {"author": "Paul Adenot \u003cpaul@paul.cx\u003e", "branch": "default", "desc": "Bug 1457137 - Move instead of copying strings returned from various GetDebugInfo functions for HTMLMediaElement::MozDumpDebugInfo. r=gerald\n\nMozReview-Commit-ID: LbZ0cWe7yb0", "files": ["dom/media/ChannelMediaDecoder.cpp", "dom/media/MediaDecoderStateMachine.cpp", "dom/media/mediasink/AudioSinkWrapper.cpp", "dom/media/mediasink/DecodedStream.cpp", "dom/media/mediasink/VideoSink.cpp"], "git_node": null, "git_parents": [null], "node": "dcbdde8d683c1f2aedbdc1f484e3d1eaa9eaa3f5", "parents": ["2851a62f97a8b5c28ac80a696a2c23b5d30c045a"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland. a=merge CLOSED TREE", "files": ["dom/interfaces/core/nsIDOMElement.idl", "extensions/spellcheck/hunspell/src/filemgr.cxx", "gfx/skia/skia/src/core/SkDeviceLooper.cpp", "gfx/skia/skia/src/core/SkDeviceLooper.h"], "git_node": null, "git_parents": [null, null], "node": "6c8dfef176b5c0d698529810f60ada56b5be7b43", "parents": ["dcbdde8d683c1f2aedbdc1f484e3d1eaa9eaa3f5", "d2d518b1f8730eb61554df7179ef9a2aeed4d843"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1371294 - Add a SearchTestUtils.jsm file and stop duplicating promiseNewSearchEngine. r=mikedeboer\n\nMozReview-Commit-ID: IP5iRstshrM", "files": ["browser/base/content/test/general/browser_contentSearchUI.js", "browser/base/content/test/general/head.js", "browser/base/content/test/urlbar/browser_autocomplete_a11y_label.js", "browser/base/content/test/urlbar/browser_urlbarOneOffs.js", "browser/base/content/test/urlbar/browser_urlbarOneOffs_searchSuggestions.js", "browser/base/content/test/urlbar/browser_urlbarPlaceholder.js", "browser/base/content/test/urlbar/browser_urlbarSearchSuggestions.js", "browser/base/content/test/urlbar/browser_urlbarSearchSuggestions_opt-out.js", "browser/base/content/test/urlbar/browser_urlbarSearchTelemetry.js", "browser/base/content/test/urlbar/browser_urlbarStopSearchOnSelection.js", "browser/base/content/test/urlbar/browser_urlbar_search_speculative_connect_engine.js", "browser/base/content/test/urlbar/head.js", "browser/components/search/moz.build", "browser/components/search/test/SearchTestUtils.jsm"], "git_node": null, "git_parents": [null], "node": "91f269ab84959f18c7e9373bcb19ee66975824d7", "parents": ["6c8dfef176b5c0d698529810f60ada56b5be7b43"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1371294 - Add a basic test for the follow-on search add-on. r=mikedeboer\n\nMozReview-Commit-ID: Do1msiPVtWZ", "files": ["browser/extensions/followonsearch/content/followonsearch-fs.js", "browser/extensions/followonsearch/moz.build", "browser/extensions/followonsearch/test/browser/.eslintrc.js", "browser/extensions/followonsearch/test/browser/browser.ini", "browser/extensions/followonsearch/test/browser/browser_followOnTelemetry.js", "browser/extensions/followonsearch/test/browser/test.html", "browser/extensions/followonsearch/test/browser/test2.html", "browser/extensions/followonsearch/test/browser/testEngine.xml"], "git_node": null, "git_parents": [null], "node": "c5afc8caa902b5c213e5c1520c482037f5546e38", "parents": ["91f269ab84959f18c7e9373bcb19ee66975824d7"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1457194 - [Gtk+\\CSD] Don't estimate window offset for Gtk+ \u003c 3.20, r=jhorak\n\nMozReview-Commit-ID: JtxujODEHBO", "files": ["widget/gtk/gtk3drawing.cpp"], "git_node": null, "git_parents": [null], "node": "921741097e18e65b236aa834502f61d78cb0f805", "parents": ["c5afc8caa902b5c213e5c1520c482037f5546e38"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1457194 - Label mShell toplevel window so property_notify_event_cb callback can find its way home, r=jhorak\n\nMozReview-Commit-ID: BGJNFnbEMQ3", "files": ["widget/gtk/nsWindow.cpp"], "git_node": null, "git_par