, r=jorendorff", "files": ["dom/indexedDB/IDBObjectStore.cpp", "js/public/StructuredClone.h", "js/src/builtin/TestingFunctions.cpp", "js/src/tests/non262/extensions/clone-errors.js", "js/src/tests/non262/extensions/clone-transferables.js", "js/src/vm/StructuredClone.cpp"], "git_node": null, "git_parents": [null], "node": "7b6f6fcaaa177324d1827f9be431e23e9e0573ad", "parents": ["6529717260a226e15e02da023bfced594a763204"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1457862.  Don't forget cellParent until we're done using it in HTMLEditor::GetCellContext.  r=masayuki", "files": ["editor/libeditor/HTMLTableEditor.cpp"], "git_node": null, "git_parents": [null], "node": "e0fcc5bcaf2454e2e2a26a0388863ff746eb02b8", "parents": ["7b6f6fcaaa177324d1827f9be431e23e9e0573ad"], "tags": []}, {"author": "Tooru Fujisawa \u003carai_a@mac.com\u003e", "branch": "default", "desc": "Bug 1457365 - Do not add source note for useless expression. r=jorendorff", "files": ["js/src/frontend/BytecodeEmitter.cpp"], "git_node": null, "git_parents": [null], "node": "2c8741c94a0dd857b86f48aad3e8f82cb8c5e6d7", "parents": ["e0fcc5bcaf2454e2e2a26a0388863ff746eb02b8"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1456182: [update-verify] Stop creating a virtualenv in update-verify-config-creator; r=nthomas\n\nSince it is run with `mach python`, it uses the environment defined by\n`build/virtualenv_packages.txt`. Thus, we don't need to create a separate\nvirtualenv.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1015", "files": ["build/sparse-profiles/update-verify", "taskcluster/ci/release-secondary-update-verify-config/kind.yml", "taskcluster/ci/release-update-verify-config/kind.yml", "testing/mozharness/scripts/release/update-verify-config-creator.py"], "git_node": null, "git_parents": [null], "node": "32f1ddc878092d0f15517e1ed5e17ce19293a3ff", "parents": ["2c8741c94a0dd857b86f48aad3e8f82cb8c5e6d7"], "tags": []}, {"author": "Eric Faust \u003cefaustbmo@gmail.com\u003e", "branch": "default", "desc": "Bug 1456768 - [BinAST] Properly set pn-\u003eop for non-spread new expressions. (r=Yoric)", "files": ["js/src/frontend/BinSource-auto.cpp", "js/src/frontend/BinSource.yaml"], "git_node": null, "git_parents": [null], "node": "9bf70e179625ca212595e8fe8cd51b237fe99039", "parents": ["32f1ddc878092d0f15517e1ed5e17ce19293a3ff"], "tags": []}, {"author": "Eric Faust \u003cefaustbmo@gmail.com\u003e", "branch": "default", "desc": "Bug 1454744 - Part 1: Allow BinSource generator to place code after parsing interface sum branches. (r=Yoric)", "files": ["js/src/frontend/binsource/src/main.rs"], "git_node": null, "git_parents": [null], "node": "42c4d4acfba5d5c07e9f95c61c737b626d37c994", "parents": ["9bf70e179625ca212595e8fe8cd51b237fe99039"], "tags": []}, {"author": "Eric Faust \u003cefaustbmo@gmail.com\u003e", "branch": "default", "desc": "Bug 1454744 - Part 2: Add bindings for formal parameter names. (r=Yoric)", "files": ["js/src/frontend/BinSource-auto.cpp", "js/src/frontend/BinSource.yaml"], "git_node": null, "git_parents": [null], "node": "02e7d188fd568150be6629adf95a06363dfd6560", "parents": ["42c4d4acfba5d5c07e9f95c61c737b626d37c994"], "tags": []}, {"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 1456680 - Part 1: Store the grid highlighter setting in HighlightersOverlay. r=pbro\n\nExtract loading the grid highlighter setting into HighlightersOverlay. This\nallows the grid highlighter toggle in the rule view to also show the grid\nhighlighter with the currently set highlight settings if the grid inspector\nhas not been initiated yet.", "files": ["devtools/client/inspector/grids/grid-inspector.js", "devtools/client/inspector/inspector.js", "devtools/client/inspector/shared/highlighters-overlay.js"], "git_node": null, "git_parents": [null], "node": "80f9a47393edf19de2941b295b315df7ac0110b6", "parents": ["02e7d188fd568150be6629adf95a06363dfd6560"], "tags": []}, {"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 1456680 - Part 2: Format markup.js; r=pbro", "files": ["devtools/client/inspector/markup/markup.js"], "git_node": null, "git_parents": [null], "node": "aef2d7d27ff141adefee8583504c20496de07d6f", "parents": ["80f9a47393edf19de2941b295b315df7ac0110b6"], "tags": []}, {"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 1456680 - Part 5: Remove unused onShowGridLineNamesHighlight method. r=pbro", "files": ["devtools/client/inspector/grids/components/Grid.js", "devtools/client/inspector/grids/grid-inspector.js", "devtools/client/inspector/layout/layout.js"], "git_node": null, "git_parents": [null], "node": "cfa4b6d2be06b3a6efd558fc0d00c86c71f6ac25", "parents": ["aef2d7d27ff141adefee8583504c20496de07d6f"], "tags": []}, {"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 1456680 - Part 6: Refactor getting the grid highlighter settings logic into HighlightersOverlay. r=pbro\n\n- Refactor the logic for getting the grid highlighter settings into HighlightersOverlay.js\n- Refactor the grid area and cell highlight into a single function in grid-inspector.js\n- Change the order of the parameters for onHighlighterChange in grid-inspector.js\n- Get the last highlighted state from the Redux store instead of storing them in a variable", "files": ["devtools/client/inspector/grids/components/Grid.js", "devtools/client/inspector/grids/components/GridOutline.js", "devtools/client/inspector/grids/grid-inspector.js", "devtools/client/inspector/layout/layout.js", "devtools/client/inspector/shared/highlighters-overlay.js"], "git_node": null, "git_parents": [null], "node": "232bed10f4d8f36466070a58ae5a37156e24d894", "parents": ["cfa4b6d2be06b3a6efd558fc0d00c86c71f6ac25"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457255 - 1. Translate kotlin warning/error messages for treeherder; r=nalexander\n\nkotlinc emits its warning/error messages as \"w: \u003cmsg\u003e\" and \"e: \u003cmsg\u003e\",\nwhich Treeherder is unable to pick up. Rather than changing Treeherder,\nit's best to make the change as close to the source of the message as\npossible. I looked at changing mach to redirect the output of gradle and\nmake adjustments as necessary, but for some reason gradle doesn't want\nto work with the pipes that mach sets up. So that leaves changing the\ngradle build script itself.\n\nThis patch adds some code to detect the kotlin messages, and output an\nadjusted version as necessary. It has the benefit of only dealing with\nkotlinc output, so output from other tools should not be inadvertently\nchanged. However, due to the way it is implemented, it does duplicate\nevery warning/error output; for example, an error would now look like\nthis in the terminal:\n\n    \u003cfile\u003e: error: \u003cmsg\u003e\n    e: \u003cfile\u003e: \u003cmsg\u003e\n\nI think this is an acceptable drawback.", "files": ["mobile/android/geckoview/build.gradle"], "git_node": null, "git_parents": [null], "node": "4eccde5dfbef9f3c2eb8e274f5a3c55514664d03", "parents": ["232bed10f4d8f36466070a58ae5a37156e24d894"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457255 - 2. Fix Java warnings; r=me\n\nFix all Java warnings in the Android codebase except deprecation and\nserial warnings, and warnings in third-party code.\n\nThere is one required change to exoplayer2 code under thirdparty,\nbecause that code is included directly in the geckoview project, instead\nof the thirdparty project. I think I'll just make a pull-request to\nupstream the change, instead of separating exoplayer2 into a\ngv-thirdparty project.", "files": ["mobile/android/base/java/org/mozilla/gecko/BrowserApp.java", "mobile/android/base/java/org/mozilla/gecko/Ta