a7b939360d52deb4eb959a7aee52a7d06741eb"], "tags": []}, {"author": "Michael Ratcliffe \u003cmratcliffe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1456087 - Create tests for devtools.main.exit telemetry event r=yulia\n\nMozReview-Commit-ID: J2PgWMEfE5C", "files": ["devtools/client/framework/test/browser.ini", "devtools/client/framework/test/browser_toolbox_telemetry_exit.js"], "git_node": null, "git_parents": [null], "node": "5af5821aa84c8f73fdf1d1802b3eea717fc4c8a4", "parents": ["04ed4418999887db0ef9caf980ba2469ee19793b"], "tags": []}, {"author": "Mike Shal \u003cmshal@mozilla.com\u003e", "branch": "default", "desc": "Bug 1425540 - Support --dry-run in the tup backend; r=chmanchester\n\nNow that bug 1454771 has simplified the TupBackend class, it is much\neasier to pass in the self.dry_run flag into BackendTupfile to avoid\nwriting out Tupfiles when --dry-run is used.\n\nMozReview-Commit-ID: 4WDgXNyYuiQ", "files": ["python/mozbuild/mozbuild/backend/tup.py"], "git_node": null, "git_parents": [null], "node": "9a020203cc6fca59853fb4f3e92eff9590896cc3", "parents": ["5af5821aa84c8f73fdf1d1802b3eea717fc4c8a4"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1456882 - Enable some passing mochitests on linux64-qr. r=jrmuizel\n\nMozReview-Commit-ID: 5VIHjwx6A2j", "files": ["browser/extensions/formautofill/test/mochitest/mochitest.ini", "docshell/test/navigation/mochitest.ini", "dom/base/test/mochitest.ini", "dom/events/test/mochitest.ini", "dom/ipc/tests/mochitest.ini", "dom/security/test/general/mochitest.ini", "dom/security/test/mixedcontentblocker/mochitest.ini", "image/test/mochitest/mochitest.ini", "layout/base/tests/mochitest.ini", "layout/generic/test/mochitest.ini", "toolkit/content/tests/mochitest/mochitest.ini"], "git_node": null, "git_parents": [null], "node": "e720e80865b2efc109a95d0607e338526a2f1030", "parents": ["9a020203cc6fca59853fb4f3e92eff9590896cc3"], "tags": []}, {"author": "Michael Ra