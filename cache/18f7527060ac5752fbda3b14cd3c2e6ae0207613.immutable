4755cd79038d89861cc29be0e5fd090e7eb", "parents": ["c2420955ce61a3e5c650b309e96564f9a494bdf8"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1456743 - P2. Have MediaFormatReader debug show live audio codec type. r=bryce\n\nAdditionally, show the number of channels and the sampling rate.\n\nMozReview-Commit-ID: L067Hbv0bXz", "files": ["dom/media/MediaFormatReader.cpp"], "git_node": null, "git_parents": [null], "node": "c526527f499ec1c912a58937031730747bc7cf29", "parents": ["0f4214755cd79038d89861cc29be0e5fd090e7eb"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1456743 - P3. Add SourceBuffer.changeType experimental method. r=bryce,bz\n\nNon functional code.\n\nSourceBuffer.changeType allows to reconfigure a sourceBuffer so that a new codec type or new container format can be fed later.\n\nThe new code is placed behind the media.mediasource.experimental.enabled pref.\n\nMozReview-Commit-ID: 5wj6J4uzLbA", "files": ["dom/media/mediasource/MediaSource.cpp", "dom/media/mediasource/MediaSource.h", "dom/media/mediasource/SourceBuffer.cpp", "dom/media/mediasource/SourceBuffer.h", "dom/webidl/SourceBuffer.webidl", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "d89660b4978f082c7676af47e3c4da2789e20153", "parents": ["c526527f499ec1c912a58937031730747bc7cf29"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1456743 - P4. Actual implementation of SourceBuffer.changeType. r=bryce\n\nCurrently, the new init segment provided following a call to changeType() must contain the same number of audio and video tracks as previously.\n\nThe Chrome team has indicated concerns in regards to this restriction. TBD.\n\nMozReview-Commit-ID: 3S6YVtQILF9", "files": ["dom/media/mediasource/SourceBuffer.cpp", "dom/media/mediasource/SourceBufferTask.h", "dom/media/mediasource/TrackBuffersManager.cpp", "dom/media/mediasource/TrackBuffersManager.h"], "git_node": null, "git_parents": [null], "node": "d858e46ec74a7963d4c0519c29e1fe3754614e8a", "parents": ["d89660b4978f082c7676af47e3c4da2789e20153"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457863 - 1. Update kotlin to 1.2.20; r=nalexander\n\nUpdate the kotlin version used for GeckoView tests to 1.2.20. Also turn\non \"warnings-as-errors\", which is a compiler option introduced in kotlin\n1.2.\n\nMozReview-Commit-ID: EjVPQebAuaS", "files": ["build.gradle", "mobile/android/geckoview/build.gradle"], "git_node": null, "git_parents": [null], "node": "d4e8c9ea8f0e7041cde174758867bd85d6f1c5b7", "parents": ["d858e46ec74a7963d4c0519c29e1fe3754614e8a"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457863 - 2. Use kotlin array literals; r=nalexander\n\nUse the new array literal syntax from kotlin 1.2.\n\nMozReview-Commit-ID: 1py4eZCBbL3", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/GeckoSessionTestRuleTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/NavigationDelegateTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/ProgressDelegateTest.kt"], "git_node": null, "git_parents": [null], "node": "a9e4a1af13b92a150a30dd9d89f12c9c4e2e97e4", "parents": ["d4e8c9ea8f0e7041cde174758867bd85d6f1c5b7"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457960 - P1. make MediaDecoder::Seek returns void. r=bryce\n\nMozReview-Commit-ID: 2pbZprnYqcF", "files": ["dom/html/HTMLMediaElement.cpp", "dom/media/MediaDecoder.cpp", "dom/media/MediaDecoder.h"], "git_node": null, "git_parents": [null], "node": "bbfe1fb6432d5c7798745e5d99090eade9526d9e", "parents": ["a9e4a1af13b92a150a30dd9d89f12c9c4e2e97e4"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457960 - P2. Don't make MediaDecoder::Seek virtual. r=bryce\n\nIt's unnecessary.\n\nMozReview-Commit-ID: Hau3nb9WLKe", "files": ["dom/media/MediaDecoder.h"], "git_node": null, "git_parents": [null], "node": "bbe0de8d6ef96fb18793488cdaf97cf9c59d37bc", "parents": ["bbfe1fb6432d5c7798745e5d99090eade9526d9e"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1458230 - Fix test_BinarySearch.js so that it actually runs the intented checks. r=Paolo\n\nCurrently, it attempts to override 'ok()', but fails in doing so.\n\nMozReview-Commit-ID: LUp6LRb1Alv", "files": ["toolkit/modules/tests/xpcshell/test_BinarySearch.js"], "git_node": null, "git_parents": [null], "node": "f53ccf5c545c44c5aecfaa1c2b55b3d64414fcf8", "parents": ["bbe0de8d6ef96fb18793488cdaf97cf9c59d37bc"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1458230 - Fix various Assert.ok tests that should be using Assert.equals in places related code. r=Paolo\n\nMozReview-Commit-ID: 7i1fPn10Xbe", "files": ["browser/components/places/tests/browser/browser_bookmarksProperties.js", "toolkit/components/places/tests/bookmarks/test_405938_restore_queries.js", "toolkit/components/places/tests/bookmarks/test_424958-json-quoted-folders.js", "toolkit/components/places/tests/unit/test_async_transactions.js"], "git_node": null, "git_parents": [null], "node": "424ed2c8b1b4a7ef471552f1567b25d48da67275", "parents": ["f53ccf5c545c44c5aecfaa1c2b55b3d64414fcf8"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1458230 - Stop passing the caller or a stack for Assert.ok messages in places tests. r=Paolo\n\nThe stacks are now correctly output by the test harness, they may not have been before.\n\nMozReview-Commit-ID: FugywVd9xoC", "files": ["toolkit/components/places/tests/head_common.js", "toolkit/components/places/tests/history/test_async_history_api.js"], "git_node": null, "git_parents": [null], "node": "969b429c982e793de88d04011f4a1aa610ff8d6d", "parents": ["424ed2c8b1b4a7ef471552f1567b25d48da67275"], "tags": []}, {"author": "Brian Grinstead \u003cbgrinstead@mozilla.com\u003e", "branch": "default", "desc": "Bug 1457963 - Add a --temp-profile argument to `mach run` that creates a new temp profile directory;r=ahal\n\nMozReview-Commit-ID: LI6a9KBNXer", "files": ["python/mozbuild/mozbuild/mach_commands.py"], "git_node": null, "git_parents": [null], "node": "eb78f49f99f095346715906321a5730bf647dfec", "parents": ["969b429c982e793de88d04011f4a1aa610ff8d6d"], "tags": []}, {"author": "Kit Cambridge \u003ckit@yakshaving.ninja\u003e", "branch": "default", "desc": "Bug 822018 - Remove unused mentions of private browsing from TPS. r=tcsc\n\nMozReview-Commit-ID: 2QKfN062gRE", "files": ["services/sync/tps/extensions/tps/resource/tps.jsm"], "git_node": null, "git_parents": [null], "node": "fa4f44996ac6a77963450d25e5ea66fc6d39c701", "parents": ["eb78f49f99f095346715906321a5730bf647dfec"], "tags": []}, {"author": "David Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "bug 1445961 - extend the lifetime of the security.pkcs11_modules_loaded telemetry probe r=francois,jcj\n\nMozReview-Commit-ID: FcHSk7AX3QB", "files": ["toolkit/components/telemetry/Scalars.yaml"], "git_node": null, "git_parents": [null], "node": "c91dda92242abf7f072485bb97bc7a0f05df500a", "parents": ["fa4f44996ac6a77963450d25e5ea66fc6d39c701"], "tags": []}, {"author": "shindli \u003cshindli@mozilla.com\u003e", "branch": "default", "desc": "Backed out 2 changesets (bug 1457863) for merge conflict on a CLOSED TREE\n\nBacked out changeset a9e4a1af13b9 (bug 1457863)\nBacked out changeset d4e8c9ea8f0e (bug 1457863)", "files": ["build.gradle", "mobile/android/geckoview/build.gradle", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/GeckoSessionTestRuleTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/NavigationDelegateTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/ProgressDelegateTest.kt"], "git_node": null, "git_parents": [null], "node": "6340700abe0f9639891ed8498287b9c5b8bcf545", "parents": ["c91dda92242abf7f072485bb97bc7a0f05df500a"], "tags": []}, {"author": "shindli \u003cshindli@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland. a=merge CLOSED TREE", "files": ["build.gradle", "mobile/android/geckoview/build.gradle"], "git_node": null, "git_parents": [null, null], "node": "c4e3dcdb87c6fa0340d9809ad20804e021a94c37", "parents": ["6340700abe0f9639891ed8498287b9c5b8bcf545", "258fa1eb49c9a559f0f75bd0a597d14398b01430"], "tags": []}, {"author": "Timothy Guan-tin Chien \u003ctimdream@gmail.com\u003e", "branch": "default", "desc": "Bug 1456728 - Bind an empty binding on scrollbar r=mconley\n\nFor some reason, removing the scrollbar binding triggers\ncontent process performance regression on Linux.\n\nWe'll add an empty binding for now until we find the real cause.\n\nMozReview-Commit-ID: 5sonOULH1x8", "files": ["toolkit/content/widgets/general.xml", "toolkit/themes/osx/global/nativescrollbars.css", "toolkit/themes/windows/global/xulscrollbars.css"], "git_node": null, "git_parents": [null], "node": "efbdd0a0a0ba523d0ec3b47ed3ad6872832c8e80", "parents": ["c4e3dcdb87c6fa0340d9809ad20804e021a94c37"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1424505: Don't try to retrieve the accessible focus from remote documents on Windows 7. r=eeejay\n\nBug 1421144 fixed IAccessible::accFocus to work when focus is within a remote document.\nUnfortunately, this causes mysterious intermittent crashes when called from a UIA client in Windows 7.\nIdeally, we'd deal with the actual cause of the crashes, but they seem to be deep in Windows RPC code and all attempts at tracking this down have failed.\nClients don't seem to need this too often anyway (and it's a minor annoyance if it doesn't work when they do).\n\nMozReview-Commit-ID: IxvbBGJ2wxA", "files": ["accessible/windows/msaa/RootAccessibleWrap.cpp"], "git_node": null, "git_parents": [null], "node": "68bfd841265f54fdd4a214214e9ccc8297c64672", "parents": ["efbdd0a0a0ba523d0ec3b47ed3ad6872832c8e80"], "tags": []}, {"author": "Mark Hammond \u003cmhammond@skippinet.com.au\u003e", "branch": "default", "desc": "Bug 1457815 - remove all sync log files when sync is disconnected. r=tcsc\n\nMozReview-Commit-ID: 3YYn5311cCE", "files": ["services/common/logmanager.js", "services/common/tests/unit/test_logmanager.js", "services/sync/modules/policies.js", "services/sync/tests/unit/test_errorhandler_filelog.js"], "git_node": null, "git_parents": [null], "node": "d28c45ebedccae786507d357b725c889170653b8", "parents": ["68bfd841265f54fdd4a214214e9ccc8297c64672"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nen-CA -\u003e default", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "87bd488c19f620d726b8363d47c8a320bae9bb7c", "parents": ["d28c45ebedccae786507d357b725c889170653b8"], "tags": []}, {"author": "Eric Faust \u003cefaustbmo@gmail.com\u003e", "branch": "default", "desc": "Bug 1451343 - Part 1: Use provided capture information. (r=Yoric)", "files": ["js/src/frontend/BinSource-auto.cpp", "js/src/frontend/BinSource.cpp", "js/src/frontend/BinSource.h", "js/src/frontend/BinSource.yaml"], "git_node": null, "git_parents": [null], "node": "03130e40886bf76d8d0de4ce16b7a042fd54b4f4", "parents": ["7134ec98560255d2c6ffa8b47a1fd78f04d29851"], "tags": []}, {"author": "Eric Faust \u003cefaustbmo@gmail.com\u003e", "branch": "default", "desc": "Bug 1451343 - Part 2: Check annotated closed vars against known uses. (r=Yoric)", "files": ["js/src/frontend/BinSource-auto.cpp", "js/src/frontend/BinSource.cpp", "js/src/frontend/BinSource.h", "js/src/frontend/BinSource.yaml"], "git_node": null, "git_parents": [null], "node": "cf0675c2f36251c5c9871987a02efe4be1e25dc0", "parents": ["03130e40886bf76d8d0de4ce16b7a042fd54b4f4"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1456556 - FetchConsumer scope-exit RAII must grab 'self' by value, r=erahm", "files": ["dom/fetch/FetchConsumer.cpp"], "git_node": null, "git_parents": [null], "node": "294524718c9af630cee7efc3b80f27f267ccb0c3", "parents": ["cf0675c2f36251c5c9871987a02efe4be1e25dc0"], "tags": []}, {"author": "Eric Faust \u003cefaustbmo@gmail.com\u003e", "branch": "default", "desc": "Bug 1456761 - Update buildFunction for the multipart grammar. (r=Yoric)", "files": ["js/src/frontend/BinSource.cpp"], "git_node": null, "git_parents": [null], "node": "6fdf52934a04f7aca7e3a0a1e8a180b7c9e0305b", "parents": ["294524718c9af630cee7efc3b80f27f267ccb0c3"], "tags": []}, {"author": "Eric Faust \u003cefaustbmo@gmail.com\u003e", "branch": "default", "desc": "Bug 1456766 - [BinAST] Bind |this| in functions. Don't yet handle lexical |this| closure. (r=Yoric)", "files": ["js/src/frontend/BinSource-auto.cpp", "js/src/frontend/BinSource.cpp", "js/src/frontend/BinSource.yaml"], "git_node": null, "git_parents": [null], "node": "b7662a1cd8cbf0ea1bb49231a8c35d6fcb0a24b3", "parents": ["6fdf52934a04f7aca7e3a0a1e8a180b7c9e0305b"], "tags": []}, {"author": "Eric Faust \u003cefaustbmo@gmail.com\u003e", "branch": "default", "desc": "Bug 1456765 - [BinAST] Properly compute Function.length. (r=Yoric)", "files": ["js/src/frontend/BinSource-auto.cpp", "js/src/frontend/BinSource.yaml"], "git_node": null, "git_parents": [null], "node": "788d134870102c3333a4564db7eef0d4ea8c52ba", "parents": ["b7662a1cd8cbf0ea1bb49231a8c35d6fcb0a24b3"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1449605 - part 1 - Rearrange thebes font code so that the decision whether to apply synthetic-bold is deferred until actually instantiating a font, not made during the font-matching process. r=jwatt\n\nThis rearranges how synthetic-bold use is determined in the font selection\n& rendering code. Previously, we would decide during the font-selection\nalgorithm whether we need to apply synthetic-bold to the chosen face, and\nthen pass that decision through the fontgroup (storing it in the FamilyFace\nentries of the mFonts array there) down to the actual rendering code that\ninstantiates fonts from the faces (font entries) we've selected.\n\nThat became a problem for variation fonts because in the case of a user\nfont, we may not have downloaded the resource yet, so we just have a \"user\nfont container\" entry, which carries the descriptors from the @font-face\nrule and will fetch the actual resource when needed. But in the case of a\n@font-face rule without a weight descriptor, we don't actually know at\nfont-selection time whether the face will support \"true\" bold (via a\nvariation axis) or not, so we can't reliably make the right decision about\napplying synthetic bold.\n\nSo we now defer that decision until we actually instantiate a platform font\nobject to shape/measure/draw text. At that point, we have the requested\nstyle and we also have the real font resource, so we can easily determine\nwhether fake-bold is required.\n\n(This patch should not result in any visible behavior change; that will\ncome in a second patch now that the architecture supports it.)", "files": ["gfx/thebes/gfxDWriteFontList.cpp", "gfx/thebes/gfxDWriteFontList.h", "gfx/thebes/gfxDWriteFonts.cpp", "gfx/thebes/gfxDWriteFonts.h", "gfx/thebes/gfxFT2FontBase.cpp", "gfx/thebes/gfxFT2FontBase.h", "gfx/thebes/gfxFT2FontList.cpp", "gfx/thebes/gfxFT2FontList.h", "gfx/thebes/gfxFT2Fonts.cpp", "gfx/thebes/gfxFT2Fonts.h", "gfx/thebes/gfxFcPlatformFontList.cpp", "gfx/thebes/gfxFcPlatformFontList.h", "gfx/thebes/gfxFont.cpp", "gfx/thebes/gfxFont.h", "gfx/thebes/gfxFontEntry.cpp", "gfx/thebes/gfxFontEntry.h", "gfx/thebes/gfxGDIFont.cpp", "gfx/thebes/gfxGDIFont.h", "gfx/thebes/gfxGDIFontList.cpp", "gfx/thebes/gfxGDIFontList.h", "gfx/thebes/gfxMacFont.cpp", "gfx/thebes/gfxMacFont.h", "gfx/thebes/gfxMacPlatformFontList.h", "gfx/thebes/gfxMacPlatformFontList.mm", "gfx/thebes/gfxPlatformFontList.cpp", "gfx/thebes/gfxPlatformFontList.h", "gfx/thebes/gfxTextRun.cpp", "gfx/thebes/gfxTextRun.h", "gfx/thebes/gfxUserFontSet.cpp", "gfx/thebes/gfxUserFontSet.h", "layout/style/FontFaceSet.cpp"], "git_node": null, "git_parents": [null], "node": "a4096171bfdbea9956e8afd4d74ac0b7c89506b1", "parents": ["788d134870102c3333a4564db7eef0d4ea8c52ba"], "tags": []}, {"author": "Andreea Pavel \u003capavel@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to mozilla-inbound. a=merge on a CLOSED TREE", "files": ["build/automation-build.mk", "devtools/client/responsive.html/actions/network-throttling.js", "devtools/client/responsive.html/components/NetworkThrottlingSelector.js", "devtools/client/responsive.html/reducers/network-throttling.js", "devtools/client/shared/network-throttling-profiles.js"], "git_node": null, "git_parents": [null, null], "node": "d6ab3049b56061284e9e0e10410588766c7245d9", "parents": ["a4096171bfdbea9956e8afd4d74ac0b7c89506b1", "d2a4720d1c334b64d88a51678758c27ba8f03c89"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1018269: Handle Shadow DOM in keyframes lookup. r=heycam\n\nMozReview-Commit-ID: AeUmsOHOUYR\n", "files": ["layout/style/ServoBindingList.h", "layout/style/ServoStyleSet.cpp", "layout/style/ServoStyleSet.h", "layout/style/nsAnimationManager.cpp", "servo/components/style/stylist.rs", "servo/ports/geckolib/glue.rs", "testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/css/css-scoping/keyframes-001.html", "testing/web-platform/tests/css/css-scoping/keyframes-002.html"], "git_node": null, "git_parents": [null], "node": "69109fe28dc09b17132ba2a793202f9fda66d5f4", "parents": ["d6ab3049b56061284e9e0e10410588766c7245d9"], "tags": []}, {"author": "Alex Chronopoulos \u003cachronop@gmail.com\u003e", "branch": "default", "desc": "Bug 1458199 - Update cubeb from upstream to 44341a1. r=kinetik", "files": ["media/libcubeb/README_MOZILLA", "media/libcubeb/src/cubeb_audiounit.cpp", "media/libcubeb/src/cubeb_wasapi.cpp"], "git_node": null, "git_parents": [null], "node": "587a7161ba5c84abce9c9fe1e39d8c50054c2f36", "parents": ["69109fe28dc09b17132ba2a793202f9fda66d5f4"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1458008 - Shuffle Shape flags around to avoid races with off-thread compilation. r=jonco", "files": ["js/src/jit/MacroAssembler.cpp", "js/src/jsfriendapi.h", "js/src/vm/NativeObject.cpp", "js/src/vm/NativeObject.h", "js/src/vm/Shape-inl.h", "js/src/vm/Shape.cpp", "js/src/vm/Shape.h"], "git_node": null, "git_parents": [null], "node": "1a97035892300bf1b50130dc89d3c10f59321011", "parents": ["587a7161ba5c84abce9c9fe1e39d8c50054c2f36"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1454887 part 1 - Remove some (disabled) invalid asserts. r=tcampbell", "files": ["js/src/vm/TypeInference-inl.h", "js/src/vm/TypeInference.cpp", "js/src/vm/TypeInference.h"], "git_node": null, "git_parents": [null], "node": "f07ea68c0fef2cb271b08358edd2c0cf0fd0aa37", "parents": ["1a97035892300bf1b50130dc89d3c10f59321011"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1454887 part 2 - Rewrite TI sweeping to be more explicit. r=tcampbell", "files": ["js/src/builtin/Array.cpp", "js/src/gc/GC.cpp", "js/src/gc/Marking.cpp", "js/src/gc/Nursery.cpp", "js/src/gc/Tracer.cpp", "js/src/jit/BaselineIC.cpp", "js/src/jit/BaselineInspector.cpp", "js/src/jit/CacheIR.cpp", "js/src/jit/CodeGenerator.cpp", "js/src/jit/Ion.cpp", "js/src/jit/IonBuilder.cpp", "js/src/jit/IonCacheIRCompiler.cpp", "js/src/jit/MCallOptimize.cpp", "js/src/jit/MIR.cpp", "js/src/jit/OptimizationTracking.cpp", "js/src/jit/SharedIC.cpp", "js/src/jit/VMFunctions.cpp", "js/src/vm/BytecodeUtil.cpp", "js/src/vm/Caches-inl.h", "js/src/vm/Interpreter.cpp", "js/src/vm/Iteration.cpp", "js/src/vm/JSObject.cpp", "js/src/vm/JSScript.h", "js/src/vm/NativeObject-inl.h", "js/src/vm/NativeObject.cpp", "js/src/vm/ObjectGroup-inl.h", "js/src/vm/ObjectGroup.cpp", "js/src/vm/ObjectGroup.h", "js/src/vm/TypeInference-inl.h", "js/src/vm/TypeInference.cpp", "js/src/vm/TypeInference.h", "js/src/vm/UnboxedObject-inl.h", "js/src/vm/UnboxedObject.cpp"], "git_node": null, "git_parents": [null], "node": "deeb18d57ad217978ff3c6a38481b5d100665279", "parents": ["f07ea68c0fef2cb271b08358edd2c0cf0fd0aa37"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1445716 - Run new Android test task, geckoview-junit; r=me,a=test-only\n\nhttps://developer.mozilla.org/en-US/docs/Mozilla/Geckoview-Junit_Tests", "files": ["taskcluster/ci/test/test-sets.yml"], "git_node": null, "git_parents": [null], "node": "e131aaef5d898a93dc49243244ec01e2abca562a", "parents": ["deeb18d57ad217978ff3c6a38481b5d100665279"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1445716 - Skip remaining failures in geckoview-junit tests; r=jchen", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/GeckoSessionTestRuleTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/NavigationDelegateTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/ProgressDelegateTest.kt"], "git_node": null, "git_parents": [null], "node": "a340a6ab84898033234f8f4bb7c8de2cfbce5aa2", "parents": ["e131aaef5d898a93dc49243244ec01e2abca562a"], "tags": []}, {"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 1456680 - Part 1: Store the grid highlighter setting in HighlightersOverlay. r=pbro\n\nExtract loading the grid highlighter setting into HighlightersOverlay. This\nallows the grid highlighter toggle in the rule view to also show the grid\nhighlighter with the currently set highlight settings if the grid inspector\nhas not been initiated yet.", "files": ["devtools/client/inspector/grids/grid-inspector.js", "devtools/client/inspector/inspector.js", "devtools/client/inspector/shared/highlighters-overlay.js"], "git_node": null, "git_parents": [null], "node": "ea070f2a2b313eb1a1442661df6d91b43b39a186", "parents": ["a340a6ab84898033234f8f4bb7c8de2cfbce5aa2"], "tags": []}, {"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 1456680 - Part 2: Format markup.js; r=pbro", "files": ["devtools/client/inspector/markup/markup.js"], "git_node": null, "git_parents": [null], "node": "81a4e70b322923922a4f45612066fcb5ebc0a081", "parents": ["ea070f2a2b313eb1a1442661df6d91b43b39a186"], "tags": []}, {"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 1456680 - Part 5: Remove unused onShowGridLineNamesHighlight method. r=pbro", "files": ["devtools/client/inspector/grids/components/Grid.js", "devtools/client/inspector/grids/grid-inspector.js", "devtools/client/inspector/layout/layout.js"], "git_node": null, "git_parents": [null], "node": "0f7bc1fadc3f8c18458679a534be0222c475e74b", "parents": ["81a4e70b322923922a4f45612066fcb5ebc0a081"], "tags": []}, {"author": "Andrei Hajdukewycz \u003csancus@pobox.com\u003e", "branch": "default", "desc": "Bug 1458162 - Change xpcshell test toolkit/mozapps/extensions/test/xpcshell/test_pluginInfoURL.js to use blocklist pref for test_infoURL_missing. r=Gijs", "files": ["toolkit/mozapps/extensions/test/xpcshell/test_pluginInfoURL.js"], "git_node": null, "git_parents