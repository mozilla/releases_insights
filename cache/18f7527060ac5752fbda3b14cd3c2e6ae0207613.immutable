 null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9172": {"changesets": [{"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1456182 - Fix python environment creation of update-verify-config-creator, r=nthomas a=release CLOSED TREE", "files": ["build/sparse-profiles/update-verify", "taskcluster/ci/release-update-verify-config/kind.yml", "testing/mozharness/scripts/release/update-verify-config-creator.py"], "git_node": null, "git_parents": [null], "node": "b5ac348daeec346d4bfb38aa01fadb7354fd156a", "parents": ["89f3ba72015ad49046247a3017087630c244eeae"], "tags": ["DEVEDITION_61_0b1_BUILD1", "DEVEDITION_61_0b1_RELEASE"]}], "date": 1524913574, "git_changesets": [null], "user": "nthomas@mozilla.com"}, "9173": {"changesets": [{"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "FIREFOX_60b_RELBRANCH", "desc": "Bug 1455970 - Write test for cookies being synced across tabs. r=Ehsan, a=test-only\n\nAdds a test for code landed in bug 1450199.\nOpens two tabs in different processes then sets cookies in one followed by checking the value in the other.\n\nMozReview-Commit-ID: 605k68Kl7nA", "files": ["netwerk/test/browser/browser.ini", "netwerk/test/browser/browser_cookie_sync_across_tabs.js"], "git_node": null, "git_parents": [null], "node": "158373b08a9c5e1e4ebcaded41ca5bfb5be1d699", "parents": ["fb9171950de8095e9859d308b4d53caec23abc2f"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "FIREFOX_60b_RELBRANCH", "desc": "Bug 1456487 - Update Firefox Account's first run UUID when re-connecting. r=rnewman, a=jcristau\n\nThe behaviour of Android Firefox Account instances recently changed in\nthe face of system \"Clear data\" commands.  To align more closely with\ncommon Apps like Dropbox and Whatsapp (which generally don't use\nAndroid Account instances), after a \"Clear data\" a Firefox Account is\nmoved to the Separated state, requiring the user to re-connect them\nwith a password challenge.  To achieve this, newly created accounts\ninclude a first run UUID; after a \"Clear data\", the App is killed and\nrestarted, Sync sees a different first run UUID, and the Account is\nmoved to the Separated state.  (I honestly don't know what happens if\nthe Sync code never sees a different first run UUID, but that's for\nanother day.)  If the user then, in the same first run session,\nre-connects the Firefox Account... the Sync code will again see the\ndifferent first run UUID and move the Account to the Separated state.\n\nThis patch updates the first run UUID when the Account is\nre-connected, breaking that cycle.\n\nMozReview-Commit-ID: 9jcO9Ym54an", "files": ["mobile/android/base/java/org/mozilla/gecko/AccountsHelper.java", "mobile/android/services/src/main/java/org/mozilla/gecko/fxa/authenticator/AndroidFxAccount.java"], "git_node": null, "git_parents": [null], "node": "4bdbddf15a016877ba545646b97f008026ac6aa2", "parents": ["158373b08a9c5e1e4ebcaded41ca5bfb5be1d699"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "FIREFOX_60b_RELBRANCH", "desc": "Bug 1456522 - Stop making the tabs toolbar transparent when there's no title bar behind it, i.e. in fullscreen mode. r=stransky, a=RyanVM on a CLOSED TREE\n\nMozReview-Commit-ID: DuKPGXKqtnD", "files": ["browser/themes/linux/browser.css"], "git_node": null, "git_parents": [null], "node": "3a1aae811a582d2f78f893a4626e125e685caef8", "parents": ["4bdbddf15a016877ba545646b97f008026ac6aa2"], "tags": []}], "date": 1524933818, "git_changesets": [null, null, null], "user": "ryanvm@gmail.com"}, "9174": {"changesets": [{"author": "Jonathan Kingston \u003cjkt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1454820 - Add support for system addon signing for web extension bundling. r=johannh,kmag\n\nMozReview-Commit-ID: 3dpQKGHOgLa", "files": ["toolkit/components/extensions/Extension.jsm", "toolkit/components/extensions/ExtensionTestCommon.jsm", "toolkit/components/extensions/test/xpcshell/test_ext_experiments.js", "toolkit/components/extensions/test/xpcshell/test_ext_schemas_interactive.js", "toolkit/mozapps/extensions/internal/XPIProvider.jsm"], "git_node": null, "git_parents": [null], "node": "7e3aa63ae7529cc0b48c106cbc918e937872c273", "parents": ["9c70604962648780c82ae1a4773b0f249b26863f"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 7e3aa63ae752 (bug 1454820) for ESlint failure on extensions/Extension.jsm:509:22. CLOSED TREE", "files": ["toolkit/components/extensions/Extension.jsm", "toolkit/components/extensions/ExtensionTestCommon.jsm", "toolkit/components/extensions/test/xpcshell/test_ext_experiments.js", "toolkit/components/extensions/test/xpcshell/test_ext_schemas_interactive.js", "toolkit/mozapps/extensions/internal/XPIProvider.jsm"], "git_node": null, "git_parents": [null], "node": "b2c04559e167b863e9aaf74481b63179868495aa", "parents": ["7e3aa63ae7529cc0b48c106cbc918e937872c273"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1456400 - [wdspec] Increase timeout for close_window/user_prompts.py test. r=whimboo\n\nMozReview-Commit-ID: 1DLDkIPxlw8", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/webdriver/tests/close_window/user_prompts.py"], "git_node": null, "git_parents": [null], "node": "b27cb10f8110cb9a3475c8ffa4579dac5017520b", "parents": ["b2c04559e167b863e9aaf74481b63179868495aa"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1457247 - Add \"www.rememberthemilk.com\" into the blacklist to allow to dispatch non-printable keypress events r=smaug\n\nwww.remberthemilk.com is a todo app. Its dropdown lists are implemented by\nthemselves, however, we cannot navigate the dropdown list with ArrowDown\nand ArrowUp keys.  For now, we should allow to dispatch non-printable key\nevents in the domain.\n\nMozReview-Commit-ID: 10iMoRZfB4j", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "3f84124ca07be0314a6a84a27479c241bf56f19f", "parents": ["b27cb10f8110cb9a3475c8ffa4579dac5017520b"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1456978 - Rename function to a more appropriate name. r=sotaro\n\nMozReview-Commit-ID: 2mVFcPsK6oe", "files": ["gfx/webrender_bindings/RenderThread.cpp", "gfx/webrender_bindings/RenderThread.h"], "git_node": null, "git_parents": [null], "node": "ca63e4de54791f32bd7896ebfd85747c56526625", "parents": ["3f84124ca07be0314a6a84a27479c241bf56f19f"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1456978 - Remove redundant construction of WindowId. r=sotaro\n\nMozReview-Commit-ID: 2XiVcQJotRv", "files": ["gfx/webrender_bindings/RenderThread.cpp"], "git_node": null, "git_parents": [null], "node": "d5e9d984dcc67576848a20b85716f9cfad675bb6", "parents": ["ca63e4de54791f32bd7896ebfd85747c56526625"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1456978 - Ensure that all generate_frame transactions end up clearing the pending frame count. r=sotaro\n\nThis prevents us from getting stuck in the frame throttling code where\nTooManyPendingFrames always returns true.\n\nMozReview-Commit-ID: 92tybPOaOTP", "files": ["gfx/webrender_bindings/RenderThread.cpp", "gfx/webrender_bindings/RenderThread.h", "gfx/webrender_bindings/src/bindings.rs", "gfx/webrender_bindings/webrender_ffi_generated.h"], "git_node": null, "git_parents": [null], "node": "704dd8298b15bdfc46b438e02fc625c9fca921cb", "parents": ["d5e9d984dcc67576848a20b85716f9cfad675bb6"], "tags": []}, {"author": "Dennis Schubert \u003cdschubert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1386807 - Part 1: Allow platform-specific UA overrides r=Felipe\n\nMozReview-Commit-ID: 8OAVyZ3j9Rn", "files": ["browser/extensions/webcompat/content/data/ua_overrides.jsm", "browser/extensions/webcompat/content/lib/ua_overrider.jsm", "browser/extensions/webcompat/install.rdf.in"], "git_node": null, "git_parents": [null], "node": "a97531cf72c34bdfb0902cc5185bc17dd8fd5574", "parents": ["704dd8298b15bdfc46b438e02fc625c9fca921cb"], "tags": []}, {"author": "Dennis Schubert \u003cdschubert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1386807 - Part 2: Add embedded webextension to enable CSS and JS overrides r=kmag,mconley\n\nMozReview-Commit-ID: JdSUZYHkuiV", "files": ["browser/extensions/webcompat/bootstrap.js", "browser/extensions/webcompat/content/data/ua_overrides.jsm", "browser/extensions/webcompat/install.rdf.in", "browser/extensions/webcompat/moz.build", "browser/extensions/webcompat/webextension/background.js", "browser/extensions/webcompat/webextension/injections/css/bug0000000-dummy-css-injection.css", "browser/extensions/webcompat/webextension/injections/js/bug0000000-dummy-js-injection.js", "browser/extensions/webcompat/webextension/manifest.json"], "git_node": null, "git_parents": [null], "node": "3307b23d288947b48e8d74e521ae8b618a1ba70f", "parents": ["a97531cf72c34bdfb0902cc5185bc17dd8fd5574"], "tags": []}, {"author": "Dennis Schubert \u003cdschubert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1386807 - Part 3: Make the UA pref actually disable UA overrides r=Felipe\n\nMozReview-Commit-ID: 25YsSg7P8DP", "files": ["browser/extensions/webcompat/bootstrap.js", "browser/extensions/webcompat/content/lib/ua_overrider.jsm"], "git_node": null, "git_parents": [null], "node": "5e1fe3a9874b5575af9dfc4baf6d42b696aa3d66", "parents": ["3307b23d288947b48e8d74e521ae8b618a1ba70f"], "tags": []}, {"author": "Dennis Schubert \u003cdschubert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1386807 - Part 4: Add hidden WebExtension window to a11y tests to make them pass r=eeejay\n\nThis is actually a workaround for the test not ignoring hidden windows. There is\nongoing work in bug 1440106 that will get rid of this issue altogether, but\nfor now, we need to add hidden windows ourselves.\n\nMozReview-Commit-ID: 2rQoz4KLHv3", "files": ["accessible/tests/mochitest/events/docload/test_docload_root.html", "accessible/tests/mochitest/events/docload/test_docload_shutdown.html"], "git_node": null, "git_parents": [null], "node": "bb6b514d69886a9b7f639859f623f1b5191245de", "parents": ["5e1fe3a9874b5575af9dfc4baf6d42b696aa3d66"], "tags": []}, {"author": "Ethan Glasser-Camp \u003cethan@betacantrips.com\u003e", "branch": "default", "desc": "Bug 1453961: bump kinto.js version to 11.1.2 r=florian\n\nThis eliminates a quadratic behavior in SyncResultObject#add.\n\nMozReview-Commit-ID: 5mZpQsMKzdO", "files": ["services/common/kinto-offline-client.js"], "git_node": null, "git_parents": [null], "node": "0d2ed925b49000f0abefb3c03a50e6b4f7e8f8b2", "parents": ["bb6b514d69886a9b7f639859f623f1b5191245de"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1457054 - [wdspec] Use correct assertions for delete cookie tests. r=automatedtester\n\nMozReview-Commit-ID: HsqeIkF5Wq7", "files": ["testing/web-platform/meta/webdriver/tests/cookies/delete_cookie.py.ini", "testing/web-platform/tests/webdriver/tests/cookies/delete_cookie.py"], "git_node": null, "git_parents": [null], "node": "ab7307312bb7ded67672b9d8cb2ec723dea1f23d", "parents": ["0d2ed925b49000f0abefb3c03a50e6b4f7e8f8b2"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1457054 - [wdspec] Remove unwanted docstrings with reference to the spec. r=automatedtester\n\nMozReview-Commit-ID: 8pxozHr4gZs", "files": ["testing/web-platform/tests/webdriver/tests/cookies/delete_cookie.py"], "git_node": null, "git_parents": [null], "node": "149859d8a23d280e1e8b62ce9747dbbf71e18a85", "parents": ["ab7307312bb7ded67672b9d8cb2ec723dea1f23d"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1457054 - [wdspec] Align formatting of custom delete cookie command. r=automatedtester\n\nMozReview-Commit-ID: KPePHYHT0CP", "files": ["testing/web-platform/tests/webdriver/tests/cookies/delete_cookie.py"], "git_node": null, "git_parents": [null], "node": "2e0af0221a8ea76a9445c51e9f86b025766e7721", "parents": ["149859d8a23d280e1e8b62ce9747dbbf71e18a85"], "tags": []}, {"author": "Chris H-C \u003cchutten@mozilla.com\u003e", "branch": "default", "desc": "bug 1451814 - Document Event Summarization in the Event Documentation r=Dexter\n\nMozReview-Commit-ID: HbUghNQnFPo", "files": ["toolkit/components/telemetry/docs/collection/events.rst", "toolkit/components/telemetry/docs/collection/scalars.rst", "toolkit/compo