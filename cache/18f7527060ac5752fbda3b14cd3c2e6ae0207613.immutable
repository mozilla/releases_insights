1"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "THUNDERBIRD_60_VERBRANCH", "desc": "Bug 1464523: [release] Remove debugging print; r=me CLOSED TREE DONTBUILD", "files": ["taskcluster/taskgraph/transforms/update_verify_config.py"], "git_node": null, "git_parents": [null], "node": "e7bdfa3e52846eacf3eb1086f78bf77be0d09d2f", "parents": ["165875ad5e995312456bd2727406944ed57a3351"], "tags": []}, {"author": "Justin Wood \u003cCallek@gmail.com\u003e", "branch": "THUNDERBIRD_60_VERBRANCH", "desc": "Bug 1453274 - Add testing for python/mozrelease/versions.py r=rail a=release\nfor: taskgraph: Make update tasks support esr60\n\nMozReview-Commit-ID: GUmAq3sBXGB", "files": ["build/virtualenv_packages.txt", "python/moz.build", "python/mozrelease/test/python.ini", "python/mozrelease/test/test_versions.py"], "git_node": null, "git_parents": [null], "node": "c16723c5b1ef6a729521e8ad652a98f553de40ce", "parents": ["e7bdfa3e52846eacf3eb1086f78bf77be0d09d2f"], "tags": []}, {"author": "Ted Mielczarek \u003cted@mielczarek.org\u003e", "branch": "THUNDERBIRD_60_VERBRANCH", "desc": "bug 1353296 - get rid of filter_upload_symbols. r=dustin\n\nfilter_upload_symbols is a relic of task configurations that were written\nbefore we had a better handle on taskgraph generation. We should only be\nuploading symbols for nightly builds anyway, so this is better served using\nnewer filtering methods.\n\nupload-symbols tasks were specified to run on non-nightly build types in the\nkind.yml, but those were filtered out in filter_upload_symbols. I believe\nthese were simply an artifact of the initial upload-symbols implementation\nhappening before nightly builds were running in Taskcluster.\n\nMozReview-Commit-ID: Je1NytrVPT8", "files": ["taskcluster/ci/upload-symbols/kind.yml", "taskcluster/taskgraph/target_tasks.py"], "git_node": null, "git_parents": [null], "node": "82bb56b791bf706d77d716076c5baacac765f4e8", "parents": ["c16723c5b1ef6a729521e8ad652a98f553de40ce"], "tags": []}, {"author": "Ted Mielczarek \u003cted@mielczarek.org\u003e", "branch": "THUNDERBIRD_60_VERBRANCH", "desc": "bug 1437577 - Upload symbols from try server builds to symbols.mozilla.org instead of symbols.stage.mozaws.net. r=peterbe\n\nThe symbol server recently gained the ability to upload symbols from try\nto a different prefix in the symbols bucket. If we change the token stored\nin the Taskcluster secret `project/releng/gecko/build/level-1/gecko-symbol-upload`\nto one that has only \"upload try symbols\" permissions then we can upload\nsymbols from try server builds directly to symbols.mo.\n\nMozReview-Commit-ID: HjQclKKXbA3", "files": ["toolkit/crashreporter/tools/upload_symbols.py"], "git_node": null, "git_parents": [null], "node": "19d83c629eef5e24cd8c69725d7d29b06959bc05", "parents": ["82bb56b791bf706d77d716076c5baacac765f4e8"], "tags": []}, {"author": "Ted Mielczarek \u003cted@mielczarek.org\u003e", "branch": "THUNDERBIRD_60_VERBRANCH", "desc": "bug 1437577 - preserve treeherder.platform from job into task. r=dustin\n\nTasks like upload-symbols that have a dependency on a build job want to\ncopy the treeherder.platform from the build job but it gets lost in\nthe task transform currently. This simply copies it into\nan extra.treeherder-platform key to make life easier.\n\nMozReview-Commit-ID: H4PtC4mvIYA", "files": ["taskcluster/taskgraph/transforms/task.py"], "git_node": null, "git_parents": [null], "node": "09d00cdf7a2f679127dcf6088a61abcb34aebcde", "parents": ["19d83c629eef5e24cd8c69725d7d29b06959bc05"], "tags": []}, {"author": "Ted Mielczarek \u003cted@mielczarek.org\u003e", "branch": "THUNDERBIRD_60_VERBRANCH", "desc": "bug 1437577 - allow uploading symbols from any build type on try. r=dustin a=tomprince DONTBUILD\n\nPreviously we would only generate upload-symbols tasks for nightly builds,\nsince we only want to upload symbols for builds we ship to users.\n\nOn try, developers may want to use the symbol server but very rarely want\nto do nightly builds, so allow uploading symbols from any build type there.\n\nMozReview-Commit-ID: IYs9mZii3DN", "files": ["taskcluster/ci/upload-symbols/kind.yml", "taskcluster/taskgraph/transforms/upload_symbols.py"], "git_node": null, "git_parents": [null], "node": "03ca12fd5db6ca1a8b765a003572acd8c168c2da", "parents": ["09d00cdf7a2f679127dcf6088a61abcb34aebcde"], "tags": []}], "date": 1527696142, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "mozilla@hocat.ca"}, "9288": {"changesets": [{"author": "\"Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e\"", "branch": "default", "desc": "No bug - Tagging d81b581fbd2cdb5fcfd982c7d2d3222204192725 with FENNEC_61_0b9_BUILD1, FENNEC_61_0b9_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "5c45e100241c4dbaf08b3abd3079bef8155b4514", "parents": ["be0aea7697f0605cf5e57c3400dc3ffd14ce61d2"], "tags": []}], "date": 1527700011, "git_changesets": [null], "user": "ffxbld"}, "9289": {"changesets": [{"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1458841 - Remove test code for the old microtask behavior. r=birtles, a=test-only\n\nMozReview-Commit-ID: ACNgQ0EWrKI", "files": ["dom/animation/test/mozilla/file_restyles.html"], "git_node": null, "git_parents": [null], "node": "110b1c4125753cd0d4d8ddbe0beb189d3efabac4", "parents": ["5c45e100241c4dbaf08b3abd3079bef8155b4514"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1458841 - Introduce a utility function that waits for a given animation being ready to be restyle. r=birtles, a=test-only\n\nAnd replace tweakExpectedRestyleCount with the function.\n\nMozReview-Commit-ID: 96jC9looyZq", "files": ["dom/animation/test/mozilla/file_restyles.html"], "git_node": null, "git_parents": [null], "node": "41a10e49031d220a3ccadd1e8660213b68b55d90", "parents": ["110b1c4125753cd0d4d8ddbe0beb189d3efabac4"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1458841 - Use waitForAnimationReadyToRestyle wherever we wait for animation.ready right after animation creation. r=birtles, a=test-only\n\nPreviously we used the tweakExpectedRestyleCount function (replaced by the\nwaitForAnimationReadyToRestyle function in the previous patch) only in cases\nwhere we were actually expecting restyles to happen.  For cases where we don't\nexpect restyles, i.e. cases where we assert the restyle count is zero, we\ndidn't use this method meaning we didn't bother checking if there was a restyle\nexpected for the current frame or not.\n\nSince we normally wait for 5 frames anyway before checking that there have been\nno restyles, failing to count the number of frames and waiting only 4 frames is\nnot a problem.  However, if a new test were added that just copied this code and\nonly waited one frame, it might fail to test what it intended.  So, to avoid\npossible future bugs and in order to be more consistent with tests that do\nexpect restyles, this patch replaces a number of uses animation.ready with\nwaitForAnimationReadyToRestyle.\n\nMozReview-Commit-ID: 7qBmobTKolh", "files": ["dom/animation/test/mozilla/file_restyles.html"], "git_node": null, "git_parents": [null], "node": "ffdd779eb0b91165288c9cee981cf74009bd965f", "parents": ["41a10e49031d220a3ccadd1e8660213b68b55d90"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1203273 - Add more diagnostics for gray buffer marking crashes on OSX. r=sfink, a=RyanVM", "files": ["js/src/gc/RootMarking.cpp"], "git_node": null, "git_parents": [null], "node": "57f7d2058ce2ef621dcf298b6415bbb829a1cb56", "parents": ["ffdd779eb0b91165288c9cee981cf74009bd965f"], "tags": []}, {"author": "Mantaroh Yoshinaga \u003cmantaroh@gmail.com\u003e", "branch": "default", "desc": "Bug 1444302 - Part 1. Add the close button into the split console. r=nchevobbe, a=RyanVM\n\nThis patch will display the button of closing split console. The FilterBar\nshould display this close button if target is split console.\n\nMozReview-Commit-ID: 29VjaqHdh2S", "files": ["devtools/client/themes/webconsole.css", "devtools/client/webconsole/actions/ui.js", "devtools/client/webconsole/components/FilterBar.js", "devtools/client/webconsole/constants.js", "devtools/client/webconsole/new-console-output-wrapper.js", "devtools/client/webconsole/new-webconsole.js", "devtools/client/webconsole/reducers/ui.js", "devtools/client/webconsole/test/mochitest/browser.ini", "devtools/client/webconsole/test/mochitest/browser_webconsole_split_close_button.js"], "git_node": null, "git_parents": [null], "node": "dbfb05cdda81d130050354ed1b108f685f0bd30f", "parents": ["57f7d2058ce2ef621dcf298b6415bbb829a1cb56"], "tags": []}, {"author": "Mantaroh Yoshinaga \u003cmantaroh@gmail.com\u003e", "branch": "default", "desc": "Bug 1444302 - Part 2. Make the filtered message element of the split console to be displayed in a new line when devtool width is narrow. r=nchevobbe, a=RyanVM\n\nPrevious part 1 patch will display close button on the right of a primary\nelement of filter bar. However, a filtered message element will display in the\nright of a close button.\n\nSo this patch will make the filtered message element to be displayed in a new\nline if devtools width is narrow. This patch uses \"media query\" as the trigger\nof replacement, this media query width size is based on Greek language string\nsince a localized string of this filtered message is longer than other localized\nstrings.\n\nMozReview-Commit-ID: Ledhrw5I4S5", "files": ["devtools/client/themes/webconsole.css"], "git_node": null, "git_parents": [null], "node": "3bb86bbf74af6e37b20673b187a8dd3ee66f1e75", "parents": ["dbfb05cdda81d130050354ed1b108f685f0bd30f"], "tags": []}, {"author": "Daisuke Akatsuka \u003cdakatsuka@mozilla.com\u003e", "branch": "default", "desc": "Bug 1463355 - Remove right margin/padding from split console close button in case of the platform is not 'mac'. r=nchevobbe, a=RyanVM\n\nMozReview-Commit-ID: DB8yM4Ce5TS", "files": ["devtools/client/themes/webconsole.css"], "git_node": null, "git_parents": [null], "node": "923b9033e8d4f8a3ba0624994681d355fe7e3dd0", "parents": ["3bb86bbf74af6e37b20673b187a8dd3ee66f1e75"], "tags": []}, {"author": "Mantaroh Yoshinaga \u003cmantaroh@gmail.com\u003e", "branch": "default", "desc": "Bug 1464265 - Apply photon icon fill to close button of webconsole. r=nchevobbe, a=RyanVM\n\nWebconsole has two close buttons. (split console and sidebar)\nThis patch will apply photon icon color fill to these buttons.\n\nMozReview-Commit-ID: EWYxQrHFhJ6", "files": ["devtools/client/themes/webconsole.css"], "git_node": null, "git_parents": [null], "node": "dbd8df4584c4df1bf4858568918d461aad8b1396", "parents": ["923b9033e8d4f8a3ba0624994681d355fe7e3dd0"], "tags": []}], "date": 1527704493, "git_changesets": [null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9290": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1458999 - Nullcheck for release, assert elsewhere. r=enn, a=RyanVM\n\nThis should allow us to figure out what's killing the window mid-flight, in case\nthere's something to fix in the chrome JS code.\n\nMozReview-Commit-ID: 1xx1AVdspB2", "files": ["xpfe/appshell/nsXULWindow.cpp", "xpfe/appshell/nsXULWindow.h"], "git_node": null, "git_parents": [null], "node": "96eeb9f7e318718bbd01ce04ee019931c354fe57", "parents": ["dbd8df4584c4df1bf4858568918d461aad8b1396"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1463819 - Account for the possibility of SyncAttributesToWidget destroying the window. r=enn, a=RyanVM\n\nMozReview-Commit-ID: 8O3We8wnSGk", "files": ["xpfe/appshell/nsXULWindow.cpp", "xpfe/appshell/nsXULWindow.h"], "git_node": null, "git_parents": [null], "node": "7aa58e74173962f26e61191567091afc35202abf", "parents": ["96eeb9f7e318718bbd01ce04ee019931c354fe57"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1464904 - When font-variations support is preffed off, do not set up variation ranges in the gfxFontEntry for a system font, so that font selection will rely only on the static properties of the faces. r=lsalzman, a=RyanVM", "files": ["gfx/thebes/gfxFontEntry.cpp"], "git_node": null, "git_parents": [null], "node": "8735fe57245edec03c7a99b82626e57f9a4997bd", "parents": ["7aa58e74173962f26e61191567091afc35202abf"], "tags": []}, {"author": "Jonathan Kingston \u003cjkt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1452666 - Simplify SessionHistory serialization code and test expanded principals are serialized and can restore tabs. r=bz, r=mikedeboer, a=RyanVM\n\nMozReview-Commit-ID: EV39wz2TFlj", "files": ["browser/components/extensions/test/browser/browser-common.ini", "browser/components/extensions/test/browser/browser_ext_sessions_restoreTab.js", "toolkit/modules/sessionstore/SessionHistory.jsm"], "git_node": null, "git_parents": [null], "node": "c3359bea833fb3ac6ec2ff9fe1426ca1f5f1e8f1", "parents": ["8735fe57245edec03c7a99b82626e57f9a4997bd"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1452666 - Implement nsISerializable on expanded principals. r=kmag, a=RyanVM", "files": ["caps/ExpandedPrincipal.cpp", "caps/ExpandedPrincipal.h", "layout/build/nsLayoutModule.cpp"], "git_node": null, "git_parents": [null], "node": "2449a216c49ff59d6a7f45a7ca33ee8739da2fff", "parents": ["c3359bea833fb3ac6ec2ff9fe1426ca1f5f1e8f1"], "tags": []}, {"author": "Daniel Holbert \u003cdholbert@cs.stanford.edu\u003e", "branch": "default", "desc": "Bug 1461446 - Make flex layout explicitly handle integer overflow when summing up flex item hypothetical sizes. r=mats, a=RyanVM\n\nThis patch accomodates for the unfortunate fact that elements with\n\"table-layout:fixed\" have a max-content size of nscoord_MAX (infinity,\neffectively), which turns out to be an easy source of integer overflow during\nflex layout.\n\nBefore this patch, a flex container with \"table-layout:fixed\" in several flex\nitems could end up triggering integer-overflow & making the wrong judgement on\nits arithmetic to determine...\n - whether a given flex item will fit on an existing flex line.\n - whether we've got positive free space and need to grow our items, or have\n   negative free space and need to shrink our items.\n\nThis patch makes two changes to fix this issue.\n\n(1) This patch makes us use CheckedInt when summing up flex item hypothetical\n    sizes, which prevents integer overflow from flipping the sign of our line's\n    total length.\n\n(2) This patch makes us *directly* track the space reserved for flex item\n    margin/border/padding within a flex line.  Previously, we tracked this\n    implicitly as the difference between two other quantities that we stored;\n    but with the other changes in this patch, those two other quantities can\n    *both* trigger overflow and get clamped, which would make us lose track of\n    how much space to reserve for margin/border/padding.  So now we simply\n    track that space-to-reserve directly.\n\nMozReview-Commit-ID: 9izhOnlS4F1", "files": ["layout/generic/nsFlexContainerFrame.cpp", "layout/reftests/flexbox/flexbox-table-flex-items-4-ref.html", "layout/reftests/flexbox/flexbox-table-flex-items-4.html", "layout/reftests/flexbox/flexbox-table-flex-items-5-ref.html", "layout/reftests/flexbox/flexbox-table-flex-items-5.html", "layout/reftests/flexbox/reftest.list"], "git_node": null, "git_parents": [null], "node": "92bbbb44e97deeca509a1eb51d2d0f76a1091b3a", "parents": ["2449a216c49ff59d6a7f45a7ca33ee8739da2fff"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1461118 - Null-check mGeckoChild after calling DispatchInputEvent. r=spohl, a=RyanVM\n\nMozReview-Commit-ID: 4bfe8TM4GuS", "files": ["widget/cocoa/nsChildView.mm"], "git_node": null, "git_parents": [null], "node": "1a44b26d00a582d19259018d4d467d5bf62dbbbd", "parents": ["92bbbb44e97deeca509a1eb51d2d0f76a1091b3a"], "tags": []}, {"author": "Olli Pettay \u003cOlli.Pettay@helsinki.fi\u003e", "branch": "default", "desc": "Bug 1459693 - Ensure the right anonymous element is focused when calling input.focus(). r=mccr8, a=RyanVM", "files": ["dom/html/HTMLInputElement.cpp"], "git_node": null, "git_parents": [null], "node": "409cd4e30401f3ffcb3b23c1fb6114fce3fe0975", "parents": ["1a44b26d00a582d19259018d4d467d5bf62dbbbd"], "tags": []}], "date": 1527705087, "git_changesets": [null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9291": {"changesets": [{"author": "Timothy Guan-tin Chien \u003ctimdream@gmail.com\u003e", "branch": "default", "desc": "Bug 1464412 - Flip vertical resizers on rtl sites. r=dao, a=RyanVM\n\nMozReview-Commit-ID: E0ejPUUCJiJ", "files": ["layout/generic/nsGfxScrollFrame.cpp", "layout/reftests/forms/textarea/reftest.list", "layout/reftests/forms/textarea/resize-rtl-vertical.html", "layout/reftests/forms/textarea/resize-vertical.html", "toolkit/content/minimal-xul.css"], "git_node": null, "git_parents": [null], "node": "1740ee9701753ed7427ecbc79b069c7b39c99750", "parents": ["409cd4e30401f3ffcb3b23c1fb6114fce3fe0975"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1464641 - Make sure we mark the out of flow frame as modified when we modify the placeholder. r=miko, a=RyanVM\n\nMozReview-Commit-ID: L44fXMOpURM", "files": ["layout/generic/nsFrame.cpp"], "git_node": null, "git_parents": [null], "node": "a56dbd423630e34c591043235bcf6d11ce977a19", "parents": ["1740ee9701753ed7427ecbc79b069c7b39c99750"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1463940 - Invalidate display items when we add a caption to a table, since it can change the ordering of the content. r=mstange, a=RyanVM\n\nMozReview-Commit-ID: HQewY2vNEJm", "files": ["layout/base/crashtests/1463940.html", "layout/base/crashtests/crashtests.list", "layout/tables/nsTableWrapperFrame.cpp"], "git_node": null, "git_parents": [null], "node": "1751ceaa8d097771db7f74f7de25d44ac3944c6c", "parents": ["a56dbd423630e34c591043235bcf6d11ce977a19"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "No bug - Re-alphabetize layout/base/crashtests/crashtests.list. r=thejanitor, a=test-only", "files": ["layout/base/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "4595defa2d63546867009d7af90ce9fe9f5ab15d", "parents": ["1751ceaa8d097771db7f74f7de25d44ac3944c6c"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1464641 - Add crashtest. a=test-only", "files": ["layout/base/crashtests/1464641.html", "layout/base/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "13924a524f1cbf616195af08388fbe24132e0fdd", "parents": ["4595defa2d63546867009d7af90ce9fe9f5ab15d"], "tags": ["DEVEDITION_61_0b10_BUILD1", "DEVEDITION_61_0b10_RELEASE", "FIREFOX_61_0b10_BUILD1", "FIREFOX_61_0b10_RELEASE"]}], "date": 1527705780, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9292": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "