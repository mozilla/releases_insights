it_parents": [null], "node": "be464c7297f52eabb4ecdcdc2a3ce95dd875fd4a", "parents": ["29331f5ffb475cf35547b436d9a54a104dfed6c8"], "tags": []}], "date": 1528468471, "git_changesets": [null], "user": "ffxbld"}, "9336": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nsk -\u003e af0c18fa399b", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "1c31084644342f84a569893dd96e95578a270fae", "parents": ["be464c7297f52eabb4ecdcdc2a3ce95dd875fd4a"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nbr -\u003e 7432fbe9c5dc\nsk -\u003e af0c18fa399b\nuk -\u003e 52fec63f40e2", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "0119d67ab929d6575b03c67a90fd7a5ffae9d7f9", "parents": ["1c31084644342f84a569893dd96e95578a270fae"], "tags": []}], "date": 1528471305, "git_changesets": [null, null], "user": "ffxbld"}, "9337": {"changesets": [{"author": "Simon Fraser \u003csfraser@mozilla.com\u003e", "branch": "default", "desc": "Bug 1467456 - Use correct hg repo in repo-update. r=lguo, a=release\n\n1. Updated hgrepo to work with mozilla-beta, mozilla-esr60 and project branches (just in case)\n2. Presquashed commits, so we only submit one.\n3. Replaced 'which' with 'command -v' to avoid future shellcheck issues.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1582", "files": ["taskcluster/docker/periodic-updates/scripts/periodic_file_updates.sh"], "git_node": null, "git_parents": [null], "node": "7679eddb8fdbf61701a1d950e34f19564726edf1", "parents": ["0119d67ab929d6575b03c67a90fd7a5ffae9d7f9"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1467215 - Abort initialisation on fatal error. r=maja_zf, a=test-only\n\nWhen the Marionette component fails to initialise we fail to bail\nout.  This causes Marionette to report itself as enabled through\nan environment variable, an observer notification, and a log message.\n\nMozReview-Commit-ID: 2nTNNP0o5dv", "files": ["testing/marionette/components/marionette.js"], "git_node": null, "git_parents": [null], "node": "a2590a16f2d8ad4a792b358cca61bbb397cbbc94", "parents": ["7679eddb8fdbf61701a1d950e34f19564726edf1"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1467215 - Reset prefs possibly set by failed init. r=maja_zf, a=test-only\n\nIf initialisation fails on being unable to start the TCP listener,\nwe may have already set some recommended preferences.  This patch\nensures any altered preferences get reset when uninit() is called\nin the try...catch block in init().\n\nMozReview-Commit-ID: B5vNvTUZcO7", "files": ["testing/marionette/components/marionette.js"], "git_node": null, "git_parents": [null], "node": "62eb18c6e28c354d9173d6dfdcfbf745338069a5", "parents": ["a2590a16f2d8ad4a792b358cca61bbb397cbbc94"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1266345 - Let MediaRecorder ignore ended tracks. r=bryce, a=RyanVM\n\nMozReview-Commit-ID: 8P1p0uI46BZ", "files": ["dom/media/MediaRecorder.cpp"], "git_node": null, "git_parents": [null], "node": "ae3aed9bb6a1b8ad23f08590342904ee274066fe", "parents": ["62eb18c6e28c354d9173d6dfdcfbf745338069a5"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1266345 - Re-enable test on linux64. r=bryce, a=RyanVM\n\nMozReview-Commit-ID: IJqncmqDeKL", "files": ["dom/media/test/mochitest.ini"], "git_node": null, "git_parents": [null], "node": "1601123621702985626c4773df5f10eb8bf23a94", "parents": ["ae3aed9bb6a1b8ad23f08590342904ee274066fe"], "tags": []}, {"author": "Honza Bambas \u003chonzab.moz@firemni.cz\u003e", "branch": "default", "desc": "Bug 1463786 - Make mozilla::Tokenizer work also with char16_t. r=froydnj, a=RyanVM", "files": ["xpcom/ds/IncrementalTokenizer.h", "xpcom/ds/Tokenizer.cpp", "xpcom/ds/Tokenizer.h", "xpcom/tests/gtest/TestTokenizer.cpp"], "git_node": null, "git_parents": [null], "node": "05773ede53681230ed0637c2a39f8bde45e752b2", "parents": ["1601123621702985626c4773df5f10eb8bf23a94"], "tags": []}, {"author": "Gabriele Svelto \u003cgsvelto@mozilla.com\u003e", "branch": "default", "desc": "Bug 1465898 - Remove unused code for managing physical audio devices. r=agaynor, a=abillings\n\nMozReview-Commit-ID: 7NsUfzJCUOB", "files": ["hal/Hal.cpp", "hal/Hal.h", "hal/HalInternal.h", "hal/HalTypes.h", "hal/fallback/FallbackSwitch.cpp", "hal/moz.build", "hal/sandbox/PHal.ipdl", "hal/sandbox/SandboxHal.cpp"], "git_node": null, "git_parents": [null], "node": "0c12ddf5d3f7b286a33d6ee464ebc8352de404f7", "parents": ["05773ede53681230ed0637c2a39f8bde45e752b2"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1466884 - Add permission needed to publish on Samsung AppStore. r=nalexander, a=RyanVM\n\nMozReview-Commit-ID: 3ISGwdy0nQQ", "files": ["mobile/android/base/FennecManifest_permissions.xml.in", "mobile/android/base/SamsungAppStoreManifest_permissions.xml.in"], "git_node": null, "git_parents": [null], "node": "534148c94be1e2cc3a6a9ff2459631d12f29ffbd", "parents": ["0c12ddf5d3f7b286a33d6ee464ebc8352de404f7"], "tags": []}], "date": 1528483437, "git_changesets": [null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9338": {"changesets": [{"author": "Honza Bambas \u003chonzab.moz@firemni.cz\u003e", "branch": "default", "desc": "Bug 1413868. r=valentin, a=RyanVM", "files": ["toolkit/xre/nsAppRunner.cpp", "toolkit/xre/nsEmbedFunctions.cpp", "xpcom/io/FilePreferences.cpp", "xpcom/io/FilePreferences.h", "xpcom/io/moz.build", "xpcom/io/nsLocalFileWin.cpp", "xpcom/tests/gtest/TestFilePreferencesWin.cpp", "xpcom/tests/gtest/moz.build"], "git_node": null, "git_parents": [null], "node": "0c31585602a7d7eea1b47dd177d74333d0a65eb9", "parents": ["534148c94be1e2cc3a6a9ff2459631d12f29ffbd"], "tags": []}, {"author": "Byron Campen [:bwc] \u003cdocfaraday@gmail.com\u003e", "branch": "default", "desc": "Bug 1464079 - Bring ICE connection state change callback up to spec. r=jib, a=RyanVM", "files": ["dom/media/PeerConnection.js"], "git_node": null, "git_parents": [null], "node": "dd3833f12682798d762fe2283a84c0420a0eac26", "parents": ["0c31585602a7d7eea1b47dd177d74333d0a65eb9"], "tags": []}, {"author": "Randell Jesup \u003crjesup@jesup.org\u003e", "branch": "default", "desc": "Bug 1395246 - Nullcheck DataChannel SendPacket calls, add some diagnostics. r=drno, a=RyanVM", "files": ["netwerk/sctp/datachannel/DataChannel.cpp", "netwerk/sctp/datachannel/DataChannel.h"], "git_node": null, "git_parents": [null], "node": "2eaf4e5e4dff0e55a3f0992af867618eb11539ea", "parents": ["dd3833f12682798d762fe2283a84c0420a0eac26"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1334981 - Backed out changeset d6ca24ba3673 for regression caused by bug 887718. r=enndeakin, a=RyanVM\n\nMozReview-Commit-ID: 9hIcRVRseO1", "files": ["dom/base/nsFocusManager.cpp"], "git_node": null, "git_parents": [null], "node": "9c3ebbc12a02922ef5812d18321a860437158c9c", "parents": ["2eaf4e5e4dff0e55a3f0992af867618eb11539ea"], "tags": []}], "date": 1528484396, "git_changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "9339": {"changesets": [{"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1467113: Save signedState in startup data. r=aswan a=RyanVM\n\nMozReview-Commit-ID: 5iIzy1qKS0P", "files": ["toolkit/mozapps/extensions/internal/XPIProvider.jsm"], "git_node": null, "git_parents": [null], "node": "8d528de4b44338c90c033032b05abc