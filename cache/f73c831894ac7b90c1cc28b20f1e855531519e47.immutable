tyle/CachedAnonBoxStyles.h"], "git_node": null, "git_parents": [null, null], "node": "b7adfffd7c227012134b40b3333fdd739a2bf5ed", "parents": ["61c9a681836a72bedb42ae41b8b0d697e6ae7453", "d2edd256c3aadb1cea48da0c8f62f725bd53cb76"], "tags": []}, {"author": "James Graham \u003cjames@hoppipolla.co.uk\u003e", "branch": "default", "desc": "Bug 1430025 - Never pause after test in CI, r=ato\n\nMozReview-Commit-ID: JP57dqYJHBe\n", "files": ["testing/mozharness/scripts/web_platform_tests.py"], "git_node": null, "git_parents": [null], "node": "e4d4a77b4c61a1be32c503ae13b4d873bbd22c1a", "parents": ["b7adfffd7c227012134b40b3333fdd739a2bf5ed"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1113014 - Don't emit a branch in LoadDOMPrivate if we know the object kind (native or proxy) statically. r=bz", "files": ["js/public/Proxy.h", "js/src/jit/CodeGenerator.cpp", "js/src/jit/IonBuilder.cpp", "js/src/jit/MIR.cpp", "js/src/jit/MIR.h", "js/src/vm/TypeInference.cpp", "js/src/vm/TypeInference.h"], "git_node": null, "git_parents": [null], "node": "4ef2425934f236201df33293a34c2400d5c5f19d", "parents": ["e4d4a77b4c61a1be32c503ae13b4d873bbd22c1a"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1426250 - allow EventUtils to dispatch drag/mouse events through the DOM only, r=enndeakin\n\nMozReview-Commit-ID: HmdRdTQ05pm", "files": ["testing/mochitest/tests/SimpleTest/EventUtils.js"], "git_node": null, "git_parents": [null], "node": "462b35675a119a778f35aed836aa88b606f0babd", "parents": ["4ef2425934f236201df33293a34c2400d5c5f19d"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1426250 - allow changing log preference at runtime for CUI.jsm, r=jaws\n\nMozReview-Commit-ID: 9kYBC27wowg", "files": ["browser/components/customizableui/CustomizableUI.jsm"], "git_node": null, "git_parents": [null], "node": "5551470e71c346c115b9aef08b7a75e9d8607e8e", "parents": ["462b35675a119a778f35aed836aa88b606f0babd"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1426250 - make tests actually pass valid mouse coordinates when testing Customize Mode, r=jaws\n\nMozReview-Commit-ID: IglKedBqrWQ", "files": ["browser/components/customizableui/CustomizeMode.jsm", "browser/components/customizableui/test/browser_876926_customize_mode_wrapping.js", "browser/components/customizableui/test/browser_878452_drag_to_panel.js", "browser/components/customizableui/test/browser_918049_skipintoolbarset_dnd.js", "browser/components/customizableui/test/browser_968565_insert_before_hidden_items.js", "browser/components/customizableui/test/browser_newtab_button_customizemode.js", "browser/components/customizableui/test/browser_remove_customized_specials.js", "browser/components/customizableui/test/head.js"], "git_node": null, "git_parents": [null], "node": "21ce1e95d697cbc1bdaa45d124e55642ff5b2fd3", "parents": ["5551470e71c346c115b9aef08b7a75e9d8607e8e"], "tags": []}, {"author": "Steve Pfister \u003csteveisok@gmail.com\u003e", "branch": "default", "desc": "Bug 1338497 - make the safebrowsing notification dismiss when navigating to other domains, r=gijs\n\nThis moves the Safe Browsing notification banner into its own object, makes it aware of the current base domain,\nand adds a function that's called when the location changes to determine if it should dismiss or not.\n\nMozReview-Commit-ID: 31JQ4dUyFb4", "files": ["browser/base/content/browser.js"], "git_node": null, "git_parents": [null], "node": "22130a72837bef78e4f29ef856f5c163a738fae5", "parents": ["21ce1e95d697cbc1bdaa45d124e55642ff5b2fd3"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1430030 - Enable parallelism when building wine, upx and fxc2. r=ted\n", "files": ["taskcluster/scripts/misc/build-mingw32-fxc2.sh", "taskcluster/scripts/misc/build-upx.sh", "taskcluster/scripts/misc/build-wine.sh"], "git_node": null, "git_parents": [null], "node": "767217abfb609e8728d4013c08a32c371a7b3326", "parents": ["22130a72837bef78e4f29ef856f5c163a738fae5"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1427340 - Build toolchains on a Debian-based docker image. r=gps\n\n... except libdmg-hfsplus. RedHat decided to patch libbz2 to have a\ndifferent soname, so a binary built on Debian can't run on\nRedHat/CentOS. Ironically, a binary built on RedHat/CentOS can run\non Debian. While we could use some tricks to make libdmg-hfsplus built\non Debian work, at this point, it's not worth the effort. We can live\nwith libdmg-hfsplus being built on CentOS until the builds that use it\nswitch to Debian, which is imminent.\n\n... and except mingw32-nsis. Sourceforce renewed their certificate last\nweek and somehow the corresponding CA is not yet recognized by the\nca-certificates in Debian wheezy (an update is underway but see below)\n\n... and except wine, because it requires more 32-bits packages than can\nbe installed on the toolchain-build docker image. But all things\nconsidered, the mingw32 builds don't need to be using the same docker\nimages as the linux builds, and they could be, like the android builds,\nbe based on a more recent build image. So the corresponding toolchains\ncan be built on a more recent version of Debian too.\n\nConsequently, we keep all the mingw32 related toolchains on the\ndesktop-build image for now.\n", "files": ["taskcluster/ci/toolchain/linux.yml", "taskcluster/ci/toolchain/macosx.yml", "taskcluster/ci/toolchain/windows.yml"], "git_node": null, "git_parents": [null], "node": "538460b6e1fd0126d2ba85ecc01609c1a728d324", "parents": ["767217abfb609e8728d4013c08a32c371a7b3326"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1427344 - Build GCC without --disable-initfini-array. r=nfroyd\n\nWhen building on Debian (which we now are), this means we enable\n.init_array/.fini_array.\n\nWhen building on CentOS, this means no change. Which implies we could\nroll back to CentOS-based toolchains by just switching back the\ntoolchain jobs to use the desktop-build docker image again.\n\nThis change causes massive differences in the resulting binaries because\nof the offset differences, but practically speaking, there is no\ndifference. .init_array/.fini_array have been supported in glibc for 18\nyears.\n", "files": ["build/unix/build-gcc/build-gcc.sh"], "git_node": null, "git_parents": [null], "node": "6e4c1669b6bafb90336ce4d9db9d134b081a9553", "parents": ["538460b6e1fd0126d2ba85ecc01609c1a728d324"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1427344 - Add Debian CRT objects to GCC. r=nfroyd\n\nOne of the last remaining differences when building Firefox on Debian\nwith all the changes we've done so far is that linking against the\nsystem libc statically links some CRT objects. This causes massive\ndifferences in the resulting binaries because of slight differences\nin those objects (because they weren't compiled with the same compiler\nand because they're not for the exact same glibc version)\n\nIn practice, their content difference don't cause any problem. If they\ndid, we wouldn't be able to run our builds on newer systems than those\nwe build them on. The only hypothetical risk would be to run on systems\nwith a glibc older than Debian 7's, but those already can't run Firefox\nanyways (those systems don't have Gtk+3, which is a system requirement).\n\nAFAICT, this is only an hypothetical problem anyways, even such systems\nwith Gtk+3 should be able to run those builds. Plus, this is a change\nthat will happen anyways when switching to Debian-based build images,\nsince they would be using the CRT objects from there. We're merely\nmaking it happen earlier so that the differences from switching to\nDebian-based build images are more tractable.\n\nNote we only do this when building GCC on Debian, allowing to roll back\nto CentOS-based toolchains by just switching back the toolchain jobs to\nuse the desktop-build docker image again.\n", "files": ["build/unix/build-gcc/build-gcc.sh"], "git_node": null, "git_parents": [null], "node": "7c92680e18dbc44de8b2bb5efbb23c686e0fc504", "parents": ["6e4c1669b6bafb90336ce4d9db9d134b081a9553"], "tags": []}, {"author": "Rofael Aleezada \u003cme@rofael.com\u003e", "branch": "default", "desc": "Bug 1427710 part 1 - Make TokenKind an enum class. r=jandem", "files": ["js/src/frontend/Parser.cpp", "js/src/frontend/Parser.h", "js/src/frontend/ReservedWords.h", "js/src/frontend/TokenKind.h", "js/src/frontend/TokenStream.cpp", "js/src/frontend/TokenStream.h", "js/src/wasm/AsmJS.cpp"], "git_node": null, "git_parents": [null], "node": "5eb4b2bdb7cd9acd4dac829bc930142d1f3b6d33", "parents": ["7c92680e18dbc44de8b2bb5efbb23c686e0fc504"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1425440 - Get rid of GetChildAt_Deprecated in nsRange, r=catalinb", "files": ["dom/base/nsRange.cpp", "dom/base/nsRange.h", "dom/html/nsGenericHTMLElement.cpp"], "git_node": null, "git_parents": [null], "node": "b3046ae63cbfbbd1ef6d0588e97f3c2a5321b0c2", "parents": ["5eb4b2bdb7cd9acd4dac829bc930142d1f3b6d33"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1425440 - Get rid of GetChildAt_Deprecated in selection, r=catalinb", "files": ["dom/base/Selection.cpp"], "git_node": null, "git_parents": [null], "node": "a0a5df1b4070ebe5acd614f6ab74aabba9d000d1", "parents": ["b3046ae63cbfbbd1ef6d0588e97f3c2a5321b0c2"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1425440 - Get rid of GetChildAt_Deprecated in nsFrameSelection, r=catal