totype/flatten/non-object-ctor-throws.js", "js/src/tests/test262/built-ins/Array/prototype/flatten/null-undefined-elements.js", "js/src/tests/test262/built-ins/Array/prototype/flatten/null-undefined-input-throws.js", "js/src/tests/test262/built-ins/Array/prototype/flatten/positive-infinity.js", "js/src/tests/test262/built-ins/Array/prototype/flatten/prop-desc.js", "js/src/tests/test262/built-ins/Array/prototype/flatten/symbol-object-create-null-depth-throws.js"], "git_node": null, "git_parents": [null], "node": "f38ff2642870a8b36cb13d3117806f4fad3a8eea", "parents": ["11049b0dda2e80706a3900403b86b72ffe45f17e"], "tags": []}, {"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400384 - only invert oblique transform on missing glyph for vertical writing mode. r=me", "files": ["gfx/thebes/gfxFont.cpp"], "git_node": null, "git_parents": [null], "node": "f5cb791416b79ef17df5909712e452bbfe4d41f7", "parents": ["f38ff2642870a8b36cb13d3117806f4fad3a8eea"], "tags": []}, {"author": "Csoregi Natalia \u003cncsoregi@mozilla.com\u003e", "branch": "default", "desc": "Backed out 2 changesets (bug 1421398) for failing xpconnect/tests/chrome/test_xrayToJS.xul - lack of security audit. on a CLOSED TREE\n\nBacked out changeset f38ff2642870 (bug 1421398)\nBacked out changeset 11049b0dda2e (bug 1421398)", "files": ["js/src/builtin/Array.js", "js/src/jsarray.cpp", "js/src/tests/jstests.list", "js/src/tests/test262-update.py", "js/src/tests/test262/built-ins/Array/prototype/flatMap/array-like-objects.js", "js/src/tests/test262/built-ins/Array/prototype/flatMap/bound-function-argument.js", "js/src/tests/test262/built-ins/Array/prototype/flatMap/depth-always-one.js", "js/src/tests/test262/built-ins/Array/prototype/flatMap/length.js", "js/src/tests/test262/built-ins/Array/prototype/flatMap/name.js", "js/src/tests/test262/built-ins/Array/prototype/flatMap/non-callable-argument-throws.js", "js/src/tests/test262/built-ins/Array/prototype/flatMap/non-object-ctor-throws.js", "js/src/tests/test262/built-ins/Array/prototype/flatMap/null-undefined-input-throws.js", "js/src/tests/test262/built-ins/Array/prototype/flatMap/thisArg-argument-strict.js", "js/src/tests/test262/built-ins/Array/prototype/flatten/array-like-objects.js", "js/src/tests/test262/built-ins/Array/prototype/flatten/bound-function-call.js", "js/src/tests/test262/built-ins/Array/prototype/flatten/empty-array-elements.js", "js/src/tests/test262/built-ins/Array/prototype/flatten/empty-object-elements.js", "js/src/tests/test262/built-ins/Array/prototype/flatten/length.js", "js/src/tests/test262/built-ins/Array/prototype/flatten/name.js", "js/src/tests/test262/built-ins/Array/prototype/flatten/non-numeric-depth-should-not-throw.js", "js/src/tests/test262/built-ins/Array/prototype/flatten/non-object-ctor-throws.js", "js/src/tests/test262/built-ins/Array/prototype/flatten/null-undefined-elements.js", "js/src/tests/test262/built-ins/Array/prototype/flatten/null-undefined-input-throws.js", "js/src/tests/test262/built-ins/Array/prototype/flatten/positive-infinity.js", "js/src/tests/test262/built-ins/Array/prototype/flatten/prop-desc.js", "js/src/tests/test262/built-ins/Array/prototype/flatten/symbol-object-create-null-depth-throws.js"], "git_node": null, "git_parents": [null], "node": "190d9992de1b9ed19e68c03f3fd0032ac324b3e7", "parents": ["f5cb791416b79ef17df5909712e452bbfe4d41f7"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1431105 - Prefix in Console when used by JSM, r=bgrins, r=smaug", "files": ["devtools/client/webconsole/new-console-output/test/fixtures/stubs/consoleApi.js", "dom/console/Console.cpp", "dom/console/Console.h", "dom/console/ConsoleInstance.cpp", "dom/console/tests/test_jsm.xul", "dom/webidl/Console.webidl"], "git_node": null, "git_parents": [null], "node": "6405716d757df0ee49f6beec764086422529b6a2", "parents": ["190d9992de1b9ed19e68c03f3fd0032ac324b3e7"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1430823: Pass in `Parameters` to `load_kinds` in `mach artifact toolchain`; r=dustin\n\nDifferential Revision: https://phabricator.services.mozilla.com/D409", "files": ["python/mozbuild/mozbuild/mach_commands.py"], "git_node": null, "git_parents": [null], "node": "3a84918576511005057a1a234587ed8fdf63ef4d", "parents": ["6405716d757df0ee49f6beec764086422529b6a2"], "tags": []}, {"author": "Jeff Gilbert \u003cjgilbert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1429963 - Don't allow RBAB on Mesa for now. - r=lenzak\n\nRBAB makes it easy to trigger TDRs, so let's punt on fixing the TDR\nhandling for now.\n\nMozReview-Commit-ID: LRimFTn1mJA\n", "files": ["gfx/gl/GLContext.cpp"], "git_node": null, "git_parents": [null], "node": "5b730501efa0302ddc914e542b2c70b06d06deb0", "parents": ["3a84918576511005057a1a234587ed8fdf63ef4d"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1429846: Fix slotted invalidation. r=heycam\n\nThis is a partial revert of\nhttps://github.com/servo/servo/commit/ce1d8cd232dfbc9e0a52f9467ba2bc209087ea63\n\nIf you're in a shadow tree, you may not be slotted but you still need to look at\nthe slotted rules, since a \u003cslot\u003e could be a descendant of yours.\n\nJust use the same invalidation map everywhere, and remove complexity.\n\nThis means that we can do some extra work while trying to gather invalidation\nif there are slotted rules, but I don't think it's a problem.\n\nThe test is ported from https://cs.chromium.org/chromium/src/third_party/WebKit/LayoutTests/fast/css/invalidation/slotted.html?l=1&rcl=58d68fdf783d7edde1c82a642e037464861f2787\n\nCuriously, Blink fails the test as written, presumably because they don't flush\nstyles from getComputedStyle correctly (in their test they do via\nupdateStyleAndReturnAffectedElementCount), due to \u003cslot\u003es not being in the flat\ntree in their implementation.\n\nMozReview-Commit-ID: 6b7BQ6bGMgd\n", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/css/css-scoping/slotted-invalidation.html"], "git_node": null, "git_parents": [null], "node": "bec4537b2efd4f8381c5f398c71bc0f09d4da981", "parents": ["1b62dd209727c2482150340c669c3957d9920670"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1430608: Make nsMediaFeatures work with a document, not a pres context. r=heycam\n\nReturning a zero-sized viewport in the case there's no shell / pres context.\n\nFor now, no other change yet. After this we can start tweaking the ShadowRoot\nStylist setup, and even try to return computed styles without a document \\o/.\n\nMozReview-Commit-ID: 3cT2PKQISri\n", "files": ["dom/base/nsIDocument.h", "gfx/thebes/gfxSVGGlyphs.cpp", "layout/base/nsPresContext.h", "layout/style/nsMediaFeatures.cpp", "layout/style/nsMediaFeatures.h", "layout/style/nsMediaList.cpp", "layout/svg/nsSVGContainerFrame.cpp", "layout/svg/nsSVGUtils.cpp"], "git_node": null, "git_parents": [null], "node": "16d1bd6dba918d51efd2a3d36d610be1a6e35200", "parents": ["bec4537b2efd4f8381c5f398c71bc0f09d4da981"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1409672: Hook in the invalidator stuff. r=xidorn\n\nMozReview-Commit-ID: EoSMrYPS7dl\n", "files": ["dom/xbl/nsBindingManager.cpp", "dom/xbl/nsBindingManager.h", "layout/base/PresShell.cpp", "layout/style/ServoBindingList.h", "layout/style/ServoStyleSet.cpp", "layout/style/ServoStyleSet.h"], "git_node": null, "git_parents": [null], "node": "b54c60961def24de47cd13dc90e837e0a5049b2e", "parents": ["16d1bd6dba918d51efd2a3d36d610be1a6e35200"], "tags": []}, {"author": "Ralph Giles \u003cgiles@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430886 - Disable incremental rust in automation. r=froydnj\n\nWork around excessive command-line length issues by\ndisabling incremental rust compilation, which is enabled\nby default outside `cargo --release` starting with Rust 1.24.\n\nIncremental rust builds shouldn't help much in automation,\nwhere sccache provides the only continuity between build\nenvironments. In the meantime, they add a lot of object\nfiles to the link line.\n\nSee https://github.com/rust-lang/rust/pull/47507 about addressing\nthe underlying issue upstream.\n\nMozReview-Commit-ID: LRwUj3fhiaO", "files": ["config/rules.mk"], "git_node": null, "git_parents": [null], "node": "261725e65af9b5d98ff593db3db08632bf019454", "parents": ["b54c60961def24de47cd13dc90e837e0a5049b2e"], "tags": []}, {"author": "Gerald Squelart \u003cgsquelart@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430494 - Skip new-list loop and its related operations if list is empty - r=mattwoodrow\n\nMozReview-Commit-ID: LkY2lldl7Al", "files": ["layout/painting/RetainedDisplayListBuilder.cpp"], "git_node": null, "git_parents": [null], "node": "50a5f0a088995c5e5fce91aab24306148491bec9", "parents": ["261725e65af9b5d98ff593db3db08632bf019454"], "tags": []}, {"author": "Dustin J. Mitchell \u003cdustin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403519 - only build docs when necessary r=gps\n\nThis marks **/docs/** as exclusively docs, and code that is autodoc'd as\ninclusively docs.\n\nThat means that a change that purely modifies documentation files will *only*\nrun `docs` tasks, while a change that modifies autodoc'd source code will\n*additionaly* run `docs` tasks.  The tasks do not run by default.\n\nMozReview-Commit-ID: G9tOK0AwtrI", "files": ["browser/base/moz.build", "browser/experiments/moz.build", "browser/moz.build", "build/moz.build", "dom/bindings/moz.build", "gfx/moz.build", "mobile/android/moz.build", "moz.build", "python/moz.build", "python/mozbuild/mozbuild/schedules.py", "taskcluster/ci/source-test/doc.yml", "taskcluster/moz.build", "testing/geckodriver/moz.build", "testing/marionette/moz.build", "testing/mozbase/moz.build", "toolkit/components/crashes/moz.build", "toolkit/components/extensions/moz.build", "toolkit/components/payments/moz.build", "toolkit/components/telemetry/moz.build", "toolkit/components/url-classifier/moz.build", "toolkit/crashreporter/moz.build", "toolkit/modules/moz.build", "toolkit/modules/subprocess/moz.build", "toolkit/mozapps/extensions/moz.build", "tools/moz.build"], "git_node": null, "git_parents": [null], "node": "0f0395687d36597098e4248457ed69f092c39f8f", "parents": ["50a5f0a088995c5e5fce91aab24306148491bec9"], "tags": []}, {"author": "Dustin J. Mitchell \u003cdustin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403519: reset SCHEDULES.exclusive if set multiple times; r=gps\n\nMozReview-Commit-ID: Kycd9i5f19P", "files": ["python/mozbuild/mozbuild/frontend/context.py", "python/mozbuild/mozbuild/test/frontend/data/schedules/moz.build", "python/mozbuild/mozbuild/test/frontend/test_reader.py", "taskcluster/docs/optimization-schedules.rst"], "git_node": null, "git_parents": [null], "node": "ce4e64aa7ea0452877bfbd597a5db413e476c1c2", "parents": ["0f0395687d36597098e4248457ed69f092c39f8f"], "tags": []}, {"author": "Bob Silverberg \u003cbsilverberg@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430590 - Watch for and respond to TP pref changes on about:preferences, r=jaws\n\nMozReview-Commit-ID: CIeg7qRLf6N", "files": ["browser/components/preferences/in-content/privacy.js"], "git_node": null, "git_parents": [null], "node": "142e0c92435a281bc5389e16694dfff8d815ea6c", "parents": ["ce4e64aa7ea0452877bfbd597a5db413e476c1c2"], "tags": []}, {"author": "Glenn Watson \u003cgithub@intuitionlibrary.com\u003e", "branch": "default", "desc": "servo: Merge #19780 - Update WR (persistent box-shadow render task cache) (from glennw:update-wr-cache); r=jdm\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 8612a87ed28bbc4b9050e47b3bc4d49ea076a1cf", "files": ["servo/Cargo.lock", "servo/components/layout/display_list/webrender_helpers.rs"], "git_node": null, "git_parents": [null], "node": "1b637d989945b19ede770bc954d0899047eac3a2", "parents": ["142e0c92435a281bc5389e16694dfff8d815ea6c"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Backout changeset b54c60961def (Bug 1409672) for failing one OSX reftest on a CLOSED TREE. r=backout\n\nMozReview-Commit-ID: 6ZHlFBpMOUo\n", "files": ["dom/xbl/nsBindingManager.cpp", "dom/xbl/nsBindingManager.h", "layout/base/PresShell.cpp", "layout/style/ServoBindingList.h", "layout/style/ServoStyleSet.cpp", "layout/style/ServoStyleSet.h"], "git_node": null, "git_parents": [null], "node": "845e7e62c673e1e7b42f54661575469d31313c02", "parents": ["1b637d989945b19ede770bc954d0899047eac3a2"], "tags": []}, {"author": "Tiberius Oros \u003ctoros@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 50a5f0a08899 (bug 1430494)for dependency with bug 1420737 that causes merge conflict on CLOSED TREE", "files": ["layout/painting/RetainedDisplayListBuilder.cpp"], "git_node": null, "git_parents": [null], "node": "115899fa5acc514905bcdab3f8d8c67c4c8d92a5", "parents": ["845e7e62c673e1e7b42f54661575469d31313c02"], "tags": []}, {"author": "Tiberius Oros \u003ctoros@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland. a=merge CLOSED TREE", "files": ["layout/painting/RetainedDisplayListBuilder.cpp", "layout/reftests/display-list/retained-dl-zindex-1-ref.html", "layout/reftests/display-list/retained-dl-zindex-1.html", "layout/reftests/display-list/retained-dl-zindex-2-ref.html", "layout/reftests/display-list/retained-dl-zindex-2.html", "layout/style/nsCSSPropList.h", "mobile/android/app/src/main/res/values-v17/themes.xml", "mobile/android/config/mozconfigs/android-api-16/nightly-without-google-play-services", "mobile/android/docs/gradle.rst", "mobile/android/gradle/product_flavors.gradle", "testing/mozharness/configs/builds/releng_sub_android_configs/64_api_16_without_google_play_services.py"], "git_node": null, "git_parents": [null, null], "node": "b0af51b89b20b4db0fdb926e67c3817a01ad0843", "parents": ["115899fa5acc514905bcdab3f8d8c67c4c8d92a5", "b7a651281314d6369658eeb58e3bb181cf95016f"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1431226 - Reference proper function and allow loading hgrc; r=nalexander\n\nThis fixes a regression in 195e88aab631 (bug 1429094).\n\nWhen I reviewed that changeset, I didn't realize there were callers\nof the renamed function outside the file.\n\nThe other caller (changed in this commit) needs to interact with the\nrepository. This may require loading extensions. So we can no longer\nunconditionally disable the loading of hgrc. We add an argument to\ncontrol the loading of hgrc to support this.\n\nMozReview-Commit-ID: 8AkPhvtC1VH", "files": ["python/mozboot/mozboot/base.py", "python/mozboot/mozboot/bootstrap.py"], "git_node": null, "git_parents": [null], "node": "921fc0797dc1ef65d17da35af667d64419cd947d", "parents": ["b0af51b89b20b4db0fdb926e67c3817a01ad0843"], "tags": []}, {"author": "Brendan Dahl \u003cbrendan.dahl@gmail.com\u003e", "branch": "default", "desc": "Bug 1355354 - Keep a reference to the progress listener to keep it from being gc'ed prematurely. r=mossop\n\nMozReview-Commit-ID: A6WM1Bj3Z5L", "files": ["browser/components/shell/HeadlessShell.jsm", "widget/headless/tests/test_headless.js"], "git_node": null, "git_parents": [null], "node": "ff483bbeacaf72aff8e6ec6e227dafdcdce11825", "parents": ["921fc0797dc1ef65d17da35af667d64419cd947d"], "tags": []}, {"author": "Andrew Halberstadt \u003cahalberstadt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1386857 - [taskgraph] Add path of offending config file to the UNKNOWN_GROUP_NAME error message, r=dustin\n\nWhen trying to remove an ubiquitous group like tc(), it's hard to tell where the\nerror was located without grepping my filesystem. This makes it a bit easier to\nfind and fix these errors.\n\nMozReview-Commit-ID: 8NjvB5zOoqb", "files": ["taskcluster/taskgraph/transforms/task.py", "taskcluster/taskgraph/transforms/tests.py"], "git_node": null, "git_parents": [null], "node": "f924db10f84f5b10536651002965ebcefb3b8a72", "parents": ["ff483bbeacaf72aff8e6ec6e227dafdcdce11825"], "tags": []}, {"author": "Andrew Halberstadt \u003cahalberstadt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1386857 - [ci] Remove the 'tc' treeherder group prefix from all tasks, r=dustin\n\nThere are now only a handful of buildbot jobs remaining and the concern over\noutdated treeherder exclusion profiles has largely been resolved.\n\nThis does remove the tc() group from a substantial number of tasks which will\nnow show up as top level tasks, potentially adding clutter. In some cases, we\nmight want to re-add a new group (e.g group builds or compiled tests together).\nHowever rather than try to predict the best group names for tasks I'm unfamiliar\nwith, I think it's best to land this as is. Then if things are looking too\ncluttered at the root namespace, file follow-up bugs as needed.\n\nMozReview-Commit-ID: 8SMwjDwAOzV", "files": ["taskcluster/ci/build/android-stuff.yml", "taskcluster/ci/build/android.yml", "taskcluster/ci/build/linux.yml", "taskcluster/ci/build/macosx.yml", "taskcluster/ci/build/windows.yml", "taskcluster/ci/config.yml", "taskcluster/ci/hazard/kind.yml", "taskcluster/ci/l10n/kind.yml", "taskcluster/ci/nightly-l10n/kind.yml", "taskcluster/ci/release-source/source.yml", "taskcluster/ci/source-test/doc.yml", "taskcluster/ci/spidermonkey/linux.yml", "taskcluster/ci/spidermonkey/windows.yml", "taskcluster/ci/static-analysis/kind.yml", "taskcluster/ci/test/awsy.yml", "taskcluster/ci/test/compiled.yml", "taskcluster/ci/test/firefox-ui.yml", "taskcluster/ci/test/marionette.yml", "taskcluster/ci/test/misc.yml", "taskcluster/ci/test/mochitest.yml", "taskcluster/ci/test/reftest.yml", "taskcluster/ci/test/talos.yml", "taskcluster/ci/test/web-platform.yml", "taskcluster/ci/test/xpcshell.yml", "taskcluster/ci/valgrind/kind.yml", "taskcluster/taskgraph/transforms/beetmover.py", "taskcluster/taskgraph/transforms/beetmover_checksums.py", "taskcluster/taskgraph/transforms/beetmover_l10n.py", "taskcluster/taskgraph/transforms/beetmover_repackage.py", "taskcluster/taskgraph/transforms/beetmover_repackage_l10n.py", "taskcluster/taskgraph/transforms/checksums_signing.py", "taskcluster/taskgraph/transforms/nightly_l10n_signing.py", "taskcluster/taskgraph/transforms/repackage.py", "taskcluster/taskgraph/transforms/repackage_l10n.py", "taskcluster/taskgraph/transforms/repackage_signing.py", "taskcluster/taskgraph/transforms/signing.py", "taskcluster/taskgraph/transforms/upload_symbols.py"], "git_node": null, "git_parents": [null], "node": "47cfae837c499c0dcf95c646114f1b4ee129d7ad", "parents": ["f924db10f84f5b10536651002965ebcefb3b8a72"], "tags": []}, {"author": "Alexandre Poirot \u003cpoirot.alex@gmail.com\u003e", "branch": "default", "desc": "Bug 1422061 - Prevent performance actor from stopping profiler started by Talos. r=gregtatum\n\nMozReview-Commit-ID: 7PrI9ZwUMtX", "files": ["devtools/server/performance/profiler.js"], "git_node": null, "git_parents": [null], "node": "cccd776a80d97621554ed046072bc7ea3dc0bdad", "parents": ["47cfae837c499c0dcf95c646114f1b4ee129d7ad"], "tags": []}, {"author": "Alexandre Poirot \u003cpoirot.alex@gmail.com\u003e", "branch": "default", "desc": "Bug 1428796 - Make devtools entry point telemetry never expire. r=Harald,liuche\n\nMozReview-Commit-ID: 9SUYvq7doWw", "files": ["toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "7c67b6dd2450bfacbffc44b8eff0444aa4cfcf73", "parents": ["cccd776a80d97621554ed046072bc7ea3dc0bdad"], "tags": []}, {"author": "Tiberius Oros \u003ctoros@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to inbound.  a=merge CLOSED TREE", "files": ["devtools/client/webconsole/new-console-output/test/mochitest/browser_webconsole_notifications.js", "layout/reftests/display-list/retained-dl-zindex-1-ref.html", "layout/reftests/display-list/retained-dl-zindex-1.html", "layout/reftests/display-list/retained-dl-zindex-2-ref.html", "layout/reftests/display-list/retained-dl-zindex-2.html", "mobile/android/app/src/main/res/values-v17/themes.xml", "mobile/android/config/mozconfigs/android-api-16/nightly-without-google-play-services", "mobile/android/docs/gradle.rst", "mobile/android/gradle/product_flavors.gradle", "testing/mozharness/configs/builds/releng_sub_android_configs/64_api_16_without_google_play_services.py", "third_party/rust/mozversion/.cargo-checksum.json", "third_party/rust/mozversion/Cargo.toml", "third_party/rust/mozversion/src/lib.rs"], "git_node": null, "git_parents": [null, null], "node": "3dc3baec3fae36a0b2344436ebd5e147aba5dd6d", "parents": ["5b730501efa0302ddc914e542b2c70b06d06deb0", "b7a651281314d6369658eeb58e3bb181cf95016f"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1429846: Skip the test in non-stylo on a CLOSED TREE. r=me\n\nMozReview-Commit-ID: HF9lt3uz2Eh\n", "files": ["testing/web-platform/meta/css/css-scoping/slotted-invalidation.html.ini"], "git_node": null, "git_parents": [null], "node": "6eb62602664db18cda1e6ce1c69b00c773e7f225", "parents": ["7c67b6dd2450bfacbffc44b8eff0444aa4cfcf73"], "tags": []}, {"author": "Edouard Oger \u003ceoger@fastmail.com\u003e", "branch": "default", "desc": "Bug 1429154 - Remove FXA_VERIFICATION_METHOD probe. r=tcsc\n\nMozReview-Commit-ID: JK8MVkmPRGK", "files": ["services/fxaccounts/FxAccounts.jsm", "toolkit/components/telemetry/Scalars.yaml"], "git_node": null, "git_parents": [null], "node": "83d55f6e89b94503199581667fa7113726b04454", "parents": ["6eb62602664db18cda1e6ce1c69b00c773e7f225"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1431089 - Truncate logged URLs. r=maja_zf\n\nBecause we use a lot of data URIs when testing Marionette, the URLs\nwe log during navigation can be quite long.  As with logged packets,\nwe should truncate the URLs.\n\nMozReview-Commit-ID: AKpr5vvdU8P", "files": ["testing/marionette/listener.js"], "git_node": null, "git_parents": [null], "node": "f390f152d0ac959dac2bb159ac35862071dba546", "parents": ["83d55f6e89b94503199581667fa7113726b04454"], "tags": []}, {"author": "Edouard Oger \u003ceoger@fastmail.com\u003e", "branch": "default", "desc": "Bug 1430970 - Fix FxAccounts internal mocking. r=tcsc\n\nMozReview-Commit-ID: 7ATwZTJ4w5K", "files": ["services/fxaccounts/FxAccounts.jsm"], "git_node": null, "git_parents": [null], "node": "16d1d6155d1df239e8663f8d8e264bc4e744cef8", "parents": ["f390f152d0ac959dac2bb159ac35862071dba546"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1431057 part 1.  Add a ChromeUtils.import that does what Cu.import does.  r=kmag\n\nMozReview-Commit-ID: IOaL8fdyoGO", "files": ["dom/base/ChromeUtils.cpp", "dom/base/ChromeUtils.h", "dom/base/moz.build", "dom/webidl/ChromeUtils.webidl"], "git_node": null, "git_parents": [null], "node": "f5e03a6d354571b39cba0ba911df5634cfa14019", "parents": ["3dc3baec3fae36a0b2344436ebd5e147aba5dd6d"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1425611 part 2.  Allow sandboxes to import the ChromeUtils API.  r=kmag\n\nMozReview-Commit-ID: JUxjcmq8gAx", "files": ["js/xpconnect/src/Sandbox.cpp", "js/xpconnect/src/xpcprivate.h"], "git_node": null, "git_parents": [null], "node": "7d463ab1b36b77e34c6b0ea7910552038b4cb063", "parents": ["f5e03a6d354571b39cba0ba911df5634cfa14019"], "tags": []}, {"author": "sotaro \u003csotaro.ikeda.g@gmail.com\u003e", "branch": "default", "desc": "Bug 1430700 - Implement WebRenderFallbackData::ClearCachedResources() r=nical", "files": ["gfx/layers/wr/WebRenderUserData.cpp", "gfx/layers/wr/WebRenderUserData.h"], "git_node": null, "git_parents": [null], "node": "524088f8b35cbdf4fb5f64c8dca083fb36f4ec35", "parents": ["7d463ab1b36b77e34c6b0ea7910552038b4cb063"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430948. P1 - add fuzzy mode to MediaTimer. r=jya\n\nWe will resolve the timer promise even if it is fired slightly before\nthe scheduled target. This is used by MDSM which doesn't require high-res\ntimers.\n\nMozReview-Commit-ID: 1IAsG5gG9D7", "files": ["dom/media/MediaTimer.cpp", "dom/media/MediaTimer.h"], "git_node": null, "git_parents": [null], "node": "d8fec54a8cc95e296970ddfbf429232d89b0d9e4", "parents": ["16d1d6155d1df239e8663f8d8e264bc4e744cef8"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430948. P2 - turn on fuzzy mode for MDSM which doesn't require high resolution timers. r=jya\n\nMozReview-Commit-ID: BcWz7UmdHC2", "files": ["dom/media/MediaDecoderStateMachine.cpp"], "git_node": null, "git_parents": [null], "node": "b0fdde0a9b35879a9496f878e8bf2d15a491bc2f", "parents": ["d8fec54a8cc95e296970ddfbf429232d89b0d9e4"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1431041: Make placeholder apply to \u003cinput type=\"number\"\u003e. r=smaug\n\nMozReview-Commit-ID: GLbdLxHLiH4", "files": ["dom/html/HTMLInputElement.cpp", "layout/reftests/css-placeholder/input/placeholdershown-ref.html", "layout/reftests/css-placeholder/input/placeholdershown.html"], "git_node": null, "git_parents": [null], "node": "7a4c3ab0ade85738f3ac614eea4be470668d4576", "parents": ["b0fdde0a9b35879a9496f878e8bf2d15a491bc2f"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1431041: Fix placeholder-shown when the value of the input is invalid. r=smaug\n\nWow, the setup for \u003cinput type=\"number\"\u003e is really weird :(.\n\nLooking at the callers, this should be sane.\n\nMozReview-Commit-ID: C0ZNNSdg0Hb", "files": ["dom/html/HTMLInputElement.cpp", "dom/html/HTMLInputElement.h", "dom/html/test/forms/mochitest.ini", "dom/html/test/forms/test_input_number_placeholder_shown.html"], "git_node": null, "git_parents": [null], "node": "57641ee7058f016c28bbb67b6a224d45e1b7fb9e", "parents": ["7a4c3ab0ade85738f3ac614eea4be470668d4576"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1431282.  Work around layout violating its own invariants and causing stylo code to crash, _again_.  r=emilio\n\nMozReview-Commit-ID: 3ggJI0qmOJV", "files": ["layout/generic/nsInlineFrame.cpp"], "git_node": null, "git_parents": [null], "node": "09d0f66b1eee218419cd244c16bfc99449fb3711", "parents": ["524088f8b35cbdf4fb5f64c8dca083fb36f4ec35"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1429951 - Propagate the non-premultiplied flag for textures to WR. r=sotaro\n\nMozReview-Commit-ID: Vd5n5e7XuW", "files": ["dom/canvas/test/reftest/reftest.list", "gfx/layers/composite/TextureHost.cpp", "gfx/layers/d3d11/TextureD3D11.cpp", "gfx/layers/opengl/MacIOSurfaceTextureHostOGL.cpp", "gfx/webrender_bindings/WebRenderAPI.cpp", "gfx/webrender_bindings/WebRenderAPI.h", "gfx/webrender_bindings/src/bindings.rs", "gfx/webrender_bindings/webrender_ffi_generated.h"], "git_node": null, "git_parents": [null], "node": "6bb1a5b5510be53b0dcabc836b6bb3d03c3b0846", "parents": ["57641ee7058f016c28bbb67b6a224d45e1b7fb9e"], "tags": []}, {"author": "Alfredo.Yang \u003cayang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1429986 - send telemetry data when users attempt to play mkv file. r=jwwang,liuche\n\nMozReview-Commit-ID: Ah3pXC4cJ7n", "files": ["dom/media/DecoderTraits.cpp", "dom/media/DecoderTraits.h", "toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "4c6d55c85948994725e9335f6867a8ad2bfaa81c", "parents": ["6bb1a5b5510be53b0dcabc836b6bb3d03c3b0846"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "servo: Merge #19799 - style: Remove new function added to the build from bindings.rs (from emilio:everything-is-red); r=emilio\n\nSince it was removed from gecko, and this confuses a lot to\nports/geckolib/tests/build.rs.\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 1f6a864ab5372fe4f59b1a4c3db7cf8e7a79b06d", "files": ["servo/components/style/gecko/generated/bindings.rs"], "git_node": null, "git_parents": [null], "node": "881f72630743689008bc0662a69a960ba630fce9", "parents": ["4c6d55c85948994725e9335f6867a8ad2bfaa81c"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1429998 - Exclude toolchain and package tasks from the target task set. r=dustin\n\nBack in bug 1360609, we added `run-on-projects` to a list so that the\ntoolchain tasks wouldn't run on every push on release branches.\n\nFast forward to now, and they're depended upon by other tasks, meaning\nthey are triggered when appropriate, without resorting to that trick. In\nfact, the commit message for bug 1360609 said we could switch to an\nempty list once the jobs have dependencies.\n\nThe same is true from package tasks, which, in fact, I suspect would\nhappen on every push on release branches.\n\nThe only exception is for a few toolchains that are depended upon by\nnothing, and that are produced for developer consumption with e.g. mach\nartifact toolchain.", "files": ["taskcluster/ci/packages/kind.yml", "taskcluster/ci/toolchain/kind.yml", "taskcluster/ci/toolchain/linux.yml", "taskcluster/ci/toolchain/macosx.yml", "taskcluster/ci/toolchain/windows.yml", "taskcluster/taskgraph/transforms/job/toolchain.py"], "git_node": null, "git_parents": [null], "node": "2b06dfba4557a49e7f271f4091fcac3eb79297d2", "parents": ["881f72630743689008bc0662a69a960ba630fce9"], "tags": []}, {"author": "Csoregi Natalia \u003cncsoregi@mozilla.com\u003e", "branch": "default", "desc": "Backed out 2 changesets (bug 1431041) for failing dom/html/test/forms/test_input_number_placeholder_shown.html. on a CLOSED TREE\n\nBacked out changeset 57641ee7058f (bug 1431041)\nBacked out changeset 7a4c3ab0ade8 (bug 1431041)", "files": ["dom/html/HTMLInputElement.cpp", "dom/html/HTMLInputElement.h", "dom/html/test/forms/mochitest.ini", "dom/html/test/forms/test_input_number_placeholder_shown.html", "layout/reftests/css-placeholder/input/placeholdershown-ref.html", "layout/reftests/css-placeholder/input/placeholdershown.html"], "git_node": null, "git_parents": [null], "node": "13c36da892b2dc4b9ba9461d6038f5d78754d58f", "parents": ["2b06dfba4557a49e7f271f4091fcac3eb79297d2"], "tags": []}, {"author": "J.C. Jones \u003cjjones@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430947 - Add [SecureContext] to navigator.credentials r=bz\n\nIt was neglected to mark navigator.credentials as [SecureContext], yet it\nmust be for spec compliance and powerful-features compliance.\n\nMozReview-Commit-ID: BYKGqqhoS2L", "files": ["dom/webidl/Navigator.webidl", "testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/credential-management/require_securecontext.html"], "git_node": null, "git_parents": [null], "node": "9f192d955648318fb10df4960cdbe2bcb1181c89", "parents": ["13c36da892b2dc4b9ba9461d6038f5d78754d58f"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430975 - Rename |aDuration| argument to |aElapsedTime|. r=boris\n\nIt's not actually duration.\n\nMozReview-Commit-ID: LUHrJTJPMuj", "files": ["layout/style/nsTransitionManager.h"], "git_node": null, "git_parents": [null], "node": "890bae053e53ac163c811aa8af12129b05ee49f3", "parents": ["9f192d955648318fb10df4960cdbe2bcb1181c89"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430975 - Don't pass a copy of StickyTimeDuration. r=boris\n\nMozReview-Commit-ID: HlQlMB1FBRi", "files": ["dom/animation/Animation.h", "layout/style/nsAnimationManager.cpp", "layout/style/nsAnimationManager.h", "layout/style/nsTransitionManager.cpp", "layout/style/nsTransitionManager.h"], "git_node": null, "git_parents": [null], "node": "bdfe507f5294259b7da34fcaf6bc7a8517300c53", "parents": ["890bae053e53ac163c811aa8af12129b05ee49f3"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430975 - Make zero duration as a static constexpr. r=boris\n\nMozReview-Commit-ID: GX9qzgLkkNn", "files": ["layout/style/nsAnimationManager.cpp", "layout/style/nsTransitionManager.cpp"], "git_node": null, "git_parents": [null], "node": "da6ed0639905f8aeb833f32975f0304f40c820bf", "parents": ["bdfe507f5294259b7da34fcaf6bc7a8517300c53"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430975 - Reduce elapsed time precision only for animationcancel event. r=boris\n\nOnly animationcancel event uses current time, the elapsed time for other\nanimation events are simply calculated from given animation properties (e.g.\nanimation-duration, animation-delay, etc.), so they should not be reduced the\nprecision.\n\nSee the table for each elapsed time;\nhttps://drafts.csswg.org/css-animations-2/#event-dispatch\n\nMozReview-Commit-ID: 1KGUAdDHyXV", "files": ["layout/style/nsAnimationManager.cpp", "layout/style/nsAnimationManager.h"], "git_node": null, "git_parents": [null], "node": "3141e18a84e7eafe76a44e35156f9177ecd5f816", "parents": ["da6ed0639905f8aeb833f32975f0304f40c820bf"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430975 - Reduce elapsed time precision for transitioncancel event. r=boris\n\nSee the table for elapsed time for each transition event;\nhttps://drafts.csswg.org/css-transitions-2/#event-dispatch\n\nMozReview-Commit-ID: DuLip0XkwtE", "files": ["layout/style/nsTransitionManager.cpp", "layout/style/nsTransitionManager.h"], "git_node": null, "git_parents": [null], "node": "bf3a9047ffca44bd3d2ac9d47196d2fdf5e646e1", "parents": ["3141e18a84e7eafe76a44e35156f9177ecd5f816"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1428608 - Forbid / or !/ in LOCAL_INCLUDES. r=froydnj\n\nAnd remove the two cases that currently set that, without actually using\nit. The webrtc gtest one never relied on it, and the gfx one was added\nin bug 1427668 for a single header, and the corresponding #includes were\nchanged in bug 1428678.", "files": ["dom/canvas/moz.build", "media/webrtc/trunk/gtest/moz.build", "python/mozbuild/mozbuild/frontend/emitter.py", "python/mozbuild/mozbuild/test/frontend/data/local_includes-invalid/objdir/moz.build", "python/mozbuild/mozbuild/test/frontend/data/local_includes-invalid/srcdir/moz.build", "python/mozbuild/mozbuild/test/frontend/test_emitter.py"], "git_node": null, "git_parents": [null], "node": "ca36a6c4f8a4a0ddaa033fdbe20836d87bbfb873", "parents": ["bf3a9047ffca44bd3d2ac9d47196d2fdf5e646e1"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1430037 - Use the in-tree image builder image to build docker images. r=dustin\n\nThe image builder image we use to build docker images is updated\nmanually, and not necessarily when changes occur in tree that should be\nreflected by a new image builder image. For instance, its run-task is\ncurrently outdated. Not enough that it's actually a problem, but it\ncould rapidly become a problem.\n\nThere is also a lot of friction when trying to make changes in how\ndocker images are built, and while last time I tried, I ended up not\nbeing able to do the changes I wanted to make because the docker version\non the host is too old, but this is already the second time I've been\ntrying to make things better and hit a wall because the the image\nbuilder is essentially fixed in stone on the docker hub.\n\nSo with this change, we make all the docker images use the in-tree image\nbuilder image, except itself, obviously. That one uses the last version\nthat was uploaded. We may want to update it at some point, but not doing\nso will only impact building the image builder image itself, not the\nother ones.", "files": ["taskcluster/ci/docker-image/kind.yml", "taskcluster/docker/image_builder/HASH", "taskcluster/docker/image_builder/VERSION", "taskcluster/taskgraph/transforms/docker_image.py", "taskcluster/taskgraph/transforms/task.py"], "git_node": null, "git_parents": [null], "node": "1227e2800bd87612b60a69a2cf5c2971432ceaee", "parents": ["ca36a6c4f8a4a0ddaa033fdbe20836d87bbfb873"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1430037 - Use sparse checkouts for docker image builds. r=dustin\n\nIn many cases, building docker images starts on machines that don't have\na cached checkout, and it often takes forever to get a full clone. It\nused to be worsened when 3 jobs could run at the same time because the\nworker would start up clean, and 3 jobs would be doing a mercurial clone\nat the same time, thrashing I/O, but that part is fortunately fixed.\n\nIt is still, however, appreciable not to waste time in the mercurial\nclone part of image creation.", "files": ["build/sparse-profiles/docker-image", "taskcluster/docker/image_builder/build-image.sh", "taskcluster/taskgraph/transforms/docker_image.py"], "git_node": null, "git_parents": [null], "node": "63351f0612b47df5f244fd99cdb7a79a109c8c3a", "parents": ["1227e2800bd87612b60a69a2cf5c2971432ceaee"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1430608 followup - Suppress valgrind error in MediaList::evaluate on a CLOSED TREE.", "files": ["build/valgrind/x86_64-redhat-linux-gnu.sup"], "git_node": null, "git_parents": [null], "node": "f628439e6f52a377ea79f82eb8863c5a5d9d5b4f", "parents": ["63351f0612b47df5f244fd99cdb7a79a109c8c3a"], "tags": []}, {"author": "Coroiu Cristina \u003cccoroiu@mozilla.com\u003e", "branch": "default", "desc": "Backed out 1 changesets (bug 1429759) on request from whimboo a=backout\n\nBacked out changeset e2dd58774f0c (bug 1429759)", "files": ["testing/marionette/client/marionette_driver/geckoinstance.py", "testing/marionette/harness/marionette_harness/tests/unit/test_prefs.py", "testing/marionette/harness/marionette_harness/tests/unit/test_profile_management.py"], "git_node": null, "git_parents": [null], "node": "f095d500e45453ae318c26097dc2258bdf48d084", "parents": ["b7a651281314d6369658eeb58e3bb181cf95016f"], "tags": []}, {"author": "David Anderson \u003cdanderson@mozilla.com\u003e", "branch": "default", "desc": "Update and reassign some expiring Telemetry probes in gfx. (bug 1430657, r=liuche)", "files": ["toolkit/components/telemetry/Histograms.json", "toolkit/components/telemetry/Scalars.yaml"], "git_node": null, "git_parents": [null], "node": "e25f027b4c50b358d649cabcf1b69d76b70e5410", "parents": ["09d0f66b1eee218419cd244c16bfc99449fb3711"], "tags": []}, {"author": "sotaro \u003csotaro.ikeda.g@gmail.com\u003e", "branch": "default", "desc": "Bug 1430610 - Change nsIFrame::InvalidateLayer() as to check WebRender's async update r=mtseng", "files": ["gfx/layers/wr/WebRenderUserData.cpp", "gfx/layers/wr/WebRenderUserData.h", "layout/generic/nsFrame.cpp"], "git_node": null, "git_parents": [null], "node": "dac05eadb24504aeb508f39562a95fc6ad05b148", "parents": ["e25f027b4c50b358d649cabcf1b69d76b70e5410"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1420737 - Fix merge algorithm to handle more complex z-index changes. r=mstange", "files": ["layout/painting/RetainedDisplayListBuilder.cpp", "layout/reftests/display-list/reftest.list", "layout/reftests/display-list/retained-dl-zindex-1-ref.html", "layout/r