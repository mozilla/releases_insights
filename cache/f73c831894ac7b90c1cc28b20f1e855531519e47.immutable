"git_parents": [null], "node": "8ac8d4c54c2b402cee26fd9a1e51acdf68f2d5c0", "parents": ["e6146cc17bec1e65d3860213782c917f1bee9081"], "tags": []}], "date": 1517361521, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8620": {"changesets": [{"author": "dw-dev \u003cdw-dev@gmx.com\u003e", "branch": "default", "desc": "Bug 1415507 - changes to tabs.saveAsPDF(); r=mixedpuppy a=lizzard\n\nThere are three changes:\n\n1. Adds a print progress listener to tabs.saveAsPDF() in ext-tabs.js so that the\n  'saved' or 'replaced' status is not returned until the PDF file has been saved.\n\n2. Adds four more \"edge\" properties to the  pageSettings object to allow positioning\n   of the page headers and footers.\n\n3. Adds automated tests for tabs.saveAsPDF() in browser_ext_tabs_saveAsPDF.js that\n   cover all returned statuses: saved, replaced, canceled, not_saved, not_replaced.\n\nMozReview-Commit-ID: iljvT8wp11", "files": ["browser/components/extensions/ext-tabs.js", "browser/components/extensions/schemas/tabs.json", "browser/components/extensions/test/browser/browser-common.ini", "browser/components/extensions/test/browser/browser_ext_tabs_saveAsPDF.js"], "git_node": null, "git_parents": [null], "node": "b8321f5cb428ad97609a75616eab56881efee200", "parents": ["8ac8d4c54c2b402cee26fd9a1e51acdf68f2d5c0"], "tags": []}, {"author": "Andrew Swan \u003caswan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1428234 Part 1: Remove incorrect uses of persistentDescriptor in AddonManager r=emk,kmag a=lizzard\n\nMozReview-Commit-ID: 3pyF58rQcoa", "files": ["toolkit/mozapps/extensions/internal/XPIInstall.jsm", "toolkit/mozapps/extensions/internal/XPIProvider.jsm", "toolkit/mozapps/extensions/test/xpcshell/test_db_path.js", "toolkit/mozapps/extensions/test/xpcshell/xpcshell-shared.ini"], "git_node": null, "git_parents": [null], "node": "eb62496a89f3990281f6fcb195d1565630f424ed", "parents": ["b8321f5cb428ad97609a75616eab56881efee200"], "tags": []}, {"author": "Andrew Swan \u003caswan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1428234 Part 2: Force extensions database rebuild r=kmag a=lizzard\n\nPrior to the first patch for this bug, users with non-ascii characters\nin the path to their profile directory got bad data in extensions.json.\nWith that bug fixed, now force a rebuild to rescue those users.\n\nMozReview-Commit-ID: F3l87A67Ojc", "files": ["toolkit/mozapps/extensions/internal/XPIProvider.jsm"], "git_node": null, "git_parents": [null], "node": "e379d4c18dbb18dff04563031d0cf1b0c45196bc", "parents": ["eb62496a89f3990281f6fcb195d1565630f424ed"], "tags": []}, {"author": "Eric Rahm \u003cerahm@mozilla.com\u003e", "branch": "default", "desc": "Bug 1428612 - Part 1: Use nsLiteralCString to wrap histogram names. r=gfritzsche a=lizzard\n\nThis switches from `nsDependentCString` to `nsLiteralCString` when adding\nhistograms to the table. It will help save some memory and should avoid the OOM\nsmalls we have been seeing.", "files": ["toolkit/components/telemetry/TelemetryHistogram.cpp"], "git_node": null, "git_parents": [null], "node": "1ced99ea80c9e8d1661a8c57318b68ed69d36849", "parents": ["e379d4c18dbb18dff04563031d0cf1b0c45196bc"], "tags": []}, {"author": "Eric Rahm \u003cerahm@mozilla.com\u003e", "branch": "default", "desc": "Bug 1428612 - Part 2: Add an assertion to check the histogram name pointer. r=gfritzsche a=lizzard\n\nThis adds a dignostic assertion that the name pointer is actually within the\nstatic name table.", "files": ["toolkit/components/telemetry/TelemetryHistogram.cpp"], "git_node": null, "git_parents": [null], "node": "cc295c6c964d4003bd2b9710078207f5af85f5d7", "parents": ["1ced99ea80c9e8d1661a8c57318b68ed69d36849"], "tags": []}], "date": 1517395443, "git_changesets": [null, null, null, null, null], "user": "btara@mozilla.com"}, "8621": {"changesets": [{"author": "Shane Caraveo \u003cscaraveo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430416 unset the findbar when discarding a browser tab, r=mikedeboer a=lizzard\n\nMozReview-Commit-ID: B36n2uG6Qhk", "files": ["browser/base/content/tabbrowser.xml"], "git_node": null, "git_parents": [null], "node": "fad47dbabc0184847114953b7fd1272c5a57acc8", "parents": ["cc295c6c964d4003bd2b9710078207f5af85f5d7"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430446 - Prefer hinted glyph widths from FreeType, except when hinting is disabled or the font includes variations. r=lsalzman a=lizzard", "files": ["gfx/thebes/gfxFT2FontBase.cpp", "layout/reftests/forms/placeholder/reftest.list", "layout/reftests/svg/text/reftest.list", "testing/web-platform/meta/css/CSS2/backgrounds/background-root-002.xht.ini", "testing/web-platform/meta/css/CSS2/linebox/vertical-align-baseline-004a.xht.ini", "testing/web-platform/meta/css/CSS2/linebox/vertical-align-baseline-005a.xht.ini", "testing/web-platform/meta/css/css-text/white-space/white-space-collapsing-preserve-breaks-001.xht.ini"], "git_node": null, "git_parents": [null], "node": "b54898c488ddb7687cbda2bfc01cac1087837f35", "parents": ["fad47dbabc0184847114953b7fd1272c5a57acc8"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1431201 - Clear native queue when disposing window; r=snorp a=lizzard\n\nDispose the native call queue when disposing a window object, so we\ndon't end up with stale calls in the queue that can cause crashes.\n\nMozReview-Commit-ID: J1HNOXKAX6E", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoSession.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/NativeQueue.java"], "git_node": null, "git_parents": [null], "node": "8292d441cb0cf8aafbb8f9555237ac26deafd09d", "parents": ["b54898c488ddb7687cbda2bfc01cac1087837f35"], "tags": []}], "date": 1517396076, "git_changesets": [null, null, null], "user": "aciure@mozilla.com"}, "8622": {"changesets": [{"author": "Jan Beich \u003cjbeich@FreeBSD.org\u003e", "branch": "default", "desc": "Bug 1433036 - FreeBSD bootstrap: add npm for linting after bug 1433036. r=froydnj a=lizzard\n\nDownstream npm package already depends node package, no need to\nspecify it explicitly. Also, node package refers to the latest NodeJS\nbut npm package can be built against an older version.\n\nMozReview-Commit-ID: KeuSFEKeStw", "files": ["python/mozboot/mozboot/freebsd.py"], "git_node": null, "git_parents": [null], "node": "a88fde4219d956f6ead8bcbd4678186cedcd0564", "parents": ["8292d441cb0cf8aafbb8f9555237ac26deafd09d"], "tags": []}, {"author": "Jan Beich \u003cjbeich@FreeBSD.org\u003e", "branch": "default", "desc": "Bug 1433036 - OpenBSD bootstrap: node-devel package doesn't exist. r=froydnj,gaston a=lizzard\n\nlang/node aka node package is what actually installs node and npm executables.\nhttps://cvsweb.openbsd.org/cgi-bin/cvsweb/ports/lang/node/pkg/PLIST?rev=HEAD\n\nMozReview-Commit-ID: H9lZGcHmEuR", "files": ["python/mozboot/mozboot/openbsd.py"], "git_node": null, "git_parents": [null], "node": "e25fc7c4ef8cf15e87701fa48fc1141797fa2d3a", "parents": ["a88fde4219d956f6ead8bcbd4678186cedcd0564"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1433551: Use fallible allocation for handleInfoBuf inside UIA detection; r=davidb a=lizzard", "files": ["accessible/windows/msaa/CompatibilityUIA.cpp"], "git_node": null, "git_parents": [null], "node": "17a7ad472925fb984b83d0b7592ecb9d503ce334", "parents": ["e25fc7c4ef8cf15e87701fa48fc1141797fa2d3a"], "tags": []}], "date": 1517396403, "git_changesets": [null, null, null], "user": "apavel@mozilla.com"}, "8623": {"changesets": [{"author": "Ben Hearsum \u003cbhearsum@mozilla.com\u003e", "branch": "default", "desc": "bug 1421346: change fennec to 100% rollout rate. r=jlund, a=release, DONTBUILD", "files": ["taskcluster/ci/push-apk/kind.yml"], "git_node": null, "git_parents": [null], "node": "7ad2f82facfad77f5b94a24e972b3ec021c3ea77", "parents": ["17a7ad472925fb984b83d0b7592ecb9d503ce334"], "tags": []}], "date": 1517406755, "git_changesets": [null], "user": "bhearsum@mozilla.com"}, "8624": {"changesets": [{"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1402358 - In Android emulator tests, shutdown faster. r=jmaher, a=test-only\n\nWhen the emulator is in good shape, emulator verification on shutdown\nonly takes a few seconds. However, if the emulator is hung or otherwise\nunresponsive, emulator verification can take several minutes. In the\npathological worst case, verification slows down the task enough to\nexceed the task timeout, resulting in a failure that would otherwise\nhave been handled as a task retry. Emulator verification on shutdown\nprovides little value, so it is simply eliminated.", "files": ["testing/mozharness/scripts/android_emulator_unittest.py"], "git_node": null, "git_parents": [null], "node": "772c01326802cca0571aac7cc66a750e0cbd0cca", "parents": ["7ad2f82facfad77f5b94a24e972b3ec021c3ea77"], "tags": []}, {"author": "J.C. Jones \u003cjjones@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418112 - Force HSTS Preloading for opt-in public suffixes. r=keeler, a=lizzard\n\nThe Chromium HSTS Preload list now includes a \"policy\" field that we can use\nto filter and force some HSTS entries. This patch unconditionally accepts list\nentries with the \"google\" or \"public-suffix-requested\" policies, and tests all\nothers via the existing connect-and-check (with failback tolerance) strategy.\n\nIn comment #0 of this bug [2], Lucas recommends we also filter the \"all others\"\nto be the \"bulk\" entries. This patch does not do that to be conservative and\navoid de-listing sites at this time. We'll probably want a follow-on to\nevaluate and potentially do that.\n\nThe patch also:\n\n* renames `getHSTSStatuses` to `probeHSTSStatuses` to indicate more clearly that\n  it's an active network load.\n\n* Sets an X-Automated-Tool: https://hg.mozilla.org/mozilla-central/file/tip/security/manager/tools/getHSTSPreloadList.js\n\n[1] https://github.com/chromium/hstspreload.org/wiki/Preload-List-Processes#manual-hsts-entries\n[2] https://bugzilla.mozilla.org/show_bug.cgi?id=1418112#c0\n\nMozReview-Commit-ID: 2r1QYXtDfjw", "files": ["security/manager/tools/getHSTSPreloadList.js"], "git_node": null, "git_parents": [null], "node": "e4109662e39437c1ee1a2d4afec0ce6e52766dc1", "parents": ["772c01326802cca0571aac7cc66a750e0cbd0cca"], "tags": []}, {"author": "J.C. Jones \u003cjjones@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418112 - Cleanup getHSTSPreloadList.js vars to lets. r=keeler, a=lizzard\n\nThis is a JS style cleanup; it changes all relevant `var` decls to `let`, and\nalso moves the `gSSService` up to the top where globals should go.\n\nMozReview-Commit-ID: 2yycCum6mRC", "files": ["security/manager/tools/getHSTSPreloadList.js"], "git_node": null, "git_parents": [null], "node": "e3770cfe218755484c622448162f294f24a5017f", "parents": ["e4109662e39437c1ee1a2d4afec0ce6e52766dc1"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1432850 - Look at the snapshots when invalidating due to stylesheet changes. r=bz, a=lizzard\n\nThe selectorText test happens to pass right now because well, we don't implement\nthe setter yet[1], but would fail if we implemented an specific invalidation in\nthe way I'd have done it yesterday.\n\n[1]: https://bugzilla.mozilla.org/show_bug.cgi?id=37468\n\nMozReview-Commit-ID: DrMTgLzQcnk", "files": ["layout/style/ServoBindingList.h", "layout/style/ServoStyleSet.cpp", "servo/components/style/gecko/data.rs", "servo/components/style/gecko/snapshot.rs", "servo/components/style/invalidation/element/element_wrapper.rs", "servo/components/style/invalidation/stylesheets.rs", "servo/components/style/stylesheet_set.rs", "servo/components/style/stylist.rs", "servo/ports/geckolib/glue.rs", "testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/css/selectors/invalidation/selectorText-dynamic-001.html", "testing/web-platform/tests/css/selectors/invalidation/sheet-going-away-001.html", "testing/web-platform/tests/css/selectors/invalidation/sheet-going-away-002-ref.html", "testing/web-platform/tests/css/selectors/invalidation/sheet-going-away-002.html"], "git_node": null, "git_parents": [null], "node": "9f9cfb102591b583c33fd208e88eaa797b10accb", "parents": ["e3770cfe218755484c622448162f294f24a5017f"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1310491 - Part 1: Always properly clear speculative downloads when forwarding a download. r=esawin, a=lizzard\n\nIf we have to forward a download that we cannot handle ourselves to the Android\ndownload manager, then the speculative download started by Firefox needs to be\naborted no matter whether forwarding succeeded or not.\n\nMozReview-Commit-ID: B6zCk28ci1P", "files": ["mobile/android/components/HelperAppDialog.js"], "git_node": null, "git_parents": [null], "node": "22861495469e6d5089b1cef7fdd26a72743e9901", "parents": ["9f9cfb102591b583c33fd208e88eaa797b10accb"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1310491 - Part 2: Abort speculative download if user backs out of our App Chooser dialogue. r=esawin, a=lizzard\n\nMozReview-Commit-ID: 1YsD2WZsats", "files": ["mobile/android/components/HelperAppDialog.js"], "git_node": null, "git_parents": [null], "node": "fa6ec1c75d754ce7a30755c794a7f7f8c73909d7", "parents": ["22861495469e6d5089b1cef7fdd26a72743e9901"], "tags": []}], "date": 1517438335, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8625": {"changesets": [{"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1433005 - Simplify codec pruning in NegotiateCodecs. r=bwc, a=lizzard", "files": ["media/webrtc/signaling/src/jsep/JsepTrack.cpp"], "git_node": null, "git_parents": [null], "node": "90ae99509f1e9cb5bdf19350a5fbb1a02d34ff0a", "parents": ["fa6ec1c75d754ce7a30755c794a7f7f8c73909d7"], "tags": []}, {"author": "Magnus Melin \u003cmkmelin+mozilla@iki.fi\u003e", "branch": "default", "desc": "Bug 1408867 - Make sure specualtive connections are enabled for tests where it's assumed. r=mcmanus, a=lizzard", "files": ["netwerk/test/unit/test_speculative_connect.js", "toolkit/mozapps/update/tests/unit_aus_update/downloadInterruptedRecovery.js"], "git_node": null, "git_parents": [null], "node": "2e091a38d41c673863a09157414c50288df66b57", "parents": ["90ae99509f1e9cb5bdf19350a5fbb1a02d34ff0a"], "tags": []}, {"author": "Shane Caraveo \u003cscaraveo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1408194 - Prevent using find api on about urls. r=gijs, a=lizzard", "files": ["browser/components/extensions/ext-find.js", "browser/components/extensions/test/browser/browser_ext_find.js"], "git_node": null, "git_parents": [null], "node": "84c1cb814b185771e99e48f0445c258ef460af16", "parents": ["2e091a38d41c673863a09157414c50288df66b57"], "tags": []}], "date": 1517447310, "git_changesets": [null, null, null], "user": "ryanvm@gmail.com"}, "8626": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1414789: Backout Stylo DOM APIs from beta. r=xidorn a=gchang\n\nMozReview-Commit-ID: BW5BZpC63B8", "files": ["dom/base/nsINode.h"], "git_node": null, "git_parents": [null], "node": "0e762fc7cb7446469e69b47932cbbdeccf50ecb2", "parents": ["84c1cb814b185771e99e48f0445c258ef460af16"], "tags": []}], "date": 1517456327, "git_changesets": [null], "user": "xquan@mozilla.com"}, "8627": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\naz -\u003e 3133e54c5eab\nbe -\u003e fc3b5e517adb\nbg -\u003e fcf9f50f21e2\nbn-BD -\u003e 1b75a8