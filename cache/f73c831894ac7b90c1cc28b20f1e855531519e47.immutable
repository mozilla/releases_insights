null, "git_parents": [null], "node": "3d8b1409f0fe8606c4c80c4215c50b2efb6302cf", "parents": ["7a56ba918a55ab5541b29323e906d621947f0eed"], "tags": []}, {"author": "Milan Sreckovic \u003cmilan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1423552: Use BaseRect access methods instead of member variables in hal/ r=gsvelto\n\nMozReview-Commit-ID: 625X8dMPL2n", "files": ["hal/android/AndroidHal.cpp", "hal/fallback/FallbackScreenConfiguration.h"], "git_node": null, "git_parents": [null], "node": "0d6cff1374dc6f0863b73eabb899d4fcf918ab26", "parents": ["3d8b1409f0fe8606c4c80c4215c50b2efb6302cf"], "tags": []}, {"author": "Milan Sreckovic \u003cmilan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1423541: Use BaseRect access methods instead of member variables in accessible/ r=surkov\n\nMozReview-Commit-ID: KRfgYEW7aWY", "files": ["accessible/base/nsAccUtils.cpp", "accessible/base/nsAccessiblePivot.cpp", "accessible/base/nsCoreUtils.cpp", "accessible/generic/Accessible.cpp", "accessible/generic/HyperTextAccessible.cpp", "accessible/generic/ImageAccessible.cpp", "accessible/generic/OuterDocAccessible.cpp", "accessible/html/HTMLImageMapAccessible.cpp", "accessible/html/HTMLListAccessible.cpp", "accessible/html/HTMLSelectAccessible.cpp", "accessible/ipc/DocAccessibleParent.cpp", "accessible/ipc/win/ProxyAccessible.cpp", "accessible/windows/ia2/ia2AccessibleComponent.cpp", "accessible/windows/ia2/ia2AccessibleText.cpp", "accessible/windows/msaa/AccessibleWrap.cpp", "accessible/windows/msaa/DocAccessibleWrap.cpp", "accessible/windows/sdn/sdnTextAccessible.cpp", "accessible/xpcom/xpcAccessible.cpp", "accessible/xpcom/xpcAccessibleHyperText.cpp", "accessible/xul/XULTreeAccessible.cpp", "accessible/xul/XULTreeGridAccessible.cpp"], "git_node": null, "git_parents": [null], "node": "40161b05e29e5561520b8d468c2ccd01b3e1ebd9", "parents": ["0d6cff1374dc6f0863b73eabb899d4fcf918ab26"], "tags": []}, {"author": "Jeremy Chen \u003cjeremychen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1429977 - make comments for BreakAndMeasureText up-to-date (comment-only, DONTBUILD). r=jfkthame\n\nMozReview-Commit-ID: ILWAnMT9Fdp", "files": ["gfx/thebes/gfxTextRun.h"], "git_node": null, "git_parents": [null], "node": "d97273fcb62f01f5bf9743d441ea0f625e774ff5", "parents": ["40161b05e29e5561520b8d468c2ccd01b3e1ebd9"], "tags": []}, {"author": "Panos Astithas \u003cpast@mozilla.com\u003e", "branch": "default", "desc": "Bug 1429364 - Fix 'Save Link As' context menu option in sidebars. r=Gijs\n\nMozReview-Commit-ID: 2RaxPjx1Jz7", "files": ["browser/base/content/nsContextMenu.js"], "git_node": null, "git_parents": [null], "node": "392278bcc755c3ea4c65c4ffb8833bd7b92b06ff", "parents": ["d97273fcb62f01f5bf9743d441ea0f625e774ff5"], "tags": []}, {"author": "CYBAI \u003ccyb.ai.815@gmail.com\u003e", "branch": "default", "desc": "servo: Merge #19752 - style: Use Python's True instead of string for arbitrary Python code in mako (from CYBAI:fix-mako-true); r=nox\n\nAs discussion in IRC with @nox and @gootorov , it's more correct to use Python's `True` for `${arbitrary Python code}` in mako.\n\nFollowing is related IRC logs\n\n```\n15:39 nox\nAs I said, that's because there are 2 ways to invoke the things with Mako.\n\n15:40 nox\n${arbitrary Python code} vs \u003c%named_helper ..\u003e...\u003c/%named_helper\u003e\n\n15:40 nox\nIIRC \u003c%foo bar=True\u003e\u003c/%foo\u003e is not valid Mako syntax,\n\n15:40 nox\nbut with bar=\"True\" it is.\n\n15:42 cybai\ngootorov: I did meet some issues when moving makos if I set \"True\" instead of Python's `True`. Thus, like nox mentioned above, it's related to how the code works\n\n15:44 gootorov\nnox: Alright, I got it now, thanks. There are a couple ${function} blocks that still use `boxed=\"True\" though. They aren't \u003c%named_helpers\u003e, shouldn't they use Python's True too, then?\n\n15:45 nox\ngootorov: I think there is an issue because this specific attribute is also used as a string through other \u003c%helpers\u003e,\n\n15:46 nox\ngootorov: Seems like it's not an issue anymore because the boxed attribute is passed to arg_to_bool,\n\n15:46 nox\nwhich either returns the boolean as is or check whether it's a \"True\" or \"False\" string.\n\n15:47 nox\ngootorov: So indeed, you can probably make those use booleans now.\n\n15:47 gootorov\nnox: Okay, got it, thanks for the explanation :)\n```\n\n---\n- [x] `./mach build -d` does not report any errors\n- [x] `./mach test-tidy` does not report any errors\n- [x] These changes do not require tests\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 865181b6e676fc9b76447ad5172e275b9861ca5e", "files": ["servo/components/style/properties/longhand/border.mako.rs", "servo/components/style/properties/longhand/box.mako.rs", "servo/components/style/properties/longhand/effects.mako.rs", "servo/components/style/properties/longhand/inherited_svg.mako.rs", "servo/components/style/properties/longhand/inherited_table.mako.rs", "servo/components/style/properties/longhand/list.mako.rs", "servo/components/style/properties/longhand/position.mako.rs"], "git_node": null, "git_parents": [null], "node": "4c0e52aa8c09ebc6be490837dbcf3c28a339c7c1", "parents": ["392278bcc755c3ea4c65c4ffb8833bd7b92b06ff"], "tags": []}, {"author": "Sylvestre Ledru \u003csledru@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418425 - Compile zlib as host lib r=glandium\n\nMozReview-Commit-ID: 5jXyVhRI0kD", "files": ["modules/zlib/src/moz.build"], "git_node": null, "git_parents": [null], "node": "142001babb39d7cce8b88a2103ba8863fce685ad", "parents": ["4c0e52aa8c09ebc6be490837dbcf3c28a339c7c1"], "tags": []}, {"author": "Sylvestre Ledru \u003csledru@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418425 - Update bsdiff to use libz instead of bz2 for the crc algo r=andi,glandium\n\nMozReview-Commit-ID: 2GLmnzF9CMh", "files": ["other-licenses/bsdiff/bsdiff.c", "other-licenses/bsdiff/moz.build"], "git_node": null, "git_parents": [null], "node": "47fbcaf5ad059616de22219b12223b798b6b758f", "parents": ["142001babb39d7cce8b88a2103ba8863fce685ad"], "tags": []}, {"author": "Sylvestre Ledru \u003csledru@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418425 - Ship only the crc table from bz2 and use it in the updater r=glandium\n\nIndeed, using zlib gives different results which mismatch with the one from\nreleng.\n\nThe next step would be to have releng use a zlib based solution.\n\nMozReview-Commit-ID: LwxHk84Ajp4", "files": ["toolkit/mozapps/update/updater/archivereader.cpp", "toolkit/mozapps/update/updater/crctable.h", "toolkit/mozapps/update/updater/moz.build", "toolkit/mozapps/update/updater/updater-common.build", "toolkit/mozapps/update/updater/updater-xpcshell/moz.build", "toolkit/mozapps/update/updater/updater.cpp"], "git_node": null, "git_parents": [null], "node": "2e95ebdcae6d37cc1b3c3f220b05210f419aea64", "parents": ["47fbcaf5ad059616de22219b12223b798b6b758f"], "tags": []}, {"author": "Sylvestre Ledru \u003csledru@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418425 - Remove libbz2 files as we were only using it for crc32 as the updater moved to lzma r=glandium\n\nMozReview-Commit-ID: 8Sz8vtV0b5G", "files": ["config/external/moz.build", "config/system-headers.mozbuild", "modules/libbz2/moz.build", "modules/libbz2/src/LICENSE", "modules/libbz2/src/blocksort.c", "modules/libbz2/src/bzlib.c", "modules/libbz2/src/bzlib.h", "modules/libbz2/src/bzlib_private.h", "modules/libbz2/src/compress.c", "modules/libbz2/src/crctable.c", "modules/libbz2/src/decompress.c", "modules/libbz2/src/huffman.c", "modules/libbz2/src/moz.build", "modules/libbz2/src/randtable.c", "old-configure.in", "tools/rewriting/ThirdPartyPaths.txt"], "git_node": null, "git_parents": [null], "node": "7b7725d1d3c34560df5a07b1536bc63182f5846b", "parents": ["2e95ebdcae6d37cc1b3c3f220b05210f419aea64"], "tags": []}, {"author": "Sylvestre Ledru \u003csledru@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418425 - Do not build bsdiff on Android. The updater doesn't use it (we ship apk directly) r=glandium\n\nMozReview-Commit-ID: FZ7A05WsQjO", "files": ["toolkit/toolkit.mozbuild"], "git_node": null, "git_parents": [null], "node": "0ecc98bd0822159169d717dbf4c6d2fc4f54e03e", "parents": ["7b7725d1d3c34560df5a07b1536bc63182f5846b"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 8c2097e14828 (bug 1429929) for failing browser-chrome's browser_audioTabIcon.js and browser_usercontextid_tabdrop.js", "files": ["browser/base/content/tabbrowser.css", "browser/base/content/tabbrowser.xml"], "git_node": null, "git_parents": [null], "node": "a3d15c0fe9a8c3e11efbb27d15695c5a623036f9", "parents": ["0ecc98bd0822159169d717dbf4c6d2fc4f54e03e"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1425965 P1 Make ServiceWorkerManager::ReportToAllClients use ConsoleUtils::ReportForServiceWorkerScope. r=asuth", "files": ["dom/workers/ServiceWorkerManager.cpp"], "git_node": null, "git_parents": [null], "node": "bbc20dc8387908c28ad7c60341c99b6d17ae5e6b", "parents": ["a82adc7bf7b027b289ff5a7dae300221cb8d5067"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1425965 P2 Add nsIConsoleReportCollector::FlushReportsToConsoleForServiceWorkerScope(). r=baku", "files": ["dom/console/ConsoleReportCollector.cpp", "dom/console/ConsoleReportCollector.h", "dom/console/nsIConsoleReportCollector.h", "netwerk/protocol/http/HttpBaseChannel.cpp", "netwerk/protocol/http/HttpBaseChannel.h"], "git_node": null, "git_parents": [null], "node": "57b875846062f8dcb318f9edfc7d2d3a5321e7fe", "parents": ["bbc20dc8387908c28ad7c60341c99b6d17ae5e6b"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1425965 P3 Make ServiceWorkerManager::FlushReportsToAllClients() use FlushReportsToConsoleForServiceWorkerScope(). r=asuth", "files": ["dom/fetch/Fetch.cpp", "dom/fetch/FetchConsumer.cpp", "dom/workers/ServiceWorkerManager.cpp", "dom/workers/ServiceWorkerManager.h"], "git_node": null, "git_parents": [null], "node": "79280bcea4451e8f64d329f6ee3c46bc1321dff9", "parents": ["57b875846062f8dcb318f9edfc7d2d3a5321e7fe"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1425965 P4 Remove mControlledDocument, mRegisteringDocuments, and mNavigationIntercepts from ServiceWorkerManager. r=asuth", "files": ["dom/base/nsDocument.cpp", "dom/interfaces/base/nsIServiceWorkerManager.idl", "dom/workers/ServiceWorkerManager.cpp", "dom/workers/ServiceWorkerManager.h"], "git_node": null, "git_parents": [null], "node": "4027039552fea211647109c3d45b4215d759bd52", "parents": ["79280bcea4451e8f64d329f6ee3c46bc1321dff9"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1425965 P5 Make SimpleTest.monitorConsole() and SpecialPowers.registerConsoleListener() observe dom/console events. r=baku", "files": ["testing/specialpowers/content/specialpowersAPI.js"], "git_node": null, "git_parents": [null], "node": "241b9e419ca4a960144320842839f4ae39be6493", "parents": ["4027039552fea211647109c3d45b4215d759bd52"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1425965 P6 Change test_fetch_integrity.html not to expect exact window ID values in console messages. r=asuth", "files": ["dom/workers/test/serviceworkers/test_fetch_integrity.html"], "git_node": null, "git_parents": [null], "node": "9972008ac10510753a6adda9af0f21b33ee861e8", "parents": ["241b9e419ca4a960144320842839f4ae39be6493"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1425965 P7 Fix dom/push/test/test_error_reporting.html to expect new console reporting mechanism. r=asuth", "files": ["dom/push/test/test_error_reporting.html"], "git_node": null, "git_parents": [null], "node": "d16fe1a6931e5dadaeddafd626ef5bc0bb8bf8ea", "parents": ["9972008ac10510753a6adda9af0f21b33ee861e8"], "tags": []}, {"author": "Marco Castelluccio \u003cmcastelluccio@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430170 - Use correct path to gcda file and fail build if grcov fails. r=jmaher", "files": ["testing/mozharness/mozharness/mozilla/testing/codecoverage.py"], "git_node": null, "git_parents": [null], "node": "a438b7e7917ee604f8613714c9f96ce4968e4701", "parents": ["d16fe1a6931e5dadaeddafd626ef5bc0bb8bf8ea"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1430175 - Update pdf.js to version 2.0.258. r=bdahl", "files": ["browser/extensions/pdfjs/README.mozilla", "browser/extensions/pdfjs/content/build/pdf.js", "browser/extensions/pdfjs/content/build/pdf.worker.js", "browser/extensions/pdfjs/content/web/viewer.js"], "git_node": null, "git_parents": [null], "node": "792b172327f28a7d90aa51c38c26dff23cc06032", "parents": ["a438b7e7917ee604f8613714c9f96ce4968e4701"], "tags": []}, {"author": "Bob Silverberg \u003cbsilverberg@mozilla.com\u003e", "branch": "default", "desc": "Bug 1363860 - Allow WebExtensions to control cookie behaviour, r=mixedpuppy\n\nThis introduces a new setting to the privacy API, browser.privacy.websites.cookieConfig,\nwhich controls both the network.cookie.cookieBehavior pref, and the network.cookie.lifetimePolicy\npref. The former controls which types of cookies are accepted, while the latter which controls\nthe expiration date of cookies.\n\nThis setting accepts an object as its value with properties for \"behavior\" and\n\"nonPersistentCookies\", which control the prefs discussed above. Each of these properties is\noptional.  nonPersistentCookies defaults to false, and an object without a value for the\nbehavior property will result in the network.cookie.cookieBehavior pref being reset to its\ndefault value.\n\n\nMozReview-Commit-ID: KKE1dMCzTt6", "files": ["toolkit/components/extensions/ext-privacy.js", "toolkit/components/extensions/schemas/privacy.json", "toolkit/components/extensions/test/xpcshell/test_ext_privacy.js"], "git_node": null, "git_parents": [null], "node": "21de927fd6adf57e678e2eac54266af5415cc16b", "parents": ["a3d15c0fe9a8c3e11efbb27d15695c5a623036f9"], "tags": []}, {"author": "decltype \u003cmozilla@decltype.org\u003e", "branch": "default", "desc": "Bug 712130 - Add reftest to ensure the first autofocus elements gets picked. r=bz\n\nMozReview-Commit-ID: 6UAUbqwVhTm", "files": ["layout/reftests/bugs/712130-1-ref.html", "layout/reftests/bugs/712130-1.html", "layout/reftests/bugs/reftest.list"], "git_node": null, "git_parents": [null], "node": "ba6c2fff9fd54ca8f836ce3e2f29aaa8a8d65bd2", "parents": ["21de927fd6adf57e678e2eac54266af5415cc16b"], "tags": []}, {"author": "decltype \u003cmozilla@decltype.org\u003e", "branch": "default", "desc": "Bug 712130 - Add reftest in case autofocus element is seen after PresShell init. r=bz\n\nMozReview-Commit-ID: 75IKOqiqBhL", "files": ["layout/reftests/bugs/712130-2-ref.html", "layout/reftests/bugs/712130-2.html", "layout/reftests/bugs/reftest.list"], "git_node": null, "git_parents": [null], "node": "a3cffbfc83950a3453bce4d446f677c6e0c2fbba", "parents": ["ba6c2fff9fd54ca8f836ce3e2f29aaa8a8d65bd2"], "tags": []}, {"author": "decltype \u003cmozilla@decltype.org\u003e", "branch": "default", "desc": "Bug 712130 - Defer autofocus until after frame construction. r=bz\n\nThe autofocus attribute on form elements forces layout in CheckIfFocusable.\nTo avoid unpleasant FOUCs, defer autofocus processing until frames are\nconstructed in PresShell::Initialize.\n\nResolve the race between nsAutoFocusEvent running and page load by checking the\nreadystate at time of event posting.\n\nMozReview-Commit-ID: 90jiJYJWmRg", "files": ["dom/base/nsDocument.cpp", "dom/base/nsDocument.h", "dom/base/nsFocusManager.cpp", "dom/base/nsIDocument.h", "dom/html/nsGenericHTMLElement.cpp", "layout/base/PresShell.cpp"], "git_node": null, "git_parents": [null], "node": "3774e90777a793f70cfb492b5a7726c9de098d16", "parents": ["a3cffbfc83950a3453bce4d446f677c6e0c2fbba"], "tags": []}, {"author": "decltype \u003cmozilla@decltype.org\u003e", "branch": "default", "desc": "Bug 712130 - Simplify focus stealing prevention for autofocus. r=bz\n\nRemove redundant check already implied by earlier condition: If the focus\nmanager's focused content is in our document, all parent windows including the\nroot window must have their focused node set to non-null.\n\nMozReview-Commit-ID: CryGb6mfczK", "files": ["dom/base/nsDocument.cpp"], "git_node": null, "git_parents": [null], "node": "e7738f07edae521d7459d2ac759416005a4899cd", "parents": ["3774e90777a793f70cfb492b5a7726c9de098d16"], "tags": []}, {"author": "Oriol Brufau \u003coriol-bugzilla@hotmail.com\u003e", "branch": "default", "desc": "Bug 1429271 - Use 'is' to compare so that the obtained value is logged when the assert fails. r=Honza\n\nMozReview-Commit-ID: 6A87wJfrC8U", "files": ["devtools/client/jsonview/test/browser_jsonview_slash.js"], "git_node": null, "git_parents": [null], "node": "b0febafcec421eb8c8fc2e067303882f5c72750c", "parents": ["e7738f07edae521d7459d2ac759416005a4899cd"], "tags": []}, {"author": "Steve Pfister \u003csteveisok@gmail.com\u003e", "branch": "default", "desc": "Bug 1374811: Added title tag and changed the title of the page to URL Classifier Information; r=dimi\n\nMozReview-Commit-ID: 1DDAHi5cWRe", "files": ["toolkit/content/aboutUrlClassifier.xhtml", "toolkit/locales/en-US/chrome/global/aboutUrlClassifier.dtd"], "git_node": null, "git_parents": [null], "node": "abb5be3dbdc71cb52a3edfc2a9a6f3a522b0f486", "parents": ["b0febafcec421eb8c8fc2e067303882f5c72750c"], "tags": []}, {"author": "Evan Tseng \u003cevan@tseng.io\u003e", "branch": "default", "desc": "Bug 1428994 - Set dividers' margin-top as 16px to make its above and below space be equal and match visual spec. r=jaws\n\nMozReview-Commit-ID: 6C66GNHfHdQ", "files": ["browser/themes/shared/incontentprefs/preferences.inc.css"], "git_node": null, "git_parents": [null], "node": "022ee7de00985e0cde5ea633de5dbec4577715c9", "parents": ["abb5be3dbdc71cb52a3edfc2a9a6f3a522b0f486"], "tags": []}, {"author": "Andrew Halberstadt \u003cahalberstadt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403012 - Fix TypeError when running python unittests via |mach test|, r=gbrown\n\nMach test now creates a structured logger and passes it down into all\nof the various test harnesses. Except |mach python-test| doesn't use\nstructured logging yet, so the argument is not expected.\n\nFor now, just accept **kwargs and ignore the logger. Eventually we'll\nwant to get python tests to use structured logging, and we can use it\nat that point.\n\nMozReview-Commit-ID: 8LwdbgI0vqR", "files": ["python/mach_commands.py"], "git_node": null, "git_parents": [null], "node": "83ce7df5790dbd42dc064f9f0d4af7874dbc193a", "parents": ["022ee7de00985e0cde5ea633de5dbec4577715c9"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Pre: Teach |mach gradle| to take GRADLE_FLAGS from the command line. r=maliu\n\nMozReview-Commit-ID: 150llND5h0j", "files": ["mobile/android/mach_commands.py"], "git_node": null, "git_parents": [null], "node": "78576ff98660a4d2b8ad07c043dfbc80be5b0399", "parents": ["83ce7df5790dbd42dc064f9f0d4af7874dbc193a"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Pre: Don't block Google's maven repository. r=maliu\n\nTurns out Google's maven repository doesn't publish checksums.  I\ncan't imagine why not, but there it is.  We have to think more about\nwhether to trust the artifacts downloaded from maven.google.com.\n\nMozReview-Commit-ID: CdWijorq1IV", "files": ["taskcluster/scripts/misc/android-gradle-dependencies/nexus.xml"], "git_node": null, "git_parents": [null], "node": "d23f467218da9318bd45233227921ada9d079c63", "parents": ["78576ff98660a4d2b8ad07c043dfbc80be5b0399"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Pre: Fix dangling resource. r=mcomella\n\nThis is just wrong.\n\nMozReview-Commit-ID: EBtKTD07aNu", "files": ["mobile/android/app/src/main/res/values-v17/themes.xml", "mobile/android/base/resources/values-v17/themes.xml"], "git_node": null, "git_parents": [null], "node": "264476c772102b9cbd4c35d1230da0229f5e866d", "parents": ["d23f467218da9318bd45233227921ada9d079c63"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Pre: Remove unused PerProfileDatabaseProvider. r=mcomella\n\nNo idea what is going on with this hierarchy, but this isn't used and\nisn't helping anything.\n\nMozReview-Commit-ID: Ir3LxLYHR6M", "files": ["mobile/android/app/lint.xml", "mobile/android/base/java/org/mozilla/gecko/db/AbstractTransactionalProvider.java", "mobile/android/base/java/org/mozilla/gecko/db/PerProfileDatabaseProvider.java", "mobile/android/base/moz.build"], "git_node": null, "git_parents": [null], "node": "fb15e1f54987a247d19c149f90fa99048638aa9e", "parents": ["264476c772102b9cbd4c35d1230da0229f5e866d"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Pre: Clear icon disk storage in test. r=mcomella\n\nNewer versions of Robolectric seem to have different semantics about\nclearing disk caches, so this is necessary.  But for older versions,\nit shouldn't hurt, and is slightly more clear than relying on an\nimplicit clear.\n\nMozReview-Commit-ID: LRcaEPasXj8", "files": ["mobile/android/app/src/test/java/org/mozilla/gecko/icons/preparation/TestLookupIconUrl.java"], "git_node": null, "git_parents": [null], "node": "108674372ef790a95db36816d4a63b7d0c96cfc7", "parents": ["fb15e1f54987a247d19c149f90fa99048638aa9e"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Pre: Gradle is no longer experimental; IntelliJ not supported. r=maliu\n\nIntelliJ should still work, but we're committed to Android Studio at\nthis point.\n\nMozReview-Commit-ID: 3BaXB4dh4vA", "files": ["python/mozbuild/mozbuild/config_status.py"], "git_node": null, "git_parents": [null], "node": "9141bbdfd13bc14c8781ebfe0eeb9044f441b716", "parents": ["108674372ef790a95db36816d4a63b7d0c96cfc7"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Pre: Update toolchain documents for Android toolchain jobs. r=maliu\n\nMozReview-Commit-ID: 9h0imqIYyaZ", "files": ["build/docs/toolchains.rst"], "git_node": null, "git_parents": [null], "node": "43787f4089c39d64bd0955a54d469f374ebd4494", "parents": ["9141bbdfd13bc14c8781ebfe0eeb9044f441b716"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Pre: Fix checkstyle whitespace error in GeckoHlsPlayer. r=nalexander\n\nMozReview-Commit-ID: 4h1p4J5B8sM", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/media/GeckoHlsPlayer.java"], "git_node": null, "git_parents": [null], "node": "bffb6a5b78d13240ee3201d273a72a67a56270f5", "parents": ["43787f4089c39d64bd0955a54d469f374ebd4494"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Pre: Remove unused HomeExpandableListView. r=mcomella\n\nThis was added for the Remote Tabs panel in Bug 785199.  That code has\nnow morphed into the combined history panel, which uses a\nRecyclerView.\n\nMozReview-Commit-ID: J6KsVCn8mzh", "files": ["mobile/android/base/java/org/mozilla/gecko/home/HomeExpandableListView.java", "mobile/android/base/moz.build"], "git_node": null, "git_parents": [null], "node": "5c64eda20f1e7447ebb3b4f689ea77689dd4d676", "parents": ["bffb6a5b78d13240ee3201d273a72a67a56270f5"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Pre: Fix CustomTabsSecurityPopup package. r=nalexander\n\nMozReview-Commit-ID: ICTdy9WRlwG", "files": ["mobile/android/base/java/org/mozilla/gecko/customtabs/ActionBarPresenter.java", "mobile/android/base/java/org/mozilla/gecko/customtabs/CustomTabsSecurityPopup.java"], "git_node": null, "git_parents": [null], "node": "359fadf9b3e9e8ba433863ca2ba9b67cdbe9585f", "parents": ["5c64eda20f1e7447ebb3b4f689ea77689dd4d676"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Part 0: Add rudimentary documentation about Gradle integration. r=maliu\n\nThis sketches the flavor dimensions.  The important ones are\n`audience` and `geckoBinaries`, which I think simplify the situation\ngreatly.  Coupled with Bug 1417232 centralizing most everything in\n`mobile/android/gradle.configure`, the Gradle configuration shouldn't\nbe so hard to evolve.\n\nMozReview-Commit-ID: DILjVrnLA3F", "files": ["mobile/android/docs/gradle.rst", "mobile/android/docs/index.rst"], "git_node": null, "git_parents": [null], "node": "eda74143389fda91a431246236c1db25f4760892", "parents": ["359fadf9b3e9e8ba433863ca2ba9b67cdbe9585f"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Part 1: Upgrade to Android-Gradle 3.0+ and build-tools;26.0.2. r=maliu\n\nNew Android-Gradle plugins pin the build-tools version, and we want to\nbe consistent between Gradle and moz.build.\n\nMozReview-Commit-ID: ApWS4rHzPuH", "files": ["build.gradle", "gradle/wrapper/gradle-wrapper.properties", "mobile/android/app/build.gradle", "mobile/android/app/src/photon/res/values/styles.xml", "mobile/android/base/Makefile.in", "mobile/android/geckoview/build.gradle", "mobile/android/geckoview_example/build.gradle", "mobile/android/gradle.configure", "mobile/android/gradle/with_gecko_binaries.gradle", "mobile/android/thirdparty/build.gradle", "old-configure.in", "python/mozboot/mozboot/android-packages.txt", "taskcluster/scripts/misc/android-gradle-dependencies/after.sh"], "git_node": null, "git_parents": [null], "node": "23cbcf427745190d86d79cb41b276fdac2120bfa", "parents": ["eda74143389fda91a431246236c1db25f4760892"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Part 2: Update Robolectric to 3.5.1. r=mcomella\n\nThere were a few API changes, mostly around explicitly creating\nServices/Activities/ContentProvider instances, but they were pretty\neasy to address.\n\nSadly, Robolectric doesn't really work with the new aapt2 processing\nin Android-Gradle plugin 3.0+ -- see in particular\nhttps://github.com/robolectric/robolectric/issues/3333#issuecomment-324300418\n-- so we have to opt-out of the new implementation for now.  Hopefully\nplugin 3.1+ will address these issues, which are widespread.\n\nMozReview-Commit-ID: dlbd32kMs6", "files": ["gradle.properties", "mobile/android/app/build.gradle", "mobile/android/app/src/test/java/org/mozilla/gecko/GlobalPageMetadataTest.java", "mobile/android/app/src/test/java/org/mozilla/gecko/icons/loader/TestLegacyLoader.java", "mobile/android/app/src/test/java/org/mozilla/gecko/util/NetworkUtilsTest.java", "mobile/android/app/src/test/resources/robolectric.properties", "mobile/android/services/src/test/java/org/mozilla/gecko/background/db/DelegatingTestContentProvider.java", "mobile/android/services/src/test/java/org/mozilla/gecko/background/db/TestTabsProvider.java", "mobile/android/services/src/test/java/org/mozilla/gecko/background/testhelpers/MockGlobalSession.java", "mobile/android/services/src/test/java/org/mozilla/gecko/background/testhelpers/MockPrefsGlobalSession.java", "mobile/android/services/src/test/java/org/mozilla/gecko/db/BrowserProviderBookmarksTest.java", "mobile/android/services/src/test/java/org/mozilla/gecko/db/BrowserProviderGeneralTest.java", "mobile/android/services/src/test/java/org/mozilla/gecko/db/BrowserProviderHistoryVisitsTestBase.java", "mobile/android/services/src/test/java/org/mozilla/gecko/db/LocalBrowserDBTest.java", "mobile/android/services/src/test/java/org/mozilla/gecko/fxa/devices/TestFxAccountDeviceListUpdater.java", "mobile/android/services/src/test/java/org/mozilla/gecko/sync/repositories/android/VisitsHelperTest.java"], "git_node": null, "git_parents": [null], "node": "0e493bacc5e396aba37213caae165c8984dedcbc", "parents": ["23cbcf427745190d86d79cb41b276fdac2120bfa"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Part 3: Make each variant handle source from moz.build. r=maliu\n\nThe advantage of doing this per-variant is that we can really separate\nthe 'local' behaviour (re-generate via re-entrant |mach build|\ninvocations) from the 'official' behaviour (never re-generate via\nre-entrance).\n\nThis also uses new Android-Gradle plugin 3.0+ APIs to integrate the\ngenerated resources and Java code.\n\nMozReview-Commit-ID: 4pd2iw1nJSb", "files": ["mobile/android/app/build.gradle"], "git_node": null, "git_parents": [null], "node": "6ff0cdf46a3df61ee10b79b35669bb3193ff78e9", "parents": ["0e493bacc5e396aba37213caae165c8984dedcbc"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Part 4: Use flavorDimensions to simplify {with,without}GeckoBinaries logic. r=maliu\n\nMozReview-Commit-ID: 2rbsP6A0BY0", "files": ["mobile/android/app/build.gradle", "mobile/android/base/Makefile.in", "mobile/android/geckoview/build.gradle", "mobile/android/geckoview_example/build.gradle", "mobile/android/gradle.configure", "mobile/android/gradle/debug_level.gradle", "mobile/android/gradle/product_flavors.gradle", "mobile/android/gradle/with_gecko_binaries.gradle", "taskcluster/ci/build/android.yml"], "git_node": 