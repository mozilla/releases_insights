/mozbase/mozprocess/tests/test_mozprocess_kill_broad_wait.py"], "git_node": null, "git_parents": [null], "node": "02992587082593cdf619ca8870ee68efd646a599", "parents": ["3ad9c15c4006d65fcaeab4eb2bcf35bc0fe1bfb0"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1432430 - Disable h2 on osx for near perma fail timing out. r=rwood, a=test-only", "files": ["taskcluster/ci/test/test-sets.yml"], "git_node": null, "git_parents": [null], "node": "d4a3eb1c7daca6ff0716ff94c5e06dd885ff230a", "parents": ["02992587082593cdf619ca8870ee68efd646a599"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1422036 - Using WorkerControlRunnable to release resources in fetch when the worker is shutting down. r=catalinb, a=RyanVM", "files": ["dom/fetch/FetchConsumer.cpp", "dom/fetch/FetchConsumer.h"], "git_node": null, "git_parents": [null], "node": "e90cb80be46176022f4219b57c25f208313c1e1e", "parents": ["d4a3eb1c7daca6ff0716ff94c5e06dd885ff230a"], "tags": []}], "date": 1517948249, "git_changesets": [null, null, null], "user": "ryanvm@gmail.com"}, "8661": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nbg -\u003e 21fce88561e6\nbn-BD -\u003e a6a599013326\ncak -\u003e 003ffd480721\neo -\u003e e661868c63c6\nms -\u003e 7748fc5a2d20\nnb-NO -\u003e 1900480e9372\npt-PT -\u003e 16d1a2ef6042\nuk -\u003e 581f37a8760b\nzh-TW -\u003e 84495f431f28", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "01882a096fe145e583161a8da2aa257b3289880b", "parents": ["e90cb80be46176022f4219b57c25f208313c1e1e"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nbg -\u0