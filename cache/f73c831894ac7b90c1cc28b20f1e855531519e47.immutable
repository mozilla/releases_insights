": "395f2da2308fab8763cd164c9b3d04dbc903a0e0", "parents": ["f40f5ac940c145d2e484c4f94032b3006e5a7a4f"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1429929 - Remove tabbrowser-close-tab-button binding. r=Gijs\n\nMozReview-Commit-ID: 3bIccSfVMuJ", "files": ["browser/base/content/tabbrowser.css", "browser/base/content/tabbrowser.xml"], "git_node": null, "git_parents": [null], "node": "11fd0d47649f5fa72d3c065de493ba9f4a764297", "parents": ["395f2da2308fab8763cd164c9b3d04dbc903a0e0"], "tags": []}, {"author": "Adrian Wielgosik \u003cadrian.wielgosik@gmail.com\u003e", "branch": "default", "desc": "Bug 1379891 - remove nsPIEditorTransaction interface, GetTxnDescription methods. r=m_kato,masayuki\n\nMozReview-Commit-ID: 4NLeMrrqIv5\n", "files": ["editor/libeditor/ChangeAttributeTransaction.cpp", "editor/libeditor/ChangeStyleTransaction.cpp", "editor/libeditor/CompositionTransaction.cpp", "editor/libeditor/CreateElementTransaction.cpp", "editor/libeditor/DeleteNodeTransaction.cpp", "editor/libeditor/DeleteRangeTransaction.cpp", "editor/libeditor/DeleteTextTransaction.cpp", "editor/libeditor/EditAggregateTransaction.cpp", "editor/libeditor/EditTransactionBase.cpp", "editor/libeditor/EditTransactionBase.h", "editor/libeditor/InsertNodeTransaction.cpp", "editor/libeditor/InsertTextTransaction.cpp", "editor/libeditor/JoinNodeTransaction.cpp", "editor/libeditor/PlaceholderTransaction.cpp", "editor/libeditor/SplitNodeTransaction.cpp", "editor/libeditor/StyleSheetTransactions.cpp", "editor/moz.build", "editor/nsPIEditorTransaction.idl"], "git_node": null, "git_parents": [null], "node": "a50f8a3e37013199700b3a0d88c2fba12608277b", "parents": ["11fd0d47649f5fa72d3c065de493ba9f4a764297"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1430109 - Combine assert.window and assert.contentBrowser. r=maja_zf\n\nThe forthcoming window tracking refactoring introduces the new\nabstractions ContentContext and ChromeContext that to a large extent\nshare the same interface.  They make it possible to interact with\nboth types of browsing context in a uniform manner.\n\nMarionette currently has a lot of convoluted if-conditions to\npaper over the differences between ChromeWindow, \u003cxul:browser\u003e,\nand browser.Context.  Examples of this includes the assert.window\nand assert.contentBrowser assertions: they essentially perform the\nsame job, but does not share the same API because the underlying\nAPIs they call are different.\n\nIn an effort to prepare Marionette for the window tracking refactoring,\nthis patch adds a bit of glue to combine them both into one assertion\ncalled assert.open.  This checks that the browsing context has not\nbeen discarded.\n\nMozReview-Commit-ID: K5e7Sr1mq0", "files": ["testing/marionette/assert.js", "testing/marionette/browser.js", "testing/marionette/driver.js", "testing/marionette/test_assert.js"], "git_node": null, "git_parents": [null], "node": "e8ae7190dd15d67766b396320de894120faa5734", "parents": ["a50f8a3e37013199700b3a0d88c2fba12608277b"], "tags": []}, {"author": "CYBAI \u003ccyb.ai.815@gmail.com\u003e", "branch": "default", "desc": "servo: Merge #19709 - style: Remove -servo-display-for-hypothetical-box from longhand (from CYBAI:servo-display-out-of-mako); r=emilio\n\nThis is a sub-PR of #19015\nr? emilio\n\nFor the `fn set_original_display` inside `properties.mako.rs`, I removed `is_item_or_root` first to see how the tests result is. If it's needed, I'll add it back.\n\n---\n- [x] `./mach build -d` does not report any errors\n- [x] `./mach test-tidy` does not report any errors\n- [x] These changes fix #19697\n- [x] These changes do not require tests\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 1b46e2e7597e90a41c6bfb3bd7008bdd922c93c6", "files": ["servo/components/layout/construct.rs", "servo/components/style/properties/gecko.mako.rs", "servo/components/style/properties/longhand/box.mako.rs", "servo/components/style/properties/properties.mako.rs", "servo/components/style/values/specified/box.rs"], "git_node": null, "git_parents": [null], "node": "ae38eda6d6ff8fe07e2846693e5547877bd17d57", "parents": ["e8ae7190dd15d67766b396320de894120faa5734"], "tags": []}, {"author": "Noemi Erli \u003cnerli@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset e8ae7190dd15 (bug 1430109) for Wr failures in /builds/worker/workspace/build/tests/web-platform/tests/tools/wptrunner/wptrunner/testrunner.py on a CLOSED TREE", "files": ["testing/marionette/assert.js", "testing/marionette/browser.js", "testing/marionette/driver.js", "testing/marionette/test_assert.js"], "git_node": null, "git_parents": [null], "node": "74055b2dab456b891e2d373e9999186639bc1ebc", "parents": ["ae38eda6d6ff8fe07e2846693e5547877bd17d57"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1430005 - For mozharness jobs, rely on the default being set by the mozharness transform. r=dustin\n\nThe mozharness transform is supposed to set the docker image to\ndesktop-build when not already set, but was not doing it properly.\n\nI guess this is why some jobs were setting the image themselves, despite\nusing the mozharness transform.\n\nConsequently, don't manually set the image to desktop-build when it's\nthe default.", "files": ["taskcluster/ci/artifact-build/kind.yml", "taskcluster/ci/build/macosx.yml", "taskcluster/ci/l10n/kind.yml", "taskcluster/ci/nightly-l10n/kind.yml", "taskcluster/ci/searchfox/kind.yml", "taskcluster/ci/static-analysis/kind.yml", "taskcluster/taskgraph/transforms/job/mozharness.py"], "git_node": null, "git_parents": [null], "node": "8d0a31ff12e5d996ab53787d23e7adc1b4ebd7aa", "parents": ["74055b2dab456b891e2d373e9999186639bc1ebc"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1430005 - Refactor spidermonkey tc configurations. r=dustin\n\nWith the use of job-defaults, we can avoid a lot of repetition from\nthose definitions.", "files": ["taskcluster/ci/spidermonkey/kind.yml", "taskcluster/ci/spidermonkey/linux.yml", "taskcluster/ci/spidermonkey/windows.yml"], "git_node": null, "git_parents": [null], "node": "5111f1ad412a8cef541f1420c675fdc775c077e1", "parents": ["8d0a31ff12e5d996ab53787d23e7adc1b4ebd7aa"], "tags": []}, {"author": "ffxbld", "branch": "default", "desc": "No bug, Automated HSTS preload list update from host bld-linux64-spot-302 - a=hsts-update", "files": ["security/manager/ssl/nsSTSPreloadList.errors", "security/manager/ssl/nsSTSPreloadList.inc"], "git_node": null, "git_parents": [null], "node": "72d73514cbd02a975d719ab93d8cd53e03be058c", "parents": ["f40f5ac940c145d2e484c4f94032b3006e5a7a4f"], "tags": []}, {"author": "ffxbld", "branch": "default", "desc": "No bug, Automated HPKP preload list update from host bld-linux64-spot-302 - a=hpkp-update", "files": ["security/manager/ssl/StaticHPKPins.h"], "git_node": null, "git_parents": [null], "node": "e157471df46e457a0f9c1eb785dc8cb5746067a4", "parents": ["72d73514cbd02a975d719ab93d8cd53e03be058c"], "tags": []}, {"author": "Narcis Beleuzu \u003cnbeleuzu@mozilla.com\u003e", "branch": "default", "desc": "Merge autoland to mozilla-central. a=merge", "files": ["editor/nsPIEditorTransaction.idl"], "git_node": null, "git_parents": [null, null], "node": "21ddfb9e6cc008e47da89db50e22697dc7b38635", "parents": ["e157471df46e457a0f9c1eb785dc8cb5746067a4", "74055b2dab456b891e2d373e9999186639bc1ebc"], "tags": []}, {"author": "Narcis Beleuzu \u003cnbeleuzu@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland. a=merge on a CLOSED TREE", "files": [], "git_node": null, "git_parents": [null, null], "node": "1a3dd418e8e7f7ece934ad0ffb91109514de3cce", "parents": ["5111f1ad412a8cef541f1420c675fdc775c077e1", "21ddfb9e6cc008e47da89db50e22697dc7b38635"], "tags": []}, {"author": "Jon Leighton \u003cj@jonathanleighton.com\u003e", "branch": "default", "desc": "servo: Merge #19766 - Move image-orientation property outside of mako (from jonleighton:issue-19765); r=emilio\n\nFixes https://github.com/servo/servo/issues/19765\n\nr? emilio\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: ec34023d7a1ba5d7cc882fbb66b880960ce79c43", "files": ["servo/components/style/properties/gecko.mako.rs", "servo/components/style/properties/longhand/inherited_box.mako.rs", "servo/components/style/values/computed/inherited_box.rs", "servo/components/style/values/computed/mod.rs", "servo/components/style/values/specified/inherited_box.rs", "servo/components/style/values/specified/mod.rs"], "git_node": null, "git_parents": [null], "node": "0969933b3908afef3035183c93f8fd67d2bcef31", "parents": ["1a3dd418e8e7f7ece934ad0ffb91109514de3cce"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1426244 - 1. Fix some errors from javadoc generation; r=nalexander\n\nTweak the javadoc task arguments to not generate errors for a standard\nGeckoView javadoc run.\n\nMozReview-Commit-ID: 931xCtUcX6N", "files": ["mobile/android/geckoview/build.gradle"], "git_node": null, "git_parents": [null], "node": "516d427dcc01f9702a2819a6990d10a68977b272", "parents": ["0969933b3908afef3035183c93f8fd67d2bcef31"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1426244 - 2. Fix javadoc comments; r=droeh,nalexander\n\nAdd some missing lines and fix some mistakes in our javadoc comments.\n\nMozReview-Commit-ID: 9Q7qWJJ51Vo", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoProfile.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoSession.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/SysInfo.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/TextInputController.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/gfx/DynamicToolbarAnimator.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/gfx/LayerSession.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/gfx/NativePanZoomController.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/util/ContextUtils.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/util/DateUtil.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/util/FileUtils.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/util/IntentUtils.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/util/StringUtils.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/util/publicsuffix/PublicSuffix.java"], "git_node": null, "git_parents": [null], "node": "14ba5b4ea2ab1c90ca5b3d93dbf92095a0798fa1", "parents": ["516d427dcc01f9702a2819a6990d10a68977b272"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1426244 - 4. Add mach android geckoview-docs command; r=nalexander\n\nAdd a './mach android geckoview-docs' command that generates javadoc for\nGeckoView using Gradle. Specifying the '--archive' option will generate\na geckoview-javadoc.jar archive. Specifying the '--upload' option,\nintended primarily for Taskcluster, will upload the javadoc to Github\npages under the given user/repository.\n\nMozReview-Commit-ID: HfwXlf8aFhw", "files": ["mobile/android/mach_commands.py"], "git_node": null, "git_parents": [null], "node": "70e6e0af00647c9e523e4a041a247ebb60f9f3a9", "parents": ["14ba5b4ea2ab1c90ca5b3d93dbf92095a0798fa1"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1426244 - 5. Add geckoview-docs job; r=nalexander\n\nAdd a geckoview-docs job that executes \"./mach android geckoview-docs\",\nwhich takes care of calling gradle to generate the javadoc archive, and\nuploading it to Github using given parameters.\n\nMozReview-Commit-ID: DTWh4XdFZEO", "files": ["taskcluster/ci/build/android-stuff.yml", "taskcluster/docker/android-build/Dockerfile", "testing/mozharness/configs/builds/releng_sub_android_configs/64_geckoview_docs.py", "testing/mozharness/mozharness/mozilla/building/buildbase.py"], "git_node": null, "git_parents": [null], "node": "ca369a31f46c1d1adef0c4ee35e033b34361fe99", "parents": ["70e6e0af00647c9e523e4a041a247ebb60f9f3a9"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1429682 - Remove HAVE_I18N_LC_MESSAGES from old-configure.in. r=froydnj\n\nAfter landing bug 1356263, no one uses HAVE_I18N_LC_MESSAGES.  So it is\nunnecessary to check LC_MESSAGES.\n\nMozReview-Commit-ID: IPgl3rQ2qrd", "files": ["js/src/old-configure.in", "old-configure.in"], "git_node": null, "git_parents": [null], "node": "af7bb8f7d477f4e466cb12a17a3b361e0669beab", "parents": ["ca369a31f46c1d1adef0c4ee35e033b34361fe99"], "tags": []}, {"author": "DimiL \u003cdlee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1422671 - Add telemetry for login reputation service. r=francois datareview?francois\n\nMozReview-Commit-ID: LaWcGww6hJx", "files": ["toolkit/components/reputationservice/LoginReputation.cpp", "toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "3d8de88bfdf35d37d6c476af1303f13b97b8b656", "parents": ["af7bb8f7d477f4e466cb12a17a3b361e0669beab"], "tags": []}, {"author": "Glenn Watson \u003cgithub@intuitionlibrary.com\u003e", "branch": "default", "desc": "servo: Merge #19768 - Update WR (overlap radii fix, subpixel AA in fast text shadows) (from glennw:update-wr-fixes1); r=jdm\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: eb1634b56b27c163a3721f7416c5ade5fa4878a6", "files": ["servo/Cargo.lock"], "git_node": null, "git_parents": [null], "node": "c5d312561c224c3c80b2eedb89d17c4f8b30bfe4", "parents": ["3d8de88bfdf35d37d6c476af1303f13b97b8b656"], "tags": []}, {"author": "Munro Mengjue Chiang \u003cmchiang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1420585 - remove unnecessary stopCapture which causes deadlock. r=jib\n\nMozReview-Commit-ID: F8xcOSPihDN", "files": ["media/webrtc/trunk/webrtc/modules/video_capture/android/java/src/org/webrtc/videoengine/VideoCaptureAndroid.java"], "git_node": null, "git_parents": [null], "node": "f5b452454285510ee2d3358332e19c3ad4fa0ec8", "parents": ["c5d312561c224c3c80b2eedb89d17c4f8b30bfe4"], "tags": []}, {"author": "Munro Mengjue Chiang \u003cmchiang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1420585 - refine logs. r=jib\n\nMozReview-Commit-ID: KJlFTQALAb4", "files": ["dom/media/webrtc/MediaEngineCameraVideoSource.cpp", "dom/media/webrtc/MediaEngineRemoteVideoSource.cpp"], "git_node": null, "git_parents": [null], "node": "0e8dc361a38f32d0faad3e85df0676d05e06b2d8", "parents": ["f5b452454285510ee2d3358332e19c3ad4fa0ec8"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1415416 - Part 1. Collapse selection on focus when value is empty. r=masayuki\n\nAfter landing bug 1375910, input.value = \"\" doesn't remove inter text node.\nWhen value is empty, SelectAllOrCollapseToEndOfText will set selection to\nend of text.  But since empty text node is still exist, it select all nodes,\ninstead of collapsed.  So if text node is empty, we should collapse selection.\n\nMozReview-Commit-ID: Gm0AP6YSJIg", "files": ["layout/forms/nsTextControlFrame.cpp"], "git_node": null, "git_parents": [null], "node": "e77e0779441a4ddc97a31c7f0b6f21fd84500420", "parents": ["0e8dc361a38f32d0faad3e85df0676d05e06b2d8"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1415416 - Part 2. Add test. r=masayuki\n\nMozReview-Commit-ID: 5Bbh5ifPSs7", "files": ["layout/base/tests/bug1415416-ref.html", "layout/base/tests/bug1415416.html", "layout/base/tests/mochitest.ini", "layout/base/tests/test_reftests_with_caret.html"], "git_node": null, "git_parents": [null], "node": "02e365e09e79fbfb387a6f17889cec86bd0136e2", "parents": ["e77e0779441a4ddc97a31c7f0b6f21fd84500420"], "tags": []}, {"author": "Alastor Wu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1428722 - part1 : always activate the top level frame. r=smaug\n\nFor top level frame, it should also be activated when user activate its child frame.\n\neg. A (youtube.com) -\u003e B (ad.com), when user activate B frame, the A frame would also be activated.\n\nMozReview-Commit-ID: BP7eGKiqYJe", "files": ["dom/base/nsDocument.cpp", "dom/base/nsIDocument.h", "dom/events/EventStateManager.cpp"], "git_node": null, "git_parents": [null], "node": "b9056b64d45b7dbf8dd7e6284e543ea1ada7502b", "parents": ["02e365e09e79fbfb387a6f17889cec86bd0136e2"], "tags": []}, {"author": "Alastor Wu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1428722 - part2 : move all user-activation implementation details to nsDocument. r=smaug\n\nIn order to write tests, I would like to create an method that allows chorome js can directly set the user-activation flag.\n\nTherefore, I need to move all these details into nsDocument, then we could easily simulate the user activation.\n\nMozReview-Commit-ID: 5JrCoQc0vF7", "files": ["dom/base/nsDocument.cpp", "dom/base/nsIDocument.h", "dom/events/EventStateManager.cpp", "dom/webidl/Document.webidl"], "git_node": null, "git_parents": [null], "node": "adbad272045dee6f307751ae15037319b4e5d3bc", "parents": ["b9056b64d45b7dbf8dd7e6284e543ea1ada7502b"], "tags": []}, {"author": "Alastor Wu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1428722 - part3 : add tests. r=smaug\n\nMozReview-Commit-ID: 4WfADcQinuQ", "files": ["toolkit/content/tests/browser/browser.ini", "toolkit/content/tests/browser/browser_autoplay_policy_iframe_hierarchy.js", "toolkit/content/tests/browser/file_autoplay_three_layers_frame1.html", "toolkit/content/tests/browser/file_autoplay_three_layers_frame2.html", "toolkit/content/tests/browser/file_autoplay_two_layers_frame1.html", "toolkit/content/tests/browser/file_autoplay_two_layers_frame2.html"], "git_node": null, "git_parents": [null], "node": "6f9b763bb1c9f03be9ff0420a7b52261306bd227", "parents": ["adbad272045dee6f307751ae15037319b4e5d3bc"], "tags": []}, {"author": "KuoE0 \u003ckuoe0.tw@gmail.com\u003e", "branch": "default", "desc": "Bug 1428297 - (Part 1) Add an nsLayoutUtils function to check whether content-select is enabled r=mats\n\nMozReview-Commit-ID: KVQ25Dhl9xl", "files": ["layout/base/nsCSSFrameConstructor.cpp", "layout/base/nsLayoutUtils.cpp", "layout/base/nsLayoutUtils.h"], "git_node": null, "git_parents": [null], "node": "4334dcb44c573785a8a716000aa9d9c5301fb0d7", "parents": ["6f9b763bb1c9f03be9ff0420a7b52261306bd227"], "tags": []}, {"author": "KuoE0 \u003ckuoe0.tw@gmail.com\u003e", "branch": "default", "desc": "Bug 1428297 - (Part 2) Ignore the widget/view usage that is used to show the dropdown menu when content-select is enabled. r=mats\n\nMozReview-Commit-ID: 68HYWmniXwt", "files": ["layout/base/nsCSSFrameConstructor.cpp", "layout/base/nsLayoutUtils.cpp", "layout/forms/nsComboboxControlFrame.cpp", "layout/forms/nsListControlFrame.cpp"], "git_node": null, "git_parents": [null], "node": "6ed02115d2c6e7695934b40f00f866845c73c648", "parents": ["4334dcb44c573785a8a716000aa9d9c5301fb0d7"], "tags": []}, {"author": "KuoE0 \u003ckuoe0.tw@gmail.com\u003e", "branch": "default", "desc": "Bug 1428297 - (Part 3) Disable the assertion that don't allow to call ShowDropDown() in the content process when content-select is enabled. r=mats\n\nTo prevent the crash when content-select is enabled, I disable this\nassertion that don't allow to call ShowDropDown() in the content\nprocess.\n\nMozReview-Commit-ID: F3BelChp1AK", "files": ["layout/forms/nsComboboxControlFrame.cpp"], "git_node": null, "git_parents": [null], "node": "46dd32e1f0fae9d4d7a56a258ce126fae0078f60", "parents": ["6ed02115d2c6e7695934b40f00f866845c73c648"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1422230 - part 1: TextEventDispatcher should manage if dispatched composition events have been handled by remote content and TSFTextStore refer the state r=m_kato\n\nWhen composition events are handled by content actually, widget receives\nNOTIFY_IME_OF_COMPOSITION_EVENT_HANDLED notification.  If focused content\nis in a remote process, this is notified only when all sending composition\nevents are handled in the remote process.  So, when widget receives the\nnotification can there is no composition in IME, that means that nobody is\ncomposing composition at that time.\n\nThis patch adds TextEventDispatcher::IsHandlingComposition() which returns\nfalse only when nobody has composition and makes TSFTextStore refer this\nmethod because TSFTextStore needs to know if focused content has composition\nin any cases.\n\nMozReview-Commit-ID: F1ZZgFJAArD", "files": ["widget/TextEventDispatcher.cpp", "widget/TextEventDispatcher.h", "widget/windows/TSFTextStore.cpp", "widget/windows/TSFTextStore.h"], "git_node": null, "git_parents": [null], "node": "7eb571ca5f142196f1ae7227ffca3272147803b4", "parents": ["46dd32e1f0fae9d4d7a56a258ce126fae0078f60"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1422230 - part 2: ContentCacheInParent should allow to query content relative to composition string even after sending eCompositionCommit(AsIs) event but not yet handled in the remote process r=m_kato\n\nCurrently, ContentCacheInParent uses selection when it handles query content\nevent whose input offset is relative one after sending eCompositionCommit(AsIs)\nevent but it's not yet handled by the remote process.  However, in this case,\nselection may not be modified with committed string.\n\nSo, when mPendingCommitCount is not 0, ContentCacheInParent should compute\nabsolute offset with the latest composition string information.  For doing\nthis, it needs to keep storing mCompositionStart until eCompositionCommit(AsIs)\nis handled in the remote process actually.\n\nMozReview-Commit-ID: 2Dc69HNIbvh", "files": ["widget/ContentCache.cpp"], "git_node": null, "git_parents": [null], "node": "9aa31af5773b97fdcc06a1f4da8830be7ff096bd", "parents": ["7eb571ca5f142196f1ae7227ffca3272147803b4"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1422230 - part 3: TSFTextStore should store composition string information until both TSF/TIP and our content finish handling composition r=m_kato\n\nIf remote process hasn't handled dispatched commit event yet, TSFTextStore\nneeds to dispatch query content event relative to latest composition string\ninformation.  So, TSFTextStore::mContentForTSF should cache composition start\nand composition string length until pending composition events are handled\nby content actually.\n\nMozReview-Commit-ID: ARM851nNZGz", "files": ["widget/windows/TSFTextStore.cpp", "widget/windows/TSFTextStore.h"], "git_node": null, "git_parents": [null], "node": "d02c066d501be954cd60ea4b20b5ed291cd6b938", "parents": ["9aa31af5773b97fdcc06a1f4da8830be7ff096bd"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1422230 - part 4: TSFTextStore::GetTextExt() should refer composition string in content r=m_kato\n\nCurrently, TSFTextStore::GetTextExt() refers mComposition for doing its own\nhack.  However, this means that it refers composition in TIP.  However,\nquery event is computed with content information.  So, even if TSFTextStore\ndispatched eCompositionCommit event, it may not be handled by content yet.\n\nIn this case, we need information relative to last composition string.\nSo, TSFTextStore::GetTextExt() should refer IsHandlingComposition() and\nlast composition string information stored by mContentForTSF.\n\nMozReview-Commit-ID: KMqrDmnUldU", "files": ["widget/windows/TSFTextStore.cpp"], "git_node": null, "git_parents": [null], "node": "3700de32eedbe6670085841c3a36fe091f7a1543", "parents": ["d02c066d501be954cd60ea4b20b5ed291cd6b938"], "tags": []}, {"author": "Scott Wu \u003cscottcwwu@gmail.com\u003e", "branch": "default", "desc": "Bug 1427510 - Use current year as expiration year in credit card test case to fix perma failure. r=lchang\n\nMozReview-Commit-ID: IuDCc6UDfay", "files": ["browser/extensions/formautofill/test/browser/browser.ini", "browser/extensions/formautofill/test/browser/browser_creditCard_doorhanger.js", "browser/extensions/formautofill/test/browser/browser_editCreditCardDialog.js", "browser/extensions/formautofill/test/browser/head.js"], "git_node": null, "git_parents": [null], "node": "93fa34d5492cfaa900f3eb109cde76ef1c5f5917", "parents": ["3700de32eedbe6670085841c3a36fe091f7a1543"], "tags": []}, {"author": "Scott Wu \u003cscottcwwu@gmail.com\u003e", "branch": "default", "desc": "Bug 1412247 - Ensure checkbox label and \"Learn more\" link stay on the same line. r=lchang\n\nMozReview-Commit-ID: L54LV6mcqg7", "files": ["browser/extensions/formautofill/FormAutofillPreferences.jsm"], "git_node": null, "git_parents": [null], "node": "48d3e471b9aa55a9376fa467541c5877bea34d6e", "parents": ["93fa34d5492cfaa900f3eb109cde76ef1c5f5917"], "tags": []}, {"author": "Csoregi Natalia \u003cncsoregi@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 93fa34d5492c (bug 1427510) for failing browser/extensions/formautofill/test/browser/browser_editCreditCardDialog.js. on a CLOSED TREE", "files": ["browser/extensions/formautofill/test/browser/browser.ini", "browser/extensions/formautofill/test/browser/browser_creditCard_doorhanger.js", "browser/extensions/formautofill/test/browser/browser_editCreditCardDialog.js", "browser/extensions/formautofill/test/browser/head.js"], "git_node": null, "git_parents": [null], "node": "9eb1b0cd2f1c281357b98418af4ed2ca04f95af2", "parents": ["48d3e471b9aa55a9376fa467541c5877bea34d6e"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430216 - For non-scalable fonts, we can't use the linearHoriAdvance field from the glyph slot; use the advance field instead to get proper metrics. r=lsalzman", "files": ["gfx/thebes/gfxFT2FontBase.cpp"], "git_node": null, "git_parents": [null], "node": "7f9d938235e76b24ac6e169e79b4534b4315bb49", "parents": ["3d28ca7c05d8f9ba3ba6ff1cd5449dce42ae95c1"], "tags": []}, {"author": "shindli \u003cshindli@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to inbound.  a=merge CLOSED TREE", "files": [], "git_node": null, "git_parents": [null, null], "node": "abdfc64ff0889313de38af7c1bfd3382ebd81269", "parents": ["7f9d938235e76b24ac6e169e79b4534b4315bb49", "f40f5ac940c145d2e484c4f94032b3006e5a7a4f"], "tags": []}, {"author": "Narcis Beleuzu \u003cnbeleuzu@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to inbound. a=merge on a CLOSED TREE", "files": ["editor/nsPIEditorTransaction.idl"], "git_node": null, "git_parents": [null, null], "node": "f156308bc836f3516822622c893e852bec52509d", "parents": ["abdfc64ff0889313de38af7c1bfd3382ebd81269", "21ddfb9e6cc008e47da89db50e22697dc7b38635"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1402526 - Add crashtest. r=me a=test-only", "files": ["editor/libeditor/crashtests/1402526.html", "editor/libeditor/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "5f74d7b82fe3aa5911e38ccfc1e19fc071555530", "parents": ["f156308bc836f3516822622c893e852bec52509d"], "tags": []}, {"author": "Stone Shih \u003csshih@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414336 - Don't fire pointercancel when content prevents default on touchstart. r=kats.\n\nMozReview-Commit-ID: LWPI415MV2F", "files": ["gfx/layers/apz/util/APZEventState.cpp"], "git_node": null, "git_parents": [null], "node": "f59d5e77eee08dc55839363423036ffd2e4f7c12", "parents": ["5f74d7b82fe3aa5911e38ccfc1e19fc071555530"], "tags": []}, {"author": "Stone Shih \u003csshih@mozilla.com\u003e", "branch": "default", "desc": "Bug 1414336 - Add a test case to make sure pointercancel isn't fired when content prevents default on touchstart. r=kats.\n\nMozReview-Commit-ID: 93FSsD3bXvA", "files": ["dom/events/test/pointerevents/mochitest.ini", "dom/events/test/pointerevents/test_bug1414336.html"], "git_node": null, "git_parents": [null], "node": "f80a0db7028491293d85bcfe17f27fa103d33938", "parents": ["f59d5e77eee08dc55839363423036ffd2e4f7c12"], "tags": []}, {"author": "Jessica Jong \u003cjjong@mozilla.com\u003e", "branch": "default", "desc": "Bug 1429982 - cloneNode on ShadowRoot interface should throw NotSupportedError. r=smaug\n\nThe spec changed in order to align with the error thrown by importNode.", "files": ["dom/base/ShadowRoot.cpp", "dom/base/nsDocument.cpp", "dom/tests/mochitest/webcomponents/mochitest.ini", "dom/tests/mochitest/webcomponents/test_bug1176757.html", "dom/tests/mochitest/webcomponents/test_shadowroot_clonenode.html", "testing/web-platform/meta/shadow-dom/Node-prototype-cloneNode.html.ini", "testing/web-platform/meta/shadow-dom/untriaged/elements-and-dom-objects/shadowroot-object/shadowroot-methods/test-010.html.ini"], "git_node": null, "git_parents": [null], "node": "b584c2d1fb904386cd94f1da1169d115e641fa9a", "parents": ["f80a0db7028491293d85bcfe17f27fa103d33938"], "tags": []}, {"author": "Jessica Jong \u003cjjong@mozilla.com\u003e", "branch": "default", "desc": "Bug 1429656 - Implement ShadowRoot.activeElement. r=smaug", "files": ["dom/base/DocumentOrShadowRoot.cpp", "dom/base/DocumentOrShadowRoot.h", "dom/base/FragmentOrElement.cpp", "dom/base/ShadowRoot.cpp", "dom/base/ShadowRoot.h", "dom/base/nsDocument.cpp", "dom/base/nsFocusManager.cpp", "dom/base/nsIContent.h", "dom/webidl/ShadowRoot.webidl", "testing/web-platform/meta/shadow-dom/ShadowRoot-interface.html.ini", "testing/web-platform/meta/shadow-dom/untriaged/elements-and-dom-objects/shadowroot-object/shadowroot-attributes/activeElement-confirm-return-null.html.ini", "testing/web-platform/meta/shadow-dom/untriaged/elements-and-dom-objects/shadowroot-object/shadowroot-attributes/test-007.html.ini", "testing/web-platform/meta/shadow-dom/untriaged/user-interaction/active-element/test-001.html.ini", "testing/web-platform/meta/shadow-dom/untriaged/user-interaction/active-element/test-002.html.ini"], "git_node": null, "git_parents": [null], "node": "52397f10a40b2dc2c2e07440e1b9c986eec112fa", "parents": ["b584c2d1fb904386cd94f1da1169d115e641fa9a"], "tags": []}, {"author": "Gurzau Raul \u003crgurzau@mozilla.com\u003e", "branch": "default", "desc": "Merge inbound to mozilla-central. a=merge", "files": ["dom/base/nsDocument.cpp", "dom/tests/mochitest/webcomponents/test_bug1176757.html", "testing/web-platform/meta/shadow-dom/Node-prototype-cloneNode.html.ini", "testing/web-platform/meta/shadow-dom/ShadowRoot-interface.html.ini", "testing/web-platform/meta/shadow-dom/untriaged/elements-and-dom-objects/shadowroot-object/shadowroot-attributes/activeElement-confirm-return-null.html.ini", "testing/web-platform/meta/shadow-dom/untriaged/elements-and-dom-objects/shadowroot-object/shadowroot-attributes/test-007.html.ini", "testing/web-platform/meta/shadow-dom/untriaged/elements-and-dom-objects/shadowroot-object/shadowroot-methods/test-010.html.ini", "testing/web-platform/meta/shadow-dom/untriaged/user-interaction/active-element/test-001.html.ini", "testing/web-platform/meta/shadow-dom/untriaged/user-interaction/active-element/test-002.html.ini"], "git_node": null, "git_parents": [null, null], "node": "b7d66e4e60ef177ec9ae687daa29443ae4a2acfc", "parents": ["6f9b763bb1c9f03be9ff0420a7b52261306bd227", "52397f10a40b2dc2c2e07440e1b9c986eec112fa"], "tags": []}, {"author": "Gurzau Raul \u003crgurzau@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland.  a=merge CLOSED TREE", "files": ["dom/tests/mochitest/webcomponents/test_bug1176757.html", "testing/web-platform/meta/shadow-dom/Node-prototype-cloneNode.html.ini", "testing/web-platform/meta/shadow-dom/ShadowRoot-interface.html.ini", "testing/web-platform/meta/shadow-dom/untriaged/elements-and-dom-objects/shadowroot-object/shadowroot-attributes/activeElement-confirm-return-null.html.ini", "testing/web-platform/meta/shadow-dom/untriaged/elements-and-dom-objects/shadowroot-object/shadowroot-attributes/test-007.html.ini", "testing/web-platform/meta/shadow-dom/untriaged/elements-and-dom-objects/shadowroot-object/shadowroot-methods/test-010.html.ini", "testing/web-platform/meta/shadow-dom/untriaged/user-interaction/active-element/test-001.html.ini", "testing/web-platform/meta/shadow-dom/untriaged/user-interaction/active-element/test-002.html.ini"], "git_node": null, "git_parents": [null, null], "node": "ab6c457eac94fed47844d470aa18ecbfa8da0cfc", "parents": ["9eb1b0cd2f1c281357b98418af4ed2ca04f95af2", "b7d66e4e60ef177ec9ae687daa29443ae4a2acfc"], "tags": []}, {"author": "Fernando Jim\u00e9nez Moreno \u003cferjmoreno@gmail.com\u003e", "branch": "default", "desc": "servo: Merge #19772 - Do not fire pending callbacks on disconnected performance observer (from ferjm:performance.wpt); r=nox\n\nImplement this change in the Performance Timeline API https://github.com/w3c/performance-timeline/issues/66\n\n- [X] `./mach build -d` does not report any errors\n- [X] `./mach test-tidy` does not report any errors\n- [X] There are tests for these changes\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: f866e1aacb5bcf17a7d11c6106d34b474d6b4f33", "files": ["servo/components/script/dom/performance.rs"], "git_node": null, "git_parents": [null], "node": "df10cf0252d0e8bd8f02aaa702bd9085a5c3bf89", "parents": ["ab6c457eac94fed47844d470aa18ecbfa8da0cfc"], "tags": []}, {"author": "Patrick Brosset \u003cpbrosset@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430001 - Highlight all used fonts in the rule-view, not just the first one; r=miker\n\nMozReview-Commit-ID: Gxi34noKsxu", "files": ["devtools/client/inspector/rules/test/browser_rules_highlight-used-fonts.js", "devtools/client/inspector/rules/views/text-property-editor.js"], "git_node": null, "git_parents": [null], "node": "f13e1bf54640cc830abab85a206a48c20cb20ff4", "parents": ["df10cf0252d0e8bd8f02aaa702bd9085a5c3bf89"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1430512: Remove unnecessary use of -moz-border-bottom-colors in aboutBase.css. r=dao\n\nA single color in the color list renders just as border-bottom-color.\n\nThis used to have two colors, but was changed in [1], so now it can go away.\n\n[1]: https://hg.mozilla.org/mozilla-central/rev/cfdf310748918c3d5eadc16daa5153091e325995\n\nMozReview-Commit-ID: LDocmCwjkzw", "files": ["mobile/android/themes/core/aboutBase.css"], "git_node": null, "git_parents": [null], "node": "85e86d628948224426be069dfec817ceaf7d5316", "parents": ["f13e1bf54640cc830abab85a206a48c20cb20ff4"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "servo: Merge #19769 - layout: Simplify the pseudo-element setup (from emilio:simplify-layout-construct); r=nox\n\nIt's kind of a mess. See individual commits for details.\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 032fd388e4efdd9ecc682877d017b9d2f78e29e2", "files": ["servo/components/layout/construct.rs", "servo/components/layout/display_list/builder.rs", "servo/components/layout/fragment.rs", "servo/components/layout/generated_content.rs", "servo/components/layout/inline.rs", "servo/components/layout_thread/dom_wrapper.rs", "servo/components/script_layout_interface/wrapper_traits.rs"], "git_node": null, "git_parents": [null], "node": "686ecd397983995980b7d30309f1b2a8eb1e3e38", "parents": ["85e86d628948224426be069dfec817ceaf7d5316"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "servo: Merge #19757 - style: Remove -servo-text-decorations-in-effect (from emilio:bye-custom-cascade); r=nox\n\nIt is bogus, because it depends on the display property as it's cascaded, but\nthe display property can change afterwards, for example, if we get blockified\nbecause we're the root element or a flex item.\n\nReplace it with a normal field instead.\n\nAlso, it carries some weight, because it's the last property that uses this\nconcept of \"derived\" property, and \"custom cascade\". So we can remove some code\nafter this.\n\nCompute it after the cascade process in StyleAdjuster.\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: f2036e7661a3f865b38d8296cc1b8ab98e60f679", "files": ["servo/components/layout/display_list/builder.rs", "servo/components/style/properties/data.py", "servo/components/style/properties/helpers.mako.rs", "servo/components/style/properties/longhand/box.mako.rs", "servo/components/style/properties/longhand/inherited_text.mako.rs", "servo/components/style/properties/longhand/text.mako.rs", "servo/components/style/properties/properties.mako.rs", "servo/components/style/servo/restyle_damage.rs", "servo/components/style/style_adjuster.rs", "servo/components/style/values/computed/text.rs", "servo/components/style/values/specified/box.rs", "servo/components/style/values/specified/text.rs"], "git_node": null, "git_parents": [null], "node": "2f4dfabedb11fab1d04cd860df5afc3514b7ab55", "parents": ["686ecd397983995980b7d30309f1b2a8eb1e3e38"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1420811 - Rename bookmark tag to empty will cause issue. r=standard8\n\nMozReview-Commit-ID: HcgDlC2qlCM", "files": ["browser/components/places/content/editBookmarkOverlay.js", "browser/components/places/tests/browser/browser_bookmarkProperties_editTagContainer.js", "browser/components/places/tests/browser/head.js"], "git_node": null, "git_parents": [null], "node": "1024fb2fa343f1762c90b081649b4f0f944e9240", "parents": ["2f4dfabedb11fab1d04cd860df5afc3514b7ab55"], "tags": []}, {"author": "Igor Gutorov \u003cigootorov@gmail.com\u003e", "branch": "default", "desc": "servo: Merge #19749 - style: Move -moz-context-properties outside of mako (from gootorov:move_-moz-context-properties_from_mako); r=emilio\n\n\u003c!-- Please describe your changes on the following line: --\u003e\nSub-PR of #19015\n\n---\n\u003c!-- Thank you for contributing to Servo! Please replace each `[ ]` by `[X]` when the step is complete, and replace `__` with appropriate data: --\u003e\n- [X] `./mach build -d` does not report any errors\n- [X] `./mach test-tidy` does not report any errors\n- [X] These changes fix #19742  (github issue number if applicable).\n\n\u003c!-- Either: --\u003e\n- [ ] There are tests for these changes OR\n- [x] These changes do not require tests\n\n\u003c!-- Also, please make sure that \"Allow edits from maintainers\" checkbox is checked, so that we can help you if you get stuck somewhere along the way.--\u003e\n\n\u003c!-- Pull requests that do not address these steps are welcome, but they will require additional verification as part of the review process. --\u003e\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 2ff3e119faab0488ebd4d790600d07695404f883", "files": ["servo/components/style/properties/gecko.mako.rs", "servo/components/style/properties/longhand/inherited_svg.mako.rs", "servo/components/style/values/computed/mod.rs", "servo/components/style/values/computed/svg.rs", "servo/components/style/values/specified/mod.rs", "servo/components/style/values/specified/svg.rs"], "git_node": null, "git_parents": [null], "node": "84925d82bda391516e88a0f8f50de0e6e07b3616", "parents": ["1024fb2fa343f1762c90b081649b4f0f944e9240"], "tags": []}, {"author": "Csoregi Natalia \u003cncsoregi@mozilla.com\u003e", "branch": "default", "desc": "Backed out 5 changesets (bug 1418425) requested per comment #83. on a CLOSED TREE\n\nBacked out changeset 0ecc98bd0822 (bug 1418425)\nBacked out changeset 7b7725d1d3c3 (bug 1418425)\nBacked out changeset 2e95ebdcae6d (bug 1418425)\nBacked out changeset 47fbcaf5ad05 (bug 1418425)\nBacked out changeset 142001babb39 (bug 1418425)", "files": ["config/external/moz.build", "config/system-headers.mozbuild", "modules/libbz2/moz.build", "modules/libbz2/src/LICENSE", "modules/libbz2/src/blocksort.c", "modules/libbz2/src/bzlib.c", "modules/libbz2/src/bzlib.h", "modules/libbz2/src/bzlib_private.h", "modules/libbz2/src/compress.c", "modules/libbz2/src/crctable.c", "modules/libbz2/src/decompress.c", "modules/libbz2/src/huffman.c", "modules/libbz2/src/moz.build", "modules/libbz2/src/randtable.c", "modules/zlib/src/moz.build", "old-configure.in", "other-licenses/bsdiff/bsdiff.c", "other-licenses/bsdiff/moz.build", "toolkit/mozapps/update/updater/archivereader.cpp", "toolkit/mozapps/update/updater/crctable.h", "toolkit/mozapps/update/updater/moz.build", "toolkit/mozapps/update/updater/updater-common.build", "toolkit/mozapps/update/updater/updater-xpcshell/moz.build", "toolkit/mozapps/update/updater/updater.cpp", "toolkit/toolkit.mozbuild", "tools/rewriting/ThirdPartyPaths.txt"], "git_node": null, "git_parents": [null], "node": "492a154a477f9f38122a5214367a95b76c82b560", "parents": ["84925d82bda391516e88a0f8f50de0e6e07b3616"], "tags": []}, {"author": "steveck-chung \u003cschung@mozilla.com\u003e", "branch": "default", "desc": "Bug 1426652 - Allow the form with non-autocomplete-attr cc-number and cc-name as valid credit card form, r=lchang\n\nMozReview-Commit-ID: 8eqJUSYyPXr", "files": ["browser/extensions/formautofill/FormAutofillHandler.jsm", "browser/extensions/formautofill/test/unit/test_collectFormFields.js"], "git_node": null, "git_parents": [null], "node": "c6f4e32c749ba4150616c00da57c4e3b90f72be4", "parents": ["492a154a477f9f38122a5214367a95b76c82b560"], "tags": []}, {"author": "Alexandre Poirot \u003cpoirot.alex@gmail.com\u003e", "branch": "default", "desc": "Bug 1415545 - Land images related to performance documentation page in DevTools. r=sole\n\nMozReview-Commit-ID: Ferwx7gVx7F", "files": ["devtools/docs/contributing/performance/perfherder-results.png", "devtools/docs/contributing/performance/profiler-buffer-size.png", "devtools/docs/contributing/performance/profiler-chrome-url.png", "devtools/docs/contributing/performance/profiler-custom-markers.png", "devtools/docs/contributing/performance/profiler-filter-js.png", "devtools/docs/contributing/performance/profiler-filter-require.png", "devtools/docs/contributing/performance/profiler-main-thread.png", "devtools/docs/contributing/performance/profiler-netmon-open-fixed.png", "devtools/docs/contributing/performance/profiler-netmonitor-open.png", "devtools/docs/contributing/performance/profiler-resource-url.png"], "git_node": null, "git_parents": [null], "node": "717d16330a1ba34b2c8e412fa9efde46e0714773", "parents": ["c6f4e32c749ba4150616c00da57c4e3b90f72be4"], "tags": []}, {"author": "Ricky Chien \u003cricky060709@gmail.com\u003e", "branch": "default", "desc": "Bug 1430117 - Checking NS_BINDING_ABORTED to avoid dispatching navigate event r=ochameau\n\nMozReview-Commit-ID: hMLQS7Sfhg", "files": ["devtools/server/actors/tab.js"], "git_node": null, "git_parents": [null], "node": "27e396761ed3bfa9e00b5ec532e2a07ba791c086", "parents": ["717d16330a1ba34b2c8e412fa9efde46e0714773"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1409707 - [Wayland] - provide library shell, r=jhorak\n\nWe don't add build-time dependency on Wayland libraries; that allows Wayland enabled Firefox\nbuilds to run on systems without Wayland support.\n\nWe also can't dlsym() Wayland symbols directly from libwayland-client.so library as we miss\nglobal data entries referenced by code at wayland-client.h then.\n\nAs a partial solution (for glibc systems only) we create dummy libwayland-client.so library\nimplementation and place it *after* Gtk+ 3.0 libraries at linking time.\n\nIt fixes build-time dependencies (we link against our libwayland-client.so library).\nRun-time dependency is resolved by ld.so - when Gtk+ 3.0 libraries are linked with\nsystem libwayland-client.so library, wayland symbols are pulled from there instead\nfrom our dummy libwayland-client.so library.\n\nWhen Gtk+ 3.0 is not linked with system libwayland-client.so it means we're running\non system without Wayland support. Our dummy libwayland-client.so implementation\nis used (symbols are pulled run-time from there) and Firefox Wayland support is\ndisabled then.\n\nMozReview-Commit-ID: IyaePwp4MxV", "files": ["browser/installer/package-manifest.in", "toolkit/library/moz.build", "widget/gtk/moz.build", "widget/gtk/mozwayland/moz.build", "widget/gtk/mozwayland/mozwayland.c"], "git_node": null, "git_parents": [null], "node": "9865d21055082ef4290f470423c2c73fd793ab17", "parents": ["27e396761ed3bfa9e00b5ec532e2a07ba791c086"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1430237 - remove newSimpleNestedURI from nsINetUtil, r=mayhemer\n\nMozReview-Commit-ID: 74RsNo60Kfh", "files": ["netwerk/base/nsINetUtil.idl", "netwerk/base/nsIOService.cpp"], "git_node": null, "git_parents": [null], "node": "d282f520d2e3a72b61740fe0d4e01b8151eead54", "parents": ["9865d21055082ef4290f470423c2c73fd793ab17"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1405340 - Enable browser_webconsole_hpkp_onvalid-headers.js in new console frontend;r=Honza.\n\nMozReview-Commit-ID: 4bcZR2HrFOd", "files": ["devtools/client/webconsole/new-console-output/test/mochitest/browser.ini", "devtools/client/webconsole/new-console-output/test/mochitest/browser_webconsole_hpkp_invalid-headers.js"], "git_node": null, "git_parents": [null], "node": "cdae594745cdb4a77cae7bae4e662af3212f2a79", "parents": ["d282f520d2e3a72b61740fe0d4e01b8151eead54"], "tags": []}, {"author": "Nicolas Chevo