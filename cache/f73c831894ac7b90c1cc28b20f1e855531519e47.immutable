author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1430006: Allow configuring scriptworkers per-graph config; r=aki\n\nDifferential Revision: https://phabricator.services.mozilla.com/D379", "files": ["taskcluster/ci/config.yml", "taskcluster/docs/taskgraph.rst", "taskcluster/taskgraph/config.py", "taskcluster/taskgraph/transforms/checksums_signing.py", "taskcluster/taskgraph/transforms/repackage_signing.py", "taskcluster/taskgraph/transforms/signing.py", "taskcluster/taskgraph/util/scriptworker.py"], "git_node": null, "git_parents": [null], "node": "c5132727a5cfeafc6aeac6b10bb849c118838355", "parents": ["732a0fe9f2fb2be4fa05e7570273aeac8d2bbf44"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1430006: Move push-apk settings into the kind; r=aki,jlorenzo\n\nDifferential Revision: https://phabricator.services.mozilla.com/D383", "files": ["taskcluster/ci/push-apk-breakpoint/kind.yml", "taskcluster/ci/push-apk/kind.yml", "taskcluster/taskgraph/transforms/push_apk.py", "taskcluster/taskgraph/transforms/push_apk_breakpoint.py", "taskcluster/taskgraph/transforms/task.py", "taskcluster/taskgraph/util/scriptworker.py"], "git_node": null, "git_parents": [null], "node": "d9d1fb68d75d8e96dc3da6ca105c552a673db862", "parents": ["c5132727a5cfeafc6aeac6b10bb849c118838355"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1430006: Add separate function for calculating phases; r=aki\n\nDifferential Revision: https://phabricator.services.mozilla.com/D384", "files": ["taskcluster/taskgraph/util/scriptworker.py"], "git_node": null, "git_parents": [null], "node": "b699c46e0381e3af329994b68b8d5f7156b16ef5", "parents": ["d9d1fb68d75d8e96dc3da6ca105c552a673db862"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1430006: Allow specifying the scope prefix to be used for script workers; r=aki\n\nDifferential Revision: https://phabricator.services.mozilla.com/D382", "files": ["taskcluster/ci/config.yml", "taskcluster/taskgraph/config.py", "taskcluster/taskgraph/util/scriptworker.py"], "git_node": null, "git_parents": [null], "node": "4da679fb17f74d0425d468afb7749048b887057f", "parents": ["b699c46e0381e3af329994b68b8d5f7156b16ef5"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1430508: Return 0 for ProcessId() when channel IPC is closed. r=dragana\n\nThere are some corner cases where we try to attach StreamFilter endpoints to a\nchannel after its IPC has been closed from from the other side, but request\nlisteners haven't been notified. This causes crashes in any of several places.\n\nThis patch changes nsHttpChannel::ProcessId to return 0 when IPC is closed, so\ncallers can detect that it's no longer possible to attach endpoints to it.\n\nMozReview-Commit-ID: BZTOqezih0P", "files": ["netwerk/protocol/http/HttpChannelParent.cpp", "netwerk/protocol/http/HttpChannelParent.h", "toolkit/components/extensions/webrequest/StreamFilterParent.cpp"], "git_node": null, "git_parents": [null], "node": "06f766e7640a3cd180f7da7c092823e500a3d674", "parents": ["4da679fb17f74d0425d468afb7749048b887057f"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1321605 - Follow-up to dump Android bogomips in main test log; r=me, a=test-only\n\nWe use bogomips as a convenient indicator or emulator performance/health and\nmake that available in the android-performance.log artifact. When the task\ntimes out, that artifact is not uploaded, leaving me curious about what the\nbogomips were; let's dump it to the test log.", "files": ["testing/mozharness/scripts/android_emulator_unittest.py"], "git_node": null, "git_parents": [null], "node": "6c21b6d9183e099047239b8a2c48c1f1665cddf1", "parents": ["06f766e7640a3cd180f7da7c092823e500a3d674"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430668 - Increase chunks for linux32/debug jsreftest; r=me, a=test-only\n\nAttempt to avoid intermittent task timeouts in these tests.", "files": ["taskcluster/ci/test/reftest.yml"], "git_node": null, "git_parents": [null], "node": "7f28bf40bfb9c6f879bdac2b6571788c6c799b86", "parents": ["6c21b6d9183e099047239b8a2c48c1f1665cddf1"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Merge autoland to mozilla-central r=merge a=merge", "files": ["mobile/android/app/src/main/res/values-v13/search_styles.xml", "mobile/android/app/src/main/res/values-v16/search_styles.xml", "mobile/android/base/geckoview.ddf", "mobile/android/base/java/org/mozilla/gecko/db/PerProfileDatabaseProvider.java", "mobile/android/base/java/org/mozilla/gecko/home/HomeExpandableListView.java", "mobile/android/base/resources/values-v17/themes.xml", "mobile/android/build/classycle/LICENSE.txt", "mobile/android/build/classycle/classycle-1.4.1.jar"], "git_node": null, "git_parents": [null, null], "node": "fc1f453bb9538d292fd325f3ecea742aaa5edd60", "parents": ["8e33bdf820dcc2ecd6f326eb83c39fc5e4769dcf", "e3cd1efb911c0fb74e36640b5866300570749a6e"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Merge inbound to mozilla-central r=merge a=merge", "files": [], "git_node": null, "git_parents": [null, null], "node": "a3887394965f161d011eebc74e8987a653366e4b", "parents": ["fc1f453bb9538d292fd325f3ecea742aaa5edd60", "7f28bf40bfb9c6f879bdac2b6571788c6c799b86"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland r=merge", "files": [], "git_node": null, "git_parents": [null, null], "node": "68c68173378867d3a4b11c5a6bad6270a556d2de", "parents": ["ffe766bd6f33fe2104ad27879cd6b4d8a7a23c57", "a3887394965f161d011eebc74e8987a653366e4b"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1425541: Expose reader mode state on the browser accessible using a \"reader\" object attribute. r=eeejay,Gijs\n\nThis makes it easy for accessibility clients to retrieve the reader mode state programmatically.\n\nThere are three possibilities:\n1. Reader mode is available for the current page (reader:available).\n2. Reader mode is being used now (reader:active).\n3. Reader is not available (the reader attribute is not present).\n\nWe do this by setting/removing the aria-reader attribute on the node.\nThis is not a real ARIA attribute, but it causes Gecko to expose it as an object attribute.\n\nMozReview-Commit-ID: B38G3AYyBnS", "files": ["browser/modules/ReaderParent.jsm"], "git_node": null, "git_parents": [null], "node": "a6004a75d2d3e5fe04b4d9920cd2e90080784c59", "parents": ["68c68173378867d3a4b11c5a6bad6270a556d2de"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1430412 - fire 'a11y-init-or-shutdown' at the end of a11y service init and shutdown calls. r=surkov\n\nMozReview-Commit-ID: FlByhwvAlMt\n", "files": ["accessible/base/nsAccessibilityService.cpp"], "git_node": null, "git_parents": [null], "node": "5be045f0db762ad5214437fadc7b177df88708be", "parents": ["7f28bf40bfb9c6f879bdac2b6571788c6c799b86"], "tags": []}, {"author": "Paul Bone \u003cpbone@mozilla.com\u003e", "branch": "default", "desc": "Bug 1424760 (Part 1) - Fix an off-by-one error r=gfritzsche\n\nlimitProperties would reject payloads with the maximum number of properties,\nwhen it should accept these and only reject when they exceed the maximum.", "files": ["toolkit/components/telemetry/GCTelemetry.jsm"], "git_node": null, "git_parents": [null], "node": "aee5e05a7e0cee7c42e0f3d2a33d9499dcc7a837", "parents": ["5be045f0db762ad5214437fadc7b177df88708be"], "tags": []}, {"author": "Paul Bone \u003cpbone@mozilla.com\u003e", "branch": "default", "desc": "Bug 1424760 (Part 2) - Number each of the GC telemetry properties r=mgaudet\n\nBy numbering each of the properties we can easily check that we do not\nexceed the limit in GCTelemetry.jsm.  Note that this is not relevent for the\nnursery since it does not send telemetry.", "files": ["js/src/gc/Statistics.cpp"], "git_node": null, "git_parents": [null], "node": "e65bb33f2ae069c91f7e379d1b19e814934f5fb7", "parents": ["aee5e05a7e0cee7c42e0f3d2a33d9499dcc7a837"], "tags": []}, {"author": "Paul Bone \u003cpbone@mozilla.com\u003e", "branch": "default", "desc": "Bug 1424760 (Part 3) - Add a TelemetryGC unit test r=gfritzsche\n\ntoolkit/components/telemetry/tests/unit/test_TelemetryGC.js:\ntoolkit/components/telemetry/tests/unit/xpcshell.ini:\n    Add new unit test.\n\ntoolkit/components/telemetry/GCTelemetry.jsm:\n    Add an extra method to make testing easier.\n\njs/src/gc/Statistics.cpp:\n    Add a reference to the unit test for anyone modifying this code.", "files": ["js/src/gc/Statistics.cpp", "toolkit/components/telemetry/GCTelemetry.jsm", "toolkit/components/telemetry/tests/unit/test_TelemetryGC.js", "toolkit/components/telemetry/tests/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "b4ecd0f0fc8dd3b0d8f35515ca6acdb11c07d3af", "parents": ["e65bb33f2ae069c91f7e379d1b19e814934f5fb7"], "tags": []}, {"author": "Paul Bone \u003cpbone@mozilla.com\u003e", "branch": "default", "desc": "Bug 1424760 (Part 4) - Try to make GC telemetry pings more robust r=gfritzsche\n\n + Log limitProperties failures.\n + Don't remove all the properties from the main GC object, some are needed\n   later, just reduce it to the 7 necessary properties.", "files": ["toolkit/components/telemetry/GCTelemetry.jsm", "toolkit/components/telemetry/tests/unit/test_TelemetryGC.js"], "git_node": null, "git_parents": [null], "node": "1f1f863ea198cd04e1a90af2be6d953e0f5502ad", "parents": ["b4ecd0f0fc8dd3b0d8f35515ca6acdb11c07d3af"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "d