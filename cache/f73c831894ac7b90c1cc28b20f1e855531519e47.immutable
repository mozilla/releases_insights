ed here are already covered in\n- https://searchfox.org/mozilla-central/source/devtools/shared/webconsole/test/unit/test_js_property_provider.js\n- https://searchfox.org/mozilla-central/source/devtools/shared/webconsole/test/test_jsterm_autocomplete.html\n\nMozReview-Commit-ID: 1LY8mq5UvCA", "files": ["devtools/client/webconsole/new-console-output/test/mochitest/browser.ini", "devtools/client/webconsole/new-console-output/test/mochitest/browser_webconsole_property_provider.js", "devtools/client/webconsole/test/browser.ini", "devtools/client/webconsole/test/browser_webconsole_property_provider.js"], "git_node": null, "git_parents": [null], "node": "715ae6e13c973fefacf37fe9e2a6ba77a0c02e47", "parents": ["2ddc9ad2b919dffe71b7a71ef01eac2864d7c7b0"], "tags": []}, {"author": "Simon Sapin \u003csimon.sapin@exyr.org\u003e", "branch": "default", "desc": "servo: Merge #19751 - Clean up the selectors crate for a new crates.io release (from servo:selectors); r=bholley\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 6ca651c0c8271ce185448e1db95b893a276eaed9", "files": ["servo/Cargo.lock", "servo/components/malloc_size_of/Cargo.toml", "servo/components/malloc_size_of/lib.rs", "servo/components/selectors/Cargo.toml", "servo/components/selectors/gecko_like_types.rs", "servo/components/selectors/lib.rs", "servo/components/selectors/parser.rs", "servo/components/selectors/size_of_tests.rs", "servo/components/selectors/tree.rs", "servo/components/selectors/visitor.rs", "servo/components/servo_arc/Cargo.toml", "servo/components/servo_arc/lib.rs", "servo/components/style/gecko/selector_parser.rs", "servo/components/style/invalidation/element/invalidation_map.rs", "servo/components/style/servo/selector_parser.rs", "servo/components/style/stylist.rs", "servo/ports/geckolib/Cargo.toml", "servo/ports/geckolib/tests/Cargo.toml", "servo/ports/geckolib/tests/size_of.rs"], "git_node": null, "git_parents": [null], "node": "31e94d208ac2e25311ae41fa95f2d06bc93070e0", "parents": ["715ae6e13c973fefacf37fe9e2a6ba77a0c02e47"], "tags": []}, {"author": "Simon Sapin \u003csimon.sapin@exyr.org\u003e", "branch": "default", "desc": "No bug - Servo bustage fix for PR 19751 r=bustage-fix", "files": ["toolkit/library/gtest/rust/Cargo.lock", "toolkit/library/rust/Cargo.lock"], "git_node": null, "git_parents": [null], "node": "e6d6fbd9255063018cb80c1590e780f93723e02d", "parents": ["31e94d208ac2e25311ae41fa95f2d06bc93070e0"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1430011 - Build a Git package for Debian wheezy. r=gps\n\nThe one available in Debian wheezy is 1.7.10.4, which is really old, and\non our centos images, we're using 2.8.0rc3, which, while old too, is\nmore modern. While we may want to go with a more recent version, I'd\nrather avoid differing from what we currently use, so use the exact same\nversion.", "files": ["build/debian-packages/git-wheezy.diff", "taskcluster/ci/packages/kind.yml"], "git_node": null, "git_parents": [null], "node": "01cea78c89c3c9e0ed6ca4aeedfcc75991c0c039", "parents": ["e6d6fbd9255063018cb80c1590e780f93723e02d"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1430011 - Use the git package in the toolchain-build docker image. r=gps", "files": ["taskcluster/ci/docker-image/kind.yml"], "git_node": null, "git_parents": [null], "node": "bcff01abd362ff7130d82859dfc372a1a5daa864", "parents": ["01cea78c89c3c9e0ed6ca4aeedfcc75991c0c039"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1430057 - fix 'view selection source' in sidebar browsers, r=past\n\nMozReview-Commit-ID: JxZkI3WWNzX", "files": ["browser/base/content/nsContextMenu.js"], "git_node": null, "git_parents": [null], "node": "f0d01c3e1c809788f2898e36f2d6f05c1ad5b72f", "parents": ["bcff01abd362ff7130d82859dfc372a1a5daa864"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1429670 - Build docker images based on Debian wheezy to use instead of desktop-build. r=gps\n\nAt the same time, restrict the installed packages to the script\nrequirements to build Firefox. Toolchains have their own image so we\ndon't need to install packages for them.", "files": ["taskcluster/ci/docker-image/kind.yml", "taskcluster/docker/debian7-build/Dockerfile"], "git_node": null, "git_parents": [null], "node": "c51cdba4c57d0e6b1c22e826d425c3329374fa35", "parents": ["f0d01c3e1c809788f2898e36f2d6f05c1ad5b72f"], "tags": []}, {"author": "Michael Froman \u003cmfroman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1429085 - only initiate ice restart in PeerConnectionMedia if jsep create offer/answer succeeds. r=drno\n\nSeparate setting up the ice credentials for ice restart from the actual\nrestart call into PeerConnectionMedia.  This allows waiting until after\nthe call to JsepSessionImpl::CreateOffer or JsepSessionImpl::CreateAnswer\nsucceeds.\n\nMozReview-Commit-ID: Hex0lNstv0H", "files": ["media/webrtc/signaling/src/peerconnection/PeerConnectionImpl.cpp", "media/webrtc/signaling/src/peerconnection/PeerConnectionImpl.h"], "git_node": null, "git_parents": [null], "node": "29006b3597ccb3e279af3aa61045fb14a57d0e56", "parents": ["c51cdba4c57d0e6b1c22e826d425c3329374fa35"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1429959 - Make nsBindingManager::EnumerateBoundContentBindings yield each binding only once. r=emilio\n\nMozReview-Commit-ID: LxiF2RngJmq", "files": ["dom/xbl/nsBindingManager.cpp"], "git_node": null, "git_parents": [null], "node": "a16df11dae3fba36cb958b06917f35d9d0591f78", "parents": ["29006b3597ccb3e279af3aa61045fb14a57d0e56"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1429088: Only style children on non-lazy frame construction after we found an insertion point. r=bz\n\nServo tries to keep this invariant that stuff under a display: none element\nsubtree doesn't get styled.\n\nThis invariant isn't checked in StyleNewChildRange, but we can fix this by just\ndoing the work after finding an insertion point, which guarantees that.\n\nDo the same for listboxes, since we also style early for them without knowing\nwhether they actually have a listbox parent frame.\n\nMozReview-Commit-ID: Glyx24wQ6qY", "files": ["layout/base/nsCSSFrameConstructor.cpp"], "git_node": null, "git_parents": [null], "node": "7647a5900c99198390ee3c7e12dac4200caf87a5", "parents": ["a16df11dae3fba36cb958b06917f35d9d0591f78"], "tags": []}, {"author": "Honza Bambas \u003chonzab.moz@firemni.cz\u003e", "branch": "default", "desc": "Bug 1386644 - Enable test for bug 1053321 on Android, r=bkelly", "files": ["dom/tests/mochitest/script/file_blocked_script.sjs", "dom/tests/mochitest/script/mochitest.ini", "dom/tests/mochitest/script/test_bug1053321.html"], "git_node": null, "git_parents": [null], "node": "7fba47d2119beacfa6484afef20d1da5cc349f71", "parents": ["792b172327f28a7d90aa51c38c26dff23cc06032"], "tags": []}, {"author": "Honza Bambas \u003chonzab.moz@firemni.cz\u003e", "branch": "default", "desc": "Bug 1391277 - Investigative logging in CSP: log when 'upgrade-insecure-requests' CSP is added to the CSP context, r=bz", "files": ["dom/html/HTMLMediaElement.cpp", "dom/html/HTMLMetaElement.cpp", "dom/security/nsCSPContext.cpp"], "git_node": null, "git_parents": [null], "node": "8e08a2cf1b2d3e509d971d52e65377fd6290e3f5", "parents": ["7fba47d2119beacfa6484afef20d1da5cc349f71"], "tags": []}, {"author": "Aditya Bharti \u003cadibhar97@gmail.com\u003e", "branch": "default", "desc": "bug 1428885 - Allow C++ to accumulate multiple samples into a keyed histogram in one call r=chutten\n\nExtended the Telemetry::Accumulate API to take a Histogram ID, string key, and a nsTArray\u003cuint32_t\u003e of samples.\nTest cases check for linear, count and histograms with a set of allowed keys. Made changes to fix try failures.", "files": ["toolkit/components/telemetry/Telemetry.cpp", "toolkit/components/telemetry/Telemetry.h", "toolkit/components/telemetry/TelemetryHistogram.cpp", "toolkit/components/telemetry/TelemetryHistogram.h", "toolkit/components/telemetry/tests/gtest/TestHistograms.cpp"], "git_node": null, "git_parents": [null], "node": "5590c751f6d814d8bf0b4fefa69fdf46182a63ed", "parents": ["8e08a2cf1b2d3e509d971d52e65377fd6290e3f5"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1413505: Apply TimeClip in Intl.DateTimeFormat format methods. r=gandalf", "files": ["js/src/builtin/Intl.cpp"], "git_node": null, "git_parents": [null], "node": "071076af815da074a65c6f8a09ffc02a6a67fa95", "parents": ["5590c751f6d814d8bf0b4fefa69fdf46182a63ed"], "tags": []}, {"author": "fernando \u003cmortificador@gmail.com\u003e", "branch": "default", "desc": "Bug 1278821 - Re-factor JS-exposed functions in TelemetryHistogram.cpp to avoid deadlocks. r=Dexter", "files": ["toolkit/components/telemetry/TelemetryHistogram.cpp"], "git_node": null, "git_parents": [null], "node": "b8ded26d5d1960d2cb3cf8e46409643d811ba333", "parents": ["071076af815da074a65c6f8a09ffc02a6a67fa95"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1430164.  Stop doing weird sandbox-callable-wrapping for DOM constructors. r=bholley\n\nThis fixes DOM constructor identity in web extension content scripts to work as expected.\n\nMozReview-Commit-ID: Ab4sFWiMU6c", "files": ["dom/bindings/BindingUtils.h", "js/xpconnect/src/Sandbox.cpp", "js/xpconnect/tests/chrome/chrome.ini", "js/xpconnect/tests/chrome/test_bug1430164.html"], "git_node": null, "git_parents": [null], "node": "8be5c5375a9010dbf91d415ccf5950a3c7c1a2c0", "parents": ["b8ded26d5d1960d2cb3cf8e46409643d811ba333"], "tags": []}, {"author": "Dragana Damjanovic dd.mozilla@gmail.com", "branch": "default", "desc": "B