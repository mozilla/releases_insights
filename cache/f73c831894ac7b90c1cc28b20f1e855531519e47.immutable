ents": [null], "node": "29e04068d1e19a41b39081e50f6cee7aed20ded3", "parents": ["6ec40d01788c1c5d54d935c8649162e596b16d79"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nbg -\u003e 368340d5a88b\ncak -\u003e f7ffa9561706\nhsb -\u003e a0c94e37d6fc\nhu -\u003e e53b1f8fa2d2\nid -\u003e e262241dbbe0\nit -\u003e f9f416f3e87a\nka -\u003e d41b0772ae83\nkab -\u003e 266965b87757\nmai -\u003e c374a373759f\nms -\u003e a2d68e616384\nnl -\u003e 49fba684aaf2\nnn-NO -\u003e f2d94109322a\npt-BR -\u003e 3e3a5f7b83e9\nro -\u003e c90e6f56e8c0\nsi -\u003e 203728a69db3\nsl -\u003e 7053976692d4\nsv-SE -\u003e 5e4a99bb7a40\nte -\u003e d49a995d4147\ntr -\u003e d5ae3b80f63c\nur -\u003e 7581ffb895da\nzh-CN -\u003e 31a8239797d7", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "5c61d722e116b54a6a6e3a61ffc47839d2ef9d2e", "parents": ["29e04068d1e19a41b39081e50f6cee7aed20ded3"], "tags": []}], "date": 1519262398, "git_changesets": [null, null], "user": "ffxbld"}, "8748": {"changesets": [{"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1408636 - Ensure accessibility tests pass regardless of image caching affecting whitespace. r=yzen, a=test-only", "files": ["accessible/tests/mochitest/elm/test_HTMLSpec.html", "accessible/tests/mochitest/name/markuprules.xml", "accessible/tests/mochitest/tree/test_txtcntr.html", "accessible/tests/mochitest/treeupdate/test_whitespace.html"], "git_node": null, "git_parents": [null], "node": "a377dbc4074c8e48c133b2c322db19ec00a71dbe", "parents": ["5c61d722e116b54a6a6e3a61ffc47839d2ef9d2e"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1375637 - Make test_async_script_timeout less likely to fail. r=automatedtester, a=test-only\n\nBy increasing the duration before setTimeout fires the callback and\nthe execute_async_script call returns control to the user we are\nless likely that there is a race condition between the relatively\nshort 100 ms interruption time.\n\nMozReview-Commit-ID: BVKRiU7a2gK", "files": ["testing/marionette/harness/marionette_harness/tests/unit/test_execute_script.py"], "git_node": null, "git_parents": [null], "node": "8306ccb1dd271181c80e9eba2129e4d563f5f204", "parents": ["a377dbc4074c8e48c133b2c322db19ec00a71dbe"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Bug 1429361 - Disabled devtools/client/webconsole/new-console-output/test/mochitest/browser_webconsole_network_messages_expand.js for frequent failures. r=jmaher, a=test-only", "files": ["devtools/client/webconsole/new-console-output/test/mochitest/browser.ini"], "git_node": null, "git_parents": [null], "node": "3e0c6008d60d98257ffcf492fc3f0a29a12c0a4f", "parents": ["8306ccb1dd271181c80e9eba2129e4d563f5f204"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1432246 - Update some safe-browsing prefs for reftests. r=jmaher, a=test-only", "files": ["layout/tools/reftest/reftest-preferences.js"], "git_node": null, "git_parents": [null], "node": "c5f9d088afab26fea12df78d91d02807919d58a6", "parents": ["3e0c6008d60d98257ffcf492fc3f0a29a12c0a4f"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1433485 - Update test prefs for telemetry. r=mythmon, r=dexter, a=test-only\n\nSet pref datareporting.healthreport.uploadEnabled=false during mochitests\nand set pref toolkit.telemetry.server to a dummy server during reftests\n(uploadEnabled was already false for reftest and the telemetry server was\nalready set for mochitests - now these prefs are consistent).\n\nSome mochitests failed with this change; they are updated to\nset datareporting.healthreport.uploadEnabled where required.", "files": ["browser/extensions/shield-recipe-client/test/browser/browser_RecipeRunner.js", "layout/tools/reftest/reftest-preferences.js", "testing/profiles/prefs_general.js"], "git_node": null, "git_parents": [null], "node": "4c672d9530bf8a488ac28e4cf137a067de4e6bb6", "parents": ["c5f9d088afab26fea12df78d91d02807919d58a6"], "tags": []}, {"author": "Eugen Sawin \u003cesawin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1434210 - [1.1] Expose text selection trimming as a utility function. r=mconley, a=lizzard", "files": ["toolkit/modules/BrowserUtils.jsm"], "git_node": null, "git_parents": [null], "node": "4442114ced5703d0d322f3e6db9de51f1a6a02ab", "parents": ["4c672d9530bf8a488ac28e4cf137a067de4e6bb6"], "tags": []}, {"author": "Eugen Sawin \u003cesawin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1434210 - [2.0] Trim selection text for search. r=snorp, a=lizzard", "files": ["mobile/android/modules/ActionBarHandler.jsm"], "git_node": null, "git_parents": [null], "node": "7a29ddefeab9bf4ad5d798a60b17957ea6cee7d3", "parents": ["4442114ced5703d0d322f3e6db9de51f1a6a02ab"], "tags": []}, {"author": "Francois Marier \u003cfrancois@mozilla.com\u003e", "branch": "default", "desc": "Bug 1433636 - Put a limit on the length of Safe Browsing metadata values. r=gcp, a=lizzard\n\nDisk corruption can lead to the stored length of a value to be\nunreasonably large and trigger an OOM.\n\nSince values are all currently \u003c= 32 bytes, we can safely enforce\na 256-byte upper bound.\n\nMozReview-Commit-ID: XygReOpEK3", "files": ["toolkit/components/telemetry/Histograms.json", "toolkit/components/url-classifier/LookupCache.cpp", "toolkit/components/url-classifier/LookupCacheV4.cpp", "toolkit/components/url-classifier/LookupCacheV4.h"], "git_node": null, "git_parents": [null], "node": "45c1f99b1b86dcdb6a7c1d28724749f2f0b79163", "parents": ["7a29ddefeab9bf4ad5d798a60b17957ea6cee7d3"], "tags": []}, {"author": "David Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "Bug 1439732 - Back