ts": [null], "node": "a87567bd0018a01cdb5d33090979a31f078f3640", "parents": ["03a6d763743dc2d4670457488bbe061960ddc9d9"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1429778 - Part 3: Update test262 exclusion list. r=sfink", "files": ["js/src/tests/jstests.list"], "git_node": null, "git_parents": [null], "node": "b9440c1e1d17bb888269c49b54bd9194c629b131", "parents": ["a87567bd0018a01cdb5d33090979a31f078f3640"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1429778 - Part 4: Enable more tests which are now passing. r=sfink", "files": ["js/src/tests/jstests.list"], "git_node": null, "git_parents": [null], "node": "5d64b00f5795af39f9cd9bbdcda47c89d3d80b0f", "parents": ["b9440c1e1d17bb888269c49b54bd9194c629b131"], "tags": []}, {"author": "Tiberius Oros \u003ctoros@mozilla.com\u003e", "branch": "default", "desc": "Backed out 1 changesets (bug 1429510)for build bustage on CLOSED TREE\n\nBacked out changeset 809a14e1c12b (bug 1429510)", "files": ["toolkit/components/telemetry/Scalars.yaml", "toolkit/components/telemetry/Telemetry.cpp", "toolkit/components/telemetry/tests/unit/test_TelemetrySession.js"], "git_node": null, "git_parents": [null], "node": "db7225f74e1f33a86616795aa0bdd110a8de9f8b", "parents": ["5d64b00f5795af39f9cd9bbdcda47c89d3d80b0f"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1430087 - Build sccache with system GCC/binutils. r=nfroyd\n\nIt was failing to build with the GCC/binutils on the CentOS-based docker\nimage, but it doesn't with the Debian-based one, so we can remove the\ndependency on the gcc toolchain task. This allows sccache to remain\nuntouched when we change the gcc build scripts, and more importantly,\nthis allows it to depend on no toolchain that requires building things.\n\nThis makes it now possible to use sccache as a dependency for all other\ntoolchains jobs that compile, if that's beneficial (which might not be\nthe case, given the current sccache retention time, but at least it's a\nviable option, now)\n", "files": ["taskcluster/ci/toolchain/linux.yml", "taskcluster/scripts/misc/build-sccache.sh"], "git_node": null, "git_parents": [null], "node": "fd14af0fbb8f13ab09e23423b4d6134fbf909855", "parents": ["db7225f74e1f33a86616795aa0bdd110a8de9f8b"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430176 - Do not try to force-stop native android processes like xpcshell; r=jmaher", "files": ["testing/mozbase/mozdevice/mozdevice/devicemanager.py", "testing/mozbase/mozdevice/mozdevice/devicemanagerADB.py", "testing/xpcshell/remotexpcshelltests.py"], "git_node": null, "git_parents": [null], "node": "4ed959e7652263aa2a57d582aed2460b4bdaab7c", "parents": ["fd14af0fbb8f13ab09e23423b4d6134fbf909855"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1425440 - Get rid of GetChildAt_Deprecated in nsCSSRuleProcessor, r=catalinb", "files": ["layout/style/nsCSSRuleProcessor.cpp"], "git_node": null, "git_parents": [null], "node": "0fa20efa446906e82545076eb72c66a18ae1ed43", "parents": ["4ed959e7652263aa2a57d582aed2460b4bdaab7c"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1429567: Add more detailed add-on info to sandbox names. r=zombie\n\nMozReview-Commit-ID: DMs8dd49j03", "files": ["toolkit/components/extensions/ExtensionContent.jsm", "toolkit/components/extensions/ProxyScriptContext.jsm", "toolkit/components/extensions/extension-process-script.js"], "git_node": null, "git_parents": [null], "node": "4806f68141637e47411ad6d202b6ce9b8cd4d910", "parents": ["0fa20efa446906e82545076eb72c66a18ae1ed43"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1429898: Add active extension details to profiler metadata. r=mstange\n\nMozReview-Commit-ID: CR64i73B4ys", "files": ["tools/profiler/core/platform.cpp"], "git_node": null, "git_parents": [null], "node": "b2498157399c438a401b54aee1e0b297a7a59ff9", "parents": ["4806f68141637e47411ad6d202b6ce9b8cd4d910"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1412726: Clean up XPCOM singleton constructor refcount handling. r=froydnj\n\nThis is a follow-up to bug 1409249. There are a lot of places where our\nfactory singleton constructors either don't correctly handle their returned\nreferences being released by the component manager, or do handle it, but in\nways that are not obvious.\n\nThis patch handles a few places where we can sometimes wind up with dangling\nsingleton pointers, adds some explanatory comments and sanity check\nassertions, and replaces some uses of manual refcounting with StaticRefPtr and\nClearOnShutdown.\n\nThere are still some places where we may wind up with odd behavior if the\nfirst QI for a getService call fails. In those cases, we wind up destroying\nthe first instance of a service that we create, and re-creating a new one\nlater.\n\nMozReview-Commit-ID: ANYndvd7aZx", "files": ["dom/media/webspeech/synth/nsSynthVoiceRegistry.cpp", "dom/media/webspeech/synth/nsSynthVoiceRegistry.h", "dom/media/webspeech/synth/speechd/SpeechDispatcherModule.cpp", "dom/media/webspeech/synth/speechd/SpeechDispatcherService.cpp", "dom/media/webspeech/synth/speechd/SpeechDispatcherService.h", "dom/plugins/base/nsPluginHost.cpp", "dom/plugins/base/nsPluginHost.h", "dom/workers/WorkerDebuggerManager.cpp", "extensions/cookie/nsPermissionManager.cpp", "js/xpconnect/src/nsXPConnect.cpp", "layout/build/nsLayoutStatics.cpp", "modules/libjar/nsJARChannel.cpp", "modules/libjar/nsJARChannel.h", "modules/libjar/nsJARFactory.cpp", "modules/libjar/nsJARProtocolHandler.cpp", "modules/libjar/nsJARProtocolHandler.h", "netwerk/base/nsIOService.cpp"