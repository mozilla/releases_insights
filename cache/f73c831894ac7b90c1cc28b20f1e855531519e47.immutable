: null, "git_parents": [null], "node": "0137e00cf2216b863c93fbabf3bae13985ef9b84", "parents": ["5a7a7bc878bcf5424c36ae080789473e51351a74"], "tags": []}, {"author": "Bob Clary \u003cbclary@bclary.com\u003e", "branch": "default", "desc": "Bug 1429375 - [mozbase] Do not use deprecated sys.exc_value in mozhttpd, r=gbrown", "files": ["testing/mozbase/mozhttpd/mozhttpd/mozhttpd.py"], "git_node": null, "git_parents": [null], "node": "4338e5f32b4cf4f3503be8963689b17a99a515e7", "parents": ["0137e00cf2216b863c93fbabf3bae13985ef9b84"], "tags": []}, {"author": "Julien Wajsberg \u003cfelash@gmail.com\u003e", "branch": "default", "desc": "Bug 1429096 - Bump the minimal mercurial version to be considered modern r=gps\n\nThis version needs to stay synchronized with version-control-tools.\n\nMozReview-Commit-ID: BN4h9XOntjD", "files": ["python/mozboot/mozboot/base.py"], "git_node": null, "git_parents": [null], "node": "fbdb20f2a216a9ebbdcb792a2d7d75519486c4cc", "parents": ["07ecfcac4bbb6b1a612ef23831ecbb4736fc92aa"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1430504 - Build a GNU make package for Debian wheezy. r=gps\n\nThe one available in Debian wheezy is 3.81, but we're explicitly using\n4.0 on CentOS, most notably because of its --output-sync option which\nhelps make logs better in some ways.\n\nThis takes the package from Debian jessie and builds it for Debian\nwheezy.", "files": ["build/debian-packages/make-wheezy.diff", "taskcluster/ci/packages/kind.yml"], "git_node": null, "git_parents": [null], "node": "dcff8a1c035bef50f1a92868da58e5138996d9d6", "parents": ["fbdb20f2a216a9ebbdcb792a2d7d75519486c4cc"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1430504 - Use the GNU make package in the Debian wheezy-based docker images. r=gps", "files": ["taskcluster/ci/docker-image/kind.yml"], "git_node": null, "git_parents": [null], "node": "1d8507d97baacd9f3a042b6a08ae2db9daca767e", "parents": ["dcff8a1c035bef50f1a92868da58e5138996d9d6"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1430622: Don't allow fallback alignment in place-content shorthand. r=xidorn,mats\n\nMozReview-Commit-ID: sALBFJeqvr\n", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/meta/css/css-align/content-distribution/place-content-shorthand-002.html.ini", "testing/web-platform/meta/css/css-align/content-distribution/place-content-shorthand-004.html.ini", "testing/web-platform/meta/css/css-align/content-distribution/place-content-shorthand-006.html.ini", "testing/web-platform/tests/css/css-align/content-distribution/place-content-shorthand-007-ref.html", "testing/web-platform/tests/css/css-align/content-distribution/place-content-shorthand-007.html"], "git_node": null, "git_parents": [null], "node": "2ea467872d7fcd3dbb31fcf881e4147b6dd6bebe", "parents": ["1d8507d97baacd9f3a042b6a08ae2db9daca767e"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1430850 - Part 1: Move mThreadId from ThreadInfo to RacyThreadInfo, r=mstange\n\nMozReview-Commit-ID: LE6j8Fm38PK\n", "files": ["tools/profiler/core/ThreadInfo.cpp", "tools/profiler/core/ThreadInfo.h"], "git_node": null, "git_parents": [null], "node": "b22667aec75a440032b21141698220f7f490b9ca", "parents": ["4338e5f32b4cf4f3503be8963689b17a99a515e7"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1430850 - Part 2: Change ProfilerMarker to use an internal ThreadId property, rather than the ThreadId entry, r=mstange\n\nMozReview-Commit-ID: J8Ckvmj4En0\n", "files": ["tools/profiler/core/ProfileBufferEntry.cpp", "tools/profiler/core/ProfilerMarker.h", "tools/profiler/core/ThreadInfo.h"], "git_node": null, "git_parents": [null], "node": "f9628da12e3fe18e911d42190706b1b462dc66c2", "parents": ["b22667aec75a440032b21141698220f7f490b9ca"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1430850 - Part 3: Expose profiler_add_marker_for_thread to add a marker for a specific thread, r=mstange\n\nMozReview-Commit-ID: 2nyp98oBKHk\n", "files": ["tools/profiler/core/platform.cpp", "tools/profiler/public/GeckoProfiler.h"], "git_node": null, "git_parents": [null], "node": "ee21d20f68dd712307f0231c4d14a20aa4513a07", "parents": ["f9628da12e3fe18e911d42190706b1b462dc66c2"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1430850 - Part 4: Rework BHR's profiler marker to use add_marker_for_thread, r=mstange\n\nMozReview-Commit-ID: BivFEJD2KCY\n", "files": ["toolkit/components/backgroundhangmonitor/BackgroundHangMonitor.cpp", "toolkit/components/backgroundhangmonitor/HangDetails.cpp", "toolkit/components/backgroundhangmonitor/HangDetails.h", "toolkit/components/backgroundhangmonitor/ThreadStackHelper.h"], "git_node": null, "git_parents": [null], "node": "8f09976eaa7a12898411343811c85b3903fd16fc", "parents": ["ee21d20f68dd712307f0231c4d14a20aa4513a07"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1424766 - Simplify `HangStack` and `HangDetails` by implementing using ipdl structs and unions, r=froydnj\n\nMozReview-Commit-ID: qlBUnvYams\n", "files": ["dom/ipc/ContentChild.cpp", "dom/ipc/ContentParent.cpp", "dom/ipc/PContent.ipdl", "gfx/ipc/GPUChild.cpp", "gfx/ipc/GPUParent.cpp", "gfx/ipc/PGPU.ipdl", "toolkit/components/backgroundhangmonitor/BackgroundHangMonitor.cpp", "toolkit/components/backgroundhangmonitor/HangDetails.cpp", "toolkit/components/backgroundhangmonitor/HangDetails.h", "toolkit/components/backgroundhangmonitor/HangStack.cpp", "toolkit/components/backgroundhangmonitor/HangStack.h", "toolkit/components/backgroundhangmonitor/HangTypes.ipdlh", "toolkit/components/backgroundhangmonitor/ThreadStackHelper.cpp", "toolkit/components/backgroundhangmonitor/ThreadStackHelper.h", "toolkit/components/backgroundhangmonitor/moz.build"], "git_node": null, "git_parents": [null], "node": "19c0ea91ed2b54c8d1a5f1a0b31e2d69054f71d7", "parents": ["8f09976eaa7a12898411343811c85b3903fd16fc"], "tags": []}, {"author": "Jason Laster \u003cjason.laster.11@gmail.com\u003e", "branch": "default", "desc": "Bug 1429908 - Update Debugger Frontend v9.0. r=jdescottes\n\nMozReview-Commit-ID: 29R66GxBFmY", "files": ["devtools/client/debugger/new/README.mozilla", "devtools/client/debugger/new/debugger.css", "devtools/client/debugger/new/debugger.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-sourcemaps-reloading.js", "devtools/client/locales/en-US/debugger.properties"], "git_node": null, "git_parents": [null], "node": "6132ddd09b0183a27631e511210f82ddc7fe9b2e", "parents": ["19c0ea91ed2b54c8d1a5f1a0b31e2d69054f71d7"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1429014.  Make test_interfaces require explicit opt-in to add a non-SecureContext interface.  r=bkelly\n\nThe big data tables had the following search-and-replaces done on them:\n\n  name: \"\\([^\"]+\\)\" -\u003e name: \"\\1\", insecureContext: true\n\n  \"\\([^\"]+\\)\",$ -\u003e {name: \"\\1\", insecureContext: true},\n\nfollowed by removal of both isSecureContext and insecureContext annotations\nwhere both appeared.\n\nMozReview-Commit-ID: BkqAwXFf48x", "files": ["dom/tests/mochitest/general/test_interfaces.js", "dom/workers/test/test_worker_interfaces.js"], "git_node": null, "git_parents": [null], "node": "fd6dca879e6a5f2a3cf1b9be4e9e992176193dd0", "parents": ["6132ddd09b0183a27631e511210f82ddc7fe9b2e"], "tags": []}, {"author": "Margareta Eliza Balazs \u003cebalazs@mozilla.com\u003e", "branch": "default", "desc": "Backed out 3 changesets (bug 1426386) for R2 failing in /layout/reftests/position-sticky/transformed-2.html on Windows on a CLOSED TREE\n\nBacked out changeset 4416e585cf77 (bug 1426386)\nBacked out changeset 1e675415a7a0 (bug 1426386)\nBacked out changeset 5402e62aaa71 (bug 1426386)", "files": ["gfx/layers/wr/StackingContextHelper.cpp", "gfx/layers/wr/StackingContextHelper.h", "layout/painting/nsDisplayList.cpp", "layout/painting/nsDisplayList.h", "layout/reftests/bugs/reftest.list", "layout/reftests/position-sticky/reftest.list", "layout/reftests/position-sticky/transformed-1-ref.html", "layout/reftests/position-sticky/transformed-1.html", "layout/reftests/position-sticky/transformed-2-ref.html", "layout/reftests/position-sticky/transformed-2.html"], "git_node": null, "git_parents": [null], "node": "929bf53b16fb1e01acdcdfcb740ee4ce73eb2fda", "parents": ["2ea467872d7fcd3dbb31fcf881e4147b6dd6bebe"], "tags": []}, {"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430292 - Warm up the tab that we'd switch to when hovering a tab's close icon. r=dao\n\nMozReview-Commit-ID: 28YhAxI5loV", "files": ["browser/base/content/tabbrowser.xml"], "git_node": null, "git_parents": [null], "node": "916232f502fe334c45b3806dc1da41adbc4b22c6", "parents": ["929bf53b16fb1e01acdcdfcb740ee4ce73eb2fda"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430417 - Do not include LeakCanary in automation builds. r=jchen\n\nThis got mixed up by Bug 1411654, which migrated to Android-Gradle\n3.0+.  However, it's also much easier to fix due to the changes in the\nnew version!  This patch uses the new audience flavor dimension to\ncontrol the version of LeakCanary included.\n\nNote that this turns off LeakCanary for builds produced by |mach\nbuild|, because |mach build| always builds the official audience\nflavor dimension.  We could use MOZILLA_OFFICIAL to differentiate, but\nit's not worth it: local developers who care about LeakCanary\nwill/should be running a local audience flavor dimension from Android\nStudio.\n\nMozReview-Commit-ID: ASgxhNOMsWc", "files": ["mobile/android/app/build.gradle"], "git_node": null, "git_parents": [null], "node": "f5c4825b6ae87e476cfcc40f3d038de970f4007f", "parents": ["916232f502fe334c45b3806dc1da41adbc4b22c6"], "tags": []}, {"author": "Julien Wajsberg \u003cfelash@gmail.com\u003e", "branch": "default", "desc": "Bug 1429094 - Define the environment variable HGRCPATH to ignore any .hgrc that may exist r=gps\n\nBy ignoring existing .hgrc we make sure we don't try to load extensions\nand have a consistent output. Especially we won't have error messages\nthat could confuse us into extracting a wrong version number.\n\nMozReview-Commit-ID: FwrfcbY8QpN", "files": ["python/mozboot/mozboot/base.py"], "git_node": null, "git_parents": [null], "node": "195e88aab631329b58a8e6a8d0e7cf26aba2dafb", "parents": ["f5c4825b6ae87e476cfcc40f3d038de970f4007f"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430797 - Allow webrender on eWindowType_child, so that it is used on OS X. r=nical\n\nMozReview-Commit-ID: Gir5QWoal8d", "files": ["widget/nsBaseWidget.cpp"], "git_node": null, "git_parents": [null], "node": "fe6f236e1fb51c18210ed992f53c2246669504b5", "parents": ["195e88aab631329b58a8e6a8d0e7cf26aba2dafb"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1420818 - For rendering to titlebar make CSD window decorations mode default, enable WM decorations on Elementary OS, r=jhorak\n\nMozReview-Commit-ID: FhF53Z34JS6", "files": ["widget/gtk/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "8dee5d879ef151920948af9cf56a4845957f2081", "parents": ["fe6f236e1fb51c18210ed992f53c2246669504b5"], "tags": []}, {"author": "Ralph Giles \u003cgiles@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430188: av1: Mark AOM_QM matricies const. r=kinetik.\n\nThese large (200 KB) static stables are functionally read-only.\nMarking them const moves them to the read-only section of shared\nlibraries, reducing memory footprint when multiple application\nprocesses are running simultaneously.\n\nThis is a backport of the upstream commit 90243cf9e670.\n\nMozReview-Commit-ID: 319jjpgNlTI", "files": ["third_party/aom/av1/common/onyxc_int.h", "third_party/aom/av1/common/quant_common.c", "third_party/aom/av1/common/quant_common.h"], "git_node": null, "git_parents": [null], "node": "d88cb52f392d66eb3b323a9d4ad4d452c7fd275d", "parents": ["8dee5d879ef151920948af9cf56a4845957f2081"], "tags": []}, {"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1413089 - Fix intermittent browser_ext_themes_dynamic_getCurrent.js. r=mixedpuppy\n\nMozReview-Commit-ID: MylrmgEfz9", "files": ["toolkit/components/extensions/test/browser/browser_ext_themes_dynamic_getCurrent.js"], "git_node": null, "git_parents": [null], "node": "b5c0f99c9a351ca4ce1700256495398b2089df9f", "parents": ["d88cb52f392d66eb3b323a9d4ad4d452c7fd275d"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430313 - Don't take brand.dtd from object directory. r=mshal\n\nThis thorn in my side turns out to be unnecessary!  For reasons\nunknown, brand.dtd is not localized for mobile/android/ in the way it\nis for browser/.  That means we can just pull from the branding\ndirectory, which avoids a frustrating issue where single-locale\nrepacks couldn't actually produce strings.xml since the subtle\ndependency on the branding directory being built first wasn't\nsatisfied.\n\nMozReview-Commit-ID: CBBaxfj5lMW", "files": ["mobile/android/base/locales/Makefile.in"], "git_node": null, "git_parents": [null], "node": "a1a5efa349c4a213049e2b8fcf4e4a77acb8e1ba", "parents": ["b5c0f99c9a351ca4ce1700256495398b2089df9f"], "tags": []}, {"author": "David Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "bug 1263765 - remove nsIBadCertListener2 implementation from the add certificate exception dialog r=jcj\n\nThis reworks the certificate-fetching portion of the add certificate exception\ndialog so as to not require a nsIBadCertListener2 implementation, which is\ndeprecated. The solution is simple: use the onerror/onload callbacks on the\nXMLHttpRequest object to grab the appropriate information.\n\nMozReview-Commit-ID: IjNrNfYA28P", "files": ["security/manager/pki/resources/content/exceptionDialog.js"], "git_node": null, "git_parents": [null], "node": "d5dd45fa551c84f7e978f0cc862747242cee8297", "parents": ["a1a5efa349c4a213049e2b8fcf4e4a77acb8e1ba"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1419581 - Pre: Add missing excludes when building without MOZ_NATIVE_DEVICES. r=nalexander\n\nMozReview-Commit-ID: BXNFBEs2017", "files": ["mobile/android/app/build.gradle"], "git_node": null, "git_parents": [null], "node": "45b5309a73cbde68fab5b75168bbeaba076ff238", "parents": ["d5dd45fa551c84f7e978f0cc862747242cee8297"], "tags": []}, {"author": "Tad \u003ctad@spotco.us\u003e", "branch": "default", "desc": "Bug 1419581 - Part 1: Simplify MMA GCM sender IDs logic. r=nechen\n\nRight now, the MMA glue is built into constants.jar.  constants.jar is\nthe home of preprocessed Java code; it's built very early in the build\nprocess and intended to be a tiny kernel of shared definitions.  The\nfact that the MMA glue has to live there is just a sad consequence of\nthe non-Gradle build system, which makes dependency injection\ndifficult.  Unfortunately, another consequence is that it's not\npossible to move reference org.mozilla.gecko.{gcm,push} in the MMA\nglue, because those packages are built after constants.jar.\n\nInstead, this patch lifts some of the logic into AppConstants, which\nis part of constants.jar.  We had grown a twisty maze of indirection\naround the GCM sender IDs and it just wasn't necessary; this just\nlifts the static pieces up a level and removes a bunch of interface\nindirection.\n\nWhat surprises me is that asking Google's InstanceId.getToken for a\nGCM token with a \"comma,separated,list\" of GCM sender IDs works -- and\nindeed, has worked since we added the second MMA sender ID.  I didn't\nexpect that and can't explain it, but this doesn't change that logic\nand local testing (both of the existing APKs, and APKs with this\nmodification) looks good.\n\n\nMozReview-Commit-ID: 3hObfAwNlPH\n***\na0c07e53 o draft Bug 1419581 - Part 1: Move MMA setGcmSenderID from MmaDelegate to MmaLeanplumImp. r=nechen\n\nMozReview-Commit-ID: A4hrk6pVqGW", "files": ["mobile/android/app/src/test/java/org/mozilla/gecko/push/TestPushManager.java", "mobile/android/base/AppConstants.java.in", "mobile/android/base/java/org/mozilla/gecko/mma/MmaDelegate.java", "mobile/android/base/java/org/mozilla/gecko/mma/MmaInterface.java", "mobile/android/base/java/org/mozilla/gecko/mma/MmaLeanplumImp.java", "mobile/android/base/java/org/mozilla/gecko/mma/MmaStubImp.java", "mobile/android/base/java/org/mozilla/gecko/push/PushManager.java"], "git_node": null, "git_parents": [null], "node": "93547276fba805541a03a47c99516a61846e0cc5", "parents": ["45b5309a73cbde68fab5b75168bbeaba076ff238"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1419581 - Part 2: Guard media Fennec JNI primitives with MOZ_NATIVE_DEVICES. r=jchen\n\nMozReview-Commit-ID: 3NWZ6BL5Tlr", "files": ["mobile/android/base/Makefile.in", "mobile/android/base/java/org/mozilla/gecko/PresentationMediaPlayerManager.java", "widget/android/fennec/FennecJNINatives.h", "widget/android/fennec/FennecJNIWrappers.cpp", "widget/android/fennec/FennecJNIWrappers.h"], "git_node": null, "git_parents": [null], "node": "bc4cda1cc57cf032ac373911a372f45d1c6d4da8", "parents": ["93547276fba805541a03a47c99516a61846e0cc5"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1419581 - Part 3: Guard PresentationMediaPlayer windows with MOZ_NATIVE_DEVICES. r=jchen\n\nMozReview-Commit-ID: 3ZlVUMufn2g", "files": ["widget/android/nsWindow.cpp", "widget/android/nsWindow.h"], "git_node": null, "git_parents": [null], "node": "d0eba5853ab6102049d1abcbb9fc863848a6b86b", "parents": ["bc4cda1cc57cf032ac373911a372f45d1c6d4da8"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1419581 - Part 4: Allow setting MOZ_ANDROID_GCM in mozconfig. r=chmanchester\n\nThis also verifies that we have Google Play Services (via\nMOZ_NATIVE_DEVICES=1) if we ask to build with GCM.  This was just an\noversight earlier.\n\nMozReview-Commit-ID: BvJi7Sfo4pu", "files": ["mobile/android/moz.configure"], "git_node": null, "git_parents": [null], "node": "8d0855cb17b7168aed64780b1fb127a5ac416661", "parents": ["d0eba5853ab6102049d1abcbb9fc863848a6b86b"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1419581 - Part 5: Add --without-google-play-services. r=chmanchester\n\nHistorically, we used MOZ_NATIVE_DEVICES to proxy for Google Play\nServices.  (MOZ_NATIVE_DEVICES was the first GPS-consuming feature in\nFennec.)  With Python moz.configure, we can easily add the real\ntop-level flag that distributions like F-Droid actually want, which is\nto build without (non-free) Google Play Services entirely.\n\nMozReview-Commit-ID: 7YJKw3G1lQA", "files": ["mobile/android/base/AndroidManifest.xml.in", "mobile/android/base/Makefile.in", "mobile/android/docs/mma.rst", "mobile/android/moz.configure"], "git_node": null, "git_parents": [null], "node": "c9aef37de282ab1dc6c64c978fccc9ed255b068f", "parents": ["8d0855cb17b7168aed64780b1fb127a5ac416661"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1419581 - Part 6: Add Android build configuration --without-google-play-services. r=dustin\n\nMozReview-Commit-ID: 526BCiQwlm6", "files": ["mobile/android/config/mozconfigs/android-api-16/nightly-without-google-play-services", "taskcluster/ci/build/android.yml", "testing/mozharness/configs/builds/releng_sub_android_configs/64_api_16_without_google_play_services.py", "testing/mozharness/mozharness/mozilla/building/buildbase.py"], "git_node": null, "git_parents": [null], "node": "1af5a54e829de694b96b2ee5a0cf5d2478677afb", "parents": ["c9aef37de282ab1dc6c64c978fccc9ed255b068f"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1430277 - Skip symbolstore.py test when building with --enable-strip. r=mshal", "files": ["toolkit/crashreporter/tools/unit-symbolstore.py"], "git_node": null, "git_parents": [null], "node": "b0a019ba2ade9622e3c543bdfe1497c5b4ac6c7a", "parents": ["1af5a54e829de694b96b2ee5a0cf5d2478677afb"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1430037 - Use the in-tree image builder image to build docker images. r=dustin\n\nThe image builder image we use to build docker images is updated\nmanually, and not necessarily when changes occur in tree that should be\nreflected by a new image builder image. For instance, its run-task is\ncurrently outdated. Not enough that it's actually a problem, but it\ncould rapidly become a problem.\n\nThere is also a lot of friction when trying to make changes in how\ndocker images are built, and while last time I tried, I ended up not\nbeing able to do the changes I wanted to make because the docker version\non the host is too old, but this is already the second time I've been\ntrying to make things better and hit a wall because the the image\nbuilder is essentially fixed in stone on the docker hub.\n\nSo with this change, we make all the docker images use the in-tree image\nbuilder image, except itself, obviously. That one uses the last version\nthat was uploaded. We may want to update it at some point, but not doing\nso will only impact building the image builder image itself, not the\nother ones.", "files": ["taskcluster/ci/docker-image/kind.yml", "taskcluster/docker/image_builder/HASH", "taskcluster/docker/image_builder/VERSION", "taskcluster/taskgraph/transforms/docker_image.py", "taskcluster/taskgraph/transforms/task.py"], "git_node": null, "git_parents": [null], "node": "800640c0dc3f22b6dacd0990e0d6748bb3df76ca", "parents": ["b0a019ba2ade9622e3c543bdfe1497c5b4ac6c7a"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1430037 - Use sparse checkouts for docker image builds. r=dustin\n\nIn many cases, building docker images starts on machines that don't have\na cached checkout, and it often takes forever to get a full clone. It\nused to be worsened when 3 jobs could run at the same time because the\nworker would start up clean, and 3 jobs would be doing a mercurial clone\nat the same time, thrashing I/O, but that part is fortunately fixed.\n\nIt is still, however, appreciable not to waste time in the mercurial\nclone part of image creation.", "files": ["build/sparse-profiles/docker-image", "taskcluster/docker/image_builder/build-image.sh", "taskcluster/taskgraph/transforms/docker_image.py"], "git_node": null, "git_parents": [null], "node": "8b80471c1d793ae3d974b672cc0041c43fd50632", "parents": ["800640c0dc3f22b6dacd0990e0d6748bb3df76ca"], "tags": []}, {"author": "ffxbld", "branch": "default", "desc": "No bug, Automated HSTS preload list update from host bld-linux64-spot-309 - a=hsts-update", "files": ["security/manager/ssl/nsSTSPreloadList.errors", "security/manager/ssl/nsSTSPreloadList.inc"], "git_node": null, "git_parents": [null], "node": "9f83ec0895ea02d44ca445e76f10e613367d8693", "parents": ["9be7249e74fd7f6d9163b59d3386ed01038197a0"], "tags": []}, {"author": "ffxbld", "branch": "default", "desc": "No bug, Automated HPKP preload list update from host bld-linux64-spot-309 - a=hpkp-update", "files": ["security/manager/ssl/StaticHPKPins.h"], "git_node": null, "git_parents": [null], "node": "d3309a569efe3d0931f14d13cf6810fbe551983f", "parents": ["9f83ec0895ea02d44ca445e76f10e613367d8693"], "tags": []}, {"author": "ffxbld", "branch": "default", "desc": "No bug, Automated blocklist update from host bld-linux64-spot-309 - a=blocklist-update", "files": ["browser/app/blocklist.xml"], "git_node": null, "git_parents": [null], "node": "a97be0f1da510a103f3f536e4a380a44042bde74", "parents": ["d3309a569efe3d0931f14d13cf6810fbe551983f"], "tags": []}, {"author": "Margareta Eliza Balazs \u003cebalazs@mozilla.com\u003e", "branch": "default", "desc": "Merge inbound to mozilla-central.  a=merge", "files": [], "git_node": null, "git_parents": [null, null], "node": "b2cb61e83ac50115a28f04aaa8a32d4db90aad23", "parents": ["a97be0f1da510a103f3f536e4a380a44042bde74", "dccbf55508540c0459f36c286e3aff6975af722e"], "tags": []}, {"author": "Margareta Eliza Balazs \u003cebalazs@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland. a=merge CLOSED TREE", "files": ["dom/base/nsDocument.cpp", "layout/reftests/bugs/reftest.list"], "git_node": null, "git_parents": [null, null], "node": "b5495d7f42a69017bf88aa697a451faafa4bc39d", "parents": ["8b80471c1d793ae3d974b672cc0041c43fd50632", "b2cb61e83ac50115a28f04aaa8a32d4db90aad23"], "tags": []}, {"author": "Margareta Eliza Balazs \u003cebalazs@mozilla.com\u003e", "branch": "default", "desc": "Backed out 7 changesets (bug 1419581) for B bustage on /builds/worker/workspace/build/src/widget/android/nsWindow.h:0 on a CLOSED TREE\n\nBacked out changeset 1af5a54e829d (bug 1419581)\nBacked out changeset c9aef37de282 (bug 1419581)\nBacked out changeset 8d0855cb17b7 (bug 1419581)\nBacked out changeset d0eba5853ab6 (bug 1419581)\nBacked out changeset bc4cda1cc57c (bug 1419581)\nBacked out changeset 93547276fba8 (bug 1419581)\nBacked out changeset 45b5309a73cb (bug 1419581)", "files": ["mobile/android/app/build.gradle", "mobile/android/app/src/test/java/org/mozilla/gecko/push/TestPushManager.java", "mobile/android/base/AndroidManifest.xml.in", "mobile/android/base/AppConstants.java.in", "mobile/android/base/Makefile.in", "mobile/android/base/java/org/mozilla/gecko/PresentationMediaPlayerManager.java", "mobile/android/base/java/org/mozilla/gecko/mma/MmaDelegate.java", "mobile/android/base/java/org/mozilla/gecko/mma/MmaInterface.java", "mobile/android/base/java/org/mozilla/gecko/mma/MmaLeanplumImp.java", "mobile/android/base/java/org/mozilla/gecko/mma/MmaStubImp.java", "mobile/android/base/java/org/mozilla/gecko/push/PushManager.java", "mobile/android/config/mozconfigs/android-api-16/nightly-without-google-play-services", "mobile/android/docs/mma.rst", "mobile/android/moz.configure", "taskcluster/ci/build/android.yml", "testing/mozharness/configs/builds/releng_sub_android_configs/64_api_16_without_google_play_services.py", "testing/mozharness/mozharness/mozilla/building/buildbase.py", "widget/android/fennec/FennecJNINatives.h", "widget/android/fennec/FennecJNIWrappers.cpp", "widget/android/fennec/FennecJNIWrappers.h", "widget/android/nsWindow.cpp", "widget/android/nsWindow.h"], "git_node": null, "git_parents": [null], "node": "a6a0d6dc6548ecd11238e8208736c03a17e52e10", "parents": ["b5495d7f42a69017bf88aa697a451faafa4bc39d"], "tags": []}, {"author": "Jonathan Watt \u003cjwatt@jwatt.org\u003e", "branch": "default", "desc": "Bug 1430689 - Make ReturnToGalleyPresentation non-virtual. r=bobowen\n\nMozReview-Commit-ID: J3dZuZfDXFd", "files": ["layout/base/nsDocumentViewer.cpp", "layout/base/nsIDocumentViewerPrint.h"], "git_node": null, "git_parents": [null], "node": "80d2455164acf704527014a975ef2d49d15b91f3", "parents": ["fd6dca879e6a5f2a3cf1b9be4e9e992176193dd0"], "tags": []}, {"author": "Jonathan Watt \u003cjwatt@jwatt.org\u003e", "branch": "default", "desc": "Bug 1430683 - Remove nsPrintData::mOrigDCScale. r=bobowen\n\nMozReview-Commit-ID: 3iUiCuiVBei", "files": ["layout/printing/nsPrintData.cpp", "layout/printing/nsPrintData.h"], "git_node": null, "git_parents": [null], "node": "001402b879ceb6eb765166b05e99414ffcf55dd5", "parents": ["80d2455164acf704527014a975ef2d49d15b91f3"], "tags": []}, {"author": "Jonathan Watt \u003cjwatt@jwatt.org\u003e", "branch": "default", "desc": "Bug 1430686 - Rename the document viewer \"DestroyRefCount\" member and methods. r=bobowen\n\nMozReview-Commit-ID: KGUJXOKEQjV", "files": ["layout/base/nsDocumentViewer.cpp", "layout/base/nsIDocumentViewerPrint.h", "layout/printing/nsPagePrintTimer.cpp", "layout/printing/nsPagePrintTimer.h"], "git_node": null, "git_parents": [null], "node": "f3d24c21360d9a34b14a6f5401de130fdb94bfb8", "parents": ["001402b879ceb6eb765166b05e99414ffcf55dd5"], "tags": []}, {"author": "Jonathan Watt \u003cjwatt@jwatt.org\u003e", "branch": "default", "desc": "Bug 1430687 - Move the mDestroyBlockedCount early return in nsDocumentViewer::Destroy to the top. r=bobowen\n\nMozReview-Commit-ID: Exe0hIFHK8z", "files": ["layout/base/nsDocumentViewer.cpp"], "git_node": null, "git_parents": [null], "node": "1359c950dc758d408238074ef84363fb3a8051f4", "parents": ["f3d24c21360d9a34b14a6f5401de130fdb94bfb8"], "tags": []}, {"author": "Jonathan Watt \u003cjwatt@jwatt.org\u003e", "branch": "default", "desc": "Bug 1430682 - Use OwningNonNull for nsPagePrintTimer::mDocViewerPrint and remove null checks. r=bobowen\n\nMozReview-Commit-ID: 5CPaYTA2PrC", "files": ["layout/printing/nsPagePrintTimer.cpp", "layout/printing/nsPagePrintTimer.h"], "git_node": null, "git_parents": [null], "node": "76ce0d94b9b75081a9f8842f4f157e3778b06f6b", "parents": ["1359c950dc758d408238074ef84363fb3a8051f4"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1429957 - Move searchfox indexing job from win32 to win64. r=rillian,dustin,chmanchester\n\nMozReview-Commit-ID: J4TkzTHBWkJ", "files": ["browser/config/mozconfigs/win32/debug-searchfox", "browser/config/mozconfigs/win64/debug-searchfox", "taskcluster/ci/searchfox/kind.yml", "testing/mozharness/configs/builds/taskcluster_firefox_win32_clang_searchfox_debug.py", "testing/mozharness/configs/builds/taskcluster_sub_win64/searchfox_debug.py"], "git_node": null, "git_parents": [null], "node": "350aac55ed6402b20d1ca84f979bbd9b212683d2", "parents": ["76ce0d94b9b75081a9f8842f4f157e3778b06f6b"], "tags": []}, {"author": "grenewode \u003cgrenewodemiller@gmail.com\u003e", "branch": "default", "desc": "Bug 1420733 - Adds support for skipping a configuration and correctly handling other exceptions.  r=jaws.\n\nMozReview-Commit-ID: FlvEw5I4bFn", "files": ["browser/tools/mozscreenshots/mozscreenshots/extension/TestRunner.jsm", "browser/tools/mozscreenshots/mozscreenshots/extension/configurations/AppMenu.jsm", "browser/tools/mozscreenshots/mozscreenshots/extension/configurations/Buttons.jsm", "browser/tools/mozscreenshots/mozscreenshots/extension/configurations/ControlCenter.jsm", "browser/tools/mozscreenshots/mozscreenshots/extension/configurations/PermissionPrompts.jsm", "browser/tools/mozscreenshots/mozscreenshots/extension/configurations/Preferences.jsm", "browser/tools/mozscreenshots/mozscreenshots/extension/configurations/Tabs.jsm", "browser/tools/mozscreenshots/mozscreenshots/extension/configurations/TabsInTitlebar.jsm", "browser/tools/mozscreenshots/mozscreenshots/extension/configurations/Toolbars.jsm"], "git_node": null, "git_parents": [null], "node": "8df2e3d57e945e3445b7aef5f6ffaffebb36e0e7", "parents": ["350aac55ed6402b20d1ca84f979bbd9b212683d2"], "tags": []}, {"author": "Nicholas Hurley \u003churley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430322 - Update expiration for PREDICTOR_PREFETCH_{DECISION,IGNORE}_REASON. r=valentin\n\nMozReview-Commit-ID: DagMyj8zxg2", "files": ["toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "1080244fbe53820b20613d71ceb1c2b9ac58aead", "parents": ["a6a0d6dc6548ecd11238e8208736c03a17e52e10"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "servo: Merge #19787 - style: Make GeckoElement::has_class faster (from emilio:opt-has-class); r=bholley\n\nBy force-inlining the fast path, and pulling out a branch that rust didn't manage to pull out.\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 1ac35dc7abd0b984838dfa4be581a319158190a5", "files": ["servo/components/style/gecko/snapshot_helpers.rs", "servo/components/style/gecko/wrapper.rs"], "git_node": null, "git_parents": [null], "node": "73b38134f4bfd06905370102959ff9a4e701858c", "parents": ["1080244fbe53820b20613d71ceb1c2b9ac58aead"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1420722: Just use GetInFlowParent for now. r=mattwoodrow\n\ndisplay: contents is about to ship in other engines, let's prevent subtle bugs.\n\nMozReview-Commit-ID: C8saQnRvRuI", "files": ["layout/generic/nsFrame.cpp", "layout/generic/nsIFrame.h", "layout/painting/nsDisplayList.cpp"], "git_node": null, "git_parents": [null], "node": "5d33d01409e34363b93d1029ce747dd70042c43c", "parents": ["73b38134f4bfd06905370102959ff9a4e701858c"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1424967: Pass the correct arguments to log in upload_symbols.py; r=ted.mielczarek\n\nMozReview-Commit-ID: JcicOipqM4Q", "files": ["toolkit/crashreporter/tools/upload_symbols.py"], "git_node": null, "git_parents": [null], "node": "e027f4bf3ed2324f094eed7e6fe51a53f05dd355", "parents": ["5d33d01409e34363b93d1029ce747dd70042c43c"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1424967: Fix remaining lint error in upload_symbols.py; r=ted.mielczarek\n\nMozReview-Commit-ID: LsvBXNy1SA6", "files": ["toolkit/crashreporter/tools/upload_symbols.py", "tools/lint/flake8.yml"], "git_node": null, "git_parents": [null], "node": "02a7d3b84dcd08e6c6a0646c49870306f3d6579a", "parents": ["e027f4bf3ed2324f094eed7e6fe51a53f05dd355"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1420722: Fix test indentation. r=whitespace-only\n\nMozReview-Commit-ID: 7rpBIekDCjj\n", "files": ["dom/tests/mochitest/general/test_bug1313753.html"], "git_node": null, "git_parents": [null], "node": "86deafd2d5023e8e9b5625fbda7489fbcfee03ee", "parents": ["02a7d3b84dcd08e6c6a0646c49870306f3d6579a"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1420722: Test this. r=me\n\nI've confirmed that the test fails without the patch for the bug.\n\nMozReview-Commit-ID: 1Udvk02upNY\n", "files": ["dom/tests/mochitest/general/test_bug1313753.html"], "git_node": null, "git_parents": [null], "node": "743d5e003df9ddd23b697c532fafe816a79907ec", "parents": ["86deafd2d5023e8e9b5625fbda7489fbcfee03ee"], "tags": []}, {"author": "J. Ryan Stinnett \u003cjryans@gmail.com\u003e", "branch": "default", "desc": "Bug 1303171 - Adjust highlighters to account for writing mode and text dir. r=gl\n\nThe `getCurrentMatrix` function is used by grid and other highlighters to\naccount for the element's position, transforms, etc.  Here we extend it with\nextra logic to account for the element's writing mode and text direction.\n\nMozReview-Commit-ID: AZT4cJySLwk", "files": ["devtools/client/preferences/devtools.js", "devtools/server/actors/highlighters/css-grid.js", "devtools/server/actors/highlighters/utils/canvas.js", "devtools/shared/layout/dom-matrix-2d.js"], "git_node": null, "git_parents": [null], "node": "d5fce5140351c71c5d2cc42fbb42d558a1989dcd", "parents": ["743d5e003df9ddd23b697c532fafe816a79907ec"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1419581 - Pre: Add missing excludes when building without MOZ_NATIVE_DEVICES. r=nalexander\n\nMozReview-Commit-ID: BXNFBEs2017", "files": ["mobile/android/app/build.gradle"], "git_node": null, "git_parents": [null], "node": "65195aae48d88edc3c23f88083cf77251d9556fe", "parents": ["d5fce5140351c71c5d2cc42fbb42d558a1989dcd"], "tags": []}, {"author": "Tad \u003ctad@spotco.us\u003e", "branch": "default", "desc": "Bug 1419581 - Part 1: Simplify MMA GCM sender IDs logic. r=nechen\n\nRight now, the MMA glue is built into constants.jar.  constants.jar is\nthe home of preprocessed Java code; it's built very early in the build\nprocess and intended to be a tiny kernel of shared definitions.  The\nfact that the MMA glue has to live there is just a sad consequence of\nthe non-Gradle build system, which makes dependency injection\ndifficult.  Unfortunately, another consequence is that it's not\npossible to move reference org.mozilla.gecko.{gcm,push} in the MMA\nglue, because those packages are built after constants.jar.\n\nInstead, this patch lifts some of the logic into AppConstants, which\nis part of constants.jar.  We had grown a twisty maze of indirection\naround the GCM sender IDs and it just wasn't necessary; this just\nlifts the static pieces up a level and removes a bunch of interface\nindirection.\n\nWhat surprises me is that asking Google's InstanceId.getToken for a\nGCM token with a \"comma,separated,list\" of GCM sender IDs works -- and\nindeed, has worked since we added the second MMA sender ID.  I didn't\nexpect that and can't explain it, but this doesn't change that logic\nand local testing (both of the existing APKs, and APKs with this\nmodification) looks good.\n\n\nMozReview-Commit-ID: 3hObfAwNlPH\n***\na0c07e53 o draft Bug 1419581 - Part 1: Move MMA setGcmSenderID from MmaDelegate to MmaLeanplumImp. r=nechen\n\nMozReview-Commit-ID: A4hrk6pVqGW", "files": ["mobile/android/app/src/test/java/org/mozilla/gecko/push/TestPushManager.java", "mobile/android/base/AppConstants.java.in", "mobile/android/base/java/org/mozilla/gecko/mma/MmaDelegate.java", "mobile/android/base/java/org/mozilla/gecko/mma/MmaInterface.java", "mobile/android/base/java/org/mozilla/gecko/mma/MmaLeanplumImp.java", "mobile/android/base/java/org/mozilla/gecko/mma/MmaStubImp.java", "mobile/android/base/java/org/mozilla/gecko/push/PushManager.java"], "git_node": null, "git_parents": [null], "node": "8f1655752d43af33356d497d559888a967bbf6a0", "parents": ["65195aae48d88edc3c23f88083cf77251d9556fe"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1419581 - Part 2: Guard media Fennec JNI primitives with MOZ_NATIVE_DEVICES. r=jchen\n\nMozReview-Commit-ID: 3NWZ6BL5Tlr", "files": ["mobile/android/base/Makefile.in", "mobile/android/base/java/org/mozilla/gecko/PresentationMediaPlayerManager.java", "widget/android/fennec/FennecJNINatives.h", "widget/android/fennec/FennecJNIWrappers.cpp", "widget/android/fennec/FennecJNIWrappers.h"], "git_node": null, "git_parents": [null], "node": "2ea82ff4a757a0aeb7bdd8cff611d5b92dec14eb", "parents": ["8f1655752d43af33356d497d559888a967bbf6a0"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1419581 - Part 3: Guard PresentationMediaPlayer windows with MOZ_NATIVE_DEVICES. r=jchen\n\nMozReview-Commit-ID: 3ZlVUMufn2g", "files": ["widget/android/nsWindow.cpp", "widget/android/nsWindow.h"], "git_node": null, "git_parents": [null], "node": "a7d75667c58ba0069bbb40ad688884a856660a60", "parents": ["2ea82ff4a757a0aeb7bdd8cff611d5b92dec14eb"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1419581 - Part 4: Allow setting MOZ_ANDROID_GCM in mozconfig. r=chmanchester\n\nThis also verifies that we have Google Play Services (via\nMOZ_NATIVE_DEVICES=1) if we ask to build with GCM.  This was just an\noversight earlier.\n\nMozReview-Commit-ID: BvJi7Sfo4pu", "files": ["mobile/android/moz.configure"], "git_node": null, "git_parents": [null], "node": "44bcb609e721598135a19bf41ba7ff94f3051553", "parents": ["a7d75667c58ba0069bbb40ad688884a856660a60"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1419581 - Part 5: Add --without-google-play-services. r=chmanchester\n\nHistorically, we used MOZ_NATIVE_DEVICES to proxy for Google Play\nServices.  (MOZ_NATIVE_DEVICES was the first GPS-consuming feature in\nFennec.)  With Python moz.configure, we can easily add the real\ntop-level flag that distributions like F-Droid actually want, which is\nto build without (non-free) Google Play Services entirely.\n\nMozReview-Commit-ID: 7YJKw3G1lQA", "files": ["mobile/android/base/AndroidManifest.xml.in", "mobile/android/base/Makefile.in", "mobile/android/docs/mma.rst", "mobile/android/moz.configure"], "git_node": null, "git_parents": [null], "node": "be888fa125dc1948fc073ed69aa8116f47e22877", "parents": ["44bcb609e721598135a19bf41ba7ff94f3051553"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1419581 - Part 6: Add Android build configuration --without-google-play-services. r=dustin\n\nMozReview-Commit-ID: 526BCiQwlm6", "files": ["mobile/android/config/mozconfigs/android-api-16/nightly-without-google-play-services", "taskcluster/ci/build/android.yml", "testing/mozharness/configs/builds/releng_sub_android_configs/64_api_16_without_google_play_services.py", "testing/mozharness/mozharness/mozilla/building/buildbase.py"], "git_node": null, "git_parents": [null], "node": "bd1e3857b5bac3dc710521a5eb7377a1168b56ac", "parents": ["be888fa125dc1948fc073ed69aa8116f47e22877"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "servo: Merge #19781 - Optimize selector matching for some common cases (from upsuper:matching-opt); r=emilio\n\nThis is the \"better way\" I mentioned in #19774, which seems to actually improve the score of dromaeo_css on talos.\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 525758ea5ef67148c28acae9404916691e9a960c", "files": ["servo/components/selectors/matching.rs", "servo/components/style/invalidation/element/invalidator.rs"], "git_node": null, "git_parents": [null], "node": "f15b8a999a451caf5ac225f6c522beadc509c605", "parents": ["bd1e3857b5bac3dc710521a5eb7377a1168b56ac"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1430315 - Add a toolchain job to build llvm-dsymutil independently. r=rillian\n\nWe've had problems with crashes in llvm-dsymutil for a while, and while\nthey are, in essence, due to the fact that rustc produces bad debug\ninfo, they are a hurdle to our builds. The tool comes along clang, and\nupdating clang is not necessarily easy (witness bug 1409265), so, so\nfar, we've relied on backporting fixes, which can be time confusing\n(witness bug 1410148).\n\nOTOH, llvm-dsymutil is a rather specific tool, that doesn't strictly\nneed to be tied to clang. It's only tied to it because it uses the llvm\ncode to do some of the things it does, and it's part of the llvm source\ntree. But it could just as well be a separate tool, like it was(is?) on\nOSX.\n\nSo, we add a toolchain job to build it from the llvm source,\nindependently from clang, so that we can update it separately, if we\nhit new crashes that happen to already be fixed on llvm trunk. It will\nalso allow to more easily update after upstream fixes crashes after we\nreport them.", "files": ["taskcluster/ci/toolchain/linux.yml", "taskcluster/scripts/misc/build-llvm-dsymutil.sh"], "git_node": null, "git_parents": [null], "node": "aee6cb0464d79fe892e526fc566e2f96629da61c", "parents": ["f15b8a999a451caf5ac225f6c522beadc509c605"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1430315 - Use the separate llvm-dsymutil toolchain to build Firefox. r=rillian", "files": ["build/macosx/cross-mozconfig.common", "taskcluster/ci/build/macosx.yml", "taskcluster/ci/searchfox/kind.yml"], "git_node": null, "git_parents": [null], "node": "fb5c087381a6f8027b9bb804ea9cc2927b809626", "parents": ["aee6cb0464d79fe892e526fc566e2f96629da61c"], "tags": []}, {"author": "Noemi Erli \u003cnerli@mozilla.com\u003e", "branch": "default", "desc": "Backed out 2 changesets (bug 1424967) for f8 lint failures in /builds/worker/checkouts/gecko/toolkit/crashreporter/tools/upload_symbols.py:78:5 on a CLOSED TREE\n\nBacked out changeset 02a7d3b84dcd (bug 1424967)\nBacked out changeset e027f4bf3ed2 (bug 1424967)", "files": ["toolkit/crashreporter/tools/upload_symbols.py", "tools/lint/flake8.yml"], "git_node": null, "git_parents": [null], "node": "714891013247ad615b4b2f5b2075bf7167ee6ff0", "parents": ["fb5c087381a6f8027b9bb804ea9cc2927b809626"], "tags": []}, {"author": "Ralph Giles \u003cgiles@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430933 - mozboot: Start with rustup 1.9.0. r=gps\n\nWhen bootstraping the development environment on a machine without\nrustup installed, download and install rustup version 1.9.0,\nreleased 2018 January 4, instead of the older 1.5.0.\n\nThis saves a self-upgrade step in the short term and reduces the\nchance of lost support failures in the long term.\n\nMozReview-Commit-ID: H8ouRszLMsP", "files": ["python/mozboot/mozboot/rust.py"], "git_node": null, "git_parents": [null], "node": "bf2a3f50b5f9e099a0db58bf35764a974c41a3aa", "parents": ["714891013247ad615b4b2f5b2075bf7167ee6ff0"], "tags": []}, {"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1427463 - Implement tabs.captureTab(tabId). r=mixedpuppy\n\nMozReview-Commit-ID: 5sr3I1A1b8A", "files": ["browser/components/extensions/ext-tabs.js", "browser/components/extensions/schemas/tabs.json", "browser/components/extensions/test/browser/browser-common.ini", "browser/components/extensions/test/browser/browser_ext_tabs_captureTab.js"], "git_node": null, "git_parents": [null], "node": "514a4f908be40cad0124ba60922c4759339d12b5", "parents": ["bf2a3f50b5f9e099a0db58bf35764a974c41a3aa"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1429995 - Mark test_WEBGL_compressed_texture_s3tc.html as not failing on Linux anymore. r=jgilbert\n\nAnd trigger a new Ubuntu 16.04 docker image with a different hash to get\nthe latest version of the GL drivers that were updated to llvmpipe 5\nrecently. Those new drivers make Firefox enabled\nWEBGL_compressed_texture_s3tc, making the test pass.", "files": ["dom/canvas/test/webgl-mochitest/mochitest.ini", "taskcluster/docker/desktop1604-test/Dockerfile"], "git_node": null, "git_parents": [null], "node": "05028d9a5e626dce8cb72ddba0527d5c0a39925b", "parents": ["514a4f908be40cad0124ba60922c4759339d12b5"], "tags": []}, {"author": "shindli \u003cshindli@mozilla.com\u003e", "branch": "default", "desc": "Backed out 2 changesets (bug 1430037) for bustage on beta r=glandium\n\nBacked out changeset 8b80471c1d79 (bug 1430037)\nBacked out changeset 800640c0dc3f (bug 1430037)", "files": ["build/sparse-profiles/docker-image", "taskcluster/ci/docker-image/kind.yml", "taskcluster/docker/image_builder/HASH", "taskcluster/docker/image_builder/VERSION", "taskcluster/docker/image_builder/build-image.sh", "taskcluster/taskgraph/transforms/docker_image.py", "taskcluster/taskgraph/transforms/task.py"], "git_node": null, "git_parents": [null], "node": "2781837e440437e7d7240c4dd6711f87f47bdd3e", "parents": ["05028d9a5e626dce8cb72ddba0527d5c0a39925b"], "tags": []}, {"author": "Luke Chang \u003clchang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430522 - [Form Autofill] Enable address autofill by default on release build. r=seanlee\n\nMozReview-Commit-ID: 9Pf8l7PqSMi", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "947d9e8d3265bd15e4c324624d141c3af71eb04f", "parents": ["2781837e440437e7d7240c4dd6711f87f47bdd3e"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1429764 Do not call ReduceTimerPrecision twice for DOM Navigation timers r=bkelly,timhuang\n\nBug 1429764 details a test failure that was asserting that the performance navigation\ntimers were strictly increasing (or equal). fetchStart should have a timestamp before\ndomainLookupStart.  But it didn't.\n\nThe problem is two-fold.  This corrects the test and the issue by addressing one part\nof the problem, the second part of the problem needs to be written up in a new bug\nand addressed there. (That bug is not yet filed at writing, but see dependencies of\n1429764 in the future to find it.)\n\nThe second, and underlying, problem is that calling ReduceTimerPrecision with the\nsame value multiple times may continually reduce it. Meaning that the first you call\nit with, say, .75, (and a precision of .20), it will be reduced to .6. The second time\nyou call it (with .6), instead of staying at .6 it will be reduced to .4. This is\nbecause floats are fuzzy. Inside ReduceTimerPrecision we are multiplying a decimal by\na decimal, so while floor(.6 / .20)  should equal 3, sometimes it's actually 2.999...\nwhich gets floors to 2, gets multiplied again by .2, and which results in .4\n\nIf that's the underlying problem, the first, and surface, problem is - why are we\ncalling ReduceTimerPrecision multiple times? We shouldn't be. That's what this\npatch fixes.\n\nTimeStampToDOMHighResOrFetchStart will return either TimeStampToDOMHighRes() or\nFetchStartHighRes(). FetchStartHighRes() internally calls TimeStampToDOMHighRes\nand then ReduceTimerPrecision - this is where (some of) the two reduction calls\nhappen - because TimeStampToDOMHighRes itself calls ReduceTimerPrecision also.\n\nI remove the ReduceTimerPrecision from TimeStampToDOMHighRes. FetchStartHighRes\nwill now only call ReduceTimerPrecision once, at the end of the return.\n\nBut we have to fix places we call TimeStampToDOMHighResOrFetchStart, because the\ncallers of that function also call ReduceTimerPrecision. So if\nTimeStampToDOMHighResOrFetchStart returned FetchStartHighRes, we'd be calling\nReduceTimerPrecision twice for those callers.\n\nSo inside first off, we remove the outer call to ReduceTimerPrecision. that\nsurrounds the 5 or so callsites of TimeStampToDOMHighResOrFetchStart. Then\ninside of TimeStampToDOMHighResOrFetchStart we return either FetchStartHighRes\n(which is has already called ReduceTimerPrecision) or we call\nReduceTimerPrecision with the value.\n\nNow. TimeStampToDOMHighRes was used in more places than just FetchStartHighRes -\nthere were several other places where we were doing double rounding, and this\nfixed those as well. AsyncOpenHighRes, WorkerStartHighRes, DomainLookupEndHighRes,\nConnectStartHighRes, SecureConnectionStartHighRes, ConnectEndHighRes, and\nResponseEndHighRes.\n\nMozReview-Commit-ID: K5nHql135rb", "files": ["dom/performance/PerformanceTiming.cpp", "dom/performance/PerformanceTiming.h", "toolkit/components/resistfingerprinting/nsRFPService.cpp"], "git_node": null, "git_parents": [null], "node": "17bf5819b42fa3b656f2d3c565bc4fb0ca050066", "parents": ["947d9e8d3265bd15e4c324624d141c3af71eb04f"], "tags": []}, {"author": "Oriol Brufau \u003coriol-bugzilla@hotmail.com\u003e", "branch": "default", "desc": "Bug 1427431 - Add methods to check if browser/page/sidebar actions are enabled/shown/open r=mixedpuppy\n\nMozReview-Commit-ID: DPbg8SwKVQL", "files": ["browser/components/extensions/ext-browserAction.js", "browser/components/extensions/ext-pageAction.js", "browser/components/extensions/ext-sidebarAction.js", "browser/components/extensions/schemas/browser_action.json", "browser/components/extensions/schemas/page_action.json", "browser/components/extensions/schemas/sidebar_action.json", "browser/components/extensions/test/browser/browser_ext_browserAction_context.js", "browser/components/extensions/test/browser/browser_ext_sidebarAction.js", "browser/components/extensions/test/browser/head_pageAction.js"], "git_node": null, "git_parents": [null], "node": "7be74a94e7667f417a92098953f0c2adfa4bb65d", "parents": ["17bf5819b42fa3b656f2d3c565bc4fb0ca050066"], "tags": []}, {"author": "Fischer.json \u003cfischer.json@gmail.com\u003e", "branch": "default", "desc": "Bug 1425173 - Fix the missing \"search\" category and extend the expire time for FX_PREFERENCES_CATEGORY_OPENED_V2 r=jaws\n\n- Extend the expire time from 59 to 66\n\n- While going to one pane we will send the \"FX_PREFERENCES_CATEGORY_OPENED_V2\" telemetry for that pane. However, the \"search\" pane category was forgotten to be put in the Histograms.json like other pane categories. As a result, we saw \"Unknown label for categorical histogram\" logged in the browser console when opening about:preferences#search\n\nMozReview-Commit-ID: HJZrAlCncKA", "files": ["toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "2194f63a80bf2fc62053bd79052eb83c5066cfe0", "parents": ["7be74a94e7667f417a92098953f0c2adfa4bb65d"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1424259 - Fix alignment of extension sidebar action icons r=mixedpuppy\n\nMozReview-Commit-ID: 4RQv30imV3B", "files": ["browser/base/content/browser.css", "browser/base/content/browser.xul", "browser/components/extensions/ext-sidebarAction.js", "browser/themes/shared/sidebar.inc.css"], "git_node": null, "git_parents": [null], "node": "db5c4c3edbda2c620aff869a76b25159a208bc6a", "parents": ["2194f63a80bf2fc62053bd79052eb83c5066cfe0"], "tags": []}, {"author": "Ray Lin \u003cralin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1429976 - Include collectionName in formautofill-storage-changed notify payload. r=lchang\n\nMozReview-Commit-ID: 55m97PwMXsx", "files": ["browser/extensions/formautofill/ProfileStorage.jsm", "browser/extensions/formautofill/test/unit/head.js", "browser/extensions/formautofill/test/unit/test_addressRecords.js", "browser/extensions/formautofill/test/unit/test_creditCardRecords.js", "browser/extensions/formautofill/test/unit/test_reconcile.js"], "git_node": null, "git_parents": [null], "node": "df2421b0dbe5fa50d1cbaccf47ec22d4e6bf05c3", "parents": ["db5c4c3edbda2c620aff869a76b25159a208bc6a"], "tags": []}, {"author": "Dustin J. Mitchell \u003cdustin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403519 - only build docs when necessary r=gps\n\nThis marks **/docs/** as exclusively docs, and code that is autodoc'd as\ninclusively docs.\n\nThat means that a change that purely modifies documentation files will *only*\nrun `docs` tasks, while a change that modifies autodoc'd source code will\n*additionaly* run `docs` tasks.  The tasks do not run by default.\n\nMozReview-Commit-ID: G9tOK0AwtrI", "files": ["browser/base/moz.build", "browser/experiments/moz.build", "browser/moz.build", "build/moz.build", "dom/bindings/moz.build", "gfx/moz.build", "mobile/android/moz.build", "moz.build", "python/moz.build", "python/mozbuild/mozbuild/schedules.py", "taskcluster/ci/source-test/doc.yml", "taskcluster/moz.build", "testing/geckodriver/moz.build", "testing/marionette/moz.build", "testing/mozbase/moz.build", "toolkit/components/crashes/moz.build", "toolkit/components/extensions/moz.build", "toolkit/components/payments/moz.build", "toolkit/components/telemetry/moz.build", "toolkit/components/url-classifier/moz.build", "toolkit/crashreporter/moz.build", "toolkit/modules/moz.build", "toolkit/modules/subprocess/moz.build", "toolkit/mozapps/extensions/moz.build", "tools/moz.build"], "git_node": null, "git_parents": [null], "node": "5b293bcd3fc71b67fd5fcbdeca83f4886d3b3cde", "parents": ["df2421b0dbe5fa50d1cbaccf47ec22d4e6bf05c3"], "tags": []}, {"author": "Dustin J. Mitchell \u003cdustin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403519: reset SCHEDULES.exclusive if set multiple times; r=gps\n\nMozReview-Commit-ID: Kycd9i5f19P", "files": ["python/mozbuild/mozbuild/frontend/context.py", "taskcluster/docs/optimization-schedules.rst"], "git_node": null, "git_parents": [null], "node": "f53f8adcd578c38a432e58f482a1c486f2c2dd55", "parents": ["5b293bcd3fc71b67fd5fcbdeca83f4886d3b3cde"], "tags": []}, {"author": "Noemi Erli \u003cnerli@mozilla.com\u003e", "branch": "default", "desc": "Backed out 2 changesets (bug 1403519) for bustage on \\python\\mozbuild\\mozbuild\\test\\frontend\\test_reader.py on a CLOSED TREE\n\nBacked out changeset f53f8adcd578 (bug 1403519)\nBacked out changeset 5b293bcd3fc7 (bug 1403519)", "files": ["browser/base/moz.build", "browser/experiments/moz.build", "browser/moz.build", "build/moz.build", "dom/bindings/moz.build", "gfx/moz.build", "mobile/android/moz.build", "moz.build", "python/moz.build", "python/mozbuild/mozbuild/frontend/context.py", "python/mozbuild/mozbuild/schedules.py", "taskcluster/ci/source-test/doc.yml", "taskcluster/docs/optimization-schedules.rst", "taskcluster/moz.build", "testing/geckodriver/moz.build", "testing/marionette/moz.build", "testing/mozbase/moz.build", "toolkit/components/crashes/moz.build", "toolkit/components/extensions/moz.build", "toolkit/components/payments/moz.build", "toolkit/components/telemetry/moz.build", "toolkit/components/url-classifier/moz.build", "toolkit/crashreporter/moz.build", "toolkit/modules/moz.build", "toolkit/modules/subprocess/moz.build", "toolkit/mozapps/extensions/moz.build", "tools/moz.build"], "git_node": null, "git_parents": [null], "node": "46f721d7988bcc0bd1cbf22854d40abd0cf1c2b2", "parents": ["f53f8adcd578c38a432e58f482a1c486f2c2dd55"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1430958 - Set docker-image as a chain-of-trust input centrally. r=dustin\n\nRelying on the various transforms setting it manually is error prone,\nand, in fact, is why bug 1430037 busted beta. This change makes this\nsetting happen at a single place. This yields the same full task graph\nas before, except for *more* chain-of-trust inputs being set now: they\nwere missing for toolchain tasks (which makes us closer to bug 1384430).", "files": ["taskcluster/taskgraph/transforms/build.py", "taskcluster/taskgraph/transforms/google_play_strings.py", "taskcluster/taskgraph/transforms/l10n.py", "taskcluster/taskgraph/transforms/partials.py", "taskcluster/taskgraph/transforms/repackage.py", "taskcluster/taskgraph/transforms/task.py"], "git_node": null, "git_parents": [null], "node": "11489f123eb8bcb6bf0ea1e78cc11866925e0046", "parents": ["46f721d7988bcc0bd1cbf22854d40abd0cf1c2b2"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430938 part 1: AccessibleHandler: Handle some additional unsupported services queried by JAWS and UI Automation. r=MarcoZ\n\nWe just return failure for these, thus avoiding a pointless cross-process call.\nI also updated the comment for an existing service, since I discovered its constant name.\n\nMozReview-Commit-ID: E5hjhR6nYtv", "files": ["accessible/ipc/win/handler/AccessibleHandler.cpp"], "git_node": null, "git_parents": [null], "node": "a5075d2577012fcf220bd89d6715df274efed291", "parents": ["11489f123eb8bcb6bf0ea1e78cc11866925e0046"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430938 part 2: AccessibleHandler: When QueryService is called for IAccessibleAction or IAccessibleText, just use QI. r=MarcoZ\n\nJAWS uses QueryService for these.\nUsing QI avoids a cross-process call, since we have these interfaces cached.\nMore importantly, if QS is used, the handler won't get used for that object, so our caching won't be used.\n\nMozReview-Commit-ID: Ejc2Bjp7NSv", "files": ["accessible/ipc/win/handler/AccessibleHandler.cpp"], "git_node": null, "git_parents": [null], "node": "b38266ed3cd460c0e941f85609b76defb20baba4", "parents": ["a5075d2577012fcf220bd89d6715df274efed291"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1419079 - Drop checking the pref for animations-api core in file_restyles.html. r=birtles\n\nIt's already specified to true in test_restyles.html.\n\nMozReview-Commit-ID: JMItunKYwIs", "files": ["dom/animation/test/mozilla/file_restyles.html"], "git_node": null, "git_parents": [null], "node": "6a91181c84aa559e4106c2020913d1b4671fbdc7", "parents": ["b38266ed3cd460c0e941f85609b76defb20baba4"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1419079 - Drop checking the pref for offscreen throttling. r=birtles\n\nThe pref has been enabled by default since firefox 49, so it's not worth\nchecking the pref in test.\n\nMozReview-Commit-ID: 5ADIFaV1ue", "files": ["dom/animation/test/mozilla/file_restyles.html"], "git_node": null, "git_parents": [null], "node": "bdec197f0448c5c9f1ede5cb3a037933fa49f733", "parents": ["6a91181c84aa559e4106c2020913d1b4671fbdc7"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1419079 - Revise a comment for a test case for missing keyframes. r=birtles\n\nThe animation in the test case is not actually additive animation, it's just a\nmissing keyframe animation and its composite operation is actually 'replace'.\n\nMozReview-Commit-ID: 4A29V5Ke2hF", "files": ["dom/animation/test/mozilla/file_restyles.html"], "git_node": null, "git_parents": [null], "node": "ce3c3c6967d15f0420ca5fa0aa52f96aab30bb3d", "parents": ["bdec197f0448c5c9f1ede5cb3a037933fa49f733"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1419079 - Add a test case for additive animation with a missing keyframe. r=birtles\n\nMozReview-Commit-ID: 5UWfDIx7RVi", "files": ["dom/animation/test/mozilla/file_restyles.html"], "git_node": null, "git_parents": [null], "node": "49fa09256a655578e9d7bf5d5d2a25007d7e386c", "parents": ["ce3c3c6967d15f0420ca5fa0aa52f96aab30bb3d"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1419079 - Don't bail out from CalculateCumulativeChangeHint() in the case of opacity property even if there is a missing keyframe or composite operation is not 'replace'. r=birtles\n\nFor opacity property, we only generate nsChangeHint_UpdateUsesOpacity,\nnsChangeHint_UpdateOpacityLayer and nsChangeHint_RepaintFrame.  All of them are\nincluded in nsChangeHint_Hints_CanIgnoreIfNotVisible.  So we can throttle\nopacity animations on out-of-view elements whatever underlying opacity value is.\n\nMozReview-Commit-ID: FdQJbItAndG", "files": ["dom/animation/KeyframeEffectReadOnly.cpp", "dom/animation/test/mozilla/file_restyles.html"], "git_node": null, "git_parents": [null], "node": "10ea246d416b35cc9a7457553ef2f5c8419a5cd1", "parents": ["49fa09256a655578e9d7bf5d5d2a25007d7e386c"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1303025 - Accept null for body param in constructor of Response. r=bkelly\n\nMozReview-Commit-ID: LeEFcQzPJlv", "files": ["dom/fetch/Response.cpp", "dom/fetch/Response.h", "dom/webidl/Response.webidl", "testing/web-platform/tests/fetch/api/response/response-init-002.html"], "git_node": null, "git_parents": [null], "node": "62f5c4a3682381134b607d359824b7605ec15156", "parents": ["10ea246d416b35cc9a7457553ef2f5c8419a5cd1"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1424967: Pass the correct arguments to log in upload_symbols.py; r=ted.mielczarek\n\nMozReview-Commit-ID: JcicOipqM4Q", "files": ["toolkit/crashreporter/tools/upload_symbols.py"], "git_node": null, "git_parents": [null], "node": "857bda1e6d53c19b3f9b7de23070d64ab5a84c3e", "parents": ["62f5c4a3682381134b607d359824b7605ec15156"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1424967: Fix remaining lint error in upload_symbols.py; r=ted.mielczarek\n\nMozReview-Commit-ID: LsvBXNy1SA6", "files": ["toolkit/crashreporter/tools/upload_symbols.py", "tools/lint/flake8.yml"], "git_node": null, "git_parents": [null], "node": "fab46ed62124c604f5c6445b46502494936c536d", "parents": ["857bda1e6d53c19b3f9b7de23070d64ab5a84c3e"], "tags": []}, {"author": "Chris Peterson \u003ccpeterson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1428984 - Part 1: Consolidate virtual, pure, override, and static MethodDecl types into an MethodSpec enum. r=froydnj\n\npure or override implies virtual. static is mutually exclusive with virtual (and pure and override). Combining these types into a \"method specifier\" enum simplifies the code and prevents bogus states like virtual=0 and pure=1.\n\nMozReview-Commit-ID: IFeuvbp1RIo", "files": ["ipc/ipdl/ipdl/cxx/ast.py", "ipc/ipdl/ipdl/cxx/cgen.py", "ipc/ipdl/ipdl/lower.py"], "git_node": null, "git_parents": [null], "node": "61215096911309c5a1cc03ada32390ea1aad5cc8", "parents": ["fab46ed62124c604f5c6445b46502494936c536d"], "tags": []}, {"author": "Chris Peterson \u003ccpeterson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1428984 - Part 2: Remove unused never_inline flag. r=froydnj\n\nnever_inline is never set so cgen never emits MOZ_NEVER_INLINE.\n\nMozReview-Commit-ID: HS7qw7D4lBC", "files": ["ipc/ipdl/ipdl/cxx/ast.py", "ipc/ipdl/ipdl/cxx/cgen.py", "ipc/ipdl/ipdl/lower.py"], "git_node": null, "git_parents": [null], "node": "18fb324726e7d12021183b3024415682f8754552", "parents": ["61215096911309c5a1cc03ada32390ea1aad5cc8"], "tags": []}, {"author": "Chris Peterson \u003ccpeterson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1428984 - Part 3: Remove unused inline flag. r=froydnj\n\ninline is never set so cgen never emits inline.\n\nMozReview-Commit-ID: BDL6BV8906t", "files": ["ipc/ipdl/ipdl/cxx/ast.py", "ipc/ipdl/ipdl/cxx/cgen.py", "ipc/ipdl/ipdl/lower.py"], "git_node": null, "git_parents": [null], "node": "1f3edc2b0da5dd6416764bac9093fc9dd45932f2", "parents": ["18fb324726e7d12021183b3024415682f8754552"], "tags": []}, {"author": "abhinav \u003cabhinav.koppula@gmail.com\u003e", "branch": "default", "desc": "Bug 1427006 - Enhanced the browser_webconsole_console_group test; r=nchevobbe\n\nMozReview-Commit-ID: Efe5xb8sq7C", "files": ["devtools/client/webconsole/new-console-output/test/mochitest/browser_webconsole_console_group.js"], "git_node": null, "git_parents": [null], "node": "5a130721f8ea9793e201453caf4bc56d5b3ae53f", "parents": ["1f3edc2b0da5dd6416764bac9093fc9dd45932f2"], "tags": []}, {"author": "Jeff Gilbert \u003cjgilbert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1429754 - Trust the driver about floating point support. - r=daoshengmu\n\nRemove the probe, and remove the cached value check.\nAlso remove dead code which relies on this sometimes-clamping glGet query.\n\nMozReview-Commit-ID: JA1VgH8fLRB\n", "files": ["dom/canvas/WebGLContextUtils.cpp", "dom/canvas/WebGLExtensionColorBufferFloat.cpp", "dom/canvas/test/webgl-mochitest/mochitest.ini", "gfx/gl/GLContext.cpp", "gfx/gl/GLContext.h"], "git_node": null, "git_parents": [null], "node": "f6d0f79d687b1f427ebaf3018d82b55eda3e173a", "parents": ["8df2e3d57e945e3445b7aef5f6ffaffebb36e0e7"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1429078 - Handle the case where the subdoc view doesn't have a frame. r=miko", "files": ["layout/painting/RetainedDisplayListBuilder.cpp"], "git_node": null, "git_parents": [null], "node": "0656d11f1328a01fa9d345e116126bb6519370de", "parents": ["f6d0f79d687b1f427ebaf3018d82b55eda3e173a"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1421345 - Check the canary during allocations. r=jet", "files": ["xpcom/ds/ArenaAllocator.h"], "git_node": null, "git_parents": [null], "node": "4bb6a59e797f812d922a5f7391beda693da21df1", "parents": ["0656d11f1328a01fa9d345e116126bb6519370de"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "B