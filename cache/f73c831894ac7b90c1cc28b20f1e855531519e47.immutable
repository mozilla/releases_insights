illa.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nan -\u003e 0eba067f149a\ncak -\u003e 8b69c0a532f6\ncs -\u003e a1fd40554493\neo -\u003e bc1d6db2f350\nes-CL -\u003e 4ec850e0c5c7\nfa -\u003e 7bae5a81265a\nfy-NL -\u003e f1ef041d4900\nhu -\u003e d26927fbc590\nhy-AM -\u003e ffee567f4f26\nis -\u003e 2d687c611f44\nit -\u003e 4f180ca910ef\nnb-NO -\u003e bcc36cd3f50f\nnl -\u003e 2d15b66460a5\noc -\u003e 31774123f831\npl -\u003e 53c0ea8b7db7", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "352f87002e5cc0d0aa47a6005c13a6b4ac67b3e3", "parents": ["4320ff21043330b71defec7a93448c4bf25f339e"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nan -\u003e 1abf11102da2\ncak -\u003e 1f0865edfa83\ncs -\u003e a1fd40554493\neo -\u003e bc1d6db2f350\nes-CL -\u003e 4ec850e0c5c7\nes-MX -\u003e 46682131ecec\nfa -\u003e 7bae5a81265a\nfr -\u003e 97a2c0f88dda\nfy-NL -\u003e f1ef041d4900\nhu -\u003e d26927fbc590\nhy-AM -\u003e 75721b9b55f8\nit -\u003e 4f180ca910ef\nko -\u003e 0befe4a5c1c6\nnb-NO -\u003e 06427ccb1681\nnl -\u003e 2851a6b60bf7\nnn-NO -\u003e 6e2d4f96a6d4\npl -\u003e c8e814af1095\npt-BR -\u003e 69cd61246285", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "f7ba10e2992062d47c69a6e01c537158ef6a8dec", "parents": ["352f87002e5cc0d0aa47a6005c13a6b4ac67b3e3"], "tags": []}], "date": 1516897265, "git_changesets": [null, null], "user": "ffxbld"}, "8590": {"changesets": [{"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1432213 - Fix the MinGW build on the beta branch and re-enable it. r=froydnj, a=NPOTB\n\nWhen we branched to beta, the MinGW build started failing with a strange error\nlike \"could not find the robustcheckout Mercurial extension\". We disabled it\nfor a while, but now we're re-enabling it (and fixing the problem.)\n\nThe root culprit of this was that we were using the incorrect mozconfig. MinGW\ndoes all sorts of stuff in the mozconfig, but the beta branch overrides the\nmozconfig using platform_overrides in\ntesting/mozharness/configs/builds/branch_specifics.py\n\nWe avoid this override by changing the MinGW platform so it doesn't match\nand the mozconfig doesn't get overridden.\n\nMozReview-Commit-ID: JkETWCRHacO", "files": ["taskcluster/taskgraph/target_tasks.py", "testing/mozharness/configs/builds/releng_base_windows_32_mingw_builds.py"], "git_node": null, "git_parents": [null], "node": "7047d5147ac6d3fca4bc0b134225617f09306930", "parents": ["f7ba10e2992062d47c69a6e01c537158ef6a8dec"], "tags": []}, {"author": "Bob Owen \u003cbobowencode@gmail.com\u003e", "branch": "default", "desc": "Bug 1433065 - Make the Chromium sandbox DLL blocking Nightly only. r=jimm, a=lizzard", "files": ["security/sandbox/win/src/sandboxbroker/sandboxBroker.cpp"], "git_node": null, "git_parents": [null], "node": "783507b1b80d927d5ef408c6ff87f8c52f2c8af9", "parents": ["7047d5147ac6d3fca4bc0b134225617f09306930"], "tags": ["DEVEDITION_59_0b4_BUILD1", "DEVEDITION_59_0b4_RELEASE", "FIREFOX_59_0b4_BUILD1", "FIREFOX_59_0b4_RELEASE"]}], "date": 1516897841, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "8591": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nru -\u003e 10f429d13724\nsk -\u003e e3acfe04afba\nsv-SE -\u003e 5771dc96c88c\ntrs -\u003e 1977401a2251\nuk -\u003e c61f117a6deb\nzh-TW -\u003e 6e13ef6f06e0", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "aaffe23142b3ba74848b964a79d37ffb45569715", "parents": ["783507b1b80d927d5ef408c6ff87f8c52f2c8af9"], "tags": []}, {"author": "L10n Bumper Bot \u003crelea