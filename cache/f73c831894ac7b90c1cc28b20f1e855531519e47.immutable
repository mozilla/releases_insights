 the string if the size is passed, r=froydnj a=RyanVM", "files": ["netwerk/base/nsNetUtil.cpp", "netwerk/test/gtest/TestReadStreamToString.cpp"], "git_node": null, "git_parents": [null], "node": "13b72310eefd7d70255edb732340288eca061a85", "parents": ["44c177fff0d8bc8758a31fc1a1598eebae85e6cc"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1437152 - NS_ReadInputStreamToString doesn't reallocate the string if the size is passed, r=me a=RyanVM", "files": ["netwerk/base/nsNetUtil.cpp"], "git_node": null, "git_parents": [null], "node": "842387c97de7ba794e46392d9340c7461ab47932", "parents": ["13b72310eefd7d70255edb732340288eca061a85"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1438180 - don't update the url bar search suggestions pref directly, r=jaws,f=myk a=RyanVM\n\nIn search.js, _updateSuggestionCheckboxes is already hooked up to update this checkbox\nbased on the preference value, including change handlers for when it changes. As a result,\nhaving both the preference attribute and the 'manual' JS means that the actual checked and\ndisabled state races with which code sets the value first.\n\nThe search suggestion order preference already doesn't have a preference attribute and is\nonly ever updated via the JS. It seems sensible to do the same here.\n\nMozReview-Commit-ID: Cm8evlembt7", "files": ["browser/components/preferences/in-content/search.xul"], "git_node": null, "git_parents": [null], "node": "df143d7bcd1930faf76dc99159781d1d378e4e73", "parents": ["842387c97de7ba794e46392d9340c7461ab47932"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1418770 - Truncate DBus names used for remote service to DBUS_MAXIMUM_NAME_LENGTH, r=jhorak a=RyanVM\n\nMozReview-Commit-ID: 3Hrt3Ef87WD", "files": ["toolkit/components/remote/nsDBusRemoteService.cpp", "widget/xremoteclient/DBusRemoteClient.cpp"], "git_node": null, "git_parents": [null], "node": "28b5b075c5e6dc6284113646b22a523f5abb02c3", "parents": ["df143d7bcd1930faf76dc99159781d1d378e4e73"], "tags": []}], "date": 1519311524, "git_changesets": [null, null, null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "8756": {"changesets": [{"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1424505 - Block osk.exe from UIA instantiation. r=Jamie, a=RyanVM", "files": ["accessible/windows/msaa/CompatibilityUIA.cpp", "accessible/windows/msaa/LazyInstantiator.cpp", "widget/windows/nsAppShell.cpp"], "git_node": null, "git_parents": [null], "node": "abc5f0d35082241616975246fd770c77359a0d5e", "parents": ["28b5b075c5e6dc6284113646b22a523f5abb02c3"], "tags": ["DEVEDITION_59_0b12_BUILD1", "DEVEDITION_59_0b12_RELEASE", "FIREFOX_59_0b12_BUILD1", "FIREFOX_59_0b12_RELEASE"]}], "date": 1519319033, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "8757": {"changesets": [{"author": "Nick Thomas \u003cnthomas@mozilla.com\u003e", "branch": "default", "desc": "Bug 1435638 - initialize repo using an ssh clone, r=jlund a=release DONTBUILD", "files": ["testing/mozharness/configs/partner_repacks/release_mozilla-esr52_desktop.py", "testing/mozharness/configs/partner_repacks/release_mozilla-release_desktop.py", "testing/mozharness/configs/partner_repacks/staging_release_mozilla-release_desktop.py", "testing/mozharness/scripts/desktop_partner_repacks.py"], "git_node": null, "git_parents": [null], "node": "3df63b8f9bfaeedc47c149528584346910e47e91", "parents": ["abc5f0d35082241616975246fd770c77359a0d5e"], "tags": []}], "date": 1519341240, "git_changesets": [null], "user": "nthomas@mozilla.com"}, "8758": {"changesets": [{"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1433463 - WebDriver:ElementSendKeys should not run unfocussing steps. r=automatedtester a=test-only\n\nAccording to the WebDriver standard the Element Send Keys command\nshould not run the unfocussing steps.  Not blurring the element\ncauses the DOM \"change\" event not to fire, but the specification\nonly expects the \"input\" event to fire.\n\nThe standard does, however, expect the Element Clear command to\nrun the unfocussing steps and to blur the element for historical reasons.\n\nMozReview-Commit-ID: FHD1whho0jT", "files": ["testing/marionette/interaction.js", "testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/webdriver/tests/element_send_keys/form_controls.py", "testing/web-platform/tests/webdriver/tests/element_send_keys/interactability.py"], "git_node": null, "git_parents": [null], "node": "c4fe0ca380a6309d37e9df5c0692e64a455e76ce", "parents": ["3df63b8f9bfaeedc47c149528584346910e47e91"], "tags": []}], "date": 1519388368, "git_changesets": [null], "user": "shindli@mozilla.com"}, "8759": {"changesets": [{"author": "Rail Aliiev \u003crail@mozilla.com\u003e", "branch": "default", "desc": "Bug 1398796 - Fix bouncer check configs r=mtabara a=release", "files": ["taskcluster/ci/release-bouncer-check/kind.yml"], "git_node": null, "git_parents": [null], "node": "6f4bcccd7daed3bc156cdeef78cabdab2ff7ff18", "parents": ["c4fe0ca380a6309d37e9df5c0692e64a455e76ce"], "tags": []}], "date": 1519402844, "git_changesets": [null], "user": "raliiev@mozilla.com"}, "8760": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "Automatic version bump. CLOSED TREE NO BUG a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "857baf410d08a105ff94bddcbff4f007a15b5c46", "parents": ["6f4bcccd7daed3bc156cdeef78cabdab2ff7ff18"], "tags": []}, {"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging abc5f0d35082241616975246fd770c77359a0d5e with FIREFOX_59_0b12_BUILD1, FIREFOX_59_0b12_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "