", "security/manager/ssl/tests/unit/test_signed_apps/empty_signerInfos.zip", "security/manager/ssl/tests/unit/test_signed_apps/only_cose_multiple_signed.zip", "security/manager/ssl/tests/unit/test_signed_apps/only_cose_signed.zip", "security/manager/ssl/tests/unit/test_signed_apps/unknown_issuer_app.zip", "security/manager/ssl/tests/unit/test_signed_apps/unsigned_app.zip"], "git_node": null, "git_parents": [null], "node": "9ea67f48a1b14b362040b467cb40f9e8775e52b9", "parents": ["87c5dfa3fc645fab244a4dd294b0ba6c128ca7b9"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Bug 1435644: Revert update of certs which have to remain outdated or are checked at a fixed point in time, update metadata hardcoded in tests. r=Try a=Try", "files": ["security/manager/ssl/tests/unit/test_baseline_requirements/ca.pem", "security/manager/ssl/tests/unit/test_cert_eku/ee-int-nsSGC-old.pem", "security/manager/ssl/tests/unit/test_cert_eku/ee-int-nsSGC-older.pem", "security/manager/ssl/tests/unit/test_startcom_wosign/StartComCA.pem", "security/manager/ssl/tests/unit/test_startcom_wosign/WoSignCA.pem", "security/manager/ssl/tests/unit/test_x509.js"], "git_node": null, "git_parents": [null], "node": "70165c809eb60a4253b4b3addd09888c7d614af8", "parents": ["9ea67f48a1b14b362040b467cb40f9e8775e52b9"], "tags": []}, {"author": "Cykesiopka \u003ccykesiopka.bmo@gmail.com\u003e", "branch": "default", "desc": "Bug 1435644 - Fix and regenerate test_cert_eku/ certs to get test_cert_eku.js passing again. r=keeler a=Aryx\n\nca.pem is used to sign certificates that are either verified at time 2016-08-25\nor time \"now\", with the earliest such certificate having a notBefore of\n2015-07-24. As such, ca.pem.certspec needs to have a notBefore time that is no\nlater than 2015-07-24, but be valid for a reasonably long time.\nTherefore, ca.pem.certspec is changed so the cert has a notBefore of 2015-01-01,\nand is valid for 20 years.\n\nee-int-nsSGC-*.pem are verified at time 2016-08-25, and so need to be valid\nat that time.\nTherefore, the ee-int-nsSGC-*.pem.certspec files are changed so the\ncorresponding certs have validity periods that match their intermediates.\n\nMozReview-Commit-ID: duOnvGGcuD", "files": ["security/manager/ssl/tests/unit/test_cert_eku/ca.pem", "security/manager/ssl/tests/unit/test_cert_eku/ca.pem.certspec", "security/manager/ssl/tests/unit/test_cert_eku/ee-int-nsSGC-old.pem", "security/manager/ssl/tests/unit/test_cert_eku/ee-int-nsSGC-old.pem.certspec", "security/manager/ssl/tests/unit/test_cert_eku/ee-int-nsSGC-older.pem", "security/manager/ssl/tests/unit/test_cert_eku/ee-int-nsSGC-older.pem.certspec", "security/manager/ssl/tests/unit/test_cert_eku/ee-int-nsSGC-recent.pem", "security/manager/ssl/tests/unit/test_cert_eku/ee-int-nsSGC-recent.pem.certspec"], "git_node": null, "git_parents": [null], "node": "cea404d167f22f0ff5b329183efefa8a270c9c43", "parents": ["70165c809eb60a4253b4b3addd09888c7d614af8"], "tags": []}], "date": 1517859573, "git_changesets": [null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "8651": {"changesets": [{"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1433422 - Move caret after focussing element. r=automatedtester, a=test-only\n\nFocussing the element changes the selection range.\n\nMozReview-Commit-ID: JW68aZupkly", "files": ["testing/marionette/interaction.js"], "git_node": null, "git_parents": [null], "node": "c70cc6ea1e7b887074bddf128b83ac7dd305c17b", "parents": ["cea404d167f22f0ff5b329183efefa8a270c9c43"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1433422 - Fix interaction.moveCaretToEnd element conditions. r=automatedtester, a=test-only\n\nBug 1432864 introduced a regression where the element conditions\nfor moving the caret to the end of the textual input were wrong.\nApparently if conditions are hard.\n\nMozReview-Commit-ID: KlRv6sCroXW", "files": ["testing/marionette/interaction.js", "testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/webdriver/tests/element_send_keys/form_controls.py"], "git_node": null, "git_parents": [null], "node": "923317a339b0395ffa98d093c630b7f27fbef87f", "parents": ["c70cc6ea1e7b887074bddf128b83ac7dd305c17b"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1433422 - Add basic form control tests for Element Send Keys. r=automatedtester, a=test-only\n\nWe are apparently missing even the most basic tests for Element\nSend Keys.  This is a moderate contribution.\n\nMozReview-Commit-ID: 9uWtTJ7MFZx", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/webdriver/tests/element_send_keys/form_controls.py"], "git_node": null, "git_parents": [null], "node": "a2d90d0ba332bf27937a98b46a26f9a31a057a44", "parents": ["923317a339b0395ffa98d093c630b7f27fbef87f"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1433422 - Show full pytest failure logs. r=jgraham, a=test-only\n\npytest truncates long lists when printing a failed assertion.\nThis is not great for debugging and arguably it should be the\ndefault to show the full diff when comparing lists.\n\nMozReview-Commit-ID: L8vxIMM9g6m", "files": ["testing/web-platform/tests/tools/wptrunner/wptrunner/executors/pytestrunner/runner.py"], "git_node": null, "git_parents": [null], "node": "73cad34ce2cdb17ee487a9754272a4c622f3d4e1", "parents": ["a2d90d0ba332bf27937a98b46a26f9a31a057a44"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1435761 - Update nsSTSPreloadList.inc to enforce HTTPS for new whole eTLDs in 59. r=jcj, a=lizzard", "files": ["security/manager/ssl/nsSTSPreloadList.inc"], "git_node": null, "git_parents": [null], "node": "2169cf07d96fb2f0b0afc842c1dc0c41dbf811df", "parents": ["73cad34ce2cdb17ee487a9754272a4c622f3d4e1"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1430628 - TextInputHandler::HandleCommand() should use native key event when it dispatches a keypress event either initializing with native event or creating fake event. r=m_kato, a=lizzard\n\nTextInputHandler::HandleCommand() has two bugs.  One is, checking whether\nthe key event has caused composition events.  Even if it caused composition\nevents, we decided to dispatch keypress event for emulating native behavior.\nTherefore, this patch removes the check of\n|currentKeyEvent-\u003eCanDispatchKeyPress()|.\n\nThe other is, for making content handle dispatching keypress event as given\ncommand, it needs to dispatch a keypress event whose key combination will\ncause the command.  However, HandleCommand() needs to set native key event\nsince content may not refer key combination for some edit actions, they just\nrefer command which is computed with native key event with NativeKeyBindings.\nTherefore, even if current native key event has already caused dispatching\nsome events, HandleCommand() needs to set\nWidgetKeyboardEvent::mNativeKeyEvent to current native key event for\nNativeKeyBindings.  Although it must be rare case, given key could be\nnot related to the command or not key could cause the command.  In this\ncase, and perhaps in all cases, we should set all commands of dispatching\nkeypress event before dispatching it.  Howevever, this needs more work,\nso, we shouldn't do it in this bug to making it possible to uplift.\nTherefore, this patch makes always set mNativeKeyEvent to current native\nkey event.  So, just warning it when command is caused without native\nkey event.\n\nMozReview-Commit-ID: 2MvDTw4ruAu", "files": ["widget/cocoa/TextInputHandler.mm"], "git_node": null, "git_parents": [null], "node": "95291d42399e45ad8beaeb59a79addf578c66eda", "parents": ["2169cf07d96fb2f0b0afc842c1dc0c41dbf811df"], "tags": []}, {"author": "Florian Qu\u00e8ze \u003cflorian@queze.net\u003e", "branch": "default", "desc": "Bug 1419152 - Avoid white flashes when opening new tabs or windows with high contrast themes. r=Gijs, a=lizzard", "files": ["browser/themes/windows/browser.css"], "git_node": null, "git_parents": [null], "node": "beb7c47f05a233f1b7afa76bce838c46f42c69a5", "parents": ["95291d42399e45ad8beaeb59a79addf578c66eda"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1275062 - Introduce a size check of IPC messages for IndexedDB. r=asuth, a=lizzard", "files": ["dom/indexedDB/ActorsParent.cpp", "dom/indexedDB/IndexedDatabase.h", "dom/indexedDB/IndexedDatabaseInlines.h"], "git_node": null, "git_parents": [null], "node": "24ea37d401ad5d7bcfaf7a5f473b0806010cfee3", "parents": ["beb7c47f05a233f1b7afa76bce838c46f42c69a5"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1432870. r=bz, a=lizzard", "files": ["chrome/nsChromeRegistry.cpp"], "git_node": null, "git_parents": [null], "node": "43c1a3c2f4c50eac8f1a818b54fd2b25726a3865", "parents": ["24ea37d401ad5d7bcfaf7a5f473b0806010cfee3"], "tags": []}, {"author": "Francois Marier \u003cfrancois@mozilla.com\u003e", "branch": "default", "desc": "Bug 1431192 - Only fetch download protection lists when Safe Browsing is enabled. r=gcp, a=RyanVM\n\nDownload protection requires both the malware list as well as its\nown special lists. The code therefore checks that both Safe\nBrowsing and download protection are enabled before checking\ndownloaded files.\n\nThe list manager should check the same prefs before downloading\nany of the download protection lists in order to avoid connecting\nto the Safe Browsing server when Safe Browsing is fully disabled.\n\nMozReview-Commit-ID: 66vMA56T4pJ", "files": ["toolkit/components/url-classifier/SafeBrowsing.jsm"], "git_node": null, "git_parents": [null], "node": "7cefe9877e46f2eefab2a8169777755b96252743", "parents": ["43c1a3c2f4c50eac8f1a818b54fd2b25726a3865"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1424469 - The Downloads view in the Library window doesn't get focus when opened. r=mak, a=RyanVM\n\nWe have to keep track of the focused element while we remove the richlistbox element temporarily.\n\nMozReview-Commit-ID: AePydUyyUS7", "files": ["browser/components/downloads/content/allDownloadsViewOverlay.js"], "git_node": null, "git_parents": [null], "node": "e83f82bb996219e9e64e05d17d489ba4d9d63f64", "parents": ["7cefe9877e46f2eefab2a8169777755b96252743"], "tags": []}], "date": 1517861756, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8652": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1433671 - Make AccessibleCaretManager flushes a bit more sound. r=TYLin, a=RyanVM\n\nThe accessible caret manager is owned by the event hub, that is owned by the\nshell.\n\nAll the callers of methods that call FlushLayout on the AccessibleCaretManager\nshould hold an external reference to the event hub.\n\nFlushing pending notifications can run arbitrary script, that can call Destroy()\non the pres shell (and thus tear down the accessible caret event hub, and the\nmanager with him).\n\nI don't know why before my change this wasn't crashing badly, but the code as it\nwas just doesn't look sound to me at all either (maybe I'm misunderstanding\nsomething and I should just revert that patch and give up on having nice\ninvariants during our flushes..., but I don't think it's the case).\n\nThis also adds some sanity-checking that we don't die under our flush.\n\nMozReview-Commit-ID: 4s0UT0fD3TI", "files": ["layout/base/AccessibleCaretEventHub.cpp", "layout/base/AccessibleCaretManager.cpp", "layout/base/AccessibleCaretManager.h", "layout/base/gtest/TestAccessibleCaretManager.cpp"], "git_node": null, "git_parents": [null], "node": "3d51ba1a7c3fdffd5f44540038f11def9832fc96", "parents": ["e83f82bb996219e9e64e05d17d489ba4d9d63f64"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1433715 - Make fallback folder icon content-accessible. r=Gijs, a=RyanVM\n\nThe skin used on Firefox for Android doesn't style directory listing, hence we\nfall back to using the default icon from gre/res/html. As of bug 863246, this\nlocation is no longer accessible from content as a resource://, hence the file\nneeds moving into the special content-accessible directory.\n\nMozReview-Commit-ID: obtefafqul", "files": ["browser/installer/package-manifest.in", "layout/generic/moz.build", "mobile/android/installer/package-manifest.in", "netwerk/streamconv/converters/nsIndexedToHTML.cpp"], "git_node": null, "git_parents": [null], "node": "711b8a407ffd287573fa14d5ca27631d47b8c413", "parents": ["3d51ba1a7c3fdffd5f44540038f11def9832fc96"], "tags": []}, {"author": "Dave Townsend \u003cdtownsend@oxymoronical.com\u003e", "branch": "default", "desc": "Bug 1418314 - Make the learn more links in plugin details work properly again. r=aswan, a=lizzard\n\nMozReview-Commit-ID: BZJ4XPiX0Uc", "files": ["toolkit/mozapps/extensions/content/pluginPrefs.xul"], "git_node": null, "git_parents": [null], "node": "e60b08577c8971ce72538499a751ce04291881dd", "parents": ["711b8a407ffd287573fa14d5ca27631d47b8c413"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1424709 - Force disable the OSX system \"nano allocator\". r=spohl, a=lizzard\n\nWe're not actually using it, and it messes up with the zone allocator in\nmozjemalloc after fork(). See the lengthy analysis in\nhttps://bugzilla.mozilla.org/show_bug.cgi?id=1424709#c34 and following.", "files": ["browser/app/macbuild/Contents/Info.plist.in", "memory/build/zone.c"], "git_node": null, "git_parents": [null], "node": "45c5d467a46077dcc3ccd59feafd0c2784432fef", "parents": ["e60b08577c8971ce72538499a751ce04291881dd"], "tags": []}, {"author": "Panos Astithas \u003cpast@mozilla.com\u003e", "branch": "default", "desc": "Bug 1434761 - Fix preprocessor check for release builds. r=glandium, a=lizzard\n\nMozReview-Commit-ID: KzSemfEkMcd", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "d52a39d61c0350a3d1d89139fe19cad6f4a99dd6", "parents": ["45c5d467a46077dcc3ccd59feafd0c2784432fef"], "tags": []}, {"author": "Munro Mengjue Chiang \u003cmchiang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1423582 - Use UniquePtr to wrap frame. r=pehrsons, a=RyanVM\n\nMozReview-Commit-ID: 2T7RC1tBbOA", "files": ["dom/media/webrtc/MediaEngineRemoteVideoSource.cpp"], "git_node": null, "git_parents": [null], "node": "7920129029aefce687e4ce6e2ac197b03d62a74e", "parents": ["d52a39d61c0350a3d1d89139fe19cad6f4a99dd6"], "tags": []}, {"author": "Bas Schouten \u003cbschouten@mozilla.com\u003e", "branch": "default", "desc": "Bug 1433790 - Disable Direct2D on drivers/devices where OMTP causes crashes. r=milan, a=RyanVM\n\nMozReview-Commit-ID: FmUh2zSnSdd", "files": ["widget/windows/GfxInfo.cpp"], "git_node": null, "git_parents": [null], "node": "60dacc12cab137a14e82a1ae7c070b520919cf8e", "parents": ["7920129029aefce687e4ce6e2ac197b03d62a74e"], "tags": []}, {"author": "Simon Sapin \u003csimon.sapin@exyr.org\u003e", "branch": "default", "desc": "Bug 1434619 - servo: Remove #![deny(warnings)]. r=nox, a=lizzard\n\nWe already have https://github.com/servo/servo/pull/19612 to deny warnings at the time of landing into master. But it\u2019s not useful to break the build when later compiler with a more recent Rust version that has introduced new warnings:\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 7546c37f1e921a112fef5828c59c6738a98c3f30", "files": ["servo/components/style/lib.rs", "servo/ports/geckolib/lib.rs", "servo/support/gecko/nsstring/src/lib.rs"], "git_node": null, "git_parents": [null], "node": "9c48b0136c8aa07f8dd8abf0af06dd331652776d", "parents": ["60dacc12cab137a14e82a1ae7c070b520919cf8e"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1434856 - Move runnable prioritization checks outside of event queue locks. r=erahm, a=RyanVM\n\nOtherwise, we might enter JS, decide to GC, and deadlock because we were\ntrying to dispatch tasks to the main thread's event queue while holding\nthe lock for the event queue.", "files": ["xpcom/tests/unit/test_bug1434856.js", "xpcom/tests/unit/xpcshell.ini", "xpcom/threads/AbstractEventQueue.h", "xpcom/threads/EventQueue.h", "xpcom/threads/PrioritizedEventQueue.cpp", "xpcom/threads/PrioritizedEventQueue.h", "xpcom/threads/ThreadEventQueue.cpp"], "git_node": null, "git_parents": [null], "node": "d4c3d0d6a6f9cd9375d0592fb85b8262371bfe8d", "parents": ["9c48b0136c8aa07f8dd8abf0af06dd331652776d"], "tags": []}], "date": 1517862990, "git_changesets": [null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8653": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nid -\u003e 2d3504313ac8\nit -\u003e 3153513d549d", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "103ade833ddf3c7424d651a024490c054ee1e48a", "parents": ["d4c3d0d6a6f9cd9375d0592fb85b8262371bfe8d"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nit -\u003e 3153513d549d", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "066c263c74e602c82f97880e0892f8fdd6419637", "parents": ["103ade833ddf3c7424d651a024490c054ee1e48a"], "tags": []}], "date": 1517863292, "git_changesets": [null, null], "user": "ffxbld"}, "8654": {"changesets": [{"author": "Julien Cristau \u003cjcristau@mozilla.com\u003e", "branch": "default", "desc": "Post Beta 6: Unset EARLY_BETA_OR_EARLIER. a=release", "files": ["build/defines.sh"], "git_node": null, "git_parents": [null], "node": "1a24837f9ed232d8d2dc4535d11ee53c9847b109", "parents": ["066c263c74e602c82f97880e0892f8fdd6419637"], "tags": ["DEVEDITION_59_0b7_BUILD1", "DEVEDITION_59_0b7_RELEASE", "FENNEC_59_0b7_BUILD1", "FENNEC_59_0b7_RELEASE", "FIREFOX_59_0b7_BUILD1", "FIREFOX_59_0b7_RELEASE"]}], "date": 1517865450, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "8655": {"changesets": [{"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 832990 - Part 0 - Improve comment wording. r=Grisha. a=comment-only\n\nSince custom tabs and PWAs were moved to GeckoView, we're down to one\nGeckoApp-based activity again.\n\nMozReview-Commit-ID: 1zO6JTDptpp", "files": ["mobile/android/base/java/org/mozilla/gecko/GeckoApp.java"], "git_node": null, "git_parents": [null], "node": "565b8dcd3e87a78507323bded95fc468b2bd2300", "parents": ["1a24837f9ed232d8d2dc4535d11ee53c9847b109"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 832990 - Part 1 - Make MenuItemInfo classes parcelable. r=Grisha. a=RyanVM\n\nLonger term, the MenuItemInfo handling needs to be moved out of BrowserApp in\norder to solve bug 1414084 [1], but the easier short term solution is to just\nsave the cached menu data via the savedInstanceState. This means that\nMenuItemInfo and friends have to be made parcelable.\n\n\n[1] Because of GeckoView, add-ons may load (and attempt to add menu items) while\nBrowserApp isn't even alive.\n\nMozReview-Commit-ID: HzPe7ZKbJOj", "files": ["mobile/android/base/java/org/mozilla/gecko/BrowserApp.java"], "git_node": null, "git_parents": [null], "node": "86d6ff85a12102157fc3db46d9fb4fcd49c2c2e9", "parents": ["565b8dcd3e87a78507323bded95fc468b2bd2300"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 832990 - Part 2 - Save and restore menu item caches via savedInstanceState. r=Grisha. a=RyanVM\n\nMozReview-Commit-ID: 6x5BDqhwabS", "files": ["mobile/android/base/java/org/mozilla/gecko/BrowserApp.java"], "git_node": null, "git_parents": [null], "node": "42a636fb6dce797f066d585db45e86505c272872", "parents": ["86d6ff85a12102157fc3db46d9fb4fcd49c2c2e9"], "tags": []}, {"author": "Amy Chung \u003camchung\u003e", "branch": "default", "desc": "Bug 1425031 - Don't broadcast to content processes cookie updates that initiated in content processes. r=jdm. a=RyanVM", "files": ["dom/ipc/ContentParent.cpp", "netwerk/cookie/CookieServiceParent.cpp", "netwerk/cookie/nsCookieService.cpp", "netwerk/cookie/nsCookieService.h", "netwerk/test/mochitests/file_1331680.js", "netwerk/test/mochitests/mochitest.ini", "netwerk/test/mochitests/test_1425031.html"], "git_node": null, "git_parents": [null], "node": "e87e706def11e307c8d2bcb2ba3e23d7c3eead9f", "parents": ["42a636fb6dce797f066d585db45e86505c272872"], "tags": []}, {"author": "Chris Pearce \u003ccpearce@mozilla.com\u003e", "branch": "default", "desc": "Bug 1433309 - Annotate createMediaKeys promise reject with whether failure occurred due to pending shutdown. r=gerald. a=lizzard\n\nAround every Firefox update, Netflix see a spike in\nMediaKeySystemAccess.createMediaKeys() promise rejects. I am wondering whether\nthis is caused by the browser restarting to apply a Firefox update while\nNetflix's player is loading.  So add more detail to the promise reject as to\nthe state of the system, to try to validate that theory.\n\nMozReview-Commit-ID: 4IDPsFwKCtq", "files": ["dom/media/gmp/ChromiumCDMParent.cpp", "dom/media/gmp/ChromiumCDMParent.h", "dom/media/gmp/ChromiumCDMProxy.cpp", "dom/media/gmp/GMPService.cpp", "dom/media/gmp/GMPService.h", "dom/media/gmp/GMPServiceChild.cpp", "dom/media/gmp/GMPServiceParent.cpp", "dom/media/gtest/TestCDMStorage.cpp"], "git_node": null, "git_parents": [null], "node": "08e9d3a3a6b13997cac9fa92231f1b17cb00c527", "parents": ["e87e706def11e307c8d2bcb2ba3e23d7c3eead9f"], "tags": []}, {"author": "David Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "bug 1434831 - ensure nsITransportSecurityInfo.failedCertChain contains the *peer cert chain* r=jcj a=lizzard\n\nIn bug 1406856 the failedCertChain property of nsITransportSecurityInfo was\nchanged to hold the built certificate chain out parameter from the call to\nCertVerifier::VerifySSLServerCert. However, this was incorrect for two reasons:\na) failedCertChain is supposed to be the peer cert chain delivered by the server\nin the TLS handshake and\nb) if VerifySSLServerCert returns a failing result, the out parameter is not\nguaranteed to hold any meaningful information, and must not be used.\nThis patch sets failedCertChain to the appropriate value.\n\nMozReview-Commit-ID: BEXs5XH9SpK", "files": ["security/manager/ssl/SSLServerCertVerification.cpp", "security/manager/ssl/tests/unit/test_cert_chains.js"], "git_node": null, "git_parents": [null], "node": "d15af2a5aa189688f925b8d0f0cfff767ca708c6", "parents": ["08e9d3a3a6b13997cac9fa92231f1b17cb00c527"], "tags": []}], "date": 1517926538, "git_changesets": [null, null, null, null, null, null], "user": "nbeleuzu@mozilla.com"}, "8656": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "Automatic version bump. CLOSED TREE NO BUG a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "5a2d33d40dc320f449e5cbd3dcf81b341f9c84fa", "parents": ["d15af2a5aa189688f925b8d0f0cfff767ca708c6"], "tags": []}, {"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging 1a24837f9ed232d8d2dc4535d11ee53c9847b109 with FIREFOX_59_0b7_BUILD1, FIREFOX_59_0b7_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "1a4c612e4a0749dd40b84c01ca57ad4c539ecb72", "parents": ["5a2d33d40dc320f449e5cbd3dcf81b341f9c84fa"], "tags": []}], "date": 1517933327, "git_changesets": [null, null], "user": "ffxbld"}, "8657": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging 1a24837f9ed232d8d2dc4535d11ee53c9847b109 with DEVEDITION_59_0b7_BUILD1, DEVEDITION_59_0b7_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "6ec77ca75c68cdcccd9eb5c98412163e735b6fb6", "parents": ["1a4c612e4a0749dd40b84c01ca57ad4c539ecb72"], "tags": []}], "date": 1517934169, "git_changesets": [null], "user": "ffxbld"}, "8658": {"changesets": [{"author": "Aki Sasaki \u003casasaki@mozilla.com\u003e", "branch": "default", "desc": "bug 1431799 - add `version` input to release promotion action. r=bhearsum\n\nalso clean up and move more config to the promotion config.\n\nMozReview-Commit-ID: FmTWNNPcEaZ", "files": ["taskcluster/docs/parameters.rst", "taskcluster/taskgraph/__init__.py", "taskcluster/taskgraph/actions/release_promotion.py", "taskcluster/taskgraph/decision.py", "taskcluster/taskgraph/parameters.py", "taskcluster/taskgraph/target_tasks.py", "taskcluster/taskgraph/util/scriptworker.py"], "git_node": null, "git_parents": [null], "node": "23d8e662a20348d7607d2e6803cb1d30881c29cf", "parents": ["6ec77ca75c68cdcccd9eb5c98412163e735b6fb6"], "tags": []}, {"author": "Aki Sasaki \u003casasaki@mozilla.com\u003e", "branch": "default", "desc": "bug 1431799 - add RC secondary tasks. r=bhearsum\n\nMozReview-Commit-ID: 2hq4K5QVbWy", "files": ["taskcluster/ci/release-secondary-balrog-publishing/kind.yml", "taskcluster/ci/release-secondary-notify-ship/kind.yml", "taskcluster/docs/kinds.rst", "taskcluster/taskgraph/target_tasks.py"], "git_node": null, "git_parents": [null], "node": "badd10b09c9a987061e116af4f64d7c9bdff5697", "parents": ["23d8e662a20348d7607d2e6803cb1d30881c29cf"], "tags": []}, {"author": "Aki Sasaki \u003casasaki@mozilla.com\u003e", "branch": "default", "desc": "bug 1431799 - rename desktop_release_type -\u003e release_type. r=bhearsum\n\nThis used to only be relevant to Devedition and Firefox releases.\nIn bug 1433536 we're going to add RC Fennec releases. Let's rename\nthe parameter now, for less parameters churn.\n\nMozReview-Commit-ID: 28e1Y5FG4On", "files": ["taskcluster/docs/parameters.rst", "taskcluster/taskgraph/actions/release_promotion.py", "taskcluster/taskgraph/decision.py", "taskcluster/taskgraph/parameters.py", "taskcluster/taskgraph/target_tasks.py", "taskcluster/taskgraph/transforms/release_updates.py"], "git_node": null, "git_parents": [null], "node": "b6ba8f32b192bd25a912159fb5b10562921d7507", "parents": ["badd10b09c9a987061e116af4f64d7c9bdff5697"], "tags": []}, {"author": "Aki Sasaki \u003casasaki@mozilla.com\u003e", "branch": "default", "desc": "bug 1431799 - add ship_fennec_rc relpro flavor. r=bhearsum a=release\n\nAlso add rc-{google-play-track,rollout-percentage} for RC pushapk.\n\nOne nice side effect of using the same push-apk kind: we don't re-run push-apk during the ship_fennec relpro flavor if we've run the ship_fennec_rc flavor with the same build. (Google Play would reject the same buildid.)\n\nThis is really for bug 1433536, but MozReview is forcing me to include this patch with the others for reasons.\n\nMozReview-Commit-ID: 69ymqVLv9E2", "files": ["taskcluster/ci/push-apk/kind.yml", "taskcluster/ci/release-secondary-notify-ship/kind.yml", "taskcluster/taskgraph/actions/release_promotion.py", "taskcluster/taskgraph/target_tasks.py", "taskcluster/taskgraph/transforms/push_apk.py"], "git_node": null, "git_parents": [null], "node": "99f0936f7d8ce1bc7ae6d5d5c513fb047ee4214e", "parents": ["b6ba8f32b192bd25a912159fb5b10562921d7507"], "tags": []}], "date": 1517943369, "git_changesets": [null, null, null, null], "user": "asasaki@mozilla.com"}, "8659": {"changesets": [{"author": "