fluent/migrate/context.py", "third_party/python/fluent/fluent/migrate/errors.py", "third_party/python/fluent/fluent/migrate/merge.py", "third_party/python/fluent/fluent/migrate/transforms.py", "third_party/python/fluent/fluent/migrate/util.py", "third_party/python/fluent/fluent/syntax/ast.py", "third_party/python/fluent/fluent/syntax/errors.py", "third_party/python/fluent/fluent/syntax/ftlstream.py", "third_party/python/fluent/fluent/syntax/parser.py", "third_party/python/fluent/fluent/syntax/serializer.py", "third_party/python/fluent/fluent/syntax/stream.py", "third_party/python/fluent/tools/migrate/blame.py", "third_party/python/fluent/tools/migrate/examples/about_dialog.py", "third_party/python/fluent/tools/migrate/examples/about_downloads.py", "third_party/python/fluent/tools/migrate/examples/bug_1291693.py", "third_party/python/fluent/tools/migrate/migrate-l10n.py"], "git_node": null, "git_parents": [null], "node": "c891235f733c6ab19dd5a523232570ab804bba1b", "parents": ["e61b91204cce35bc148e0bf6fa1e4bb537a51db0"], "tags": []}], "date": 1518518773, "git_changesets": [null, null, null, null, null, null, null, null], "user": "shindli@mozilla.com"}, "8694": {"changesets": [{"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1434538 - Don't lock while rescaling or copying video frame buffers. r=jib a=RyanVM\n\nMozReview-Commit-ID: 78bXkY8kBfV", "files": ["dom/media/webrtc/MediaEngineRemoteVideoSource.cpp"], "git_node": null, "git_parents": [null], "node": "ab0beff6b8b082aaa845286cd4ac738ae9fc8ddf", "parents": ["c891235f733c6ab19dd5a523232570ab804bba1b"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1434538 - Handle kAllocated in UpdateSingleSource. r=jib a=lizzard\n\nThis will make us properly process the constraints of an Allocate()\nhappening just after another Allocate().\n\nMozReview-Commit-ID: KHZfuKmJZSG", "files": ["dom/media/webrtc/MediaEngineRemoteVideoSource.cpp"], "git_node": null, "git_parents": [null], "node": "66fc17858fe7b4936b34e80b49a6f6f8ec89af37", "parents": ["ab0beff6b8b082aaa845286cd4ac738ae9fc8ddf"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1434538 - Allocate per-allocation members in Allocate(). r=jib a=lizzard\n\nThis removes the assumption that a Start() call always follows an Allocate()\ncall for the same allocation.\n\nWe still assume that Start() calls come in the same order as Allocate() calls,\nand that all Allocate() calls eventually get a Start() call.\n\nThis is fine, as all the paths causing Start() to not happen are related to\nshutdown.\n\nWhat we have to be careful with now is a call to Deallocate() where Stop()\ndidn't happen (because Start() didn't happen). There is probably no issue in\nnot cleaning up the arrays there, but we do just to stay sane.\n\nMozReview-Commit-ID: KmfTbZaT5bA", "files": ["dom/media/webrtc/MediaEngineCameraVideoSource.h", "dom/media/webrtc/MediaEngineRemoteVideoSource.cpp"], "git_node": null, "git_parents": [null], "node": "38f370417409110b1fc422bb3d4088a3a91f8ff1", "parents": ["66fc17858fe7b4936b34e80b49a6f6f8ec89af37"], "tags": []}], "date": 1518527343, "git_changesets": [null, null, null], "user": "ebalazs@mozilla.com"}, "8695": {"changesets": [{"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1427239 - Always create FormAssistPopup in WebAppActivity; r=droeh a=lizzard\n\nRight now we create FormAssistPopup in WebAppActivity based on whether\nthe manifest is successfully loaded. We should always create it because\nwe always try to destroy it in onDestroy().\n\nMozReview-Commit-ID: KskEZmYrDS1", "files": ["mobile/android/base/java/org/mozilla/gecko/webapps/WebAppActivity.java"], "git_node": null, "git_parents": [null], "node": "e1b7cf0d65abf9792e795b99f7875193969cf832", "parents": ["38f370417409110b1fc422bb3d4088a3a91f8ff1"], "tags": []}, {"author": "Hector Zhao \u003cbzhao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1427712 - full installer page to install optional extensions with partner distribution. r=mhowell a=lizzard\n\nMozReview-Commit-ID: FGIgyQTwfj", "files": ["browser/installer/windows/Makefile.in", "browser/installer/windows/nsis/defines.nsi.in", "browser/installer/windows/nsis/extensionsLocale.nsh", "browser/installer/windows/nsis/installer.nsi", "toolkit/mozapps/installer/windows/nsis/common.nsh"], "git_node": null, "git_parents": [null], "node": "ab285921713c97914561c3834dc4c1a6c31383cf", "parents": ["e1b7cf0d65abf9792e795b99f7875193969cf832"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1432716 - Group the \"Show search suggestions ahead of browsing history in address bar results\" checkbox with other search suggestion checkboxes. ui=shorlander r=adw a=lizzard\n\nMozReview-Commit-ID: CSuNpA0Yq0w", "files": ["browser/components/preferences/in-content/search.js", "browser/components/preferences/in-content/search.xul", "browser/components/preferences/in-content/tests/browser_searchShowSuggestionsFirst.js", "browser/themes/shared/incontentprefs/search.css"], "git_node": null, "git_parents": [null], "node": "152720a4efe7421404020e2728a05bf5af543919", "parents": ["ab285921713c97914561c3834dc4c1a6c31383cf"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1434925 - Skip drawing hidden toolbar elements; r=rbarker a=lizzard\n\nApparently a toolbar element can be zero-sized when we try to draw it to\nthe bitmap. We should just skip drawing in that case.\n\nMozReview-Commit-ID: LlFQX5uN20h", "files": ["mobile/android/base/java/org/mozilla/gecko/toolbar/CanvasDelegate.java"], "git_node": null, "git_parents": [null], "node": "70cc9d6d659f726d328bfd6b529b28adccd62b5e", "parents": ["152720a4efe7421404020e2728a05bf5af543919"], "tags": []}, {"author": "Byron Campen [:bwc] \u003cdocfaraday@gmail.com\u003e", "branch": "default", "desc": "Bug 1435013: Sync transceivers before creating offers/answers. r=jib a=lizzard\n\nMozReview-Commit-ID: EORXVc8Hnky", "files": ["dom/media/PeerConnection.js"], "git_node": null, "git_parents": [null], "node": "3c16503565e67e1a4046bf19016f7b4b15515532", "parents": ["70cc9d6d659f726d328bfd6b529b28adccd62b5e"], "tags": []}], "date": 1518528058, "git_changesets": [null, null, null, null, null], "user": "ebalazs@mozilla.com"}, "8696": {"changesets": [{"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1433552 - Allow zeroes to CamerasParent's FeasibilityDistance functions. r=jib a=lizzard\n\nGetting zeroes here is rare, but the numbers come from a platform API so no\nguarantees are given for them. This patch makes it as permissive as possible.\n\nMozReview-Commit-ID: 2bjPRzhk1L7", "files": ["dom/media/systemservices/CamerasParent.cpp"], "git_node": null, "git_parents": [null], "node": "10d1af7903cb7f348453e5cca0a7901e9f56faa5", "parents": ["3c16503565e67e1a4046bf19016f7b4b15515532"], "tags": []}, {"author": "Ian Moody \u003cmoz-ian@perix.co.uk\u003e", "branch": "default", "desc": "Bug 1435320 - Specify a default empty object for the Chart.js table header. r=Honza a=lizzard\n\nSo it doesn't break if one isn't supplied.\nAlso document the header argument.\n\nMozReview-Commit-ID: 8UAVztN12Gw", "files": ["devtools/client/shared/widgets/Chart.js"], "git_node": null, "git_parents": [null], "node": "47d05846b2c1459afec5c222b2328f2b0c4f6a0b", "parents": ["10d1af7903cb7f348453e5cca0a7901e9f56faa5"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1435499 - Guard against OOM when getting toolbar pixels; r=rbarker a=lizzard\n\nGuard against OOM errors when getting toolbar pixels, and send a failure\nmessage back to compositor when OOM happens.\n\nMozReview-Commit-ID: FooZlE979DD", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/gfx/DynamicToolbarAnimator.java"], "git_node": null, "git_parents": [null], "node": "47310c2f21485df8159da1e7022da778107b6d2f", "parents": ["47d05846b2c1459afec5c222b2328f2b0c4f6a0b"], "tags": []}, {"author": "Nicholas Hurley \u003churley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1436517 - Limit access to the server-timing header to HTTPS contexts. r=mcmanus a=lizzard\n\nThis also introduces a hidden pref to allow server-timing access from\nHTTP contexts for the purposes of our xpcshell tests. We'll remove that\nonce we get h2 (and therefore tls test) support for server-timing\ntrailers (https://bugzilla.mozilla.org/show_bug.cgi?id=1436601).\n\nThis does not reject or otherwise error when receiving server-timing\nheaders or trailers on non-HTTPS contexts, it just makes it unavailable\noutside the channel.\n\nMozReview-Commit-ID: qi4h0VQknE", "files": ["netwerk/protocol/http/HttpBaseChannel.cpp", "netwerk/protocol/http/nsHttpHandler.cpp", "netwerk/protocol/http/nsHttpHandler.h", "netwerk/test/unit/test_header_Server_Timing.js"], "git_node": null, "git_parents": [null], "node": "8507a552a358bf60a26d9c51be4016ea0eae8dce", "parents": ["47310c2f21485df8159da1e7022da778107b6d2f"], "tags": []}, {"author": "Bobby Holley \u003cbobbyholley@gmail.com\u003e", "branch": "default", "desc": "Bug 1436541 - Don't clobber the thread-local arenas when we happen to hit a large allocation. r=glandium a=lizzard\n\nMozReview-Commit-ID: 9i5B76vkNfr", "files": ["memory/build/mozjemalloc.cpp"], "git_node": null, "git_parents": [null], "node": "22be9d71d70b5c79486843468fc3766415e30c4f", "parents": ["8507a552a358bf60a26d9c51be4016ea0eae8dce"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1435530 - part 1: Add automated tests to check Alt + D works as Ctrl + L when Alt is content access key's modifier r=enndeakin+6102 a=test-only\n\nMozReview-Commit-ID: FG5sRJfTvue", "files": ["dom/events/moz.build", "dom/events/test/browser.ini", "dom/events/test/browser_shortcutkey_modifier_conflicts_with_content_accesskey_modifier.js"], "git_node": null, "git_parents": [null], "node": "544407b1ac2f2d4cb579a7b558693b63707ff5ec", "parents": ["22be9d71d70b5c79486843468fc3766415e30c4f"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1435530 - part 2: Make nsXBLWindowKeyHandler treat eAccessKeyNotFound as eKeyPress event r=enndeakin+6102 a=lizzard\n\nModifiers of shortcut keys may be same as modifier of content access keys.\n\nWhen focus is in the main process, such eKeyPress event is sent to remote\ncontent first.  Then, and if it's not handled in the remote content,\neAccessKeyNotFound is dispatched into the DOM tree in the main process.\nHowever, nsXBLWindowKeyHandler doesn't handle it as eKeyPress event.  So,\nit causes that shortcut keys whose modifier conflicts with content access key\nwon't be handled.\n\nThis patch just makes nsXBLWindowKeyHandler treat eAccessKeyNotFound as\neKeyPress event even though other shortcut keys which are handled by JS\nwon't be executed.  Perhaps, we should stop using eAccessKeyNotFound but\nit's too risky change for now.\n\nMozReview-Commit-ID: IJltg5gwBc5", "files": ["dom/ipc/TabParent.cpp", "dom/xbl/nsXBLWindowKeyHandler.cpp"], "git_node": null, "git_parents": [null], "node": "30d165841f3da737624edb48dbfe87442c916f96", "parents": ["544407b1ac2f2d4cb579a7b558693b63707ff5ec"], "tags": []}], "date": 1518529812, "git_changesets": [null, null, null, null, null, null, null], "user": "nerli@mozilla.com"}, "8697": {"changesets": [{"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1436248 - Don't use selectionchange event in browser-chrome test since it's not standardized yet whether it should be fired on \u003cinput\u003e and \u003ctextarea\u003e r=enndeakin+6102+6102 a=lizzard\n\nIn current draft, selectionchange event should be fired when Selection is\nchanged in Document.  However, selection of \u003cinput\u003e and \u003ctextarea\u003e is different\nfrom Selection in web standards (although our implementation uses Selection).\n\nSo, we should check it with SimpleText.executeSoon() for now since it might\nbe possible that selectionchange event in \u003cinput\u003e and \u003ctextarea\u003e would be\nremoved completely.\n\nMozReview-Commit-ID: APvMwbysDzs", "files": ["dom/events/test/browser_shortcutkey_modifier_conflicts_with_content_accesskey_modifier.js"], "git_node": null, "git_parents": [null], "node": "b76b1af27cc15b15a9b53a371eb33f27fc3859b0", "parents": ["30d165841f3da737624edb48dbfe87442c916f96"], "tags": []}, {"author": "Daniel Holbert \u003cdholbert@cs.stanford.edu\u003e", "branch": "default", "desc": "Bug 1324042: Fix trimmedOffsets arithmetic in GetRenderedText(). r=mats a=abillings\n\nMozReview-Commit-ID: H4ngU8Juyln", "files": ["layout/generic/nsTextFrame.cpp"], "git_node": null, "git_parents": [null], "node": "bec50ba1fb12aebde4e4065b2799bc730bc30010", "parents": ["b76b1af27cc15b15a9b53a371eb33f27fc3859b0"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1435670 - Remove assert when there's no capability for a device. r=jib a=lizzard\n\nNot all devices have capabilities. Our code is already setup to handle that\ncase by defaulting to a capability with width,height,maxFPS=0 and propagating\nthe failure to start.\n\nMozReview-Commit-ID: AZJKZeBrYC2", "files": ["dom/media/systemservices/CamerasParent.cpp"], "git_node": null, "git_parents": [null], "node": "18ee6c43696db0470138c203edd519a6cb65b0f5", "parents": ["bec50ba1fb12aebde4e4065b2799bc730bc30010"], "tags": []}], "date": 1518533071, "git_changesets": [null, null, null], "user": "archaeopteryx@coole-files.de"}, "8698": {"changesets": [{"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 8507a552a358 (bug 1436517) for failing modified xpcshell test netwerk/test/unit/test_header_Server_Timing.js. a=backout", "files": ["netwerk/protocol/http/HttpBaseChannel.cpp", "netwerk/protocol/http/nsHttpHandler.cpp", "netwerk/protocol/http/nsHttpHandler.h", "netwerk/test/unit/test_header_Server_Timing.js"], "git_node": null, "git_parents": [null], "node": "7590a5f25ea3eab7a8bf1ed118f394f6a01ea335", "parents": ["18ee6c43696db0470138c203edd519a6cb65b0f5"], "tags": []}], "date": 1518533652, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "8699": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "Automatic version bump. CLOSED TREE NO BUG a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "caa3a8b55ccab1b4c30cafaaab23d45b7b3b0da7", "parents": ["7590a5f25ea3eab7a8bf1ed118f394f6a01ea335"], "tags": []}, {"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging 7dcfefd76e4c48fb8635b11541dcbe43108a4431 with FENNEC_59_0b9_BUILD1, FENNEC_59_0b9_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "53d29f4b304457d18c789b6de12f558c2d4c5610", "parents": ["caa3a8b55ccab1b4c30cafaaab23d45b7b3b0da7"], "tags": []}], "date": 1518539250, "git_changesets": [null, null], "user": "ffxbld"}, "8700": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging 7dcfefd76e4c48fb8635b11541dcbe43108a4431 with FIREFOX_59_0b9_BUILD1, FIREFOX_59_0b9_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "a45f6bf98b9c406c0c2224dad28fd5e30f330f2a", "parents": ["53d29f4b304457d18c789b6de12f558c2d4c5610"], "tags": []}], "date": 1518542892, "git_changesets": [null], "user": "ffxbld"}, "8701": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging 7dcfefd76e4c48fb8635b11541dcbe43108a4431 with DEVEDITION_59_0b9_BUILD1, DEVEDITION_59_0b9_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "c0f3f8112b601b4af96edcc16667e7532c761d9b", "parents": ["a45f6bf98b9c406c0c2224dad28fd5e30f330f2a"], "tags": []}], "date": 1518543570, "git_changesets": [null], "user": "ffxbld"}, "8702": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\ncak -\u003e c3363478ee18\nte -\u003e d96ecedde0d6\nur -\u003e 52aff451f217", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "4ca8f3004071244dc6a92b7737d6c7275f620c66", "parents": ["c0f3f8112b601b4af96edcc16667e7532c761d9b"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nbe -\u003e 134adc7a15dd\nbr -\u003e f2858e537146\ncak -\u003e c3363478ee18\ncs -\u003e b1bed5ba91d8\ncy -\u003e 2d0d1e2a2cc6\nes-CL -\u003e 2c4dcc0db2ce\nfy-NL -\u003e 2d8ca726243b\ngu-IN -\u003e e1a6c32fa898\nhi-IN -\u003e 8f28f4e07b4d\nhu -\u003e 36335be80fe5\nia -\u003e fb2df0af8552\nit -\u003e 02fd3bb67a01\nkab -\u003e c80cd568cdff\nkk -\u003e e6cfe8285a74\nms -\u003e adac315289ae\nnl -\u003e 54211b2cc50d\nte -\u003e d96ecedde0d6\ntr -\u003e b838fe67b96f\nuk -\u003e a7e011fce9ae\nur -\u003e 52aff451f217\nzh-TW -\u003e 2b00c9271d9a", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "b1ede796f3e37196fb5f0dddeb78b6c4f98ea1d4", "parents": ["4ca8f3004071244dc6a92b7737d6c7275f620c66"], "tags": []}], "date": 1518607194, "git_changesets": [null, null], "user": "ffxbld"}, "8703": {"changesets": [{"author": "David Parks \u003cdparks@mozilla.com\u003e", "branch": "default", "desc": "Bug 1358372: Part 1 - Move Windows content process AudioSession init before sandbox lowering r=jimm a=ritu\n\nSomething about setting the grouping parameter was harmed by the sandbox.", "files": ["dom/ipc/ContentParent.cpp"], "git_node": null, "git_parents": [null], "node": "e9139fb87c850c1006ca03b5cb41443c0ed06a8c", "parents": ["b1ede796f3e37196fb5f0dddeb78b6c4f98ea1d4"], "tags": []}, {"author": "David Parks \u003cdparks@mozilla.com\u003e", "branch": "default", "desc": "Bug 1358372: Part 2 - Run Windows AudioSessionControl operations on main thread r=jimm a=ritu\n\nThis plays better with sndvol.exe.  It reduces the impact of a bug that shows multiple volume sliders for the content processes.", "files": ["accessible/ipc/win/HandlerProvider.h", "widget/windows/AudioSession.cpp"], "git_node": null, "git_parents": [null], "node": "444056446ee9c8c6c3c9a3471e4d68432881aa98", "parents": ["e9139fb87c850c1006ca03b5cb41443c0ed06a8c"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1405685 - Use geospecific defaults for all locales. r=florian a=ritu\n\nMozReview-Commit-ID: 6nAAvsoDZZu", "files": ["browser/app/profile/firefox.js", "browser/locales/en-US/firefox-l10n.js"], "git_node": null, "git_parents": [null], "node": "f8d212c4a686626116e66a38c9775890064966fd", "parents": ["444056446ee9c8c6c3c9a3471e4d68432881aa98"], "tags": []}, {"author": "Samael Wang \u003cfreesamael@gmail.com\u003e", "branch": "default", "desc": "Bug 1416307 - Set triggeringPrincipal to current document's principal, if aPrincipal is not given. r=bz a=ritu\n\nMozReview-Commit-ID: 8lxKFeUlyzq", "files": ["docshell/base/nsDocShell.cpp", "docshell/base/nsIRefreshURI.idl"], "git_node": null, "git_parents": [null], "node": "9df27a7142ffb065fb56c3fc873298988deacb98", "parents": ["f8d212c4a686626116e66a38c9775890064966fd"], "tags": []}, {"author": "Nicholas Hurley \u003churley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1416529 r=mcmanus a=ritu\nMozReview-Commit-ID: CD1l5vLB4yy", "files": ["netwerk/protocol/http/Http2Session.cpp", "netwerk/protocol/http/Http2Stream.cpp", "netwerk/protocol/http/Http2Stream.h"], "git_node": null, "git_parents": [null], "node": "8463e06147690aa1e683a8c3064fd9a8e3ed6b64", "parents": ["9df27a7142ffb065fb56c3fc873298988deacb98"], "tags": []}, {"author": "Florian Qu\u00e8ze \u003cflorian@queze.net\u003e", "branch": "default", "desc": "Bug 1418814 - the user specified background color should be used for the tabbrowser background when 'Always override the colors specified by the page' is selected, r=Gijs. a=ritu", "files": ["browser/base/content/tabbrowser.xml"], "git_node": null, "git_parents": [null], "node": "618633d326dd69a5e9f1fa68415b5b1b8bf563c0", "parents": ["8463e06147690aa1e683a8c3064fd9a8e3ed6b64"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1431264 part 1: Accessible HandlerProvider: Implement a method to retrieve info for all relations in a single call. r=MarcoZ a=ritu\n\nIAccessible2::relations allows you to fetch IAccessibleRelation objects for all relations.\nHowever, you must first call IAccessible2::nRelations to get the number of relations.\nIn addition, getting the type and number of targets for each relation requires additional calls.\nThis new method allows all of this to be retrieved in a single cross-process call.\n\nMozReview-Commit-ID: 3zEIjxEyMP5", "files": ["accessible/ipc/win/HandlerProvider.cpp", "accessible/ipc/win/HandlerProvider.h", "accessible/ipc/win/handler/HandlerData.idl"], "git_node": null, "git_parents": [null], "node": "e2ec2a10573d21fd773c9845b24d95081fcf195c", "parents": ["618633d326dd69a5e9f1fa68415b5b1b8bf563c0"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1431264 part 2: AccessibleHandler: Local implementation of IAccessibleRelation using data provided in IARelationData. r=MarcoZ a=ritu\n\nThe HandlerProvider::RelationsInfo method provides the type and number of targets for each relation in an IARelationData struct.\nThis local implementaition of IAccessibleRelation is constructed with an IARelationData struct and serves a single relation.\nIt uses the data from the struct to answer queries, except for actual targets.\nFor targets, it makes a remote call to IA2_2::relationTargetsOfType to answer the query.\nWe use relationTargetsOfType instead of IARelation::targets because marshaling so many IARelation pointers is a major bottleneck.\n\nMozReview-Commit-ID: Dva00FhoSbx", "files": ["accessible/ipc/win/handler/HandlerRelation.cpp", "accessible/ipc/win/handler/HandlerRelation.h", "accessible/ipc/win/handler/moz.build"], "git_node": null, "git_parents": [null], "node": "617e767b8af15c1d81f1f512193c76747837c62f", "parents": ["e2ec2a10573d21fd773c9845b24d95081fcf195c"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1431264 part 3: AccessibleHandler: If a client wants to query all relations, fetch as much info as possible in a single cross-process call. r=MarcoZ a=ritu\n\nIf a client calls IAccessible2::nRelations, it's likely that it will next call IAccessible2::relations to query each relation.\nFurthermore, it's likely the client will call relationType and nTargets on each relation.\nTherefore, fetch all of this info when nRelations is called.\nThe number of relations is immediately returned to the client.\nThe rest of the info is cached and returned to the client when the appropriate methods are called.\nThe info is only cached for one call; i.e. after the client calls relations once, the cache is dropped.\nThis makes memory management simpler and lowers the risk of cache invalidation problems.\n\nMozReview-Commit-ID: IBoJbu42osG", "files": ["accessible/ipc/win/handler/AccessibleHandler.cpp", "accessible/ipc/win/handler/AccessibleHandler.h"], "git_node": null, "git_parents": [null], "node": "6f99bde986e07b6606f172483ce0e1384fd22bd9", "parents": ["617e767b8af15c1d81f1f512193c76747837c62f"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1432160 - Initialize PushService for custom tabs / PWA; r=snorp a=ritu\n\nWe currently initialize PushService on delayed startup, which only\nhappens when Fennec is launched. This patch makes us also initialize\nPushService if needed by web content from custom tabs / PWA, by\nlistening for the push initialization event in GeckoApplication.\n\nMozReview-Commit-ID: 9CTOEZmOqls", "files": ["mobile/android/base/java/org/mozilla/gecko/GeckoApplication.java", "mobile/android/base/java/org/mozilla/gecko/push/PushService.java"], "git_node": null, "git_parents": [null], "node": "31a1ad5257ecfd6b3d5d79c34c3ff286d390d77e", "parents": ["6f99bde986e07b6606f172483ce0e1384fd22bd9"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1432385 - Use window manager borders on LXQt, r=jhorak a=ritu\n\nMozReview-Commit-ID: JkyBMBovCIG", "files": ["widget/gtk/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "0128f159f3a3aabd70b0b6bddc50255c907bc7a6", "parents": ["31a1ad5257ecfd6b3d5d79c34c3ff286d390d77e"], "tags": []}, {"author": "Milan Sreckovic \u003cmilan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1432411: Wallpaper over the case where there is no Screen. r=jgilbert a=ritu\n\nMozReview-Commit-ID: ISeBw7qxGdH", "files": ["gfx/layers/client/CanvasClient.cpp"], "git_node": null, "git_parents": [null], "node": "38c1798e2a2e7d06733f1d715af22d3d44d454e7", "parents": ["0128f159f3a3aabd70b0b6bddc50255c907bc7a6"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1433869 - Disable CSD titlebar mode on untested/unknown systems for Release/Beta, r=jhorak a=ritu\n\nMozReview-Commit-ID: JRF0BAbtkRN", "files": ["widget/gtk/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "cb55e5e2cdd5eb7e953b73f4bfce6c14a38b1c35", "parents": ["38c1798e2a2e7d06733f1d715af22d3d44d454e7"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1434861 - Simplify rescaling code in MediaEngineRemoteVideoSource::DeliverFrame. r=jib a=ritu\n\nMost importantly, this reduces the number of copies to 1 in the common case.\nIn a case where we are rescaling because there are competing gUM requests\nthis does two copies, where one is the crop-and-scale operation itself.\n\nIn the worst case we do two allocations, but with a buffer pool and a recycling\nImageContainer we allocate very rarely in practice.\n\nMozReview-Commit-ID: B0Et4wZol9n", "files": ["dom/media/webrtc/MediaEngineCameraVideoSource.h", "dom/media/webrtc/MediaEngineRemoteVideoSource.cpp"], "git_node": null, "git_parents": [null], "node": "1b25b61d773b47ad1ca081c2c88b0ae9286a38d3", "parents": ["cb55e5e2cdd5eb7e953b73f4bfce6c14a38b1c35"], "tags": []}, {"author": "Karl Tomlinson \u003ckarlt+@karlt.net\u003e", "branch": "default", "desc": "bug 1436267 fallback from audio callback to system clock driver on error only once r=padenot a=ritu\n\nUsually, mShouldFallbackIfError has been reset to false in DataCallback()\nbefore Stop() is called.  However, if fallback to a system clock driver due to\ncubeb error had already occurred, then mShouldFallbackIfError would not have\nbeen reset, and Stop() is still called.  With mShouldFallbackIfError still\ntrue, a cubeb error in stop would have created another fallback thread.\n\nI expect that resetting mShouldFallbackIfError in Stop() would also be an\neffective alternative solution, but resetting on StateCallback() happens\nearlier, which would be an advantage if any additional errors could possibly\nbe reported to StateCallback().\n\nMozReview-Commit-ID: E9j7PQmS3O4", "files": ["dom/media/GraphDriver.cpp"], "git_node": null, "git_parents": [null], "node": "2e8b4957bf5f477c66ef4da8390426d261b1daf2", "parents": ["1b25b61d773b47ad1ca081c2c88b0ae9286a38d3"], "tags": []}, {"author": "sotaro \u003csotaro.ikeda.g@gmail.com\u003e", "branch": "default", "desc": "Bug 1436466 - Set dirty in CopyableCanvasRenderer::ClearCachedResources() r=jrmuizel a=ritu\n\nbug 1379920 changed the way of dirty flag handling. And the dirty flag was not set when CopyableCanvasRenderer::ClearCachedResources() is called. Then ShareableCanvasRenderer::UpdateCompositableClient() did not update canvas.", "files": ["gfx/layers/CopyableCanvasRenderer.cpp"], "git_node": null, "git_parents": [null], "node": "ff9753468f8c52fb2c29ab76bc888675335bee26", "parents": ["2e8b4957bf5f477c66ef4da8390426d261b1daf2"], "tags": []}, {"author": "Nicholas Hurley \u003churley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1436517 - Limit access to the server-timing header to HTTPS contexts. r=mcmanus a=ritu\nThis also introduces a hidden pref to allow server-timing access from\nHTTP contexts for the purposes of our xpcshell tests. We'll remove that\nonce we get h2 (and therefore tls test) support for server-timing\ntrailers (https://bugzilla.mozilla.org/show_bug.cgi?id=1436601).\n\nThis does not reject or otherwise error when receiving server-timing\nheaders or trailers on non-HTTPS contexts, it just makes it unavailable\noutside the channel.\n\nMozReview-Commit-ID: qi4h0VQknE", "files": ["netwerk/protocol/http/HttpBaseChannel.cpp", "netwerk/protocol/http/nsHttpHandler.cpp", "netwerk/protocol/http/nsHttpHandler.h", "netwerk/test/unit/test_header_Server_Timing.js"], "git_node": null, "git_parents": [null], "node": "4e1f1641976cd22428ba7bbec063d2eb8ff9c8cb", "parents": ["ff9753468f8c52fb2c29ab76bc888675335bee26"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1437213 - Revert top site pref to show 1 row instead of 2 rows for 59. r=dmose a=ritu on a CLOSED TREE\n\nMozReview-Commit-ID: 8mblhw6IoJ", "files": ["browser/extensions/activity-stream/common/PrerenderData.jsm", "browser/extensions/activity-stre