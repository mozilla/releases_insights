02bf6f7580"], "tags": []}], "date": 1517247262, "git_changesets": [null], "user": "ffxbld"}, "8609": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging 64737c752ac4af4766ad6f82720818521f3aca24 with FENNEC_59_0b5_BUILD1, FENNEC_59_0b5_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "d4c9c277daebc12801df7ee20fcf990911ddf23e", "parents": ["e38e2989ee4ef65ba339703d035e848833dcf86d"], "tags": []}], "date": 1517249222, "git_changesets": [null], "user": "ffxbld"}, "8610": {"changesets": [{"author": "Maja Frydrychowicz \u003cmjzffr@gmail.com\u003e", "branch": "default", "desc": "Bug 1432773 - listen for unload in capture phase to reset click count; r=whimboo a=test-only\n\nThe bubbling phase is too late so resetClick didn't always get called.\n\nMozReview-Commit-ID: JIseY5o3oAX", "files": ["testing/marionette/listener.js"], "git_node": null, "git_parents": [null], "node": "d791950b5abd3e4a3f767296183dde9ad315c996", "parents": ["d4c9c277daebc12801df7ee20fcf990911ddf23e"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1433390 - Move all assert helps into support.asserts. r=jgraham a=test-only\n\nFor a better management of assertion helpers those should be\nadded to the central assertion helper module.\n\nMozReview-Commit-ID: DYMfOFl9Fjd", "files": ["testing/web-platform/tests/webdriver/tests/actions/mouse.py", "testing/web-platform/tests/webdriver/tests/actions/mouse_dblclick.py", "testing/web-platform/tests/webdriver/tests/actions/support/mouse.py", "testing/web-platform/tests/webdriver/tests/support/asserts.py"], "git_node": null, "git_parents": [null], "node": "982cc606296b0945a3848016ea4e00c8c5cd620c", "parents": ["d791950b5abd3e4a3f767296183dde9ad315c996"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1433390 - Use register_assert_rewrite to enable introspection in assertion helper. r=jgraham a=test-only\n\nPytest by default only loads test modules, and enables assert\nintrospection for them. For any helper method which also uses\nasserts, only a plain assertion is printed.\n\nTo enable introspection also for the assertion helper, the\nmodule has to be registered for assertion rewrite.\n\nMozReview-Commit-ID: 97JzuykXxWE", "files": ["testing/web-platform/tests/webdriver/tests/__init__.py"], "git_node": null, "git_parents": [null], "node": "24685f33b77a0c4fa4073441de605b728e37971c", "parents": ["982cc606296b0945a3848016ea4e00c8c5cd620c"], "tags": []}], "date": 1517252184, "git_changesets": [null, null, null], "user": "archaeopteryx@coole-files.de"}, "8611": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nbe -\u003e 00c024013130\nbg -\u003e 49edf25326e2\nbn-BD -\u003e a343eb0738da\nes-AR -\u003e 928db9656474\nfr -\u003e 66b2f81a2e03\nid -\u003e 96e3d18dbcff\nlv -\u003e 9cc3a318c8e9", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "0b253c293596e14dc39a29d5388866e624555a88", "parents": ["24685f33b77a0c4fa4073441de605b728e37971c"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nbe -\u003e 2aeda190e8ad\nbg -\u003e 49edf25326e2\ncy -\u003e 5485d8b21110\ndsb -\u003e ca9075be5049\nes-AR -\u003e 928db9656474\nfy-NL -\u003e cb861a24ac66\nhsb -\u003e 055b28a3cb4b\nhu -\u003e a9bd14c310bc\nid -\u003e 96e3d18dbcff\nka -\u003e da1f6caea10e\nlv -\u003e 9cc3a318c8e9\nnl -\u003e 2dc42ff70f83\npt-BR -\u003e 47fd5d9ef873\nsv-SE -\u003e 3d8a8c566013\nte -\u003e 121a42397704", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "0c9fca