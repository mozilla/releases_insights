itest.ini", "dom/indexedDB/test/test_upgrade_add_index.html", "dom/indexedDB/test/unit/test_upgrade_add_index.js", "dom/indexedDB/test/unit/xpcshell-shared.ini"], "git_node": null, "git_parents": [null], "node": "71516540db51fd17d6d938ea224c3231fe636fd5", "parents": ["bfa90e7a245f0496e9434796681674f7b5f54ace"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430053 - Add prefs for index masking Spectre mitigations. r=luke,mccr8", "files": ["dom/ipc/ContentPrefs.cpp", "js/src/jit/JitOptions.cpp", "js/src/jit/JitOptions.h", "js/src/jsapi.cpp", "js/src/jsapi.h", "js/src/shell/js.cpp", "js/xpconnect/src/XPCJSContext.cpp", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "a98f615965d73f6462924188fc2b1f2a620337bb", "parents": ["71516540db51fd17d6d938ea224c3231fe636fd5"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430561 - Make sure the empty elements header is followed by an unused Value. r=luke", "files": ["js/src/vm/NativeObject.cpp"], "git_node": null, "git_parents": [null], "node": "4dc616cbbb203e6b36ae21507359e70481a25919", "parents": ["a98f615965d73f6462924188fc2b1f2a620337bb"], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1431130 - Ensure we retain the lock when accessing sLayerIndirectTree off the compositor thread. r=botond\n\nCompositorBridgeParent::GetIndirectShadowTree is meant to be a\ncompositor thread only method. This however was not enforced with an\nassert and over time we began using it on the main thread for simple\naccesses. These accesses should generally be safe on the main thread,\ndepending on the individual access, but not outside the lock\nGetIndirectShadowTree holds. As such, a safer variant is provided to\nexecute a lambda inside the lock context, and the unsafe variant will\nassert it is indeed in the compositor thread context.", "files": ["gfx/layers/apz/src/APZCTreeManager.cpp", "gfx/layers/apz/src/APZCTreeManager.h", "gfx/layers/ipc/CompositorBridgeParent.cpp", "gfx/layers/ipc/CompositorBridgeParent.h", "gfx/layers/ipc/UiCompositorControllerParent.cpp"], "git_node": null, "git_parents": [null], "node": "3919edc6531353d70f57214ec2f7ae7376010763", "parents": ["4dc616cbbb203e6b36ae21507359e70481a25919"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Backed out 11 changesets (bug 1382251) for clipbloard failures, mingw32 bustage\n\nBacked out changeset a5f447c3bde8 (bug 1382251)\nBacked out changeset f9f8aba058c1 (bug 1382251)\nBacked out changeset dc0ce4cae588 (bug 1382251)\nBacked out changeset 7a304ff7873a (bug 1382251)\nBacked out changeset 09cb062d95ee (bug 1382251)\nBacked out changeset 95701ac611fa (bug 1382251)\nBacked out changeset 37cad137215f (bug 1382251)\nBacked out changeset 0d82d0b69c9e (bug 1382251)\nBacked out changeset 24de376fb860 (bug 1382251)\nBacked out changeset 5f33ad77c5b4 (bug 1382251)\nBacked out changeset d2f531c6a6d8 (bug 1382251)", "files": ["dom/plugins/ipc/FunctionBroker.cpp", "dom/plugins/ipc/FunctionBroker.h", "dom/plugins/ipc/FunctionBrokerChild.cpp", "dom/plugins/ipc/FunctionBrokerChild.h", "dom/plugins/ipc/FunctionBrokerIPCUtils.cpp", "dom/plugins/ipc/FunctionBrokerIPCUtils.h", "dom/plugins/ipc/FunctionBrokerParent.cpp", "dom/plugins/ipc/FunctionBrokerParent.h", "dom/plugins/ipc/FunctionBrokerThread.h", "dom/plugins/ipc/FunctionHook.cpp", "dom/plugins/ipc/FunctionHook.h", "dom/plugins/ipc/IpdlTuple.h", "dom/plugins/ipc/PFunctionBroker.ipdl", "dom/plugins/ipc/PPluginModule.ipdl", "dom/plugins/ipc/PluginMessageUtils.cpp", "dom/plugins/ipc/PluginMessageUtils.h", "dom/plugins/ipc/PluginModuleChild.cpp", "dom/plugins/ipc/PluginModuleChild.h", "dom/plugins/ipc/PluginModuleParent.cpp", "dom/plugins/ipc/PluginModuleParent.h", "dom/plugins/ipc/PluginProcessChild.cpp", "dom/plugins/ipc/PluginProcessParent.h", "dom/plugins/ipc/PluginQuirks.h", "dom/plugins/ipc/moz.build", "ipc/glue/IPCMessageUtils.h", "ipc/ipdl/sync-messages.ini", "toolkit/xre/nsAppRunner.cpp", "toolkit/xre/test/win/TestDllInterceptor.cpp", "xpcom/build/nsWindowsDllInterceptor.h", "xpcom/build/nsXULAppAPI.h"], "git_node": null, "git_parents": [null], "node": "398fb8533bcb1ca48b5977ef04e3efa97b089214", "parents": ["3919edc6531353d70f57214ec2f7ae7376010763"], "tags": []}, {"author": "Kai Engert \u003ckaie@kuix.de\u003e", "branch": "default", "desc": "Bug 1420407, uplift NSPR_4_18_RTM, no code change, only version number. Require version 4.18 for building. r=me\nUPGRADE_NSPR_RELEASE", "files": ["nsprpub/TAG-INFO", "nsprpub/config/prdepend.h", "nsprpub/pr/include/prinit.h", "old-configure.in"], "git_node": null, "git_parents": [null], "node": "2e91a03fa6b8e72435aed05993dff55ec4ce0047", "parents": ["398fb8533bcb1ca48b5977ef04e3efa97b089214"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430053 followup - Use this-\u003e in Cell::as() to work around a weird intermittent compiler error. r=me", "files": ["js/src/gc/Cell.h"], "git_node": null, "git_parents": [null], "node": "e7d03e11f55a7f9d3dd22017cfeb8a88634f2626", "parents": ["2e91a03fa6b8e72435aed05993dff55ec4ce0047"], "tags": []}, {"author": "arthur.iakab \u003caiakab@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to mozilla-inbound. a=merge", "files": [], "git_node": null, "git_parents": [null, null], "node": "51d4b45e54e3ee85e1bef88b3def5369fb70ad21", "parents": ["e7d03e11f55a7f9d3dd22017cfeb8a88634f2626", "0a543687fd36bc0dc4188c3d33d117b0a8174721"], "tags": []}, {"author": "Ekanan Ketunuti \u003cananuti@gmail.com\u003e", "branch": "default", "desc": "Bug 1430714 - Remove duplicate words. r=jet", "files": ["extensions/spellcheck/locales/en-US/hunspell/en-US.dic"], "git_node": null, "git_parents": [null], "node": "5889cb86d834d4689720f0ce376e83cbecef037c", "parents": ["51d4b45e54e3ee85e1bef88b3def5369fb70ad21"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1430123 - Add vendor capability for old Pointer Origin behavior. r=ato\n\nWith the WebDriver spec the calculation of the pointer origin\nposition will no longer be done based on the top and left\nposition of the referenced element, but based on the center\npoint of the viewport.\n\nThis capability allows to turn on and off the new behavior in\nFirefox 59 and following.\n\nMozReview-Commit-ID: Ir3HpgvVg6Y", "files": ["testing/geckodriver/CHANGES.md", "testing/geckodriver/README.md", "testing/geckodriver/src/capabilities.rs"], "git_node": null, "git_parents": [null], "node": "d97649d30062fb55af2e8de3631a854afa52ab94", "parents": ["a4a6b952ba39cb2ecf9bf3de217f61b1b1b143cd"], "tags": []}, {"author": "Kit Cambridge \u003ckit@yakshaving.ninja\u003e", "branch": "default", "desc": "Bug 1431149 - Add an optional schema name argument to `OpenedConnection#{get, set}SchemaVersion`. r=mak\n\nMozReview-Commit-ID: 8Uk1Vuqc1lc", "files": ["toolkit/modules/Sqlite.jsm", "toolkit/modules/tests/xpcshell/test_sqlite.js"], "git_node": null, "git_parents": [null], "node": "410a941bdce8c11ec1da55d6cc541b93a93dda5c", "parents": ["d97649d30062fb55af2e8de3631a854afa52ab94"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 4581da0d9525 (bug 1431155) for failing Browser-chrome on browser/base/content/test/static/browser_all_files_referenced.js on a CLOSED TREE", "files": ["testing/marionette/browser.js", "testing/marionette/driver.js", "testing/marionette/wm.js"], "git_node": null, "git_parents": [null], "node": "7ed62b395dc2b4c0f50cb1d97abf9ddb8d10e86f", "parents": ["410a941bdce8c11ec1da55d6cc541b93a93dda5c"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1404371 - migrate and rename browser_webconsole_input_expansion.js;r=Honza\n\nMozReview-Commit-ID: JAS13KdCDoP", "files": ["devtools/client/webconsole/new-console-output/test/mochitest/browser.ini", "devtools/client/webconsole/new-console-output/test/mochitest/browser_jsterm_input_expansion.js", "devtools/client/webconsole/new-console-output/test/mochitest/browser_webconsole_input_expansion.js"], "git_node": null, "git_parents": [null], "node": "d7bb0c1fef886df88f8971f9474b4d678f6a67ec", "parents": ["7ed62b395dc2b4c0f50cb1d97abf9ddb8d10e86f"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1431194 - avoid timeouts when clearing prefs set via pushPrefEnv;r=jmaher\n\nMozReview-Commit-ID: 1EYsxYnj2GE", "files": ["testing/mochitest/tests/Harness_sanity/test_SpecialPowersPushPrefEnv.html", "testing/specialpowers/content/specialpowersAPI.js"], "git_node": null, "git_parents": [null], "node": "f746bffde0ffec556fb712458d8b569efee490c1", "parents": ["d7bb0c1fef886df88f8971f9474b4d678f6a67ec"], "tags": []}, {"author": "tigercosmos \u003cphy.tiger@gmail.com\u003e", "branch": "default", "desc": "servo: Merge #19713 - auto clean cache in build bot (from tigercosmos:r1); r=jdm\n\n\u003c!-- Please describe your changes on the following line: --\u003e\nauto clean cache in build bot\n\nonce this merged, servo/saltfs#321 should be closed\n\n---\n\u003c!-- Thank you for contributing to Servo! Please replace each `[ ]` by `[X]` when the step is complete, and replace `__` with appropriate data: --\u003e\n- [X] `./mach build -d` does not report any errors\n- [X] `./mach test-tidy` does not report any errors\n- [X] These changes fix #19712  (github issue number if applicable).\n\n\u003c!-- Either: --\u003e\n- [ ] There are tests for these changes OR\n- [ ] These changes do not require tests because _____\n\n\u003c!-- Also, please make sure that \"Allow edits from maintainers\" checkbox is checked, so that we can help you if you get stuck somewhere along the way.--\u003e\n\n\u003c!-- Pull requests that do not address these steps are welcome, but they will require additional verification as part of the review process. --\u003e\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: d11886e9a12c2ef7262e34de3de7595005a66080", "files": ["servo/appveyor.yml", "servo/etc/ci/buildbot_steps.yml", "servo/python/servo/bootstrap_commands.py"], "git_node": null, "git_parents": [null], "node": "9d2dd504726a51f7a0c9727eea80ee3c47b4901a", "parents": ["f746bffde0ffec556fb712458d8b569efee490c1"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1431069 - allow eslint to deal with ChromeUtils imports, r=standard8\n\nMozReview-Commit-ID: KHVewE1Rrov", "files": ["tools/lint/eslint/eslint-plugin-mozilla/lib/helpers.js", "tools/lint/eslint/eslint-plugin-mozilla/lib/rules/no-import-into-var-and-global.js", "tools/lint/eslint/eslint-plugin-mozilla/lib/rules/no-single-arg-cu-import.js", "tools/lint/eslint/eslint-plugin-mozilla/tests/test-no-import-into-var-and-global.js", "tools/lint/eslint/eslint-plugin-mozilla/tests/test-no-single-arg-cu-import.js"], "git_node": null, "git_parents": [null], "node": "046fb034b32344a48035b423240127a3a7731c17", "parents": ["9d2dd504726a51f7a0c9727eea80ee3c47b4901a"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1431334 - Fix typo in getNewCurrentGroup;r=bgrins.\n\nReplaces \"currentGoup\" with \"currentGroup\".\n\nMozReview-Commit-ID: 1s34ko24b1i", "files": ["devtools/client/webconsole/new-console-output/reducers/messages.js"], "git_node": null, "git_parents": [null], "node": "56c0944b999dddebef68d4ea82c15456bc16d870", "parents": ["046fb034b32344a48035b423240127a3a7731c17"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1431041: Make placeholder apply to \u003cinput type=\"number\"\u003e. r=smaug\n\nMozReview-Commit-ID: GLbdLxHLiH