 "git_parents": [null], "node": "c68efeeab64f779652a13a257cfdcc1caf78b4e4", "parents": ["f735779189fb757fa5307072865252c16f7589b7"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nar -\u003e 837331ffed93\ndsb -\u003e 5a297047ce59\nfr -\u003e c1d8bcb0aa02\nka -\u003e 63e2112afffa\nlt -\u003e bae5e9103f18\nnn-NO -\u003e 3d8a3c457ae8\npl -\u003e a3674c7645d5\npt-BR -\u003e 92d19502dc4b\npt-PT -\u003e 16bc22fe3af3\nsk -\u003e 66f477806839\nsl -\u003e de8695405ed7\nta -\u003e bb8b0ddfca62", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "b062a5040e113655bd30a853da1f753c10fe4a18", "parents": ["c68efeeab64f779652a13a257cfdcc1caf78b4e4"], "tags": []}], "date": 1519806056, "git_changesets": [null, null], "user": "ffxbld"}, "8785": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nff -\u003e cf8adeefcb43\nkab -\u003e b0c70bc343c4", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "5e0608b82eb34151cf7fb49248354b2251f2a83d", "parents": ["b062a5040e113655bd30a853da1f753c10fe4a18"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nbn-BD -\u003e 1dca69298009\nbr -\u003e 21383fce0aeb\nff -\u003e 4b8c547d8127\nkab -\u003e b0c70bc343c4", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "7690c7e5ef4a05cf2b4a1985268ec55fda6a15cf", "parents": ["5e0608b82eb34151cf7fb49248354b2251f2a83d"], "tags": []}], "date": 1519809615, "git_changesets": [null, null], "user": "ffxbld"}, "8786": {"changesets": [{"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1350349 - collect data for feed reader usage to evaluate its future, r=mak,data-review=liuche, a=lizzard\n\nThis patch adds data collection for 6 different data points:\n- number of live bookmarks the user has\n- number of times the user subscribes to a feed\n- number of times we attempt to open feed preview\n- number of times the user opens a feed popup in the UI\n- number of times the user opens an entry from a feed popup in the UI.\n\nMozReview-Commit-ID: DG9JDFXCjai", "files": ["browser/base/content/browser-feeds.js", "browser/components/feeds/FeedWriter.js", "browser/components/feeds/moz.build", "browser/components/feeds/test/browser/.eslintrc.js", "browser/components/feeds/test/browser/browser.ini", "browser/components/feeds/test/browser/browser_telemetry_checks.js", "browser/components/feeds/test/browser/valid-feed.xml", "browser/components/places/PlacesUIUtils.jsm", "browser/components/places/content/browserPlacesViews.js", "toolkit/components/places/PlacesDBUtils.jsm", "toolkit/components/telemetry/Scalars.yaml"], "git_node": null, "git_parents": [null], "node": "63366815c258d2be09d71785ab7aeba260245520", "parents": ["7690c7e5ef4a05cf2b4a1985268ec55fda6a15cf"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418672 In Resist Fingerprinting mode, correct the version of Firefox to spoof in 59 r=baku a=lizzard\n\nVersion 59 is confused, because it thought it was supposed to be an ESR.\nBug 1418162 will update the equation to use our new ESR schedule, but\nthat leaves 59 to be corrected.\n\nRather than try to write some complicated equation, and an assertion to\nmake sure we're future-proof, just hardcode the version we're supposed\nto spoof to: 52.\n\nIn Bug 1418162 we'll correct the function for real and that will be used\ninto the future for 60.\n\nMozReview-Commit-ID: IHmeDeqFtER", "files": ["toolkit/components/resistfingerprinting/nsRFPService.cpp"], "git_node": null, "git_parents": [null], "node": "01f3f0dc10701aec97254c8973e30726f3e99f14", "parents": ["63366815c258d2be09d71785ab7aeba260245520"], "tags": []}, {"author": "Chris H-C \u003cchutten@mozilla.com\u003e", "branch": "default", "desc": "bug 1438335 - Clamp the samples accumulated to histograms. r=Dexter a=lizzard\n\nInternally Histograms use int, which is signed.\n\nOur API uses uint32_t, which is not.\n\nOur JS API uses ToUint32, which takes provided values modulo UINT32_MAX.\n\nThis patch consolidates behaviour so that all values greater than INT_MAX will\nbe correctly recorded in the highest bucket of a Histogram... instead of\nhaving values between INT_MAX and UINT32_MAX end up as 0s, and values above\nUINT32_MAX being taken modulo UINT32_MAX, but only from the JS API.\n\nMozReview-Commit-ID: CzaaNZkPEji", "files": ["toolkit/components/telemetry/TelemetryHistogram.cpp"], "git_node": null, "git_parents": [null], "node": "00e20572ed812d2988e066ffed5f5e3d4d12eeb4", "parents": ["01f3f0dc10701aec97254c8973e30726f3e99f14"], "tags": []}, {"author": "Chris H-C \u003cchutten@mozilla.com\u003e", "branch": "default", "desc": "bug 1438335 - Document Histogram accumulation clamping behaviour r=Dexter a=lizzard\n\nMozReview-Commit-ID: K7gB4zoAleM", "files": ["toolkit/components/telemetry/docs/collection/histograms.rst"], "git_node": null, "git_parents": [null], "node": "8505f530d9f9c748ca86b16ee667b4208f9af03a", "parents": ["00e20572ed812d2988e066ffed5f5e3d4d12eeb4"], "tags": []}, {"author": "Chris H-C \u003cchutten@mozilla.com\u003e", "branch": "default", "desc": "bug 1438335 - Test edge-of-representation accumulations to Histograms. r=Dexter a=lizzard\n\nMozReview-Commit-ID: 4FflK2q7Gea", "files": ["toolkit/components/telemetry/tests/gtest/TestHistograms.cpp"], "git_node": null, "git_parents": [null], "node": "dc5d87eb8bfc23ee6e113657e230d9f829a06023", "parents": ["8505f530d9f9c748ca86b16ee667b4208f9af03a"], "tags": []}, {"author": "Chris H-C \u003cchutten@mozilla.com\u003e", "branch": "default", "desc": "bug 1438335 - Record when we have to clamp large Telemetry accumulations. r=Dexter,francois a=lizzard\n\nWe need to clamp accumulations to fit in our data representation (int). This\npatch records the number of times, and for which probes, we had to do so.\n\nMozReview-Commit-ID: GSs3oFvLKlL", "files": ["toolkit/components/telemetry/Scalars.yaml", "toolkit/components/telemetry/TelemetryHistogram.cpp", "toolkit/components/telemetry/tests/gtest/TestHistograms.cpp"], "git_node": null, "git_parents": [null], "node": "72a0030b41dc6c325b178911d7ae5e20c1348dba", "parents": ["dc5d87eb8bfc23ee6e113657e230d9f829a06023"], "tags": []}], "date": 1519811650, "git_changesets": [null, null, null, null, null, null], "user": "nerli@mozilla.com"}, "8787": {"changesets": [{"author": "tbirdbld", "branch": "THUNDERBIRD590b2_2018022807_RELBRANCH", "desc": "Automated checkin: version bump for thunderbird 59.0b2 release. DONTBUILD CLOSED TREE a=release", "files": [], "git_node": null, "git_parents": [null], "node": "6df98ce7da1f5c296f6c0a255ac75b003a9921ff", "parents": ["6429339f38d8b985891c97f5c09580bfb846dddd"], "tags": ["THUNDERBIRD_59_0b2_BUILD2", "THUNDERBIRD_59_0b2_RELEASE"]}, {"author": "tbirdbld", "branch": "THUNDERBIRD590b2_2018022807_RELBRANCH", "desc": "Added THUNDERBIRD_59_0b2_RELEASE THUNDERBIRD_59_0b2_BUILD2 tag(s) for changeset 6df98ce7da1f. DONTBUILD CLOSED TREE a=release", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "4a31203c167d024c6a0ebf2137972cc369478226", "parents": ["6df98ce7da1f5c296f6c0a255ac75b003a9921ff"], "tags": []}], "date": 1519822300, "git_changesets": [null, null], "user": "tbirdbld"}, "8788": {"changesets": [{"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1437575 - Better shutdown hang reporting: all the notifications must be received, r=smaug a=lizzard CLOSED TREE", "files": ["toolkit/components/terminator/nsTerminator.cpp", "toolkit/components/terminator/nsTerminator.h", "xpcom/build/XPCOMInit.cpp"], "git_node": null, "git_parents": [null], "node": "4a24da7b8cd51443fcdb3bb9a52a3c7483894829", "parents": ["72a0030b41dc6c325b178911d7ae5e20c1348dba"], "tags": []}], "date": 1519824758, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "8789": {"changesets": [{"author": "shindli \u003cshindli@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 63366815c258 (bug 1350349) for bc failures in browser/components/feeds/test/browser/browser_telemetry_checks.js on a CLOSED TREE", "files": ["browser/base/content/browser-feeds.js", "browser/components/feeds/FeedWriter.js", "browser/components/feeds/moz.build", "browser/components/feeds/test/browser/.eslintrc.js", "browser/components/feeds/test/browser/browser.ini", "browser/components/feeds/test/browser/browser_telemetry_checks.js", "browser/components/feeds/test/browser/valid-feed.xml", "browser/components/places/PlacesUIUtils.jsm", "browser/components/places/content/browserPlacesViews.js", "toolkit/components/places/PlacesDBUtils.jsm", "toolkit/components/telemetry/Scalars.yaml"], "git_node": null, "git_parents": [null], "node": "47d2222746944315b59dd76e97640aef66df9b49", "parents": ["4a24da7b8cd51443fcdb3bb9a52a3c7483894829"], "tags": []}, {"author": "shindli \u003cshindli@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 01f3f0dc1070 (bug 1418672) for bc failures in browser/components/resistfingerprinting/test/browser/browser_navigator.js on a CLOSED TREE", "files": ["toolkit/components/resistfingerprinting/nsRFPService.cpp"], "git_node": null, "git_parents": [null], "node": "8f710379c2794c018c452aa386f9e7ffdffedfe3", "parents": ["47d2222746944315b59dd76e97640aef66df9b49"], "tags": []}], "date": 1519826703, "git_changesets": [null, null], "user": "shindli@mozilla.com"}, "8790": {"changesets": [{"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418672 In Resist Fingerprinting mode, correct the version of Firefox to spoof in 59 r=baku a=lizzard CLOSED TREE\n\nVersion 59 is confused, because it thought it was supposed to be an ESR.\nBug 1418162 will update the equation to use our new ESR schedule, but\nthat leaves 59 to be corrected.\n\nRather than try to write some complicated equation, and an assertion to\nmake sure we're future-proof, just hardcode the version we're supposed\nto spoof to: 52.\n\nIn Bug 1418162 we'll correct the function for real and that will be used\ninto the future for 60.\n\nMozReview-Commit-ID: IHmeDeqFtER", "files": ["browser/components/resistfingerprinting/test/browser/browser_navigator.js", "toolkit/components/resistfingerprinting/nsRFPService.cpp"], "git_node": null, "git_parents": [null], "node": "5e884033774ed5b9447e823091ce33a63b5cc1c4", "parents": ["8f710379c2794c018c452aa386f9e7ffdffedfe3"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1350349 - collect data for feed reader usage to evaluate its future, r=mak,data-review=liuche,a=lizzard CLOSED TREE\n\nThis patch adds data collection for 6 different data points:\n- number of live bookmarks the user has\n- number of times the user subscribes to a feed\n- number of times we attempt to open feed preview\n- number of times the user opens a feed popup in the UI\n- number of times the user opens an entry from a feed popup in the UI.\n\nMozReview-Commit-ID: DG9JDFXCjai", "files": ["browser/base/content/browser-feeds.js", "browser/components/feeds/FeedWriter.js", "browser/components/feeds/moz.build", "browser/components/feeds/test/browser/.eslintrc.js", "browser/components/feeds/test/browser/browser.ini", "browser/components/feeds/test/browser/browser_telemetry_checks.js", "browser/components/feeds/test/browser/valid-feed.xml", "browser/components/places/PlacesUIUtils.jsm", "browser/components/places/content/browserPlacesViews.js", "toolkit/components/places/PlacesDBUtils.jsm", "toolkit/components/telemetry/Scalars.yaml"], "git_node": null, "git_parents": [null], "node": "ef2ed1192d9bda8e9507d2b3eb9c7818e50d98b5", "parents": ["5e884033774ed5b9447e823091ce33a63b5cc1c4"], "tags": []}], "date": 1519837494, "git_changesets": [null, null], "user": "archaeopteryx@coole-files.de"}, "8791": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nbe -\u003e 0c9c3cd9ae3f\nes-CL -\u003e 205483db747c\nkab -\u003e bcb7cb4ddc41\npt-BR -\u003e c53dabc6abed\nte -\u003e 2009dd02a391", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "d244f9f0118124b0b9b33ed1a080f58a7b850ea8", "parents": ["ef2ed1192d9bda8e9507d2b3eb9c7818e50d98b5"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nach -\u003e bc6e5a52cd63\nbe -\u003e 0c9c3cd9ae3f\nes-CL -\u003e 205483db747c\ngl -\u003e 0368702ecc81\ngu-IN -\u003e dbb4c588f567\nkab -\u003e bcb7cb4ddc41\nlt -\u003e c109a02f40ec\npt-BR -\u003e c53dabc6abed\nte -\u003e 2009dd02a391", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "6282ef8df781bc4538e82ba179d71e4281a90842", "parents": ["d244f9f0118124b0b9b33ed1a080f58a7b850ea8"], "tags": []}], "date": 1519845627, "git_changesets": [null, null], "user": "ffxbld"}, "8792": {"changesets": [{"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1376865 Automatically decline the canvas permission if it is not in response to user input r=baku a=lizzard\n\nThe canvas prompt is extremely annoying. It happens everyone, automatically. And in\n99.9% (not scientific) of cases it is not triggered by user input, but my automatic\ntracking scripts.\n\nThis commit will automatically decline the canvas read if it was not triggered by\nuser input.\n\nJust in case this breaks something irrepairably, we have a cutoff pref.\n\nWe don't intend to keep this pref forever, and have asked anyone who sets it to\ntell us why.\n\nMozReview-Commit-ID: CxNkuraRWpV", "files": ["dom/base/DOMPrefsInternal.h", "dom/canvas/CanvasUtils.cpp", "dom/ipc/ContentPrefs.cpp", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "602513ec27274254fa07676375423ae11ca26078", "parents": ["6282ef8df781bc4538e82ba179d71e4281a90842"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1376865 Add a test for Canvas Image Prompts triggered by user inputs. r=baku a=lizzard\n\nMozReview-Commit-ID: Ht9gaW92yMG", "files": ["browser/base/content/test/permissions/browser_canvas_fingerprinting_resistance.js"], "git_node": null, "git_parents": [null], "node": "35ace045dd2133828ff3f28ada0a49ad84d33d34", "parents": ["602513ec27274254fa07676375423ae11ca26078"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1435705 - Fix WebExtensions options_ui hidden. r=aswan a=lizzard\n\nIf a user opens the about:addons page and then immediately switches\nto the addon details, while the discovery panel is still loading,\nthen a ViewChanged event is received once the discovery panel has\nbeen completely loaded and the options_ui of the extension was removed\n(because the ViewChanged event is also sent when the about:addons page\nnavigates between its sub-views).\n\nMozReview-Commit-ID: GBF5NHezpNB", "files": ["toolkit/mozapps/extensions/content/extensions.js"], "git_node": null, "git_parents": [null], "node": "9d4192f91c6071dc160db49963c27505601ef738", "parents": ["35ace045dd2133828ff3f28ada0a49ad84d33d34"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1439529 - Same resolution is also feasible. r=jib a=lizzard\n\nMozReview-Commit-ID: F9DGzgr7pCN", "files": ["dom/media/systemservices/CamerasParent.cpp"], "git_node": null, "git_parents": [null], "node": "4742bec115147335324b5c81827621233307ae1b", "parents": ["9d4192f91c6071dc160db49963c27505601ef738"], "tags": []}, {"author": "Andrew Swan \u003caswan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1439600 Mark addons as incompatible if we can no longer parse the manifest r=mossop a=lizzard\n\nMozReview-Commit-ID: 8H1cuAPlPmW", "files": ["toolkit/mozapps/extensions/internal/XPIProviderUtils.js", "toolkit/mozapps/extensions/test/xpcshell/test_upgrade_incompatible.js", "toolkit/mozapps/extensions/test/xpcshell/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "4ebc3f8a7357f68c706ef8224c6ed91697bc22d5", "parents": ["4742bec115147335324b5c81827621233307ae1b"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1440941 - FetchDriver should check if the operation has been already aborted when OnStartRequest is called, r=bkelly a=lizzard", "files": ["dom/fetch/FetchDriver.cpp"], "git_node": null, "git_parents": [null], "node": "f83587c150abb271b3f15742007994ca57bc8395", "parents": ["4ebc3f8a7357f68c706ef8224c6ed91697bc22d5"], "tags": ["DEVEDITION_59_0b14_BUILD1", "DEVEDITION_59_0b14_RELEASE", "FIREFOX_59_0b14_BUILD1", "FIREFOX_59_0b14_RELEASE"]}], "date": 1519871168, "git_changesets": [null, null, null, null, null, null], "user": "csabou@mozilla.com"}, "8793": {"changesets": [{"author": "Henri Sivonen \u003chsivonen@hsivonen.fi\u003e", "branch": "default", "desc": "Bug 1425520. r=smaug. a=abillings\n\nMozReview-Commit-ID: IoZeR5BGjmQ", "files": ["dom/base/nsDocumentEncoder.cpp"], "git_node": null, "git_parents": [null], "node": "a330f1d4d12a7c144797f3686f35a99c37b0755e", "parents": ["f83587c150abb271b3f15742007994ca57bc8395"], "tags": []}], "date": 1519896078, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "8794": {"changesets": [{"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1439082 - ensure shield checkbox is disabled when about:preferences loads while FHR/Telemetry is preffed off, r=myk,mythmon,a=lizzard\n\nMozReview-Commit-ID: 7mhuD7BS7xz", "files": ["browser/extensions/shield-recipe-client/lib/ShieldPreferences.jsm"], "git_node": null, "git_parents": [null], "node": "4c21d43deece7f619ac673ffbc624c64437f43f1", "parents": ["a330f1d4d12a7c144797f3686f35a99c37b0755e"], "tags": []}], "date": 1519898438, "git_changesets": [null], "user": "gijskruitbosch@gmail.com"}, "8795": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging mozilla-beta 4c21d43deece7f619ac673ffbc624c64437f43f1 with FIREFOX_RELEASE_59_BASE a=release DONTBUILD CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "5a21c2f52c784f7890a5f35f7854753a02e360c4", "parents": ["4c21d43deece7f619ac673ffbc624c64437f43f1"], "tags": []}], "date": 1519904176, "git_changesets": [null], "user": "mtabara@mozilla.com"}, "8796": {"changesets": [{"author": "Mihai Tabara \u003cmtabara@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 5a21c2f52c78 a=release DONTBUILD CLOSED TREE\n\nMozReview-Commit-ID: 9klk4p25VB4", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "8eb7e5c863ed744d64d095959bcc5cb936f9e23f", "parents": ["5a21c2f52c784f7890a5f35f7854753a02e360c4"], "tags": ["FIREFOX_RELEASE_59_BASE"]}], "date": 1519906379, "git_changesets": [null], "user": "mtabara@mozilla.com"}, "8797": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging mozilla-beta 8eb7e5c863ed744d64d095959bcc5cb936f9e23f with FIREFOX_RELEASE_59_BASE a=release DONTBUILD CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "0ed280054c9bb81959994ae7d02945d8d4798992", "parents": 