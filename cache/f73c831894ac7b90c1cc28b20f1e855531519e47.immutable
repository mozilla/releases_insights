["fb4cc60cfca29f7e18949c87f070085f26ead21f", "d1b820065830a3e44711ead07c0b47babdc53cf1"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430309 - Remove classycle from the tree. r=froydnj\n\nThis was added in Bug 1096627 to enforce the baseline GeckoView\nlayering that we had at that time.  Now that GeckoView is a separate\nGradle project, that layering is automatically enforced.  It's time\nfor this to go.\n\nMozReview-Commit-ID: Ly35QhgBdWM", "files": ["mobile/android/base/Makefile.in", "mobile/android/base/geckoview.ddf", "mobile/android/base/moz.build", "mobile/android/build/classycle/LICENSE.txt", "mobile/android/build/classycle/classycle-1.4.1.jar"], "git_node": null, "git_parents": [null], "node": "0b0cab4592d9e15e0ae68ded75838993c7bd9f7e", "parents": ["1cf3422c44890c30f38833c6c3df47f3edec59d6"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418131: Part 1 - Add Windows Security Center info to nsSystemInfo; r=erahm,jimm\n\nMozReview-Commit-ID: 7XUAIesDpRu", "files": ["xpcom/base/moz.build", "xpcom/base/nsSystemInfo.cpp"], "git_node": null, "git_parents": [null], "node": "5dd6963e2a123df1baa6fab3a878ed4b1660133c", "parents": ["0b0cab4592d9e15e0ae68ded75838993c7bd9f7e"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418131: Part 2 - Add security software section to about:support; r=jimm\n\nMozReview-Commit-ID: 2hJkpPxFakp", "files": ["toolkit/content/aboutSupport.js", "toolkit/content/aboutSupport.xhtml", "toolkit/locales/en-US/chrome/global/aboutSupport.dtd", "toolkit/modules/Troubleshoot.jsm"], "git_node": null, "git_parents": [null], "node": "73dca204352537366f995ca177e69870a3ccf693", "parents": ["5dd6963e2a123df1baa6fab3a878ed4b1660133c"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418131: Part 3 - Add Windows Security Center info to telemetry environment; r=gfritzsche\n\nMozReview-Commit-ID: 3Cw7XIrROTn", "files": ["toolkit/components/telemetry/TelemetryEnvironment.jsm", "toolkit/components/telemetry/docs/data/environment.rst", "toolkit/components/telemetry/tests/unit/test_TelemetryEnvironment.js"], "git_node": null, "git_parents": [null], "node": "75591ea83b3c104643603a8992f2e20b1abd2bdf", "parents": ["73dca204352537366f995ca177e69870a3ccf693"], "tags": []}, {"author": "Coroiu Cristina \u003cccoroiu@mozilla.com\u003e", "branch": "default", "desc": "Backed out 1 changesets (bug 1430309) for build bustage because of unused rule in mobile/android/moz.build after file removals on a CLOSED TREE\n\nBacked out changeset 0b0cab4592d9 (bug 1430309)", "files": ["mobile/android/base/Makefile.in", "mobile/android/base/geckoview.ddf", "mobile/android/base/moz.build", "mobile/android/build/classycle/LICENSE.txt", "mobile/android/build/classycle/classycle-1.4.1.jar"], "git_node": null, "git_parents": [null], "node": "8b27687d761714797e575c79709c1b2c69ca0d41", "parents": ["75591ea83b3c104643603a8992f2e20b1abd2bdf"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430309 - Remove classycle from the tree. r=froydnj\n\nThis was added in Bug 1096627 to enforce the baseline GeckoView\nlayering that we had at that time.  Now that GeckoView is a separate\nGradle project, that layering is automatically enforced.  It's time\nfor this to go.\n\nMozReview-Commit-ID: Ly35QhgBdWM", "files": ["mobile/android/base/Makefile.in", "mobile/android/base/geckoview.ddf", "mobile/android/base/moz.build", "mobile/android/build/classycle/LICENSE.txt", "mobile/android/build/classycle/classycle-1.4.1.jar", "mobile/android/moz.build"], "git_node": null, "git_parents": [null], "node": "bb714754672f8412df2e35df2f40fb8872192d3a", "parents": ["8b27687d761714797e575c79709c1b2c69ca0d41"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430645 - Fix win64 compilation of mozsearch-plugin. r=emilio\n\nMozReview-Commit-ID: 6xrnnZeYmFy", "files": ["build/clang-plugin/mozsearch-plugin/FileOperations.cpp"], "git_node": null, "git_parents": [null], "node": "8d1a13fa5847c774625e9936d1238dee7138b01c", "parents": ["bb714754672f8412df2e35df2f40fb8872192d3a"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Pre: Teach |mach gradle| to take GRADLE_FLAGS from the command line. r=maliu\n\nMozReview-Commit-ID: 150llND5h0j", "files": ["mobile/android/mach_commands.py"], "git_node": null, "git_parents": [null], "node": "d276d3deba053f66d74d258d964cab3fd5358a14", "parents": ["8d1a13fa5847c774625e9936d1238dee7138b01c"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Pre: Don't block Google's maven repository. r=maliu\n\nTurns out Google's maven repository doesn't publish checksums.  I\ncan't imagine why not, but there it is.  We have to think more about\nwhether to trust the artifacts downloaded from maven.google.com.\n\nMozReview-Commit-ID: CdWijorq1IV", "files": ["taskcluster/scripts/misc/android-gradle-dependencies/nexus.xml"], "git_node": null, "git_parents": [null], "node": "0850b319efd43ac8f4d61485451722975da55ca1", "parents": ["d276d3deba053f66d74d258d964cab3fd5358a14"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Pre: Fix dangling resource. r=mcomella\n\nThis is just wrong.\n\nMozReview-Commit-ID: EBtKTD07aNu", "files": ["mobile/android/app/src/main/res/values-v17/themes.xml", "mobile/android/base/resources/values-v17/themes.xml"], "git_node": null, "git_parents": [null], "node": "22a861db1573364916ab2c5b6d0c6321ba08ff55", "parents": ["0850b319efd43ac8f4d61485451722975da55ca1"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Pre: Remove unused PerProfileDatabaseProvider. r=mcomella\n\nNo idea what is going on with this hierarchy, but this isn't used and\nisn't helping anything.\n\nMozReview-Commit-ID: Ir3LxLYHR6M", "files": ["mobile/android/app/lint.xml", "mobile/android/base/java/org/mozilla/gecko/db/AbstractTransactionalProvider.java", "mobile/android/base/java/org/mozilla/gecko/db/PerProfileDatabaseProvider.java", "mobile/android/base/moz.build"], "git_node": null, "git_parents": [null], "node": "3dc3beab95f83b2f08ff9ff305fdd4b85cc05d9d", "parents": ["22a861db1573364916ab2c5b6d0c6321ba08ff55"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Pre: Clear icon disk storage in test. r=mcomella\n\nNewer versions of Robolectric seem to have different semantics about\nclearing disk caches, so this is necessary.  But for older versions,\nit shouldn't hurt, and is slightly more clear than relying on an\nimplicit clear.\n\nMozReview-Commit-ID: LRcaEPasXj8", "files": ["mobile/android/app/src/test/java/org/mozilla/gecko/icons/preparation/TestLookupIconUrl.java"], "git_node": null, "git_parents": [null], "node": "373c9a71d9451498462594b302b4fe2648431fef", "parents": ["3dc3beab95f83b2f08ff9ff305fdd4b85cc05d9d"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Pre: Gradle is no longer experimental; IntelliJ not supported. r=maliu\n\nIntelliJ should still work, but we're committed to Android Studio at\nthis point.\n\nMozReview-Commit-ID: 3BaXB4dh4vA", "files": ["python/mozbuild/mozbuild/config_status.py"], "git_node": null, "git_parents": [null], "node": "901b304603d9d4816856d560c61387501efceadc", "parents": ["373c9a71d9451498462594b302b4fe2648431fef"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Pre: Update toolchain documents for Android toolchain jobs. r=maliu\n\nMozReview-Commit-ID: 9h0imqIYyaZ", "files": ["build/docs/toolchains.rst"], "git_node": null, "git_parents": [null], "node": "e7b0cc801cf1406a46f576106f014c74a90d9534", "parents": ["901b304603d9d4816856d560c61387501efceadc"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Pre: Fix checkstyle whitespace error in GeckoHlsPlayer. r=nalexander\n\nMozReview-Commit-ID: 4h1p4J5B8sM", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/media/GeckoHlsPlayer.java"], "git_node": null, "git_parents": [null], "node": "d0d513d1c3791cbb7ae24b22699f0663e45943d9", "parents": ["e7b0cc801cf1406a46f576106f014c74a90d9534"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Pre: Remove unused HomeExpandableListView. r=mcomella\n\nThis was added for the Remote Tabs panel in Bug 785199.  That code has\nnow morphed into the combined history panel, which uses a\nRecyclerView.\n\nMozReview-Commit-ID: J6KsVCn8mzh", "files": ["mobile/android/base/java/org/mozilla/gecko/home/HomeExpandableListView.java", "mobile/android/base/moz.build"], "git_node": null, "git_parents": [null], "node": "2b37201606f5a921d91339e2c8a2ec86885b68e8", "parents": ["d0d513d1c3791cbb7ae24b22699f0663e45943d9"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Pre: Fix CustomTabsSecurityPopup package. r=nalexander\n\nMozReview-Commit-ID: ICTdy9WRlwG", "files": ["mobile/android/base/java/org/mozilla/gecko/customtabs/ActionBarPresenter.java", "mobile/android/base/java/org/mozilla/gecko/customtabs/CustomTabsSecurityPopup.java"], "git_node": null, "git_parents": [null], "node": "76085ddd5ac768b3ec8dfe9ca03283630c436681", "parents": ["2b37201606f5a921d91339e2c8a2ec86885b68e8"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Part 0: Add rudimentary documentation about Gradle integration. r=maliu\n\nThis sketches the flavor dimensions.  The important ones are\n`audience` and `geckoBinaries`, which I think simplify the situation\ngreatly.  Coupled with Bug 1417232 centralizing most everything in\n`mobile/android/gradle.configure`, the Gradle configuration shouldn't\nbe so hard to evolve.\n\nMozReview-Commit-ID: DILjVrnLA3F", "files": ["mobile/android/docs/gradle.rst", "mobile/android/docs/index.rst"], "git_node": null, "git_parents": [null], "node": "cec2b8828cc8800fa269d290ce38ea82c454b445", "parents": ["76085ddd5ac768b3ec8dfe9ca03283630c436681"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Part 1: Upgrade to Android-Gradle 3.0+ and build-tools;26.0.2. r=maliu\n\nNew Android-Gradle plugins pin the build-tools version, and we want to\nbe consistent between Gradle and moz.build.\n\nMozReview-Commit-ID: ApWS4rHzPuH", "files": ["build.gradle", "gradle/wrapper/gradle-wrapper.properties", "mobile/android/app/build.gradle", "mobile/android/app/src/photon/res/values/styles.xml", "mobile/android/base/Makefile.in", "mobile/android/geckoview/build.gradle", "mobile/android/geckoview_example/build.gradle", "mobile/android/gradle.configure", "mobile/android/gradle/with_gecko_binaries.gradle", "mobile/android/thirdparty/build.gradle", "old-configure.in", "python/mozboot/mozboot/android-packages.txt", "taskcluster/scripts/misc/android-gradle-dependencies/after.sh"], "git_node": null, "git_parents": [null], "node": "f918500d9cf5112b70bc8e0a120df435b02252b7", "parents": ["cec2b8828cc8800fa269d290ce38ea82c454b445"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Part 2: Update Robolectric to 3.5.1. r=mcomella\n\nThere were a few API changes, mostly around explicitly creating\nServices/Activities/ContentProvider instances, but they were pretty\neasy to address.\n\nSadly, Robolectric doesn't really work with the new aapt2 processing\nin Android-Gradle plugin 3.0+ -- see in particular\nhttps://github.com/robolectric/robolectric/issues/3333#issuecomment-324300418\n-- so we have to opt-out of the new implementation for now.  Hopefully\nplugin 3.1+ will address these issues, which are widespread.\n\nMozReview-Commit-ID: dlbd32kMs6", "files": ["gradle.properties", "mobile/android/app/build.gradle", "mobile/android/app/src/test/java/org/mozilla/gecko/GlobalPageMetadataTest.java", "mobile/android/app/src/test/java/org/mozilla/gecko/icons/loader/TestLegacyLoader.java", "mobile/android/app/src/test/java/org/mozilla/gecko/util/NetworkUtilsTest.java", "mobile/android/app/src/test/resources/robolectric.properties", "mobile/android/services/src/test/java/org/mozilla/gecko/background/db/DelegatingTestContentProvider.java", "mobile/android/services/src/test/java/org/mozilla/gecko/background/db/TestTabsProvider.java", "mobile/android/services/src/test/java/org/mozilla/gecko/background/testhelpers/MockGlobalSession.java", "mobile/android/services/src/test/java/org/mozilla/gecko/background/testhelpers/MockPrefsGlobalSession.java", "mobile/android/services/src/test/java/org/mozilla/gecko/db/BrowserProviderBookmarksTest.java", "mobile/android/services/src/test/java/org/mozilla/gecko/db/BrowserProviderGeneralTest.java", "mobile/android/services/src/test/java/org/mozilla/gecko/db/BrowserProviderHistoryVisitsTestBase.java", "mobile/android/services/src/test/java/org/mozilla/gecko/db/LocalBrowserDBTest.java", "mobile/android/services/src/test/java/org/mozilla/gecko/fxa/devices/TestFxAccountDeviceListUpdater.java", "mobile/android/services/src/test/java/org/mozilla/gecko/sync/repositories/android/VisitsHelperTest.java"], "git_node": null, "git_parents": [null], "node": "690e265c684ce70ecb89355314fd1574bb421f0b", "parents": ["f918500d9cf5112b70bc8e0a120df435b02252b7"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Part 3: Make each variant handle source from moz.build. r=maliu\n\nThe advantage of doing this per-variant is that we can really separate\nthe 'local' behaviour (re-generate via re-entrant |mach build|\ninvocations) from the 'official' behaviour (never re-generate via\nre-entrance).\n\nThis also uses new Android-Gradle plugin 3.0+ APIs to integrate the\ngenerated resources and Java code.\n\nMozReview-Commit-ID: 4pd2iw1nJSb", "files": ["mobile/android/app/build.gradle"], "git_node": null, "git_parents": [null], "node": "730a70767743b74a7e3a1fcf4018540edfdf30a3", "parents": ["690e265c684ce70ecb89355314fd1574bb421f0b"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Part 4: Use flavorDimensions to simplify {with,without}GeckoBinaries logic. r=maliu\n\nMozReview-Commit-ID: 2rbsP6A0BY0", "files": ["mobile/android/app/build.gradle", "mobile/android/base/Makefile.in", "mobile/android/geckoview/build.gradle", "mobile/android/geckoview_example/build.gradle", "mobile/android/gradle.configure", "mobile/android/gradle/debug_level.gradle", "mobile/android/gradle/product_flavors.gradle", "mobile/android/gradle/with_gecko_binaries.gradle", "taskcluster/ci/build/android.yml"], "git_node": null, "git_parents": [null], "node": "01836fd98c6351667c70cfd187cf1e3c437e1f94", "parents": ["730a70767743b74a7e3a1fcf4018540edfdf30a3"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Part 5: Work through various new lint issues. r=mcomella\n\nMozReview-Commit-ID: AhrT7jbztE3", "files": ["mobile/android/app/src/main/res/drawable/ic_as_trending.xml", "mobile/android/app/src/main/res/layout/customtabs_action_bar_custom_view.xml", "mobile/android/base/AndroidManifest.xml.in", "mobile/android/base/java/org/mozilla/gecko/CrashReporter.java", "mobile/android/base/java/org/mozilla/gecko/db/LocalBrowserDB.java"], "git_node": null, "git_parents": [null], "node": "fde9bf9c14c31c11b4e9279ae7b56b94b5a02d53", "parents": ["01836fd98c6351667c70cfd187cf1e3c437e1f94"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Part 6: Fix checkstyle. r=mcomella\n\nMozReview-Commit-ID: GPRogNGKQBJ", "files": ["mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/model/Highlight.java", "mobile/android/base/java/org/mozilla/gecko/updater/UpdateService.java"], "git_node": null, "git_parents": [null], "node": "c270f97bb0da1347151bb429c81bba0044545da5", "parents": ["fde9bf9c14c31c11b4e9279ae7b56b94b5a02d53"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Part 5b: Work through WrongConstant lint issues. r=mcomella\n\nMozReview-Commit-ID: 6zJ7EMu9rgO", "files": ["mobile/android/app/lint.xml", "mobile/android/base/java/org/mozilla/gecko/activitystream/ActivityStreamTelemetry.java", "mobile/android/base/java/org/mozilla/gecko/dlc/BaseAction.java", "mobile/android/base/java/org/mozilla/gecko/dlc/DownloadAction.java", "mobile/android/base/moz.build"], "git_node": null, "git_parents": [null], "node": "c5bf85d56fedf600363dda3b077fdf950ba60688", "parents": ["c270f97bb0da1347151bb429c81bba0044545da5"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Part 5c: Work through ResourceUnused lint issues. r=mcomella\n\nMozReview-Commit-ID: 82rgLEEMQzG", "files": ["mobile/android/app/src/main/res/values-v11/themes.xml", "mobile/android/app/src/main/res/values-v13/search_styles.xml", "mobile/android/app/src/main/res/values-v16/search_styles.xml", "mobile/android/app/src/main/res/values/themes.xml", "mobile/android/app/src/photon/res/values-v11/styles.xml", "mobile/android/app/src/photon/res/values-v16/styles.xml", "mobile/android/app/src/photon/res/values/styles.xml", "mobile/android/base/java/org/mozilla/gecko/util/UnusedResourcesUtil.java"], "git_node": null, "git_parents": [null], "node": "55776829a744ec20be08d29083c4b39b9519b9b4", "parents": ["c5bf85d56fedf600363dda3b077fdf950ba60688"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411654 - Post: Cull unused variables; guard more with MOZ_BUILD_MOBILE_ANDROID_WITH_GRADLE. r=maliu\n\nMozReview-Commit-ID: 8EGzVISIEQZ", "files": ["mobile/android/base/Makefile.in"], "git_node": null, "git_parents": [null], "node": "cfad693be9185ae858a29a715b3e5a6d2d3d6fbf", "parents": ["55776829a744ec20be08d29083c4b39b9519b9b4"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1430018 - Don't use nsWindow::IsX11Display() as it's not implemented, r=jhorak\n\nMozReview-Commit-ID: cR6q3fBhTo", "files": ["widget/gtk/WindowSurfaceProvider.cpp"], "git_node": null, "git_parents": [null], "node": "5093649180890f591ea10137025f8354ef1b1d6d", "parents": ["cfad693be9185ae858a29a715b3e5a6d2d3d6fbf"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1430018 - Add runnable function name to NewRunnableFunction() calls, r=jhorak\n\nMozReview-Commit-ID: CmN0U8WH8De", "files": ["widget/gtk/WindowSurfaceWayland.cpp"], "git_node": null, "git_parents": [null], "node": "15f4b0d4bae53daf7a087ecdc1f32fd1a9d57029", "parents": ["5093649180890f591ea10137025f8354ef1b1d6d"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1430018 - Unify GtkCompositorWidgetInitData() call for X11 and Wayland, r=jhorak\n\nMozReview-Commit-ID: 1sv3X59dMvZ", "files": ["widget/gtk/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "4cf0168d93c51f7bb6aeea5b46fa0647214a498e", "parents": ["15f4b0d4bae53daf7a087ecdc1f32fd1a9d57029"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1430018 - Don't use gdk_x11_screen_supports_net_wm_hint(_NET_WM_STATE_FULLSCREEN) on Wayland, r=jhorak\n\nMozReview-Commit-ID: 9ZmQhkftunW", "files": ["widget/gtk/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "7350873319faa1552949a9b4dd3bc3842e7d731f", "parents": ["4cf0168d93c51f7bb6aeea5b46fa0647214a498e"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1430018 - Don't call gdk_flush() from expose event on Wayland as it crashes Gtk+ (Gnome BZ #773307), r=jhorak\n\nMozReview-Commit-ID: EmwcG3VzHYn", "files": ["widget/gtk/nsNativeThemeGTK.cpp"], "git_node": null, "git_parents": [null], "node": "cb71ca2516f2236418447f18a4a1eb4289b53e10", "parents": ["7350873319faa1552949a9b4dd3bc3842e7d731f"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1430018 - Add namespace mozilla::widget to nsNativeThemeGTK.cpp as it's needed by ScreenHelperGTK, r=jhorak\n\nMozReview-Commit-ID: HG7Zt0LaOU8", "files": ["widget/gtk/nsNativeThemeGTK.cpp"], "git_node": null, "git_parents": [null], "node": "c361754494d0b604f2bb66e3b5ce5650e1669ef6", "parents": ["cb71ca2516f2236418447f18a4a1eb4289b53e10"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1430018 - Fixed wrong profile param name at DBusRemoteClient::DoSendDBusCommandLine(), r=jhorak\n\nMozReview-Commit-ID: 6KKEwjLXTR9", "files": ["widget/xremoteclient/DBusRemoteClient.cpp"], "git_node": null, "git_parents": [null], "node": "e432cc393634cdb6ac5a85030dc7fb518f5bfbe6", "parents": ["c361754494d0b604f2bb66e3b5ce5650e1669ef6"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1430018 - dlsym gdk_wayland_* routines as those are available at Gtk+ \u003e 3.8, r=jhorak\n\nMozReview-Commit-ID: EUgmc9QNeoI", "files": ["widget/gtk/mozcontainer.cpp", "widget/gtk/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "40a2e98240cff8b9db471c2005dac54017369314", "parents": ["e432cc393634cdb6ac5a85030dc7fb518f5bfbe6"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1430414 - Remove unused package-manifest.in references. r=nalexander\n\nThose are all remnants of APIs that are now gone for good.\n\nMozReview-Commit-ID: 266GvgbES3s", "files": ["mobile/android/installer/package-manifest.in"], "git_node": null, "git_parents": [null], "node": "b88adc63e02f99d12614dbf87244647a8e935c29", "parents": ["40a2e98240cff8b9db471c2005dac54017369314"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1430411 - Exclude viewZoomOverlay.js from Fennec builds. r=esawin\n\nThat file is only needed for desktop Firefox and when displaying the page source\nin a separate window, which is a desktop-only feature as well.\n\nMozReview-Commit-ID: 5wgvoIW12Xn", "files": ["toolkit/content/jar.mn"], "git_node": null, "git_parents": [null], "node": "58c0a6ed3bb71d9f79d4b7e89135d984768a2a4f", "parents": ["b88adc63e02f99d12614dbf87244647a8e935c29"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Backed out 3 changesets (bug 1418131) for Browser-chrome failure, mochitest failre and build bustage on Windows mingw\n\nBacked out changeset 75591ea83b3c (bug 1418131)\nBacked out changeset 73dca2043525 (bug 1418131)\nBacked out changeset 5dd6963e2a12 (bug 1418131)", "files": ["toolkit/components/telemetry/TelemetryEnvironment.jsm", "toolkit/components/telemetry/docs/data/environment.rst", "toolkit/components/telemetry/tests/unit/test_TelemetryEnvironment.js", "toolkit/content/aboutSupport.js", "toolkit/content/aboutSupport.xhtml", "toolkit/locales/en-US/chrome/global/aboutSupport.dtd", "toolkit/modules/Troubleshoot.jsm", "xpcom/base/moz.build", "xpcom/base/nsSystemInfo.cpp"], "git_node": null, "git_parents": [null], "node": "c4dd70f035f664022212b841862ffe4d9cd1e96e", "parents": ["58c0a6ed3bb71d9f79d4b7e89135d984768a2a4f"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418131: Part 1 - Add Windows Security Center info to nsSystemInfo; r=erahm,jimm\n\nMozReview-Commit-ID: 7XUAIesDpRu", "files": ["xpcom/base/moz.build", "xpcom/base/nsSystemInfo.cpp"], "git_node": null, "git_parents": [null], "node": "d66bae3d5be11415ce50fc35c3b6510f57678b02", "parents": ["c4dd70f035f664022212b841862ffe4d9cd1e96e"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418131: Part 2 - Add security software section to about:support; r=jimm\n\nMozReview-Commit-ID: 2hJkpPxFakp", "files": ["toolkit/content/aboutSupport.js", "toolkit/content/aboutSupport.xhtml", "toolkit/locales/en-US/chrome/global/aboutSupport.dtd", "toolkit/modules/Troubleshoot.jsm"], "git_node": null, "git_parents": [null], "node": "625b2d120fd9f71f06803e8bce619bb69eeea463", "parents": ["d66bae3d5be11415ce50fc35c3b6510f57678b02"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418131: Part 3 - Add Windows Security Center info to telemetry environment; r=gfritzsche\n\nMozReview-Commit-ID: 3Cw7XIrROTn", "files": ["toolkit/components/telemetry/TelemetryEnvironment.jsm", "toolkit/components/telemetry/docs/data/environment.rst", "toolkit/components/telemetry/tests/unit/test_TelemetryEnvironment.js"], "git_node": null, "git_parents": [null], "node": "073eb94e1d21ce20fa1452d65be4f4fc420fe0d8", "parents": ["625b2d120fd9f71f06803e8bce619bb69eeea463"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1430077 - Broadcast Marionette:Deregister once. r=whimboo\n\nThe global message manager reaches all browsers and all frames.\n\nIf Marionette was _not_ using the global message manager, this\nwould have been the correct approach.\n\nMozReview-Commit-ID: HKrlfd9pzK2", "files": ["testing/marionette/driver.js"], "git_node": null, "git_parents": [null], "node": "989f852dc1a8b6531b24de5741b4b56a151f1954", "parents": ["073eb94e1d21ce20fa1452d65be4f4fc420fe0d8"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1430077 - Remove global outerWindowID in frame script. r=whimboo\n\nouterWindowID is no longer used for adding message listeners,\nwhich means we do not need to store it globally.\n\nMozReview-Commit-ID: HZ0oY7ozwnu", "files": ["testing/marionette/listener.js"], "git_node": null, "git_parents": [null], "node": "8c33350d63a22e035575054950a57f14083cdcbe", "parents": ["989f852dc1a8b6531b24de5741b4b56a151f1954"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1430077 - Correct safety checks on Marionette:Register reply. r=whimboo\n\nsendSyncMessage returns an array of replies from the frame message\nmanager, each item being the return value from each message listener\nthat handles the message.\n\nIn testing/marionette/driver.js there are two handlers for\nMarionette:Register, but it is not predictable at the moment when\nboth or either one of them is triggered.  We would, however, always\nexpect a response, which means the reply array should never be empty.\n\nMozReview-Commit-ID: 5F8YfKO8jBU", "files": ["testing/marionette/listener.js"], "git_node": null, "git_parents": [null], "node": "5b775719d4320edc5a5534d9dc7ffc5a119e0292", "parents": ["8c33350d63a22e035575054950a57f14083cdcbe"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1430077 - Separate clearing session state from deregistering listeners. r=whimboo\n\nWith the forthcoming window tracking changes the message listeners of\nthe content frame script are left listening for the duration of the\nMarionette lifetime, and not for the duration of the Marionette session.\n\nTo prepare for the window tracking refactoring, we will want to\nremove message listeners separately from clearing the session state.\nFunctionally, this patch changes nothing in Marionette for the moment,\nexcept we send two IPC messages to the frame script instead of one.\n\nMozReview-Commit-ID: DwVBCpvk9V9", "files": ["testing/marionette/driver.js", "testing/marionette/listener.js"], "git_node": null, "git_parents": [null], "node": "659526d528ff2dc3291b2140d2190d73d16b11e4", "parents": ["5b775719d4320edc5a5534d9dc7ffc5a119e0292"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Backed out 3 changesets (bug 1418131) for build bustages on Windows mingw\n\nBacked out changeset 073eb94e1d21 (bug 1418131)\nBacked out changeset 625b2d120fd9 (bug 1418131)\nBacked out changeset d66bae3d5be1 (bug 1418131)", "files": ["toolkit/components/telemetry/TelemetryEnvironment.jsm", "toolkit/components/telemetry/docs/data/environment.rst", "toolkit/components/telemetry/tests/unit/test_TelemetryEnvironment.js", "toolkit/content/aboutSupport.js", "toolkit/content/aboutSupport.xhtml", "toolkit/locales/en-US/chrome/global/aboutSupport.dtd", "toolkit/modules/Troubleshoot.jsm", "xpcom/base/moz.build", "xpcom/base/nsSystemInfo.cpp"], "git_node": null, "git_parents": [null], "node": "412cb15c620265f7545812b2de1714e7b7ad1485", "parents": ["659526d528ff2dc3291b2140d2190d73d16b11e4"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1430506 - Install pulseaudio 2.0 on CentOS build images. r=nalexander\n\nSwitching to Debian build images will force a version bump from\npulseaudio 0.9.something to pulseaudio 2.0. Practically speaking, as\nlong as bug 1427150 is fixed (which it is), this is strictly better,\nbecause this enables all the PA_CHECK_VERSION(2,0,0) code in libcubeb,\nwhich handles port availability (whether output is plugged or not), and\nwith bug 1427150, it does so in a backward compatible manner.\n\nNow, since this is a behavior change from what we're currently shipping,\nthis has the potential of triggering unexpected test failures, or break\nsound for users. The likelyhood of the latter happening is rather low,\nthough, because Linux distros have been building with pulseaudio \u003e= 2.0\nfor a long time and we haven't heard about port availability breaking\nsound for them. But it's still better to decouple this change from the\nswitch to Debian.\n\nWe abuse the build-gtk3.sh script which installs gtk3 in the CentOS\nbuild image to install pulseaudio as well.", "files": ["build/unix/build-gtk3/build-gtk3.sh"], "git_node": null, "git_parents": [null], "node": "e3cd1efb911c0fb74e36640b5866300570749a6e", "parents": ["412cb15c620265f7545812b2de1714e7b7ad1485"], "tags": []}, {"author": "Zibi Braniecki \u003czbraniecki@mozilla.com\u003e", "branch": "default", "desc": "Bug 1389384 - Batch l10n mutations to one per paint. r=mossop\n\nMozReview-Commit-ID: AbclA2lzTfT", "files": ["intl/l10n/DOMLocalization.jsm", "intl/l10n/test/test_domlocalization.js"], "git_node": null, "git_parents": [null], "node": "e140335f123762045a9a3bfcd31e83736f968150", "parents": ["e3cd1efb911c0fb74e36640b5866300570749a6e"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1425541: Expose reader mode state on the browser accessible using a \"reader\" object attribute. r=eeejay,Gijs\n\nThis makes it easy for accessibility clients to retrieve the reader mode state programmatically.\n\nThere are three possibilities:\n1. Reader mode is available for the current page (reader:available).\n2. Reader mode is being used now (reader:active).\n3. Reader is not available (the reader attribute is not present).\n\nWe do this by setting/removing the aria-reader attribute on the node.\nThis is not a real ARIA attribute, but it causes Gecko to expose it as an object attribute.\n\nMozReview-Commit-ID: B38G3AYyBnS", "files": ["browser/modules/ReaderParent.jsm"], "git_node": null, "git_parents": [null], "node": "196006c746bde8b894252ec1310a4b5124e04c14", "parents": ["e140335f123762045a9a3bfcd31e83736f968150"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418131: Part 1 - Add Windows Security Center info to nsSystemInfo; r=erahm,jimm\n\nMozReview-Commit-ID: 7XUAIesDpRu", "files": ["xpcom/base/moz.build", "xpcom/base/nsSystemInfo.cpp"], "git_node": null, "git_parents": [null], "node": "a0cf39ae0b3d4db3bf77e0b669258e7393288079", "parents": ["196006c746bde8b894252ec1310a4b5124e04c14"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418131: Part 2 - Add security software section to about:support; r=jimm\n\nMozReview-Commit-ID: 2hJkpPxFakp", "files": ["toolkit/content/aboutSupport.js", "toolkit/content/aboutSupport.xhtml", "toolkit/locales/en-US/chrome/global/aboutSupport.dtd", "toolkit/modules/Troubleshoot.jsm"], "git_node": null, "git_parents": [null], "node": "a287c5db8be683855745e4367c801f057b842859", "parents": ["a0cf39ae0b3d4db3bf77e0b669258e7393288079"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418131: Part 3 - Add Windows Security Center info to telemetry environment; r=gfritzsche\n\nMozReview-Commit-ID: 3Cw7XIrROTn", "files": ["toolkit/components/telemetry/TelemetryEnvironment.jsm", "toolkit/components/telemetry/docs/data/environment.rst", "toolkit/components/telemetry/tests/unit/test_TelemetryEnvironment.js"], "git_node": null, "git_parents": [null], "node": "8962ed624e0c5e775ae46990563de641f6c6a861", "parents": ["a287c5db8be683855745e4367c801f057b842859"], "tags": []}, {"author": "Dustin J. Mitchell \u003cdustin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430491: stop depending, incorrectly, on docker images; r=glandium\n\nMozReview-Commit-ID: DksKKZQcXo0", "files": ["taskcluster/taskgraph/transforms/job/__init__.py"], "git_node": null, "git_parents": [null], "node": "cc223a707701dc87cd711bc7deb31562e052d7b1", "parents": ["8962ed624e0c5e775ae46990563de641f6c6a861"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 196006c746bd (bug 1425541) for failing Mochitest on intl/l10n/test/dom/test_domloc_overlay.html on a CLOSED TREE", "files": ["browser/modules/ReaderParent.jsm"], "git_node": null, "git_parents": [null], "node": "10400d85b71114dbee7c73b7fd02f9b3dae0495e", "parents": ["cc223a707701dc87cd711bc7deb31562e052d7b1"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Backed out 3 changesets (bug 1418131) for failing Browser-chrome on toolkit/modules/tests/browser/browser_Troubleshoot.js on a CLOSED TREE\n\nBacked out changeset 8962ed624e0c (bug 1418131)\nBacked out changeset a287c5db8be6 (bug 1418131)\nBacked out changeset a0cf39ae0b3d (bug 1418131)", "files": ["toolkit/components/telemetry/TelemetryEnvironment.jsm", "toolkit/components/telemetry/docs/data/environment.rst", "toolkit/components/telemetry/tests/unit/test_TelemetryEnvironment.js", "toolkit/content/aboutSupport.js", "toolkit/content/aboutSupport.xhtml", "toolkit/locales/en-US/chrome/global/aboutSupport.dtd", "toolkit/modules/Troubleshoot.jsm", "xpcom/base/moz.build", "xpcom/base/nsSystemInfo.cpp"], "git_node": null, "git_parents": [null], "node": "4ad0761df5db065e46f0716f966076c0ad00b62e", "parents": ["10400d85b71114dbee7c73b7fd02f9b3dae0495e"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1429961: Make sure to remove all the continuations with the same PostDestroyData. r=mats\n\nIf we remove the first continuation of the ::after content before the last,\nbefore this patch unbind the generated content ASAP. Part of the generated\ncontent (the second counter) in the test-case ends up in a continuation of that\nframe.\n\nThat text node would already be unbound from the tree when destroying its\nframe.\n\nMozReview-Commit-ID: 4VtVRSoGxCT", "files": ["layout/generic/nsContainerFrame.cpp", "layout/generic/nsIFrame.h"], "git_node": null, "git_parents": [null], "node": "467cbbd4d1602a7fd04722e32eba9740929d4f97", "parents": ["4ad0761df5db065e46f0716f966076c0ad00b62e"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1429961: Destroy continuations last-to-first. r=mats\n\nMozReview-Commit-ID: Ftc8NJLTaAw", "files": ["layout/generic/nsContainerFrame.cpp", "layout/generic/nsIFrame.h"], "git_node": null, "git_parents": [null], "node": "5bceb041669bda78c1fa381bbab04f133601d345", "parents": ["467cbbd4d1602a7fd04722e32eba9740929d4f97"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1429961: Avoid copying PostDestroyData. r=mats\n\nWe don't want that to happen.\n\nMozReview-Commit-ID: EQ6igMRyeaV", "files": ["layout/generic/nsFrameList.h"], "git_node": null, "git_parents": [null], "node": "2cb5c90e995c099aae97febb6723947722bd3149", "parents": ["5bceb041669bda78c1fa381bbab04f133601d345"], "tags": []}, {"author": "Brad Werth \u003cbwerth@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430329: Make StyleSheetActor.update only emit ruleCount change events when necessary. r=tromey\n\nMozReview-Commit-ID: 6rwEo1mCFgG", "files": ["devtools/server/actors/stylesheets.js"], "git_node": null, "git_parents": [null], "node": "07bdc1156ee2b037696aca213289ca5c329d2103", "parents": ["2cb5c90e995c099aae97febb6723947722bd3149"], "tags": []}, {"author": "Bobby Holley \u003cbobbyholley@gmail.com\u003e", "branch": "default", "desc": "servo: Merge #19779 - Avoid debug serialization of PropertyDeclaration & co in release builds (from bholley:avoid_rule_debug_hooks); r=emilio\n\nIn total, this PR saves ~60k.\n\nThe conditional compilation on the _Debug FFI function eliminates one\nof the ToCss variants, eliminating 54.4k, as well as a bunch of other\n\u003c1k functions. Removing the public trait implementation of Debug for the\nfont metrics provider eliminates the last Debug impl from stylo.\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 7de87c487b247b479fa38c40f683de8783032e11", "files": ["servo/components/style/font_metrics.rs", "servo/ports/geckolib/glue.rs"], "git_node": null, "git_parents": [null], "node": "64f0d9b1f9ce738c8801b1d92e988239a2298d66", "parents": ["07bdc1156ee2b037696aca213289ca5c329d2103"], "tags": []}, {"author": "James Cheng \u003cjacheng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430517 - Remove VIDEO_CHROMIUM_CDM_MAX_SHMEMS telemetry. r=cpearce\n\nMozReview-Commit-ID: 6dPV5dGACnx", "files": ["dom/media/gmp/ChromiumCDMParent.cpp", "dom/media/gmp/ChromiumCDMParent.h", "toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "8a743132915dbdfaf28999e34633c9dbf09ea322", "parents": ["64f0d9b1f9ce738c8801b1d92e988239a2298d66"], "tags": []}, {"author": "Chris Pearce \u003ccpearce@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430673 - Remove CDMProxy::GetSessionIdsForKeyId(). r=JamesCheng\n\nMozReview-Commit-ID: EMT8BaHE2Pf", "files": ["dom/media/MediaData.h", "dom/media/eme/CDMCaps.cpp", "dom/media/eme/CDMCaps.h", "dom/media/eme/CDMProxy.h", "dom/media/eme/mediadrm/MediaDrmCDMProxy.cpp", "dom/media/eme/mediadrm/MediaDrmCDMProxy.h", "dom/media/gmp/ChromiumCDMProxy.cpp", "dom/media/gmp/ChromiumCDMProxy.h", "dom/media/platforms/agnostic/eme/EMEDecoderModule.cpp"], "git_node": null, "git_parents": [null], "node": "79ffd285b6daa1c9ab23085fced8fb3d4ff344c7", "parents": ["8a743132915dbdfaf28999e34633c9dbf09ea322"], "tags": []}, {"author": "James Cheng \u003cjacheng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1430519 - Extend telemetry MEDIA_EME_REQUEST_DEPRECATED_WARNINGS to gecko 63. r=cpearce\n\nM