pcom/threads/nsThreadManager.cpp", "xpcom/threads/nsThreadManager.h"], "git_node": null, "git_parents": [null], "node": "a0c5b937edb5cc7a765a26df0ea80a676f42a2df", "parents": ["7c3d1a48781b90db6ab70a9abeaa4fcd612e581a"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1425559 - \"content-child-will-shutdown\" notification when the content process starts the shutting down, r=smaug a=lizzard", "files": ["dom/ipc/ContentChild.cpp", "dom/ipc/ContentChild.h"], "git_node": null, "git_parents": [null], "node": "4cc99f0c610e71abd799be545f7a851fb9f2ea4a", "parents": ["a0c5b937edb5cc7a765a26df0ea80a676f42a2df"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1425559 - nsPrompter must use nsIThreadManager::spinEventLoopUntilOrShutdown, r=smaug a=lizzard", "files": ["testing/web-platform/meta/webdriver/tests/execute_async_script/user_prompts.py.ini", "testing/web-platform/meta/webdriver/tests/execute_script/user_prompts.py.ini", "toolkit/components/prompts/src/nsPrompter.js"], "git_node": null, "git_parents": [null], "node": "331bb529635e88354ca87bafa707694c3214644a", "parents": ["4cc99f0c610e71abd799be545f7a851fb9f2ea4a"], "tags": []}, {"author": "Zibi Braniecki \u003czbraniecki@mozilla.com\u003e", "branch": "default", "desc": "Bug 1426054 - Update Fluent in Gecko to 0.6. r=Pike a=lizzard\n\nThis upstream uses fluent.js revision ae1b55a.\n\nMozReview-Commit-ID: 1IynCPWWN14", "files": ["intl/l10n/DOMLocalization.jsm", "intl/l10n/Localization.jsm", "intl/l10n/MessageContext.jsm", "intl/l10n/README", "intl/l10n/fluent.js.patch", "intl/l10n/test/test_messagecontext.js"], "git_node": null, "git_parents": [null], "node": "5c4e1b96f6c92116ac6b9073934eb2961ff60ba4", "parents": ["331bb529635e88354ca87bafa707694c3214644a"], "tags": []}, {"author": "Zibi Braniecki \u003czbraniecki@mozilla.com\u003e", "branch": "default", "desc": "Bug 1436790 - Update Flue