3f93bb", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "f4a2f35bd561cecf9f3f2e3901766ef7aa65e7b5", "parents": ["479140b15f42313dbfc87670d6ab1ebe9173590c"], "tags": []}], "date": 1518020407, "git_changesets": [null, null], "user": "ffxbld"}, "8664": {"changesets": [{"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1388020 - improve diagnostics in BuildDisplayList. r=froydnj a=abillings", "files": ["layout/generic/nsFrame.cpp", "xpcom/ds/ArenaAllocator.h"], "git_node": null, "git_parents": [null], "node": "a144e7e01f42ed8cd1eea993c5b35086b84735b0", "parents": ["f4a2f35bd561cecf9f3f2e3901766ef7aa65e7b5"], "tags": []}, {"author": "Brian Hackett \u003cbhackett1024@gmail.com\u003e", "branch": "default", "desc": "Bug 1416523 - Don't attach arguments stub if the IC isn't monitored. r=jandem a=abillings", "files": ["js/src/jit/CacheIR.cpp"], "git_node": null, "git_parents": [null], "node": "367b18b6007bd65b84cc77e027e9bbcc20e55350", "parents": ["a144e7e01f42ed8cd1eea993c5b35086b84735b0"], "tags": []}, {"author": "Oriol Brufau \u003coriol-bugzilla@hotmail.com\u003e", "branch": "default", "desc": "Bug 1433655 - Allow JSON Viewer to change expandedNodes state. r=Honza a=RyanVM\n\nMozReview-Commit-ID: C2Db2U2KQKp", "files": ["devtools/client/jsonview/components/MainTabbedArea.js", "devtools/client/jsonview/test/browser_jsonview_chunked_json.js"], "git_node": null, "git_parents": [null], "node": "cd07ba84f98d8368e334b4e8fe4375350c0121e0", "parents": ["367b18b6007bd65b84cc77e027e9bbcc20e55350"], "tags": []}, {"author": "Michael Froman \u003cmfroman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1434531 - fix missing TCP relay candidates. r=drno a=RyanVM\n\nBecause the nr_transport_addr_check_compatibility check also includes\nprotocol, it was failing checks that used to pass.  However, the actual\naddress used was created farther down in code by copying the current\naddress and setting the protocol to TCP.  Moving that address copy up\nin the processing flow lets the more stringent check work.\n\nMozReview-Commit-ID: 95SOQzxuxXB", "files": ["media/mtransport/third_party/nICEr/src/ice/ice_component.c"], "git_node": null, "git_parents": [null], "node": "2d975e7d80673f2f86212273e11274040db2b3cc", "parents": ["cd07ba84f98d8368e334b4e8fe4375350c0121e0"], "tags": []}], "date": 1518020581, "git_changesets": [null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "8665": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nfi -\u003e 893009904ff4\nru -\u003e a4a108270818\nth -\u003e 40c41733cb1b\nuk -\u003e 931acf64d354", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "4b09568a52748d8486d8bdefb1ebce507d531f51", "parents": ["2d975e7d80673f2f86212273e11274040db2b3cc"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\ncy -\u003e 5f648a6a0b10\nfi -\u003e 893009904ff4\nru -\u003e a4a108270818\nth -\u003e 5272fed4d168\nuk -\u003e 931acf64d354", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "19f11eb832317842731710a16b4af31dd97f9896", "parents": ["4b09568a52748d8486d8bdefb1ebce507d531f51"], "tags": []}], "date": 1518023998, "git_changesets": [null, null], "user": "ffxbld"}, "8666": {"changesets": [{"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1420714 - fix favicon fetching in reader mode, r=mak a=RyanVM\n\nMozReview-Commit-ID: KZFoKNqVPPy", "files": ["browser/modules/ReaderParent.jsm", "toolkit/components/reader/test/browser_readerMode.js"], "git_node": null, "git_parents": [null], "node": "5924d4660bad4d58d0b0b5dbc00cc3f054dc04ff", "parents": ["19f11eb832317842731710a16b4af31dd97f9896"], "tags": []}, {"author": "Francois Marier \u003cfrancois@mozilla.com\u003e", "branch": "default", "desc": "Bug 1431370 - Make DoRiceDeltaDecode allocation fallible to fix startup OOM crash. r=gcp a=RyanVM\n\nMozReview-Commit-ID: 2vf4EU4TVCq", "files": ["toolkit/components/url-classifier/ProtocolParser.cpp"], "git_node": null, "git_parents": [null], "node": "fb10c0f561b34bcb31397f50338066ef1f34cfe7", "parents": ["5924d4660bad4d58d0b0b5dbc00cc3f054dc04ff"], "tags": []}, {"author": "Dragana Damjanovic dd.mozilla@gmail.com", "branch": "default", "desc": "Bug 1431738 - We will disable TFO on late beta and release. r=jduell a=lizzard", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "13c900643140bfe187f1f5cdd941ee4c9b1b54bc", "parents": ["fb10c0f561b34bcb31397f50338066ef1f34cfe7"], "tags": []}, {"author": "Luke Crouch \u003clcrouch@mozilla.com\u003e", "branch": "default", "desc": "Bug 1432915 - don't save download source url when aIsPrivate r=Ehsan a=RyanVM\n\nMozReview-Commit-ID: 9mQjwcCtrWg", "files": ["toolkit/components/jsdownloads/src/DownloadPlatform.cpp"], "git_node": null, "git_parents": [null], "node": "a40559a7c596616bde26964fe781cef6031f687f", "parents": ["13c900643140bfe187f1f5cdd941ee4c9b1b54bc"], "tags": []}, {"author": "Chris Pearce \u003ccpearce@mozilla.com\u003e", "branch": "default", "desc": "Bug 1433344 - Convert encrypted AAC to ADTS before decryption. r=jya a=RyanVM\n\nMozReview-Commit-ID: IGmBfJtYsCi", "files": ["dom/media/MediaData.cpp", "dom/media/MediaData.h", "dom/media/platforms/agnostic/bytestreams/Adts.cpp", "dom/media/platforms/agnostic/bytestreams/Adts.h", "dom/media/platforms/agnostic/eme/EMEDecoderModule.cpp"], "git_node": null, "git_parents": [null], "node": "735be632d41e1e44776e18472594dc6840d73239", "parents": ["a40559a7c596616bde26964fe781cef6031f687f"], "tags": []}, {"author": "vprabhu \u003cvenkateshprabhu2@gmail.com\u003e", "branch": "default", "desc": "Bug 1434299 - Changed href to refer to '#' to display \"finger pointer\" over the \"enabled\" link in about:telemetry. r=chutten a=RyanVM\n\nMozReview-Commit-ID: FPaZfwNhPfP", "files": ["toolkit/content/aboutTelemetry.js"], "git_node": null, "git_parents": [null], "node": "5e23604f2d3392133c15f0702ade36f5407bc8e9", "parents": ["735be632d41e1e44776e18472594dc6840d73239"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1435015: Unbreak display: contents on unknown MathML elements. r=mats a=RyanVM\n\nBug 1427292 broke display: contents on non-special MathML elements.\n\nJust for reference, I've manually audited calls to nsIFrame::GetContent() in\nMathML and turns out that MathML is pretty well-behaved in that sense (it\ninspects the frame tree, then gets the content), so it should work fine with\ndisplay: contents / ShadowDOM.\n\nOnly exception to that is[1], but that one seems harmless.\n\n[1]: https://searchfox.org/mozilla-central/rev/eeb7190f9ad6f1a846cd6df09986325b3f2c3117/layout/mathml/nsMathMLmactionFrame.cpp#301\n\nSo we can enable or implement when the CSSWG pleases.\n\nMozReview-Commit-ID: 8N6kiGyjE4i", "files": ["layout/base/crashtests/1435015.html", "layout/base/crashtests/crashtests.list", "layout/base/nsCSSFrameConstructor.cpp"], "git_node": null, "git_parents": [null], "node": "a54547237ecb7177619de84de81b9cbb46fe3c1b", "parents": ["5e23604f2d3392133c15f0702ade36f5407bc8e9"], "tags": []}, {"author": "Francois Marier \u003cfrancois@mozilla.com\u003e", "branch": "default", "desc": "Bug 1435098 - Gate flashinfobar list on the plugins.show_infobar. r=bytesized,gcp a=RyanVM\n\nThe list of sites to suppress flash infobars on should not be\ndownloaded from shavar unless the infobar feature is enabled.\n\nMozReview-Commit-ID: BjkS5vWiilg", "files": ["toolkit/components/url-classifier/SafeBrowsing.jsm"], "git_node": null, "git_parents": [null], "node": "536f8eeb6485913cabc1abbe56798b7bcd380fe3", "parents": ["a54547237ecb7177619de84de81b9cbb46fe3c1b"], "tags": []}, {"author": "Jonathan Watt \u003cjwatt@jwatt.org\u003e", "branch": "default", "desc": "Bug 1435286 - Stop recording draw events for reference DrawTargets returned from PrintTarget. r=bobowen a=RyanVM\n\nMozReview-Commit-ID: 1cE71hBCGx5", "files": ["gfx/src/nsDeviceContext.cpp", "gfx/thebes/PrintTarget.cpp", "gfx/thebes/PrintTarget.h", "gfx/thebes/PrintTargetCG.h", "gfx/thebes/PrintTargetCG.mm", "gfx/thebes/PrintTargetEMF.cpp", "gfx/thebes/PrintTargetEMF.h", "gfx/thebes/PrintTargetSkPDF.cpp", "gfx/thebes/PrintTargetSkPDF.h", "gfx/thebes/PrintTargetThebes.cpp", "gfx/thebes/PrintTargetThebes.h"], "git_node": null, "git_parents": [null], "node": "9d8a25ef4fd74e465fcc75a7fc12c6671024a88f", "parents": ["536f8eeb6485913cabc1abbe56798b7bcd380fe3"], "tags": []}], "date": 1518029879, "git_changesets": [null, null, null, null, null, null, null, null, null], "user": "apavel@mozilla.com"}, "8667": {"changesets": [{"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1420485 - Added new tabs.insertCSS test case to ensure that the injected CSS are cleaned up. r=mixedpuppy, a=RyanVM\n\nMozReview-Commit-ID: EPTTA2MnZ6O", "files": ["browser/components/extensions/test/browser/browser_ext_tabs_insertCSS.js"], "git_node": null, "git_parents": [null], "node": "24e9a78c27eb173d9eba4b0ab029b318a03bd97c", "parents": ["9d8a25ef4fd74e465fcc75a7fc12c6671024a88f"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1420485 - Fix an exception raised by browser_ext_tabs_insertCSS.js on injecting the same cached preloaded stylesheet twice. r=mixedpuppy, a=RyanVM\n\nMozReview-Commit-ID: Jq2JdXwt7zC", "files": ["browser/components/extensions/test/browser/browser_ext_tabs_insertCSS.js"], "git_node": null, "git_parents": [null], "node": "dbc6d70aff8771875986647eaa24f35da0882061", "parents": ["24e9a78c27eb173d9eba4b0ab029b318a03bd97c"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1420485 - Fix browser.test.notifyFailure is not defined in tabs.insertCSS/removeCSS tests. r=mixedpuppy, a=RyanVM\n\nThis patch fix a type in the tests related to tabs.insertCSS/removeCSS,\nthe test function is actually named browser.test.notifyFail.\n\nMozReview-Commit-ID: 8DpOFBpm795", "files": ["browser/components/extensions/test/browser/browser_ext_tabs_insertCSS.js", "browser/components/extensions/test/browser/browser_ext_tabs_removeCSS.js"], "git_node": null, "git_parents": [null], "node": "a20b24dc938970597c9268b11e4cbc4f8ae3bcb2", "parents": ["dbc6d70aff8771875986647eaa24f35da0882061"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1420485 - Fix 'message manager count' failure when browser_ext_tabs_insertCSS.js is executed first. r=mixedpuppy, a=RyanVM\n\nMozReview-Commit-ID: HEWS8Lxldbi", "files": ["browser/components/extensions/test/browser/browser_ext_tabs_insertCSS.js"], "git_node": null, "git_parents": [null], "node": "05fd88206d24afef45187cf35c6f8b04d496fc9b", "parents": ["a20b24dc938970597c9268b11e4cbc4f8ae3bcb2"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1420485 - Reduce memory usage related to the tabs.insertCSS cssCode urls. r=mixedpuppy, a=RyanVM\n\nThis patch introduces a cache of blob urls which are related to the cssCode\ninjected by the extensions using tabs.insertCSS, which aims to reduce the\namount of memory used by the extensions to store the cssCode injected\ninto the tabs and their subframes in the content child process.\n\nThe generated Blob URL are associated to the extension principal,\nso that it is easier to identify in the about:memory reports\nwhich is extension that is using the cached data.\n\nMozReview-Commit-ID: ERhR5nmVMqY", "files": ["toolkit/components/extensions/ExtensionContent.jsm", "toolkit/components/extensions/ExtensionUtils.jsm", "toolkit/components/extensions/extension-process-script.js"], "git_node": null, "git_parents": [null], "node": "16970266565679053bf6a9c63ad6084c14422d0b", "parents": ["05fd88206d24afef45187cf35c6f8b04d496fc9b"], "tags": []}], "date": 1518039529, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8668": {"changesets": [{"author": "Nick Thomas \u003cnthomas@mozilla.com\u003e", "branch": "default", "desc": "Bug 1435638 - Use ssh to clone partner repack manifests, r=bhearsum a=release DONTBUILD", "files": ["taskcluster/ci/release-partner-repack/kind.yml", "testing/mozharness/configs/partner_repacks/release_mozilla-esr52_desktop.py"], "git_node": null, "git_parents": [null], "node": "f0c62c006c4206cb8c5ea71ec164d962b7c75a22", "parents": ["16970266565679053bf6a9c63ad6084c14422d0b"], "tags": []}], "date": 1518056895, "git_changesets": [null], "user": "nthomas@mozilla.com"}, "8669": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nfi -\u003e 4a2dc3490e16\nnn-NO -\u003e 4bda33f46135\nrm -\u003e 3dda4a40c920", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "305a67069be1d92fd26f62f769d19f2525070cfe", "parents": ["f0c62c006c4206cb8c5ea71ec164d962b7c75a22"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nfi -\u003e 4a2dc3490e16\nis -\u003e 05ec518d0c80\nnn-NO -\u003e 4bda33f46135\nrm -\u003e 3dda4a40c920\nth -\u003e ea5d5606dfcf", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "3b3bdaf075d3b40ddf3dbc68f8a319b92d46f689", "parents": ["305a67069be1d92fd26f62f769d19f2525070cfe"], "tags": []}], "date": 1518059997, "git_changesets": [null, null], "user": "ffxbld"}, "8670": {"changesets": [{"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1432045 - Maintain consistent alignment in case of font fallback for non-Latin characters. r=Gijs a=RyanVM\n\nas suggested in https://bugzilla.mozilla.org/show_bug.cgi?id=1409615#c4\n\nMozReview-Commit-ID: EUbVxUx3UkF", "files": ["browser/themes/shared/tabs.inc.css"], "git_node": null, "git_parents": [null], "node": "a2cd586a63ecd6483c5aef6e00b456164064d818", "parents": ["3b3bdaf075d3b40ddf3dbc68f8a319b92d46f689"], "tags": []}, {"author": "Zibi Braniecki \u003czbraniecki@mozilla.com\u003e", "branch": "default", "desc": "Bug 1433411 - Import `fetch` API in nsBrowserGlue. r=Gijs a=RyanVM\n\nMozReview-Commit-ID: 4jgi2NOu81A", "files": ["browser/components/nsBrowserGlue.js"], "git_node": null, "git_parents": [null], "node": "e8928484234d092ea9e5d6771c296d0a42a8b3da", "parents": ["a2cd586a63ecd6483c5aef6e00b456164064d818"], "tags": []}], "date": 1518086292, "git_changesets": [null, null], "user": "ebalazs@mozilla.com"}, "8671": {"changesets": [{"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1434922 - Set a favicon for about:privatebrowsing. r=florian a=RyanVM\n\nThis was initially removed when we added support for setting the favicon\nahead of parsing the page for newtab-like pages. Turns out we need it in\nsome scenarios, such as navigating back and forth or duplicating the tab.\n\nMozReview-Commit-ID: HuMeEnqpLLB", "files": ["browser/components/privatebrowsing/content/aboutPrivateBrowsing.xhtml"], "git_node": null, "git_parents": [null], "node": "9dbb3d090a27b36a5a11e14621c4c37b44e8f410", "parents": ["e8928484234d092ea9e5d6771c296d0a42a8b3da"], "tags": []}, {"author": "Matthew Noorenberghe \u003cmozilla@noorenberghe.ca\u003e", "branch": "default", "desc": "Bug 1435274 - Stop form autofilling if the master password prompt is cancelled. r=johannh a=RyanVM\n\nMozReview-Commit-ID: HnFbcWYX6QL", "files": ["browser/extensions/formautofill/FormAutofillHandler.jsm", "browser/extensions/formautofill/test/browser/browser.ini", "browser/extensions/formautofill/test/browser/browser_creditCard_fill_master_password.js"], "git_node": null, "git_parents": [null], "node": "f235b6c433a899562b3ee38edd12a3b1eba17666", "parents": ["9dbb3d090a27b36a5a11e14621c4c37b44e8f410"], "tags": []}, {"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1435992 - Disabled page actions still show extension context menu items. r=mixedpuppy a=RyanVM\n\nMozReview-Commit-ID: JmC6PXtW1SK", "files": ["browser/components/extensions/ext-pageAction.js", "browser/components/extensions/test/browser/browser_ext_menus.js"], "git_node": null, "git_parents": [null], "node": "08a592e1b2ecddc6c73ab45e4f85f5e8a40ffd96", "parents": ["f235b6c433a899562b3ee38edd12a3b1eba17666"], "tags": []}], "date": 1518087016, "git_changesets": [null, null, null], "user": "shindli@mozilla.com"}, "8672": {"changesets": [{"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset a144e7e01f42 (bug 1388020) for landing with wrong bug number. a=backout", "files": ["layout/generic/nsFrame.cpp", "xpcom/ds/ArenaAllocator.h"], "git_node": null, "git_parents": [null], "node": "58dc2e0f5a1562f390caf8ebfc517989348ddd0c", "parents": ["08a592e1b2ecddc6c73ab45e4f85f5e8a40ffd96"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1406727 - improve diagnostics in BuildDisplayList. r=froydnj a=abillings", "files": ["layout/generic/nsFrame.cpp", "xpcom/ds/ArenaAllocator.h"], "git_node": null, "git_parents": [null], "node": "01d3f0695fc4947d9a086d01f8d105816e94a3ce", "parents": ["58dc2e0f5a1562f390caf8ebfc517989348ddd0c"], "tags": []}], "date": 1518094671, "git_changesets": [null, null], "user": "archaeopteryx@coole-files.de"}, "8673": {"changesets": [{"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out 2 changesets (bug 1324883) for causing bug 1431674. a=backout\n\nBacked out changeset 3e22200b7e83 (bug 1324883)\nBacked out changeset 9d197f1860e6 (bug 1324883)", "files": ["dom/base/nsDocument.cpp", "dom/html/HTMLMediaElement.cpp", "dom/html/HTMLMediaElement.h"], "git_node": null, "git_parents": [null], "node": "e61fa00f6ebfc5c528ab639fe03f7a1ec3ad5b05", "parents": ["01d3f0695fc4947d9a086d01f8d105816e94a3ce"], "tags": []}, {"author": "Bas Schouten \u003cbschouten@mozilla.com\u003e", "branch": "default", "desc": "Bug 1425257: Introduce a global lock to protect the dependency graph between DrawTargets. r=lsalzman a=RyanVM\n\nThis patch takes the safest route for securing modifications to the dependency graph for D2D DrawTargets. It's possible a slightly optimal approach is possible, however lock contention should be rare and I believe this is the safest and most upliftable approach.\n\nMozReview-Commit-ID: HGfSdEp2U5N", "files": ["gfx/2d/2D.h", "gfx/2d/DrawTargetD2D1.cpp", "gfx/2d/DrawTargetD2D1.h", "gfx/2d/Factory.cpp"], "git_node": null, "git_parents": [null], "node": "4437812f495f6b1eef1797c0a30a8b2667414d4e", "parents": ["e61fa00f6ebfc5c528ab639fe03f7a1ec3ad5b05"], "tags": []}], "date": 1518102411, "git_changesets": [null, null], "user": "archaeopteryx@coole-files.de"}, "8674": {"changesets": [{"author": "Mihai Tabara \u003cmtabara@mozilla.com\u003e", "branch": "default", "desc": "Bug 1436305 - fix notifications lies. r=bhearsum a=release\n\nMozReview-Commit-ID: 9LuxIGDFbIH", "files": ["taskcluster/ci/release-notify-ship/kind.yml", "taskcluster/ci/release-secondary-notify-ship/kind.yml"], "git_node": null, "git_parents": [null], "node": "fc55ea1db218ace64f3e2579e3bb145afa09685f", "parents": ["4437812f495f6b1eef1797c0a30a8b2667414d4e"], "tags": []}], "date": 1518109321, "git_changesets": [null], "user": "mtabara@mozilla.com"}, "8675": {"changesets": [{"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Be sure to preserve the current transform when restoring an SkCanvas (bug 1431813, r=lsalzman) a=RyanVM", "files": ["gfx/2d/DrawTargetSkia.cpp"], "git_node": null, "git_parents": [null], "node": "f546a01d96f18c00972908f500c88311d576d588", "parents": ["fc55ea1db218ace64f3e2579e3bb145afa09685f"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Deduplicate unneeded SetTransform and SetPermitSubpixelAA calls from DrawTargetCapture (bug 1431813, r=bas) a=RyanVM", "files": ["gfx/2d/DrawTargetCapture.cpp"], "git_node": null, "git_parents": [null], "node": "54b1046e68b8d38471402e0062ab66de57dd7243", "parents": ["f546a01d96f18c00972908f500c88311d576d588"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Reuse existing DrawingCommand for SetTransform and SetPermitSubpixelAA (bug 1431813, r=bas) a=RyanVM", "files": ["gfx/2d/CaptureCommandList.h", "gfx/2d/DrawCommand.h", "gfx/2d/DrawCommands.h", "gfx/2d/DrawTargetCapture.cpp", "gfx/2d/DrawTargetCapture.h"], "git_node": null, "git_parents": [null], "node": "5fee2e25af3d6c801cad30a1d645b17be2c2b203", "parents": ["54b1046e68b8d38471402e0062ab66de57dd7243"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1434538 - Don't lock while rescaling or copying video frame buffers. r=jib a=RyanVM\n\nMozReview-Commit-ID: 78bXkY8kBfV", "files": ["dom/media/webrtc/MediaEngineRemoteVideoSource.cpp"], "git_node": null, "git_parents": [null], "node": "1870acb46d67b36dcd407be651240b741875819c", "parents": ["5fee2e25af3d6c801cad30a1d645b17be2c2b203"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1435701 - Make TSFStaticSink::IsATOKActiveInternal() aware of ATOK Passport r=m_kato a=RyanVM\n\nTIP name of ATOK Passport's ATOK 31.1.2 is just \"ATOK\", not \"ATOK \" + release\nyear.  Therefore, TSFStaticSink::IsATOKActiveInternal() returns false when\nnew ATOK is active.  This patch updates it.\n\nAdditionally, this patch adds GUID list of new Japanese TIPs with comment.\nThey should be useful when somebody needs to add hack for them.\n\nMozReview-Commit-ID: 6L5SjWEK6i0", "files": ["widget/windows/TSFTextStore.cpp"], "git_node": null, "git_parents": [null], "node": "805fb5f7db8f1f2d5f25b94b5883fd5c71d4dd17", "parents": ["1870acb46d67b36dcd407be651240b741875819c"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1431173 - Use Spectre index masking for more bounds checked loads. r=nbp a=RyanVM", "files": ["js/src/jit/BaselineCacheIRCompiler.cpp", "js/src/jit/CacheIRCompiler.cpp", "js/src/jit/CodeGenerator.cpp", "js/src/jit/Lowering.cpp", "js/src/jit/MacroAssembler.cpp", "js/src/jit/MacroAssembler.h", "js/src/jit/shared/LIR-shared.h"], "git_node": null, "git_parents": [null], "node": "b8d51c323a862eb563faee8e276415f37b0dfcce", "parents": ["805fb5f7db8f1f2d5f25b94b5883fd5c71d4dd17"], "tags": []}, {"author": "Nicolas B. Pierron \u003cnicolas.b.pierron@gmail.com\u003e", "branch": "default", "desc": "Bug 1435249 - Generalized x86/x64 cmov encoding. r=jandem a=RyanVM", "files": ["js/src/jit/x64/Assembler-x64.h", "js/src/jit/x64/BaseAssembler-x64.h", "js/src/jit/x86-shared/Assembler-x86-shared.cpp", "js/src/jit/x86-shared/Assembler-x86-shared.h", "js/src/jit/x86-shared/BaseAssembler-x86-shared.h", "js/src/jit/x86-shared/CodeGenerator-x86-shared.cpp", "js/src/jit/x86-shared/Encoding-x86-shared.h"], "git_node": null, "git_parents": [null], "node": "2764b3a41f36c32b48fb669795efc92e389a810a", "parents": ["b8d51c323a862eb563faee8e276415f37b0dfcce"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1435209 - Use CMOVcc instead of index masking. r=luke a=RyanVM", "files": ["js/src/jit/CodeGenerator.cpp", "js/src/jit/Lowering.cpp", "js/src/jit/MacroAssembler.cpp", "js/src/jit/MacroAssembler.h", "js/src/jit/arm/MacroAssembler-arm-inl.h", "js/src/jit/arm64/MacroAssembler-arm64-inl.h", "js/src/jit/arm64/MacroAssembler-arm64.h", "js/src/jit/x86-shared/Assembler-x86-shared.h", "js/src/jit/x86-shared/MacroAssembler-x86-shared-inl.h"], "git_node": null, "git_parents": [null], "node": "41310e95042844c74c58adc4650770540c6cc06c", "parents": ["2764b3a41f36c32b48fb669795efc92e389a810a"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1435266 - Enable Spectre index masking by default. r=luke a=RyanVM", "files": ["js/src/jit/JitOptions.cpp", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "aa1153f2621f4e896b92796f572f6d9bd42413a6", "parents": ["41310e95042844c74c58adc4650770540c6cc06c"], "tags": []}], "date": 1518113749, "git_changesets": [null, null, null, null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "8676": {"changesets": [{"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 1870acb46d67 (bug 1434538) for permafailing mda's dom/media/tests/mochitest/test_peerConnection_twoAudioVideoStreams.html, at least on Linux. a=backout on a CLOSED TREE", "files": ["dom/media/webrtc/MediaEngineRemoteVideoSource.cpp"], "git_node": null, "git_parents": [null], "node": "73ef186ad51ac2c4fc27b1f149fcc94355fe7dc6", "parents": ["aa1153f2621f4e896b92796f572f6d9bd42413a6"], "tags": ["DEVEDITION_59_0b8_BUILD2", "DEVEDITION_59_0b8_RELEASE", "FIREFOX_59_0b8_BUILD2", "FIREFOX_59_0b8_RELEASE"]}], "date": 1518118625, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "8677": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nbe -\u003e 38109f7ed569\nfi -