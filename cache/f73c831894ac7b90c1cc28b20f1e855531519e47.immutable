r.h"], "git_node": null, "git_parents": [null], "node": "00868cd43957fa7b9f2a2cfc34230cf259fd86e5", "parents": ["4ca9cf8165105bec7ce5327b5db307f4968eb11d"], "tags": []}, {"author": "Karl Tomlinson \u003ckarlt+@karlt.net\u003e", "branch": "FIREFOX_58b_RELBRANCH", "desc": "bug 1429666 cubeb_resampler_speex: don't call data callback while draining r=padenot a=gchang\n\nMozReview-Commit-ID: 1XEzZjPGai9", "files": ["media/libcubeb/README_MOZILLA", "media/libcubeb/gtest/test_resampler.cpp", "media/libcubeb/src/cubeb_resampler.cpp", "media/libcubeb/src/cubeb_resampler_internal.h"], "git_node": null, "git_parents": [null], "node": "63bf6cd0005459718a8a4a51bc3a7670aad5cdd2", "parents": ["00868cd43957fa7b9f2a2cfc34230cf259fd86e5"], "tags": []}], "date": 1516185963, "git_changesets": [null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "8550": {"changesets": [{"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "FIREFOX_58b_RELBRANCH", "desc": "Backed out changeset 7151850b2933 (bug 1421345) - dependency bug 1406727 hasn't been uplifted yet. a=backout", "files": ["xpcom/ds/ArenaAllocator.h"], "git_node": null, "git_parents": [null], "node": "ae8dbca85bfec5b3e53e578b5c65b0effbeccdc2", "parents": ["63bf6cd0005459718a8a4a51bc3a7670aad5cdd2"], "tags": []}], "date": 1516190449, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "8551": {"changesets": [{"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418131: Part 1 - Add Windows Security Center info to nsSystemInfo; r=erahm,jimm\n\nMozReview-Commit-ID: 7XUAIesDpRu", "files": ["xpcom/base/moz.build", "xpcom/base/nsSystemInfo.cpp"], "git_node": null, "git_parents": [null], "node": "fcad66c3d2e2e1443c9fd1c59423f40cc77acdff", "parents": ["a6004a75d2d3e5fe04b4d9920cd2e90080784c59"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418131: Part 2 - Add security software section to about:support; r=jimm\n\nMozReview-Commit-ID: 2hJkpPxFakp", "files": ["toolkit/content/aboutSupport.js", "toolkit/content/aboutSupport.xhtml", "toolkit/locales/en-US/chrome/global/aboutSupport.dtd", "toolkit/modules/Troubleshoot.jsm", "toolkit/modules/tests/browser/browser_Troubleshoot.js"], "git_node": null, "git_parents": [null], "node": "e825d7b57a4fefd1db175757b50ce76e5f48fc13", "parents": ["fcad66c3d2e2e1443c9fd1c59423f40cc77acdff"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418131: Part 3 - Add Windows Security Center info to telemetry environment; r=gfritzsche\n\nMozReview-Commit-ID: 3Cw7XIrROTn", "files": ["toolkit/components/telemetry/TelemetryEnvironment.jsm", "toolkit/components/telemetry/docs/data/environment.rst", "toolkit/components/telemetry/tests/unit/test_TelemetryEnvironment.js"], "git_node": null, "git_parents": [null], "node": "d47ec9fc25863d3fa7102ea3e48c5e5398e49bb6", "parents": ["e825d7b57a4fefd1db175757b50ce76e5f48fc13"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1416084. P1 - reapply bug 1412737 P4: wake up readers only when we have blocks committed to the cache. r=bechen,gerald\n\nPer bug 1412737 P2 changes, a reader will always read data from the cache or\nfrom the last block in the memory. NotifyDataReceived() will be slightly more\nefficient if we don't wake up readers unnecessarily when there are no new blocks\ncommitted to the cache.\n\nMozReview-Commit-ID: Afcy5OOeIk3", "files": ["dom/media/MediaCache.cpp"], "git_node": null, "git_parents": [null], "node": "e3ca97a44f1c09771297071bb459d07e0ccf15b2", "parents": ["d47ec9fc25863d3fa7102ea3e48c5e5398e49bb6"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1416084. P2 - wake up readers when download is suspended. r=bechen,gerald\n\nIt is possible that download is suspended after all bytes are received but\nbefore OnStopRequest is notified. In that case, we will fail to wake up the\nreaders waiting to read the partial block and cause bug 1412737 comment 30.\n\nMozReview-Commit-ID: GUk4lXO6Upk", "files": ["dom/media/MediaCache.cpp"], "git_node": null, "git_parents": [null], "node": "4ae35d2b108a7d98b98a6d6d3943b78b297dd35b", "parents": ["e3ca97a44f1c09771297071bb459d07e0ccf15b2"], "tags": []}, {"author": "James Cheng \u003cjacheng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1420836 - Part1 - Provide a utility function to compute the storage id. r=cpearce\n\nThe CDM on Mac and Windows will ask the host for storage id.\nWe compute the storage id by hashing machine id, origin salt and browser id.\n\nMozReview-Commit-ID: 4fTCaOKgSIe", "files": ["dom/media/gmp/CDMStorageIdProvider.cpp", "dom/media/gmp/CDMStorageIdProvider.h", "dom/media/gmp/moz.build"], "git_node": null, "git_parents": [null], "node": "1595c6002aa6b675c87c4ff4255242bf2252fea4", "parents": ["4ae35d2b108a7d98b98a6d6d3943b78b297dd35b"], "tags": []}, {"author": "James Cheng \u003cjacheng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1420836 - Part2 - Pass the storage id from content process to GMP process then provide it to CDM. r=cpearce\n\nMozReview-Commit-ID: 2VFNHaL5p73", "files": ["dom/media/gmp/ChromiumCDMChild.cpp", "dom/media/gmp/ChromiumCDMChild.h", "dom/media/gmp/GMPChild.cpp", "dom/media/gmp/GMPChild.h", "dom/media/gmp/GMPContentChild.cpp", "dom/media/gmp/GMPParent.cpp", "dom/media/gmp/PGMP.ipdl"], "git_node": null, "git_parents": [null], "node": "5a46db143897c53211818c722f15c510dd708c6c", "parents": ["1595c6002aa6b675c87c4ff4255242bf2252fea4"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1417933 - enable CSD titlebar rendering mode as Bug 1424974 regression is fixed, r=jhorak\n\nMozReview-Commit-ID: 7SCjbJr9Arl", "files": ["widget/gtk/nsLookAndFeel.cpp"], "git_node": null, "git_parents": [null], "node": "4fbda731082898ff82b807464b27