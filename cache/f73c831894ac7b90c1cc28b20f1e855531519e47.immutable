ib/softoken/sdb.c", "security/nss/lib/softoken/sdb.h", "security/nss/lib/softoken/sftkdb.c", "security/nss/lib/ssl/ssl3prot.h", "security/nss/lib/ssl/sslt.h", "security/nss/lib/ssl/tls13con.c", "security/nss/lib/util/nssutil.def", "security/nss/lib/util/utilmod.c", "security/nss/lib/util/utilpars.c", "security/nss/lib/util/utilpars.h", "security/nss/lib/util/utilparst.h", "security/nss/readme.md", "security/nss/tests/all.sh", "security/nss/tests/cert/TestCA-bogus-rsa-pss1.crt", "security/nss/tests/cert/TestCA-bogus-rsa-pss2.crt", "security/nss/tests/cert/cert.sh", "security/nss/tests/fips/fips.sh"], "git_node": null, "git_parents": [null], "node": "fb3c27bdee4648e0240e61b5dd6e1b82ec4884ca", "parents": ["9f4397eb2e08246073e0f5b053ba6cd0a3d746a8"], "tags": []}, {"author": "Masatoshi Kimura \u003cVYV03354@nifty.ne.jp\u003e", "branch": "default", "desc": "Bug 1428538 - Use UTF-8 file paths for NSS database. r=keeler", "files": ["security/manager/ssl/nsNSSComponent.cpp"], "git_node": null, "git_parents": [null], "node": "617446a093babcb0fb5ad66931f7883914a4abee", "parents": ["fb3c27bdee4648e0240e61b5dd6e1b82ec4884ca"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset ef258af45592 (bug 1429535) for test_bug704320_preload.html timeouts", "files": ["dom/script/ScriptLoader.cpp", "dom/script/ScriptLoader.h"], "git_node": null, "git_parents": [null], "node": "7e52c1fdef97315248a347608c38677cd63ddc57", "parents": ["617446a093babcb0fb5ad66931f7883914a4abee"], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1429413 - Ensure Factory::CreateDataSourceSurface allocation failures are gracefully handled. r=bas", "files": ["dom/canvas/ImageBitmap.cpp", "gfx/2d/DrawTargetTiled.h", "gfx/2d/FilterProcessingSIMD-inl.h", "gfx/layers/AsyncCanvasRenderer.cpp"], "git_node": null, "git_parents": [null], "node": "cc133159ed927638fbd2606b6b7e2c4badcb079e", "parents": ["7e52c1fdef97315248a347608c38677cd63ddc57"], "tags": []}, {"author": "David Parks \u003cdparks@mozilla.com\u003e", "branch": "default", "desc": "Bug 1382251: Part 1 - Add x64 opcodes to nsWindowsDllInterceptor needed for plugin process SSL brokering r=aklotz\n\nAdds \"LEA reg, opcode\", \"mov word ptr [reg+disp8], reg\", \"and [reg+disp8], imm8\" and \"MOV r/m8, imm8\" to DLLInterceptor.", "files": ["xpcom/build/nsWindowsDllInterceptor.h"], "git_node": null, "git_parents": [null], "node": "56a6f6bcc5c511cc12d0b0debc89df6698e07a7b", "parents": ["cc133159ed927638fbd2606b6b7e2c4badcb079e"], "tags": []}, {"author": "David Parks \u003cdparks@mozilla.com\u003e", "branch": "default", "desc": "Bug 1382251: Part 2 - Allow constructing nsWindowsDllInterceptor from module name r=aklotz\n\nAllow constructor to behave like Init().", "files": ["xpcom/build/nsWindowsDllInterceptor.h"], "git_node": null, "git_parents": [null], "node": "a1ca7804d84876782d6d14c448ade93049e77d49", "parents": ["56a6f6bcc5c511cc12d0b0debc89df6698e07a7b"], "tags": []}, {"author": "David Parks \u003cdparks@mozilla.com\u003e", "branch": "default", "desc": "Bug 1382251: Part 3 - Add mechanism for automatically hooking DLL functions r=jimm\n\nFunctionHook uses the DLL interceptor to redirect Win32 calls to a user-supplied function.", "files": ["dom/plugins/ipc/FunctionHook.cpp", "dom/plugins/ipc/FunctionHook.h"], "git_node": null, "git_parents": [null], "node": "5dc95b140fd75283c58a86793791759b98550937", "parents": ["a1ca7804d84876782d6d14c448ade93049e77d49"], "tags": []}, {"author": "David Parks \u003cdparks@mozilla.com\u003e", "branch": "default", "desc": "Bug 1382251: Part 4 - Init/Shutdown parts of XPCOM needed in plugin process r=erahm\n\nWe have not been initializing or shutting down XPCOM in the plugin process.  We need the nsThreadManager for this bug but, more importantly, we need to properly shut down XPCOM in order to get things like handlers connected to the ShutdownPhases (e.g. ClearOnShutdown, used to free resources at process end).\n\nThis patch includes some work to make services that are uninitialized in the plugin process to handle Shutdown calls without failing.", "files": ["dom/plugins/ipc/PluginProcessChild.cpp"], "git_node": null, "git_parents": [null], "node": "e8262c37dfaca6409a2df0bc5146efbb331c73a2", "parents": ["5dc95b140fd75283c58a86793791759b98550937"], "tags": []}, {"author": "David Parks \u003cdparks@mozilla.com\u003e", "branch": "default", "desc": "Bug 1382251: Part 5 - Add IpdlTuple for type-safely marshaling tuples r=jld\n\nIpdlTuple is an array of Variants that is accessed by type and that reports an error if there is a type error.  This is used for safe and easy communication of IPDL objects, validated at run time since IPC data is untrusted.", "files": ["dom/plugins/ipc/IpdlTuple.h"], "git_node": null, "git_parents": [null], "node": "e6056433a119d8342d416826930bfcdf2f4c5d88", "parents": ["e8262c37dfaca6409a2df0bc5146efbb331c73a2"], "tags": []}, {"author": "David Parks \u003cdparks@mozilla.com\u003e", "branch": "default", "desc": "Bug 1382251: Part 6 - Start/stop new top-level brokering actors on their own threads r=jld\n\nThe FunctionBroker actors allow the NPAPI process (child) to run methods on the main process (parent).  Both the parent and the child run dedicated threads for this task -- this is a top-level protocol.", "files": ["dom/plugins/ipc/FunctionBrokerChild.cpp", "dom/plugins/ipc/FunctionBrokerChild.h", "dom/plugins/ipc/FunctionBrokerParent.cpp", "dom/plugins/ipc/FunctionBrokerParent.h", "dom/plugins/ipc/FunctionBrokerThread.h", "dom/plugins/ipc/PFunctionBroker.ipdl", "dom/plugins/ipc/PPluginModule.ipdl", "dom/plugins/ipc/PluginModuleChild.cpp", "dom/plugins/ipc/PluginModuleChild.h", "dom/plugins/ipc/PluginModuleParent.cpp", "dom/plugins/ipc/PluginModuleParent.h", "ipc/ipdl/sync-messages.ini", "toolkit/xre/nsAppRunner.cpp", "xpcom/build/nsXULAppAPI.h"], "git_node": null, "git_parents": [null], "node": "7936c75851a2cab47f651fe92017dd40c8b410d7", "parents": ["e6056433a119d8342d416826930bfcdf2f4c5d88"], "tags": []}, {"author": "David Parks \u003cdparks@mozilla.com\u003e", "branch": "default", "desc": "Bug 1382251: Part 7 - Add mechanism for automatically brokering DLL functions r=jimm\n\nThe FunctionBroker is a special kind of FunctionHook that brokers the hooked function on another process.  In the child process, it uses the FunctionBrokerChild to request that the FunctionBrokerParent run a function and return the response.  It handles most cases of parameter, return value and error marshaling on its own.  It also guarantees that requests are issued from the proper thread.", "files": ["dom/plugins/ipc/FunctionBroker.cpp", "dom/plugins/ipc/FunctionBroker.h", "dom/plugins/ipc/FunctionBrokerParent.cpp", "dom/plugins/ipc/FunctionBrokerParent.h", "dom/plugins/ipc/PluginQuirks.h", "ipc/glue/IPCMessageUtils.h"], "git_node": null, "git_parents": [null], "node": "e63fa691fa348669f38529083183abfc111f8b2a", "parents": ["7936c75851a2cab47f651fe92017dd40c8b410d7"], "tags": []}, {"author": "David Parks \u003cdparks@mozilla.com\u003e", "branch": "default", "desc": "Bug 1382251: Part 8 - Migrate some previously hooked functions to FunctionHook/Broker r=froydnj\n\nMoves GetWindowInfo, GetKeyState, SetCursorPos, GetSaveFileNameW and GetOpenFileNameW to the new FunctionHook and FunctionBroker systems.", "files": ["dom/plugins/ipc/FunctionBroker.cpp", "dom/plugins/ipc/FunctionBrokerIPCUtils.cpp", "dom/plugins/ipc/FunctionBrokerIPCUtils.h", "dom/plugins/ipc/FunctionBrokerParent.cpp", "dom/plugins/ipc/FunctionBrokerParent.h", "dom/plugins/ipc/FunctionHook.cpp", "dom/plugins/ipc/PPluginModule.ipdl", "dom/plugins/ipc/PluginMessageUtils.cpp", "dom/plugins/ipc/PluginMessageUtils.h", "dom/plugins/ipc/PluginModuleChild.cpp", "dom/plugins/ipc/PluginModuleParent.cpp", "dom/plugins/ipc/PluginModuleParent.h", "ipc/ipdl/sync-messages.ini"], "git_node": null, "git_parents": [null], "node": "77ccb100a25802415aefdd65f77cce0e2a71e964", "parents": ["e63fa691fa348669f38529083183abfc111f8b2a"], "tags": []}, {"author": "David Parks \u003cdparks@mozilla.com\u003e", "branch": "default", "desc": "Bug 1382251: Part 9 - Hook functions needed for SSL communication in NPAPI process r=jimm\n\nAdds Win32 networking APIs to the function broker so that we can run SSL communications outside of the sandbox.", "files": ["dom/plugins/ipc/FunctionBroker.cpp", "dom/plugins/ipc/FunctionBroker.h", "dom/plugins/ipc/FunctionBrokerIPCUtils.cpp", "dom/plugins/ipc/FunctionBrokerIPCUtils.h"], "git_node": null, "git_parents": [null], "node": "5bf011fc507d5fa1383b0fcfa28b92ff7e13fc10", "parents": ["77ccb100a25802415aefdd65f77cce0e2a71e964"], "tags": []}, {"author": "David Parks \u003cdparks@mozilla.com\u003e", "branch": "default", "desc": "Bug 1382251: Part 10 - Add nsWindowsDllInterceptor tests for the new functions r=aklotz\n\nAdds tests for the DLL interception of the SSL APIs included in the previous patch.", "files": ["toolkit/xre/test/win/TestDllInterceptor.cpp"], "git_node": null, "git_parents": [null], "node": "e9cce57796741c93e2c22a963cee6ec9d37ac7ed", "parents": ["5bf011fc507d5fa1383b0fcfa28b92ff7e13fc10"], "tags": []}, {"author": "David Parks \u003cdparks@mozilla.com\u003e", "branch": "default", "desc": "Bug 1382251: Part 11 - Update moz.build with new files r=jimm\n\nIncludes the build changes made by the earlier patches in this series.  Also adds some #includes required by other files when these are added to the unified build.", "files": ["dom/plugins/ipc/PluginProcessParent.h", "dom/plugins/ipc/moz.build"], "git_node": null, "git_parents": [null], "node": "cc3ec37e0dbe422223a699ff76b94cbc11b28b45", "parents": ["e9cce57796741c93e2c22a963cee6ec9d37ac7ed"], "tags": []}, {"author": "Kai Engert \u003ckaie@kuix.de\u003e", "branch": "default", "desc": "Bug 1420060, trivial bustage fix, export new NSS APIs in Firefox' specific API export list", "files": ["security/nss.symbols"], "git_node": null, "git_parents": [null], "node": "7ce1e0ca10e1ab33b3158934f61ab72e3f3e7aeb", "parents": ["cc3ec37e0dbe422223a699ff76b94cbc11b28b45"], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1428946 - Part 1. Make comparing and mapping DataSourceSurfaceWrapper objects work consistently. r=bas", "files": ["dom/base/nsDOMWindowUtils.cpp", "gfx/2d/2D.h", "gfx/2d/DataSourceSurfaceWrapper.h"], "git_node": null, "git_parents": [null], "node": "779a3a7cd1fd41339e339f2120a68b98622dd914", "parents": ["7ce1e0ca10e1ab33b3158934f61ab72e3f3e7aeb"], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1428946 - Part 2. Make ApplyBlending_SIMD and ApplyArithmeticCombine_SIMD support the same surface for both inputs. r=bas", "files": ["gfx/2d/FilterProcessingSIMD-inl.h"], "git_node": null, "git_parents": [null], "node": "68e0118f11a2e8a71aaff24b57384b15fa087977", "parents": ["779a3a7cd1fd41339e339f2120a68b98622dd914"], "tags": []}, {"author": "Kai Engert \u003ckaie@kuix.de\u003e", "branch": "default", "desc": "Bug 1420060, additional bustage fix as suggested by Masatoshi Kimura, r=kaie, CLOSED TREE", "files": ["security/nss.symbols"], "git_node": null, "git_parents": [null], "node": "7604bcd50b63cc8f3e867d8844d7bab871dc0af3", "parents": ["68e0118f11a2e8a71aaff24b57384b15fa087977"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "servo: Merge #19744 - style: A few trivial changes in preparation for document state invalidation (from emilio:doc-invalidation-preparation); r=upsuper\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 9b3fc43f5a576f4cc466a779e2a308e53a8a46f7", "files": ["servo/components/style/data.rs", "servo/components/style/gecko/non_ts_pseudo_class_list.rs", "servo/components/style/gecko/selector_parser.rs", "servo/components/style/gecko/wrapper.rs", "servo/components/style/invalidation/element/collector.rs", "servo/components/style/invalidation/element/mod.rs", "servo/components/style/invalidation/element/state_and_attributes.rs", "servo/components/style/selector_parser.rs"], "git_node": null, "git_parents": [null], "node": "8b31db3e000c5527e7675b33c6cd648a0e252fbd", "parents": ["ec1a634f8feaa198469acf34f37d13e917175226"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1405636 - enable and rename browser_webconsole_netlogging_reset_filter.js;r=Honza\n\nMozReview-Commit-ID: IcFW6itKo7I", "files": ["devtools/client/webconsole/new-console-output/test/mochitest/browser.ini", "devtools/client/webconsole/new-console-output/test/mochitest/browser_webconsole_netlogging_reset_filter.js", "devtools/client/webconsole/new-console-output/test/mochitest/browser_webconsole_network_messages_openinnet.js", "devtools/client/webconsole/new-console-output/test/mochitest/browser_webconsole_network_reset_filter.js", "devtools/client/webconsole/new-console-output/test/mochitest/head.js"], "git_node": null, "git_parents": [null], "node": "5f6417128acb05b280c3c59a611e605458214dfd", "parents": ["8b31db3e000c5527e7675b33c6cd648a0e252fbd"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1428766 - Update webrender to commit 722e8b104bf99d29d61ecb1fe456eebe89ad81fd. r=jrmuizel\n\nMozReview-Commit-ID: GsDbUIfQFlm", "files": ["gfx/doc/README.webrender", "gfx/webrender/src/batch.rs", "gfx/webrender/src/picture.rs", "gfx/webrender/src/prim_store.rs", "gfx/webrender/src/record.rs", "gfx/webrender/src/render_backend.rs", "gfx/webrender/src/renderer.rs", "gfx/webrender_api/src/api.rs"], "git_node": null, "git_parents": [null], "node": "c31d02201979e5329bf84af157a7a3c666e74ea3", "parents": ["5f6417128acb05b280c3c59a611e605458214dfd"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1428766 - Update for changes in WR PR 2243. r=jrmuizel\n\nMozReview-Commit-ID: 3CG67NcAiRk", "files": ["layout/reftests/svg/filters/css-filter-chains/reftest.list"], "git_node": null, "git_parents": [null], "node": "4d8fbb071d0ef1951b05873bf6dfb797645c2a99", "parents": ["c31d02201979e5329bf84af157a7a3c666e74ea3"], "tags": []}, {"author": "Edouard Oger \u003ceoger@fastmail.com\u003e", "branch": "default", "desc": "Bug 1429245 - Optimize CommonUtils.bytesAsHex. r=tcsc\n\nMozReview-Commit-ID: 2f3o6OwUwn4", "files": ["services/common/utils.js"], "git_node": null, "git_parents": [null], "node": "d7e62d039551133a61070e60dd4fb002db61b6e0", "parents": ["4d8fbb071d0ef1951b05873bf6dfb797645c2a99"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1429116 - Turn Context enum into a class. r=maja_zf\n\nThere is no functional purpose of this patch apart from laying\ngroundwork to make the window tracking patches easier to review.\n\nMozReview-Commit-ID: GOIysDLVWIf", "files": ["testing/marionette/browser.js"], "git_node": null, "git_parents": [null], "node": "706bf6511a6f04f1f05b2d1836d8941511e360e7", "parents": ["d7e62d039551133a61070e60dd4fb002db61b6e0"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1429111 - Remove unused nsITimer from element.Store. r=maja_zf\n\nThere is an unused nsITimer instance in element.Store#timer that\nthis patch safely removes.\n\nMozReview-Commit-ID: APvPsXfHUk9", "files": ["testing/marionette/element.js"], "git_node": null, "git_parents": [null], "node": "ba4ce1d35c2d5aee17412c113473b6673b2b9a7d", "parents": ["706bf6511a6f04f1f05b2d1836d8941511e360e7"], "tags": []}, {"author": "Andrei Oprea \u003candrei.br92@gmail.com\u003e", "branch": "default", "desc": "Bug 1429119 - Revert 1422246 Special handling of about:newtab on session restore r=Mardak\n\nMozReview-Commit-ID: 3wvfWcIpiv3", "files": ["browser/components/sessionstore/SessionStore.jsm"], "git_node": null, "git_pa