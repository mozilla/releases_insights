Stamp.html to consider its upper & lower bounds as part of the valid range. r=birtles, a=test-only\n\nMozReview-Commit-ID: 4FZDKqKZLHM", "files": ["dom/events/test/test_eventTimeStamp.html"], "git_node": null, "git_parents": [null], "node": "323cfb8ec74d7102698ace9735202e8e7bd25479", "parents": ["40d54bf9f2d0b9c9b9649bf58caf5c2f3856c364"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1404253 - Disable places' bookmarks backups in mochitests to avoid intermittent failures. r=mak, a=test-only\n\nMozReview-Commit-ID: 53TipklHXxX", "files": ["testing/profiles/prefs_general.js"], "git_node": null, "git_parents": [null], "node": "7a901ba2676d35d2c90f8236200985e5f51ae28b", "parents": ["323cfb8ec74d7102698ace9735202e8e7bd25479"], "tags": []}, {"author": "Alexandre Poirot \u003cpoirot.alex@gmail.com\u003e", "branch": "default", "desc": "Bug 1426906 - Fix intermittent leak from test_websocket-server.html. r=jryans, a=test-only\n\nMozReview-Commit-ID: HlPgPjCnA1q", "files": ["devtools/server/tests/mochitest/chrome.ini", "devtools/server/tests/mochitest/test_websocket-server.html"], "git_node": null, "git_parents": [null], "node": "201a4b8a3db0ec041742c58b7ac075bc597c3849", "parents": ["7a901ba2676d35d2c90f8236200985e5f51ae28b"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1434715 - Remove reftest-no-accel from windows10. r=ahal, a=test-only", "files": ["taskcluster/ci/test/reftest.yml"], "git_node": null, "git_parents": [null], "node": "1b4ab9a276ce7bb217c02b83057586e7946860f9", "parents": ["201a4b8a3db0ec041742c58b7ac075bc597c3849"], "tags": ["DEVEDITION_59_0b6_BUILD1", "DEVEDITION_59_0b6_RELEASE", "FIREFOX_59_0b6_BUILD1", "FIREFOX_59_0b6_RELEASE"]}], "date": 1517505250, "git_changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "8634": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nes-AR -\u003e 6bd785c61332\nes-MX -\u003e 8d0df747448b\nid -\u003e b36e76b0f407\nmai -\u003e f434a571cd39", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "ff359bfad06d8062e49fcb3bde5a8c0df235b822", "parents": ["1b4ab9a276ce7bb217c02b83057586e7946860f9"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nes-MX -\u003e f8dca03adb64\nid -\u003e b36e76b0f407\npt-BR -\u003e 39749e742c52\nsr -\u003e f2e66bdfcc6f", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "54810cf6c8c4fa1f5ac757b607b243fdd3d2e6b8", "parents": ["ff359bfad06d8062e49fcb3bde5a8c0df235b822"], "tags": []}], "date": 1517537977, "git_changesets": [null, null], "user": "ffxbld"}, "8635": {"changesets": [{"author": "Tom Prince", "branch": "THUNDERBIRD590b1_2018020201_RELBRANCH", "desc": "Bug 1387524 - Back out removal of MOZ_PRETTY to build Thunderbird 59 beta a=jorgk DONTBUILD\n\nBackout most of changeset 318f1bcd336e from bug 1329355 to support building releases on buildbot.\n\nMozReview-Commit-ID: K4QAA8IIpVX", "files": ["toolkit/locales/l10n.mk", "toolkit/mozapps/installer/package-name.mk"], "git_node": null, "git_parents": [null], "node": "cc4b91cf0cdb6f52d448a7eb011993b617ff321b", "parents": ["64737c752ac4af4766ad6f82720818521f3aca24"], "tags": []}], "date": 1517562527, "git_changesets": [null], "user": "mozilla@jorgk.com"}, "8636": {"changesets": [{"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1432864 - Decouple focussing from moving caret in textual form controls. r=automatedtester\n\nRenames the interaction.focusElement, which also happened to move\nthe caret in textual form controls, to interaction.moveCaretToEnd,\nfocussed solely on moving the caret.  It doesn't make sense to\ncoalesce these two operations into one function.\n\nMozReview-Commit-ID: 2QxV8FllW8J", "files": ["testing/marionette/interaction.js"], "git_node": null, "git_parents": [null], "node": "a25a343d7937b33a5771db430776c724870e6c8c", "parents": ["54810cf6c8c4fa1f5ac757b607b243fdd3d2e6b8"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1432864 - Run native focussing steps on interaction commands. r=automatedtester\n\nInstead of generating custom focus events when interacting with elements,\nwe can run the HTMLElement.focus() function will do the correct thing.\n\nBefore this patch we only simulated focus events, whereas this\npatch will actually focus the element.\n\nMozReview-Commit-ID: IoBV2ngqOA5", "files": ["testing/marionette/event.js", "testing/marionette/interaction.js", "testing/web-platform/tests/webdriver/tests/interaction/element_clear.py", "testing/web-platform/tests/webdriver/tests/support/asserts.py"], "git_node": null, "git_parents": [null], "node": "feae5d29e679fb637a0ca44800464fee9f1bc91f", "parents": ["a25a343d7937b33a5771db430776c724870e6c8c"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1432864 - Run unfocussing steps after interaction. r=automatedtester\n\nA couple of commands were not running the appropriate unfocussing\nsteps as the WebDriver standards says they should.\n\nMozReview-Commit-ID: FyuRvkct19m", "files": ["testing/marionette/interaction.js"], "git_node": null, "git_parents": [null], "node": "cc6e54bee19e7153ae5ac6cc7887805f001c2470", "parents": ["feae5d29e679fb637a0ca44800464fee9f1bc91f"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1432864 - Unfocussing steps will target \u003cbody\u003e element. r=automatedtester a=test-only\n\nThe WebDriver Element Send Keys command is meant to run the HTML\nunfocussing steps after clearing the element.  When HTMLElement.blur()\nis called on the root document element (\u003chtml\u003e) it is the \u003cbody\u003e\nthat is in focus when the unfocussing steps have run.\n\nThe same applies in the case of typing into an \u003ciframe\u003e element.\nThe controlling element of the \u003ciframe\u003e is the \u003cbody\u003e, as this is\nthe element ath will receive focus should you blur the frame.\n\nMozReview-Commit-ID: 19Ox3W9CF8O", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/webdriver/tests/element_send_keys/interactability.py"], "git_node": null, "git_parents": [null], "node": "11887cd21e75fcb2a1dd94ad7bd49d81a2acbfe3", "parents": ["cc6e54bee19e7153ae5ac6cc7887805f001c2470"], "tags": []}], "date": 1517573782, "git_changesets": [null, null, null, null], "user": "ccoroiu@mozilla.com"}, "8637": {"changesets": [{"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1389759 - Fix GPUProcessManager::EnsureGPUReady how did not guarantee the GPU process state is consistent. r=rhunt a=lizzard\n\nGPUProcessManager::EnsureGPUReady promises that its state will be\nconsistent after returning. Either the GPU process is ready to be used,\nor there is no GPU process at all. In the case it is attempted to\nsynchronously initialize the GPUChild with the device data and failed,\nit broke that promise. This is because the GPU process was still setup,\nbut we weren't going to use it. This became a problem with the\nCompositorManagerChild because it uses the process token as an\nidentifier, and it should have been reset to 0 in this case.\n\nNow if GPUChild::EnsureGPUReady (the initialization step) fails, we\ndisable the GPU process entirely. This ensures our internal state is\nconsistent and the callers expectations are upheld.", "files": ["gfx/ipc/GPUProcessManager.cpp"], "git_node": null, "git_parents": [null], "node": "7b20f617fd153301eff11f4f892e6dab460ea191", "parents": ["11887cd21e75fcb2a1dd94ad7bd49d81a2acbfe3"], "tags": []}], "date": 1517577193, "git_changesets": [null], "user": "aiakab@mozilla.com"}, "8638": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "Automatic version bump. CLOSED TREE NO BUG a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "f9f68bbfd582f29d050f1f1eaf3121590ca65716", "parents": ["7b20f617fd153301eff11f4f892e6dab460ea191"], "tags": []}, {"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging 1b4ab9a276ce7bb217c02b83057586e7946860f9 with FIREFOX_59_0b6_BUILD1, FIREFOX_59_0b6_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "543fbe7e47c77d03a6e52cfaf4c0387915161148", "parents": ["f9f68bbfd582f29d050f1f1eaf3121590ca65716"], "tags": []}], "date": 1517586510, "git_changesets": [null, null], "user": "ffxbld"}, "8639": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging 1b4ab9a276ce7bb217c02b83057586e7946860f9 with DEVEDITION_59_0b6_BUILD1, DEVEDITION_59_0b6_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "a5992a4e8dc8709a683cc5f464c3320062eb1f61", "parents": ["543fbe7e47c77d03a6e52cfaf4c0387915161148"], "tags": []}], "date": 1517586645, "git_changesets": [null], "user": "ffxbld"}, "8640": {"changesets": [{"author": "tbirdbld", "branch": "THUNDERBIRD590b1_2018020214_RELBRANCH", "desc": "Automated checkin: version bump for thunderbird 59.0b1 release. DONTBUILD CLOSED TREE a=release", "files": [], "git_node": null, "git_parents": [null], "node": "fb77a04662d5b8729d00f32d825c2383831c35e9", "parents": ["cc4b91cf0cdb6f52d448a7eb011993b617ff321b"], "tags": ["THUNDERBIRD_59_0b1_BUILD1"]}, {"author": "tbirdbld", "branch": "THUNDERBIRD590b1_2018020214_RELBRANCH", "desc": "Added THUNDERBIRD_59_0b1_RELEASE THUNDERBIRD_59_0b1_BUILD1 tag(s) for changeset fb77a04662d5. DONTBUILD CLOSED TREE a=release", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "9d044a58d556a5da43ffd47f92d0f30cb5c40b55", "parents": ["fb77a04662d5b8729d00f32d825c2383831c35e9"], "tags": []}], "date": 1517600148, "git_changesets": [null, null], "user": "tbirdbld"}, "8641": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nit -\u003e 48b66ab7f2f2", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "9453ba21f86e0cab272128cdd6fc8ee6acc1c583", "parents": ["a5992a4e8dc8709a683cc5f464c3320062eb1f61"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nit -\u003e 59139c27be13", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "b3403ce787c05d2e3b61786a6d94618a2c32862f", "parents": ["9453ba21f86e0cab272128cdd6fc8ee6acc1c583"], "tags": []}], "date": 1517602792, "git_changesets": [null, null], "user": "ffxbld"}, "8642": {"changesets": [{"author": "Amit Kumar \u003camit2rockpower@gmail.com\u003e", "branch": "default", "desc": "Bug 1431535 - Increase timeout for new connection in test_disable_enable_new_connections from timeout 1.0 to 10.0. r=whimboo, a=test-only\n\nMozReview-Commit-ID: KjRu5yMHxFO", "files": ["testing/marionette/harness/marionette_harness/tests/unit/test_marionette.py"], "git_node": null, "git_parents": [null], "node": "5ed2ef7317d085d0db3879af1442ab82da2ce3f2", "parents": ["b3403ce787c05d2e3b61786a6d94618a2c32862f"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1435079 - Stop running most Android non-gradle tests. r=jmaher, a=test-only\n\nAndroid non-gradle tests run against an Android apk built without\ngradle, \"Bng\" on treeherder; confusingly, this platform is labelled\n\"Android API16+ Gradle opt\". This patch significantly reduces the\ntests run on this platform: now only robocop tests are run.\n\nThe full set of Android tests, including mochitests and reftests,\ncontinue to run on the \"Android 4.3 API16+ opt\" platform.", "files": ["taskcluster/ci/test/test-platforms.yml"], "git_node": null, "git_parents": [null], "node": "e82e444a853a8f3ea5315614ed33b90764e0edc4", "parents": ["5ed2ef7317d085d0db3879af1442ab82da2ce3f2"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1422234 - Part 1: HTMLEditRules::ReturnInParagraph() should adjust split point if caret position is positioned at edge of anchor element. r=m_kato, a=lizzard\n\nWhen Enter key is pressed at start or end of \u003ca href=\"foo\"\u003e element, we\nshouldn't split it (in other words, we shouldn't create empty \u003ca href=\"foo\"\u003e\nelement in new paragraph) because users must not want to keep editing *same*\nlink in new paragraph in most cases.\n\nThis patch adjusts HTMLEditRules::ReturnInParagraph() selection start point\nlocally when it gets selection.  If caret is at start of an \u003ca href=\"foo\"\u003e\nelement, moves caret to before the element.  If caret is at end of an\n\u003ca href=\"foo\"\u003e element, moves to after the element.\n\nMozReview-Commit-ID: 3L3eDzc6Dk", "files": ["editor/libeditor/EditorDOMPoint.h", "editor/libeditor/HTMLEditRules.cpp", "testing/web-platform/meta/editing/run/insertparagraph.html.ini"], "git_node": null, "git_parents": [null], "node": "1d6350b5091323b87ba8ae42b440ae8c99fa7a56", "parents": ["e82e444a853a8f3ea5315614ed33b90764e0edc4"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1422234 - Part 2: Add wpt-tests to check if insertParagraph command splits or doesn't split inline elements at their edge. r=m_kato, a=lizzard\n\nSpec bug: https://github.com/w3c/editing/issues/172\n\nInline elements in paragraph except anchor elements which have non-empty\nhref attribute should be created in new paragraph even when new ones are\nempty because users must expect to keep writing some text with same style,\nbut for anchor elements with non-empty href attribute, users must not\nexpect to create same link in new paragraph in most cases.\n\nMozReview-Commit-ID: KjpOzfv4F0j", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/meta/editing/run/insertparagraph.html.ini", "testing/web-platform/tests/editing/data/insertparagraph.js"], "git_node": null, "git_parents": [null], "node": "0fe1f0b63facaac51367d071018d8c22612bbb80", "parents": ["1d6350b5091323b87ba8ae42b440ae8c99fa7a56"], "tags": []}, {"author": "Olli Pettay \u003cOlli.Pettay@helsinki.fi\u003e", "branch": "default", "desc": "Bug 1434580 - Ensure proper mouseover handling. r=masayuki, a=abillings", "files": ["dom/events/EventStateManager.cpp"], "git_node": null, "git_parents": [null], "node": "8660689b18cd25f0110276bfc5bb8e8dd9c325f9", "parents": ["0fe1f0b63facaac51367d071018d8c22612bbb80"], "tags": []}], "date": 1517605208, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8643": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\neo -\u003e f049a4ca3652\nhe -\u003e e7eebebf34c3\nmai -\u003e 2a0ae4bd0ecb\nsk -\u003e f8abac6dccc7\nte -\u003e b20706cc9ad0\nuk -\u003e 8b70f9d1d332\nvi -\u003e 42b8b550e73b", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "4bb81205ea3f68a8bd17dea16ea2874d5411bde6", "parents": ["8660689b18cd25f0110276bfc5bb8e8dd9c325f9"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc":