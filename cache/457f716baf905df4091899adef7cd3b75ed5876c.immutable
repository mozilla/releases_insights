dom/canvas/WebGLContextDraw.cpp", "dom/canvas/WebGLContextValidate.cpp"], "git_node": null, "git_parents": [null], "node": "1c2bf2316ce642b25f0e1ff27f17ea2ecf5d5955", "parents": ["e475fdfb17d48d7b5fe1073d0e99127b8da68769"], "tags": []}], "date": 1485480077, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "6834": {"changesets": [{"author": "Timothy Nikkel \u003ctnikkel@gmail.com\u003e", "branch": "default", "desc": "Bug 1332569. r=bzbarsky a=dveditz", "files": ["dom/xslt/xslt/txMozillaXMLOutput.cpp"], "git_node": null, "git_parents": [null], "node": "872d753fafbc61e948b9da0d0b161548bca43261", "parents": ["1c2bf2316ce642b25f0e1ff27f17ea2ecf5d5955"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1323185 - Fix test_close_not_selected_tab for correctly closing a background tab. r=maja_zf a=test-only\n\nIt should not be possible to close a background tab via the menu shortcut.\nInstead another method should be used, best here is the close button.\n\nMozReview-Commit-ID: 3cZmAyPsnj7", "files": ["testing/firefox-ui/tests/puppeteer/test_tabbar.py"], "git_node": null, "git_parents": [null], "node": "615cff70df60f377dc3f51ddb1fd1b27fd1a5a25", "parents": ["872d753fafbc61e948b9da0d0b161548bca43261"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1323185 - Skip unit tests which should not be run with Fennec. r=maja_zf a=test-only\n\nMozReview-Commit-ID: 5aiuT7vlm3f", "files": ["testing/marionette/harness/marionette_harness/tests/unit/test_window_close_content.py"], "git_node": null, "git_parents": [null], "node": "9cc076bce62f459533edef870c72057361d15a37", "parents": ["615cff70df60f377dc3f51ddb1fd1b27fd1a5a25"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1323185 - Add window (tab) handling support for Fennec. r=ato a=test-only\n\nSo far Marionette did support Fennec but not any of its tab handling\nfeatures. As such most of the commands fail because they do not take\nBrowserApp into account.\n\nThis patch adds support for retrieving window handles, switching\nbetween windows, and closing tabs.\n\nAdditionally to those changes a couple of unit tests are getting\nupdated, and added.\n\nMozReview-Commit-ID: 7sbVIblm0Hw", "files": ["testing/marionette/browser.js", "testing/marionette/driver.js", "testing/marionette/harness/marionette_harness/tests/unit/test_about_pages.py", "testing/marionette/harness/marionette_harness/tests/unit/test_window_handles.py", "testing/marionette/harness/marionette_harness/tests/unit/test_window_handles_chrome.py", "testing/marionette/harness/marionette_harness/tests/unit/test_window_handles_content.py", "testing/marionette/harness/marionette_harness/tests/unit/unit-tests.ini", "testing/marionette/harness/marionette_harness/www/windowHandles.html"], "git_node": null, "git_parents": [null], "node": "88d8b4f8a2dfc0ea1b22c8e9fdb196ce61d1306f", "parents": ["9cc076bce62f459533edef870c72057361d15a37"], "tags": []}, {"author": "Kate McKinley \u003ckmckinley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1329940 - Ignore window.opener for password manager warnings r=baku,jwatt,MattN a=jcristau\n\nMozReview-Commit-ID: KiIR6WEddgO", "files": ["dom/base/nsGlobalWindow.cpp", "dom/base/nsGlobalWindow.h", "dom/base/nsPIDOMWindow.h", "dom/webidl/Window.webidl", "toolkit/components/passwordmgr/InsecurePasswordUtils.jsm"], "git_node": null, "git_parents": [null], "node": "f28c092abe746a9c7b39fb5c715141810a9c87d4", "parents": ["88d8b4f8a2dfc0ea1b22c8e9fdb196ce61d1306f"], "tags": []}], "date": 1485523864, "git_changesets": [null, null, null, null, null], "user": "cbook@mozilla.com"}, "6835": {"changesets": [{"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1331619 Make ServiceWorkerClients check the return value of OpenWindow2(). r=catalinb a=jcristau", "files": ["dom/workers/ServiceWorkerClients.cpp