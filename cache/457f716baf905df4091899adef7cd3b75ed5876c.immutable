7a918dc24076077a5b31d241476", "parents": ["3d077ece238f535f4085cb513becddfb5297c8d7"], "tags": []}], "date": 1487084572, "git_changesets": [null, null, null, null, null, null, null], "user": "cbook@mozilla.com"}, "6927": {"changesets": [{"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1325052. r=Waldo a=jcristau", "files": ["js/src/jsarray.cpp"], "git_node": null, "git_parents": [null], "node": "2004932dea6e6092f0446fc8fe0599d998dcbaed", "parents": ["d719bea83ed157a918dc24076077a5b31d241476"], "tags": []}, {"author": "Ray Lin \u003clieeray4136@gmail.com\u003e", "branch": "default", "desc": "Bug 1332994 - highlight current enabled CC item when video first loaded. r=jaws a=jcristau\n\nMozReview-Commit-ID: DWaGb1YSzGt", "files": ["toolkit/content/tests/widgets/test_videocontrols_vtt.html", "toolkit/content/widgets/videocontrols.xml"], "git_node": null, "git_parents": [null], "node": "b79afbae1a169374c257ef9ed72a081f0d21a07b", "parents": ["2004932dea6e6092f0446fc8fe0599d998dcbaed"], "tags": []}, {"author": "David Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "Bug 1338228 - disable SHA-1 for 100% of beta users and 25% of release users r=jcj a=jcristau", "files": ["browser/extensions/disableSHA1rollout/bootstrap.js", "browser/extensions/disableSHA1rollout/install.rdf.in"], "git_node": null, "git_parents": [null], "node": "3a0e9dab386403cec5b899eb7f321c2aa27e0186", "parents": ["b79afbae1a169374c257ef9ed72a081f0d21a07b"], "tags": []}], "date": 1487084961, "git_changesets": [null, null, null], "user": "cbook@mozilla.com"}, "6928": {"changesets": [{"author": "Rail Aliiev \u003crail@mozilla.com\u003e", "branch": "default", "desc": "Bug 1337366 - Gecko-specific changes to support mozilla-esr52 r=jlund\n\nMozReview-Commit-ID: KrXbAPLEN2m", "files": ["testing/mozharness/configs/merge_day/bump_esr.py", "testing/mozharness/configs/merge_day/release_to_esr.py", "testing/mozharness/configs/multi_locale/release_mozilla-esr_android-armv6.json", "testing/mozharness/configs/multi_locale/staging_release_mozilla-esr_android-armv6.json", "testing/mozharness/configs/releases/postrelease_esr38.py", "testing/mozharness/configs/releases/postrelease_firefox_esr45.py", "testing/mozharness/configs/releases/postrelease_firefox_esr52.py", "testing/mozharness/configs/releases/updates_firefox_esr45.py", "testing/mozharness/configs/releases/updates_firefox_esr52.py", "testing/mozharness/configs/single_locale/mozilla-esr45.py", "testing/mozharness/configs/single_locale/mozilla-esr52.py"], "git_node": null, "git_parents": [null], "node": "57673f0994a00eeb23bd530ea52c47ce15569ce6", "parents": ["3a0e9dab386403cec5b899eb7f321c2aa27e0186"], "tags": []}, {"author": "Rail Aliiev \u003crail@mozilla.com\u003e", "branch": "default", "desc": "Bug 1337366 - Remove reference to unused latest_mar_dir r=jlund a=release DONTBUILD\n\nMozReview-Commit-ID: Ba8rzGPJnGt", "files": ["testing/mozharness/configs/single_locale/alder.py", "testing/mozharness/configs/single_locale/ash.py", "testing/mozharness/configs/single_locale/dev-mozilla-beta.py", "testing/mozharness/configs/single_locale/dev-mozilla-release.py", "testing/mozharness/configs/single_locale/mozilla-aurora.py", "testing/mozharness/configs/single_locale/mozilla-beta.py", "testing/mozharness/configs/single_locale/mozilla-central.py", "testing/mozharness/configs/single_locale/mozilla-release.py", "testing/mozharness/configs/single_locale/try.py", "testing/mozharness/mozharness/mozilla/building/buildbase.py", "testing/mozharness/scripts/desktop_l10n.py", "testing/mozharness/scripts/fx_desktop_build.py"], "git_node": null, "git_parents": [null], "node": "20c0934c5df550e81fc7f3460f34e157d055ffc3", "parents": ["57673f0994a00eeb23bd530ea52c47ce15569ce6"], "tags": []}], "date": 1487091331, "git_changesets": [null, null], "user": "raliiev@mozilla.com"}, "6929": {"changesets": [{"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1276669 - Part 1: Make nsHtml5Atoms initialization explicit in nsLayoutStatics. r=hsivonen, a=jcristau\n\nMoving the html5 atoms out into their own initialization phase makes the\ninitialization of atoms more explicit and avoids problems with trying to\nmove modules around so their atoms get initialized in the correct place.\nAs an aesthetic bonus, this change produces pleasing symmetry in\nnsHtml5Module::{Initialize,Release}Statics.\n\nReviewed-by: Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "files": ["layout/build/nsLayoutStatics.cpp", "parser/html/nsHtml5Module.cpp"], "git_node": null, "git_parents": [null], "node": "c2a2e606cf8d859a427aa8004ff90e948b3f6562", "parents": ["20c0934c5df550e81fc7f3460f34e157d055ffc3"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1276669 - Part 2: Move nsTextServicesDocument::RegisterAtoms call. r=bz, a=jcristau\n\nMoving this call closer to the other atom initializations will enable us\nto seal the static atom table sooner.", "files": ["layout/build/nsLayoutStatics.cpp"], "git_node": null, "git_parents": [null], "node": "1962102a1aaf33af66db76c7da78cccb4a6b845f", "parents": ["c2a2e606cf8d859a427aa8004ff90e948b3f6562"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1276669 - Part 3: Split out nsHTMLTags atom initialization. r=hsivonen, a=jcristau\n\nWe do this for much the same reason that we moved the nsHtml5Atoms\ninitialization.  Otherwise, the nsHTMLTags atoms are lazily initialized\nlong after we've sealed the static atom table in nsLayoutStatics.", "files": ["layout/build/nsLayoutStatics.cpp", "parser/htmlparser/nsHTMLTags.cpp", "parser/htmlparser/nsHTMLTags.h"], "git_node": null, "git_parents": [null], "node": "03ec073931a45ebc051ac3468e508aac34942c0d", "parents": ["1962102a1aaf33af66db76c7da78cccb4a6b845f"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1276669 - Part 4: Initialize RDF atoms in nsLayoutStatics. r=Pike, a=jcristau\n\nThis is not the cleanest code ever, but we need to move all static atom\ninitialization prior to NS_SealStaticAtomTable to avoid the possibility\nof dynamic atoms being transmuted into static atoms.  We therefore need\nto open up an avenue for somebody else to initialize the atoms that RDF needs.", "files": ["layout/build/nsLayoutStatics.cpp", "rdf/base/nsIRDFContentSink.h", "rdf/base/nsRDFContentSink.cpp"], "git_node": null, "git_parents": [null], "node": "27e0795c40f5d12c9ba9822e89ddd3f4641a759e", "parents": ["03ec073931a45ebc051ac3468e508aac34942c0d"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1276669 - Part 5: Don't try to test NS_RegisterStaticAtoms. r=erahm, a=jcristau\n\nThere are several XPCOM tests that purport to call\nNS_RegisterStaticAtoms.  The tests located in the xpcom/tests/ directory\nare unused, so we might as well just remove them.  The gtests do get\nrun, but there's going to be no way to test NS_RegisterStaticAtoms once\nsealing the atom table actually means forbidding new additions.  So we\nmight as well remove the gtest too.", "files": ["xpcom/tests/MoreTestingAtomList.h", "xpcom/tests/MoreTestingAtoms.cpp", "xpcom/tests/MoreTestingAtoms.h", "xpcom/tests/TestStaticAtoms.cpp", "xpcom/tests/TestingAtoms.cpp", "xpcom/tests/TestingAtoms.h", "xpcom/tests/gtest/TestAtoms.cpp", "xpcom/tests/moz.build"], "git_node": null, "git_parents": [null], "node": "72914fb1b733b2db149fd4c734ee0211f647874d", "parents": ["27e0795c40f5d12c9ba9822e89ddd3f4641a759e"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1276669 - Part 6: Seal the static atom table sooner. r=bz, a=jcristau\n\nWe do this to ensure that everybody has registered all the static atoms\nwe'll care about, and to pave the way for asserting that nobody is\ntrying to create any static atoms past this point in the next patch.", "files": ["layout/build/nsLayoutStatics.cpp"], "git_node": null, "git_parents": [null], "node": "275d01760b8c4ad1cd8e85f42b54bb260e2b44be", "parents": ["72914fb1b733b2db149fd4c734ee0211f647874d"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1276669 - Part 7: Don't register static atoms after the table has been sealed. r=erahm, a=jcristau\n\nThis change seems like an obvious thing we should have been doing, but\nwe weren't.", "files": ["xpcom/ds/nsAtomTable.cpp"], "git_node": null, "git_parents": [null], "node": "12178b9ec166a1d51527584a861e9755b2b75cee", "parents": ["275d01760b8c4ad1cd8e85f42b54bb260e2b44be"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1276669 - Part 8: Add a comment in NS_InitXPCOM2 to make static atom initialization less cryptic. r=erahm, a=jcristau\n\nThis comment makes things slightly more greppable.", "files": ["xpcom/build/XPCOMInit.cpp"], "git_node": null, "git_parents": [null], "node": "61056266ab9e44a315247104aac6576db1a68729", "parents": ["12178b9ec166a1d51527584a861e9755b2b75cee"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1276669 - Part 9: Forbid transmutation of dynamic atoms. r=erahm, a=jcristau\n\nWe can do this now that we've shuffled static atom initialization around\nappropriately.", "files": ["xpcom/ds/nsAtomTable.cpp"], "git_node": null, "git_parents": [null], "node": "7b7ca08168a046b7cac9cf96ea459f2ae96aa7c2", "parents": ["61056266ab9e44a315247104aac6576db1a68729"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1276669 - Part 10: Remove dynamic-\u003estatic atom transmutation code. r=erahm, a=jcristau\n\nGood riddance to some sketchy code.", "files": ["xpcom/ds/nsAtomTable.cpp"], "git_node": null, "git_parents": [null], "node": "345d7454ed893a80bba18a3cf697c303465447d0", "parents": ["7b7ca08168a046b7cac9cf96ea459f2ae96aa7c2"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1276669 - Part 11: Strengthen assertions for atom table shutdown GC. r=erahm, a=jcristau\n\nThis could have been done more simply, but the small amount of\nrefactoring that takes place in this comment enables better error\nmessages in the case where something does go wrong.", "files": ["xpcom/ds/nsAtomTable.cpp"], "git_node": null, "git_parents": [null], "node": "49f969a728e99b3cc3bc8759c226e93a34b9b08b", "parents": ["345d7454ed893a80bba18a3cf697c303465447d0"], "tags": []}, {"author": "Jorg K \u003cjorgk@jorgk.com\u003e", "branch": "default", "desc": "Bug 1335854 - Tone down non-zero refcount message for dynamic atoms. r=froydnj, a=jcristau", "files": ["xpcom/ds/nsAtomTable.cpp"], "git_node": null, "git_parents": [null], "node": "97ce4f0843b9aa1288ddf3553efe1d0c2fd8c6a4", "parents": ["49f969a728e99b3cc3bc8759c226e93a34b9b08b"], "tags": []}], "date": 1487097067, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "6930": {"changesets": [{"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1325707: P1. Check returned value. r=gerald, a=jcristau\n\nThis is really just for cleanliness perspective, as it can never happen, we always check that demuxing a packet succeeded first.\n\nMozReview-Commit-ID: FQ1yz16m9Ix\n", "files": ["dom/media/ogg/OggCodecState.cpp", "dom/media/ogg/OggDemuxer.cpp"], "git_node": null, "git_parents": [null], "node": "52f1268d8868d8295865c9fa12600c1dad3798e8", "parents": ["97ce4f0843b9aa1288ddf3553efe1d0c2fd8c6a4"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1325707: P2. Handle OOM conditions when creating MediaRawData object. r=gerald, a=jcristau\n\nMozReview-Commit-ID: HtkhrT36Kf4\n", "files": ["dom/media/gmp/widevine-adapter/WidevineVideoDecoder.cpp", "dom/media/ipc/VideoDecoderParent.cpp", "dom/media/ogg/OggCodecState.cpp", "dom/media/webm/WebMDemuxer.cpp"], "git_node": null, "git_parents": [null], "node": "d2d15b1d60525688a744450736174f24dfe7794d", "parents": ["52f1268d8868d8295865c9fa12600c1dad3798e8"], "tags": []}], "date": 1487104047, "git_changesets": [null, null], "user": "jyavenard@mozilla.com"}, "6931": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1325707 - Change IPC_OK() to true to fix bustage in VideoDecoderParent.cpp. a=bustage", "files": ["dom/media/ipc/VideoDecoderParent.cpp"], "git_node": null, "git_parents": [null], "node": "bcb00c291057912faded2a802c72d01c9cb1e76d", "parents": ["d2d15b1d60525688a744450736174f24dfe7794d"], "tags": []}], "date": 1487105139, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "6932": {"changesets": [{"author": "Paul Adenot \u003cpaul@paul.cx\u003e", "branch": "default", "desc": "Bug 1339438 - Fix the test that checks that MediaElementAudioSourceNode are working correctly. r=pehrsons a=test-only\n\nMozReview-Commit-ID: Fazp4QsbxHk", "files": ["dom/media/webaudio/test/mochitest.ini", "dom/media/webaudio/test/sine-440-10s.opus", "dom/media/webaudio/test/test_mediaElementAudioSourceNodeFidelity.html"], "git_node": null, "git_parents": [null], "node": "5e8f82a565cfe536feb9bb3a6b16395eaf14bf40", "parents": ["bcb00c291057912faded2a802c72d01c9cb1e76d"], "tags": []}], "date": 1487163048, "git_changesets": [null], "user": "paul@paul.cx"}, "6933": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "THUNDERBIRD520b3_2017021501_RELBRANCH", "desc": "Bug 1322027 - Update jemalloc 4 to version 4.4.0. r=glandium a=jorgk", "files": ["build/autoconf/jemalloc.m4", "memory/jemalloc/src/ChangeLog", "memory/jemalloc/src/INSTALL", "memory/jemalloc/src/Makefile.in", "memory/jemalloc/src/VERSION", "memory/jemalloc/src/build-aux/config.guess", "memory/jemalloc/src/build-aux/config.sub", "memory/jemalloc/src/configure", "memory/jemalloc/src/configure.ac", "memory/jemalloc/src/doc/jemalloc.xml.in", "memory/jemalloc/src/include/jemalloc/internal/arena.h", "memory/jemalloc/src/include/jemalloc/internal/chunk.h", "memory/jemalloc/src/include/jemalloc/internal/extent.h", "memory/jemalloc/src/include/jemalloc/internal/jemalloc_internal.h.in", "memory/jemalloc/src/include/jemalloc/internal/jemalloc_internal_defs.h.in", "memory/jemalloc/src/include/jemalloc/internal/pages.h", "memory/jemalloc/src/include/jemalloc/internal/private_symbols.txt", "memory/jemalloc/src/include/jemalloc/internal/stats.h", "memory/jemalloc/src/include/jemalloc/internal/util.h", "memory/jemalloc/src/include/jemalloc/internal/valgrind.h", "memory/jemalloc/src/msvc/projects/vc2015/test_threads/test_threads.cpp", "memory/jemalloc/src/src/arena.c", "memory/jemalloc/src/src/base.c", "memory/jemalloc/src/src/chunk.c", "memory/jemalloc/src/src/chunk_dss.c", "memory/jemalloc/src/src/extent.c", "memory/jemalloc/src/src/huge.c", "memory/jemalloc/src/src/jemalloc.c", "memory/jemalloc/src/src/pages.c", "memory/jemalloc/src/src/stats.c", "memory/jemalloc/src/src/tcache.c", "memory/jemalloc/src/src/util.c", "memory/jemalloc/src/test/integration/MALLOCX_ARENA.c", "memory/jemalloc/src/test/integration/allocated.c", "memory/jemalloc/src/test/integration/chunk.c", "memory/jemalloc/src/test/integration/mallocx.c", "memory/jemalloc/src/test/integration/overflow.c", "memory/jemalloc/src/test/integration/rallocx.c", "memory/jemalloc/src/test/integration/sdallocx.c", "memory/jemalloc/src/test/integration/thread_arena.c", "memory/jemalloc/src/test/integration/thread_tcache_enabled.c", "memory/jemalloc/src/test/integration/xallocx.c", "memory/jemalloc/src/test/unit/arena_reset.c", "memory/jemalloc/src/test/unit/decay.c", "memory/jemalloc/src/test/unit/mallctl.c", "memory/jemalloc/src/test/unit/pack.c", "memory/jemalloc/src/test/unit/pages.c", "memory/jemalloc/src/test/unit/prof_accum.c", "memory/jemalloc/src/test/unit/prof_active.c", "memory/jemalloc/src/test/unit/prof_gdump.c", "memory/jemalloc/src/test/unit/prof_idump.c", "memory/jemalloc/src/test/unit/prof_reset.c", "memory/jemalloc/src/test/unit/prof_thread_name.c", "memory/jemalloc/src/test/unit/run_quantize.c", "memory/jemalloc/src/test/unit/size_classes.c", "memory/jemalloc/src/test/unit/stats.c", "memory/jemalloc/src/test/unit/tsd.c", "memory/jemalloc/src/test/unit/util.c", "memory/jemalloc/upstream.info"], "git_node": null, "git_parents": [null], "node": "2de37a3fe26522d1ffe690328b739b91bb4babb8", "parents": ["5e8f82a565cfe536feb9bb3a6b16395eaf14bf40"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "THUNDERBIRD520b3_2017021501_RELBRANCH", "desc": "Bug 1322027 - Don't disable hugepage support since it no longer causes PGO issues. a=jorgk", "files": ["build/autoconf/jemalloc.m4"], "git_node": null, "git_parents": [null], "node": "6b15a1c1b523a4c26f9ffd9a0ee224b7ee281a64", "parents": ["2de37a3fe26522d1ffe690328b739b91bb4babb8"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "THUNDERBIRD520b3_2017021501_RELBRANCH", "desc": "Bug 1311039 - Properly detect the default malloc zone on OSX 10.12. r=njn a=jorgk", "files": ["memory/mozjemalloc/jemalloc.c"], "git_node": null, "git_parents": [null], "node": "339db4c6bec0f0b21e4ad443e95364ce80e46c05", "parents": ["6b15a1c1b523a4c26f9ffd9a0ee224b7ee281a64"], "tags": []}, {"author": "John Paul Adrian Glaubitz \u003cglaubitz@physik.fu-berlin.de\u003e", "branch": "THUNDERBIRD520b3_2017021501_RELBRANCH", "desc": "Bug 1275204 - mozjemalloc: Use better pre-processor defines for sparc64. r=glandium a=jorgk", "files": ["memory/mozjemalloc/jemalloc.c"], "git_node": null, "git_parents": [null], "node": "f87031603d732aa84a32409a0d50fd09064a8b89", "parents": ["339db4c6bec0f0b21e4ad443e95364ce80e46c05"], "tags": []}, {"author": "John Paul Adrian Glaubitz \u003cglaubitz@physik.fu-berlin.de\u003e", "branch": "THUNDERBIRD520b3_2017021501_RELBRANCH", "desc": "Bug 1275204 - mozjemalloc: Use the JS arm64 allocator on Linux/sparc64. r=glandium a=jorgk", "files": ["memory/mozjemalloc/jemalloc.c"], "git_node": null, "git_parents": [null], "node": "8e6231d2b82e0e7cd5a21c6cd516963b4a8aa298", "parents": ["f87031603d732aa84a32409a0d50fd09064a8b89"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "THUNDERBIRD520b3_2017021501_RELBRANCH", "desc": "Bug 1286613 - Properly call mozjemalloc pre/post fork hooks on OSX when replace-malloc is enabled. r=njn a=jorgk\n\nSomehow, we never called those hooks when replace-malloc is enabled. I'd\nexpect this to cause random deadlocks when forking, and I'm surprised\nthis hasn't surfaced. Maybe it actually causes some intermittent oranges\non automation, who knows.\n\nThis also brings consistency with what is done for jemalloc 4, and with\nthe mozjemalloc implementation, too, that we're going to replace with\nthis one in a subsequent changeset.", "files": ["memory/build/replace_malloc.c", "memory/mozjemalloc/jemalloc.c"], "git_node": null, "git_parents": [null], "node": "b76377c0399b2680450d570d670f9bf70105bafe", "parents": ["8e6231d2b82e0e7cd5a21c6cd516963b4a8aa298"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "THUNDERBIRD520b3_2017021501_RELBRANCH", "desc": "Bug 1286613 - Move replace-malloc zone allocator to a separate file. r=njn a=jorgk\n\nThe intent here is to reuse the zone allocator for mozjemalloc, to avoid\nall the shortcomings of mozjemalloc using a different one. This change\nonly moves the replace-malloc zone allocator out of replace-malloc.c, to\nmake changes for mozjemalloc integration clearer.", "files": ["memory/build/moz.build", "memory/build/replace_malloc.c", "memory/build/zone.c"], "git_node": null, "git_parents": [null], "node": "f70c4c3941b199481dae7e51ce55f1b9102e04fc", "parents": ["b76377c0399b2680450d570d670f9bf70105bafe"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "THUNDERBIRD520b3_2017021501_RELBRANCH", "desc": "Bug 1286613 - Use the same zone allocator implementation as replace-malloc for mozjemalloc. r=njn a=jorgk\n\nWe have been using a different zone allocator between mozjemalloc and\nreplace-malloc for a long time. Jemalloc 4 uses the same as\nreplace-malloc, albeit as part of the jemalloc upstream code base.\n\nWe've been bitten many times in the past with Apple changes breaking the\nzone allocator, and each time we've had to make changes to the three\ninstances, although two of them are similar and the changes there are\nstraightforward.\n\nIt also turns out that the way the mozjemalloc zone allocator is set up,\nwhen a new version of OSX appears with a new version of the system zone\nallocator, Firefox ends up using the system allocator, because the zone\nallocator version is not supported.\n\nSo, we use the same zone allocator for both replace-malloc and\nmozjemalloc, making everything on par with jemalloc 4.", "files": ["memory/build/moz.build", "memory/build/zone.c", "memory/mozjemalloc/jemalloc.c", "memory/mozjemalloc/osx_zone_types.h"], "git_node": null, "git_parents": [null], "node": "5cfc35d102ae0bc4a2268139292e83a0cd827ea6", "parents": ["f70c4c3941b199481dae7e51ce55f1b9102e04fc"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "THUNDERBIRD520b3_2017021501_RELBRANCH", "desc": "Bug 1286613 - Don't rely on OSX SDK malloc/malloc.h for malloc_zone struct definitions. r=njn a=jorgk\n\nThe SDK jemalloc is built against might be not be the latest for various\nreasons, but the resulting binary ought to work on newer versions of\nOSX.\n\nIn order to ensure this, we need the fullest definitions possible, so\ncopy what we need from the latest version of malloc/malloc.h available\non opensource.apple.com.\n\n[Adapted from\nhttps://github.com/jemalloc/jemalloc/commit/c68bb4179312665e22d375aecf9f4306607c7c1a]", "files": ["memory/build/zone.c"], "git_node": null, "git_parents": [null], "node": "c167ab84f6087db0571429062012e9532e5fbac0", "parents": ["5cfc35d102ae0bc4a2268139292e83a0cd827ea6"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "THUNDERBIRD520b3_2017021501_RELBRANCH", "desc": "Bug 1286613 - Add dummy implementations for most remaining OSX zone allocator functions. r=njn a=jorgk\n\nSome system libraries are using malloc_default_zone() and then using\nsome of the malloc_zone_* API. Under normal conditions, those functions\ncheck the malloc_zone_t/malloc_introspection_t struct for the values\nthat are allowed to be NULL, so that a NULL deref doesn't happen.\n\nAs of OSX 10.12, malloc_default_zone() doesn't return the actual default\nzone anymore, but returns a fake, wrapper zone. The wrapper zone defines\nall the possible functions in the malloc_zone_t/malloc_introspection_t\nstruct (almost), and calls the function from the registered default zone\n(jemalloc in our case) on its own. Without checking whether the pointers\nare NULL.\n\nThis means that a system library that calls e.g.\nmalloc_zone_batch_malloc(malloc_default_zone(), ...) ends up trying to\ncall jemalloc_zone.batch_malloc, which is NULL, and crash follows.\n\nSo as of OSX 10.12, the default zone is required to have all the\nfunctions available (really, the same as the wrapper zone), even if they\ndo nothing.\n\nThis is arguably a bug in libsystem_malloc in OSX 10.12, but jemalloc\nstill needs to work in that case.\n\n[Adapted from\nhttps://github.com/jemalloc/jemalloc/commit/c6943acb3c56d1b3d1e82dd43b3fcfeae7771990]", "files": ["memory/build/zone.c"], "git_node": null, "git_parents": [null], "node": "42c68421c0844c74f947675fc9006844edaeb6ed", "parents": ["c167ab84f6087db0571429062012e9532e5fbac0"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "THUNDERBIRD520b3_2017021501_RELBRANCH", "desc": "Bug 1286613 - Update jemalloc 4 to c6943ac. r=njn a=jorgk\n\nThis picks the same changes as the ones we just did to\nmemory/build/zone.c, plus a oneliner for sparc64.", "files": ["memory/jemalloc/src/VERSION", "memory/jemalloc/src/configure", "memory/jemalloc/src/configure.ac", "memory/jemalloc/src/include/jemalloc/internal/jemalloc_internal.h.in", "memory/jemalloc/src/include/jemalloc/internal/jemalloc_internal_defs.h.in", "memory/jemalloc/src/include/jemalloc/internal/mb.h", "memory/jemalloc/src/src/zone.c", "memory/jemalloc/upstream.info"], "git_node": null, "git_parents": [null], "node": "b65cb0c58fdfb56fd77cd6c0775910d3148c9769", "parents": ["42c68421c0844c74f947675fc9006844edaeb6ed"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "THUNDERBIRD520b3_2017021501_RELBRANCH", "desc": "Bug 1332508 - Reinitialize allocator mutexes in fork() child processes. r=njn a=jorgk DONTBUILD\n\nAdapted from\nhttps://github.com/jemalloc/jemalloc/commit/4e2e3dd9cf19ed5991938a708a8b50611aa5bbf8\nand\nhttps://github.com/jemalloc/jemalloc/commit/d9f7b2a4307f7ff9f7a139b33d366d44e8a8b83d\n\nAs per the latter commit, it would seem unlocking, in fork() child\nprocesses, mutexes that were locked in the parent process is not really\nwell supported on OSX 10.12. The addition of the zone_reinit_lock\nfunction in 10.12 supports this idea.", "files": ["memory/build/zone.c", "memory/mozjemalloc/jemalloc.c"], "git_node": null, "git_parents": [null], "node": "83856b479b9a29e49e80ff42c1227c84a9a3e086", "parents": ["b65cb0c58fdfb56fd77cd6c0775910d3148c9769"], "tags": []}], "date": 1487169205, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "mozilla@jorgk.com"}, "6934": {"changesets": [{"author": "tbirdbld", "branch": "THUNDERBIRD520b3_2017021511_RELBRANCH", "desc": "Automated checkin: version bump for thunderbird 52.0b3 release. DONTBUILD CLOSED TREE a=release", "files": [], "git_node": null, "git_parents": [null], "node": "a73b7f5955b2369745213bde42d315ee4af31b12", "parents": ["83856b479b9a29e49e80ff42c1227c84a9a3e086"], "tags": ["THUNDERBIRD_52_0b3_BUILD1", "THUNDERBIRD_52_0b3_RELEASE"]}, {"author": "tbirdbld", "branch": "THUNDERBIRD520b3_2017021511_RELBRANCH", "desc": "Added THUNDERBIRD_52_0b3_RELEASE THUNDERBIRD_52_0b3_BUILD1 tag(s) for changeset a73b7f5955b2. DONTBUILD CLOSED TREE a=release", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "e990276c99353565f3e57f0c9495378c5b482f19", "parents": ["a73b7f5955b2369745213bde42d315ee4af31b12"], "tags": []}], "date": 1487176079, "git_changesets": [null, null], "user": "tbirdbld"}, "6935": {"changesets": [{"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1337807 - Suppress Windows modal dialogs during builds. r=jlund, a=NPOTB", "files": ["testing/mozharness/scripts/fx_desktop_build.py"], "git_node": null, "git_parents": [null], "node": "a59dadcedc0866e4179e7ba9b6423419b47bf6bd", "parents": ["5e8f82a565cfe536feb9bb3a6b16395eaf14bf40"], "tags": []}, {"author": "L. David Baron \u003cdbaron@dbaron.org\u003e", "branch": "default", "desc": "Bug 1159532 - Make reference transitions in test_transitions.html run for 16s instead of 8s. r=birtles, a=test-only\n\nThis is needed because check_descendant_tests tests a transition that\nchanges through 16s.\n\nMozReview-Commit-ID: EYX79SuNZ76", "files": ["layout/style/test/test_transitions.html"], "git_node": null, "git_parents": [null], "node": "84c93f6800f26a4245a421d37b3d53887618d0e1", "parents": ["a59dadcedc0866e4179e7ba9b6423419b47bf6bd"], "tags": []}, {"author": "L. David Baron \u003cdbaron@dbaron.org\u003e", "branch": "default", "desc": "Bug 1159532 - Number the output messages from the descendant tests. r=birtles, a=test-only\n\nMozReview-Commit-ID: 8GG3LGb2DB5", "files": ["layout/style/test/test_transitions.html"], "git_node": null, "git_parents": [null], "node": "c79b61700177693e486bd968dfd51f38c8781f0a", "parents": ["84c93f6800f26a4245a421d37b3d53887618d0e1"], "tags": []}], "date": 1487189329, "git_changesets": [null, null, null], "user": "ryanvm@gmail.com"}, "6936": {"changesets": [{"author": "Rail Aliiev \u003crail@mozilla.com\u003e", "branch": "default", "desc": "Bug 1339523 - Merge day script's bump_second_digit() should bump 52.0 to 52.1.0 not 52.1 r=jlorenzo a=release DONTBUILD\n\nMozReview-Commit-ID: 1WC3Zvds5xg", "files": ["testing/mozharness/scripts/merge_day/gecko_migration.py"], "git_node": null, "git_parents": [null], "node": "b6cd02fa0eee4766f3c2c4ca95e0e939dd960cf9", "parents": ["c79b61700177693e486bd968dfd51f38c8781f0a"], "tags": []}], "date": 1487206314, "git_changesets": [null], "user": "raliiev@mozilla.com"}, "6937": {"changesets": [{"author": "Kirk Steuber \u003cksteuber@mozilla.com\u003e", "branch": "default", "desc": "Bug 1333303 - Relax the list comparison in test_safe_browsing_initial_download.py. r=francois, a=test-only", "files": ["testing/firefox-ui/tests/functional/security/test_safe_browsing_initial_download.py"], "git_node": null, "git_parents": [null], "node": "38cee6e8a5bbc3459f377bc39007e10cb0f2fd7e", "parents": ["b6cd02fa0eee4766f3c2c4ca95e0e939dd960cf9"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1335450 - Fix our condition for rescheduling frame request callbacks. r=mrbkap, a=abillings", "files": ["dom/base/nsDocument.cpp"], "git_node": null, "git_parents": [null], "node": "6975b54ba6000e7a66b76525fb9c4efe973a3dc3", "parents": ["38cee6e8a5bbc3459f377bc39007e10cb0f2fd7e"], "tags": []}, {"author": "Benjamin Smedberg \u003cbenjamin@smedbergs.us\u003e", "branch": "default", "desc": "Bug 1333887 - Hold nsNPAPIPlugin alive for active nsNPAPIPluginInstance objects. This should happen through the plugin tag, but apparently that isn't always working. r=qdot, a=abillings", "files": ["dom/plugins/base/nsNPAPIPlugin.cpp", "dom/plugins/base/nsNPAPIPlugin.h", "dom/plugins/base/nsNPAPIPluginInstance.h"], "git_node": null, "git_parents": [null], "node": "f961305ce9f04040ffd55d90d62de5e62715ae25", "parents": ["6975b54ba6000e7a66b76525fb9c4efe973a3dc3"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1322971 - Expose cells found via iteration. r=sfink, a=abillings", "files": ["js/public/GCAPI.h", "js/src/jscompartment.cpp", "js/src/jsgc.cpp", "js/src/jsgcinlines.h"], "git_node": null, "git_parents": [null], "node": "6e2dcde91b89e2a42b62af7b22e892abcea94ae9", "parents": ["f961305ce9f04040ffd55d90d62de5e62715ae25"], "tags": []}, {"author": "Kirk Steuber \u003cksteuber@mozilla.com\u003e", "branch": "default", "desc": "Bug 1333483 - Hardcode itisatrap manual testing URLs for Flash blocking into the SafeBrowsing module. r=francois, a=jcristau\n\nMozReview-Commit-ID: ASCt3VfRJgg", "files": ["toolkit/components/url-classifier/SafeBrowsing.jsm"], "git_node": null, "git_parents": [null], "node": "30d276f390d35281daeef8d56749801668613e93", "parents": ["6e2dcde91b89e2a42b62af7b22e892abcea94ae9"], "tags": []}, {"author": "Marco Castelluccio \u003cmcastelluccio@mozilla.com\u003e", "branch": "default", "desc": "Bug 1339083 - Blocklist old K7TotalSecurity versions. r=aklotz, a=ritu", "files": ["mozglue/build/WindowsDllBlocklist.cpp"], "git_node": null, "git_parents": [null], "node": "24c5c108f6d63bf2872fda200fc1e643333bfbc7", "parents": ["30d276f390d35281daeef8d56749801668613e93"], "tags": []}], "date": 1487211167, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "6938": {"changesets": [{"author": "ffxbld", "branch": "default", "desc": "No bug, Automated blocklist update from host bld-linux64-spot-307 - a=blocklist-update", "files": ["browser/app/blocklist.xml"], "git_node": null, "git_parents": [null], "node": "b5dec8abc97b2b8259d71b74c00b0ad90cc37d4e", "parents": ["24c5c108f6d63bf2872fda200fc1e643333bfbc7"], "tags": []}], "date": 1487245052, "git_changesets": [null], "user": "ffxbld"}, "6939": {"changesets": [{"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1313176 - Fail index/cursor operations gracefully if they need preprocessing. This fixes the crash when devtools try to inspect idb databases with WebAssembly modules). It's a temporary fix until we implement preprocessing for indexes and cursors. A bunch of new tests is added to test indexes and cursors with wasm; r=asuth a=jcristau", "files": ["dom/indexedDB/ActorsParent.cpp", "dom/indexedDB/test/mochitest.ini", "dom/indexedDB/test/test_wasm_cursors.html", "dom/indexedDB/test/test_wasm_index_getAllObjects.html", "dom/indexedDB/test/test_wasm_indexes.html", "dom/indexedDB/test/unit/test_wasm_cursors.js", "dom/indexedDB/test/unit/test_wasm_getAll.js", "dom/indexedDB/test/unit/test_wasm_index_getAllObjects.js", "dom/indexedDB/test/unit/test_wasm_indexes.js", "dom/indexedDB/test/unit/test_wasm_put_get_values.js", "dom/indexedDB/test/unit/xpcshell-head-parent-process.js", "dom/indexedDB/test/unit/xpcshell-parent-process.ini"], "git_node": null, "git_parents": [null], "node": "d273229cde3cccea129e2450ec1234e9ac51efc4", "parents": ["b5dec8abc97b2b8259d71b74c00b0ad90cc37d4e"], "tags": []}], "date": 1487248572, "git_changesets": [null], "user": "jvarga@mozilla.com"}, "6940": {"changesets": [{"author": "Julian Seward \u003cjseward@acm.org\u003e", "branch": "default", "desc": "Bug 1245477 - Crashes in lul::DerefTUW.  r=nfroyd a=jcristau", "files": ["tools/profiler/lul/LulMain.cpp"], "git_node": null, "git_parents": [null], "node": "446c05b65b97cffe035811e6ceb104ee03deb207", "parents": ["d273229cde3cccea129e2450ec1234e9ac51efc4"], "tags": []}, {"author": "Nils Ohlmeier [:drno] \u003cdrno@ohlmeier.org\u003e", "branch": "default", "desc": "Bug 1315248: ensure socket is available for connect and send. r=schien a=jcristau\n\nMozReview-Commit-ID: 5ScyhIehwog", "files": ["dom/network/UDPSocketParent.cpp"], "git_node": null, "git_parents": [null], "node": "0d1e2aa8c0c2e4c244cc3f47b4cfe9e2c820d9b2", "parents": ["446c05b65b97cffe035811e6ceb104ee03deb207"], "tags": []}, {"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1316566 - Search settings button moves to its own line with 150% zoom. r=florian a=jcristau\n\nMozReview-Commit-ID: Lb0GjHLZSEX", "files": ["browser/components/search/content/search.xml"], "git_node": null, "git_parents": [null], "node": "6662ad2a09b6cda441b380570177ba60549e362d", "parents": ["0d1e2aa8c0c2e4c244cc3f47b4cfe9e2c820d9b2"], "tags": []}, {"author": "Karl Tomlinson \u003ckarlt+@karlt.net\u003e", "branch": "default", "desc": "Bug 1319957 - don't realize widgets for their style r=stransky+263117 a=jcristau\n\nThis was needed in GTK2 to get the style of the widget, but styles are almost\nindependent of widgets with GTK3, where realizing is not necessary to get the\nstyle context.\n\nMozReview-Commit-ID: GtL2FLDl9uA", "files": ["widget/gtk/WidgetStyleCache.cpp"], "git_node": null, "git_parents": [null], "node": "c05d4fe691177b899b08142f7c106b7b642221b5", "parents": ["6662ad2a09b6cda441b380570177ba60549e362d"], "tags": []}, {"author": "Alexander Surkov \u003csurkov.alexander@gmail.com\u003e", "branch": "default", "desc": "Bug 1321384 - attempt to fix a wrong index issue on accessible child removal, r=eeejay a=jcristau", "files": ["accessible/generic/Accessible.cpp"], "git_node": null, "git_parents": [null], "node": "5701c0b8b4b8814647a1a4ec022785caab146424", "parents": ["c05d4fe691177b899b08142f7c106b7b642221b5"], "tags": []}, {"author": "Honza Bambas \u003chonzab.moz@firemni.cz\u003e", "branch": "default", "desc": "Bug 1325655 - Let HttpChannelParent::ConnectChannel hard-fail when no nsHttpChannel is not found registered. r=jduell a=jcristau", "files": ["netwerk/protocol/http/HttpChannelParent.cpp"], "git_node": null, "git_parents": [null], "node": "d4c847e22d29ba95a19ee9307dbcee01ce79394a", "parents": ["5701c0b8b4b8814647a1a4ec022785caab146424"], "tags": []}, {"author": "Honza Bambas \u003chonzab.moz@firemni.cz\u003e", "branch": "default", "desc": "Bug 1325655 - Let HttpChannelParent::ConnectChannel delete itself if redirect target nsHttpChannel is not found registered. r=valentin a=jcristau", "files": ["netwerk/protocol/http/HttpChannelParent.cpp"], "git_node": null, "git_parents": [null], "node": "85636236764360abbdf59aae2009c0f0e7360ec1", "parents": ["d4c847e22d29ba95a19ee9307dbcee01ce79394a"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1328740 - Focus popup notification panels on anchor icon keypress. r=florian a=jcristau\n\nMozReview-Commit-ID: 1s0RzGJGVCX", "files": ["browser/base/content/test/popupNotifications/browser_popupNotification_keyboard.js", "toolkit/modules/PopupNotifications.jsm"], "git_node": null, "git_parents": [null], "node": "1eb3b2fe8c268badd4ec23a6f751a963247d0827", "parents": ["85636236764360abbdf59aae2009c0f0e7360ec1"], "tags": []}, {"author": "Matt Howell \u003cmhowell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1333789 - Try to avoid UAC prompts during automated installations using INI files. r=agashlin a=gchang a=jcristau\n\nMozReview-Commit-ID: CIOKXTT5AHh", "files": ["toolkit/mozapps/installer/windows/nsis/common.nsh"], "git_node": null, "git_parents": [null], "node": "fac7be108937e914e9db5b479f7c9d20eee12b0a", "parents": ["1eb3b2fe8c268badd4ec23a6f751a963247d0827"], "tags": []}, {"author": "Benjamin Smedberg \u003cbenjamin@smedbergs.us\u003e", "branch": "default", "desc": "Bug 1334080 - If a plugin is associated with a window that has no nsIWebNavigation, don't crash, r=qdot a=jcristau\n\nMozReview-Commit-ID: CZLne2N498d", "files": ["dom/plugins/base/nsPluginStreamListenerPeer.cpp"], "git_node": null, "git_parents": [null], "node": "b144dd6dc8122b407a4fa9079dd253f4d7717bd3", "parents": ["fac7be108937e914e9db5b479f7c9d20eee12b0a"], "tags": []}, {"author": "Jan Beich \u003cjbeich@FreeBSD.org\u003e", "branch": "default", "desc": "Bug 1334777 - Hide unused has_avx() if CXXFLAGS have -mavx. r=glandium a=jcristau\n\nMozReview-Commit-ID: 1IWEU8HrmtW", "files": ["mozglue/build/SSE.cpp"], "git_node": null, "git_parents": [null], "node": "a2a86679f818b5b54a1a0cbb2b56dbb0fa3428d8", "parents": ["b144dd6dc8122b407a4fa9079dd253f4d7717bd3"], "tags": []}, {"author": "Junior Hsu \u003cjuhsu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1338154 - not normalize ipv4 for resource and chrome uri. r=valentin a=jcristau", "files": ["netwerk/base/nsStandardURL.cpp", "netwerk/test/mochitests/test_uri_scheme.html", "netwerk/test/unit/test_standardurl.js"], "git_node": null, "git_parents": [null], "node": "7703bdf63084d45879fdad3d71f455ecd47b309e", "parents": ["a2a86679f818b5b54a1a0cbb2b56dbb0fa3428d8"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1338893 - Don't use the window on application-foreground if it doesn't yet exist. r=sebastian, a=jcristau\n\nDuring a cold startup, depending how this exactly plays out we might receive an application-foreground notification before the browser window is ready. Since the code to restore the selected tab if it has been left zombified while in background is only relevant if Gecko was already running and backgrounded, we can simply add a null check for the window before accessing it.\n\nMozReview-Commit-ID: Ahp5NAODKRF", "files": ["mobile/android/components/SessionStore.js"], "git_node": null, "git_parents": [null], "node": "189be0f13dfce7ddd53c8d4c15e0a9aa2bb7fadc", "parents": ["7703bdf63084d45879fdad3d71f455ecd47b309e"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1339351 - fix typo. r=kaku a=jcristau\n\nMozReview-Commit-ID: ApKvXMTqcDm", "files": ["dom/media/test/background_video.js"], "git_node": null, "git_parents": [null], "node": "23b6c61a00882647e9275d67a5d608fd83f04915", "parents": ["189b