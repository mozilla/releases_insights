ibles are shutdown before their document. r=davidb, r=smaug, a=jcristau", "files": ["accessible/generic/Accessible.cpp", "accessible/generic/Accessible.h", "accessible/generic/DocAccessible.cpp", "accessible/windows/msaa/AccessibleWrap.cpp"], "git_node": null, "git_parents": [null], "node": "9bd07f34ec539be831d867ca8f0e5068e75d610d", "parents": ["f6822b27c3e997cf30057776542bf14a7546897b"], "tags": []}, {"author": "Jan Odvarko \u003codvarko@gmail.com\u003e", "branch": "default", "desc": "Bug 1330827 - Fix CSS for Tab's cursor and background. r=jryans, a=jcristau\n\nMozReview-Commit-ID: GZd51GV3nFP", "files": ["browser/installer/allowed-dupes.mn", "devtools/client/jsonview/converter-child.js", "devtools/client/shared/components/tabs/tabbar.css", "devtools/client/shared/components/tabs/tabs.css", "devtools/client/themes/moz.build"], "git_node": null, "git_parents": [null], "node": "64067a9d83569d5c259c3ff6ff27a517a1a1157d", "parents": ["9bd07f34ec539be831d867ca8f0e5068e75d610d"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@gmail.com\u003e", "branch": "default", "desc": "Bug 1332619 - Add gtest for skipped frames. r=jesup, a=jcristau", "files": ["dom/media/gtest/TestVideoTrackEncoder.cpp"], "git_node": null, "git_parents": [null], "node": "a19f845ef02553eb3c21a7977be4ffdf295f977f", "parents": ["64067a9d83569d5c259c3ff6ff27a517a1a1157d"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@gmail.com\u003e", "branch": "default", "desc": "Bug 1332619 - Fix missed duration when skipping a frame in VP8TrackEncoder. r=jesup, a=jcristau", "files": ["dom/media/encoder/VP8TrackEncoder.cpp"], "git_node": null, "git_parents": [null], "node": "df261e5fa4e88700ad510a51fadf8c27833330e7", "parents": ["a19f845ef02553eb3c21a7977be4ffdf295f977f"], "tags": []}, {"author": "J. Ryan Stinnett \u003cjryans@gmail.com\u003e", "branch": "default", "desc": "Bug 1319950 - Wrap dPR state in object for consistency. r=gl, a=jcristau\n\nMozReview-Commit-ID: ERiDO14wGUz", "files": ["devtools/client/responsive.html/app.js", "devtools/client/responsive.html/components/dpr-selector.js", "devtools/client/responsive.html/components/global-toolbar.js", "devtools/client/responsive.html/reducers/viewports.js", "devtools/client/responsive.html/test/unit/test_change_viewport_pixel_ratio.js", "devtools/client/responsive.html/types.js"], "git_node": null, "git_parents": [null], "node": "a6cb4268d7b4b8fcd2f0f446024349beab5fe3a2", "parents": ["df261e5fa4e88700ad510a51fadf8c27833330e7"], "tags": []}, {"author": "J. Ryan Stinnett \u003cjryans@gmail.com\u003e", "branch": "default", "desc": "Bug 1319950 - Use consistent naming with viewport properties. r=gl, a=jcristau\n\nUse \"change\" instead of \"update\" terminology with viewport properties.\nRemove redundant \"viewport\" word from viewport changes.\n\nMozReview-Commit-ID: HSFLiZyTVYy", "files": ["devtools/client/responsive.html/actions/index.js", "devtools/client/responsive.html/actions/touch-simulation.js", "devtools/client/responsive.html/actions/viewports.js", "devtools/client/responsive.html/app.js", "devtools/client/responsive.html/components/device-selector.js", "devtools/client/responsive.html/components/dpr-selector.js", "devtools/client/responsive.html/components/global-toolbar.js", "devtools/client/responsive.html/components/resizable-viewport.js", "devtools/client/responsive.html/components/viewport-dimension.js", "devtools/client/responsive.html/components/viewport-toolbar.js", "devtools/client/responsive.html/components/viewport.js", "devtools/client/responsive.html/components/viewports.js", "devtools/client/responsive.html/manager.js", "devtools/client/responsive.html/reducers/touch-simulation.js", "devtools/client/responsive.html/reducers/viewports.js", "devtools/client/responsive.html/test/browser/browser_device_change.js", "devtools/client/responsive.html/test/browser/head.js", "devtools/client/responsive.html/test/unit/test_change_device.js", "devtools/client/responsive.html/test/unit/test_change_pixel_ratio.js", "devtools/client/responsive.html/test/unit/test_change_viewport_device.js", "devtools/client/responsive.html/test/unit/test_change_viewport_pixel_ratio.js", "devtools/client/responsive.html/test/unit/test_update_touch_simulation_enabled.js", "devtools/client/responsive.html/test/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "7ea353eafc60d907d713e2ae32b1bc3bf73b29b7", "parents": ["a6cb4268d7b4b8fcd2f0f446024349beab5fe3a2"], "tags": []}, {"author": "J. Ryan Stinnett \u003cjryans@gmail.com\u003e", "branch": "default", "desc": "Bug 1319950 - Only clear properties on resize if device is active. r=gl, a=jcristau\n\nIf a device is active, remove it on resize.  If not, leave device properties\nalone, so that things like touch simulation stay enabled when resizing without\na device.\n\nMozReview-Commit-ID: Hvo6AdTJRBJ", "files": ["devtools/client/responsive.html/actions/index.js", "devtools/client/responsive.html/actions/viewports.js", "devtools/client/responsive.html/app.js", "devtools/client/responsive.html/components/resizable-viewport.js", "devtools/client/responsive.html/components/viewport-dimension.js", "devtools/client/responsive.html/components/viewport.js", "devtools/client/responsive.html/components/viewports.js", "devtools/client/responsive.html/manager.js", "devtools/client/responsive.html/reducers/viewports.js", "devtools/client/responsive.html/test/browser/browser.ini", "devtools/client/responsive.html/test/browser/browser_device_change.js", "devtools/client/responsive.html/test/browser/browser_dpr_change.js", "devtools/client/responsive.html/test/browser/browser_touch_device.js", "devtools/client/responsive.html/test/browser/browser_touch_simulation.js", "devtools/client/responsive.html/test/browser/head.js"], "git_node": null, "git_parents": [null], "node": "bf69066e6917986ee1e091022f23b08613599017", "parents": ["7ea353eafc60d907d713e2ae32b1bc3bf73b29b7"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1331685 - Ensure that the ContentChild constructor send methods return null when shutting down. r=billm, a=jcristau\n\nOtherwise, the IPC attempt will crash the content process.", "files": ["dom/ipc/ContentChild.cpp"], "git_node": null, "git_parents": [null], "node": "aeac5786707489d14ceed90061ba9d107662b9eb", "parents": ["bf69066e6917986ee1e091022f23b08613599017"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1332704 - Have ~nsDocument actually clear the self-pointer from _all_ its sheets, and reenable Rule::IsKnownLive bits that depends on that pointer being managed correctly. r=heycam, a=jcristau", "files": ["dom/base/nsDocument.cpp"], "git_node": null, "git_parents": [null], "node": "e2e9026ac248832b840bda584417f21ceb1538e8", "parents": ["aeac5786707489d14ceed90061ba9d107662b9eb"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1332271 - Do not cancel timer when captive portal request times out. r=mcmanus, a=jcristau\n\nThe fact that nsICaptivePortalServiceCallback.complete got called with a true\nargument made it difficult to be sure when the you were actually in a captive\nportal, and when the network timed out.\nMoreover, one artefact of the initial plan for the captive portal service was\nthat we'd cancel the timer after the first request succeeded, making the backoff\nmechanism not run at all, and only checked for CP when instructed by nsIOService.\nThis patch changes captivedetect.js to send back success=false when the retry\ncount is exceeded - it's equivalent to an aborted request anyway - doesn't\ncancel the timeer, and changes how we set the current state of the captive portal.\n\nMozReview-Commit-ID: 4RV50KPbEdt", "files": ["netwerk/base/CaptivePortalService.cpp", "toolkit/components/captivedetect/captivedetect.js", "toolkit/components/captivedetect/test/unit/test_captive_portal_not_found_404.js"], "git_node": null, "git_parents": [null], "node": "f7f886a58559798f737da2757d9e00109cfc75b9", "parents": ["e2e9026ac248832b840bda584417f21ceb1538e8"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1333106 - Stop leaking in the prefetch service if the prefetch is blocked by security checks. r=mcmanus, a=jcristau", "files": ["netwerk/protocol/http/nsHttpChannel.cpp", "uriloader/prefetch/nsPrefetchService.cpp"], "git_node": null, "git_parents": [null], "node": "cc96795b07cb61fb0851b3d6d901a1a576d758b0", "parents": ["f7f886a58559798f737da2757d9e00109cfc75b9"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1256730 - Fail configure when API key files do not exist or are empty. r=chmanchester, r=mikedeboer, a=jcristau", "files": ["build/moz.configure/keyfiles.configure", "python/mozbuild/mozbuild/test/configure/test_checks_configure.py"], "git_node": null, "git_parents": [null], "node": "10be69536c446764fa0cea672768abc93540b31d", "parents": ["cc96795b07cb61fb0851b3d6d901a1a576d758b0"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1256730 - Add Mozilla and Google API files to artifact and cross-osx builds. r=gps, r=mikedeboer, a=jcristau", "files": ["testing/mozharness/configs/builds/releng_base_mac_64_cross_builds.py", "testing/mozharness/configs/builds/releng_sub_linux_configs/64_artifact.py"], "git_node": null, "git_parents": [null], "node": "e8e90b0da7c42819565ecbde023b531a8ad95065", "parents": ["10be69536c446764fa0cea672768abc93540b31d"], "tags": []}], "date": 1485363741, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "6827": {"changesets": [{"author": "Jim Mathies \u003cjmathies@mozilla.com\u003e", "branch": "default", "desc": "Bug 1294650 - Install shim 'qipcap' dlls into the Firefox folder to circumvent dll injection by the 3rd party Websense product. r=aklotz a=ritu\nCLOSED TREE\nMozReview-Commit-ID: 11qJbfim7Lm", "files": ["browser/installer/package-manifest.in", "toolkit/library/dummydll/dummydll.cpp", "toolkit/library/dummydll/moz.build", "toolkit/library/moz.build"], "git_node": null, "git_parents": [null], "node": "2cfff4488cc160aafb9d8f1b3baa8543d7a170b2", "parents": ["e8e90b0da7c42819565ecbde023b531a8ad95065"], "tags": []}], "date": 1485372269, "git_changesets": [null], "user": "kwierso@gmail.com"}, "6828": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "Automatic version bump. CLOSED TREE NO BUG a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "bbbda1fe1cc3c600cff84e5db7b6949ba93d8951", "parents": ["2cfff4488cc160aafb9d8f1b3baa8543d7a170b2"], "tags": []}, {"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging 78ae21055d9f303be257abe155ba9dee466c0651 with FIREFOX_52_0b1_BUILD2, FIREFOX_52_0b1_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "3c59e804284b06302c10645d5057624f41540e9d", "parents": ["bbbda1fe1cc3c600cff84e5db7b6949ba93d8951"], "tags": []}], "date": 1485382979, "git_changesets": [null, null], "user": "ffxbld"}, "6829": {"changesets": [{"author": "tbirdbld", "branch": "THUNDERBIRD520b1_2017012613_RELBRANCH", "desc": "Automated checkin: version bump for thunderbird 52.0b1 release. DONTBUILD CLOSED TREE a=release", "files": [], "git_node": null, "git_parents": [null], "node": "0ba4201762d7c2de3a8c84dd101e4c3ef395e606", "parents": ["78ae21055d9f303be257abe155ba9dee466c0651"], "tags": ["THUNDERBIRD_52_0b1_BUILD2", "THUNDERBIRD_52_0b1_RELEASE"]}, {"author": "tbirdbld", "branch": "THUNDERBIRD520b1_2017012613_RELBRANCH", "desc": "Added THUNDERBIRD_52_0b1_RELEASE THUNDERBIRD_52_0b1_BUILD2 tag(s) for changeset 0ba4201762d7. DONTBUILD CLOSED TREE a=release", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "3af96517e78c71366c8760a3ba846e230ddfda11", "parents": ["0ba4201762d7c2de3a8c84dd101e4c3ef395e606"], "tags": []}], "date": 1485456827, "git_changesets": [null, null], "user": "tbirdbld"}, "6830": {"changesets": [{"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1322277 - Fix usage of capabilities in start_session. r=ato, a=test-only\n\nCapabilities as passed into start_session() can be desiredCapabilities\nand requiredCapabilities. As such the parameter name should be clear.\n\nMozReview-Commit-ID: GPNv4g9HMO2", "files": ["testing/marionette/client/marionette_driver/marionette.py"], "git_node": null, "git_parents": [null], "node": "6f4c97200bb7f20bf2706bef9a5b6281ce01e2e5", "parents": ["3c59e804284b06302c10645d5057624f41540e9d"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1322277 - Marionette client should be able to set default capabilities. r=ato, a=test-only\n\nSome default values for capabilities as defined by the Webdriver spec do not\nmatch the expectations for Marionette client. Therefore we should add the possibility\nto override those defaults in start_session(), but also still allow consumers to\nset their own values.\n\nMozReview-Commit-ID: CTUycCRV5kg", "files": ["testing/marionette/client/marionette_driver/marionette.py", "testing/marionette/harness/marionette_harness/tests/unit/test_capabilities.py"], "git_node": null, "git_parents": [null], "node": "96e2a1ec523dd8b4f364a4c01ff1e087d3bafd71", "parents": ["6f4c97200bb7f20bf2706bef9a5b6281ce01e2e5"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1322277 - Default socket timeout has to be larger than the default page load timeout. r=ato, a=test-only\n\nTo not run into socket failures and forced application shutdown scenarios, the socket timeout\nshould always be larger then the page load timeout.\n\nMozReview-Commit-ID: EOBW4mozDT1", "files": ["testing/marionette/client/marionette_driver/marionette.py", "testing/marionette/harness/marionette_harness/runner/base.py"], "git_node": null, "git_parents": [null], "node": "7ce8d1a5678c322d376ffd632778ef791c0e8ca0", "parents": ["96e2a1ec523dd8b4f364a4c01ff1e087d3bafd71"], "tags": []}, {"author": "Bob Clary \u003cbclary@bclary.com\u003e", "branch": "default", "desc": "Bug 1279259 - Make TURN server port configurable. r=jmaher, a=test-only", "files": ["testing/mochitest/mochitest_options.py", "testing/mochitest/runtests.py", "testing/tools/websocketprocessbridge/websocketprocessbridge.py"], "git_node": null, "git_parents": [null], "node": "14e0a18e9ee0b799076902e010a1603c33ea1263", "parents": ["7ce8d1a5678c322d376ffd632778ef791c0e8ca0"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "Bug 1330822 - Remove CPOWs from browser_usercontext.js. r=Gijs, a=test-only\n\nMozReview-Commit-ID: 6gFJKF76ZDE", "files": ["browser/components/contextualidentity/test/browser/browser_usercontext.js"], "git_node": null, "git_parents": [null], "node": "eebc55e20cc930ed2641b0970cce135ed76d0288", "parents": ["14e0a18e9ee0b799076902e010a1603c33ea1263"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "Bug 1330822 - Remove CPOWs from customizableui/head.js. r=Gijs, a=test-only\n\nMozReview-Commit-ID: eycB4S9ANq", "files": ["browser/components/customizableui/test/head.js"], "git_node": null, "git_parents": [null], "node": "9d8bd6eaf52502e2ae4b8b9b877b4e7be1c4006d", "parents": ["eebc55e20cc930ed2641b0970cce135ed76d0288"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "Bug 1330822 - Remove CPOWs from browser_context_menu_iframe.js. r=Gijs, a=test-only\n\nThis was tricky because synthesizeMouse would compute the incorrect\ncoordinates if the requested event target was in a sub-frame. With this patch,\nwe deal correctly with sub-frames.\n\nMozReview-Commit-ID: KpUKxFXKMrl", "files": ["testing/mochitest/BrowserTestUtils/BrowserTestUtils.jsm", "testing/mochitest/tests/SimpleTest/AsyncUtilsContent.js", "toolkit/components/passwordmgr/test/browser/browser_context_menu_iframe.js"], "git_node": null, "git_parents": [null], "node": "2c9226752040ef189f2e07392ddbdd863d49ea2e", "parents": ["9d8bd6eaf52502e2ae4b8b9b877b4e7be1c4006d"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "Bug 1330822 - Remove CPOWs from browser_bug839103.js. r=Gijs, a=test-only\n\nIn converting this test, I found that `initialStylesheetAdded` was testing the\nwrong thing. It was firing instead for the dynamic case. Fixing it is hard\nwithout converting the test to be a mochitest-plain test. I simply removed it.\nIf we want to add it back, we can at another date.\n\nMozReview-Commit-ID: 7UohwERTPkb", "files": ["browser/base/content/test/general/browser_bug839103.js"], "git_node": null, "git_parents": [null], "node": "bace9af707bfd019de10d89ed6840ee6a1bccd3d", "parents": ["2c9226752040ef189f2e07392ddbdd863d49ea2e"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "Bug 1330822 - Remove CPOWs from browser_no_mcb_on_http_site.js. r=Felipe, a=test-only", "files": ["browser/base/content/test/general/browser_no_mcb_on_http_site.js"], "git_node": null, "git_parents": [null], "node": "56ce2dca89a669fe13ac52a5e5ec1f0517fd4a83", "parents": ["bace9af707bfd019de10d89ed6840ee6a1bccd3d"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "Bug 1330822 - Remove CPOWs from browser_favicon_change.js. r=Felipe, a=test-only", "files": ["browser/base/content/test/general/browser_favicon_change.js"], "git_node": null, "git_parents": [null], "node": "d006ddf8eaa3bd25110622bc4f7ca780adbf4051", "parents": ["56ce2dca89a669fe13ac52a5e5ec1f0517fd4a83"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "Bug 1330822 - Remove CPOWs from browser_identity_UI.js. r=Felipe, a=test-only", "files": ["browser/base/content/test/general/browser_identity_UI.js"], "git_node": null, "git_parents": [null], "node": "47e7220e1a9e071acaff67bc6e4944420923eeae", "parents": ["d006ddf8eaa3bd25110622bc4f7ca780adbf4051"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "Bug 1330822 - Remove CPOWs from browser_mixedcontent_securityflags.js. r=Felipe, a=test-only", "files": ["browser/base/content/test/general/browser_mixedcontent_securityflags.js"], "git_node": null, "git_parents": [null], "node": "a4dd0e9734d2aee088d88ed721b9b3918eb6c852", "parents": ["47e7220e1a9e071acaff67bc6e4944420923eeae"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "Bug 1330822 - Remove CPOWs from browser_popupUI.js. r=Felipe, a=test-only\n\nFinding the popup window after the fact was going to be messy (maintaining\nwindow identity across the message manager is a tricky task). Instead, it's\nmuch easier to wait for the new window to open and grab a reference to it\nthen.", "files": ["browser/base/content/test/general/browser_popupUI.js"], "git_node": null, "git_parents": [null], "node": "711fc611dbd85f3f480e1121186852dd10361431", "parents": ["a4dd0e9734d2aee088d88ed721b9b3918eb6c852"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "Bug 1330822 - Remove CPOWs from browser_loadURI.js. r=Felipe, a=test-only", "files": ["docshell/test/browser/browser_loadURI.js"], "git_node": null, "git_parents": [null], "node": "848bf93b1a969898651df12dbbe9fc95bc8691c9", "parents": ["711fc611dbd85f3f480e1121186852dd10361431"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "Bug 1330822 - Remove CPOWs from browser_bug633691.js. r=Gijs, a=test-only\n\nMozReview-Commit-ID: 829vnw81Xkd", "files": ["browser/base/content/test/general/browser_bug633691.js"], "git_node": null, "git_parents": [null], "node": "48718f7f527f54a9af9c772151cc11b882fa0db7", "parents": ["848bf93b1a969898651df12dbbe9fc95bc8691c9"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1332597 - IsMarked should return true for things owned by a different runtime. r=sfink, a=jcristau", "files": ["js/src/gc/Marking.cpp", "js/src/gc/Marking.h", "js/src/jit/Ion.cpp", "js/src/jit/IonCode.h", "js/src/jit/JitcodeMap.cpp", "js/src/jit/JitcodeMap.h", "js/src/jsapi-tests/testIntern.cpp", "js/src/jsgc.cpp", "js/src/jswatchpoint.cpp", "js/src/jsweakmap.h", "js/src/vm/Debugger.cpp", "js/src/vm/Debugger.h", "js/src/vm/RegExpObject.cpp", "js/src/vm/TypeInference.cpp", "js/src/vm/TypeInference.h"], "git_node": null, "git_parents": [null], "node": "b90333b8250fbf57085ca5b04a16c7704c9998ea", "parents": ["48718f7f527f54a9af9c772151cc11b882fa0db7"], "tags": []}, {"author": "Randell Jesup \u003crjesup@jesup.org\u003e", "branch": "default", "desc": "Bug 1333752 - Fix memset sizes in rtt_filter.cc. r=dminor, a=jcristau\n\nMozReview-Commit-ID: 3pnTseY4k2M", "files": ["media/webrtc/trunk/webrtc/modules/video_coding/main/source/rtt_filter.cc"], "git_node": null, "git_parents": [null], "node": "c4d7b21349eacbfc8d1c6fc31631da4d7ff539f0", "parents": ["b90333b8250fbf57085ca5b04a16c7704c9998ea"], "tags": []}, {"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1324379 - Fix cairo_cff_font_write_cid_fontdict array output. r=jrmuizel, a=jcristau\n\nMozReview-Commit-ID: DVMOpNLmY6D", "files": ["gfx/cairo/cairo/src/cairo-cff-subset.c"], "git_node": null, "git_parents": [null], "node": "075fae264dd8b80f9ee712886559876c8f75f6c4", "parents": ["c4d7b21349eacbfc8d1c6fc31631da4d7ff539f0"], "tags": []}, {"author": "Cervantes Yu \u003ccyu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1317259 - Prevent double init in mozilla::TimeStamp::Startup() on Windows. r=froydnj, a=jcristau\n\nMozReview-Commit-ID: JKfEFqo5qHj", "files": ["mozglue/misc/TimeStamp_windows.cpp"], "git_node": null, "git_parents": [null], "node": "47beb6fad37a97a96db8fbd03f064905b7153a99", "parents": ["075fae264dd8b80f9ee712886559876c8f75f6c4"], "tags": []}, {"author": "Neil Deakin \u003cneil@mozilla.com\u003e", "branch": "default", "desc": "Bug 1314251 - Close menulist on alt+up/down. r=ksteuber, a=jcristau", "files": ["layout/xul/nsXULPopupManager.cpp", "toolkit/content/tests/chrome/test_menulist_keynav.xul"], "git_node": null, "git_parents": [null], "node": "21d352f5869b3702c3066f2a52915df0820d6066", "parents": ["47beb6fad37a97a96db8fbd03f064905b7153a99"], "tags": []}, {"author": "Nicolas Chevobbe \u003cchevobbe.nicolas@gmail.com\u003e", "branch": "default", "desc": "Bug 1320399 - Fix error in Grip Rep. r=nchevobbe, a=jcristau\n\nCheck that the `preview` property is not null before using it.\nThe bug was harmless because we catch it and return an\nempty array as the properties of the grip, which is the same\nwhen we don't have anything in the preview prop.\n\nMozReview-Commit-ID: COU8XLATw7x", "files": ["devtools/client/shared/components/reps/grip.js"], "git_node": null, "git_parents": [null], "node": "a284c0fee28956b77aff624082f3c3d1ddfb4692", "parents": ["21d352f5869b3702c3066f2a52915df0820d6066"], "tags": []}, {"author": "cku \u003ccku@mozilla.com\u003e", "branch": "default", "desc": "Bug 1320032 - Early return if the size of mask surface will be empty. r=mstange, a=jcristau\n\nMozReview-Commit-ID: Bd0ddkyNCMr", "files": ["layout/base/FrameLayerBuilder.cpp"], "git_node": null, "git_parents": [null], "node": "471c4b0e0abd72aa4fc350b2b563fde084830a7d", "parents": ["a284c0fee28956b77aff624082f3c3d1ddfb4692"], "tags": []}, {"author": "Jan Beich \u003cjbeich@FreeBSD.org\u003e", "branch": "default", "desc": "Bug 1329895 - Apply Linux fieldtext opacity for all GTK platforms. r=dao, a=jcristau\n\nMozReview-Commit-ID: B16q1UgRXHU", "files": ["browser/themes/shared/icon-colors.inc.svg"], "git_node": null, "git_parents": [null], "node": "4d0788cd5f7ffabbc6ffd5788d292d29d792d68d", "parents": ["471c4b0e0abd72aa4fc350b2b563fde084830a7d"], "tags": []}, {"author": "Ethan Glasser-Camp \u003ceglassercamp@mozilla.com\u003e", "branch": "default", "desc": "Bug 1320324 - Deleted values are not handled correctly on sync. r=markh, a=jcristau\n\nNo tests existed for this functionality either, so add some.\n\nMozReview-Commit-ID: FkHV0GBTHov", "files": ["services/sync/modules/engines/extension-storage.js", "toolkit/components/extensions/test/xpcshell/test_ext_storage_sync.js"], "git_node": null, "git_parents": [null], "node": "a1baa5a308da82d4e90fb699061a40e2504f937d", "parents": ["4d0788cd5f7ffabbc6ffd5788d292d29d792d68d"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1331798 - Bookmark panel for new bookmark shouldn't be closed automatically during composition and after text input without keyboard events nor composition events. r=jaws, a=jcristau\n\nBookmark panel for a new bookmark shouldn't be closed automatically during composition even if mouse cursor is moved outside the panel because user may click in IME's UI.\n\nAdditionally, editor might be modified without keyboard events nor composition events.  In such case, the bookmark panel shouldn't be closed automatically too.\n\nMozReview-Commit-ID: 1FAUmkXjid", "files": ["browser/base/content/browser-places.js", "browser/base/content/test/general/browser_bookmark_popup.js"], "git_node": null, "git_parents": [null], "node": "7fbb9a8737712f21dab958e0ca98cbdcc0babefe", "parents": ["a1baa5a308da82d4e90fb699061a40e2504f937d"], "tags": []}, {"author": "David Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "Bug 1328718 - Implement system 