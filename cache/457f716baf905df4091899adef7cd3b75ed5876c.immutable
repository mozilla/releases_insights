6", "parents": ["54bab4dfb7936e8b943cb355e223464871f20508"], "tags": []}, {"author": "Jorg K \u003cjorgk@jorgk.com\u003e", "branch": "default", "desc": "Bug 770022 - Provide fallback when UnEscapeNonAsciiURI() fails in nsMIMEInfoWin::LoadUriInternal(). r=bz, a=lizzard", "files": ["uriloader/exthandler/win/nsMIMEInfoWin.cpp"], "git_node": null, "git_parents": [null], "node": "b9bc6b310328ff989cd4f0f6bcf9cc85ca12dbe8", "parents": ["e33a33688cc9eeb0e7ec78459a45b58e2fd927e6"], "tags": []}, {"author": "Tooru Fujisawa \u003carai_a@mac.com\u003e", "branch": "default", "desc": "Bug 1331009 - Remove wrong restriction for a newline after await. r=till, a=jcristau", "files": ["js/src/frontend/Parser.cpp", "js/src/js.msg", "js/src/tests/ecma_7/AsyncFunctions/await-newline.js", "js/src/tests/ecma_7/AsyncFunctions/syntax.js"], "git_node": null, "git_parents": [null], "node": "65be24609b44bc07afabf5581cffea84722ed796", "parents": ["b9bc6b310328ff989cd4f0f6bcf9cc85ca12dbe8"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1338083 - Restore full year in Library date columns. r=jfkthame, a=jcristau\n\nMozReview-Commit-ID: GIp7xzdAC9C", "files": ["browser/components/places/content/treeView.js", "browser/components/places/tests/chrome/test_treeview_date.xul"], "git_node": null, "git_parents": [null], "node": "a02c7784fc530b6409e72026f4ea0ee76aeb614f", "parents": ["65be24609b44bc07afabf5581cffea84722ed796"], "tags": []}, {"author": "Mike Taylor \u003cmiket@mozilla.com\u003e", "branch": "default", "desc": "Bug 1338260 - Add Fennec-only UA override for directv.com. r=mconnor, a=jcristau\n\nThey use an older version of Sencha Touch (v2.1.0) which is known\nto not be compatibile with Firefox. However, pretending to be Chrome\nfixes the issue of not being able to scroll and various paint bugs.\n\nMozReview-Commit-ID: K35ll42Xxlt", "files": ["mobile/android/app/ua-update.json.in"], "git_node": null, "git_parents": [null], "node": "fe1a313151e8ffec4016ec1da4c8100a9fa2d850", "parents": ["a02c7784fc530b6409e72026f4ea0ee76aeb614f"], "tags": []}], "date": 1486759326, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "6917": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset 4603dc332d7f (bug 1333483) for causing test_safe_browsing_initial_download.py permafails.", "files": ["toolkit/components/url-classifier/SafeBrowsing.jsm"], "git_node": null, "git_parents": [null], "node": "f29a51aaae32824ec1202953991cdb098f25b056", "parents": ["fe1a313151e8ffec4016ec1da4c8100a9fa2d850"], "tags": []}], "date": 1486764353, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "6918": {"changesets": [{"author": "Matthew Noorenberghe \u003cmozilla@noorenberghe.ca\u003e", "branch": "default", "desc": "Bug 1334026 - Show the the insecure field warning on insecure password fields even if they're not marked. r=mconley, a=jcristau\n\nMozReview-Commit-ID: LxvPzD3SOnc", "files": ["toolkit/components/satchel/nsFormFillController.cpp", "toolkit/components/satchel/test/test_password_autocomplete.html"], "git_node": null, "git_parents": [null], "node": "858a114711db3ae5c5e5bdb19822935099da6722", "parents": ["f29a51aaae32824ec1202953991cdb098f25b056"], "tags": []}, {"author": "Matthew Noorenberghe \u003cmozilla@noorenberghe.ca\u003e", "branch": "default", "desc": "Bug 1330111 - Always attempt to autocomplete on type=password fields upon focus. r=daleharvey a=jcristau\n\nLet password manager handle opening the popup on username fields itself.\n\nMozReview-Commit-ID: FbI6CgsadEd", "files": ["mobile/android/app/mobile.js", "toolkit/components/satchel/nsFormFillController.cpp"], "git_node": null, "git_parents": [null], "node": "235bab6aab6541d77119d7ca657ab5b8c2d47df1", "parents": ["858a114711db3ae5c5e5bdb19822935099da6722"], "tags": []}, {"author": "Matthew Noorenberghe \