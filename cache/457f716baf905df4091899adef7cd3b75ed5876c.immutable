: [null], "node": "509d5333e21aea15133a94c03ea6f50cd8b65895", "parents": ["4840d6a750ccc47d82de19957e47ba5ae3752263"], "tags": []}, {"author": "Tracy Walker \u003ctwalker@mozilla.com\u003e", "branch": "default", "desc": "Bug 1326292 - Add null check of drawTarget in WinCompositorWidget.cpp, to avoid crash. r=jimm a=jcristau", "files": ["widget/windows/WinCompositorWidget.cpp"], "git_node": null, "git_parents": [null], "node": "ea512fbead9b8fd48757e5896bfdfaaf648e9bcd", "parents": ["509d5333e21aea15133a94c03ea6f50cd8b65895"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1329438 - Wait until Gecko is ready to open URI; r=snorp a=jcristau\n\nRight now we wait until PROFILE_READY state, but we may not have a\nbrowser DOM window until RUNNING state, so wait until then.", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoView.java"], "git_node": null, "git_parents": [null], "node": "eecc293011dde0ab8ce174aba2ef39a25c47aff1", "parents": ["ea512fbead9b8fd48757e5896bfdfaaf648e9bcd"], "tags": []}, {"author": "Ralph Giles \u003cgiles@mozilla.com\u003e", "branch": "default", "desc": "Bug 1333931 - Handle nullptr TextTrack objects in sorting. r=kinetik, a=jcristau\n\nCheck for nullptr arguments passed to CompareTextTracks. Based\non Ben Kelly's analysis this can happen if the cycle collector\nhas cleared a TextTrack pointer while comparision is still\nhappening, perhaps in a queued event task.\n\nThis change makes nullptr sort to the end, and adds a\nMOZ_DIAGNOSTIC_ASSERT for trying to get the position\nof a nullptr track should someone add another call at\na later date.", "files": ["dom/html/TextTrackManager.cpp"], "git_node": null, "git_parents": [null], "node": "8e853e2c67d149fc4dcc289298b7f133bafb04c2", "parents": ["eecc293011dde0ab8ce174aba2ef39a25c47aff1"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1336622 - Don't allow subnormal surfaceScale values to be used in the lighting filter calculations. r=jrmuizel, a=gchang/jcristau\n\nMozReview-Commit-ID: LkmLX7zOfGe", "files": ["gfx/2d/FilterNodeSoftware.cpp"], "git_node": null, "git_parents": [null], "node": "7b8aa893944b94d35e47314e52e0abff576c5ce2", "parents": ["8e853e2c67d149fc4dcc289298b7f133bafb04c2"], "tags": ["FIREFOX_52_0b6_BUILD1", "FIREFOX_52_0b6_RELEASE"]}], "date": 1486998561, "git_changesets": [null, null, null, null, null, null], "user": "cbook@mozilla.com"}, "6920": {"changesets": [{"author": "Mike de Boer \u003cmdeboer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1261233 - Prevent test_bug331215.xul from intermittently timing out. r=Gijs, a=test-only\n\nMozReview-Commit-ID: 4dvWUdNTBOx", "files": ["toolkit/content/tests/chrome/bug331215_window.xul"], "git_node": null, "git_parents": [null], "node": "a537b707d7d2413de5c35f5effa02826eb3c61e9", "parents": ["7b8aa893944b94d35e47314e52e0abff576c5ce2"], "tags": []}, {"author": "Mats Palmgren \u003cmats@mozilla.com\u003e", "branch": "default", "desc": "Bug 1179543 - Add a fuzz factor to reftest 368020-1.html to account for anti-aliasing. a=test-only", "files": ["layout/reftests/bugs/reftest.list"], "git_node": null, "git_parents": [null], "node": "9eea4f9f5bb309af3971807dc00067463c83fe42", "parents": ["a537b707d7d2413de5c35f5effa02826eb3c61e9"], "tags": []}, {"author": "Ricky Chien \u003crchien@mozilla.com\u003e", "branch": "default", "desc": "Bug 1335322 - Add aria-pressed to the filter buttons. r=Honza, a=jcristau\n\nMozReview-Commit-ID: KMftH2dpVs7", "files": ["devtools/client/netmonitor/components/filter-buttons.js"], "git_node": null, "git_parents": [null], "node": "e51baf47ffeb359c685ac0d4c2fab2ee31153427", "parents": ["9eea4f9f5bb309af3971807dc00067463c83fe42"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1328861 - Be a little less trusting about our error codes in ErrorResult. r=smaug, a=abillings", "files": ["dom/bindings/ErrorResult.h"], "git_node": null, "git_parents": [null], "node": "b000e60212be6963d7edba66a52914d575efcbbc", "parents": ["e51baf47ffeb359c685ac0d4c2fab2ee31153427"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1338812 - Call TelemetryStopwatch only once per item (history / bookmarks / logins) rather than for each resource. r=Gijs, a=jcristau\n\nMozReview-Commit-ID: 7c5DgKDIFTv", "files": ["browser/components/migration/MigrationUtils.jsm"], "git_node": null, "git_parents": [null], "node": "4ad8573642c78523c549e9ee3b90c24f9a464834", "parents": ["b000e60212be6963d7edba66a52914d575efcbbc"], "tags": []}], "date": 1487010254, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "6921": {"changesets": [{"author": "ffxbld", "branch": "MOBILE520b6_2017021314_RELBRANCH", "desc": "Automated checkin: version bump for fennec 52.0b6 release. DONTBUILD CLOSED TREE a=release", "files": [], "git_node": null, "git_parents": [null], "node": "394d22ba8d064d64c5a27c9bd25c9aa7c26db0d6", "parents": ["7b8aa893944b94d35e47314e52e0abff576c5ce2"], "tags": ["FENNEC_52_0b6_BUILD1", "FENNEC_52_0b6_RELEASE"]}, {"author": "ffxbld", "branch": "MOBILE520b6_2017021314_RELBRANCH", "desc": "Added FENNEC_52_0b6_RELEASE FENNEC_52_0b6_BUILD1 tag(s) for changeset 394d22ba8d06. DONTBUILD CLOSED TREE a=release", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "4d76ae9734d58fdd908a9b084a1a682760645dfb", "parents": ["394d22ba8d064d64c5a27c9bd25c9aa7c26db0d6"], "tags": []}], "date": 1487014265, "git_changesets": [null, null], "user": "ffxbld"}, "6922": {"changesets": [{"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1336822 Optimize ResetTimesForTHrottleReduction() for common case. r=ehsan a=lizzard", "files": ["dom/base/nsGlobalWindow.cpp"], "git_node": null, "git_parents": [null], "node": "bd9cd325c4bca4a9f0256d9300c7ac00dd9bf7a8", "parents": ["4ad8573642c78523c549e9ee3b90c24f9a464834"], "tags": []}], "date": 1487024198, "git_changesets": [null], "user": "bkelly@mozilla.com"}, "6923": {"changesets": [{"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1336598 P1 Tune setTimeout anti-flood constants to minimize jank. r=smaug a=lizzard", "files": ["dom/base/nsGlobalWindow.cpp"], "git_node": null, "git_parents": [null], "node": "81a1e81407be2206b5e00dac1660fc702bed9996", "parents": ["bd9cd325c4bca4a9f0256d9300c7ac00dd9bf7a8"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1336598 P2 Avoid underflow in timeout CancelOrUpdateBackpressure(). r=smaug a=lizzard", "files": ["dom/base/nsGlobalWindow.cpp"], "git_node": null, "git_parents": [null], "node": "8939ba38982b706c6abc62eb2c56aae44c20f0d1", "parents": ["81a1e81407be2206b5e00dac1660fc702bed9996"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1336598 P3 Add preferences to control timeout back pressure algorithm. r=smaug a=lizzard", "files": ["dom/base/nsGlobalWindow.cpp"], "git_node": null, "git_parents": [null], "node": "3ea27580c85dad05759fbd7ab6aac3ea9a355c2c", "parents": ["8939ba38982b706c6abc62eb2c56aae44c20f0d1"], "tags": []}], "date": 1487024847, "git_changesets": [null, null, null], "user": "bkelly@mozilla.com"}, "6924": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "Automatic version bump. CLOSED TREE NO BUG a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "7b9610bb284adcea43a434236854663898e619fa", "parents": ["3ea27580c85dad05759fbd7ab6aac3ea9a355c2c"], "tags": []}, {"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging 7b8aa893944b94d35e47314e52e0abff576c5ce2 with FIREFOX_52_0b6_BUILD1, FIREFOX_52_0b6_RELEASE a=release CLOSED TREE", "files": [".hgta