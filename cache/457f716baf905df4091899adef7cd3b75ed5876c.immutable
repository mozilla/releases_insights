7561 - Fix executable page allocator to avoid fragmenting the JIT code space. r=luke", "files": ["js/src/gc/GCRuntime.h", "js/src/irregexp/RegExpEngine.cpp", "js/src/jit/ExecutableAllocator.cpp", "js/src/jit/ExecutableAllocator.h", "js/src/jit/ExecutableAllocatorPosix.cpp", "js/src/jit/ExecutableAllocatorWin.cpp", "js/src/jit/ProcessExecutableMemory.cpp", "js/src/jit/ProcessExecutableMemory.h", "js/src/jsgc.cpp", "js/src/moz.build", "js/src/vm/Initialization.cpp", "js/src/vm/MutexIDs.h", "js/src/wasm/WasmCode.cpp"], "git_node": null, "git_parents": [null], "node": "6b35bbf96b677d500ce87fa9548dcd2eecef467a", "parents": ["efb9b503adaee72e0410b53e4662221b06d0d167"], "tags": []}, {"author": "Mantaroh Yoshinaga \u003cmantaroh@gmail.com\u003e", "branch": "default", "desc": "Bug 1322970 - Use primary frame for checking throttle instead of using style context. r=dholbert, r=hiro, a=jcristau\n\nThis changeset will skip finding the first SMIL animation function to affect the sandwich from multiple functions if element hasn't primary frame when composing attributes.\nThis mean that target element's animation don't need to animate in the following cases.\n- ancestor elements has display:none attribute.\n- target element have display:none attribute.\n- ancestor element's tag produces a non-rendering subtree, by definition (like \u003cdesc\u003e).\n\nMozReview-Commit-ID: 253qTpBLc8L", "files": ["dom/smil/nsSMILCompositor.cpp", "dom/svg/test/test_SVGxxxList.xhtml", "layout/reftests/svg/smil/anim-change-display-block-for-dynamically-appended-elem.html", "layout/reftests/svg/smil/anim-change-display-none-for-ancestor-elem.html", "layout/reftests/svg/smil/anim-change-display-none-for-dynamically-appended-elem.html", "layout/reftests/svg/smil/anim-change-display-none-for-target-elem.html", "layout/reftests/svg/smil/anim-standard-ref.html", "layout/reftests/svg/smil/lime.html", "layout/reftests/svg/smil/reftest.list"], "git_node": null, "git_parents": [null], "node": "614f4899b294f23286d340d2e6f67f58ed4c7364", "parents": ["6b35bbf96b677d500ce87fa9548dcd2eecef467a"], "tags": []}, {"author": "Milan Sreckovic \u003cmilan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1325511 - Mark as used sooner. r=mtseng, a=jcristau", "files": ["gfx/angle/src/libANGLE/renderer/d3d/d3d11/Buffer11.cpp"], "git_node": null, "git_parents": [null], "node": "aba7f4593fc97b90d7f1ceac0b7caabe2fd6dd6f", "parents": ["614f4899b294f23286d340d2e6f67f58ed4c7364"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1335349 - Add survey link option to 'undo' for automigration. r=Dolske, a=jcristau\n\nMozReview-Commit-ID: BGsxAdsTu7X", "files": ["browser/components/migration/AutoMigrate.jsm", "browser/components/migration/tests/browser/browser_undo_notification.js"], "git_node": null, "git_parents": [null], "node": "9c1abdef23a872d6c04a93f1de8be8fa73034617", "parents": ["aba7f4593fc97b90d7f1ceac0b7caabe2fd6dd6f"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 995069 - Use getrandom system call on Linux if available instead of opening /dev/urandom. r=cpeterson, a=jcristau", "files": ["js/src/jsmath.cpp"], "git_node": null, "git_parents": [null], "node": "8345541aea0bc794a1d238cde7aa0c7390f91087", "parents": ["9c1abdef23a872d6c04a93f1de8be8fa73034617"], "tags": []}, {"author": "Kaku Kuo \u003ckaku@mozilla.com\u003e", "branch": "default", "desc": "Bug 1337301 - Part 1: Histogram for VIDEO_AS_CONTENT_SOURCE_IN_TREE_OR_NOT. r=bsmedberg, r=gerald, a=jcristau\n\nMozReview-Commit-ID: HGA6yKbaFxE", "files": ["toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "cc6f316cc3e8390208a05fa79be2b79bfd5d06ef", "parents": ["8345541aea0bc794a1d238cde7aa0c7390f91087"], "tags": []}, {"author": "Kaku Kuo \u003ckaku@mozilla.com\u003e", "branch": "default", "desc": "Bug 1337301 - Part 2: Modify the MarkAsContentSource() API. r=gerald, a=jcristau\n\nMozReview-Commit-ID: 7hgZZUEvDEK", "files": ["dom/html/HTMLMediaElement.cpp"], "git_node": null, "git_parents": [null], "node": "3f04711ccc4f750cc39b8a418acd2f4110a1f2d3", "parents": ["cc6f316cc3e8390208a05fa79be2b79bfd5d06ef"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1330687 - Fix computation of zone edges for weakmap key delgates. r=sfink, a=jcristau", "files": ["js/src/jsgc.cpp", "js/src/jsweakmap.cpp", "js/src/jsweakmap.h"], "git_node": null, "git_parents": [null], "node": "dbd0fa47f7a2970bbe4842e3cef7cec3101fe01a", "parents": ["3f04711ccc4f750cc39b8a418acd2f4110a1f2d3"], "tags": []}], "date": 1486662041, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "6902": {"changesets": [{"author": "Michal Novotny \u003cmichal.novotny@gmail.com\u003e", "branch": "default", "desc": "Bug 1320894 - Fixed serialization of cache index. r=valentin, a=jcristau", "files": ["netwerk/cache2/CacheIndex.cpp", "netwerk/cache2/CacheIndex.h"], "git_node": null, "git_parents": [null], "node": "5dc896e5b70062282a73cfb5b774c4beb31cb626", "parents": ["dbd0fa47f7a2970bbe4842e3cef7cec3101fe01a"], "tags": []}, {"author": "Byron Campen [:bwc] \u003cdocfaraday@gmail.com\u003e", "branch": "default", "desc": "Bug 1328643 - Add some locking to prevent races caused by Cancel/Init from threads other than the target. r=froydnj, a=jcristau\n\nMozReview-Commit-ID: FdAPTGDNKup", "files": ["xpcom/threads/TimerThread.cpp", "xpcom/threads/TimerThread.h", "xpcom/threads/nsTimerImpl.cpp", "xpcom/threads/nsTimerImpl.h"], "git_node": null, "git_parents": [null], "node": "16f96708bef9c19fd9ad80d5201bda24ceb5f235", "parents": ["5dc896e5b70062282a73cfb5b774c4beb31cb626"], "tags": []}], "date": 1486662898, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "6903": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "THUNDERBIRD520b2_2017020901_RELBRANCH", "desc": "Bug 1322027 - Update jemalloc 4 to version 4.4.0. r=glandium a=jorgk", "files": ["build/autoconf/jemalloc.m4", "memory/jemalloc/src/ChangeLog", "memory/jemalloc/src/INSTALL", "memory/jemalloc/src/Makefile.in", "memory/jemalloc/src/VERSION", "memory/jemalloc/src/build-aux/config.guess", "memory/jemalloc/src/build-aux/config.sub", "memory/jemalloc/src/configure", "memory/jemalloc/src/configure.ac", "memory/jemalloc/src/doc/jemalloc.xml.in", "memory/jemalloc/src/include/jemalloc/internal/arena.h", "memory/jemalloc/src/include/jemalloc/internal/chunk.h", "memory/jemalloc/src/include/jemalloc/internal/extent.h", "memory/jemalloc/src/include/jemalloc/internal/jemalloc_internal.h.in", "memory/jemalloc/src/include/jemalloc/internal/jemalloc_internal_defs.h.in", "memory/jemalloc/src/include/jemalloc/internal/pages.h", "memory/jemalloc/src/include/jemalloc/internal/private_symbols.txt", "memory/jemalloc/src/include/jemalloc/internal/stats.h", "memory/jemalloc/src/include/jemalloc/internal/util.h", "memory/jemalloc/src/include/jemalloc/internal/valgrind.h", "memory/jemalloc/src/msvc/projects/vc2015/test_threads/test_threads.cpp", "memory/jemalloc/src/src/arena.c", "memory/jemalloc/src/src/base.c", "memory/jemalloc/src/src/chunk.c", "memory/jemalloc/src/src/chunk_dss.c", "memory/jemalloc/src/src/extent.c", "memory/jemalloc/src/src/huge.c", "memory/jemalloc/src/src/jemalloc.c", "memory/jemalloc/src/src/pages.c", "memory/jemalloc/src/src/stats.c", "memory/jemalloc/src/src/tcache.c", "memory/jemalloc/src/src/util.c", "memory/jemalloc/src/test/integration/MALLOCX_ARENA.c", "memory/jemalloc/src/test/integration/allocated.c", "memory/jemalloc/src/test/integration/chunk.c", "memory/jemalloc/src/test/integration/mallocx.c", "memory/jemalloc/src/test/integration/overflow.c", "memory/jemalloc/src/test/integration/rallocx.c", "memory/jemalloc/src/test/integration/sdallocx.c", "memory/jemalloc/src/test/integration/thread_arena.c", "memory/jemalloc/src/test/integration/thread_tcache_enabled.c", "memory/jemalloc/src/test/integration/xallocx.c", "memory/jemalloc/src/test/unit/arena_reset.c", "memory/jemalloc/src/test/unit/decay.c", "memory/jemalloc/src/test/unit/mallctl.c", "memory/jemalloc/src/test/unit/pack.c", "memory/jemalloc/src/test/unit/pages.c", "memory/jemalloc/src/test/unit/prof_accum.c", "memory/jemalloc/src/test/unit/prof_active.c", "memory/jemalloc/src/test/unit/prof_gdump.c", "memory/jemalloc/src/test/unit/prof_idump.c", "memory/jemalloc/src/test/unit/prof_reset.c", "memory/jemalloc/src/test/unit/prof_thread_name.c", "memory/jemalloc/src/test/unit/run_quantize.c", "memory/jemalloc/src/test/unit/size_classes.c", "memory/jemalloc/src/test/unit/stats.c", "memory/jemalloc/src/test/unit/tsd.c", "memory/jemalloc/src/test/unit/util.c", "memory/jemalloc/upstream.info"], "git_node": null, "git_parents": [null], "node": "f11b7236b009f39bfb9609499fad31249406a6a1", "parents": ["dbd0fa47f7a2970bbe4842e3cef7cec3101fe01a"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "THUNDERBIRD520b2_2017020901_RELBRANCH", "desc": "Bug 1322027 - Don't disable hugepage support since it no longer causes PGO issues. a=jorgk", "files": ["build/autoconf/jemalloc.m4"], "git_node": null, "git_parents": [null], "node": "34f22de867241911d4cbffb9bf87e889bd183277", "parents": ["f11b7236b009f39bfb9609499fad31249406a6a1"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "THUNDERBIRD520b2_2017020901_RELBRANCH", "desc": "Bug 1311039 - Properly detect the default malloc zone on OSX 10.12. r=njn a=jorgk", "files": ["memory/mozjemalloc/jemalloc.c"], "git_node": null, "git_parents": [null], "node": "8f2c8819ba749c7483b5fda4c97d9fcb25253c05", "parents": ["34f22de867241911d4cbffb9bf87e889bd183277"], "tags": []}, {"author": "John Paul Adrian Glaubitz \u003cglaubitz@physik.fu-berlin.de\u003e", "branch": "THUNDERBIRD520b2_2017020901_RELBRANCH", "desc": "Bug 1275204 - mozjemalloc: Use better pre-processor defines for sparc64. r=glandium a=jorgk", "files": ["memory/mozjemalloc/jemalloc.c"], "git_node": null, "git_parents": [null], "node": "5d4b85a2f42dd37377986709c50b281c48ac1fcb", "parents": ["8f2c8819ba749c7483b5fda4c97d9fcb25253c05"], "tags": []}, {"author": "John Paul Adrian Glaubitz \u003cglaubitz@physik.fu-berlin.de\u003e", "branch": "THUNDERBIRD520b2_2017020901_RELBRANCH", "desc": "Bug 1275204 - mozjemalloc: Use the JS arm64 allocator on Linux/sparc64. r=glandium a=jorgk", "files": ["memory/mozjemalloc/jemalloc.c"], "git_node": null, "git_parents": [null], "node": "5c11077ee428b12bea3ee43a46ed26d61150efb8", "parents": ["5d4b85a2f42dd37377986709c50b281c48ac1fcb"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "THUNDERBIRD520b2_2017020901_RELBRANCH", "desc": "Bug 1286613 - Properly call mozjemalloc pre/post fork hooks on OSX when replace-malloc is enabled. r=njn a=jorgk\n\nSomehow, we never called those hooks when replace-malloc is enabled. I'd\nexpect this to cause random deadlocks when forking, and I'm surprised\nthis hasn't surfaced. Maybe it actually causes some intermittent oranges\non automation, who knows.\n\nThis also brings consistency with what is done for jemalloc 4, and with\nthe mozjemalloc implementation, too, that we're going to replace with\nthis one in a subsequent changeset.", "files": ["memory/build/replace_malloc.c", "memory/mozjemalloc/jemalloc.c"], "git_node": null, "git_parents": [null], "node": "86ce4943165e550918d9ce0fd5448e4c62555ab3", "parents": ["5c11077ee428b12bea3ee43a46ed26d61150efb8"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "THUNDERBIRD520b2_2017020901_RELBRANCH", "desc": "Bug 1286613 - Move replace-malloc zone allocator to a separate file. r=njn a=jorgk\n\nThe intent here is to reuse the zone allocator for mozjemalloc, to avoid\nall the shortcomings of mozjemalloc using a different one. This change\nonly moves the replace-malloc zone allocator out of replace-malloc.c, to\nmake changes for mozjemalloc integration clearer.", "files": ["memory/build/moz.build", "memory/build/replace_malloc.c", "memory/build/zone.c"], "git_node": null, "git_parents": [null], "node": "c98a67766f9d1f8a9dd567267317e4e15618ebc0", "parents": ["86ce4943165e550918d9ce0fd5448e4c62555ab3"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "THUNDERBIRD520b2_2017020901_RELBRANCH", "desc": "Bug 1286613 - Use the same zone allocator implementation as replace-malloc for mozjemalloc. r=njn a=jorgk\n\nWe have been using a different zone allocator between mozjemalloc and\nreplace-malloc for a long time. Jemalloc 4 uses the same as\nreplace-malloc, albeit as part of the jemalloc upstream code base.\n\nWe've been bitten many times in the past with Apple changes breaking the\nzone allocator, and each time we've had to make changes to the three\ninstances, although two of them are similar and the changes there are\nstraightforward.\n\nIt also turns out that the way the mozjemalloc zone allocator is set up,\nwhen a new version of OSX appears with a new version of the system zone\nallocator, Firefox ends up using the system allocator, because the zone\nallocator version is not supported.\n\nSo, we use the same zone allocator for both replace-malloc and\nmozjemalloc, making everything on par with jemalloc 4.", "files": ["memory/build/moz.build", "memory/build/zone.c", "memory/mozjemalloc/jemalloc.c", "memory/mozjemalloc/osx_zone_types.h"], "git_node": null, "git_parents": [null], "node": "5d52458aea2980aba9b1258c3f34be4d32998f22", "parents": ["c98a67766f9d1f8a9dd567267317e4e15618ebc0"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "THUNDERBIRD520b2_2017020901_RELBRANCH", "desc": "Bug 1286613 - Don't rely on OSX SDK malloc/malloc.h for malloc_zone struct definitions. r=njn a=jorgk\n\nThe SDK jemalloc is built against might be not be the latest for various\nreasons, but the resulting binary ought to work on newer versions of\nOSX.\n\nIn order to ensure this, we need the fullest definitions possible, so\ncopy what we need from the latest version of malloc/malloc.h available\non opensource.apple.com.\n\n[Adapted from\nhttps://github.com/jemalloc/jemalloc/commit/c68bb4179312665e22d375aecf9f4306607c7c1a]", "files": ["memory/build/zone.c"], "git_node": null, "git_parents": [null], "node": "9210061231955997bd4aad699e04c2cd103452b4", "parents": ["5d52458aea2980aba9b1258c3f34be4d32998f22"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "THUNDERBIRD520b2_2017020901_RELBRANCH", "desc": "Bug 1286613 - Add dummy implementations for most remaining OSX zone allocator functions. r=njn a=jorgk\n\nSome system libraries are using malloc_default_zone() and then using\nsome of the malloc_zone_* API. Under normal conditions, those functions\ncheck the malloc_zone_t/malloc_introspection_t struct for the values\nthat are allowed to be NULL, so that a NULL deref doesn't happen.\n\nAs of OSX 10.12, malloc_default_zone() doesn't return the actual default\nzone anymore, but returns a fake, wrapper zone. The wrapper zone defines\nall the possible functions in the malloc_zone_t/malloc_introspection_t\nstruct (almost), and calls the function from the registered default zone\n(jemalloc in our case) on its own. Without checking whether the pointers\nare NULL.\n\nThis means that a system library that calls e.g.\nmalloc_zone_batch_malloc(malloc_default_zone(), ...) ends up trying to\ncall jemalloc_zone.batch_malloc, which is NULL, and crash follows.\n\nSo as of OSX 10.12, the default zone is required to have all the\nfunctions available (really, the same as the wrapper zone), even if they\ndo nothing.\n\nThis is arguably a bug in libsystem_malloc in OSX 10.12, but jemalloc\nstill needs to work in that case.\n\n[Adapted from\nhttps://github.com/jemalloc/jemalloc/commit/c6943acb3c56d1b3d1e82dd43b3fcfeae7771990]", "files": ["memory/build/zone.c"], "git_node": null, "git_parents": [null], "node": "d478e77e521b4c360ea6c5a6d980a4ec8f111d67", "parents": ["9210061231955997bd4aad699e04c2cd103452b4"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "THUNDERBIRD520b2_2017020901_RELBRANCH", "desc": "Bug 1286613 - Update jemalloc 4 to c6943ac. r=njn a=jorgk\n\nThis picks the same changes as the ones we just did to\nmemory/build/zone.c, plus a oneliner for sparc64.", "files": ["memory/jemalloc/src/VERSION", "memory/jemalloc/src/configure", "memory/jemalloc/src/configure.ac", "memory/jemalloc/src/include/jemalloc/internal/jemalloc_internal.h.in", "memory/jemalloc/src/include/jemalloc/internal/jemalloc_internal_defs.h.in", "memory/jemalloc/src/include/jemalloc/internal/mb.h", "memory/jemalloc/src/src/zone.c", "memory/jemalloc/upstream.info"], "git_node": null, "git_parents": [null], "node": "861ac63842ddecc44ad242e16472a90341c05a38", "parents": ["d478e77e521b4c360ea6c5a6d980a4ec8f111d67"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "THUNDERBIRD520b2_2017020901_RELBRANCH", "desc": "Bug 1332508 - Reinitialize allocator mutexes in fork() child processes. r=njn a=jorgk\n\nAdapted from\nhttps://github.com/jemalloc/jemalloc/commit/4e2e3dd9cf19ed5991938a708a8b50611aa5bbf8\nand\nhttps://github.com/jemalloc/jemalloc/commit/d9f7b2a4307f7ff9f7a139b33d366d44e8a8b83d\n\nAs per the latter commit, it would seem unlocking, in fork() child\nprocesses, mutexes that were locked in the parent process is not really\nwell supported on OSX 10.12. The addition of the zone_reinit_lock\nfunction in 10.12 supports this idea.", "files": ["memory/build/zone.c", "memory/mozjemalloc/jemalloc.c"], "git_node": null, "git_parents": [null], "node": "5f22c17aeac24ce0854f80521e13fb17f601c744", "parents": ["861ac63842ddecc44ad242e16472a90341c05a38"], "tags": []}], "date": 1486663033, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "mozilla@jorgk.com"}, "6904": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset 16f96708bef9 (bug 1328643) for bustage.", "files": ["xpcom/threads/TimerThread.cpp", "xpcom/threads/TimerThread.h", "xpcom/threads/nsTimerImpl.cpp", "xpcom/threads/nsTimerImpl.h"], "git_node": null, "git_parents": [null], "node": "937faf1c1cf167907250103c38a8bc1c78710e4f", "parents": ["16f96708bef9c19fd9ad80d5201bda24ceb5f235"], "tags": []}, {"author": "Daosheng Mu \u003cdaoshengmu@gmail.com\u003e", "branch": "default", "desc": "Bug 1315718 - Replace mGamepadManager raw pointer with RefPtr in VRManagerChild. r=smaug, r=kip, r=dmu, a=jcristau\n\nMozReview-Commit-ID: HOqQm2F6Dpn", "files": ["dom/gamepad/GamepadManager.cpp", "gfx/vr/ipc/VRManagerChild.cpp", "gfx/vr/ipc/VRManagerChild.h", "gfx/vr/ipc/VRManagerParent.cpp", "gfx/vr/ipc/VRManagerParent.h"], "git_node": null, "git_parents": [null], "node": "25c61e4eb82ddd366b9c472c0961e1d38299d588", "parents": ["937faf1c1cf167907250103c38a8bc1c78710e4f"], "tags": []}], "date": 1486663920, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "6905": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1324497 - Add waitForNotificationPanel function to fix test bustage. a=test-only", "files": ["browser/base/content/test/popupNotifications/head.js"], "git_node": null, "git_parents": [null], "node": "cbfc87ea5508b744abc2e2909cddd01840877236", "parents": ["25c61e4eb82ddd366b9c472c0961e1d38299d588"], "tags": []}], "date": 1486667777, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "6906": {"changesets": [{"author": "Byron Campen [:bwc] \u003cdocfaraday@gmail.com\u003e", "branch": "default", "desc": "Bug 1328643 - Add some locking to prevent races caused by Cancel/Init from threads other than the target. (build fixed) r=froydnj, a=jcristau\n\nMozReview-Commi