ID: 9RW0BretWU5", "files": ["testing/marionette/action.js", "testing/marionette/test_action.js"], "git_node": null, "git_parents": [null], "node": "f48f562cf64dfc117719b8f2528713a9480d3260", "parents": ["7b65b6b433f858df747ad74178c097891f0a095b"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@mozilla.com\u003e", "branch": "default", "desc": "Bug 1336214 - Remove duplicate error.wrap. r=maja_zf, a=test-only\n\nMozReview-Commit-ID: KC6ByTiyhre", "files": ["testing/marionette/error.js", "testing/marionette/test_error.js"], "git_node": null, "git_parents": [null], "node": "0dd199ef6823dc12ae35edfefcd1a18a48c5be0a", "parents": ["f48f562cf64dfc117719b8f2528713a9480d3260"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@mozilla.com\u003e", "branch": "default", "desc": "Bug 1336214 - Use static lookup of errors. r=maja_zf, a=test-only\n\nTo avoid errors from being needlessly constructed on starting the\nMarionette server, this changes testing/marionette/error.js to use a\nstatic lookup table for error status codes.\n\nThis also provides some added security since individual custom errors\nmay have specific constructor logic that would cause an error to throw\nan error if the correct arguments were not provided, and we cannot\nguarantee that we provide the right ones generically when loading in\nthe error module.\n\nMozReview-Commit-ID: 1sejpNzsjJp", "files": ["testing/marionette/error.js"], "git_node": null, "git_parents": [null], "node": "bc051001a42a12c34b0a84fe4d5e020e41c65512", "parents": ["0dd199ef6823dc12ae35edfefcd1a18a48c5be0a"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@mozilla.com\u003e", "branch": "default", "desc": "Bug 1336214 - Preserve stacktraces in Marionette errors. r=maja_zf, a=test-only\n\nSince bug 1326534 we have discarded the original stacktrace from errors\noriginating inside Marionette.  This was due to faulty logic when\nattempting to generate a new stacktrace when it was missing from a\npropagated error.\n\nThis change simplifies WebDriver errors by making use of Error\ninheritance.  The WebDriver error specific functions error.toJson and\nerror.fromJson has additionally been moved to WebDriverError.\n\nMozReview-Commit-ID: C3Ns0H01LyG", "files": ["testing/marionette/assert.js", "testing/marionette/error.js", "testing/marionette/message.js", "testing/marionette/proxy.js", "testing/marionette/test_assert.js", "testing/marionette/test_error.js", "testing/marionette/test_message.js"], "git_node": null, "git_parents": [null], "node": "21fc5cafcf6854e12f3878490247ca736b806140", "parents": ["bc051001a42a12c34b0a84fe4d5e020e41c65512"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1325778 - Intermittent toolkit/components/passwordmgr/test/mochitest/test_insecure_form_field_autocomplete.html. r=gbrown, a=test-only\n\nMozReview-Commit-ID: 99eVjotuRZ2", "files": ["toolkit/components/passwordmgr/test/mochitest/mochitest.ini"], "git_node": null, "git_parents": [null], "node": "a1a71de4e2dc5c26982a673728a5354409889496", "parents": ["21fc5cafcf6854e12f3878490247ca736b806140"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1304273 - Intermittent browser/base/content/test/general/browser_offlineQuotaNotification.js. disabled on linux opt/pgo. r=gbrown, a=test-only\n\nMozReview-Commit-ID: FkjLhHL6dtY", "files": ["browser/base/content/test/general/browser.ini"], "git_node": null, "git_parents": [null], "node": "6c43b3dae2bb02cb39d97c212209d3c6a80dac2e", "parents": ["a1a71de4e2dc5c26982a673728a5354409889496"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1296622 - Intermittent dom/tests/mochitest/chrome/test_focus.xul, disabled on linux opt. r=gbrown, a=test-only\n\nMozReview-Commit-ID: FGG9Z3T8BYC", "files": ["dom/tests/mochitest/chrome/chrome.ini"], "git_node": null, "git_parents": [null], "node": "21910c6fc9440fea632d07a11f14eabc805536d8", "parents": ["6c43b3dae2bb02cb39d97c212209d3c6a80dac2e"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1316305 - Intermittent dom/security/test/csp/test_upgrade_insecure.html. disabled on osx. r=gbrown, a=test-only\n\nMozReview-Commit-ID: FyX1wqxhyT7", "files": ["dom/security/test/csp/mochitest.ini"], "git_node": null, "git_parents": [null], "node": "06849854b2b579434c41a4c4cdddb49086970122", "parents": ["21910c6fc9440fea632d07a11f14eabc805536d8"], "tags": []}, {"author": "Michael Layzell \u003cmichael@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1332783 - Null out privateWin and testBrowser. r=ehsan, a=test-only\n\nMozReview-Commit-ID: KVi1okXUqGV", "files": ["dom/html/test/browser_bug1108547.js"], "git_node": null, "git_parents": [null], "node": "28eb6ec7d3039fd910ada84cad0d0a668e56901f", "parents": ["06849854b2b579434c41a4c4cdddb49086970122"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1300017 - Skip crashtest 373122-1.html except on osx, for intermittent leaks. r=jmaher, a=test-only", "files": ["widget/cocoa/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "d45c20a48ae5df77f7b652c12840f15c0abadefc", "parents": ["28eb6ec7d3039fd910ada84cad0d0a668e56901f"], "tags": []}, {"author": "Grigory Kruglov \u003cgkruglov@mozilla.com\u003e", "branch": "default", "desc": "Bug 1341125 - Clear accounts in-memory cache when necessary. r=nalexander, a=jcristau", "files": ["mobile/android/base/java/org/mozilla/gecko/AccountsHelper.java", "mobile/android/services/src/main/java/org/mozilla/gecko/fxa/receivers/FxAccountDeletedService.java"], "git_node": null, "git_parents": [null], "node": "f4e950ed234bcf6eda4b347fb16c15369cc635ee", "parents": ["d45c20a48ae5df77f7b652c12840f15c0abadefc"], "tags": []}, {"author": "Alastor Wu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1339230 - Only need to do audio competing for active agent. r=baku, a=jcristau", "files": ["dom/audiochannel/AudioChannelService.cpp", "dom/audiochannel/AudioChannelService.h", "dom/html/HTMLMediaElement.cpp", "modules/libpref/init/all.js", "toolkit/content/tests/browser/browser.ini", "toolkit/content/tests/browser/browser_audioCompeting_onlyForActiveAgent.js", "toolkit/content/tests/browser/file_multiplePlayingAudio.html"], "git_node": null, "git_parents": [null], "node": "8bedf41ebfd9a88f3ea63509c28e94c1b258efe1", "parents": ["f4e950ed234bcf6eda4b347fb16c15369cc635ee"], "tags": []}, {"author": "Brian Hackett \u003cbhackett1024@gmail.com\u003e", "branch": "default", "desc": "Bug 1338642 - Backout bug 1315596 (Don't evict bundles which won't help with allocating the target bundle). r=sunfish, a=jcristau", "files": ["js/src/jit/BacktrackingAllocator.cpp", "js/src/jit/BacktrackingAllocator.h"], "git_node": null, "git_parents": [null], "node": "5392976baadbf9d55fe272826eae7356ff03e126", "parents": ["8bedf41ebfd9a88f3ea63509c28e94c1b258efe1"], "tags": []}, {"author": "Milan Sreckovic \u003cmilan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1336350 - CAIRO_INT_STATUS_UNSUPPORTED is a special case of an error. r=jrmuizel, a=jcristau\n\nMozReview-Commit-ID: Hsl5eA1YMl0", "files": ["gfx/cairo/cairo/src/cairo-scaled-font.c"], "git_node": null, "git_parents": [null], "node": "d1b4c5e38c8fabe11d2b9e9fb79441e53d568381", "parents": ["5392976baadbf9d55fe272826eae7356ff03e126"], "tags": []}], "date": 1488404333, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "6990": {"changesets": [{"author": "seabld", "branch": "SEA248b1_2017021701_RELBRANCH", "desc": "Added tag SEAMONKEY_2_48b1_BUILD1 for changeset 001253005de3. CLOSED TREE a=release", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "e8fc3653284e8e9c93713ce33ad7e8dd403de739", "parents": ["001253005de37dfdf1b3292f08431fca669a2704"], "tags": []}, {"author": "seabld", "branch": "SEA248b1_2017021701_RELBRANCH", "desc": "Added tag SEAMONKEY_2_48b1_RELEASE for changeset 001253005de3. CLOSED TREE a=release", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "f79f0090924c6cce5377d497c1d076f93cb6c061", "parents": ["e8fc3653284e8e9c93713ce33ad7e8dd403de739"], "tags": []}], "date": 1488425467, "git_changesets": [null, null], "user": "seabld"}, "6991": {"changesets": [{"author": "Alastor Wu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1340191 - Reverse the checking condition. r=sebastian, a=jcristau\n\nSince BBC website puts their audio in another iframe, we can't get the media\nelement to check its duration, so we always return false.\n\nThe ideal way to fix it is to get every iframe and check its element, but I think\nit's not very easy to do considering the flexibility of using iframe and the cost time.\n\nFirst, if we want to get the information inside iframe, we need to listen the\nonload event, but it's async operation. If there are lots iframe, we need to spend\nlots time to wait every iframe. The worst situation is we got the nested iframe,\nit would need lots time and effect to wait every iframe loaded and get the element we want.\n\nTherefore, I would prefer the workaround which is to reverse the checking condition,\nthat is we only check duration for the main window.\n\nMozReview-Commit-ID: F93BjbzRMXO", "files": ["mobile/android/chrome/content/browser.js"], "git_node": null, "git_parents": [null], "node": "4011ea8c02046f86467c3488f63846bd258fb6eb", "parents": ["d1b4c5e38c8fabe11d2b9e9fb79441e53d568381"], "tags": []}, {"author": "Alastor Wu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1326114 - Only do duration checking for active-media. r=sebastian, a=jcristau\n\nSince we don't want to show the media control for the short sound, so we added the duration checking.\nAnd this checking only needs to be run when the media is active, we don't need to check the inactive media.\n\nMozReview-Commit-ID: AaVGi77nXJ1", "files": ["mobile/android/chrome/content/browser.js"], "git_node": null, "git_parents": [null], "node": "f38b2da7ec120f82264778629e2abb0879105cb1", "parents": ["4011ea8c02046f86467c3488f63846bd258fb6eb"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1342051 - Clear css grid highlighter cache when destroying highlighter. r=zer0, a=jcristau\n\nMozReview-Commit-ID: 5LpjjzjZfs3", "files": ["devtools/client/inspector/rules/test/browser.ini", "devtools/client/inspector/rules/test/browser_rules_grid-highlighter-on-reload.js", "devtools/server/actors/highlighters/css-grid.js"], "git_node": null, "git_parents": [null], "node": "742686c19a176d3482d63e52ee4c3b5ac1f8132e", "parents": ["f38b2da7ec120f82264778629e2abb0879105cb1"], "tags": []}], "date": 1488459136, "git_changesets": [null, null, null], "user": "ryanvm@gmail.com"}, "6992": {"changesets": [{"author": "ffxbld", "branch": "MOBILE520b11_2017030210_RELBRANCH", "desc": "Automated checkin: version bump for fennec 52.0b11 release. DONTBUILD CLOSED TREE a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "47344625ee69c03b10fc3bc82a87e4bc8d5dc3a4", "parents": ["742686c19a176d3482d63e52ee4c3b5ac1f8132e"], "tags": ["FENNEC_52_0b11_BUILD1", "FENNEC_52_0b11_RELEASE"]}, {"author": "ffxbld", "branch": "MOBILE520b11_2017030210_RELBRANCH", "desc": "Added FENNEC_52_0b11_RELEASE FENNEC_52_0b11_BUILD1 tag(s) for changeset 47344625ee69. DONTBUILD CLOSED TREE a=release", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "75cab4fa7bffdb6badfacd42184744151c7c8900", "parents": ["47344625ee69c03b10fc3bc82a87e4bc8d5dc3a4"], "tags": []}], "date": 1488467552, "git_changesets": [null, null], "user": "ffxbld"}, "6993": {"changesets": [{"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "Bug 1153457 - Remove CP