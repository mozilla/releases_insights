list if GC cells were leaked at shutdown. r=sfink, a=NPOTB", "files": ["js/src/jscompartment.cpp"], "git_node": null, "git_parents": [null], "node": "23ca52f77b78bbb221a786c96def039dffd1da69", "parents": ["588d478a51eee4b80a220d6a532726deb9a9f3d5"], "tags": []}], "date": 1485565676, "git_changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "6838": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset bef0eb878659 (bug 1328718) for non-local connection crashes.", "files": ["browser/extensions/disableSHA1rollout/README.md", "browser/extensions/disableSHA1rollout/bootstrap.js", "browser/extensions/disableSHA1rollout/install.rdf.in", "browser/extensions/disableSHA1rollout/moz.build", "browser/extensions/moz.build", "testing/talos/talos/xtalos/xperf_whitelist.json"], "git_node": null, "git_parents": [null], "node": "eee47824f4687534a901cd9c28126041bd19d261", "parents": ["23ca52f77b78bbb221a786c96def039dffd1da69"], "tags": []}], "date": 1485569795, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "6839": {"changesets": [{"author": "Andreas Pehrson \u003cpehrsons@gmail.com\u003e", "branch": "default", "desc": "Bug 1331839 - Harden test_mediarecorder_bitrate.html. r=jwwang a=test-only\n\nMozReview-Commit-ID: BFNAhS7B7C6", "files": ["dom/media/test/test_mediarecorder_bitrate.html"], "git_node": null, "git_parents": [null], "node": "8817536bea8400edae027932fe0586ec47bebf22", "parents": ["eee47824f4687534a901cd9c28126041bd19d261"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1279693 - Add the Win7 version of himalaya.ttf to the GDEF blacklist in harfbuzz. r=jrmuizel a=jcristau", "files": ["gfx/harfbuzz/src/hb-ot-layout.cc"], "git_node": null, "git_parents": [null], "node": "0f53157d8586f85fcea234895d22291d54acfef1", "parents": ["8817536bea8400edae027932fe0586ec47bebf22"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1317704 - Part 1. Hold current ranges into RemoveInlineProperty. r=masayuki a=jcristau\n\nSince current selection ranges might be modified by SplitStyleAboveRange,  this crash occurs into RemoveInlinePropertyImpl.  So we need hold current selection range for loop.\n\nMozReview-Commit-ID: JuXn9XlwCp6", "files": ["editor/libeditor/HTMLStyleEditor.cpp"], "git_node": null, "git_parents": [null], "node": "2332cedca400d8ed64580d90222c74f0d482d90e", "parents": ["0f53157d8586f85fcea234895d22291d54acfef1"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1317704 - Part 2. Add test. r=masayuki a=test-only\n\nMozReview-Commit-ID: AVOvEZ1sMVq", "files": ["editor/libeditor/crashtests/1317704.html", "editor/libeditor/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "5aee8dff330f19c9a27b0114371d2c09b2a65d93", "parents": ["2332cedca400d8ed64580d90222c74f0d482d90e"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1320705: P1. Fix function prototyping. r=gerald a=jcristau\n\nReturning already_AddRefed is by convention preferred.\n\nMozReview-Commit-ID: 1UyIcyBm923\n\n\nG: changed dom/media/ogg/OggCodecState.h", "files": ["dom/media/ogg/OggCodecState.cpp", "dom/media/ogg/OggCodecState.h"], "git_node": null, "git_parents": [null], "node": "17ac9bf7648b299461303f5c28bababa76764889", "parents": ["5aee8dff330f19c9a27b0114371d2c09b2a65d93"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1320705: P2. Add mDiscardPadding information. r=kinetik a=jcristau\n\nThe WebMDemuxer added this information in the ExtraData field. However, this is incompatible with the MSE demuxer which will override the ExtraData field under some circumstances.\nIt's cleaner to have a dedicated field anyway.\n\nMozReview-Commit-ID: GadD11zzZ8f", "files": ["dom/media/MediaData.h"], "git_node": null, "git_parents": [null], "node": "8f145a69abd7d292a114fbcc06b78009a5e1efae", "parents": ["17ac9bf7648b299461303f5c28bababa76764889"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1320705: P3. Update Opus decoder to discared mDiscardPadding. r=kinetik a=jcristau\n\nMozReview-Commit-ID: 5BpUgsjh8i9", "files": ["dom/media/platforms/agnostic/OpusDecoder.cpp"], "git_node": null, "git_parents": [null], "node": "1d3f67b775b36ab2437e08b6685d7275a66bc79b", "parents": ["8f145a69abd7d292a114fbcc06b78009a5e1efae"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1320705: P4. Pass discard padding information from webm container. r=kinetik a=jcristau\n\nMozReview-Commit-ID: G2OnV1iZohn", "files": ["dom/media/webm/WebMDemuxer.cpp"], "git_node": null, "git_parents": [null], "node": "15c7e43f42488f2ea073a3879161f92c6634e328", "parents": ["1d3f67b775b36ab2437e08b6685d7275a66bc79b"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1320705: P5. Pass discard padding information from ogg container. r=kinetik a=jcristau\n\nMozReview-Commit-ID: 8UKSVM0F0xF", "files": ["dom/media/ogg/OggCodecState.cpp", "dom/media/ogg/OggCodecState.h"], "git_node": null, "git_parents": [null], "node": "29a707e6a7c80c6f1c6285e6f7f1b9c78c168750", "parents": ["15c7e43f42488f2ea073a3879161f92c6634e328"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1320705: P6. Fix codec mimetypes. r=gerald a=jcristau\n\nMozReview-Commit-ID: FozWtbvDNnA", "files": ["dom/media/ogg/OggDemuxer.cpp", "dom/media/platforms/agnostic/OpusDecoder.cpp", "dom/media/platforms/agnostic/TheoraDecoder.cpp", "dom/media/platforms/agnostic/VorbisDecoder.cpp", "dom/media/webm/WebMDemuxer.cpp"], "git_node": null, "git_parents": [null], "node": "6d316ab0fc3ff220ebd13a5e9655edb7fffdca68", "parents": ["29a707e6a7c80c6f1c6285e6f7f1b9c78c168750"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1320705: P7. Ensure audio decoder is recreated when chaining encountered. r=gerald a=jcristau\n\nThe Opus decoder will error if we feed it new data if it has seen the last packet of a stream.\n\nMozReview-Commit-ID: Kw3cZuEKxie", "files": ["dom/media/ogg/OggDemuxer.cpp", "dom/media/ogg/OggDemuxer.h"], "git_node": null, "git_parents": [null], "node": "a8ee326f2b441088034cbfccf8e03217004c5526", "parents": ["6d316ab0fc3ff220ebd13a5e9655edb7fffdca68"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1320705: P8. Don't use stagefright to decode vorbis. r=gerald a=jcristau\n\nFixing the codec mimetype in P6, had the side effect of Android PDM trying to use the stagefright decoder which crashes.\n\nMozReview-Commit-ID: 1OSGGCTdGFO", "files": ["dom/media/platforms/android/AndroidDecoderModule.cpp"], "git_node": null, "git_parents": [null], "node": "1eff2d1a58c303b0e012b2272eba4b001593d222", "parents": ["a8ee326f2b441088034cbfccf8e03217004c5526"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1323425 - WebSocket::CreateAndDispatchCloseEvent must check if mImpl has been nullified, r=smaug a=jcristau", "files": ["dom/base/WebSocket.cpp"], "git_node": null, "git_parents": [null], "node": "b01263e0808e8d8a065564516526e847911c32a1", "parents": ["1eff2d1a58c303b0e012b2272eba4b001593d222"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1325158: Part 1 - Don't return error result from OnRedirectVerifyCallback. r=ehsan a=jcristau\n\nMozReview-Commit-ID: Hb3I0U8kxdz", "files": ["dom/xhr/XMLHttpRequestMainThread.cpp"], "git_node": null, "git_parents": [null], "node": "76e66c9bdc1c89bb801d6401c7e52fd58be5f1d6", "parents": ["b01263e0808e8d8a065564516526e847911c32a1"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1325158: Part 2 - Correctly handle extra OnRedirectVerifyCallback calls. r=honzab\n\nMozReview-Commit-ID: Hl1C6ZEdZKF", "files": ["netwerk/base/nsAsyncRedirectVerifyHelper.cpp"], "git_node": null, "git_parents": [null], "node": "07f14f4cf04ac91b2f3070400d299f6918f70c1f", "parents": ["76e66c9bdc1c89bb801d6401c7e52fd58be5f1d6"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1325158: Part 3 - Don't create a reference cycle via HTTP channel property bag. r=mixedpuppy\n\nMozReview-Commit-ID: 40Ox7BDlgwy", "files": ["toolkit/modules/addons/WebRequest.jsm"], "git_node": null, "git_parents": [null], "node": "5196491659ff46a249863af21868877698523506", "parents": ["07f14f4cf04ac91b2f3070400d299f6918f70c1f"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1333576 - Ensure Shutdown() is called before releasing the decoder. r=gerald a=jcristau\n\nMozReview-Commit-ID: CBEOgh5v90L", "files": ["dom/html/HTMLMediaElement.cpp", "dom/html/HTMLMediaElement.h"], "git_node": null, "git_parents": [null], "node": "e2be2a6d8c057ac80953e25244df94378878ed28", "parents": ["5196491659ff46a249863af21868877698523506"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1334165 Don't allow event dispatch after WebSocket allows worker thread to exit cleanly. r=baku a=jcristau", "files": ["dom/base/WebSocket.cpp"], "git_node": null, "git_parents": [null], "node": "4271550cd0b402cfb44cc0bc4312338582a7418f", "parents": ["e2be2a6d8c057ac80953e25244df94378878ed28"], "tags": []}, {"author": "Mats Palmgren \u003cmats@mozilla.com\u003e", "branch": "default", "desc": "Bug 1334403 - Make \u003ccaption\u003e inline size stretch again for table flex items.  r=dholbert, a=jcristau", "files": ["layout/generic/ReflowInput.cpp"], "git_node": null, "git_parents": [null], "node": "0e5fcab28382aa0dc2db37f34b30e51fc610cbc6", "parents": ["4271550cd0b402cfb44cc0bc4312338582a7418f"], "tags": []}, {"author": "Mats Palmgren \u003cmats@mozilla.com\u003e", "branch": "default", "desc": "Bug 1334403 - Some \u003ccaption\u003e size tests for table flex items. a=test-only", "files": ["layout/reftests/flexbox/flexbox-table-flex-items-1-ref.html", "layout/reftests/flexbox/flexbox-table-flex-items-1.html", "layout/reftests/flexbox/reftest.list"], "git_node": null, "git_parents": [null], "node": "9ac0e74f530d7f1f0fac6364f1a644b6c9e73381", "parents": ["0e5fcab28382aa0dc2db37f34b30e51fc610cbc6"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1334480 - Don't try to update a nullptr registration. r=asuth a=jcristau", "files": ["dom/workers/ServiceWorkerPrivate.cpp"], "git_node": null, "git_parents": [null], "node": "0f54c5ef73d6fd308bc450835bf8c83840c33548", "parents": ["9ac0e74f530d7f1f0fac6364f1a644b6c9e73381"], "tags": []}], "date": 1485787269, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "cbook@mozilla.com"}, "6840": {"changesets": [{"author": "David Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "Bug 1328718 - implement system add-on to facilitate rollout of disabling SHA-1 r=Felipe,jcj data-review=bsmedberg a=jcristau", "files": ["browser/extensions/disableSHA1rollout/README.md", "browser/extensions/disableSHA1rollout/bootstrap.js", "browser/extensions/disableSHA1rollout/install.rdf.in", "browser/extensions/disableSHA1rollout/moz.build", "browser/extensions/moz.build", "testing/talos/talos/xtalos/xperf_whitelist.json"], "git_node": null, "git_parents": [null], "node": "cd23479f1e746be41d872f4f2ea71e33cd0f07ae", "parents": ["0f54c5ef73d6fd308bc45