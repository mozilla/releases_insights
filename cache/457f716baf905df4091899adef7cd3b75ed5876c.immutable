compatibility issues, a=jcristau", "files": ["old-configure.in", "security/nss/TAG-INFO", "security/nss/cmd/bltest/blapitest.c", "security/nss/cmd/ecperf/ecperf.c", "security/nss/cmd/fbectest/fbectest.c", "security/nss/cmd/fipstest/fipstest.c", "security/nss/coreconf/coreconf.dep", "security/nss/lib/cryptohi/keyi.h", "security/nss/lib/cryptohi/keythi.h", "security/nss/lib/cryptohi/seckey.c", "security/nss/lib/freebl/blapi.h", "security/nss/lib/freebl/blapit.h", "security/nss/lib/freebl/ec.c", "security/nss/lib/freebl/ecdecode.c", "security/nss/lib/freebl/ldvector.c", "security/nss/lib/freebl/loader.c", "security/nss/lib/freebl/loader.h", "security/nss/lib/nss/nss.h", "security/nss/lib/pk11wrap/pk11akey.c", "security/nss/lib/pk11wrap/pk11skey.c", "security/nss/lib/softoken/pkcs11.c", "security/nss/lib/softoken/pkcs11c.c", "security/nss/lib/softoken/softkver.h", "security/nss/lib/ssl/ssl3ecc.c", "security/nss/lib/util/eccutil.h", "security/nss/lib/util/nssutil.h"], "git_node": null, "git_parents": [null], "node": "b570b28bb0f5092d293de5a70bc4d4c840460ee0", "parents": ["42db8a0b3673b959560b0edc2ac89a44576bddd1"], "tags": []}], "date": 1487600233, "git_changesets": [null], "user": "kaie@kuix.de"}, "6952": {"changesets": [{"author": "Rail Aliiev \u003crail@mozilla.com\u003e", "branch": "default", "desc": "Bug 1337366 - Gecko-specific changes to support mozilla-esr52; r=jlund a=release DONTBUILD\n\nMozReview-Commit-ID: 96uxlGaFBjo", "files": ["testing/mozharness/configs/builds/branch_specifics.py"], "git_node": null, "git_parents": [null], "node": "346bcdd75fc230161035bf31c319ee170160e1fb", "parents": ["b570b28bb0f5092d293de5a70bc4d4c840460ee0"], "tags": []}], "date": 1487600987, "git_changesets": [null], "user": "raliiev@mozilla.com"}, "6953": {"changesets": [{"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1270235 - Part 1: Check parent node is null in RemoveEmptyNodes. r=masayuki, a=jcristau\n\nRemoveEmptyNodes doesn't check whether parent node is null.  So we shouldn't add null to skip list.\n\nAlso, although this crash depends on clang, if debug build, it will hit the assertion on all compiler.\n\nMozReview-Commit-ID: GgiczVExlIn", "files": ["editor/libeditor/HTMLEditRules.cpp"], "git_node": null, "git_parents": [null], "node": "e197e817582e5d9ad02ff8c4a51ae137ca4f8855", "parents": ["346bcdd75fc230161035bf31c319ee170160e1fb"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1270235 - Part 2: Add test. r=masayuki, a=jcristau\n\nMozReview-Commit-ID: BV7Dc6YiNM6", "files": ["editor/libeditor/tests/mochitest.ini", "editor/libeditor/tests/test_bug1270235.html"], "git_node": null, "git_parents": [null], "node": "db5e61ac282d94631be31bd6f5d2e85d75d289b5", "parents": ["e197e817582e5d9ad02ff8c4a51ae137ca4f8855"], "tags": []}, {"author": "Thinker K.F. Li \u003cthinker@codemud.net\u003e", "branch": "default", "desc": "Bug 1313753 - Test case for correctness of visible regions of preserve-3d. r=mattwoodrow a=test-only", "files": ["dom/tests/mochitest/general/mochitest.ini", "dom/tests/mochitest/general/test_bug1313753.html"], "git_node": null, "git_parents": [null], "node": "85400a46019b9663ff62727565a8e478dd1577e1", "parents": ["db5e61ac282d94631be31bd6f5d2e85d75d289b5"], "tags": []}, {"author": "Thinker K.F. Li \u003cthinker@codemud.net\u003e", "branch": "default", "desc": "Bug 1313753 - Update overflow at the establisher of the 3D rendering context. r=dbaron a=jcristau", "files": ["layout/base/OverflowChangedTracker.h"], "git_node": null, "git_parents": [null], "node": "da123a8b468f6004cef07a9d8a1c7a59c1434be8", "parents": ["85400a46019b9663ff62727565a8e478dd1577e1"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1315752 - Avoid using LookupLocalFont to find the Osaka-Mono face in InitSingleFaceList, so we don't risk triggering a font-download prompt. r=mstange a=jcristau\n\n    The issue is that with Osaka becoming a downloadable asset rather than a\n    universally pre-installed font, it's possible for a user's system to be in\n    a state where the Osaka-Regular face is present (and therefore the Osaka\n    family shows up in the main font family list), but Osaka-Mono has still not\n    been downloaded. Until recently, I wasn't aware that the family could be in\n    that partially-installed state, but apparently it does happen (perhaps\n    depending on how the download was originally triggered).\n\n    The download prompt then occurs when we use LookupLocalFont() to find the\n    Osaka-Mono face, because that calls CGFontCreateWithFontName, which is\n    aware of the downloadable font assets; so when it is asked for Osaka-Mono,\n    and sees that it hasn't been downloaded, it offers to help out.\n\n    We tried to avoid this by checking for the presence of the Osaka family\n    before calling LookupLocalFont(), and that solved things for most users\n    (where the Osaka family was either fully installed or not installed at\n    all), but it fails in the case where the Regular face is present but Mono\n    isn't.\n\n    So this patch works around that by avoiding LookupLocalFont (and therefore\n    CGFontCreateWithFontName) altogether, and instead searching the faces\n    actually present in the main Osaka family. If Osaka-Mono is installed, it\n    will be found there and we can then duplicate its font entry and create the\n    separate Osaka-Mono family; and if not, we safely (and silently) ignore it.", "files": ["gfx/thebes/gfxMacPlatformFontList.mm"], "git_node": null, "git_parents": [null], "node": "398b16c6ce7a7918e01098767faf2c65b28fc7c7", "parents": ["da123a8b468f6004cef07a9d8a1c7a59c1434be8"], "tags": []}, {"author": "Honza Bambas \u003chonzab.moz@firemni.cz\u003e", "branch": "default", "desc": "Bug 1333568. r=valentin a=jcristau", "files": ["netwerk/cache/nsDiskCacheDeviceSQL.cpp", "netwerk/cache/nsDiskCacheDeviceSQL.h"], "git_node": null, "git_parents": [null], "node": "14a2e9a60736cea784f4a797e512bef5da53584f", "parents": ["398b16c6ce7a7918e01098767faf2c65b28fc7c7"], "tags": []}, {"author": "Henri Sivonen \u003chsivonen@hsivonen.fi\u003e", "branch": "default", "desc": "Bug 1336836 - Null-check mEncoder for XPCOM shutdown. r=emk a=jcristau\n\nMozReview-Commit-ID: G6UeBdUbK85", "files": ["intl/uconv/nsNCRFallbackEncoderWrapper.cpp"], "git_node": null, "git_parents": [null], "node": "7084f0d7a43e3485bda9cb790346ce2cdb95d2ea", "parents": ["14a2e9a60736cea784f4a797e512bef5da53584f"], "tags": []}, {"author": "L. David Baron \u003cdbaron@dbaron.org\u003e", "branch": "default", "desc": "Bug 1340593 - Set NS_STYLE_HAS_CHILD_THAT_USES_RESET_STYLE from the WalkRuleTree codepath too.  r=heycam a=jcristau", "files": ["layout/style/nsRuleNode.cpp"], "git_node": null, "git_parents": [null], "node": "3b31bcb88fe341172e93cc8b1143e617c0988694", "parents": ["7084f0d7a43e3485bda9cb790346ce2cdb95d2ea"], "tags": ["FIREFOX_52_0b8_BUILD1", "FIREFOX_52_0b8_RELEASE"]}], "date": 1487602839, "git_changesets": [null, null, null, null, null, null, null, null], "user": "cbook@mozilla.com"}, "6954": {"changesets": [{"author": "Mihai Tabara \u003cmtabara@mozilla.com\u003e", "branch": "default", "desc": "Bug 1338232 - add sha256 hash in checksums automation. r=rail a=release DONTBUILD\n\nMozReview-Commit-ID: C0tahX0pG55", "files": ["testing/mozharness/mozharness/base/script.py", "testing/mozharness/scripts/release/beet_mover.py", "testing/mozharness/scripts/release/generate-checksums.py"], "git_node": null, "git_parents": [null], "node": "482e65e3b6e06f0ce0b9ce363e79cd9060c3a628", "parents": ["3b31bcb88fe341172e93cc8b1143e617c0988694"], "tags": []}], "date": 1487611431, "git_changesets": [null], "user": "mtabara@mozilla.com"}, "6955": {"changesets": [{"author": "ffxbld", "branch": "MOBILE520b8_2017022015_RELBRANCH", "desc": "Automated checkin: version bump for fennec 52.0b8 release. DONTBUILD CLOSED TREE a=release"