03e", "branch": "default", "desc": "Bug 1327949 - Fixing new tab icon in high DPI mode when moved to be the correct width. r=dao, a=jcristau\n\nMozReview-Commit-ID: 3DnAjYNDUlD", "files": ["browser/themes/windows/browser.css"], "git_node": null, "git_parents": [null], "node": "2e91c8334463411fe75e448a4b27c48ce37f21ad", "parents": ["f867ccafb47482578642cff261383e0d60cf4633"], "tags": []}, {"author": "Kirk Steuber \u003cksteuber@mozilla.com\u003e", "branch": "default", "desc": "Bug 1333483 - Hardcode itisatrap manual testing URLs for Flash blocking into the SafeBrowsing module. r=francois, a=jcristau\n\nMozReview-Commit-ID: ASCt3VfRJgg", "files": ["toolkit/components/url-classifier/SafeBrowsing.jsm"], "git_node": null, "git_parents": [null], "node": "4603dc332d7f1a384c5f4b39192e992f596a4c5b", "parents": ["2e91c8334463411fe75e448a4b27c48ce37f21ad"], "tags": []}], "date": 1486758577, "git_changesets": [null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "6916": {"changesets": [{"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1330840 - Add Padding to in-content Insecure Password Warning. r=MattN, a=jcristau\n\nMozReview-Commit-ID: 9jgdZPIfpMI", "files": ["browser/base/content/browser.xul"], "git_node": null, "git_parents": [null], "node": "b77d127a3c11ba4e3abb1656c21e901ce3956534", "parents": ["4603dc332d7f1a384c5f4b39192e992f596a4c5b"], "tags": []}, {"author": "Bob Owen \u003cbobowencode@gmail.com\u003e", "branch": "default", "desc": "Bug 1321724 - Change USER_NON_ADMIN access token level from whitelist to blacklist containing Admin SIDs. r=jimm, a=jcristau\n\nMozReview-Commit-ID: 9cx2R6kMUwa", "files": ["security/sandbox/chromium/sandbox/win/src/restricted_token.cc", "security/sandbox/chromium/sandbox/win/src/restricted_token.h", "security/sandbox/chromium/sandbox/win/src/restricted_token_utils.cc"], "git_node": null, "git_parents": [null], "node": "eb7b524ddced9bd89d033010782089634fb8704a", "parents": ["b77d127a3c11ba4e3abb1656c21e901ce3956534"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1334594 - Call NSTextInputClient's insertText:replacementRange: instead of NSTextInput's insertText: from IMEInputHandler::SendCommittedText(). r=m_kato, a=jcristau\n\nBug 1180564 dropped NSTextInput protocl implementation from ChildView but IMEInputHandler::SendCommittedText() still calls it via mView.  Therefore, it fails to commit composition in widget level.  Instead, we it should call insertText:replacementRange: of NSTextInputClient protocol.\n\nAdditionally, this patch adds a last resort path. If calling insertText:replacementRange: didn't commit composition in widget level, it calls TextInputHandler::InsertText() directly.\n\nMozReview-Commit-ID: BZZypBqC0Mx", "files": ["widget/cocoa/TextInputHandler.mm"], "git_node": null, "git_parents": [null], "node": "878de02bf5c6399f6cd5b86315238de518d2c71b", "parents": ["eb7b524ddced9bd89d033010782089634fb8704a"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1337388 - Remove unnecessary AsyncPanZoomEnabled check, and add a null guard. r=tnikkel, a=jcristau\n\nMozReview-Commit-ID: 87zwTEwPyLt", "files": ["layout/base/nsLayoutUtils.cpp"], "git_node": null, "git_parents": [null], "node": "11cbfffd2ea895aa26c0ebb7f83291b5c3ad98b4", "parents": ["878de02bf5c6399f6cd5b86315238de518d2c71b"], "tags": []}, {"author": "Jet Villegas \u003cbugs@junglecode.net\u003e", "branch": "default", "desc": "Bug 1311368 - Fix ShouldBlockContent logic when content blocking is enabled. r=tobytailor, a=jcristau", "files": ["dom/base/nsObjectLoadingContent.cpp", "dom/base/nsObjectLoadingContent.h"], "git_node": null, "git_parents": [null], "node": "6f05f53c02cdac3254d2cbb8e93735d4be244969", "parents": ["11cbfffd2ea895aa26c0ebb7f83291b5c3ad98b4"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "bran