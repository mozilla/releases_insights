315464 - Dynamically allocate test regions. r=jrmuizel, a=test-only\n\nAvoid allocating 720K on the stack.", "files": ["gfx/tests/gtest/TestRegion.cpp"], "git_node": null, "git_parents": [null], "node": "651b85366876fd0407383ac063f5a0e2d8c63b89", "parents": ["cfe1b04271782572a6bd0e309731e17f3826b378"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1302854 - Disable jetpack/test-context-menu.js subtest for frequent failures. r=kmag, a=test-only\n\nMozReview-Commit-ID: 74CpzkiFVja", "files": ["addon-sdk/source/test/test-context-menu.js"], "git_node": null, "git_parents": [null], "node": "d6174e6fd41f1110bfa6430396207abcb0c9e972", "parents": ["651b85366876fd0407383ac063f5a0e2d8c63b89"], "tags": []}, {"author": "Eric Rahm \u003cerahm@mozilla.com\u003e", "branch": "default", "desc": "Bug 1332202 - Convert most infallible NS_EscapeURL calls to fallible version. r=froydnj, a=jcristau\n\nThis makes most users of |NS_EscapeURL| use the fallible version. A few are\nleft infallible as it seems like the entire function is assumed to be\ninfallible.\n\nMozReview-Commit-ID: Cy1L5jQwjO1", "files": ["caps/nsNullPrincipalURI.cpp", "dom/html/HTMLFormSubmission.cpp", "dom/jsurl/nsJSProtocolHandler.cpp", "dom/quota/ActorsParent.cpp", "dom/storage/DOMStorageObserver.cpp", "embedding/components/webbrowserpersist/nsWebBrowserPersist.cpp", "netwerk/base/nsSimpleURI.cpp", "netwerk/base/nsStandardURL.cpp", "netwerk/base/nsURLHelperUnix.cpp", "netwerk/protocol/http/nsHttpDigestAuth.cpp"], "git_node": null, "git_parents": [null], "node": "d6ff11588e1d1de9e257555319e6c4d0cb378e8c", "parents": ["d6174e6fd41f1110bfa6430396207abcb0c9e972"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1333648 - Update the en-US dictionary to SCOWL 2017.01.22. r=ehsan, a=jcristau", "files": ["extensions/spellcheck/locales/en-US/hunspell/README_en_US.txt", "extensions/spellcheck/locales/en-US/hunspell/dictionary-sources/5-mozilla-added", "extensions/spellcheck/locales/en-US/hunspell/dictionary-sources/orig/README_en_US-custom.txt", "extensions/spellcheck/locales/en-US/hunspell/dictionary-sources/orig/en_US-custom.dic", "extensions/spellcheck/locales/en-US/hunspell/en-US.dic"], "git_node": null, "git_parents": [null], "node": "71e0c2ed4fa4521cc452d56e0ff280a05b9051e0", "parents": ["d6ff11588e1d1de9e257555319e6c4d0cb378e8c"], "tags": []}], "date": 1485797580, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "6844": {"changesets": [{"author": "ffxbld", "branch": "MOBILE520b2_2017013013_RELBRANCH", "desc": "Automated checkin: version bump for fennec 52.0b2 release. DONTBUILD CLOSED TREE a=release", "files": [], "git_node": null, "git_parents": [null], "node": "254417a9fca49d9ffb158666edbf1678e51140cd", "parents": ["0f339c1e154f75c484fe2fac507a9a225990d212"], "tags": ["FENNEC_52_0b2_BUILD1", "FENNEC_52_0b2_RELEASE"]}, {"author": "ffxbld", "branch": "MOBILE520b2_2017013013_RELBRANCH", "desc": "Added FENNEC_52_0b2_RELEASE FENNEC_52_0b2_BUILD1 tag(s) for changeset 254417a9fca4. DONTBUILD CLOSED TREE a=release", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "0674cd970d61f6e973a563041bd8861b8773f68b", "parents": ["254417a9fca49d9ffb158666edbf1678e51140cd"], "tags": []}], "date": 1485803041, "git_changesets": [null, null], "user": "ffxbld"}, "6845": {"changesets": [{"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1333803 - Revert setting of the update channel to modifying channel-prefs.js. r=maja_zf, a=test-only\n\nAs it has been turned out setting the desired update channel via a preference\non the default branch does not work. Instead it really has to be set in the\nchannel-prefs.js file.\n\nIf not done so, the updater will see the new channel as invalid and abort the\nupdate process.", "files": ["testing/firefox-ui/harness/firefox_ui_harness/testcases.py", "testing/firefox-ui/tests/puppeteer/test_software_update.py", "testing/marionette/puppeteer/firefox/firefox_puppeteer/api/software_update.py"], "git_node": null, "git_parents": [null], "node": "787766dd27b7373797a3fa6ab7115c85f27c04f2", "parents": ["71e0c2ed4fa4521cc452d56e0ff280a05b9051e0"], "tags": []}], "date": 1485805810, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "6846": {"changesets": [{"author": "George P\u00eerlea \u003cgeorge@dranov.ro\u003e", "branch": "default", "desc": "Bug 991965 - Use event.target and inhibit item selection if the context menu is open. r=paolo a=jcristau\n\n1) In the Downloads Panel, hovering over an item would sometimes not trigger an\nactual selection, due to an error in how 'onDownloadMouseOver()' events were\nprocessed - 'aEvent.orginalTarget' doesn't take retargets into account. Fixed\nby using 'aEvent.target' instead of 'aEvent.originalTarget'.\n\n2) In the Downloads Panel, right-clicking an item opens a context menu that\nlets you act on the selected item. However, if you unintentionally hover over a\ndifferent item when the context menu is open, the selection changes. You may,\nfor example, 'Remove From History' a different, unintended item. Fixed by\ninhibiting item selection when a context menu is open for a download item.\n\nMozReview-Commit-ID: DLIAFNcs33N", "files": ["browser/components/downloads/content/downloads.js", "browser/components/downloads/content/downloadsOverlay.xul"], "git_node": null, "git_parents": [null], "node": "7c172c2d11ba454bac1992f300556eccace5bf94", "parents": ["787766dd27b7373797a3fa6ab7115c85f27c04f2"], "tags": []}, {"author": "George P\u00eerlea \u003cgeorge@dranov.ro\u003e", "branch": "default", "desc": "Bug 991965 - Inhibit item selection and update commands when the DownloadsBlockedSubview is open. r=paolo a=jcristau\n\nMozReview-Commit-ID: Akly0NenY8Z", "files": ["browser/components/downloads/content/downloads.js"], "git_node": null, "git_parents": [null], "node": "6708a90583ea4169de6b1ef828cc52923f644854", "parents": ["7c172c2d11ba454bac1992f300556eccace5bf94"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1264053 - Transfer DifferentProcess ArrayBuffers by copying, r=jorendorff a=jcristau", "files": ["js/src/builtin/TestingFunctions.cpp", "js/src/tests/js1_8_5/extensions/clone-errors.js", "js/src/tests/js1_8_5/extensions/clone-transferables.js", "js/src/vm/StructuredClone.cpp", "mfbt/BufferList.h"], "git_node": null, "git_parents": [null], "node": "294e61b943c4ceb92c2625d1652785a4f0689125", "parents": ["6708a90583ea4169de6b1ef828cc52923f644854"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Bug 1297867 - Add a telemetry probe to track the amount of scrolling in a page. r=jaws data-review=bsmedberg a=jcristau", "files": ["toolkit/components/telemetry/Histograms.json", "toolkit/content/browser-content.js"], "git_node": null, "git_parents": [null], "node": "d382faa1a2e2c10b92a55cee5f4cc6c3a36e9e8e", "parents": ["294e61b943c4ceb92c2625d1652785a4f0689125"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1320481 - thumbnails cache not cleared with clear history on shutdown. r=Felipe a=jcristau\n\nThe \"places-shutdown\" notification is not a good time to remove observers, since\nhistory notifications (and in particular onClearHistory) may happen at the same\ntime (The sanitizer runs at \"profile-change-teardown\" that is basically the same\nas \"places-shutdown\").\nWe can't ensure proper order of these calls, the safest/simplest thing is just\nto keep a weak reference and continue observing.\n\nMozReview-Commit-ID: 9zHkDqozXup", "files": ["browser/components/newtab/NewTabMessages.jsm", "browser/components/newtab/PlacesProvider.jsm", "browser/components/newtab/tests/xpcshell/test_PlacesProvider.js", "browser/components/nsBrowserGlue.js", "toolkit/components/thumbnails/PageThumbs.jsm"], "git_node": null, "git_parents": [null], "node": "61b8c52dd25e29bd2f2a53067996a579ade28242", "parents": ["d382faa1a2e2c10b92a55cee5f4cc6c3a36e9e8e"], "tags": []}, {"author": "Thom Chiovoloni \u003ctchiovoloni@mozilla.com\u003e", "branch": "default", "desc": "Bug 1321396 - Skip oversized records without aborting the sync by default in sync engines. r=markh a=jcristau\n\nMozReview-Commit-ID: 7hgzyKb2UxY", "files": ["services/sync/modules/engines.js", "services/sync/modules/engines/bookmarks.js", "services/sync/modules/engines/clients.js", "services/sync/modules/engines/extension-storage.js", "services/sync/modules/engines/forms.js", "services/sync/modules/engines/history.js", "services/sync/modules/engines/prefs.js", "services/sync/tests/unit/test_syncengine_sync.js"], "git_node": null, "git_parents": [null], "node": "b293d6e395a1b0f9ee367c85d789de0bbbf00a96", "parents": ["61b8c52dd25e29bd2f2a53067996a579ade28242"], "tags": []}, {"author": "Jamie Nicol \u003cjnicol@mozilla.com\u003e", "branch": "default", "desc": "Bug 1324312 - Handle alloc failure when uploading texture. r=sotaro a=jcristau\n\nWhen GL_UNPACK_ROW_LENGTH is not supported and the source data has a\ndifferent stride to that of the texture (often because we are\nuploading only the modified subimage) we allocate a temporary buffer\nwith the correct stride. This was found to be more efficient than\nuploading each row of texture data individually.\n\nSometimes allocating the buffer will fail, however. In such cases fall\nback to uploading the texture row-by-row, rather than aborting.\n\nMozReview-Commit-ID: E7LE8nHPE0M", "files": ["gfx/gl/GLUploadHelpers.cpp"], "git_node": null, "git_parents": [null], "node": "bbc148936ba4da23034c02eff006f7e33c862974", "parents": ["b293d6e395a1b0f9ee367c85d789de0bbbf00a96"], "tags": []}, {"author": "Honza Bambas \u003chonzab.moz@firemni.cz\u003e", "branch": "default", "desc": "Bug 1329506 - Add missing non-null check in mozilla::net::DoUpdateExpirationTime. r=michal a=jcristau", "files": ["netwerk/cache2/CacheEntry.cpp"], "git_node": null, "git_parents": [null], "node": "56b35490bf160226dd5c48ad9f600183f92a4cdf", "parents": ["bbc148936ba4da23034c02eff006f7e33c862974"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1332773 - Don't trace things in other runtimes in the pre barrier verifier r=sfink a=jcristau", "files": ["js/src/gc/Verifier.cpp", "js/src/jit-test/tests/gc/bug-1332773.js"], "git_node": null, "git_parents": [null], "node": "1ba06428e641e5ee399a329920b2ef54074264bc", "parents": ["56b35490bf160226dd5c48ad9f600183f92a4cdf"], "tags": []}, {"author": "Mats Palmgren \u003cmats@mozilla.com\u003e", "branch": "default", "desc": "Bug 1332876 - Bail out of HTMLEditRules::BeforeEdit if we have no Selection.  r=masayuki a=jcristau", "files": ["editor/libeditor/HTMLEditRules.cpp"], "git_node": null, "git_parents": [null], "node": "c0345ca8cb3bf10c4f69021d6c38c9b95a925625", "parents": ["1ba06428e641e5ee399a329920b2ef54074264bc"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1333064 - Unblocked malware downloads are styled incorrectly in the Downloads Panel. r=mak a=jcristau\n\nMozReview-Commit-ID: IT4Dd9tBzt0", "files": ["browser/components/downloads/DownloadsViewUI.jsm"], "git_node": null, "git_parents": [null], "node": "c3e3b17bcc696e3b3aaa01fbf59055fe287ba69f", "parents": ["c0345ca8cb3bf10c4f69021d6c38c9b95a925625"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1333210, r=honzab,ckerschb a=jcristau\n\nMozReview-Commit-ID: 2Gu8sv36Yyy", "files": ["devtools/client/jsonview/converter-child.js", "devtools/client/jsonview/test/browser_jsonview_valid_json.js"], "git_node": null, "git_parents": [null], "node": "d5aa0f7f0237cf2f6a09947ac4d8098bfaae6959", "parents": ["c3e3b17bcc696e3b3aaa01fbf59055fe287ba69f"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1334257: Assure that TIPMessageHandler hooks may not be instantiated more than once; r=jimm a=jcristau\n\nMozReview-Commit-ID: LiDQ9yUzGTK", "files": ["widget/windows/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "716b06d074332b9c0b6f921312b2a0beb242b0d7", "parents": ["d5aa0f7f0237cf2f6a09947ac4d8098bfaae6959"], "tags": []}, {"author": "philipp \u003cmadperson@gmx.at\u003e", "branch": "default", "desc": "Bug 1334561 - Add another batch of affected AMD driver versions to d3d11 dxva blacklist. r=gerald a=jcristau", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "f01c5c342a5cb4a5862ea31eeee7f0812a273227", "parents": ["716b06d074332b9c0b6f921312b2a0beb242b0d7"], "tags": []}], "date": 1485877192, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "cbook@mozilla.com"}, "6847": {"changesets": [{"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1322349 - Allow a touch swipe gesture at the top of the screen to show the URL bar in fullscreen mode. r=jaws a=jcristau\n\nMozReview-Commit-ID: 8Gp4VkrMueu", "files": ["browser/base/content/browser-fullScreenAndPointerLock.js"], "git_node": null, "git_parents": [null], "node": "b4d00fe2451bddd592379046df735382e1279159", "parents": ["f01c5c342a5cb4a5862ea31eeee7f0812a273227"], "tags": []}], "date": 1485877345, "git_changesets": [null], "user": "kgupta@mozilla.com"}, "6848": {"changesets": [{"author": "Mats Palmgren \u003cmats@mozilla.com\u003e", "branch": "default", "desc": "Bug 1332876 - test. a=test-only", "files": ["editor/libeditor/tests/mochitest.ini", "editor/libeditor/tests/test_bug1332876.html"], "git_node": null, "git_parents": [null], "node": "f7b5ec13731e3723550887060dfab89713a898fa", "parents": ["b4d00fe2451bddd592379046df735382e1279159"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1333736 - Disable usage of new tab page by default. r=maja_zf a=test-only\n\nNow that Marionette can load about:blank multiple times right after each\nother there is no need to prevent using it when turning of the new tab page.\n\ntest_about_blank_for_new_docshell can also be updated by using a new tab for\nthe test. This also gives us a new docshell and can also be run for Fennec.\n\nMozReview-Commit-ID: GWxtsH3nQt", "files": ["testing/marionette/client/marionette_driver/geckoinstance.py", "testing/marionette/harness/marionette_harness/tests/unit/test_navigation.py", "testing/marionette/harness/marionette_harness/www/windowHandles.html"], "git_node": null, "git_parents": [null], "node": "d859990cc3113332b24cc0088c8d75fbe5471775", "parents": ["f7b5ec13731e3723550887060dfab89713a898fa"], "tags": []}], "date": 1485877652, "git_changesets": [null, null], "user": "cbook@mozilla.com"}, "6849": {"changesets": [{"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1307461 - Disable MediaPipelineTest.TestAudioSendMux; r=jesup a=test-only", "files": ["media/webrtc/signaling/test/mediapipeline_unittest.cpp"], "git_node": null, "git_parents": [null], "node": "95e076f66b6b41ded3d6fb0662dec35524a714ba", "parents": ["d859990cc3113332b24cc0088c8d75fbe5471775"], "tags": []}, {"author": "Matthew Noorenberghe \u003cmozilla@noorenberghe.ca\u003e", "branch": "default", "desc": "Bug 1333256 - Bring back the insecure field warning Learn More text in bold on beta. r=seanlee l10n=flod  a=jcristau\n\nMozReview-Commit-ID: 8Z6pKwFqk3M", "files": ["toolkit/components/passwordmgr/LoginManagerContent.jsm", "toolkit/content/widgets/autocomplete.xml", "toolkit/locales/en-US/chrome/passwordmgr/passwordmgr.properties"], "git_node": null, "git_parents": [null], "node": "147b55311d5350e6d7022d031f725934d6c717a0", "parents": ["95e076f66b6b41ded3d6fb0662dec35524a714ba"], "tags": []}], "date": 1485877957, "git_changesets": [nu