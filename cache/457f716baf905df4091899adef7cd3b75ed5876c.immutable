gfx/2d/DrawTargetSkia.cpp"], "git_node": null, "git_parents": [null], "node": "9770defcb76a67743da11ec26f265d9c36083b06", "parents": ["3ae45b6e6eb1a047579e6fae68000907c5d79095"], "tags": []}, {"author": "Ethan Lin \u003cethlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1325159 - Add nullptr check for GetTop(). r=mattwoodrow, a=jcristau", "files": ["layout/base/nsDisplayList.h"], "git_node": null, "git_parents": [null], "node": "a9a756031446537aa1525125166e31ffbfea1db7", "parents": ["9770defcb76a67743da11ec26f265d9c36083b06"], "tags": []}, {"author": "Ethan Lin \u003cethlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1325159 - Add crash test for bug 1325159. r=pchang, a=jcristau", "files": ["gfx/tests/crashtests/1325159-1.html", "gfx/tests/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "89e4f1010091f089eeeaa6a591c0d67fcf7cf4d4", "parents": ["a9a756031446537aa1525125166e31ffbfea1db7"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1329386 - Fallback to WMF decoding if the OOP decoder fails. r=jya, a=jcristau", "files": ["dom/media/ipc/RemoteVideoDecoder.cpp", "dom/media/platforms/PlatformDecoderModule.h"], "git_node": null, "git_parents": [null], "node": "d626dac2573064ab9723b23ddbe7dfb74feb7beb", "parents": ["89e4f1010091f089eeeaa6a591c0d67fcf7cf4d4"], "tags": []}, {"author": "Nevin Chen \u003ccnevinchen@gmail.com\u003e", "branch": "default", "desc": "Bug 1331431 - Use baseline and FontMetrics instead of textview's center and text size to get the real text height. r=sebastian, a=jcristau\n\nMozReview-Commit-ID: 4HJKZP0F0ow", "files": ["mobile/android/base/java/org/mozilla/gecko/widget/FadedMultiColorTextView.java"], "git_node": null, "git_parents": [null], "node": "9c822f8fbd6528a2e566a8c678d5540ed793c512", "parents": ["d626dac2573064ab9723b23ddbe7dfb74feb7beb"], "tags": []}, {"author": "J. Ryan Stinnett \u003cjryans@gmail.com\u003e", "branch": "default", "desc": "Bug 1331601 - Copy tab listener state flags in RDM. r=ochameau, a=jcristau\n\nWhen starting and stopping RDM, we need want to ensure tab listener state flags\nare preserved for the tab involved, which is a bit tricky with the tab dance\nRDM is doing.\n\nThe state flags ensure the browser will call the correct handlers when switching\ntabs to update the primary browser UI.  For example, this is needed to correctly\nupdate the enabled state of the view source command for the current tab.\n\nMozReview-Commit-ID: 7lKY0DKxgJH", "files": ["devtools/client/responsive.html/browser/swap.js"], "git_node": null, "git_parents": [null], "node": "339271ebe1d736770c5a90b909b1b6d5b8cf750b", "parents": ["9c822f8fbd6528a2e566a8c678d5540ed793c512"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1330759 - Part 1: Change various bits of DOMString code to work better when it has a stringbuffer which is effectively not null-terminated (in the sense that indexing into it at the DOMString's length doesn't yield '\\0'). r=froydnj, a=jcristau", "files": ["dom/bindings/DOMString.h"], "git_node": null, "git_parents": [null], "node": "6ca3b97b5e421f5e3069c7d4823c62e27fc5f1d1", "parents": ["339271ebe1d736770c5a90b909b1b6d5b8cf750b"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1330759 - Part 2: Fix XPCConvert::JSData2Native to not share an external string stringbuffer if it would create a non-null-terminated string. r=froydnj, a=jcristau", "files": ["js/xpconnect/src/XPCConvert.cpp"], "git_node": null, "git_parents": [null], "node": "8dcb11ae3b13d49ccfecfd7d43c1aaed9f4360ad", "parents": ["6ca3b97b5e421f5e3069c7d4823c62e27fc5f1d1"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1330759 - Part 3: Add a \"stringbuffer we own\" mode to DOMString. r=froydnj, a=jcristau\n\nWe're going to need it because we're going to add a consumer that cannot in fact\npromise that its stringbuffer reference will outlive the DOMString.", "files": ["dom/bindings/DOMString.h", "js/xpconnect/src/xpcpublic.h"], "git_node": null, "git_parents": [null], "node": "0f3d229ed368c45b2e12e080d0e1d4956a88aaa0", "parents": ["8dcb11ae3b13d49ccfecfd7d43c1aaed9f4360ad"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1330759 - Part 4: Change XMLHttpRequest's responseText getter to take a DOMString, not an nsAString. r=froydnj, a=jcristau", "files": ["dom/xhr/XMLHttpRequest.h", "dom/xhr/XMLHttpRequestMainThread.cpp", "dom/xhr/XMLHttpRequestMainThread.h", "dom/xhr/XMLHttpRequestString.cpp", "dom/xhr/XMLHttpRequestString.h", "dom/xhr/XMLHttpRequestWorker.cpp", "dom/xhr/XMLHttpRequestWorker.h"], "git_node": null, "git_parents": [null], "node": "cdaba011494a6f01f7ed4e8f419653b4ee5dbcca", "parents": ["0f3d229ed368c45b2e12e080d0e1d4956a88aaa0"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1330759 - Part 5: Back out the nsTSubstring changes we made in bug 1324430, because they can lead to non-null-terminated nsStrings. r=froydnj, a=jcristau", "files": ["xpcom/string/nsTSubstring.cpp", "xpcom/string/nsTSubstring.h"], "git_node": null, "git_parents": [null], "node": "121ee6ad585ef8d8f26a986830d71afc9b306c86", "parents": ["cdaba011494a6f01f7ed4e8f419653b4ee5dbcca"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1330759 - Part 6: Make the null-termination asserts in nsStringBuffer::ToString into diagnostic asserts. r=froydnj, a=jcristau", "files": ["xpcom/string/nsSubstring.cpp"], "git_node": null, "git_parents": [null], "node": "1522cb56a651b62675f392d4064bd4365aac07f4", "parents": ["121ee6ad585ef8d8f26a986830d71afc9b306c86"], "tags": []}], "date": 1485237165, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, nu