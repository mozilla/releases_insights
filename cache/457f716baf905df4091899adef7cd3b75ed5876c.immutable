s/test/webgl-conf/checkout/js/tests/tex-image-and-sub-image-with-image-bitmap-utils.js", "dom/canvas/test/webgl-conf/checkout/js/webgl-test-utils.js", "dom/canvas/test/webgl-conf/checkout/resources/glsl-generator.js", "dom/canvas/test/webgl-conf/checkout/webgl-conformance-tests.html"], "git_node": null, "git_parents": [null], "node": "49ee6ecf35c2b576755453eebd648035d882779b", "parents": ["c6089115c5947a891b6a68e4139b7b1093903e87"], "tags": []}], "date": 1485267050, "git_changesets": [null, null, null, null, null], "user": "cbook@mozilla.com"}, "6811": {"changesets": [{"author": "Jordan Lund \u003cjlund@mozilla.com\u003e", "branch": "default", "desc": "Bug 1333443 - fixes mozilla-beta osx uni mozconfigs post migration, r=rail a=testing", "files": ["browser/config/mozconfigs/macosx-universal/l10n-mozconfig", "browser/config/mozconfigs/macosx-universal/nightly"], "git_node": null, "git_parents": [null], "node": "78ae21055d9f303be257abe155ba9dee466c0651", "parents": ["49ee6ecf35c2b576755453eebd648035d882779b"], "tags": ["FIREFOX_52_0b1_BUILD2", "FIREFOX_52_0b1_RELEASE"]}], "date": 1485279948, "git_changesets": [null], "user": "jlund@mozilla.com"}, "6812": {"changesets": [{"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1319668 - Check for null context before trying to draw canvas text. r=mats, a=jcristau", "files": ["dom/canvas/CanvasRenderingContext2D.cpp"], "git_node": null, "git_parents": [null], "node": "6c44d7b72386be8362d0c536a95a92a3b0fc1a4f", "parents": ["78ae21055d9f303be257abe155ba9dee466c0651"], "tags": []}, {"author": "sotaro \u003csotaro.ikeda.g@gmail.com\u003e", "branch": "default", "desc": "Bug 1329300 - Update validity check of SharedPlanarYCbCrImage. r=nical, a=jcristau", "files": ["gfx/layers/ipc/SharedPlanarYCbCrImage.cpp"], "git_node": null, "git_parents": [null], "node": "3ea055ea09e2df09d601edaebb45aa5b6287ee97", "parents": ["6c44d7b72386be8362d0c536a95a92a3b0fc1a4f"], "tags": []}, {"author": "Eric Rahm \u003cerahm@mozilla.com\u003e", "branch": "default", "desc": "Bug 1322735 - Enable frame pointers on 32-bit windows builds. r=glandium, a=jcristau\n\nThis universally disables FPO on win32.\n\nMozReview-Commit-ID: AT9ozxGN0C5", "files": ["build/autoconf/frameptr.m4"], "git_node": null, "git_parents": [null], "node": "543f7d3a61ddc135be85b9a1b319b39ffb815d54", "parents": ["3ea055ea09e2df09d601edaebb45aa5b6287ee97"], "tags": []}, {"author": "Eric Rahm \u003cerahm@mozilla.com\u003e", "branch": "default", "desc": "Bug 1322735 - Remove MOZ_STACKWALKING define. r=glandium, a=jcristau\n\nWith frame pointer omission disabled we should always have usable stacks on Windows. This allows us to remove the MOZ_STACKWALKING define as it will always be enabled.\n\nMozReview-Commit-ID: 54xs3Hf1r4P", "files": ["browser/app/profile/firefox.js", "js/src/jit/ExecutableAllocatorWin.cpp", "mozglue/misc/StackWalk.h", "mozglue/misc/moz.build", "old-configure.in", "security/sandbox/chromium-shim/sandbox/win/loggingCallbacks.h", "tools/profiler/core/platform-win32.cc", "xpcom/base/nsTraceRefcnt.cpp", "xpcom/build/LateWriteChecks.cpp"], "git_node": null, "git_parents": [null], "node": "62d73eeb27e00faa33b57711282401183ee93c3b", "parents": ["543f7d3a61ddc135be85b9a1b319b39ffb815d54"], "tags": []}, {"author": "Neil Deakin \u003cneil@mozilla.com\u003e", "branch": "default", "desc": "Bug 1329907 - Use opacity to clear the treecell text while editing instead of changing the value. r=jaws, a=jcristau", "files": ["toolkit/content/widgets/tree.xml", "toolkit/themes/linux/global/tree.css", "toolkit/themes/osx/global/tree.css", "toolkit/themes/windows/global/tree.css"], "git_node": null, "git_parents": [null], "node": "7a4a33b8e52241f5e01276a2dce89382d940f60f", "parents": ["62d73eeb27e00faa33b57711282401183ee93c3b"], "tags": []}, {"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1317212 - \u003cxul:browser\u003e's that flip remoteness should not send progress updates for the initial about:blank load. r=Gijs, a=jcristau\n\nThis is kind of a sad story. In bug 1254669, I made it so that we destroy the original\ntab progress listener and create a new one when flipping remoteness. This is because\nthe initial about:blank load for a flipped browser is not something we ever want\nto show progress for.\n\nI goofed though*, and didn't call the mTabProgressListener constructor with the right\nargument that indicates that the first messages are from about:blank. This opened us\nup for a race with e10s-mode where, after a tab tear out, the initial browser would\nflip remoteness to remote, send up a StateChange message to indicate loading of\nabout:blank (which we'd accidentally listen to). The race happened when we'd sometimes\ndo the frameloader swap before the StateChange to indicate that about:blank had finished\nloading would come up. This would mean (after the frameloader swap), we'd never hear\nabout the initial about:blank finishing loading, so we'd always show \"busy\".\n\n* :(\n\nMozReview-Commit-ID: 6pU1fqiIDUc", "files": ["browser/base/content/tabbrowser.xml"], "git_node": null, "git_parents": [null], "node": "c47910706101e816c10076e75a798ba01b87d1fc", "parents": ["7a4a33b8e52241f5e01276a2dce89382d940f60f"], "tags": []}, {"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1317212 - Make tab progress listeners smarter at ignoring nsIWebProgress notifications from an initial about:blank. r=Gijs, a=jcristau\n\nMozReview-Commit-ID: Ji1oCNZksge", "files": ["browser/base/content/tabbrowser.xml"], "git_node": null, "git_parents": [null], "node": "b85a8f6a5f6160d305a8742a07afd70af10b1902", "parents": ["c47910706101e816c10076e75a798ba01b87d1fc"], "tags": []}, {"author": "Yura Zenevich \u003cyzenevich@mozilla.com\u003e", "branch": "default", "desc": "Bug 1327972 - Make sure alt/cmd+lefr/right navigate history even if devtools toolbar is focused. r=jryans, a=jcristau\n\nMozReview-Commit-ID: 86Qhmtz4ODG", "files": ["devtools/client/framework/toolbox.js"], "git_node": null, "git_parents": [null], "node": "07692c9040cf50bb9eed3d9d9ab38138220a511e", "parents": ["b85a8f6a5f6160d305a8742a07afd70af10b1902"], "tags": []}, {"author": "Dave Townsend \u003cdtownsend@oxymoronical.com\u003e", "branch": "default", "desc": "Bug 1331968 - Implement the moz: protocol handler to redirect to a fixed website. r=gijs, a=jcristau\n\nThe protocol handler is intentionally simple. It works for the entering into the\nurlbar case but not a lot else. Included some basic tests.\n\nMozReview-Commit-ID: 4FQ1irdt3Nj", "files": ["browser/installer/package-manifest.in", "caps/tests/mochitest/browser_checkloaduri.js", "mobile/android/installer/package-manifest.in", "toolkit/components/moz.build", "toolkit/components/mozprotocol/moz.build", "toolkit/components/mozprotocol/mozProtocolHandler.js", "toolkit/components/mozprotocol/mozProtocolHandler.manifest", "toolkit/components/mozprotocol/tests/browser.ini", "toolkit/components/mozprotocol/tests/browser_mozprotocol.js", "toolkit/components/mozprotocol/tests/mozprotocol.html"], "git_node": null, "git_parents": [null], "node": "9a120078e698dcbfb89c8f04c388a0eaac3576d6", "parents": ["07692c9040cf50bb9eed3d9d9ab38138220a511e"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1316236 - Treat perspective(0) as perspective(infinity). r=dholbert, a=jcristau\n\nMozReview-Commit-ID: H9xlpjxrzht", "files": ["layout/reftests/w3c-css/submitted/transforms/perspective-zero.html", "layout/reftests/w3c-css/submitted/transforms/reference/green.html", "layout/reftests/w3c-css/submitted/transforms/reftest.list", "layout/style/StyleAnimationValue.cpp", "layout/style/nsStyleTransformMatrix.cpp", "layout/style/nsStyleTransformMatrix.h"], "git_node": null, "git_parents": [null], "node": "a425672d300fb8a861d1c552cf55004eb1c45469", "parents": ["9a120078e698dcbfb89c8f04c388a0eaac3576d6"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@gmail.com\u003e", "branch": "default", "desc": "Bug 1332619 - Add gtest for skipped frames. r=jesup, a=jcristau\n\nMozReview-Commit-ID: G5BkNVayJOV", "files": ["dom/media/gtest/TestVideoTrackEncoder.cpp"], "git_node": null, "git_parents": [null], "node": "b6ca9b088e2d6694d26479950e7f81a8ce5a4300", "parents": ["a425672d300fb8a861d1c552cf55004eb1c45469"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@gmail.com\u003e", "branch": "default", "desc": "Bug 1332619 - Fix missed duration when skipping a frame in VP8TrackEncoder. r=jesup, a=jcristau\n\nMozReview-Commit-ID: GpXUHfUj5v2", "files": ["dom/media/encoder/VP8TrackEncoder.cpp"], "git_node": null, "git_parents": [null], "node": "82d7cc4c6fe46f384e0b9e214bb9baf05f4d40e8", "parents": ["b6ca9b088e2d6694d26479950e7f81a8ce5a4300"], "tags": []}], "date": 1485285417, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "6813": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changesets 82d7cc4c6fe4 and b6ca9b088e2d (bug 1332619) for bustage.", "files": ["dom/media/encoder/VP8TrackEncoder.cpp", "dom/media/gtest/TestVideoTrackEncoder.cpp"], "git_node": null, "git_parents": [null], "node": "b307ee07a1146933d227b0748de6a1c6473e71d8", "parents": ["82d7cc4c6fe46f384e0b9e214bb9baf05f4d40e8"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1322735 - Fix check_spidermonkey_style.py bustage. a=bustage", "files": ["js/src/jit/ExecutableAllocatorWin.cpp"], "git_node": null, "git_parents": [null], "node": "a6d7a8138baa146108e9100f542a198c0b37f797", "parents": ["b307ee07a1146933d227b0748de6a1c6473e71d8"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1318569 - Skip browser_treeupdate_imagemap.js on e10s across all platforms. a=test-only", "files": ["