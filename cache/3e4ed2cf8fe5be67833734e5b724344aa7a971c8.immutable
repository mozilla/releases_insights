owers/content/specialpowers.js", "testing/specialpowers/content/specialpowersAPI.js", "testing/specialpowers/content/specialpowersFrameScript.js"], "git_node": null, "git_parents": [null, null], "node": "760966ed9ccf1457f49e998a2a53ae20dacb4bb8", "parents": ["8a9279474147d96daf6cfa7aea7ea273c689255f", "32d7797bd8bd91e7b62ef2a5e19b8888881766f1"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1563336: Add a common implementation of module version info extraction to WinHeaderOnlyUtils; r=mhowell\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36817", "files": ["toolkit/xre/CmdLineAndEnvUtils.h", "toolkit/xre/LauncherRegistryInfo.h", "widget/windows/WinHeaderOnlyUtils.h"], "git_node": null, "git_parents": [null], "node": "e9a1abfdd5b6759ee046f9c98f20a772f57aecc6", "parents": ["760966ed9ccf1457f49e998a2a53ae20dacb4bb8"], "tags": []}, {"author": "Erica Wright \u003cewright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1557058 - use real data for protection report graph r=nhnt11,johannh\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36249", "files": ["browser/components/about/AboutProtectionsHandler.jsm", "browser/components/protections/content/protections.css", "browser/components/protections/content/protections.html", "browser/components/protections/content/protections.js", "browser/components/protections/moz.build", "browser/components/protections/test/browser/browser.ini", "browser/components/protections/test/browser/browser_protections_ui.js", "toolkit/components/antitracking/TrackingDBService.jsm", "toolkit/components/antitracking/nsITrackingDBService.idl", "toolkit/components/antitracking/test/xpcshell/test_tracking_db_service.js"], "git_node": null, "git_parents": [null], "node": "cbb9a325576ed78a813d8d535c6f8f8504aeccaa", "parents": ["e9a1abfdd5b6759ee046f9c98f20a772f57aecc6"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1563465 - Remove leftovers from bug 1451104. r=froydnj\n\nBug 1451104 removed the GCC 4.9 toolchain, but left the build script and\nthe patch that only that toolchain build was using.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36886", "files": ["build/unix/build-gcc/PR64905.patch", "taskcluster/scripts/misc/build-gcc-4.9-linux.sh"], "git_node": null, "git_parents": [null], "node": "dda10c593af043a0b1db62a3fd9ea22f66654d0c", "parents": ["cbb9a325576ed78a813d8d535c6f8f8504aeccaa"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1525314 - Disable tile markers on Android as they seem to crash a lot. r=gw\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36794", "files": ["gfx/wr/webrender/src/renderer.rs"], "git_node": null, "git_parents": [null], "node": "7032c413182eda992d7a99ea8ce49ed0c1c7f1c0", "parents": ["dda10c593af043a0b1db62a3fd9ea22f66654d0c"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1525314 - Auto-fuzz WR on Android with maxDifference\u003c=2. r=jmaher\n\nDue to the sheer number of tests that exhibit a random fuzz with maxDifference=1\nand maxDifference=2 with WR on Android, it's easier to just tweak the harness\nto autofuzz these away. This adds machinery to do so, and also adds a new\nannotation that can be used to disable the autofuzzing on specific tests.\n\nDepends on D36794\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36796", "files": ["layout/reftests/reftest-sanity/reftest.list", "layout/tools/reftest/README.txt", "layout/tools/reftest/manifest.jsm", "layout/tools/reftest/reftest.jsm"], "git_node": null, "git_parents": [null], "node": "4f43e8655fefb4e1ea61385993458484821060f3", "parents": ["7032c413182eda992d7a99ea8ce49ed0c1c7f1c0"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc"