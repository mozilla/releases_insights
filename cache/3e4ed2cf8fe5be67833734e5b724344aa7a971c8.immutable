ly.)\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36449", "files": ["mobile/android/themes/geckoview/content.css"], "git_node": null, "git_parents": [null], "node": "529c44a1eba8c3e5721b1677dfd7a980159695d8", "parents": ["d65cbaac955be2d3ae9956a2b06ae24b2a100904"], "tags": []}, {"author": "Cameron McCormack \u003ccam@mcc.id.au\u003e", "branch": "default", "desc": "Bug 1562361 - Clear cached style indices whenever we clear the actual styles. r=emilio\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36450", "files": ["layout/style/ServoStyleSet.cpp", "layout/style/ServoStyleSet.h", "layout/style/crashtests/1562361.html", "layout/style/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "4fd603ca7224eb7d073aba2edf33793224f0055c", "parents": ["529c44a1eba8c3e5721b1677dfd7a980159695d8"], "tags": []}, {"author": "Cameron McCormack \u003ccam@mcc.id.au\u003e", "branch": "default", "desc": "Bug 1562361 - Turn the cached style pref back on. r=emilio\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36451", "files": ["modules/libpref/init/StaticPrefList.h"], "git_node": null, "git_parents": [null], "node": "c6d86a83de2e11bae6ad6e2d0f3916cd3445f8c3", "parents": ["4fd603ca7224eb7d073aba2edf33793224f0055c"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1560149 - Add some documentation for document splitting. r=dthayer\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36210", "files": ["gfx/docs/DocumentSplitting.rst", "gfx/docs/index.rst"], "git_node": null, "git_parents": [null], "node": "405f857977e5589e4e4e8c23146000b0e5cabfd7", "parents": ["c6d86a83de2e11bae6ad6e2d0f3916cd3445f8c3"], "tags": []}, {"author": "Mihai Alexandru Michis \u003cmalexandru@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset c68a6b2e0157 (bug 1557371) for causing failures in reftest/content/bugs/272646-1.xul CLOSED TRE