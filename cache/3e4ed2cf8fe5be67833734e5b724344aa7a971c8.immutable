it_node": null, "git_parents": [null], "node": "eb58740c994a323899cede3e07241c4ab8ee43c7", "parents": ["f677469459a4b47a4c147dc236ffab7dc0043805"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1562277 - Pocket New Tab - Revisit spoc dismissal flow. r=thecount a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39215", "files": ["browser/components/newtab/common/Actions.jsm", "browser/components/newtab/common/Reducers.jsm", "browser/components/newtab/content-src/lib/selectLayoutRender.js", "browser/components/newtab/data/content/activity-stream.bundle.js", "browser/components/newtab/lib/DiscoveryStreamFeed.jsm", "browser/components/newtab/test/unit/common/Reducers.test.js", "browser/components/newtab/test/unit/content-src/lib/selectLayoutRender.test.js", "browser/components/newtab/test/unit/lib/DiscoveryStreamFeed.test.js"], "git_node": null, "git_parents": [null], "node": "600f9bc042665de144ee6f3c0f24b5f2ccfcf6a5", "parents": ["eb58740c994a323899cede3e07241c4ab8ee43c7"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1562928 - Thumbnail sticks around for dismissed \"recommended\" tile, alongside unrelated new text (until new thumbnail has been downloaded). r=thecount a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com//D39213", "files": ["browser/components/newtab/content-src/components/DiscoveryStreamComponents/CardGrid/CardGrid.jsx", "browser/components/newtab/content-src/components/DiscoveryStreamComponents/Hero/Hero.jsx", "browser/components/newtab/content-src/components/DiscoveryStreamComponents/List/List.jsx", "browser/components/newtab/data/content/activity-stream.bundle.js"], "git_node": null, "git_parents": [null], "node": "82898a5be493059e7c3ee26113f4e66c726aa04b", "parents": ["600f9bc042665de144ee6f3c0f24b5f2ccfcf6a5"], "tags": []}, {"author": "Glenn Watson \u003cgithub@intuitionlibrary.com\u003e", "branch": "default", "desc": "Bug 1566901 - Make picture caching more robust to float issues. r=kvark,nical a=RyanVM\n\nThis patch fixes a couple of picture caching issues that could\ncause more invalidations than required. Specifically:\n\n* Ensure the viewport rect is included in child surfaces, so\n  that redundant clips are filtered out correctly.\n* Use epsilon comparisons where appropriate for tile descriptor\n  comparisons, to avoid invalidations due to float inaccuracies.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38455", "files": ["gfx/wr/webrender/src/clip.rs", "gfx/wr/webrender/src/picture.rs", "gfx/wr/webrender/src/prim_store/mod.rs", "testing/web-platform/meta/css/motion/offset-rotate-005.html.ini"], "git_node": null, "git_parents": [null], "node": "79459ea654f59e741de12f491d62e0e9b003cc52", "parents": ["82898a5be493059e7c3ee26113f4e66c726aa04b"], "tags": []}, {"author": "Glenn Watson \u003cgithub@intuitionlibrary.com\u003e", "branch": "default", "desc": "Bug 1567472 - Fix bug in preserve-3d batching code in WebRender. r=nical a=RyanVM\n\nThe code to batch preserve-3d elements was incorrectly using the\nbounds and visibility mask from the parent element. This could\nresult in batching bugs in some cases, which were showing up as\ndraw order issues.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38834", "files": ["gfx/wr/webrender/src/batch.rs", "gfx/wr/wrench/reftests/split/order-3-ref.yaml", "gfx/wr/wrench/reftests/split/order-3.yaml", "gfx/wr/wrench/reftests/split/reftest.list"], "git_node": null, "git_parents": [null], "node": "1d05fe8447ed78f49ca0f31c7b322b1ebb11d45f", "parents": ["79459ea654f59e741de12f491d62e0e9b003cc52"], "tags": []}, {"author": "sotaro \u003csotaro.ikeda.g@gmail.com\u003e", "branch": "default", "desc": "Bug 1568136 - Call gfxUtils::RemoveShaderCacheFromDiskIfNecessary() in gfxPlatform::InitWebRenderConfig() r=nical a=RyanVM\n\nThe RemoveShaderCacheFromDiskIfNecessary() needs to be called after WebRenderConfig initialization.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38978", "files": ["gfx/thebes/gfxPlatform.cpp"], "git_node": null, "git_parents": [null], "node": "53bb71da50e59d953cdcd68a29c5afabd160abfc", "parents": ["1d05fe8447ed78f49ca0f31c7b322b1ebb11d45f"], "tags": ["DEVEDITION_69_0b8_BUILD1", "DEVEDITION_69_0b8_RELEASE", "FIREFOX_69_0b8_BUILD1", "FIREFOX_69_0b8_RELEASE"]}], "date": 1564076786, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "11636": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 53bb71da50e59d953cdcd68a29c5afabd160abfc with DEVEDITION_69_0b8_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "0b680f90e44b5c9c1637f67bd0a9c9e98c48d24a", "parents": ["53bb71da50e59d953cdcd68a29c5afabd160abfc"], "tags": []}], "date": 1564087837, "git_changesets": [null], "user": "ffxbld"}, "11637": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 53bb71da50e59d953cdcd68a29c5afabd160abfc with FIREFOX_69_0b8_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "83a50b2026343e4801935708d73e718234d9f8ca", "parents": ["0b680f90e44b5c9c1637f67bd0a9c9e98c48d24a"], "tags": []}], "date": 1564088200, "git_changesets": [null], "user": "ffxbld"}, "11638": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 53bb71da50e59d953cdcd68a29c5afabd160abfc with DEVEDITION_69_0b8_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "9ae4c9566c413d709a8e8572ab69a211507c8d5