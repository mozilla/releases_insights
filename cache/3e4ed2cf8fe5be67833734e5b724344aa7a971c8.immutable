 "cc3b977576b9cae6526a0cf774aaac371ec0747e", "parents": ["730a6412e76c6eca2715444d589465af6fe36559"], "tags": []}], "date": 1563297238, "git_changesets": [null], "user": "ffxbld"}, "11591": {"changesets": [{"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "THUNDERBIRD_68_VERBRANCH", "desc": "Bug 1563529 - Make HTML inputs inherit font in global.css. r=dao a=jorgk DONTBUILD\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36933", "files": ["toolkit/themes/shared/global.inc.css"], "git_node": null, "git_parents": [null], "node": "e3099f60b0774651728a6f9a142b6896327b8bd2", "parents": ["f0c0729a02198b423b995f2873adac7cb0b96435"], "tags": []}], "date": 1563303410, "git_changesets": [null], "user": "mozilla@jorgk.com"}, "11592": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\ngn -\u003e 76775425d0d3\nit -\u003e 3f02ad641afd\nkab -\u003e 04aae0535639\nnn-NO -\u003e 51018987a282\nsr -\u003e bc638c7ea351\ntr -\u003e 41031eafa3c1\ntrs -\u003e 10ce570995eb", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "763af77e0a398f8d64e71108ef084ba1a1c62a44", "parents": ["cc3b977576b9cae6526a0cf774aaac371ec0747e"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\ngn -\u003e 76775425d0d3\nit -\u003e 3f02ad641afd\nkab -\u003e 04aae0535639\nnn-NO -\u003e 51018987a282\nsr -\u003e bc638c7ea351\ntr -\u003e 41031eafa3c1", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "4308a30c46a0fccd3630771dd38148053291c665", "parents": ["763af77e0a398f8d64e71108ef084ba1a1c62a44"], "tags": []}], "date": 1563346832, "git_changesets": [null, null], "user": "ffxbld"}, "11593": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nen-CA -\u003e 8b6e7bf5bec0\nhr -\u003e db67ed6f0c4e\nhu -\u003e 440b6da4ca6d\nsl -\u003e 111c12a93f34\nzh-TW -\u003e 1f96ffca86a3", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "446c6880c6fb618dbb125dbaa202688c7c93677f", "parents": ["4308a30c46a0fccd3630771dd38148053291c665"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nen-CA -\u003e 8b6e7bf5bec0\nhr -\u003e db67ed6f0c4e\nhu -\u003e 440b6da4ca6d\nsl -\u003e 111c12a93f34\nzh-TW -\u003e 1f96ffca86a3", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "ce5894238261c312a833fa3734acebf4c038b6e6", "parents": ["446c6880c6fb618dbb125dbaa202688c7c93677f"], "tags": []}], "date": 1563361231, "git_changesets": [null, null], "user": "ffxbld"}, "11594": {"changesets": [{"author": "Haik Aftandilian \u003chaftandilian@mozilla.com\u003e", "branch": "default", "desc": "Bug 1556846 - [10.15] Crash in [@ mozilla::plugins::PluginUtilsOSX::SetProcessName] r=spohl a=RyanVM\n\nAllow limited access to the proc_pidinfo() syscall from the Mac utility process sandbox.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37533", "files": ["security/sandbox/mac/SandboxPolicyUtility.h"], "git_node": null, "git_parents": [null], "node": "6ab5b8214d16cf568c9f0f90e31d86ba9920ed04", "parents": ["ce5894238261c312a833fa3734acebf4c038b6e6"], "tags": []}, {"author": "Jan Odvarko \u003codvarko@gmail.com\u003e", "branch": "default", "desc": "Bug 1566019 - Fix URL column sorting + test r=nchevobbe a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38065", "files": ["devtools/client/netmonitor/src/selectors/requests.js", "devtools/client/netmonitor/src/utils/sort-predicates.js", "devtools/client/netmonitor/test/browser_net_sort-02.js"], "git_node": null, "git_parents": [null], "node": "06a0ccc9f3745c71283a3d87d7dc6ca0dbd48392", "parents": ["6ab5b8214d16cf568c9f0f90e31d86ba9920ed04"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe.birchill@mozilla.com\u003e", "branch": "default", "desc": "Bug 1564021 - Use the default desktop width (980px) in the case where we have any viewport meta element but no valid content there. r=botond a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37329", "files": ["dom/base/Document.cpp", "dom/base/Document.h", "layout/reftests/meta-viewport/invalid-content.html", "layout/reftests/meta-viewport/reftest.list", "layout/reftests/meta-viewport/width-980-ref.html"], "git_node": null, "git_parents": [null], "node": "c5a662c74c0bd730ffd033bf151f0568c3a31384", "parents": ["06a0ccc9f3745c71283a3d87d7dc6ca0dbd48392"], "tags": []}, {"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1563918 - Avoid spamming native message loop with WM_NCMOUSELEAVE messages. r=jmathies a=RyanVM\n\nIn bug 1551961, a WM_NCMOUSELEAVE message handler was added to the Windows widget\nbackend so that we can detect when the mouse leaves a draggable region (since\ndraggable regions are hittest'ed as HTCAPTION, and are therefore \"non-client\").\n\nInside that message handler, we used the WindowAtMouse handler to determine whether\nor not the WM_NCMOUSELEAVE was firing because the mouse was moving off of the\nnon-client area to client area, or moving out of the window entirely.\n\nFor reasons that are not particularly clear, on Windows Aero Glass, when clicking on\none of the min/max/close caption buttons, a WM_NCMOUSELEAVE message fires, and the\n::WindowFromPoint call that WindowAtMouse uses causes another WM_NCMOUSELEAVE message\nto be queued immediately after, so we end up in this situation where the message\nloop is getting spammed by WM_NCMOUSELEAVE messages. Moving the mouse away from\nthe caption buttons seems to stop the spamming.\n\nWe have a function similar to WindowAtMouse called EventIsInsideWindow which\ndoes not use ::WindowFromPoint, and this seems to sidestep the issue, while\nbeing functionally equivalent.\n\nDepends on D37421\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37422", "files": ["widget/windows/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "d81eefb325ca966df9a7a2c412cfc974f810cd1b", "parents": ["c5a662c74c0bd730ffd033bf151f0568c3a31384"], "tags": []}, {"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1563812 - Quantumbar: Fix keyboard navigation after stale results have been removed. r=dao a=RyanVM\n\nWe need to update indices after removing stale rows.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37142", "files": ["browser/components/urlbar/UrlbarView.jsm", "browser/components/urlbar/tests/browser/browser_selectStaleResults.js"], "git_node": null, "git_parents": [null], "node": "831b736de685497be79821571eea10722b0a1f26", "parents": ["d81eefb325ca966df9a7a2c412cfc974f810cd1b"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1528180 - Don't align scroll offsets to layer pixels when using WebRender. r=tnikkel a=RyanVM\n\nThis position is only invalidated from FrameLayerBuilder, that's not a very good\nsignal.\n\nThis would get out of sync when using WebRender, and APZ messages will send\nsub-pixel scroll positions that will get wrongly adjusted, causing small scroll\noffsets which scroll anchoring would incorrectly try to correct, which is the\nultimate cause of the jittering.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37875", "files": ["layout/generic/nsGfxScrollFrame.cpp"], "git_node": null, "git_parents": [null], "node": "a60290b9de2c0d51d4622e55c9b33319ee5fdd8e", "parents": ["831b736de685497be79821571eea10722b0a1f26"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1563508 - part 1: Make window_composition_text_querycontent.xul use `let` in functions instead of `var` r=m_kato a=RyanVM\n\nFor making the scope of variants clearer, make it use `let` instead of `var`.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37057", "files": ["widget/tests/window_composition_text_querycontent.xul"], "git_node": null, "git_parents": [null], "node": "63472899c1b1c0413603a1c010d543f0762023fe", "parents": ["a60290b9de2c0d51d4622e55c9b33319ee5fdd8e"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1563508 - part 2: Make `runIMEContentObserverTest()` async r=m_kato a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37058", "files": ["widget/tests/window_composition_text_querycontent.xul"], "git_node": null, "git_parents": [null], "node": "c10e8a001a98217bb03a6eb0784cd68f298cced2", "parents": ["63472899c1b1c0413603a1c010d543f0762023fe"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1563508 - part 3: Make `runEditorReframeTests()` async r=m_kato a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37059", "files": ["widget/tests/window_composition_text_querycontent.xul"], "git_node": null, "git_parents": [null], "node": "93c68c624bd57a89a5f17da327cb118e6c0c77bd", "parents": ["c10e8a001a98217bb03a6eb0784cd68f298cced2"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1563508 - part 4: Make `runAsyncForceCommitTest()` async r=m_kato a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37060", "files": ["widget/tests/window_composition_text_querycontent.xul"], "git_node": null, "git_parents": [null], "node": "e8a0379f87fd215547b708f0baf78064d39bb406", "parents": ["93c68c624bd57a89a5f17da327cb118e6c0c77bd"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1563508 - part 5: Make `runRemoveContentTest()` async and fix an editor's bug which found by the test order change r=m_kato a=RyanVM\n\nPreviously, `runRemoveContentTest()` was the last test which synthesizes\ncomposition in the `\u003ctextarea\u003e`.  However, new test order move it to middle\nof the other tests.  Then, it hits an `MOZ_ASSERT()` in\n`TextComposition::EditorWillHandleCompositionChangeEvent()` that detects a\nbug.  When editable element is removed from the DOM tree during a composition,\neditor cannot listen to `eCompositionEnd` event.  Therefore, when the editor\ngets back, it still has destroyed `TextComposition` and keeps handling new\ncomposition with the old one.  Therefore this patch makes\n`EditorBase::InstallEventListeners()` forget the destroyed composition.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37061", "files": ["editor/libeditor/EditorBase.cpp", "widget/tests/window_composition_text_querycontent.xul"], "git_node": null, "git_parents": [null], "node": "255e9fcc1f56d9728a41f6909392e07499dc1d34", "parents": ["e8a0379f87fd215547b708f0baf78064d39bb406"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1563508 - part 6: Make `runPanelTest()` async r=m_kato a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37062", "files": ["widget/tests/window_composition_text_querycontent.xul"], "git_node": null, "git_parents": [null], "node": "d6e09426a5f8c8070db1fb5c005b3530d86eaca7", "parents": ["255e9fcc1f56d9728a41f6909392e07499dc1d34"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1563508 - part 7: Remove unnecessary code from window_composition_text_querycontent.xul r=m_kato a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37063", "files": ["widget/tests/window_composition_text_querycontent.xul"], "git_node": null, "git_parents": [null], "node": "922cbc9dc3c0698b0416bb7de83056cfb9f8dea5", "parents": ["d6e09426a5f8c8070db1fb5c005b3530d86eaca7"], "tags": []}], "date": 1563364903, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "malexandru@mozilla.com"}, "11595": {"changesets": [{"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1564330: Update tzdata in ICU data files to 2019b. r=jwalden! a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com//D37543", "files": ["config/external/icu/data/icudt64l.dat", "intl/tzdata/GIT-INFO", "intl/tzdata/VERSION", "intl/tzdata/source/be/zoneinfo64.res", "intl/tzdata/source/ee/zoneinfo64.res", "intl/tzdata/source/le/zoneinfo64.res", "intl/tzdata/source/zoneinfo64.txt", "js/src/builtin/intl/TimeZoneDataGenerated.h", "js/src/tests/non262/Intl/DateTimeFormat/timeZone_backward_links.js", "js/src/tests/non262/Intl/DateTimeFormat/timeZone_backzone.js", "js/src/tests/non262/Intl/DateTimeFormat/timeZone_backzone_links.js", "js/src/tests/non262/Intl/DateTimeFormat/timeZone_notbackward_links.js"], "git_node": null, "git_parents": [null], "node": "b3925e68f5ebe93f3d23e25c163df973fcb4738b", "parents": ["922cbc9dc3c0698b0416bb7de83056cfb9f8dea5"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1565414 - update audit functionality to include warnings and best practices results. r=mtigley a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37817", "files": ["devtools/server/actors/accessibility/walker.js"], "git_node": null, "git_parents": [null], "node": "33e3b3f1fca8963b88db56f4177b73214bc69536", "parents": ["b3925e68f