default", "desc": "Bug 1561844 Remove OpenH264 plugin from about:addons r=VladBaicu a=RyanVM\n\nRemoved OpenH264 plugin from addons list for users that doesn't have it installed.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37237", "files": ["mobile/android/chrome/content/browser.js"], "git_node": null, "git_parents": [null], "node": "67b5cc66a182b7e8e0ab458ccb832e8d1ded0c8d", "parents": ["65ccf4163c2615a8d6340ac9a26d9f00900c78ea"], "tags": []}, {"author": "Byron Campen [:bwc] \u003cdocfaraday@gmail.com\u003e", "branch": "default", "desc": "Bug 1562341: Set mNegotiatedIdLimit when the channel opens, and remove some code that was stomping our initially chosen max streams. r=mjf a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36517", "files": ["netwerk/sctp/datachannel/DataChannel.cpp"], "git_node": null, "git_parents": [null], "node": "e699e0db71f7b4d17c55f298f7a268ac5d6592ab", "parents": ["67b5cc66a182b7e8e0ab458ccb832e8d1ded0c8d"], "tags": []}], "date": 1563201143, "git_changesets": [null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "11581": {"changesets": [{"author": "Jan Andre Ikenmeyer \u003cjan@ikenmeyer.eu\u003e", "branch": "default", "desc": "Bug 1563854 - Restrict Nvidia blocklist entry to the proprietary driver. r=aosmond a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37672", "files": ["widget/GfxInfoX11.cpp"], "git_node": null, "git_parents": [null], "node": "d21fde52d0b0574ddd6025909e0d69ae93360a9d", "parents": ["e699e0db71f7b4d17c55f298f7a268ac5d6592ab"], "tags": []}, {"author": "Jeff Gilbert \u003cjgilbert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1443181 - If ANGLE D3D11 disabled, ask for D3D9 explicitly. r=lsalzman a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37351", "files": ["gfx/gl/GLLibraryEGL.cpp"], "git_node": null, "git_parents": [null], "node": "3259bd8480591d3f404b904f30520c1cddf5d9c5", "parents": ["d21fde52d0b0574ddd6025909e0d69ae93360a9d"], "tags": []}, {"author": "Florens Verschelde \u003cflorens@fvsch.com\u003e", "branch": "default", "desc": "Bug 1564267 - Fix console line-height for large text; r=nchevobbe a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37367", "files": ["devtools/client/themes/webconsole.css"], "git_node": null, "git_parents": [null], "node": "4583a66c4d516e6687e30e72bef44e9248f1415c", "parents": ["3259bd8480591d3f404b904f30520c1cddf5d9c5"], "tags": []}, {"author": "harry \u003chtwyford@mozilla.com\u003e", "branch": "default", "desc": "Bug 1562145 - Fix mouse-dragging regression caused by patch to 1554864. r=dao a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36329", "files": ["browser/base/content/test/general/browser_bug1261299.js", "browser/components/urlbar/UrlbarInput.jsm"], "git_node": null, "git_parents": [null], "node": "dc0af2195c1f7d77b0b8a7d40203693ed9a4b562", "parents": ["4583a66c4d516e6687e30e72bef44e9248f1415c"], "tags": []}, {"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1557710 - Fire eMouseExitFromWidget when transitioning from a draggable to a non-draggable non-client region on Windows. r=jmathies a=RyanVM\n\nWe need to do this in order to not override the mouse cursor that we set in the\nwidget layer when hit-testing in the non-client region.\n\nWe were accidentally overriding before because the PresShell normally queues up a\nsynthetic mousemove event when the mouse is moving within the client region. That\nmousemove cause the EventStateManager to update the cursor to match Gecko's\nreckoning of the cursor CSS style of the underlying frame (which overrides the\ncursor we may have set in the Windows non-client region hittest - for example,\none of the window resize cursors).\n\nBy clearing the mMouseInDraggableArea boolean when transitioning from a draggable\nto non-draggable region in the non-client region, we make sure that we process the\nWM_MOUSELEAVE message, which sends the eMouseExitFromWidget event into Gecko, which\neffectively cancels handling of the synthetic mousemove.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37421", "files": ["widget/windows/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "3c3a566d83352b78c08d70cb3e0c379eaed6e853", "parents": ["dc0af2195c1f7d77b0b8a7d40203693ed9a4b562"], "tags": []}, {"author": "Oriol Brufau \u003coriol-bugzilla@hotmail.com\u003e", "branch": "default", "desc": "Bug 1558823 - Show generic icon for extensions without icon. r=mstriemer,mixedpuppy a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36730", "files": ["toolkit/mozapps/extensions/content/aboutaddons.js", "toolkit/mozapps/extensions/test/browser/browser_html_list_view.js"], "git_node": null, "git_parents": [null], "node": "01431d1df2e8906a414ea5249b24ca4acc7e3f5f", "parents": ["3c3a566d83352b78c08d70cb3e0c379eaed6e853"], "tags": []}], "date": 1563202750, "git_changesets": [null, null, null, null, null, null], "user": "rmaries@mozilla.com"}, "11582": {"changesets": [{"author": "Jeff Muizelaar \u003cjrmuizel@gmail.com\u003e", "branch": "default", "desc": "Bug 1564907. Add AMD Navi GPUs to WebRender qualified device list. r=aosmond a=RyanVM\n", "files": ["gfx/thebes/gfxPlatform.cpp"], "git_node": null, "git_parents": [null], "node": "1d8031f29e6767da7bc39d5fabc6f209cb3b3e83", "parents": ["01431d1df2e8906a414ea5249b24ca4acc7e3f5f"], "tags": []}], "date": 1563204171, "git_changesets": [null], "user": "kgupta@mozilla.com"}, "11583": {"changesets": [{"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1563997: Handle webcompat Components stub in MozillaFileLogger.js. r=nika a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37938", "files": ["testing/mochitest/tests/SimpleTest/MozillaLogger.js"], "git_node": null, "git_parents": [null], "node": "e0a81e0687285f20853b5a5494d0c34ae5acdf1b", "parents": ["1d8031f29e6767da7bc39d5fabc6f209cb3b3e83"], "tags": []}], "date": 1563211693, "git_changesets": [null], "user": "maglione.k@gmail.com"}, "11584": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP blocklist remote-settings - a=repo-update r=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38064", "files": ["browser/app/blocklist.xml", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/blocklists/addons.json"], "git_node": null, "git_parents": [null], "node": "52bda0b5d793e760fa60fec8b9a2112447a99adb", "parents": ["e0a81e0687285f20853b5a5494d0c34ae5acdf1b"], "tags": []}, {"author": "Vijay Budhram \u003cvbudhram@mozilla.com\u003e", "branch": "default", "desc": "Bug 1564877 - Fix fxa avatar not clearing on sign out. r=eoger, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37571", "files": ["browser/base/content/browser-sync.js"], "git_node": null, "git_parents": [null], "node": "0c8aee9afd1cea471b474c80510cfc2aa2f4aed9", "parents": ["52bda0b5d793e760fa60fec8b9a2112447a99adb"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1563039 - Fix erroneous base domain highlighting. r=VladBaicu, a=RyanVM\n\nDomain highlighting needs to find the *last* instance of the base domain within\nthe domain part of the URL. Otherwise, there's a chance we mistakenly highlight\n(parts of) a subdomain if it matches the base domain, too.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37311", "files": ["mobile/android/base/java/org/mozilla/gecko/toolbar/ToolbarDisplayLayout.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/util/StringUtils.java"], "git_node": null, "git_parents": [null], "node": "20015237f3bf35daa3265a18bb8c7a3a