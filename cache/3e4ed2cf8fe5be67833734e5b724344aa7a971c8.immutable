f/init/StaticPrefList.h"], "git_node": null, "git_parents": [null], "node": "3780202d7104307ec4c5f4a1dde788e5123c47ac", "parents": ["adc59d50adf815ad6764ff235f833a5ba74291b6"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1562331 - Make webgl.* static prefs follow the naming convention. r=KrisWright\n\nAlso converts webgl.pref-16bpp from a VarCache pref to a normal pref, because\nit doesn't need to be a VarCache pref.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36397", "files": ["dom/canvas/WebGL2ContextSync.cpp", "dom/canvas/WebGLContext.cpp", "dom/canvas/WebGLContextExtensions.cpp", "dom/canvas/WebGLContextValidate.cpp", "dom/canvas/WebGLExtensions.cpp", "dom/canvas/WebGLQuery.cpp", "dom/canvas/WebGLShaderValidator.cpp", "dom/canvas/WebGLTextureUpload.cpp", "gfx/gl/GLLibraryEGL.cpp", "gfx/gl/GLScreenBuffer.cpp", "gfx/gl/SharedSurfaceD3D11Interop.cpp", "gfx/src/DriverCrashGuard.cpp", "gfx/thebes/gfxPlatform.cpp", "modules/libpref/init/StaticPrefList.h"], "git_node": null, "git_parents": [null], "node": "98d86b9328ef5cf0454b98385f056020a4569f72", "parents": ["3780202d7104307ec4c5f4a1dde788e5123c47ac"], "tags": []}, {"author": "Oana Pop Rus \u003copoprus@mozilla.com\u003e", "branch": "default", "desc": "Merge autoland to mozilla-central. a=merge", "files": [], "git_node": null, "git_parents": [null, null], "node": "501f50ccafdfd30a6bc8d85f2be8704ca335d65f", "parents": ["7573050ba145afe5c0f9fcb28f5fead5e240cba9", "8b3c35badb46e9cf4adc823be50e1357eefd193d"], "tags": []}, {"author": "Oana Pop Rus \u003copoprus@mozilla.com\u003e", "branch": "default", "desc": "Merge inbound to mozilla-central.  a=merge", "files": [], "git_node": null, "git_parents": [null, null], "node": "b3eb1ee3b85dfb87789c92d417e20f377ebcfca3", "parents": ["501f50ccafdfd30a6bc8d85f2be8704ca335d65f", "98d86b9328ef5cf0454b98385f056020a4569f72"], "tags": []}, {"author": "Oana Pop Rus \u003copoprus@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland. a=merge CLOSED TREE", "files": ["dom/media/ipc/RemoteVideoDecoder.cpp", "gfx/gl/GLLibraryEGL.cpp"], "git_node": null, "git_parents": [null, null], "node": "11168f905222e9ea49de07fb73f1901e66e183e7", "parents": ["5e49abc7455e35ca25c08a0bd58693158fc0a6b7", "b3eb1ee3b85dfb87789c92d417e20f377ebcfca3"], "tags": []}, {"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, taskcluster/docker/funsize-update-generator pipfile-update. r=sfraser\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36462", "files": ["taskcluster/docker/funsize-update-generator/Pipfile.lock"], "git_node": null, "git_parents": [null], "node": "6c9e4b8eda9b456b68993376ff8fc83037cc2160", "parents": ["11168f905222e9ea49de07fb73f1901e66e183e7"], "tags": []}, {"author": "Simon Fraser \u003csfraser@mozilla.com\u003e", "branch": "default", "desc": "Bug 1559980 Remove python/safety from py3 linting r=Callek\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35242", "files": ["tools/lint/py3.yml"], "git_node": null, "git_parents": [null], "node": "340f71c8f1dc1d79a6c5976ada31151563f06244", "parents": ["6c9e4b8eda9b456b68993376ff8fc83037cc2160"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1561698 - Check the layers id in hit-testing mochitests as well. r=botond,hsivonen\n\nThis exposes the layers id on the APZ hit result testing API, and\nupdates callers to check the layers id is correct. This is mostly\nunnecessary for these tests, but introduces machinery that will be\nuseful in Fission-enabled tests, where iframes may be OOP and have\ndifferent layers ids.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36146", "files": ["dom/base/nsDOMWindowUtils.cpp", "dom/interfaces/base/nsIDOMWindowUtils.idl", "dom/webidl/APZTestData.webidl", "gfx/layers/apz/src/APZCTreeManager.cpp", "gfx/layers/apz/test/mochitest/apz_test_utils.js", "gfx/layers/apz/test/mochitest/helper_hittest_basic.html", "gfx/layers/apz/test/mochitest/helper_hittest_checkerboard.html", "gfx/layers/apz/test/mochitest/helper_hittest_clippath.html", "gfx/layers/apz/test/mochitest/helper_hittest_clipped_fixed_modal.html", "gfx/layers/apz/test/mochitest/helper_hittest_fixed_in_scrolled_transform.html", "gfx/layers/apz/test/mochitest/helper_hittest_float_bug1434846.html", "gfx/layers/apz/test/mochitest/helper_hittest_float_bug1443518.html", "gfx/layers/apz/test/mochitest/helper_hittest_nested_transforms_bug1459696.html", "gfx/layers/apz/test/mochitest/helper_hittest_pointerevents_svg.html", "gfx/layers/apz/test/mochitest/helper_hittest_sticky_bug1478304.html", "gfx/layers/apz/test/mochitest/helper_hittest_touchaction.html", "gfx/layers/apz/testutil/APZTestData.cpp", "gfx/layers/apz/testutil/APZTestData.h"], "git_node": null, "git_parents": [null], "node": "430451f5bf5d15c6ae158ddc66d72bce7c3bb1a5", "parents": ["340f71c8f1dc1d79a6c5976ada31151563f06244"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1560149 - Add some documentation for document splitting. r=dthayer\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36210", "files": ["gfx/docs/DocumentSplitting.rst", "gfx/docs/index.rst"], "git_node": null, "git_parents": [null], "node": "34b35632f194e4e711d74bce6415dddb34cebf42", "parents": ["430451f5bf5d15c6ae158ddc66d72bce7c3bb1a5"], "tags": []}, {"author": "dlee \u003cdlee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1553951 - Safe Browsing doesn't call the lookup callback when an error occurs in DoLocalLookup. r=baku\n\nFirefox cannot open any URL when Safe Browsing database is corrupted.\nThis is because when Necko asks URL Classifier to classify an URL, it\nfirst suspends the channel, and then wait for a callback to see if the\nchannel should be canceled or resumed.\n\nIn this bug, DoLocalLookup returns an error because Safe Browsing is not\nable to read its database(database is corrupted), but we don't call the\ncallback to resume loading channel, so users cannot load any website.\n\nThis patch adds a scope exit handler to make sure the callback will\nalways be invoked.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36456", "files": ["toolkit/components/url-classifier/nsUrlClassifierDBService.cpp"], "git_node": null, "git_parents": [null], "node": "b308a5b128aa3a34277476fd3237083f5a21e5c2", "parents": ["34b35632f194e4e711d74bce6415dddb34cebf42"], "tags": []}, {"author": "shindli \u003cshindli@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 34b35632f194 (bug 1560149) for linting failure in /builds/worker/checkouts/gecko/gfx/docs/DocumentSplitting.rst:162 CLOSED TREE", "files": ["gfx/docs/DocumentSplitting.rst", "gfx/docs/index.rst"], "git_node": null, "git_parents": [null], "node": "ca0726ea50cb5e8b02e758b2db7161e472779553", "parents": ["b308a5b128aa3a34277476fd3237083f5a21e5c2"], "tags": []}, {"author": "shindli \u003cshindli@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset b308a5b128aa (bug 1553951) for causing bustages in builds/worker/workspace/build/src/toolkit/components/url-classifier/nsUrlClassifierDBService.cpp CLOSED TREE", "files": ["toolkit/components/url-classifier/nsUrlClassifierDBService.cpp"], "git_node": null, "git_parents": [null], "node": "88c43064571c77ef47d09e14853a8f3d28819860", "parents": ["ca0726ea50cb5e8b02e758b2db7161e472779553"], "tags": []}, {"author": "Benjamin Bouvier \u003cbenj@benj.me\u003e", "branch": "default", "desc": "Bug 1559099: Bump Cranelift in Spidermonkey to e455f6ae; r=lth\n\nChanges have been reviewed on the Cranelift side; this is just a bump to the\nlatest version.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36327", "files": [".cargo/config.in", "Cargo.lock", "Cargo.toml", "third_party/rust/cranelift-bforest/.cargo-checksum.jso