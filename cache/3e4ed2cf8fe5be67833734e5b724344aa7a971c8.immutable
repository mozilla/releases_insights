 null, "git_parents": [null], "node": "62db9e3b8d6fd773c8b801638ed652dafe4a3ec5", "parents": ["ee83ffabc1095818f78aea985172fb660e0197f8"], "tags": []}, {"author": "Neil Deakin \u003cneil@mozilla.com\u003e", "branch": "default", "desc": "Bug 1567723 - Back out bug 1558919 so that zoom works on new tab page. r=Gijs, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41170", "files": ["toolkit/actors/ZoomChild.jsm", "toolkit/actors/ZoomParent.jsm", "toolkit/actors/moz.build", "toolkit/content/widgets/browser-custom-element.js", "toolkit/modules/ActorManagerParent.jsm"], "git_node": null, "git_parents": [null], "node": "5566b1724de945b950c71b32b64c75b78b58a6b6", "parents": ["62db9e3b8d6fd773c8b801638ed652dafe4a3ec5"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1571342 - unify save paths for console and netmonitor and fix the latter to not do docshell loads, r=Honza,nchevobbe, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41858", "files": ["devtools/client/netmonitor/src/har/har-exporter.js", "devtools/client/netmonitor/src/widgets/RequestListContextMenu.js", "devtools/client/shared/file-saver.js", "devtools/client/shared/moz.build", "devtools/client/webconsole/test/mochitest/browser_webconsole_context_menu_export_console_output.js", "devtools/client/webconsole/utils/context-menu.js", "devtools/shared/DevToolsUtils.js", "devtools/shared/tests/unit/test_console_save-file.js", "devtools/shared/tests/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "a969e02f8c9c0a46a4c25efcc05eadaf62c5a89e", "parents": ["5566b1724de945b950c71b32b64c75b78b58a6b6"], "tags": []}, {"author": "dlee \u003cdlee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1574450 - Close inputstream before reseting HashStore file. r=gcp, a=RyanVM\n\nmInputStream holds a reference to the current opened HashStore file.\nWhile resetting the file, mInputStream should be closed first, otherwise,\nthe file-\u003eRemove returns failure code NS_ERROR_FILE_IS_LOCKED.\n(This only happens in Windows platform)\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42460", "files": ["toolkit/components/url-classifier/HashStore.cpp"], "git_node": null, "git_parents": [null], "node": "9b2474ad94517039fcc1c23732c829c13b1e5d62", "parents": ["a969e02f8c9c0a46a4c25efcc05eadaf62c5a89e"], "tags": []}, {"author": "Shane Caraveo \u003cscaraveo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1513855 ensure we notify quit application when running silent r=kmag, a=RyanVM\n\nRunning with -silent does not result in the quit application granted notification.\nWithout that notification, we have a deadlock in EnvironmentAddonBuilder where it blocks\nbeforeShutdown waiting on the XPIDatabase to load.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41877", "files": ["browser/components/BrowserContentHandler.jsm"], "git_node": null, "git_parents": [null], "node": "66a12ddcf77c6a1548989ced39edf39af78deb80", "parents": ["9b2474ad94517039fcc1c23732c829c13b1e5d62"], "tags": ["DEVEDITION_69_0b15_BUILD1", "DEVEDITION_69_0b15_RELEASE", "FIREFOX_69_0b15_BUILD1", "FIREFOX_69_0b15_RELEASE"]}], "date": 1566240144, "git_changesets": [null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "11813": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 66a12ddcf77c6a1548989ced39edf39af78deb80 with DEVEDITION_69_0b15_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "36859908a40c0aa2f6f8115f203e810180a60cbe", "parents": ["66a12ddcf77c6a1548989ced39edf39af78deb80"], "tags": []}], "date": 1566247831, "git_changesets": [null], "user": "ffxbld"}, "11814": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "b