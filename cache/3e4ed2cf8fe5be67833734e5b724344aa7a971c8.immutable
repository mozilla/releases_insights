rvices.mozilla.com/D36411", "files": ["dom/base/DOMMatrix.cpp", "dom/base/DOMMatrix.h", "dom/webidl/DOMMatrix.webidl", "testing/web-platform/meta/css/geometry/DOMMatrix-003.html.ini", "testing/web-platform/meta/css/geometry/DOMMatrix-newobject.html.ini", "testing/web-platform/meta/css/geometry/historical.html.ini", "testing/web-platform/meta/css/geometry/interfaces.html.ini", "testing/web-platform/meta/css/geometry/interfaces.worker.js.ini", "testing/web-platform/tests/css/geometry/DOMMatrix-003.html"], "git_node": null, "git_parents": [null], "node": "bb9f7df3f7365a5d5cf334807f352c1ee0272c2a", "parents": ["8b4565507d192210e95fa7d91a05ce1106ffbeb0"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1561153 - Fix problems with box-drawing chars in about:memory. r=jfkthame\n\nIn Japanese (and Chinese?) locales the box-drawing chars may be twice the width\nof ASCII chars, which messes up about:memory's layout. By explicitly specifying\nthe language and font-family, we increase the chance that single-width\nbox-drawing chars are used.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36287", "files": ["toolkit/components/aboutmemory/content/aboutMemory.css", "toolkit/components/aboutmemory/content/aboutMemory.xhtml", "toolkit/themes/mobile/global/aboutMemory.css"], "git_node": null, "git_parents": [null], "node": "6d855f154cd753312fcd5ed233de5dee5ab9fba6", "parents": ["bb9f7df3f7365a5d5cf334807f352c1ee0272c2a"], "tags": []}, {"author": "Coroiu Cristina \u003cccoroiu@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 65f2110d9bb9 (bug 1560495) for wpt failures at navigation-timing/nav2_test_unloadEvents_with_cross_origin_redirect_opt_in.html", "files": ["dom/performance/PerformanceNavigationTiming.cpp", "testing/web-platform/meta/navigation-timing/nav2_test_unloadEvents_with_cross_origin_redirect_chain_partial_opt_in.html.ini"], "git_node": null, "git_parents": [null