.mozilla.com/D38561", "files": ["layout/style/FontFaceSet.cpp"], "git_node": null, "git_parents": [null], "node": "5eb5970cd31d09e3f30b28c742e2ebcb5c6f592c", "parents": ["cfcd67d313d27a797bb447ad23949deddc579955"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1565489 - Part 1: Avoid null dereference in IsProcessRoot, a=RyanVM\n\nThe crash appears to be being caused by the GetEmbedderWindowGlobal call\nreturning a null value. This patch simply avoids the crash in this case, and\nreturns a reasonable default value of false, as it should never be true for a\nBrowsingContext with a parent without Fission enabled.\n\nThis patch should be small enough to safely uplift if necessary.\n\nDifferential Revision: https://phabricator.services.mozilla.com//D38722", "files": ["dom/ipc/WindowGlobalParent.cpp"], "git_node": null, "git_parents": [null], "node": "9843506318f9f82a851384f28cc9d3658735e927", "parents": ["5eb5970cd31d09e3f30b28c742e2ebcb5c6f592c"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1557256 - handle scrollwheel zoom in reader mode, r=jaws a=RyanVM", "files": ["browser/base/content/browser-fullZoom.js", "toolkit/components/reader/AboutReader.jsm"], "git_node": null, "git_parents": [null], "node": "de26254af9920d922666b1f76ab8240db13c6695", "parents": ["9843506318f9f82a851384f28cc9d3658735e927"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1557960 - cope with 0 values in Chrome's date/time columns when importing, r=mak a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com//D37810", "files": ["browser/components/migration/ChromeMigrationUtils.jsm", "browser/components/migration/ChromeProfileMigrator.jsm", "browser/components/migration/tests/unit/test_Chrome_history.js"], "git_node": null, "git_parents": [null], "node": "8fc282145f2eac7067e60a2827f46a57636fa08d", "parents": ["de26254af9920d922666b1f76ab8240db13c6695"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1564542: Add a dummy implementation of Bounds() on DocProxyAccessibleWrap/RemoteIframeDocProxyAccessibleWrap to prevent crashes when hit testing via XPCOM. a=RyanVM\n\nOuterDocAccessible can return a DocProxyAccessibleWrap or RemoteIframeDocProxyAccessibleWrap as a child.\nAccessible::ChildAtPoint on an ancestor might retrieve this proxy and call Bounds() on it.\nThis will crash on a proxy, so we override it on these document proxies to do nothing.\n\nDifferential Revision: https://phabricator.services.mozilla.com//D38256", "files": ["accessible/windows/ProxyWrappers.h"], "git_node": null, "git_parents": [null], "node": "524bbb009aa8b0956b0790b915d88ffda43fc6f3", "parents": ["8fc282145f2eac7067e60a2827f46a57636fa08d"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1566299: Update XULListBoxAccessible now that autocomplete-richlistbox-popup is a Custom Element. r=surkov a=RyanVM\n\nIn bug 1525101, autocomplete-richlistbox-popup was converted to a Custom Element.\nThis means we can no longer use do_QueryInterface to get nsIAutoCompletePopup.\nInstead, we must use Element::AsAutoCompletePopup.\nThis fixes accessibility focus for these autocompletes.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38158", "files": ["accessible/xul/XULListboxAccessible.cpp"], "git_node": null, "git_parents": [null], "node": "07d0601ce1716b9f1d425a9d1b469eddd5410165", "parents": ["524bbb009aa8b0956b0790b915d88ffda43fc6f3"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1480031 - Truncate floating menu labels if they overflow screen width; r=VladBaicu a=RyanVM\n\nThere's currently a bug in Android's framework that manifests by placing the\nfloating menu off-screen if a menu label overflows the menu's width.\nhttps://issuetracker.google.com/issues/137169336\nTo overcome this we'll manually check and truncate any menu label that could\ncause issues based on the floating menu style declared upstream.\n\nDifferential Revision: https://phabricator.services.mozilla.com//D37684", "files": ["mobile/android/app/src/main/res/values/dimens.xml", "mobile/android/base/java/org/mozilla/gecko/text/FloatingActionModeCallback.java", "mobile/android/base/java/org/mozilla/gecko/util/WindowUtils.java"], "git_node": null, "git_parents": [null], "node": "43030692b97baac6e41b94f3a59829209fdd3aaa", "parents": ["07d0601ce1716b9f1d425a9d1b469eddd5410165"], "tags": []}, {"author": "Honza Bambas \u003chonzab.moz@firemni.cz\u003e", "branch": "default", "desc": "Bug 1566884 - Do not replace \"direct\" proxy info result from proxy.onRequest with a null default proxy info, r=mixedpuppy a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com//D38364", "files": ["toolkit/components/extensions/ProxyScriptContext.jsm", "toolkit/components/extensions/test/xpcshell/test_proxy_listener.js"], "git_node": null, "git_parents": [null], "node": "50dcd65bee401205c50299cbe6fa5cc8dc67a5fa", "parents": ["43030692b97baac6e41b94f3a59829209fdd3aaa"], "tags": []}], "date": 1563824705, "git_changesets": [null, null, null, null, null, null, null, null], "user": "rmaries@mozilla.com"}, "11621": {"changesets": [{"author": "Will Hawkins \u003cwhawkins@mozilla.com\u003e", "branch": "default", "desc": "Bug 1560495: Update unload event security information for Navigation-Timing Level 2 specification. r=baku a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36293", "files": ["dom/performance/PerformanceNavigationTiming.cpp", "testing/web-platform/meta/navigation-timing/nav2_test_redirect_xserver_opt_in.html.ini", "testing/web-platform/meta/navigation-timing/nav2_test_unloadEvents_no_previous_document.html.ini", "testing/web-platform/meta/navigation-timing/nav2_test_unloadEvents_previous_document_cross_origin.sub.html.ini", "testing/web-platform/meta/navigation-timing/nav2_test_unloadEvents_with_cross_origin_redirect_chain_partial_opt_in.html.ini", "testing/web-platform/meta/navigation-timing/nav2_test_unloadEvents_with_cross_origin_redirect_opt_in.html.ini", "testing/web-platform/meta/navigation-timing/nav2_test_unloadEvents_with_cross_origin_redirects.html.ini", "testing/web-platform/meta/navigation-timing/nav2_test_unloadEvents_with_previous_document.html.ini"], "git_node": null, "git_parents": [null], "node": "6aa4c38274c43f00b98eeb974c7ee067dfc4e8e4", "parents": ["50dcd65bee401205c50299cbe6fa5cc8dc67a5fa"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1560178 - fix/remove about:addons tests that load discovery pane in the parent, r=aswan a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36308", "files": ["toolkit/mozapps/extensions/test/browser/browser_discovery.js", "toolkit/mozapps/extensions/test/browser/browser_webapi_access.js"], "git_node": null, "git_parents": [null], "node": "20dec11dae3c02b4a87c7a9809de38262f61752d", "parents": ["6aa4c38274c43f00b98eeb974c7ee067dfc4e8e4"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1560178 - adjust webextension tests that rely on loading untrusted URIs in the parent process when remote webextensions are turned off, r=aswan a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36309", "files": ["browser/components/extensions/test/browser/browser_ext_popup_api_injection.js", "browser/components/extensions/test/browser/browser_ext_webRequest.js", "toolkit/components/extensions/test/mochitest/test_ext_subframes_privileges.html", "toolkit/components/extensions/test/xpcshell/test_WebExtensionContentScript.js", "toolkit/components/extensions/test/xpcshell/test_ext_ipcBlob.js", "toolkit/components/extensions/test/xpcshell/test_ext_native_messaging.js"], "git_node": null, "git_parents": [null], "node": "823a920c31272d43d8790e9630f44391a4de4bcb", "parents": ["20dec11dae3c02b4a87c7a9809de38262f61752d"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1560178 - fix miscellaneous tests to allow them to keep working when disallowing remote content in the parent process, r=aswan,ckerschb a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36310", "files": ["browser/components/customizableui/test/browser_PanelMultiView_keyboard.js", "browser/components/places/tests/browser/browser_click_bookmarks_on_toolbar.js", "docshell/test/browser/browser_bug1206879.js", "dom/base/test/browser.ini", "dom/base/test/browser_bug593387.js", "dom/security/test/general/browser_test_assert_systemprincipal_documents.js", "dom/tests/browser/browser_xhr_sandbox.js", "toolkit/content/tests/browser/browser_findbar.js"], "git_node": null, "git_parents": [null], "node": "73297d7f6db9b7a060813dce751e9999aeb1d347", "parents": ["823a920c31272d43d8790e9630f44391a4de4bcb"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1560178 - fix devtools tests that load untrusted URIs in the parent, r=jdescottes a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36311", "files": ["devtools/client/aboutdebugging-new/test/browser/browser.ini", "devtools/client/aboutdebugging-new/test/browser/empty.html", "devtools/client/aboutdebugging-new/test/browser/mocks/helper-client-wrapper-mock.js", "devtools/client/framework/test/head.js", "devtools/client/inspector/extensions/test/browser_inspector_extension_sidebar.js", "devtools/client/jar.mn", "devtools/client/shared/test/browser_layoutHelpers.js", "devtools/client/shared/test/browser_outputparser.js", "devtools/client/shared/test/browser_treeWidget_basic.js", "devtools/client/shared/test/browser_treeWidget_keyboard_interaction.js", "devtools/client/shared/test/browser_treeWidget_mouse_interaction.js", "devtools/client/shared/test/head.js", "devtools/client/shared/webextension-fallback.html", "devtools/server/actors/targets/webextension.js"], "git_node": null, "git_parents": [null], "node": "a188fb7e00d9d6d25b08d93bfece15498ed1bef8", "parents": ["73297d7f6db9b7a060813dce751e9999aeb1d347"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1560178 - disallow unsafe loads in the parent, r=bzbarsky a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36312", "files": ["docshell/base/nsDocShell.cpp", "modules/libpref/init/StaticPrefList.h", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "d5c1f040691a4b986aa7fa03d9127c34b72c57d9", "parents": ["a188fb7e00d9d6d25b08d93bfece15498ed1bef8"], "tags": []}, {"author": "Cameron McCormack \u003ccam@mcc.id.au\u003e", "branch": "default", "desc": "Bug 1565965 - Allow unsafe loads in the Layout Debugger. r=bzbarsky a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38037", "files": ["docshell/base/moz.build", "docshell/base/nsDocShell.cpp"], "git_node": null, "git_parents": [null], "node": "cbf0daa7f713e2d86bb0bb8ea823dbc396bb8aba", "parents": ["d5c1f040691a4b986aa7fa03d9127c34b72c57d9"], "tags": []}, {"author": "Daisuke Akatsuka \u003cdakatsuka@mozilla.com\u003e", "branch": "default", "desc": "Bug 1521085: Return false if the property name is an invalid identifier. r=gl a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37219", "files": ["devtools/shared/fronts/css-properties.js"], "git_node": null, "git_parents": [null], "node": "650f8bb0184e7027916abebef499384673dfba9f", "parents": ["cbf0daa7f713e2d86bb0bb8ea823dbc396bb8aba"], "tags": []}, {"author": "Daisuke Akatsuka \u003cdakatsuka@mozilla.com\u003e", "branch": "default", "desc": "Bug 1521085: Add a test which add a property which is an invalid identifier. r=gl a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37220", "files": ["devtools/client/inspector/rules/test/browser.ini", "devtools/client/inspector/rules/test/browser_rules_add-property-invalid-identifier.js"], "git_node": null, "git_parents": [null], "node": "d9e38635ca03c29282078fa9b6cb388c4203f52d", "parents": ["650f8bb0184e7027916abebef499384673dfba9f"], "tags": []}, {"author": "Brad Arant \u003cbrad.arant@softvision.com\u003e", "branch": "default", "desc": "Bug 1268019 - Return default icon for download files that do not have intent for handling.;r=VladBaicu a=RyanVM\n\nDepends on D34386\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34387", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoAppShell.java", "mobile/android/geckoview/src/main/res/drawable/ic_generic_file.xml"], "git_node": null, "git_parents": [null], "node": "8d8802147a78b165439eb25dd66c49d26aab40e0", "parents": ["d9e38635ca03c29282078fa9b6cb388c4203f52d"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1556437 - Use VectorDrawableCompat to load the error svg; r=AndreiLazar a=RyanVM\n\nVectorDrawableCompat allows backwards compatibility up to API 14.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38185", "files": ["mobile/android/base/java/org/mozilla/gecko/FindInPageBar.java"], "git_node": null, "git_parents": [null], "node": "b0ad1f66125c316df95b46bede5856a59ea0d75c", "parents": ["8d8802147a78b165439eb25dd66c49d26aab40e0"], "tags": []}, {"author": "harry \u003chtwyford@mozilla.com\u003e", "branch": "default", "desc": "Bug 1566086 - Add error message if touchBarAction crash is encountered. r=spohl a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38116", "files": ["widget/cocoa/nsTouchBar.mm"], "git_node": null, "git_parents": [null], "node": "80b47b3c406e9e8bffb31d45c9e11bfb1547dfc3", "parents": ["b0ad1f66125c316df95b46bede5856a59ea0d75c"], "tags": []}, {"author": "Dana Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "bug 1564481 - reset HSTS/HPKP state to factory settings rather than storing knockout entries for preloaded sites r=jcj r=KevinJacobs a=RyanVM\n\nAs originally implemented, nsISiteSecurityService.removeState allowed direct\naccess to remove HSTS state. It also provided the implementation for when the\nbrowser encountered an HSTS header with \"max-age=0\". In bug 775370, it was\nupdated to store an entry that would override preloaded information when\nprocessing such headers. However, this meant that the semantics of the direct\naccess API had changed. Preloaded information could be overridden if a user\ninvoked the \"forget about this site\" feature. This change fixes the public API\n(and renames it to \"resetState\") so it actually behaves as its consumers expect.\n\nReviewers: jcj!, KevinJacobs!\n\nTags: #secure-revision\n\nBug #: 1564481\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38108", "files": ["browser/base/content/test/general/browser_blockHPKP.js", "browser/base/content/test/general/browser_star_hsts.js", "devtools/shared/webconsole/test/test_network_security-hpkp.html", "devtools/shared/webconsole/test/test_network_security-hsts.html", "security/manager/ssl/nsISiteSecurityService.idl", "security/manager/ssl/nsSiteSecurityService.cpp", "security/manager/ssl/nsSiteSecurityService.h", "security/manager/ssl/tests/mochitest/browser/browser_bug627234_perwindowpb.js", "security/manager/ssl/tests/unit/test_ocsp_must_staple.js", "security/manager/ssl/tests/unit/test_pinning_header_parsing.js", "security/manager/ssl/tests/unit/test_sss_originAttributes.js", "security/manager/ssl/tests/unit/test_sss_resetState.js", "security/manager/ssl/tests/unit/test_sts_fqdn.js", "security/manager/ssl/tests/unit/xpcshell.ini", "testing/specialpowers/content/SpecialPowersAPIParent.jsm", "toolkit/components/cleardata/ClearDataService.jsm"], "git_node": null, "git_parents": [null], "node": "fea8c86cd0d3c087575f393fa2b793eca3976126", "parents": ["80b47b3c406e9e8bffb31d45c9e11bfb1547dfc3"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1565781 - Fix ConsoleTable with nested holey array. r=Honza. a=RyanVM\n\nA test is added to ensure this is fixed properly.\nWe also fix the Array previewer to properly return\nundefined for unknown array properties, rather than null.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38467", "files": ["devtools/client/webconsole/components/Output/ConsoleTable.js", "devtools/client/webconsole/test/mochitest/browser_webconsole_console_table.js", "devtools/server/actors/object/previewers.js"], "git_node": null, "git_parents": [null], "node": "441998ce7a5e32dca5f00505c575d4b75706256b", "parents": ["fea8c86cd0d3c087575f393fa2b793eca3976126"], "tags": []}, {"author": "Matthew Noorenberghe \u003cmozilla@noorenberghe.ca\u003e", "branch": "default", "desc": "Bug 1565780 - Await masterPasswordLogin before copying passwords. r=jaws a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38551", "files": ["toolkit/components/passwordmgr/content/passwordManager.js"], "git_node": null, "git_parents": [null], "node": "f8413df45c553f2a72eec17dbe1042ffe38ff5db", "parents": ["441998ce7a5e32dca5f00505c575d4b75706256b"], "tags": ["DEVEDITION_69_0b7_BUILD1", "DEVEDITION_69_0b7_RELEASE", "FIREFOX_69_0b7_BUILD1", "FIREFOX_69_0b7_RELEASE"]}], "date": 1563826595, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "11622": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging f8413df45c553f2a72eec17dbe1042ffe38ff5db with DEVEDITION_69_0b7_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "4d7c5c31b0e52d2818de5d579494ef0c49755784", "parents": ["f8413df45c553f2a72eec17dbe1042ffe38ff5db"], "tags": []}], "date": 1563837285, "git_changesets": [null], "user": "ffxbld"}, "11623": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging f8413df45c553f2a72eec17dbe1042ffe38ff5db with FIREFOX_69_0b7_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "7871a6e386084eec070778e873d4c0f2875977e5", "parents": ["4d7c5c31b0e52d2818de5d579494ef0c49755784"], "tags": []}], "date": 1563837486, "git_changesets": [null], "user": "ffxbld"}, "11624": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nkn -\u003e 90f9bc51dffd\nrm -\u003e aa9d453a6408\nro -\u003e 12ba59dd78db\ntrs -\u003e e2c3cf92e471", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "8bcc11e9d0fa6e92af48eab0b4c4d16b116fac3c", "parents": ["7871a6e386084eec070778e873d4c0f2875977e5"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nes-AR -\u003e d6ba8a737908\nes-MX -\u003e b0f40ce8a3ad\nhi-IN -\u003e 2be586d31900\nkn -\u003e 53f4f01fefc2\npt-BR -\u003e a548c7fb474e\nrm -\u003e e9085e85a1b4\nro -\u003e 12ba59dd78db", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "5458cb45241aa4c5a68f6d106aeb013c3cde2a62", "parents": ["8bcc11e9d0fa6e92af48eab0b4c4d16b116fac3c"], "tags": []}], "date": 1563883244, "git_changesets": [null, null], "user": "ffxbld"}, "11625": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging f8413df45c553f2a72eec17dbe1042ffe38ff5db with DEVEDITION_69_0b7_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "5c0f08294dbc741e8b9648f4c322fb24e04df79f", "parents": ["5458cb45241aa4c5a68f6d106aeb013c3cde2a62"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release DONTBUILD", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "6941948e4cba1c4b3928f3b3078a071fd785278c", "parents": ["5c0f08294dbc741e8b9648f4c322fb24e04df79f"], "tags": []}], "date": 1563892750, "git_changesets": [null, null], "user": "ffxbld"}, "11626": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging f8413df45c553f2a72eec17dbe1042ffe38ff5db with FIREFOX_69_0b7_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "f42332113310132a124e8ec350eba4e109e84644", "parents": ["6941948e4cba1c4b3928f3b3078a071fd785278c"], "tags": []}], "date": 1563892946, "git_changesets": [null], "user": "ffxbld"}, "11627": {"changesets": [{"author": "Julien Cristau \u003cjcristau@mozilla.com\u003e", "branch": "default", "desc": "No bug - Unset EARLY_BETA_OR_EARLIER. a=RyanVM", "files": ["build/defines.sh"], "git_node": null, "git_parents": [null], "node": "9f55691b5cfe1cce0c9fb3b6d0256214a2813125", "parents": ["f42332113310132a124e8ec350eba4e109e84644"], "tags": []}], "date": 1563909495, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "11628": {"changesets": [{"author": "Jeff Walden \u003cjwalden@mit.edu\u003e", "branch": "default", "desc": "Bug 1543517 - Enable UTF-8 parsing of external (non-inline) and worker scripts unconditionally in beta builds (in suitable fashion to ride the trains into release).  r=bzbarsky\n\nDifferential Revision: https://phabricator.services.mozilla.com//D38785", "files": ["modules/libpref/init/StaticPrefList.h"], "git_node": null, "git_parents": [null], "node": "b7c75f5e6296027f35f97bb4da3d8bcbe2309af5", "parents": ["9f55691b5cfe1cce0c9fb3b6d0256214a2813125"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1543599 - Don't suppress scroll anchoring adjustments when switching display to `none`. r=rhunt,dholbert\n\n\nSince that means that we won't suppress them when switching display back (since\nwe have no frame to pull the old style from).\n\nWe may want to match Chrome more exactly and don't do this any time `display`\nchanges (which if I'm reading their code correctly is what they do...).\n\nBut for now I've done the minimal thing and added a test.\n\nDifferential Revision: https://phabricator.services.mozilla.com//D38094", "files": ["layout/base/RestyleManager.cpp", "testing/web-platform/tests/css/css-scroll-anchoring/position-change-heuristic-display-none-change.html"], "git_node": null, "git_parents": [null], "node": "34ac17699d075f59d0642c216823a4ff83d8188c", "parents": ["b7c75f5e6296027f35f97bb4da3d8bcbe2309af5"], "tags": []}, {"author": "Oriol Brufau \u003coriol-bugzilla@hotmail.com\u003e", "branch": "default", "desc": "Bug 1544329 - Don't load browser console in an invisibleToDebugger compartment. r?ochameau\n\nDifferential Revision: https://phabricator.services.mozilla.com//D37926", "files": ["devtools/client/webconsole/hudservice.js"], "git_node": null, "git_parents": [null], "node": "b0403a37fb008afcecd2504f0335b1ef735f68dd", "parents": ["34ac17699d075f59d0642c216823a4ff83d8188c"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1545381 - be more defensive in nsAppShellSingleton; r=erahm\n\n\nWe're seeing crashes in bug 1545381 in appshell shutdown, which appear\nto point to appshell initialization somehow falling over non-obviously.\nAppshell initialization should basically never fail, so let's complain\nloudly if that ever happens.\n\nDifferential Revision: https://phabricator.services.mozilla.com//D38915", "files": ["widget/nsAppShellSingleton.h"], "git_node": null, "git_parents": [null], "node": "b7de4c7bb68d5f89ff1600cf103ef0d911dfc638", "parents": ["b0403a37fb008afcecd2504f0335b1ef735f68dd"], "tags": []}, {"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1560520 - limit the size of WebRender's glyph cache. r?kvark\n\nDifferential Revision: https://phabricator.services.mozilla.com//D37982", "files": ["gfx/wr/webrender/src/glyph_cache.rs", "gfx/wr/webrender/src/glyph_rasterizer/mod.rs", "gfx/wr/webrender/src/glyph_rasterizer/no_pathfinder.rs", "gfx/wr/webrender/src/glyph_rasterizer/pathfinder.rs", "gfx/wr/webrender/src/render_backend.rs", "gfx/wr/webrender/src/render_task.rs", "gfx/wr/webrender/src/renderer.rs", "gfx/wr/webrender/src/resource_cache.rs", "gfx/wr/webrender/src/texture_cache.rs"], "git_node": null, "git_parents": [null], "node": "472132eeee82d6ee852d27867151e5fb92057ffe", "parents": ["b7de4c7bb68d5f89ff1600cf103ef0d911dfc638"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1561411 - Fix abuse report message bar string shown on report on addon uninstall. r=mstriemer r=ryanvm\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35993", "files": ["toolkit/mozapps/extensions/content/aboutaddons.js", "toolkit/mozapps/extensions/content/aboutaddonsCommon.js", "toolkit/mozapps/extensions/content/abuse-reports.js", "toolkit/mozapps/extensions/test/browser/browser_html_abuse_report.js"], "git_node": null, "git_parents": [null], "node": "74c9645ad84e607738dce8601efe207051bd5f9f", "parents": ["472132eeee82d6ee852d27867151e5fb92057ffe"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1565129 - Re-introduce plain_text.wrap_long_lines. r=bzbarsky a=ryanvm\n\nLooks like some users use it, and it's not too much effort to support. This is\nsomewhat simpler, and IMO better than what existed before bug 1514655 because:\n\n * It doesn't regress bidi rendering when the pref is disabled (before, the pref\n   would prevent plaintext.css from applying altogether).\n\n * It's consistent with the way view-source docs work.\n\n * It doesn't use non-standard stylesheet APIs to toggle the stylesheet\n   (bug 1260720).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37742", "files": ["layout/reftests/bugs/1565129.txt", "layout/reftests/bugs/reftest.list", "layout/style/res/plaintext.css", "modules/libpref/init/StaticPrefList.h", "parser/html/nsHtml5PlainTextUtils.cpp", "parser/html/nsHtml5PlainTextUtils.h", "parser/html/nsHtml5TreeBuilderCppSupplement.h"], "git_node": null, "git_parents": [null], "node": "4fc420cd0c74ebabc7b82ff6006f6efbde96478f", "parents": ["74c9645ad84e607738dce8601efe207051bd5f9f"], "tags": []}, {"author": "sotaro \u003csotaro.ikeda.g@gmail.com\u003e", "branch": "default", "desc": "Bug 1565255 - Backout Bug 1552734 r=nical a=ryanvm\n\nSince Bug 1531898 fix, fix of Bug 1552734 is not necessary anymore. The backout reduces memory usage.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38257", "files": ["gfx/layers/D3D11YCbCrImage.cpp", "gfx/layers/D3D11YCbCrImage.h", "gfx/layers/client/ImageClient.cpp", "gfx/layers/client/ImageClient.h"], "git_node": null, "git_parents": [null], "node": "29185afc3f8960aba202fb4fd1e263ff498d1dd3", "parents": ["4fc420cd0c74ebabc7b82ff6006f6efbde96478f"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1567098 - Allow line-break after a float placeholder if the line is empty. r=emilio a=ryanvm\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38512", "files": ["layout/generic/nsLineLayout.cpp"], "git_node": null, "git_parents": [null], "node": "34fca225d15c50b205f5fdcbb2c9bd1d198f7c38", "parents": ["29185afc3f8960aba202fb4fd1e263ff498d1dd3"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1567098 - Add a WPT reftest where no content fits onto the shortened line beside a float. r=emilio a=ryanvm\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38535", "files": ["testing/web-platform/tests/css/CSS2/floats/float-no-content-beside-001-ref.html", "testing/web-platform/tests/css/CSS2/floats/float-no-content-beside-001.html"], "git_node": null, "git_parents": [null], "node": "b665d4c489805f0d5a3027e8ba23a7b28f79772c", "parents": ["34fca225d15c50b205f5fdcbb2c9bd1d198f7c38"], "tags": []}, {"author": "ksenia \u003ckberezina@mozilla.com\u003e", "branch": "default", "desc": "Bug 1567198 - create UA override for corporate.santander.co.uk r=denschub,rhelmer a=ryanvm\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38509", "files": ["browser/extensions/webcompat/manifest.json", "browser/extensions/webcompat/ua_overrides.js", "mobile/android/extensions/webcompat/manifest.json", "mobile/android/extensions/webcompat/ua_overrides.js"], "git_node": null, "git_parents": [null], "node": "a372e4f1eee80bac19e0a0f95ddc3f7c3a62a371", "parents": ["b665d4c489805f0d5a3027e8ba23a7b28f79772c"], "tags": []}, {"author": "Tim D. Smith \u003ctdsmith@mozilla.com\u003e", "branch": "default", "desc": "Bug 1567607 - Expose network.trr.mode to telemetry r=janerik a=ryanvm\n\nAdd the network.trr.mode pref, which reflects whether DNS over HTTPS is enabled or not, to the telemetry environment.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38743", "files": ["toolkit/components/telemetry/app/TelemetryEnvironment.jsm"], "git_node": null, "git_parents": [null], "node": "9fc885879ec5eeb2918c42a04d932a43870246fb", "parents": ["a372e4f1eee80bac19e0a0f95ddc3f7c3a62a371"], "tags": []}], "date": 1563917185, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "shindli@mozilla.com"}, "11629": {"changesets": [{"author": "Razvan Caliman \u003crcaliman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1567164 - Ensure StyleRuleActor.getRuleText() returns text content of minified CSS. r=gl a=RyanVM\n\nThe patch for Bug 724505 changed the return of `prettifyCSS()` from a string to an object and the reference in the StyleRuleActor.getRuleText() was not updated. This patch fixes this and introduces a test.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38673", "files": ["devtools/server/actors/styles.js", "devtools/server/tests/browser/browser.ini", "devtools/server/tests/browser/browser_styles_getRuleText.js"], "git_node": null, "git_parents": [null], "node": "4e778d09c6b239042d90d20667aff5821709f6f4", "parents": ["9fc885879ec5eeb2918c42a04d932a43870246fb"], "tags": []}, {"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1567301 - UnifiedComplete: Change the title-tags separator to a non-printable character. r=mak a=RyanVM\n\nThis just changes the `TITLE_TAGS_SEPARATOR` to the non-printable character `\\x1F`, the unit separator, which seems appropriate.\n\nAt first I thought we could use the result label to store tags since we're not using the label at all right now. Hacky, but better than storing them in the title. But (1) `nsAutoCompleteSimpleResult::GetLabelAt` falls back to the value if the label is empty, and (2) `nsAutoCompleteController::GetLabelAt` actually returns the same thing as `GetValueAt`, i.e., the value, not the label. It's doable, but we'd need set the label to some special value for every result that doesn't have tags so that the label doesn't fall back to the value so we can tell which results don't have tags, and we'd need to make sure to always directly ask results for labels instead of going through the controller.  head_autocomplete.js goes through the controller, and I didn't check what else does too.\n\nSo then I thought we could store tags in the style with a special substring like \"tags=tag1,tag2,tag3\". Again it's doable, but:\n\nThe simplest fix is to just change the separator to an unprintable character. That should work, right? We can do better whenever we finally rewrite/refactor UnifiedComplete for quantumbar.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38790", "files": ["browser/components/urlbar/UrlbarProviderUnifiedComplete.jsm", "browser/components/urlbar/UrlbarUtils.jsm", "toolkit/components/places/UnifiedComplete.jsm", "toolkit/components/places/tests/unifiedcomplete/head_autocomplete.js"], "git_node": null, "git_parents": [null], "node": "12d0b5cc1b57a64db81f7ae47cc11458a1416af0", "parents": ["4e778d09c6b239042d90d20667aff5821709f6f4"], "tags": []}, {"author": "Marian Raiciof \u003cmraiciof@mozilla.com\u003e", "branch": "default", "desc": "Bug 1564200 - No such file or directory running Raptor against x86 emulator r=perftest-reviewers,Bebe a=test-only\n\nHandle the exception ADBProcessError raised by\nthermal_zone0 = self.device.shell_output('cat sys/class/thermal/thermal_zone0/temp')\non the emulator\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38859", "files": ["testing/raptor/raptor/raptor.py"], "git_node": null, "git_parents": [null], "node": "82471347dccf306a3450e654f79a85290cb088d5", "parents": ["12d0b5cc1b57a64db81f7ae47cc11458a1416af0"], "tags": []}, {"author": "Marian Raiciof \u003cmraiciof@mozilla.com\u003e", "branch": "default", "desc": "Bug 1560339 - Extra incoherent logging when running android mochitest r=gbrown a=test-only\n\nDo not decode data returned by get_file() in adb.py\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38844", "files": ["testing/mozbase/mozdevice/mozdevice/adb.py"], "git_node": null, "git_parents": [null], "node": "71fc0f456868dddcee6391a9dc421548ddc69545", "parents": ["82471347dccf306a3450e654f79a85290cb088d5"], "tags": []}, {"author": "Sebastian Streich \u003csstreich@mozilla.com\u003e", "branch": "default", "desc": "Bug 1558197 Adding more time to worker-subresource-fetch-redirect-upgrade r=ckerschb,jgraham a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38843", "files": ["testing/web-platform/tests/upgrade-insecure-requests/support/generate.py", "testing/web-platform/tests/upgrade-insecure-requests/worker-subresource-fetch-redirect-upgrade.https.html"], "git_node": null, "git_parents": [null], "node": "4f7affad853b1bf80ed072649a7b3058c6d064e6", "parents": ["71fc0f456868dddcee6391a9dc421548ddc69545"], "tags": []}], "date": 1563922897, "git_changesets": [null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "11630": {"changesets": [{"author": "Narcis Beleuzu \u003cnbeleuzu@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 12d0b5cc1b57 (bug 1567301) for bc failures on browser_autocomplete_tag_star_visibility.js . a=backout", "files": ["browser/components/urlbar/UrlbarProviderUnifiedComplete.jsm", "browser/components/urlbar/UrlbarUtils.jsm", "toolkit/components/places/UnifiedComplete.jsm", "toolkit/components/places/tests/unifiedcomplete/head_autocomplete.js"], "git_node": null, "git_parents": [null], "node": "7637d97a71442be83ea60b8036f65a09255659fd", "parents": ["4f7affad853b1bf80ed072649a7b3058c6d064e6"], "tags": []}], "date": 1563931298, "git_changesets": [null], "user": "nbeleuzu@mozilla.com"}, "11631": {"changesets": [{"author": "Nicolas Silva \u003cnsilva@mozilla.com\u003e", "branch": "default", "desc": "Bug 1557208 - Leak WebRender's thread pool. r=jrmuizel a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38368", "files": ["gfx/webrender_bindings/src/bindings.rs"], "git_node": null, "git_parents": [null], "node": "4aab05ffedb6d92080aa73ac1e2ece89b78a87e0", "parents": ["7637d97a71442be83ea60b8036f65a09255659fd"], "tags": []}, {"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1567301 - UnifiedComplete: Change the title-tags separator to a non-printable character. r=mak a=RyanVM\n\nThis just changes the `TITLE_TAGS_SEPARATOR` to the non-printable character `\\x1F`, the unit separator, which seems appropriate.\n\nAt first I thought we could use the result label to store tags since we're not using the label at all right now. Hacky, but better than storing them in the title. But (1) `nsAutoCompleteSimpleResult::GetLabelAt` falls back to the value if the label is empty, and (2) `nsAutoCompleteController::GetLabelAt` actually returns the same thing as `GetValueAt`, i.e., the value, not the label. It's doable, but we'd need set the label to some special value for every result that doesn't have tags so that the label doesn't fall back to the value so we can tell which results don't have tags, and we'd need to make sure to always directly ask results for labels instead of going through the controller.  head_autocomplete.js goes through the controller, and I didn't check what else does too.\n\nSo then I thought we could store tags in the style with a special substring like \"tags=tag1,tag2,tag3\". Again it's doable, but:\n\nThe simplest fix is to just change the separator to an unprintable character. That should work, right? We can do better whenever we finally rewrite/refactor UnifiedComplete for quantumbar.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38790", "files": ["browser/components/urlbar/UrlbarProviderUnifiedComplete.jsm", "browser/components/urlbar/UrlbarUtils.jsm", "toolkit/components/places/UnifiedComplete.jsm", "toolkit/components/places/tests/unifiedcomplete/head_autocomplete.js", "toolkit/content/widgets/autocomplete-richlistitem.js"], "git_node": null, "git_parents": [null], "node": "12fc62083dd63f4b78009206bc272367a6f8fcfa", "parents": ["4aab05ffedb6d92080aa73ac1e2ece89b78a87e0"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1567105 - When cloning a document for printing, call SetCompatMode rather than silently copying over the compat mode. r=jwatt a=RyanVM\n\nSo that the styleset and CSS loader react appropriately.\n\nBug 1535788 causes the styleset to be created earlier, so it stopped grabbing the\nalready-updated compat mode.\n\nI think the CSS loader stuff could already cause some issues before bug 1535788,\nfor what is worth.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39053", "files": ["dom/base/Document.cpp"], "git_node": null, "git_parents": [null], "node": "0142a67ef10d096e9f9a3d90e7204e8b1b5f6168", "parents": ["12fc62083dd63f4b78009206bc272367a6f8fcfa"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1567105 - Tests. r=jwatt a=RyanVM\n\nThe reftest-paged tests don't trigger the document clone code-path (I realized\nthat after writing them), but I guess they don't hurt, the printpreview test\ndoes fail without the previous patch.\n\nDepends on D39053\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39054", "files": ["layout/base/tests/chrome/chrome.ini", "layout/base/tests/chrome/printpreview_helper.xul", "layout/base/tests/chrome/printpreview_quirks.html", "layout/base/tests/chrome/printpreview_quirks_ref.html", "layout/reftests/pagination/quirks-notref.html", "layout/reftests/pagination/quirks-ref.html", "layout/reftests/pagination/quirks.html", "layout/reftests/pagination/reftest.list"], "git_node": null, "git_parents": [null], "node": "6fca9f4239e20df1458f23b8284e29f3d11c904f", "parents": ["0142a67ef10d096e9f9a3d90e7204e8b1b5f6168"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1567298 - Refresh preference sheet data from ThemeChanged(). r=heycam a=RyanVM\n\nSo as to grab updated high contrast settings and co.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39084", "files": ["layout/base/nsPresContext.cpp"], "git_node": null, "git_parents": [null], "node": "5629476e2815fdfb3e3ba285626c95dd69df54fe", "parents": ["6fca9f4239e20df1458f23b8284e29f3d11c904f"], "tags": []}], "date": 1563994975, "git_changesets": [null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "11632": {"changesets": [{"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1567301 - UnifiedComplete: Change the title-tags separator to a non-printable character (follow-up to fix eslint failure). a=eslint-fix", "files": ["toolkit/content/widgets/autocomplete-richlistitem.js"], "git_node": null, "git_parents": [null], "node": "732745aaad647992ba126f35ec9374d9f068c6d6", "parents": ["5629476e2815fdfb3e3ba285626c95dd69df54fe"], "tags": []}], "date": 1563999808, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "11633": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP blocklist remote-settings tld-suffixes - a=repo-update r=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39337", "files": ["browser/app/blocklist.xml", "netwerk/dns/effective_tld_names.dat", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/blocklists/addons.json"], "git_node": null, "git_parents": [null], "node": "0869bbb117034bf98f15d540763e117507d1b27f", "parents": ["732745aaad647992ba126f35ec9374d9f068c6d6"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1469113 - Fix intermittent issues in browser_884402_customize_from_overflow.js, r=jaws, a=test-only\n\nDifferential Revision: https://phabricator.