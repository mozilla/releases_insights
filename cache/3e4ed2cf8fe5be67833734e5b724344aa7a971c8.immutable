/package.json", "tools/lint/eslint/manifest.tt"], "git_node": null, "git_parents": [null], "node": "5def55cc75a70465407ab31228c77c6dd7bec349", "parents": ["7acff7d47dec051740d4d09ce6313f0b0f1f6a53"], "tags": []}], "date": 1563453038, "git_changesets": [null], "user": "mbanner@mozilla.com"}, "11605": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP blocklist remote-settings tld-suffixes - a=repo-update r=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38481", "files": ["browser/app/blocklist.xml", "netwerk/dns/effective_tld_names.dat", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/blocklists/addons.json", "services/settings/dumps/blocklists/plugins.json"], "git_node": null, "git_parents": [null], "node": "ea85bbc0cb0002477b2490574ed458ebb054342d", "parents": ["5def55cc75a70465407ab31228c77c6dd7bec349"], "tags": []}], "date": 1563454927, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "11606": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\ngn -\u003e 8dcdbd791470\nsk -\u003e 0d563df9fdc4\nuk -\u003e 52e1450c2a6a", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "a87605be5fe448d9fae1c6e3249c43c8a1a79ae0", "parents": ["ea85bbc0cb0002477b2490574ed458ebb054342d"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\ngn -\u003e 8dcdbd791470\nsk -\u003e 0d563df9fdc4\nuk -\u003e 52e1450c2a6a", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "2dd4b1997a5eb5b0654842fcb15767a2fc744852", "parents": ["a87605be5fe448d9fae1c6e3249c43c8a1a79ae0"], "tags": []}], "date": 1563458435, "git_changesets": [null, null], "user": "ffxbld"}, "11607": {"changesets": [{"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1563722 - Prefer DejaVu or Liberation fonts over Fira for treelines in about:memory, to minimize overlap issues. r=njn a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37725", "files": ["toolkit/components/aboutmemory/content/aboutMemory.css"], "git_node": null, "git_parents": [null], "node": "ad7d0b8d27ec549c053c91805053c9013d518485", "parents": ["2dd4b1997a5eb5b0654842fcb15767a2fc744852"], "tags": []}, {"author": "Bob Owen \u003cbobowencode@gmail.com\u003e", "branch": "default", "desc": "Bug 1564899: Make CloseHandleWrapper CHECK a DCHECK on non-Nightly builds. r=handyman a=RyanVM\n\nThis is because we are hitting it frequently during PolicyBase::OnJobEmpty and\ncurrently we can't work out how this can happen.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38090", "files": ["security/sandbox/chromium-shim/patches/after_update/change_to_DCHECK_in_CloseHandleWrapper.patch", "security/sandbox/chromium-shim/patches/after_update/patch_order.txt", "security/sandbox/chromium/base/win/scoped_handle_verifier.cc"], "git_node": null, "git_parents": [null], "node": "a0bbef741c7189165641f9b1b20972b4924c8eb6", "parents": ["ad7d0b8d27ec549c053c91805053c9013d518485"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1550637 - hide tooltip when the docshell navigate, don't show tooltips if the docshell is no longer active, r=nika,dao a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35503", "files": ["browser/base/content/browser.js", "docshell/base/nsDocShellTreeOwner.cpp", "docshell/base/nsDocShellTreeOwner.h", "docshell/base/nsIDocShell.idl"], "git_node": null, "git_parents": [null], "node": "195538371838a1bc539eeb5e0eecc4d534fcdd64", "parents": ["a0bbef741c7189165641f9b1b20972b4924c8eb6"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1529557 - Ensure share icons will have the same size r=VladBaicu a=RyanVM\n\nUsed `fitCenter` and`adjustViewBounds` to ensure the images will be scaled to\nfit their container while keeping their aspect ratio.\nIncreased resolution of some images used in the share menu to maths the others'\nand also remove some bluriness of the previous' when they are enlarged.\nThey were losslessly optimized with an average of 18% savings.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37386", "files": ["mobile/android/app/src/main/res/drawable-hdpi/ic_menu_share.png", "mobile/android/app/src/main/res/drawable-hdpi/icon_shareplane.png", "mobile/android/app/src/main/res/drawable-hdpi/shareplane.png", "mobile/android/app/src/main/res/drawable-xhdpi/ic_menu_share.png", "mobile/android/app/src/main/res/drawable-xhdpi/icon_shareplane.png", "mobile/android/app/src/main/res/drawable-xhdpi/shareplane.png", "mobile/android/app/src/main/res/drawable-xxhdpi/ic_menu_share.png", "mobile/android/app/src/main/res/drawable-xxhdpi/icon_shareplane.png", "mobile/android/app/src/main/res/drawable-xxhdpi/shareplane.png", "mobile/android/app/src/main/res/drawable-xxxhdpi/ic_menu_share.png", "mobile/android/app/src/main/res/drawable-xxxhdpi/icon_shareplane.png", "mobile/android/app/src/main/res/drawable-xxxhdpi/shareplane.png", "mobile/android/app/src/main/res/values/styles.xml"], "git_node": null, "git_parents": [null], "node": "18ed4493aa99009f084e2ee606fdc73f6ddffe92", "parents": ["195538371838a1bc539eeb5e0eecc4d534fcdd64"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1529557 - Mutate share drawable to prevent against it being reused from cache; r=VladBaicu a=RyanVM\n\nSummary:\nThe share drawable is used in multiple places in code.\nAndroid would cache it and subsequently serve a now dirty version of it with\ntransformations potentially added.\nBy mutating it into a new drawable we ensure we'll always have it clean.\n\nReviewers: VladBaicu\n\nReviewed By: VladBaicu\n\nSubscribers: emilio\n\nBug #: 1529557\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37734", "files": ["mobile/android/base/java/org/mozilla/gecko/menu/MenuItemSwitcherLayout.java"], "git_node": null, "git_parents": [null], "node": "345b3f7685faf0fa46b568e34a5d2baf9e92cae0", "parents": ["18ed4493aa99009f084e2ee606fdc73f6ddffe92"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1529557 - Use smaller share image to ensure consistency; r=AndreiLazar a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38195", "files": ["mobile/android/app/src/main/res/drawable-hdpi/ic_menu_share.png", "mobile/android/app/src/main/res/drawable-xhdpi/ic_menu_share.png", "mobile/android/app/src/main/res/drawable-xxhdpi/ic_menu_share.png", "mobile/android/app/src/main/res/drawable-xxxhdpi/ic_menu_share.png"], "git_node": null, "git_parents": [null], "node": "067e54510790223f29c1c10d8f488e10d679ae6c", "parents": ["345b3f7685faf0fa46b568e34a5d2baf9e92cae0"], "tags": []}], "date": 1563459154, "git_changesets": [null, null, null, null, null, null], "user": "nerli@mozilla.com"}, "11608": {"changesets": [{"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1536227: Block safemon64.dll (360 Safeguard/360 Total Security) for causing a11y crashes. r=aklotz a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D27203", "files": ["mozglue/build/WindowsDllBlocklistDefs.h"], "git_node": null, "git_parents": [null], "node": "302d6a3d1ca8673034456b04a90489f427793910", "parents": ["067e54510790223f29c1c10d8f488e10d679ae6c"], "tags": []}], "date": 1563460796, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "11609": {"changesets": [{"author": "Sebastian Streich \u003csstreich@mozilla.com\u003e", "branch": "default", "desc": "Bug 1388015 - Add checks to respect CSP-wildcard + Ports r=ckerschb a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35432", "files": ["dom/security/nsCSPUtils.cpp", "dom/security/test/csp/file_dummy_pixel.png", "dom/security/test/csp/mochitest.ini", "dom/security/test/csp/test_bug1388015.html"], "git_node": null, "git_parents": [null], "node": "127895e5664ce792527642f050ae218e29982784", "parents": ["302d6a3d1ca8673034456b04a90489f427793910"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1561970 - BrowserTabParent should ignore browser elements related to non-tab extension pages. r=mconley a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37051", "files": ["browser/actors/BrowserTabParent.jsm"], "git_node": null, "git_parents": [null], "node": "ebdd702238d977554718d55ddacf6b56e8ac666b", "parents": ["127895e5664ce792527642f050ae218e29982784"], "tags": []}, {"author": "Sebastian Streich \u003csstreich@mozilla.com\u003e", "branch": "default", "desc": "Bug 1452037 - Fix Whitelisting of javascript-uris with csp hash r=ckerschb a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35412", "files": ["dom/security/nsCSPContext.cpp", "dom/security/test/csp/file_bug1452037.html", "dom/security/test/csp/mochitest.ini", "dom/security/test/csp/test_bug1452037.html"], "git_node": null, "git_parents": [null], "node": "df88785f07c89fdbee528624bcb741f24cc3fe75", "parents": ["ebdd702238d977554718d55ddacf6b56e8ac666b"], "tags": ["DEVEDITION_69_0b6_BUILD1", "DEVEDITION_69_0b6_RELEASE", "FIREFOX_69_0b6_BUILD1", "FIREFOX_69_0b6_RELEASE"]}], "date": 1563470458, "git_changesets": [null, null, null], "user": "archaeopteryx@coole-files.de"}, "11610": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging df88785f07c89fdbee528624bcb741f24cc3fe75 with FIREFOX_69_0b6_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "402b492ff41842266922ea6089049fbbd6c70c69", "parents": ["df88785f07c89fdbee528624bcb741f24cc3fe75"], "tags": []}], "date": 1563482178, "git_changesets": [null], "user": "ffxbld"}, "11611": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging df88785f07c89fdbee528624bcb741f24cc3fe75 with DEVEDITION_69_0b6_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "6d9c319fbb991b56e46382180813ba793794b49e", "parents": ["402b492ff41842266922ea6089049fbbd6c70c69"], "tags": []}], "date": 1563482377, "git_changesets": [null], "user": "ffxbld"}, "11612": {"changesets": [{"author": "Erica Wright \u003cewright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1563700 - Improve protections database performance. r=johannh a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37262", "files": ["toolkit/components/antitracking/TrackingDBService.jsm"], "git_node": null, "git_parents": [null], "node": "57d5f2ae8afd6e492cf0cf9dd6d62e2fa0b83cfb", "parents": ["6d9c319fbb991b56e46382180813ba793794b49e"], "tags": []}, {"author": "Mark Hammond \u003cmhammond@skippinet.com.au\u003e", "branch": "default", "desc": "Bug 1564131 - re-enable syncing of builtin themes. r=rpl a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37837", "files": ["browser/app/profile/firefox.js", "services/sync/modules/engines/prefs.js", "services/sync/tests/unit/test_prefs_store.js"], "git_node": null, "git_parents": [null], "node": "046a7bd8885499ad1ba280dd8533a9bdacb06cf5", "parents": ["57d5f2ae8afd6e492cf0cf9dd6d62e2fa0b83cfb"], "tags": []}, {"author": "Matt Howell \u003cmhowell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1566968 - Prevent very long reinstall prompt strings from overflowing the window. r=agashlin a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38421", "files": ["browser/branding/official/branding.nsi"], "git_node": null, "git_parents": [null], "node": "ec6c6890c684785000c5559c805f308ed427c94c", "parents": ["046a7bd8885499ad1ba280dd8533a9bdacb06cf5"], "tags": []}, {"author": "Byron Campen [:bwc] \u003cdocfaraday@gmail.com\u003e", "branch": "default", "desc": "Bug 1558887: Reduce this STUN response delay a little, since on some platforms it seems to be too long. r=mjf a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37474", "files": ["media/mtransport/test/ice_unittest.cpp"], "git_node": null, "git_parents": [null], "node": "016e96e8f65f8f3665ac328169061290ce8521b4", "parents": ["ec6c6890c684785000c5559c805f308ed427c94c"], "tags": []}], "date": 1563507378, "git_changesets": [null, null, null, null], "user": "nbeleuzu@mozilla.com"}, "11613": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nes-MX -\u003e ea2cc1d2aedd\neu -\u003e 4e13c883ea55\nfr -\u003e 56cd07059971\ngn -\u003e 1bcbf75033e3\nhi-IN -\u003e 90ae1a185264\nit -\u003e c55b6394e2bd\nkk -\u003e 1af4b29f9498\nko -\u003e 264f9c270d44\nlij -\u003e 627d91a8ad54\nnb-NO -\u003e a4a057056cb2\nnl -\u003e 231bbcf2c9d2\nnn-NO -\u003e 4131e31dc2e9\npt-PT -\u003e fb2999fc7104\nsk -\u003e 90568ec879bd\nuk -\u003e 7384f904aef9", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "6f91ca9e857f2611a9ba411ba3eafb870c28e04b", "parents": ["016e96e8f65f8f3665ac328169061290ce8521b4"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nes-MX -\u003e ea2cc1d2aedd\neu -\u003e 4e13c883ea55\nfr -\u003e 56cd07059971\ngn -\u003e 1bcbf75033e3\nhi-IN -\u003e 90ae1a185264\nit -\u003e c55b6394e2bd\nkk -\u003e 1af4b29f9498\nko -\u003e 264f9c270d44\nlij -\u003e 627d91a8ad54\nnb-NO -\u003e a4a057056cb2\nnl -\u003e 231bbcf2c9d2\nnn-NO -\u003e 4131e31dc2e9\npt-PT -\u003e fb2999fc7104\nsk -\u003e 90568ec879bd\nuk -\u003e 7384f904aef9", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "c68a49b77d511ac1bc6099bf418dcc80cce3cbf9", "parents": ["6f91ca9e857f2611a9ba411ba3eafb870c28e04b"], "tags": []}], "date": 1563548432, "git_changesets": [null, null], "user": "ffxbld"}, "11614": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging df88785f07c89fdbee528624bcb741f24cc3fe75 with DEVEDITION_69_0b6_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "3c58e5258d0f9cdb554734ab4ce477b943c2422d", "parents": ["c68a49b77d511ac1bc6099bf418dcc80cce3cbf9"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release DONTBUILD", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "4e1327dacf8c61e4968b3b29f00041201fcd9638", "parents": ["3c58e5258d0f9cdb554734ab4ce477b943c2422d"], "tags": []}], "date": 1563552686, "git_changesets": [null, null], "user": "ffxbld"}, "11615": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging df88785f07c89fdbee528624bcb741f24cc3fe75 with FIREFOX_69_0b6_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "37409ab4ab9074431017ad70866a57d55ecbae61", "parents": ["4e1327dacf8c61e4968b3b29f00041201fcd9638"], "tags": []}], "date": 1563552882, "git_changesets": [null], "user": "ffxbld"}, "11616": {"changesets": [{"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1563133 - limit GlyphBuffer capacity. r=jfkthame a=abillings\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38214", "files": ["gfx/thebes/gfxFont.cpp"], "git_node": null, "git_parents": [null], "node": "b5b868d520a2ee6043adaddffb893bae932c24b3", "parents": ["37409ab4ab9074431017ad70866a57d55ecbae61"], "tags": []}], "date": 1563556310, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "11617": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP remote-settings - a=repo-update r=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38857", "files": ["security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc"], "git_node": null, "git_parents": [null], "node": "7aee03d62b0ce63de493cdcfb0d8ae5cc672b170", "parents": ["b5b868d520a2ee6043adaddffb893bae932c24b3"], "tags": []}, {"author": "Sean Feng \u003csefeng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1557549 - Disable BFCache for navigate back tests. r=smaug, a=test-only\n\nWe have some tests which the top level document would\nnavigate to navigate_back.html, use history.back()\nto navigate back to the top level document, and wait for\nthe iframes to fire a postMessage. This behavior requires\nBFCache to be disabled to work correctly, otherwise BFCache\ncould block the code.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38520", "files": ["testing/web-platform/tests/resource-timing/resources/embed-navigate-back.html", "testing/web-platform/tests/resource-timing/resources/iframe-navigate-back.html", "testing/web-platform/tests/resource-timing/resources/object-navigate-back.html"], "git_node": null, "git_parents": [null], "node": "ab6dab07a70c93df5947564a49b41a3a922d706b", "parents": ["7aee03d62b0ce63de493cdcfb0d8ae5cc672b170"], "tags": []}, {"author": "Sean Feng \u003csefeng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1557549 - Enable the navigate back WPT tests for Android. r=smaug, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38556", "files": ["testing/web-platform/meta/resource-timing/nested-context-navigations-embed.html.ini", "testing/web-platform/meta/resource-timing/nested-context-navigations-iframe.html.ini", "testing/web-platform/meta/resource-timing/nested-context-navigations-object.html.ini"], "git_node": null, "git_parents": [null], "node": "364ffc51fc5401b85874ac2bf05e203375c885ed", "parents": ["ab6dab07a70c93df5947564a49b41a3a922d706b"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1565497 - Improve android gtest's wait for final output; r=jmaher, a=test-only\n\nA possible explanation for the infrequent observation of an incomplete log is that\nthe log is still being written when the harness detects that the process has completed.\nWaiting for one extra polling interval may avoid this.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38577", "files": ["testing/gtest/remotegtests.py"], "git_node": null, "git_parents": [null], "node": "798dfb5c0825c0f61b6cc7da5b23ecbaf751a70a", "parents": ["364ffc51fc5401b85874ac2bf05e203375c885ed"], "tags": []}, {"author": "Alastor Wu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1550442 - check track's ready state in the beginning of the test. r=baku, a=test-only\n\nIf the track has already finished loading, we can directly run `trackLoaded()`.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37953", "files": ["testing/web-platform/tests/html/semantics/embedded-content/media-elements/track/track-element/track-mode.html"], "git_node": null, "git_parents": [null], "node": "aeae22ede71c4efc577de134ec886b46f4fc1df2", "parents": ["798dfb5c0825c0f61b6cc7da5b23ecbaf751a70a"], "tags": []}, {"author": "alwu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1550442 - extend cue's duration. r=baku, a=test-only\n\nIn order not to miss the second cue, we extend the duration of both the second and third cue to 1 second. And adjust the third cue's start time to keep them non-overlapping.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38529", "files": ["testing/web-platform/tests/html/semantics/embedded-content/media-elements/track/track-element/resources/captions-fast.vtt"], "git_node": null, "git_parents": [null], "node": "e840e5fffe9ab85ee4fac0abd01ad67faab7dbc7", "parents": ["aeae22ede71c4efc577de134ec886b46f4fc1df2"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1566957 - Ensure robocop runs with --disable-e10s; r=jmaher, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38395", "files": ["testing/mozharness/scripts/android_emulator_unittest.py"], "git_node": null, "git_parents": [null], "node": "b2e6876280540542727e147e2f4a5c402db422de", "parents": ["e840e5fffe9ab85ee4fac0abd01ad67faab7dbc7"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1565908 - ensure we never try to run with e10s enabled on fennec, r=sparky, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38358", "files": ["testing/raptor/raptor/raptor.py"], "git_node": null, "git_parents": [null], "node": "48ed488f1c9363fb8799431013b9f3a3d09eaec0", "parents": ["b2e6876280540542727e147e2f4a5c402db422de"], "tags": []}], "date": 1563802742, "git_changesets": [null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "11618": {"changesets": [{"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1567420 - Fix interactive element check in CustomizableUI.jsm. r=dao a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38728", "files": ["browser/components/customizableui/CustomizableUI.jsm"], "git_node": null, "git_parents": [null], "node": "57689d90bbb83eb9e2dcbb372cd316f4e63acb53", "parents": ["48ed488f1c9363fb8799431013b9f3a3d09eaec0"], "tags": []}, {"author": "Christoph Kerschbaumer \u003cckerschb@christophkerschbaumer.com\u003e", "branch": "default", "desc": "Bug 1566734: Update CSP for about:telemetry to include resource:.r=Gijs a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38518", "files": ["toolkit/content/aboutTelemetry.xhtml"], "git_node": null, "git_parents": [null], "node": "2110d20c80e6922c9531bc31679f057e452fc28d", "parents": ["57689d90bbb83eb9e2dcbb372cd316f4e63acb53"], "tags": []}, {"author": "Glenn Watson \u003cgithub@intuitionlibrary.com\u003e", "branch": "default", "desc": "Bug 1566712 - Fix quality issues with picture caching when the transform has a fractional offset. r=kvark a=RyanVM\n\nThis patch reverts the previous attempted fix for snapping issues\nwith picture caching, and implements a better solution.\n\nThis fixes the main visual issue by ensuring that any fractional\noffset in the root transform is accounted for by:\n\n * Offsetting the tile rects by this amount, so that the content\n   origin is a whole device pixel.\n * Invalidating all tiles if the fractional part of the root\n   transform changes. This is required since it can affect the\n   snapping logic that WR applies. Fortunately, this occurs\n   very rarely - Gecko typically has a constant fractional part\n   for each page.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38267", "files": ["gfx/wr/webrender/res/brush_image.glsl", "gfx/wr/webrender/src/batch.rs", "gfx/wr/webrender/src/frame_builder.rs", "gfx/wr/webrender/src/picture.rs", "gfx/wr/webrender/src/texture_cache.rs"], "git_node": null, "git_parents": [null], "node": "94b21fc8b6439034c00f71743b7b60ca971769bd", "parents": ["2110d20c80e6922c9531bc31679f057e452fc28d"], "tags": []}, {"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1565927 - Default FrameCrashedEvent's isTopFrame to true if never set. r=nika a=RyanVM\n\nThis is the safer assumption, since we normally skip setting isTopFrame\nexplicitly if no BrowsingContext exists (which is the case if, for example,\nthe crash is due to the fact that creating the top-level browser failed).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38119", "files": ["dom/webidl/FrameCrashedEvent.webidl"], "git_node": null, "git_parents": [null], "node": "f9ab4049b714471f4979545c338789a2d84cb186", "parents": ["94b21fc8b6439034c00f71743b7b60ca971769bd"], "tags": []}, {"author": "alwu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1565501 - use fallible memory allocation in MediaSpan. r=jya a=RyanVM\n\nUse fallible memory allocation in order to avoid the OOM issue.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38400", "files": ["dom/media/MediaSpan.h"], "git_node": null, "git_parents": [null], "node": "8d2b4af58b16f54bb4fe5728c38e8befc0d7ee8a", "parents": ["f9ab4049b714471f4979545c338789a2d84cb186"], "tags": []}, {"author": "John Lin \u003cjolin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1560611 - remember valid buffers only. r=jya a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38129", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/media/CodecProxy.java"], "git_node": null, "git_parents": [null], "node": "6760861cd25c4fdbb6afc82f12f01d2422199260", "parents": ["8d2b4af58b16f54bb4fe5728c38e8befc0d7ee8a"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486717 - Do not emit contextmenu from parentprocess if target is the RDM iframe (beta)  r=mconley,mtigley a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37691", "files": ["browser/actors/ContextMenuChild.jsm", "devtools/client/responsive.html/test/browser/browser.ini", "devtools/client/responsive.html/test/browser/browser_contextmenu_inspect.js", "devtools/client/responsive.html/test/browser/doc_contextmenu_inspect.html"], "git_node": null, "git_parents": [null], "node": "63c95b7c0ba076234065695536f5450005ac6e09", "parents": ["6760861cd25c4fdbb6afc82f12f01d2422199260"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1567082 - Fix console table overflow. r=Honza. a=RyanVM\n\nReviewers: Honza\n\nReviewed By: Honza\n\nBug #: 1567082\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38466", "files": ["devtools/client/themes/webconsole.css", "devtools/client/webconsole/test/mochitest/browser_webconsole_console_table.js"], "git_node": null, "git_parents": [null], "node": "50e3b40b9d54cc36b384b649ff147901863ff806", "parents": ["63c95b7c0ba076234065695536f5450005ac6e09"], "tags": []}, {"author": "Daniel Varga \u003cdvarga@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 0eaeadceac47 (bug 1563040) requested by whimboo a=whimbo on a CLOSED TREE", "files": ["testing/marionette/browser.js", "testing/marionette/harness/marionette_harness/runner/mixins/window_manager.py"], "git_node": null, "git_parents": [null], "node": "473500c4dca7e1e161fc35f67dd63ac49bfa2ce0", "parents": ["50e3b40b9d54cc36b384b649ff147901863ff806"], "tags": []}], "date": 1563814691, "git_changesets": [null, null, null, null, null, null, null, null, null], "user": "dvarga@mozilla.com"}, "11619": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nca -\u003e 8c49f8e52514\ncy -\