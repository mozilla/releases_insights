e": "ef2dbdb0271b8344aec22b0f23a8e5fb4d607a48", "parents": ["bb5e43a6126870f421c0f2a90594ca3169f24efc"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1571770 - Part 1: Stop using Preferences.jsm inside URLDecorationAnnotationsService.jsm; r=florian,baku a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D40843", "files": ["toolkit/components/antitracking/URLDecorationAnnotationsService.jsm"], "git_node": null, "git_parents": [null], "node": "f30101f36b4d32e428b8f78c82dc399bae0f3ad6", "parents": ["ef2dbdb0271b8344aec22b0f23a8e5fb4d607a48"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1571770 - Part 2: Package antitracking.manifest in packaged builds; r=baku a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D40844", "files": ["browser/installer/package-manifest.in", "mobile/android/installer/package-manifest.in"], "git_node": null, "git_parents": [null], "node": "e7fc00beb048981f0c7eba7a7fcfb7e5ec9b5c31", "parents": ["f30101f36b4d32e428b8f78c82dc399bae0f3ad6"], "tags": []}, {"author": "Jed Davis \u003cjld@mozilla.com\u003e", "branch": "default", "desc": "Bug 1565744. r=kmag,bobowen a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39380", "files": ["dom/ipc/MemMapSnapshot.cpp"], "git_node": null, "git_parents": [null], "node": "fdde0d73c765753cf50517cd9404ea191e528115", "parents": ["e7fc00beb048981f0c7eba7a7fcfb7e5ec9b5c31"], "tags": []}, {"author": "Bob Owen \u003cbobowencode@gmail.com\u003e", "branch": "default", "desc": "Bug 1570358: Check validity of enums before playing back Moz2D RecordedEvents. r=jrmuizel a=RyanVM", "files": ["gfx/2d/InlineTranslator.cpp", "gfx/2d/Logging.h", "gfx/2d/RecordedEvent.h", "gfx/2d/RecordedEventImpl.h", "gfx/2d/RecordingTypes.h", "gfx/layers/CanvasDrawEventRecorder.h", "gfx/layers/RecordedCanvasEventImpl.h", "layout/printing/DrawEventRecorder.h"], "git_node": null, "git_parents": [null], "node": "b2e1689352c5fbf9b9ffdd42901b1d1a6bd7e014", "parents": ["fdde0d73c765753cf50517cd9404ea191e528115"], "tags": []}, {"author": "longsonr \u003clongsonr@gmail.com\u003e", "branch": "default", "desc": "Bug 1559715 r=dholbert,mstange a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36874", "files": ["dom/svg/SVGFEImageElement.cpp"], "git_node": null, "git_parents": [null], "node": "9a9f7c1cd4c0d1f5c2f73bb86dd0a2e2de7a4535", "parents": ["b2e1689352c5fbf9b9ffdd42901b1d1a6bd7e014"], "tags": []}, {"author": "Jan-Ivar Bruaroey \u003cjib@mozilla.com\u003e", "branch": "default", "desc": "Bug 1564588 - No longer persist third-party permission. r=johannh a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D40897", "files": ["browser/modules/webrtcUI.jsm"], "git_node": null, "git_parents": [null], "node": "312a7ec149de0ab5d6bb330db9771b8f28c2ac63", "parents": ["9a9f7c1cd4c0d1f5c2f73bb86dd0a2e2de7a4535"], "tags": []}, {"author": "Jan-Ivar Bruaroey \u003cjib@mozilla.com\u003e", "branch": "default", "desc": "Bug 1564588 - Add test for third-party permission prompt wo/remember this decision. r=johannh a=RyanVM\n\nDepends on D40897\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41435", "files": ["browser/base/content/test/webrtc/browser.ini", "browser/base/content/test/webrtc/browser_devices_get_user_media_in_xorigin_frame.js", "browser/base/content/test/webrtc/get_user_media_in_xorigin_frame.html"], "git_node": null, "git_parents": [null], "node": "2b6ef3ea5181aab4559623e519a156cfdf589370", "parents": ["312a7ec149de0ab5d6bb330db9771b8f28c2ac63"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1542181 - IndexedDB.jsm Transaction promiseCompleted should reject on a transaction abort event. r=kmag a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36822", "files": ["toolkit/modules/IndexedDB.jsm"], "git_node": null, "git_parents": [null], "node": "491c5c3abe3a81b64fb4d0430d652af30eecb032", "parents": ["2b6ef3ea5181aab4559623e519a156cfdf589370"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1542181 - Abort storage.local IDB data migration if the extension or app is shutting down. r=robwu,mixedpuppy a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36033", "files": ["toolkit/components/extensions/ExtensionStorageIDB.jsm", "toolkit/components/extensions/test/xpcshell/test_ext_storage_idb_data_migration.js"], "git_node": null, "git_parents": [null], "node": "9d645412277f75684ce8485d3ebbe9db88726a15", "parents": ["491c5c3abe3a81b64fb4d0430d652af30eecb032"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1542181 - Mark newly installed extensions as migrated to the storage.local IDB backend. r=robwu,mixedpuppy a=RyanVM\n\nDepends on D36033\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36034", "files": ["toolkit/components/extensions/Extension.jsm", "toolkit/components/extensions/test/xpcshell/test_ext_storage_idb_data_migration.js"], "git_node": null, "git_parents": [null], "node": "85a391d2b86900ed19c559187bb47d9790985a72", "parents": ["9d645412277f75684ce8485d3ebbe9db88726a15"], "tags": []}, {"author": "Alexandre Poirot \u003cpoirot.alex@gmail.com\u003e", "branch": "default", "desc": "Bug 1567210 - Ensure resuming page execution when the toolbox closes. r=loganfsmyth a=RyanVM\n\npre and post nest functions are rather something specific to the thread actor\nor the event loop classes. The only reason it is today on the target actors\nis that the list of targetted windows can be different based on the target.\nBut we can figure out, from the thread actor's debuggees, the list of these\nwindows that are inspected by the thread actor.\nI think that it is better that was as it better reflect what actual final\nglobals, the thread actor is interacting with. The previous code could possibly\nintroduce differences between globals for which we pauses the timeouts and events\nversus the globals being inspected by the thread actor.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39186", "files": ["devtools/server/actors/targets/browsing-context.js", "devtools/server/actors/targets/content-process.js", "devtools/server/actors/targets/parent-process.js", "devtools/server/actors/thread.js", "devtools/server/actors/utils/event-loop.js", "devtools/server/tests/unit/test_breakpoint-25.js", "devtools/server/tests/unit/testactors.js", "devtools/server/tests/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "377d42633864bab4eebe4425e592cdaf8e52bf9c", "parents": ["85a391d2b86900ed19c559187bb47d9790985a72"], "tags": []}, {"author": "Timothy Nikkel \u003ctnikkel@gmail.com\u003e", "branch": "default", "desc": "Bug 1569215. In StackingContextHelper constructor pass parent scale to ChooseScale. r=jrmuizel a=RyanVM\n\nThis might seem like we are including the parent scale twice because it is also included in mInheritedTransform but FrameLayerBuilder::ChooseScale only incorporates the passed in scale when combining it with a scale computed purely based on the local transform induced by this stacking context item.\n\nThis also fixes bug 1564698 and doesn't regress bug 1495163 (the only testcase I can still find for the regressing bug, bug 1415987).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39867", "files": ["gfx/layers/wr/StackingContextHelper.cpp", "layout/reftests/transform/1569215-1-ref.html", "layout/reftests/transform/1569215-1.html", "layout/reftests/transform/reftest.list"], "git_node": null, "git_parents": [null], "node": "6dcfe7b2a1c58e4fbe8693cdf33937a262b788ca", "parents": ["377d42633864bab4eebe4425e592cdaf8e52bf9c"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1570861 - Editor should store text node in mCachedSelectionNode to pass previous selected node/offset to spell checker r=masayuki a=RyanVM\n\nWhen using `\u003ctextarea\u003e`, spell checker sometimes check spell when editing last text node. Because editor passes invalid previous selection node and offset via `HandleInlineSpellCheck`.\n\nAlthough previous selected node uses `mCachedSelectionNode` that is stored by `BeforeEdit`, when this occurs, it isn't text node.\n\nWhen editing last text node in `\u003ctextarea\u003e`, anchror node might be root node, not current text node. So we should use text node instead when this is inserting text operation.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D40368", "files": ["editor/libeditor/TextEditRules.cpp"], "git_node": null, "git_parents": [null], "node": "022a270e63d9c9360be162ac7f457725e213b86d", "parents": ["6dcfe7b2a1c58e4fbe8693cdf33937a262b788ca"], "tags": []}, {"author": "Scott \u003cscott.downe@gmail.com\u003e", "branch": "default", "desc": "Bug 1570192 - Potential perf fixes in DS image onSeen. r=Mardak a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41217", "files": ["browser/components/newtab/content-src/components/DiscoveryStreamComponents/DSImage/DSImage.jsx", "browser/components/newtab/data/content/activity-stream.bundle.js", "browser/components/newtab/test/unit/content-src/components/DiscoveryStreamComponents/DSImage.test.jsx"], "git_node": null, "git_parents": [null], "node": "6b5f7122a0b345b2ef35ac771b7c88476df0d95a", "parents": ["022a270e63d9c9360be162ac7f457725e213b86d"], "tags": []}, {"author": "Scott \u003cscott.downe@gmail.com\u003e", "branch": "default", "desc": "Bug 1568932 - reverting PR #5111 due to perf regression (#5210). r=Mardak a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41213", "files": ["browser/components/newtab/content-src/components/DiscoveryStreamComponents/DSImage/DSImage.jsx", "browser/components/newtab/data/content/activity-stream.bundle.js"], "git_node": null, "git_parents": [null], "node": "d3d2b884f3b80529c4269d77e708d63a39ad4c79", "parents": ["6b5f7122a0b345b2ef35ac771b7c88476df0d95a"], "tags": []}], "date": 1565628071, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "11761": {"changesets": [{"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1565507 - Enable default theme on theme uninstallation r=aswan a=RyanVM\n\n... and re-enable the original theme when the uninstallation is undone,\niff it was enabled before.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39381", "files": ["toolkit/mozapps/extensions/internal/XPIDatabase.jsm", "toolkit/mozapps/extensions/internal/XPIInstall.jsm", "toolkit/mozapps/extensions/test/browser/browser_html_list_view.js", "toolkit/mozapps/extensions/test/xpcshell/test_webextension_theme.js"], "git_node": null, "git_parents": [null], "node": "a6ce868f8d1c9fc282a2843a17a8cac299021f95", "parents": ["d3d2b884f3b80529c4269d77e708d63a39ad4c79"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1565919 - Don't separate words by contextual-based character. r=Ehsan a=RyanVM\n\nOriginal regression was by bug 1362858, and bug 1418629 wasn't enough to fix.\n\nBy bug 1362858, we use `CHAR_CLASS_SEPARATOR` in additional to DOM word separator. But some characters such as single quote, `@` and etc are `CHAR_CLASS_SEPARATOR`, so we may check spell by incomplete word.\n\nWe shouldn't separate word by characters that is email part, URL part or conditional punctuation.\n\nAnd I also update test cases for this situation. `\u003ctextarea\u003e` is better for spell checking since it can has multiple anonymous text nodes.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39829", "files": ["editor/libeditor/tests/spellcheck.js", "editor/spellchecker/tests/test_bug1418629.html", "extensions/spellcheck/src/mozInlineSpellWordUtil.cpp"], "git_node": null, "git_parents": [null], "node": "f302b058e8db005da897478b471ce58c03a3909f", "parents": ["a6ce868f8d1c9fc282a2843a17a8cac299021f95"], "tags": []}, {"author": "Bob Owen \u003cbobowencode@gmail.com\u003e", "branch": "default", "desc": "Bug 1567054: Always call EnsureTarget in CanvasRenderingContext2D::GetSurfaceSnapshot. r=jrmuizel a=RyanVM\n\nThis reverts to the previous behavior when the function was defined in the\nheader file, where we always called EnsureTarget first. Not doing this\nintroduces an as yet unexplained performance issue in certain circumstances.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41230", "files": ["dom/canvas/CanvasRenderingContext2D.cpp"], "git_node": null, "git_parents": [null], "node": "b0454be04d9e416c9f63c65cf1d465a698b5d4c5", "parents": ["f302b058e8db005da897478b471ce58c03a3909f"], "tags": []}, {"author": "Andrew Swan \u003caswan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1569135 Fix --screenshot r=kmag a=RyanVM\n\nThis patch ressurects HiddenFrame.jsm and uses it when handling\nthe --screenshot command line argument to load the requested page\nin a content process.  The actual logic for grabbing the image is\nalso ported to a JSWindowActor.  The test for this feature remains\nsuboptimal as described in the bug.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D40148", "files": ["browser/base/content/test/static/browser_all_files_referenced.js", "browser/base/content/test/static/browser_parsable_css.js", "browser/components/extensions/test/browser/browser_ext_webRequest.js", "browser/components/shell/HeadlessShell.jsm", "browser/components/shell/ScreenshotChild.jsm", "browser/components/shell/moz.build", "browser/components/uitour/test/browser_no_tabs.js", "toolkit/modules/moz.build"], "git_node": null, "git_parents": [null], "node": "f80d1353670b6519a5621349c9e51aa1efb566ad", "parents": ["b0454be04d9e416c9f63c65cf1d465a698b5d4c5"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1570673 - Add mochitest. r=bwc a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D40597", "files": ["dom/media/tests/mochitest/mochitest.ini", "dom/media/tests/mochitest/test_peerConnection_disabledVideoPreNegotiation.html"], "git_node": null, "git_parents": [null], "node": "0291822afd2da38c59d12ff0fee97fb5ae34432f", "parents": ["f80d1353670b6519a5621349c9e51aa1efb566ad"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1570673 - Add an active state to VideoFrameConverter and propagate it from MediaPipeline. r=bwc a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D40598", "files": ["dom/media/VideoFrameConverter.h", "dom/media/gtest/TestVideoFrameConverter.cpp", "media/webrtc/signaling/src/mediapipeline/MediaPipeline.cpp"], "git_node": null, "git_parents": [null], "node": "c63aa7985beb8f697ef2442b28f236593cf67107", "parents": ["0291822afd2da38c59d12ff0fee97fb5ae34432f"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1570673 - Update last frame's time on same-frame-ticks. r=bwc a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D40599", "files": ["dom/media/VideoFrameConverter.h", "dom/media/gtest/TestVideoFrameConverter.cpp"], "git_node": null, "git_parents": [null], "node": "1b6a325b60bae842ccd150ba96c02ce7349a7666", "parents": ["c63aa7985beb8f697ef2442b28f236593cf67107"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1571349 - Fix unwanted reflows on message hover. r=jdescottes a=RyanVM\n\nWe were adding a before pseudo element on message hover, which\nwas causing reflows (which are quite expansive in console).\nWe fix this by always rendering a before pseudo element,\nonly changing its background color on hover.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D40590", "files": ["devtools/client/themes/webconsole.css"], "git_node": null, "git_parents": [null], "node": "48cb377f63cf6de0221656201a1f867ad5ba5440", "parents": ["1b6a325b60bae842ccd150ba96c02ce7349a7666"], "tags": []}, {"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1571913 - Quantumbar: Allow keyword offers to specify whether to show the keyword, and fix secondary text color when there's no title. r=dao a=RyanVM\n\nReplace the \"is heuristic?\" logic for hiding keywords in keyword offers with something more flexible. Here's how the top sites extension uses this new `keywordOffer` payload property: https://github.com/0c0w3/top-sites-experiment/commit/8408d13d2f80478ad04f6b7a2927280cc97032f1\n\nWhen a result's title is hidden, use the title color for the secondary color.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D40898", "files": ["browser/components/urlbar/UrlbarInput.jsm", "browser/components/urlbar/UrlbarProviderUnifiedComplete.jsm", "browser/components/urlbar/UrlbarResult.jsm", "browser/components/urlbar/UrlbarUtils.jsm", "browser/components/urlbar/UrlbarView.jsm", "browser/docs/AddressBar.rst", "browser/themes/shared/urlbar-autocomplete.inc.css"], "git_node": null, "git_parents": [null], "node": "70aa6961b410e14b94220824d48d6ed00ad21c6c", "parents": ["48cb377f63cf6de0221656201a1f867ad5ba5440"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1572139 - Enable sending UI notifications for ETP on mobile. r=baku a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41037", "files": ["browser/app/profile/firefox.js", "modules/libpref/init/StaticPrefList.h"], "git_node": null, "git_parents": [null], "node": "513c1ea45a6a4e630e079f5214d1f2c350c063f6", "parents": ["70aa6961b410e14b94220824d48d6ed00ad21c6c"], "tags": []}, {"author": "Liang-Heng Chen \u003cxeonchen@gmail.com\u003e", "branch": "default", "desc": "Bug 1572666 - enable telemetry on release channel; r=kershaw a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41346", "files": ["toolkit/components/telemetry/Histograms.json", "toolkit/components/telemetry/Scalars.yaml"], "git_node": null, "git_parents": [null], "node": "37a5c968f3363e7519fcea64d63e92e1f348a6d1", "parents": ["513c1ea45a6a4e630e079f5214d1f2c350c063f6"], "tags": []}], "date": 1565629446, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "11762": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset 377d42633864 (bug 1567210) for eslint failures.", "files": ["devtools/server/actors/targets/browsing-context.js", "devtools/server/actors/targets/content-process.js", "devtools/server/actors/targets/parent-process.js", "devtools/server/actors/thread.js", "devtools/server/actors/utils/event-loop.js", "devtools/server/tests/unit/test_breakpoint-25.js", "devtools/server/tests/unit/testactors.js", "devtools/server/tests/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "8ecc148a2fadc312c58f241222c0fcb024718827", "parents": ["37a5c968f3363e7519fcea64d63e92e1f348a6d1"], "tags": ["DEVEDITION_69_0b13_BUILD1", "DEVEDITION_69_0b13_RELEASE", "FIREFOX_69_0b13_BUILD1", "FIREFOX_69_0b13_RELEASE"]}], "date": 1565631385, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "11763": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 8ecc148a2fadc312c58f241222c0fcb024718827 with DEVEDITION_69_0b13_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "gi