c00b987d7394a65ba8", "parents": ["7f1c561e7389c0531b15519f4daa0ca76b6916e3"], "tags": []}, {"author": "Byron Campen [:bwc] \u003cdocfaraday@gmail.com\u003e", "branch": "default", "desc": "Bug 1558886: Don't expect exactly one ready stream once ICE is connected. r=mjf a=testonly\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36501", "files": ["media/mtransport/test/ice_unittest.cpp"], "git_node": null, "git_parents": [null], "node": "5278fcb90ca1bbaf639c481e47a52a98fbc1adf5", "parents": ["41d17f1283880b2ebd74f9c00b987d7394a65ba8"], "tags": []}, {"author": "Edwin Gao \u003cegao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1555454 - disable permafailing tests on macosx1014, migrate mochitest-browser-chrome to macosx1014 r=jmaher a=testonly\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38783", "files": ["browser/base/content/test/general/browser.ini", "browser/base/content/test/performance/browser.ini", "browser/base/content/test/performance/io/browser.ini", "browser/base/content/test/permissions/browser.ini", "browser/base/content/test/webrtc/browser.ini", "browser/components/extensions/test/browser/browser-common.ini", "browser/components/sessionstore/test/browser.ini", "browser/components/shell/test/browser.ini", "browser/components/urlbar/tests/browser/browser.ini", "browser/components/urlbar/tests/legacy/browser.ini", "layout/xul/test/browser.ini", "taskcluster/ci/test/test-platforms.yml", "taskcluster/ci/test/test-sets.yml", "toolkit/mozapps/extensions/test/xpinstall/browser.ini", "xpcom/tests/gtest/moz.build"], "git_node": null, "git_parents": [null], "node": "4d7e8d12749d7b99a7f2bd613193fa93b4eace49", "parents": ["5278fcb90ca1bbaf639c481e47a52a98fbc1adf5"], "tags": []}], "date": 1564166776, "git_changesets": [null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "11641": {"changesets": [{"author": "sotaro \u003csotaro.ikeda.g@gmail.com\u003e", "branch": "default", "desc": "Bug 1562847 - for beta - Disable double buffering with compositor when device reset happens r=nical, bas a=RyanVM", "files": ["gfx/config/gfxVars.h", "gfx/ipc/GPUParent.cpp", "gfx/ipc/GPUProcessManager.cpp", "gfx/layers/d3d11/CompositorD3D11.cpp", "gfx/layers/d3d11/MLGDeviceD3D11.cpp", "gfx/layers/ipc/CompositorBridgeParent.cpp", "gfx/thebes/gfxPlatform.cpp"], "git_node": null, "git_parents": [null], "node": "f4ff6dfe4a354e7314be414f09b3c72388b5946e", "parents": ["4d7e8d12749d7b99a7f2bd613193fa93b4eace49"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1568163: Don't return proxy wrappers from OuterDocAccessible::ChildAtPoint with eDeepestChild to prevent crashes when hit testing via XPCOM. r=yzen a=RyanVM\n\nOn Windows, OuterDocAccessible::GetChildAt can return a proxy wrapper for a remote document.\nThese aren't real Accessibles and shouldn't be returned except to the Windows a11y code (which doesn't use eDeepestChild).\nCalling ChildAtPoint on these will crash!\nTherefore, just return null in this case.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39135", "files": ["accessible/generic/OuterDocAccessible.cpp"], "git_node": null, "git_parents": [null], "node": "2e5cb51c62af4511c247739494c67028f76b3dc2", "parents": ["f4ff6dfe4a354e7314be414f09b3c72388b5946e"], "tags": []}, {"author": "Bob Owen \u003cbobowencode@gmail.com\u003e", "branch": "default", "desc": "Bug 1565848: Revert latest change to MITIGATION_DLL_SEARCH_ORDER. r=aklotz a=RyanVM\n\nThis is until any regressions can be fixed, see bug 1568850.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39357", "files": ["security/sandbox/chromium-shim/patches/with_update/patch_order.txt", "security/sandbox/chromium-shim/patches/with_update/revert_removal_of_app_dir_for_DLL_load.patch", "security/sandbox/chromium/sandbox/win/src/process_mitigations.cc", "security/sandbox/chromium/sandbox/win/src/security_level.h"], "git_node": null, "git_parents": [null], "node": "f2b6167e93e1a18662a6147893da8005cec49788", "parents": ["2e5cb51c62af4511c247739494c67028f76b3dc2"], "tags": []}], "date": 1564170887, "git_changesets": [null, null, null], "user": "btara@mozilla.com"}, "11642": {"changesets": [{"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1565853 - Enable MULTI_SZ and EXPAND_SZ for policies. r=agashlin a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37990", "files": ["toolkit/components/enterprisepolicies/WindowsGPOParser.jsm"], "git_node": null, "git_parents": [null], "node": "0add8fb5a7147f5359f1bf3e72f7cec2dca19755", "parents": ["f2b6167e93e1a18662a6147893da8005cec49788"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1567752 - Keep mInFontFaceset and mFontFaceSet in sync. r=heycam a=RyanVM\n\nWhen we unlink, we may null out the mFontFaceSet pointer, but still keep\nmInFontFaceset as true. Which can cause null dereference bugs as described in\ncomment 0.\n\nThis is mostly a speculative fix since I think that's a plausible cause for a\nbug like that, but it may not be the only cause for the crash.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38822", "files": ["layout/style/FontFace.cpp"], "git_node": null, "git_parents": [null], "node": "5cfd6b2055a3db37811b23944e7fd1e49ae3e423", "parents": ["0add8fb5a7147f5359f1bf3e72f7cec2dca19755"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1558866 - Use a list of chrome URLs to block. r=jaws,Gijs a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34933", "files": ["browser/components/enterprisepolicies/Policies.jsm"], "git_node": null, "git_parents": [null], "node": "e3a79b34348bf8502543b0cb4cf9c8384558befb", "parents": ["5cfd6b2055a3db37811b23944e7fd1e49ae3e423"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1560228 - Strip only leading question marks from search string. r=adw a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39206", "files": ["browser/components/urlbar/tests/browser/browser_keyword.js", "toolkit/components/places/UnifiedComplete.jsm", "toolkit/components/places/tests/unifiedcomplete/test_restrict_searchstring.js", "toolkit/components/places/tests/unifiedcomplete/test_search_engine_alias.js", "toolkit/components/places/tests/unifiedcomplete/test_tab_matches.js", "toolkit/components/places/tests/unifiedcomplete/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "77b48431ba6f4be89bc1497b16f22c086c2449dd", "parents": ["e3a79b34348bf8502543b0cb4cf9c8384558befb"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1567095 - fix styling of address inputs in preferences, r=dao a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39160", "files": ["browser/extensions/formautofill/skin/shared/editAddress.css"], "git_node": null, "git_parents": [null], "node": "ba70f4987ba615bdbe04a511e6bb22394d831785", "parents": ["77b48431ba6f4be89bc1497b16f22c086c2449dd"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1568246 - Disable Exceptions button if popup pref is locked. r=jaws a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39058", "files": ["browser/components/preferences/in-content/privacy.js"], "git_node": null, "git_parents": [null], "node": "50f29c924e44dba295948f687aedd15a9b8700ee", "parents": ["ba70f4987ba615bdbe04a511e6bb22394d831785"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Bug 1547952 - Increase maximum task run time for partials generation on non-asan platforms to 15 minutes. r=mhentges a=RyanVM\n\nDifferential Revision: http