 "browser/components/newtab/yamscripts.yml"], "git_node": null, "git_parents": [null], "node": "7dcdb13f0c8ebfca8ad8bd49dcb56ccb787c6f2e", "parents": ["c385e1de2be7392caff3a34e36f8b0b08420ba33"], "tags": []}, {"author": "David Major \u003cdmajor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1563252 - Merge LLVM fix for ASan with VS2019 r=froydnj\n\nhttps://reviews.llvm.org/rL357725\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36770", "files": ["build/build-clang/clang-win64.json", "build/build-clang/r357725-asan-vs2019.patch"], "git_node": null, "git_parents": [null], "node": "421d97550e01ac8400954ecde1383e6a2642ecb6", "parents": ["7dcdb13f0c8ebfca8ad8bd49dcb56ccb787c6f2e"], "tags": []}, {"author": "Jeff Muizelaar \u003cjrmuizel@gmail.com\u003e", "branch": "default", "desc": "Bug 1563359. Add a test for clipping and stroking text. r=mstange\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36825", "files": ["layout/reftests/backgrounds/reftest.list", "layout/reftests/backgrounds/text-clip-and-no-stroke.html", "layout/reftests/backgrounds/text-clip-and-stroke.html"], "git_node": null, "git_parents": [null], "node": "0e51ec69bb72792e0924da390b33657d8c2448dc", "parents": ["421d97550e01ac8400954ecde1383e6a2642ecb6"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1562389 - Set correct triple for rustc when host and target are different compiler type. r=froydnj\n\nWhen host and target are different compiler type, triple for rustc may be incorrect. If target is clang, host is always clang, not using host compiler type.\n\nExample, when host is clang-cl for windows, and target is clang for Android, host's triple for ructc sets `windows-gnu`, not `windows-msvc`.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36421", "files": ["build/moz.configure/rust.configure"], "git_node": null, "git_parents": [null], "node": "68ad44276058484da94325b0b221e6b638e52ae3", "parents": ["0e51ec69bb72792e0924da390b33657d8c2448dc"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1562389 - Better detect non-clang-cl native windows clang r=glandium\n\nWhen building Gecko/Android/aarch64 on Windows, `--target` parameter may not be incorrect value. Although `check_compiler`'s `info` is target compiler, clang on Windows is always detected as `clang-cl`, not `clang`.\n\n```\nc:/Users/mkato/.mozbuild/clang/bin/clang.exe -E  -dM - \u003c /dev/null\n...\n#define _MSC_VER 1916\n```\n\nSo even if using clang on Windows, not clang-cl, we should detect as 'clang' correctly\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36422", "files": ["build/moz.configure/toolchain.configure"], "git_node": null, "git_parents": [null], "node": "7dbb546e613875cec06e1615c42dd7c4266fe170", "parents": ["68ad44276058484da94325b0b221e6b638e52ae3"], "tags": []}, {"author": "shindli \u003cshindli@mozilla.com\u003e", "branch": "default", "desc": "Backed out 2 changesets (bug 1562389) for causing bustages in ../python/mozbuild/mozbuild/test/configure/test_toolchain_configure.py::WindowsToolchainTest::test_clang_cl CLOSED TREE\n\nBacked out changeset 7dbb546e6138 (bug 1562389)\nBacked out changeset 68ad44276058 (bug 1562389)", "files": ["build/moz.configure/rust.configure", "build/moz.configure/toolchain.configure"], "git_node": null, "git_parents": [null], "node": "41de4f2ef2136f650bf07e070e94a798173b8688", "parents": ["7dbb546e613875cec06e1615c42dd7c4266fe170"], "tags": []}, {"author": "Jeff Gilbert \u003cjgilbert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1563420 - Don't trigger fb-inval-count warning during resolve. r=lsalzman\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36858", "files": ["dom/canvas/WebGLFramebuffer.cpp", "dom/canvas/WebGLFramebuffer.h"], "git_node": null, "git_parents": [null], "node": "6a2bd09a6bf9aada14581e923408d7308479b76d",