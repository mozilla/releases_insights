s": [null], "node": "0c1b4097e9cbc127b07b7a8c11bd1af42dfcc9f8", "parents": ["c7bae7b13ad41ad2a1d8be34f9f377b00a313bf7"], "tags": []}, {"author": "Olli Pettay \u003cOlli.Pettay@helsinki.fi\u003e", "branch": "default", "desc": "Bug 1556579, try to make browser_html_options_ui_in_tab.js less racy, r=rpl, a=test-only\n\nThe test starts to fail more often with Fission session history (which is still using sync IPC).\nThe change should guarantee that there is time to send and receive options-loaded message.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42574", "files": ["toolkit/mozapps/extensions/test/browser/browser_html_options_ui_in_tab.js"], "git_node": null, "git_parents": [null], "node": "a8863909ef9f54e342e1f9c5eb6f4ea9e89353d8", "parents": ["0c1b4097e9cbc127b07b7a8c11bd1af42dfcc9f8"], "tags": []}, {"author": "Jan Horak \u003cjhorak@redhat.com\u003e", "branch": "default", "desc": "Bug 1572455 Workaround for restoring minimized window in Wayland; r=stransky, a=RyanVM\n\nUnder Wayland the GTK does not send the correct window state event change\nwhen the window is iconified. We need to add a workaround for that to avoid\nunresponsive UI after restoring the window.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41219", "files": ["widget/gtk/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "ae05305802d31eadc76d11eb2c72014352e1678b", "parents": ["a8863909ef9f54e342e1f9c5eb6f4ea9e89353d8"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1574428: IAccessible2_2::relationTargetsOfType: Support 0 for all targets and fix off-by-one error. r=MarcoZ, a=RyanVM\n\n1. As per the spec, if maxTargets is 0, return all targets.\n2. Where maxTargets \u003e 0, fix the loop condition so it doesn't incorrectly fetch one more target than requested.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42446", "files": ["accessible/windows/ia2/ia2Accessible.cpp"], "git_node": null, "git_parents": [null], "node": "d60979a33a6c2b7b186f79073816c22c93946794", "parents": ["ae05305802d31eadc76d11eb2c72014352e1678b"], "tags": []}, {"author": "Logan Smyth \u003cloganfsmyth@gmail.com\u003e", "branch": "default", "desc": "Bug 1575096 - Disable beforeunload/unload event-breakpoint UI until fixed. r=jlast, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42577", "files": ["devtools/server/actors/utils/event-breakpoints.js"], "git_node": null, "git_parents": [null], "node": "35080e7f003d851d9b1503505faca78d49f20c41", "parents": ["d60979a33a6c2b7b186f79073816c22c93946794"], "tags": []}], "date": 1566319756, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "11819": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nbn -\u003e e27e45641eb7\nca -\u003e fed9901c8f97\ncy -\u003e e23fc1ecf568\ndsb -\u003e f80dd35ad423\neo -\u003e c3df54b21746\nes-AR -\u003e 1b55414bd975\nes-MX -\u003e f96f9e5e43d6\nfr -\u003e ba23f3a1b86c\nhe -\u003e a823f988137e\nhsb -\u003e bc0c42d264fd\nid -\u003e 68003cc25555\nit -\u003e 42c51209981f\nkk -\u003e 46f6e213653c\nko -\u003e 937d0c129e96\nnb-NO -\u003e d830f16a17e6\nnn-NO -\u003e 06c0f31b9e20\npa-IN -\u003e ba90b66cd4e8\npt-BR -\u003e ab10382910a9\nro -\u003e 6ac0bc68e1bc\nsl -\u003e 29f8c6a7d081\nsr -\u003e be009c805e18\nte -\u003e d62da0dfae08\nth -\u003e 176155e69eac\ntr -\u003e 8fdfeb445fc3\nuk -\u003e f039188f0ac9", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "a3ad14c6651ade7030a813aaab237a6253d589c7", "parents": ["35080e7f003d851d9b1503505faca78d49f20c41"], "tags": []}], "date": 1566370835, "git_changesets": [null], "user": "ffxbld"}, "11820": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nbn -\u003e e27e45641eb7\nca -\u003e fed9901c8f97\ncy -\u003e e23fc1ecf568\ndsb -\u003e f80dd35ad423\neo -\u003e c3df54b21746\nes-AR -\u003e 1b55414bd975\nes-MX -\u003e f96f9e5e43d6\nfr -\u003e ba23f3a1b86c\nfy-NL -\u003e e76aac6f79c8\nhe -\u003e 906ed6dde59c\nhsb -\u003e bc0c42d264fd\nhu -\u003e a8761bcf302c\nid -\u003e 68003cc25555\nit -\u003e 42c51209981f\nkk -\u003e 46f6e213653c\nko -\u003e 937d0c129e96\nnb-NO -\u003e 61d5fbf22298\nnl -\u003e 64abfab2deb6\nnn-NO -\u003e 06c0f31b9e20\npa-IN -\u003e ba90b66cd4e8\npt-BR -\u003e ab10382910a9\nro -\u003e 6ac0bc68e1bc\nsl -\u003e 29f8c6a7d081\nsr -\u003e be009c805e18\nte -\u003e d62da0dfae08\nth -\u003e 176155e69eac\ntr -\u003e 8fdfeb445fc3\nuk -\u003e f039188f0ac9", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "73875843f8268b359906821466a2d15c523afbf3", "parents": ["a3ad14c6651ade7030a813aaab237a6253d589c7"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nfy-NL -\u003e e76aac6f79c8\nhe -\u003e 2806fc62200a\nnb-NO -\u003e 61d5fbf22298\nnl -\u003e 64abfab2deb6", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "6b5bb3e6a030541887b8955eaa68b6c1f3f274a9", "parents": ["73875843f8268b359906821466a2d15c523afbf3"], "tags": []}], "date": 1566374444, "git_changesets": [null, null], "user": "ffxbld"}, "11821": {"changesets": [{"author": "Gabriele Svelto \u003cgsvelto@mozilla.com\u003e", "branch": "default", "desc": "Bug 1282776 - Finalize crash reports for child process crashes happening too early r=froydnj a=RyanVM\n\nThis changes the way crash reports for child processes happening too early\nduring the child process' startup. Before bug 1547698 we wrote a partial\n.extra file with those crashes that lacked the process type. The user would\nnot be notified of those crashes until she restarted Firefox and even when\nsubmitted those crashes would be erroneously labeled as browser crashes.\n\nAfter bug 1547698 we stopped writing .extra files entirely for those crashes\nwhich left orphaned .dmp files among the pending crash reports.\n\nThis patch does three things to improve the situation:\n\n* It writes a partial .extra file so that the crashes are detected at the next\n  startup. So the user is still not notified directly of these crashes but she\n  can report them later.\n* It adds the process type to the .extra file so that the crash reporters are\n  labelled correctly.\n* It fixes a leak in the `pidToMinidump` hash-map. Since the crashes were\n  not finalized the `ChildProcessData` strucutre associated with them would\n  never be fred.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D40810", "files": ["dom/ipc/ContentParent.cpp", "dom/media/gmp/GMPParent.cpp", "dom/media/gmp/GMPParent.h", "dom/media/ipc/RDDChild.cpp", "dom/plugins/ipc/PluginModuleParent.cpp", "dom/plugins/ipc/PluginModuleParent.h", "gfx/ipc/GPUChild.cpp", "gfx/vr/ipc/VRChild.cpp", "ipc/glue/CrashReporterHost.cpp", "netwerk/ipc/SocketProcessParent.cpp", "security/sandbox/win/src/remotesandboxbroker/RemoteSandboxBrokerParent.cpp", "toolkit/crashreporter/nsDummyExceptionHandler.cpp", "toolkit/crashreporter/nsExceptionHandler.cpp", "toolkit/crashreporter/nsExceptionHandler.h", "toolkit/xre/nsEmbedFunctions.cpp", "xpcom/build/nsXULAppAPI.h"], "git_node": null, "git_parents": [null], "node": "522b14ff237200dc29a918ab477c083648df568d", "parents": ["6b5bb3e6a030541887b8955eaa68b6c1f3f274a9"], "tags": []}, {"author": "Bryce Seager van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1571081 - Make MediaKeys correctly specify a NS_INTERFACE_MAP_ENTRY for nsISupports. r=mccr8 a=RyanVM\n\nBug 1522547 overlooked the need for specifying map entries for both nsISupports\nand nsIDocumentActivity and only had the latter. This changeset adds the missing\nnsISupports case.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42563", "files": ["dom/media/eme/MediaKeys.cpp"], "git_node": null, "git_parents": [null], "node": "729d67dfacef969c9527b6492fbffbef181ce70d", "parents": ["522b14ff237200dc29a918ab477c083648df568d"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1567094 - Fix non-unified build in nsCSSRendering.cpp. r=jrmuizel a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41932", "files": ["layout/painting/nsCSSRendering.cpp"], "git_node": null, "git_parents": [null], "node": "b96a05e1dc18b6810eeca3dc23921416bc4a913b", "parents": ["729d67dfacef969c9527b6492fbffbef181ce70d"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1567094 - Rename some arguments to avoid being unnecessarily verbose. r=jrmuizel a=RyanVM\n\nComputedStyle* aComputedStyle doesn't provide any extra value over just aStyle.\n\nLots of these should be const and what not, oh well.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41933", "files": ["layout/painting/nsCSSRendering.cpp", "layout/painting/nsCSSRendering.h"], "git_node": null, "git_parents": [null], "node": "21377c2206ec2a520bcd95a05c8b11ec95f3de30", "parents": ["b96a05e1dc18b6810eeca3dc23921416bc4a913b"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1567094 - Make GetVisitedDependentColor const-friendly. r=jrmuizel a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41934", "files": ["layout/style/ComputedStyle.cpp", "layout/style/ComputedStyle.h"], "git_node": null, "git_parents": [null], "node": "34d66455046cf7fde9d9221f0aeb786724d0ede0", "parents": ["21377c2206ec2a520bcd95a05c8b11ec95f3de30"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1567094 - Make WebRender look at visited dependent border colors. r=jrmuizel a=RyanVM\n\nWe do have test coverage for this\n(layout/style/test/test_visited_reftests.html), but it seems that that uses\nsnapshotWindow() / drawWindow() and that may not use the WR code paths? It seems\nwe may be missing a bit of test coverage there. Is this expected?\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41935", "files": ["layout/painting/nsCSSRendering.cpp"], "git_node": null, "git_parents": [null], "node": "183af4e0079fc0f5e5adcda4947eebe05781e6b8", "parents": ["34d66455046cf7fde9d9221f0aeb786724d0ede0"], "tags": []}, {"author": "Toshihito Kikuchi \u003ctkikuchi@mozilla.com\u003e", "branch": "default", "desc": "Bug 1573051 - Use both SHParseDisplayName and CreateUri to validate a uri. r=aklotz a=RyanVM\n\nFor launching with an external protocol handler on Windows, we validate a uri\nbefore sending it to `ShellExecute`, by converting a string into `PIDL` using\n`SHParseDisplayName` and extract a string back from PIDL using\n`IShellFolder::GetDisplayNameOf`.  The problem was that if a fragment, a\nstring following a hash mark (#), is always dropped after this validation.\nThis is caused by the intended design of Windows.\n\nA proposed fix is to use `CreateUri` for validation, which is used behind\n`IShellFolder::GetDisplayNameOf`.  However, we also keep `SHParseDisplayName`\nbecause there are cases where `CreateUri` succeeds while `SHParseDisplayName`\nfails such as a non-existent `file:` uri and we want to keep the same\nvalidation result for those cases.\n\nAdding `CreateUri` broke MinGW build because of our toolkit issue.  We use\ndynamic linking for MinGW build in the meantime.\n\nThis patch adds a new unittest to make sure the new validation logic\nbehaves the same as the old one except the fragment issue.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42041", "files": ["testing/cppunittest.ini", "toolkit/library/moz.build", "uriloader/exthandler/win/nsMIMEInfoWin.cpp", "widget/windows/ShellHeaderOnlyUtils.h", "widget/windows/UrlmonHeaderOnlyUtils.h", "widget/windows/moz.build", "widget/windows/tests/TestUriValidation.cpp", "widget/windows/tests/TestUrisToValidate.h", "widget/windows/tests/moz.build"], "git_node": null, "git_parents": [null], "node": "894ca270cd7e5b15d5ed7a0a1baa87b0c11e4b74", "parents": ["183af4e0079fc0f5e5adcda4947eebe05781e6b8"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe.birchill@mozilla.com\u003e", "branch": "default", "desc": "Bug 1573648 - Introduce ToDoubleAllowTrailingChars and ToFloatAllowTrailingChars. r=njn a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42239", "files": ["xpcom/string/nsStringObsolete.cpp", "xpcom/string/nsTString.h", "xpcom/tests/gtest/TestStrings.cpp"], "git_node": null, "git_parents": [null], "node": "40120557f1e2e80a7e4022b8ecc0b740ce1841b5", "parents": ["894ca270cd7e5b15d5ed7a0a1baa87b0c11e4b74"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe.birchill@mozilla.com\u003e", "branch": "default", "desc": "Bug 1573648 - Use ToFloatAllowTrailingChars for parsing scale values in meta viewport tag. r=botond a=RyanVM\n\nFrom the spec \u003chttps://drafts.csswg.org/css-device-adapt/#parsing-algorithm\u003e\n\n  If a prefix of property-value can be converted to a number using strtod,\n  the value will be that number. The remainder of the string is ignored.\n\nNote that nsTSubStrubg::ToInteger() allows trailing characters as it is so that\nwe don't need to modify the width/height parser for meta viewport.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42240", "files": ["dom/base/Document.cpp", "dom/base/test/mochitest.ini", "dom/base/test/test_meta_viewport_initial_scale_with_trailing_characters.html", "dom/base/test/test_meta_viewport_width_with_trailing_characters.html"], "git_node": null, "git_parents": [null], "node": "750a7788ab0382d51c8fe04b9203a078720511aa", "parents": ["40120557f1e2e80a7e4022b8ecc0b740ce1841b5"], "tags": []}, {"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1574246 - Quantumbar: Don't collapse secondary text for search results when the title is empty. r=dao a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42419", "files": ["browser/themes/shared/urlbar-autocomplete.inc.css"], "git_node": null, "git_parents": [null], "node": "0a5ba27e416309d1d68b1b2fc539496731d52ae3", "parents": ["750a7788ab0382d51c8fe04b9203a078720511aa"], "tags": []}], "date": 1566379354, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "ccoroiu@mozilla.com"}, "11822": {"changesets": [{"author": "Daniel Varga \u003cdvarga@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset b96a05e1dc18 (bug 1567094) for build bustage at build/src/layout/painting/nsCSSRendering.cpp a=backout", "files": ["layout/painting/nsCSSRendering.cpp"], "git_node": null, "git_parents": [null], "node": "c6b3e3f56fa5b7ba3ad81f30f2cfa7cab0340303", "parents": ["0a5ba27e416309d1d68b1b2fc539496731d52ae3"], "tags": []}], "date": 1566382586, "git_changesets": [null], "user": "dvarga@mozilla.com"}, "11823": {"changesets": [{"author": "Daniel Varga \u003cdvarga@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 894ca270cd7e (bug 1573051) for build bustage at build/src/obj-firefox/dist/include/mozilla/UniquePtr.h a=backout", "files": ["testing/cppunittest.ini", "toolkit/library/moz.build", "uriloader/exthandler/win/nsMIMEInfoWin.cpp", "widget/windows/ShellHeaderOnlyUtils.h", "widget/windows/UrlmonHeaderOnlyUtils.h", "widget/windows/moz.build", "widget/windows/tests/TestUriValidation.cpp", "widget/windows/tests/TestUrisToValidate.h", "widget/windows/tests/moz.build"], "git_node": null, "git_parents": [null], "node": "ebf7ea8d8848f8b7ac895b550ebbb1d