919d1f275124e99dce0707ab97b56c7c09b7845", "parents": ["8ceebaf1ded681476f1209d818c4eba4ba67f7f2"], "tags": []}], "date": 1562670032, "git_changesets": [null, null], "user": "ffxbld"}, "11542": {"changesets": [{"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1563971 - part 1: Fix promote graphs by passing down jobs instead of tasks r=mtabara a=release\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37231", "files": ["taskcluster/taskgraph/transforms/partner_signing.py"], "git_node": null, "git_parents": [null], "node": "7f7392be9ddbf634afd810f5e0aa7639a6560e30", "parents": ["f919d1f275124e99dce0707ab97b56c7c09b7845"], "tags": []}, {"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1563971 - part 2: geckoview, use update-channel instead of hardcoded file name r=mtabara a=release\n\nDepends on D37231\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37232", "files": ["taskcluster/taskgraph/transforms/beetmover_geckoview.py", "taskcluster/taskgraph/util/declarative_artifacts.py"], "git_node": null, "git_parents": [null], "node": "50c84e8e8e469b589414af70068d0da99199d565", "parents": ["7f7392be9ddbf634afd810f5e0aa7639a6560e30"], "tags": []}], "date": 1562674990, "git_changesets": [null, null], "user": "jlorenzo@mozilla.com"}, "11543": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 9cdcc170dc1a51fc14a10d38f8aa2237d9928ba4 with FIREFOX_69_0b3_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "7958099a307c20f29c0c6c8d1492d026da8fa8f3", "parents": ["50c84e8e8e469b589414af70068d0da99199d565"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release DONTBUILD", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "6aeeb84a581e001194029ec57795f444dc546e05", "parents": ["7958099a307c20f29c0c6c8d1492d026da8fa8f3"], "tags": []}], "date": 1562681477, "git_changesets": [null, null], "user": "ffxbld"}, "11544": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 9cdcc170dc1a51fc14a10d38f8aa2237d9928ba4 with DEVEDITION_69_0b3_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "a5c24b617c1383f728266fae85b9c277bff4789b", "parents": ["6aeeb84a581e001194029ec57795f444dc546e05"], "tags": []}], "date": 1562681678, "git_changesets": [null], "user": "ffxbld"}, "11545": {"changesets": [{"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1409773 - Use WebRender instead of fallback for border raster images. r=jrmuizel a=RyanVM\n\nBefore this patch, we would use fallback for all border images. Now for\nall but vector images we will use the WebRender border images\nprimitives. Vector images are an exception because the fallback is\nclever in that it upscales the vector image and clips to only draw the\nregion it requires. This avoids artifacting but to do something similar\nfor WebRender as it is currently defined, we would increase our CPU and\nmemory footprint as we would need to produce the entire vector image\nupscaled, not just the parts we need. In the future we should change\nWebRender to accept different image resources for each of the segments.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37093", "files": ["gfx/webrender_bindings/WebRenderAPI.cpp", "gfx/webrender_bindings/WebRenderAPI.h", "gfx/webrender_bindings/src/bindings.rs", "layout/forms/nsFieldSetFrame.cpp", "layout/painting/nsCSSRendering.cpp", "layout/painting/nsCSSRendering.h", "layout/painting/nsCSSRenderingBorders.cpp", "layout/painting/nsImageRenderer.h", "layout/reftests/border-image/reftest.list", "layout/reftests/bugs/reftest.list", "layout/reftests/css-break/reftest.list"], "git_node": null, "git_parents": [null], "node": "cac8c357f51faf76e0287e84f18c1e658374a810", "parents": ["a5c24b617c1383f728266fae85b9c277bff4789b"], "tags": []}, {"author": "Daniel Holbert \u003cdholbert@cs.stanford.edu\u003e", "branch": "default", "desc": "Bug 1563050: Treat table-cells with contain:layout as if they had no baseline. r=TYLin a=RyanVM\n\nThis makes us pass web platform test contain-layout-baseline-004.html (i.e. it\nmakes us treat that test's 'contain:layout' table-cell as having no baseline,\nso we align its bottom edge with the other cell's actual baseline, as the test\nexpects).\n\nThis is required by the spec text at [1] which excludes most table parts but\nincludes table cells, and says \"the containing element is treated as having no\nbaseline\".\n\n[1] https://drafts.csswg.org/css-contain/#containment-layout\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37118", "files": ["layout/tables/nsTableCellFrame.cpp", "testing/web-platform/meta/css/css-contain/contain-layout-baseline-004.html.ini"], "git_node": null, "git_parents": [null], "node": "b38ee676c48b833f5913bb16645dbb2fac927317", "parents": ["cac8c357f51faf76e0287e84f18c1e658374a810"], "tags": []}, {"author": "Daniel Holbert \u003cdholbert@cs.stanford.edu\u003e", "branch": "default", "desc": "Bug 1487493: Remove early-beta restriction on CSS Containment (i.e. let it ride the trains to release). r=TYLin a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37303", "files": ["modules/libpref/init/StaticPrefList.h"], "git_node": null, "git_parents": [null], "node": "b6dae45b2816bd16076dc736562964aba65d2ae5", "parents": ["b38ee676c48b833f5913bb16645dbb2fac927317"], "tags": []}], "date": 1562723646, "git_changesets": [null, null, null], "user": "dluca@mozilla.com"}, "11546": {"changesets": [{"a