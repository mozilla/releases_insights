 -\u003e 70ec3d3de0b0\ngl -\u003e e2f54a313383\ngn -\u003e b72db57873ac\ngu-IN -\u003e 21909020b030\nhe -\u003e ad3020812202\nhi-IN -\u003e 1e185de38191\nhr -\u003e 364b1a28020b\nhsb -\u003e b3def46137cc\nhu -\u003e 3922ae582680\nhy-AM -\u003e bee0e03c6471\nia -\u003e 2d951db38c4c\nid -\u003e ccf4365646e5\nis -\u003e 996d4b424a76\nit -\u003e 97cf7b67c8d0\nja -\u003e b6a839416221\nja-JP-mac -\u003e a865ffcc3b33\nka -\u003e 4430e6136f93\nkab -\u003e 9386c91baac4\nkk -\u003e 505e07f72f3e\nkm -\u003e bc6ea48585e5\nkn -\u003e 377074b0c5fd\nko -\u003e c17562d85f29\nlij -\u003e 23f11b724078\nlo -\u003e removed\nlt -\u003e 459086f6dd63\nltg -\u003e removed\nlv -\u003e 7b8be8666f38\nmk -\u003e 46a0281c9d3f\nmr -\u003e 4201f21ee660\nms -\u003e 1ed42a2d716d\nmy -\u003e 2fd821dbee2f\nnb-NO -\u003e 69604a7141f6\nne-NP -\u003e 86f81ae0b656\nnl -\u003e 638ce88cfa9c\nnn-NO -\u003e 3c4cea7ab1c8\noc -\u003e a491984a57ec\npa-IN -\u003e c7defc89a8ce\npl -\u003e 002ee5745100\npt-BR -\u003e 45e2281bbc58\npt-PT -\u003e 6be8aea631cd\nrm -\u003e 3961a374d76b\nro -\u003e 2cff835a4561\nru -\u003e 14e3d078057d\nsi -\u003e c2a2f9026325\nsk -\u003e d76ebc48d1cf\nsl -\u003e 319dc3cbded6\nson -\u003e 89cb21264b30\nsq -\u003e 0bb89b45c26c\nsr -\u003e 2956bcdcef2b\nsv-SE -\u003e 3074a7f378fd\nta -\u003e 9f86162965ac\nte -\u003e d0ccfa6d57b3\nth -\u003e d793824e0b8b\ntl -\u003e removed\ntr -\u003e 5f4763e09454\ntrs -\u003e removed\nuk -\u003e 54633d916ec8\nur -\u003e 47f5556d3e3e\nuz -\u003e b6de3c432834\nvi -\u003e 8f4b99442fd0\nwo -\u003e removed\nxh -\u003e 6b7c8ab276d3\nzh-CN -\u003e 3386058ff4e9\nzh-TW -\u003e 3bafbeef2623", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "bcbdec13649cd4c0d3b8bdd1023e488816fce03d", "parents": ["bfbe04be6adf52ce10a8bf19043827692c4877fc"], "tags": ["DEVEDITION_69_0b1_BUILD1"]}], "date": 1561972173, "git_changesets": [null, null], "user": "ffxbld"}, "11524": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging bcbdec13649cd4c0d3b8bdd1023e488816fce03d with DEVEDITION_69_0b1_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "8d56c246fb51ef4155456f77e8ac2de872f1fd17", "parents": ["bcbdec13649cd4c0d3b8bdd1023e488816fce03d"], "tags": []}], "date": 1561993763, "git_changesets": [null], "user": "ffxbld"}, "11525": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1562612 - Bump the timeout for Linux32 DevEdition builds to 4hr. r=Callek, a=release\nCLOSED TREE", "files": ["taskcluster/ci/build/linux.yml"], "git_node": null, "git_parents": [null], "node": "625005a94d4d324f9e9b9f14ebe8986dc6bdcc39", "parents": ["8d56c246fb51ef4155456f77e8ac2de872f1fd17"], "tags": ["DEVEDITION_69_0b1_BUILD2", "DEVEDITION_69_0b1_RELEASE"]}], "date": 1562012035, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "11526": {"changesets": [{"author": "Geoff Lankow \u003cgeoff@darktrojan.net\u003e", "branch": "THUNDERBIRD_68_VERBRANCH", "desc": "Bug 1529205 - Remove DateTimePickerParent's dependency on gBrowser; r=mconley a=jorgk\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35392", "files": ["browser/base/content/tabbrowser.js", "browser/modules/FormValidationHandler.jsm", "toolkit/content/widgets/browser-custom-element.js", "toolkit/modules/DateTimePickerParent.jsm"], "git_node": null, "git_parents": [null], "node": "db4f8b58bf16e6737ac31e115a9bb4f8e4b68945", "parents": ["80a61871ecfd082792b39ca68d3632fd334e91ef"], "tags": []}, {"author": "Emilio Cobos Alvarez \u003cemilio@crisal.io\u003e", "branch": "THUNDERBIRD_68_VERBRANCH", "desc": "Bug 1561288 - Don't override currentContent when focusing something on a shadow root. r=smaug a=jorgk DONTBUILD CLOSED TREE\n\nIt is wrong, what we're trying to focus is frame-\u003eGetContent() still.\n\nThis is not reproducible outside of Thunderbird because for it to happen the\nfocus manager needs to wrap around the start content.\n\nHere's what's going on:\n\n * We start with a \u003ctree\u003e focused, which is a shadow host.\n * There's nothing else to focus inside the \u003ctree\u003e, or after the \u003ctree\u003e in document order.\n * So we restart the search with a different tabindex (1), but find nothing before the tree (since all focusable elements before the tree also have tabindex 0), and we return wrongly in [1], instead of searching with tabindex 0 again afterwards. (Since the child frame is not focusable, we wrongly end up at [1], and returning early, since currentContent != frame-\u003eGetContent(), instead of keeping looking for the right thing to focus.)\n\nAs I said this cannot reproduce on content, as far as I can tell, so I'm not\nsure how to go about testing this, but all the shadow dom tab navigation tests\nkeep passing with this change.\n\n[1]: https://searchfox.org/mozilla-central/rev/06bd14ced96f25ff1dbd5352cb985fc0fa12a64e/dom/base/nsFocusManager.cpp#3560\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36196", "files": ["dom/base/nsFocusManager.cpp"], "git_node": null, "git_parents": [null], "node": "f0c0729a02198b423b995f2873adac7cb0b96435", "parents": ["db4f8b58bf16e6737ac31e115a9bb4f8e4b68945"], "tags": []}], "date": 1562015170, "git_changesets": [null, null], "user": "mozilla@jorgk.com"}, "11527": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 625005a94d4d324f9e9b9f14ebe8986dc6bdcc39 with DEVEDITION_69_0b1_BUILD2 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "ebdef926863c152bdb135506dab8e60f4320abf3", "parents": ["625005a94d4d324f9e9b9f14ebe8986dc6bdcc39"], "tags": []}], "date": 1562021302, "git_changesets": [null], "user": "ffxbld"}, "11528": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 625005a94d4d324f9e9b9f14ebe8986dc6bdcc39 with DEVEDITION_69_0b1_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "c2896b9c5dc2b346f8f8b6a5de677da6000dfe75", "parents": ["ebdef926863c152bdb135506dab8e60f4320abf3"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release DONTBUILD", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "75e5f62b44ed3a080f7863606863f1fd5e36b18a", "parents": ["c2896b9c5dc2b346f8f8b6a5de677da6000dfe75"], "tags": []}], "date": 1562078796, "git_changesets": [null, null], "user": "ffxbld"}, "11529": {"changesets": [{"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1551601 - When performing a cross process redirect update the loadInfo to have the correct browsingContext r=nika\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35839", "files": ["docshell/base/nsDocShell.cpp", "netwerk/base/LoadInfo.h", "netwerk/protocol/http/HttpChannelChild.cpp", "netwerk/protocol/http/HttpChannelParent.cpp", "netwerk/protocol/http/HttpChannelParent.h", "netwerk/protocol/http/PHttpChannel.ipdl"], "git_node": null, "git_parents": [null], "node": "1582b3ffe71226af68979a58b5852afa49ff939b", "parents": ["adc59d50adf815ad6764ff235f833a5ba74291b6"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1551738: [partner] Add partner-config repositories for esr68; r=nthomas\n\nDifferential Revision: https://phabricator.services.mozilla.com/D31184", "files": ["taskcluster/ci/config.yml"], "git_node": null, "git_parents": [null], "node": "199bcb54e5122b5e7ac2476c90288b2169db2013", "parents": ["1582b3ffe71226af68979a58b5852afa49ff939b"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1551738: Set snapcraft track for esr68; r=jlorenzo\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36226", "files": ["taskcluster/ci/release-secondary-snap-push/kind.yml", "taskcluster/ci/release-snap-push/kind.yml", "taskcluster/taskgraph/transforms/release_snap_push.py", "taskcluster/taskgraph/transforms/task.py"], "git_node": null, "git_parents": [null], "node": "7d964bfcda0e0aded01a4fb05a8405b9cb61bafd", "parents": ["199bcb54e5122b5e7ac2476c90288b2169db2013"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1557190: Update esr migration script for esr68; r=Callek\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36368", "files": ["testing/mozharness/configs/merge_day/release_to_esr.py", "testing/mozharness/scripts/merge_day/gecko_migration.py"], "git_node": null, "git_parents": [null], "node": "696aa5fa31ea5c39cee412a6cecfd4af19f845fd", "parents": ["7d964bfcda0e0aded01a4fb05a8405b9cb61bafd"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1561858 - Use only transforms outside of the subtree when computing the subtree transform to root. r=kats\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36304", "files": ["gfx/layers/apz/src/APZCTreeManager.cpp", "gfx/layers/apz/test/mochitest/helper_fission_transforms.html"], "git_node": null, "git_parents": [null], "node": "da65877c0fec3c21af44c542bada87ea8e8c6eea", "parents": ["696aa5fa31ea5c39cee412a6cecfd4af19f845fd"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Bug 1560736 - Disable test_socialtracking.html for frequent failures. a=testonly", "files": ["toolkit/components/url-classifier/tests/mochitest/mochitest.ini"], "git_node": null, "git_parents": [null], "node": "02010cfcae6e59b41160dcef1af7501a91d70805", "parents": ["da65877c0fec3c21af44c542bada87ea8e8c6eea"], "tags": []}, {"author": "Chun-Min Chang \u003cchun.m.chang@gmail.com\u003e", "branch": "default", "desc": "Bug 1561945 - P2: Update cubeb from upstream to 98a1c8e. r=achronop\n\nPick commits:\n98a1c8e - Enable Windows build on Travis. (#514)\n02bcf9c -  cubeb_sun: Fixes to support high latency playback, and illumos build fix. (#513)\n9f39687 - sunaudio (NetBSD/illumos) backend (#510)\n03eb237 - Fix tests warnings (#512)\nacbed7d - Add audiounit-rust backend (#511)\n421010c - Update Travis builds: clang 3.6 -\u003e 3.8, g++ 4.8 -\u003e 5.x, XCode 6.4 -\u003e 9.4. (#509)\n3643750 - wasapi: return unique_ptr normally, without std::move (#443)\n9ea8137 - Switch Travis builds to Ubuntu Xenial (16.04) to pick up a newer MinGW. (#508)\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36212", "files": ["media/libcubeb/moz.yaml", "media/libcubeb/src/cubeb.c", "media/libcubeb/src/cubeb_sun.c", "media/libcubeb/src/cubeb_wasapi.cpp"], "git_node": null, "git_parents": [null], "node": "c3d1fc5ebcc5032372989d442f27e61f42810f24", "parents": ["02010cfcae6e59b41160dcef1af7501a91d70805"], "tags": []}, {"author": "Jatin \u003csaijatin28@gmail.com\u003e", "branch": "default", "desc": "Bug 1554209 - Added spacing to Accessibility icon in RTL Firefox builds. r=yzen,gl\n\nBefore this change, the accessibility icon was too close to the text beside it\non the RTL versions of Firefox.\nNow a margin has been added to create sufficient space between the icon and\nthe text.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36014", "files": ["devtools/client/accessibility/accessibility.css"], "git_node": null, "git_parents": [null], "node": "b587e6d83d558adf85c050e0e60808d6775e107e", "parents": ["c3d1fc5ebcc5032372989d442f27e61f42810f24"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554985 - Invert condition to reduce indentation. r=jrmuizel\n\nNo functional changes here.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36385", "files": ["layout/painting/nsDisplayList.cpp"], "git_node": null, "git_parents": [null], "node": "8edcb5f6ceff9cdd1944c32889e3f13adbcc0f8a", "parents": ["b587e6d83d558adf85c050e0e60808d6775e107e"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554985 - Dump the render root boundary information when dumping WR scroll data. r=jrmuizel\n\nDepends on D36385\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36386", "files": ["gfx/layers/wr/RenderRootBoundary.h", "gfx/layers/wr/WebRenderScrollData.cpp"], "git_node": null, "git_parents": [null], "node": "e16eda1824f7998a06c63e2c3220a10866d8f638", "parents": ["8edcb5f6ceff9cdd1944c32889e3f13adbcc0f8a"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554985 - Prevent the WebRenderUserData on the render root item from getting discarded prematurely. r=jrmuizel\n\nWith retained display lists, a content render root might get marked as not\nneeding a build, in which case the nsDisplayRenderRoot::CreateWRCommands\nfunction does an early exit. In this case, we don't mark the associated\nWebRenderUserData as used during the display list build, which causes it to\nget deleted at the end of the transaction. The next transaction that\ndoesn't early-exit will re-create the WebRenderUserData with a new boundary\nobject. The compositor therefore thinks it's a brand new thing and, if\nconditions are right, could end up destroying and re-creating much of the\nAPZC tree. That in turn can have effects like discarding paint-skipped\nscrolling.\n\nThis patch ensures we always touch the WebRenderUserData during the display\nlist build, so we don't discard it. This problem may still affect nested\nnsDisplayRenderRoot instances but I don't think we ever cases where those\noccur.\n\nDepends on D36386\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36387", "files": ["layout/painting/nsDisplayList.cpp"], "git_node": null, "git_parents": [null], "node": "5ebb4441aa24eb6cbe8dad58d232004a3ea11b28", "parents": ["e16eda1824f7998a06c63e2c3220a10866d8f638"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1562141 - [Wayland] Hide/show popup when it's positioned by gdk_window_move_to_rect() and it's visible, r=jhorak\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36331", "files": ["widget/gtk/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "8b3c35badb46e9cf4adc823be50e1357eefd193d", "parents": ["5ebb4441aa24eb6cbe8dad58d232004a3ea11b28"], "tags": []}, {"author": "Alexandre Poirot \u003cpoirot.alex@gmail.com\u003e", "branch": "default", "desc": "Bug 1543185 - Implement Input.dispatchMouseEvent. r=remote-protocol-reviewers,ato\n\nDifferential Revision: https://phabricator.services.mozilla.com/D27500", "files": ["remote/domains/parent/Input.jsm", "remote/test/browser/browser.ini", "remote/test/browser/browser_input_dispatchMouseEvent.js"], "git_node": null, "git_parents": [null], "node": "f9109d328c084b09696106aabc6cf75a6490cdbb", "parents": ["8b3c35badb46e9cf4adc823be50e1357eefd193d"], "tags": []}, {"author": "Paul Bone \u003cpbone@mozilla.com\u003e", "branch": "default", "desc": "Bug 1561832 - Separate setting the current chunk from poisoning it r=jonco\n\nThis allows us to run the poisoning code after resizing the nursery,\nensuring that the correct region of that chunk is poisoned, fixing the bug.\n\nThis also simplifies the logic around how much of the nursery to poison, we\nalways poison the valid region of the nursery regardless of how much was\nused (removing an earlier optimisation).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36315", "files": ["js/src/gc/Nursery.cpp", "js/src/gc/Nursery.h"], "git_node": null, "git_parents": [null], "node": "75e28014a6bbaebf9d5226772ddd43689114089c", "parents": ["f9109d328c084b09696106aabc6cf75a6490cdbb"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1538072 - Crash if a null principal or a non-file uri tries to load a file:// uri (ContentParent.cpp case) r=nika\n\nDifferential Revision: https://phabricator.services.mozilla.com/D34171", "files": ["browser/app/profile/firefox.js", "dom/ipc/ContentChild.cpp", "dom/ipc/ContentParent.cpp", "dom/ipc/ContentParent.h", "dom/ipc/PContent.ipdl", "mobile/android/app/mobile.js", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "3280dc915c88a1876298cdedb28929a188b9d350", "parents": ["75e28014a6bbaebf9d5226772ddd43689114089c"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1561883 - [Wayland] Provide WaylandDisplayGetWLDisplay() to directly get wl_display, r=jhorak\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36183", "files": ["gfx/gl/GLLibraryEGL.cpp", "gfx/gl/moz.build", "widget/gtk/WindowSurfaceWayland.cpp", "widget/gtk/nsGtkKeyUtils.cpp", "widget/gtk/nsWaylandDisplay.cpp", "widget/gtk/nsWaylandDisplay.h"], "git_node": null, "git_parents": [null], "node": "c078c5a5c8b9ed122e3a86ad3f805539aef82164", "parents": ["3280dc915c88a1876298cdedb28929a188b9d350"], "tags": []}, {"author": "ksenia \u003ckberezina@mozilla.com\u003e", "branch": "default", "desc": "Bug 1562248 - scrolling in Gmail fix and some ua overrides removal for webcompat go faster r=denschub,rhelmer\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36347", "files": ["browser/extensions/webcompat/injections.js", "browser/extensions/webcompat/injections/css/bug1561371-mail.google.com-allow-horizontal-scrolling.css", "browser/extensions/webcompat/manifest.json", "browser/extensions/webcompat/moz.build", "browser/extensions/webcompat/ua_overrides.js", "