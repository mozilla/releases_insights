ice.jsm"], "git_node": null, "git_parents": [null], "node": "6c5c0e279a386b0bcfba2900dffa4e4b3e7d15f9", "parents": ["5d9128d7056f78f1632c3feeb350d547fdef04df"], "tags": []}, {"author": "Adam Gashlin \u003cagashlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1563790 - Part 2: Lower No Progress Timeout when UI is displayed r=bytesized,rstrong a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39270", "files": ["toolkit/components/bitsdownload/Bits.jsm", "toolkit/components/bitsdownload/nsIBits.idl", "toolkit/components/bitsdownload/src/bits_interface/action.rs", "toolkit/components/bitsdownload/src/bits_interface/error.rs", "toolkit/components/bitsdownload/src/bits_interface/request.rs", "toolkit/components/bitsdownload/src/bits_interface/task/mod.rs", "toolkit/components/bitsdownload/src/bits_interface/task/request_task.rs", "toolkit/mozapps/update/UpdateService.jsm"], "git_node": null, "git_parents": [null], "node": "04382a534a2070436bc612718c368b859e6ff297", "parents": ["6c5c0e279a386b0bcfba2900dffa4e4b3e7d15f9"], "tags": []}, {"author": "Matthew Noorenberghe \u003cmozilla@noorenberghe.ca\u003e", "branch": "default", "desc": "Bug 1554458 - Increase min-width for login autocomplete popups. r=sfoster,flod a=RyanVM\n\nRegular login popups go to 17em whereas a popup containing password generation goes to 21em.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39578", "files": ["browser/base/content/browser.css", "browser/extensions/formautofill/content/formautofill.css", "toolkit/components/satchel/AutoCompletePopup.jsm"], "git_node": null, "git_parents": [null], "node": "8b51f3b7c75e12a6a55355e5af55524222c707f3", "parents": ["04382a534a2070436bc612718c368b859e6ff297"], "tags": []}, {"author": "Honza Bambas \u003chonzab.moz@firemni.cz\u003e", "branch": "default", "desc": "Bug 1572790 - Add a null check before dereferencing the |trans| argument in nsHttpConnection::CloseTransaction, r=dragana a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41592", "files": ["netwerk/protocol/http/nsHttpConnection.cpp"], "git_node": null, "git_parents": [null], "node": "2bdfb6e78b9e50357f38e71825165897f8e9d063", "parents": ["8b51f3b7c75e12a6a55355e5af55524222c707f3"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1499000 - Don't do CORS checks on CSS images with the resource:// scheme. r=bzbarsky a=RyanVM\n\nCORS only works on http channels, so anything else that tries to do a\nCORS-enabled request fails catastrophically.\n\nresource:// images are useful for extension developers, so don't perform CORS\nchecks on them. We may want to also do file:// and fix bug 1565509, while at it,\nif we consider it's causing developer pain.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D40651", "files": ["layout/reftests/svg/mask-resource-ref.html", "layout/reftests/svg/mask-resource.html", "layout/reftests/svg/reftest.list", "layout/style/ImageLoader.cpp", "layout/style/ServoStyleConstsInlines.h", "servo/ports/geckolib/cbindgen.toml"], "git_node": null, "git_parents": [null], "node": "bab19dbd7043fa2f80ea4139ee1b72d5aeb22988", "parents": ["2bdfb6e78b9e50357f38e71825165897f8e9d063"], "tags": []}], "date": 1565838876, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "btara@mozilla.com"}, "11783": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nbe -\u003e 57ed747acf03\ncak -\u003e 6a68c366b2c5\ndsb -\u003e f60d31d87866\nes-AR -\u003e 8911620e6459\nfy-NL -\u003e 1ab45cdaa2e8\nhe -\u003e 669a2c2af0ce\nhsb -\u003e 8fa55e597e35\nhu -\u003e af21955054a1\nit -\u003e eaeb3d919f15\nka -\u003e 414e2cb56540\npa-IN -\u003e ee08561c734e\npl -\u003e bbb19c9aadf2\npt-BR -\u003e 43a1d1760248\nvi -\u003e 31af5a282a4f\nzh-CN -\u0