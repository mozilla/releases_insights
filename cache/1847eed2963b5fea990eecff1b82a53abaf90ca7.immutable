ags": []}], "date": 1507454450, "git_changesets": [null, null], "user": "ffxbld"}, "7919": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nast -\u003e 0e53cc10bdf0\net -\u003e b896b77bb053\nhi-IN -\u003e dc96c8f1b180\nkk -\u003e 1239b3605b2c\nne-NP -\u003e 8eb11c1f8ee7\nsr -\u003e 6f2947aa9280", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "6f91be4b69515116c463a8d4d5fc4de75604ce96", "parents": ["9accccb09caddded0c399a75169efba551a7979f"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nast -\u003e 0e53cc10bdf0\nbe -\u003e fe22e36db5a1\net -\u003e 105fd676cef9\nkk -\u003e 1239b3605b2c\nnb-NO -\u003e f3d97fa40ece\nnn-NO -\u003e 1690a8d5a32f\nsr -\u003e 096ad78fcb68", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "e2b1ae43a46273f3cc641a5ea3401c9370c83ceb", "parents": ["6f91be4b69515116c463a8d4d5fc4de75604ce96"], "tags": []}], "date": 1507494056, "git_changesets": [null, null], "user": "ffxbld"}, "7920": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nda -\u003e 9f3806f7da9e", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "747439ff40f825c9cbb47ddc332ea35283874825", "parents": ["e2b1ae43a46273f3cc641a5ea3401c9370c83ceb"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nda -\u003e fef3ff6989bd\net -\u003e e2df46e81a53", "files": ["browser/locale