e94de609e16", "parents": ["6998422519778a38cfde7e901d05919fde0b023b"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401243 followup - fix explicit constructor warning on a CLOSED TREE", "files": ["js/src/frontend/Parser.h"], "git_node": null, "git_parents": [null], "node": "f668fa4b566d4cfe2ddcda84989d7c2df48eac9d", "parents": ["d375b8dad67e21de64df02b21e508e94de609e16"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset f668fa4b566d (bug 1401243)", "files": ["js/src/frontend/Parser.h"], "git_node": null, "git_parents": [null], "node": "269c3306bcfd55fcbc757995d763088fdcf573ab", "parents": ["f668fa4b566d4cfe2ddcda84989d7c2df48eac9d"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 3c7dfc3cc0c0 (bug 1401243) on request from sfink (issue with hazard build). r=backout on a CLOSED TREE", "files": ["js/src/frontend/BytecodeCompiler.h", "js/src/frontend/Parser.cpp", "js/src/frontend/Parser.h", "js/src/gc/RootMarking.cpp", "js/src/jspubtd.h"], "git_node": null, "git_parents": [null], "node": "35e80f56a79726c4c79b559a07e43324264a3b61", "parents": ["269c3306bcfd55fcbc757995d763088fdcf573ab"], "tags": []}, {"author": "Ralph Giles \u003cgiles@mozilla.com\u003e", "branch": "default", "desc": "Bug 1394696 - stylo: Suppress valgrind warning. r=jseward\n\nLLVM can optimize code to a form `if B && A` when A is\nalways false but B is undefined. This triggers a valgrind\nmemcheck warning since the conditional depends on undefined\ndata but in practice it can never have side-effects.\n\nRust 1.20.0 seems to trigger this in the Option code. Since\nwe believe the transform is correct in these cases and\nvalgrind is incorrect to warn, we surpress the error.\n\nThanks to Julian Seward for the analysis and help\nwriting the suppression entries.\n\nMozReview-Commit-ID: pF1Bmy5PRY\n", "files": ["build/valgrind/x86_64-redhat-linux-gnu.sup"], "git_node": null, "git_parents": [null], "node": "16f7779bc325484892766b270986f2bbaacbe2bc", "parents": ["35e80f56a79726c4c79b559a07e43324264a3b61"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1336364 P1 Refact nsDocShell::ShouldPrepareForIntercept() to short-circuit on subresource instead of non-subresource. r=smaug", "files": ["docshell/base/nsDocShell.cpp"], "git_node": null, "git_parents": [null], "node": "9caa08b97a7dac57c99c623cf591a10ab99cfc01", "parents": ["16f7779bc325484892766b270986f2bbaacbe2bc"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1336364 P2 Fix the SW interception 3rd party cookie check to only apply to non-subresource requests and to properly check top window URI. r=smaug", "files": ["docshell/base/nsDocShell.cpp"], "git_node": null, "git_parents": [null], "node": "269f242c98dcfedad395a4eed745658095898cbe", "parents": ["9caa08b97a7dac57c99c623cf591a10ab99cfc01"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1336364 P3 Restrict service worker interception for more cookie policies. r=asuth", "files": ["docshell/base/nsDocShell.cpp", "dom/workers/test/serviceworkers/test_third_party_iframes.html"], "git_node": null, "git_parents": [null], "node": "4326596d4880308b4acc6be1f401ef468dd11ae4", "parents": ["269f242c98dcfedad395a4eed745658095898cbe"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1336364 P4 Disallow service worker register() is storage is forbidden for the window. r=asuth", "files": ["dom/workers/ServiceWorkerManager.cpp", "dom/workers/test/serviceworkers/test_third_party_iframes.html", "dom/workers/test/serviceworkers/thirdparty/register.html"], "git_node": null, "git_parents": [null], "node": "864019cce2c952a77abb48b288b2600cd0cd