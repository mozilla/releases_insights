src/jit/JitCompartment.h", "js/src/jit/MacroAssembler.cpp", "js/src/jit/VMFunctions.cpp", "js/src/jit/VMFunctions.h", "js/src/jit/shared/CodeGenerator-shared.cpp", "js/src/jsapi.cpp", "js/src/jsatom.cpp", "js/src/jscntxt.cpp", "js/src/jscntxt.h", "js/src/jscompartment.h", "js/src/jsobj.cpp", "js/src/jsscript.cpp", "js/src/vm/ArrayBufferObject.cpp", "js/src/vm/Debugger.cpp", "js/src/vm/MemoryMetrics.cpp", "js/src/vm/Runtime.cpp", "js/src/vm/Runtime.h", "js/src/vm/WeakMapPtr.cpp", "js/src/wasm/WasmDebug.cpp"], "git_node": null, "git_parents": [null], "node": "e226c0b7420dfbd9b84a6b07d8fba32a1c8a5483", "parents": ["ba0cf71cb9cb2d101f1053ed41bcf98662e1b259"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 4dab43248f15 (bug 1372823) for crashing GTest on Windows 10 x64 debug. r+a=backout\n\nMozReview-Commit-ID: 1u7TFtv6Mdv", "files": ["mozglue/build/WindowsDllBlocklist.cpp", "toolkit/xre/test/win/TestDllInterceptor.cpp"], "git_node": null, "git_parents": [null], "node": "c23b7af37eaf1e19ee232f4d17cb1f204daf70ae", "parents": ["e226c0b7420dfbd9b84a6b07d8fba32a1c8a5483"], "tags": []}], "date": 1506007957, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "7790": {"changesets": [{"author": "Kim Moir \u003ckmoir@mozilla.com\u003e", "branch": "default", "desc": "update display version so devedition 57.0b2 can proceed r=rail a=release DONTBUILD", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "a823dba52c9de3527650bb67f75b9b5e0df2adec", "parents": ["c23b7af37eaf1e19ee232f4d17cb1f204daf70ae"], "tags": []}], "date": 1506020964, "git_changesets": [null], "user": "kmoir@mozilla.com"}, "7791": {"changesets": [{"author": "Kim Moir \u003ckmoir@mozilla.com\u003e", "branch": "default", "desc": "update display version so devedition 57.0b2 can proceed r=rail a=release DONTBUILD", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "62078fe32d5682299e4127a23ad0d46dfe47d7c9", "parents": ["a823dba52c9de3527650bb67f75b9b5e0df2adec"], "tags": []}], "date": 1506021229, "git_changesets": [null], "user": "kmoir@mozilla.com"}, "7792": {"changesets": [{"author": "Kim Moir \u003ckmoir@mozilla.com\u003e", "branch": "default", "desc": "update display version so devedition 57.0b2 can proceed r=rail a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "3354b84cc524a26b78ce0058fef279cf523b948f", "parents": ["62078fe32d5682299e4127a23ad0d46dfe47d7c9"], "tags": ["DEVEDITION_57_0b2_RELEASE", "FIREFOX_57_0b2_BUILD1", "FIREFOX_57_0b2_RELEASE"]}], "date": 1506021254, "git_changesets": [null], "user": "kmoir@mozilla.com"}, "7793": {"changesets": [{"author": "Tom Prince", "branch": "THUNDERBIRD560b4_2017092101_RELBRANCH", "desc": "Bug 1387524 - Back out removal of MOZ_PRETTY to build Thunderbird 56 beta a=jorgk\n\nBackout most of changeset 318f1bcd336e from bug 1329355 to support building releases on buildbot.\n\nMozReview-Commit-ID: K4QAA8IIpVX", "files": ["toolkit/locales/l10n.mk", "toolkit/mozapps/installer/package-name.mk"], "git_node": null, "git_parents": [null], "node": "5a64d43646f9e466abf3099a67b44f0f1c6f924b", "parents": ["a6fb3b978941f76b727eafee21ea3d440299648d"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "THUNDERBIRD560b4_2017092101_RELBRANCH", "desc": "Bug 1385905 - part2: HTMLEditRules::SplitParagraph() should insert normal \u003cbr\u003e element rather than moz-\u003cbr\u003e element if split element and/or new element is empty r=m_kato a=jorgk\n\nCurrently, HTMLEditRules::SplitParagraph() inserts moz-\u003cbr\u003e element when split element and/or new element causes empty line.  However, PlaintextSerializer ignores moz-\u003cbr\u003e elements.  Therefore, empty lines which are created by SplitParagraph() will be removed when it's converted to plaintext.\n\nSo, it should insert normal \u003cbr\u003e element for placeholder of empty lines instead.  Note that moz-\u003cbr\u003e elements are appeared as normal \u003cbr\u003e elements in the result of Element.innerHTML.  Additionally, Chromium always inserts a \u003cbr\u003e element for empty block elements which are created by Enter key press.  Therefore, using normal \u003cbr\u003e element in this case shouldn't cause any compatibility problems.\n\nMozReview-Commit-ID: FNV41zEFWqQ", "files": ["editor/libeditor/HTMLEditRules.cpp", "editor/libeditor/HTMLEditRules.h", "editor/libeditor/TextEditRules.cpp", "editor/libeditor/TextEditRules.h"], "git_node": null, "git_parents": [null], "node": "60699b65329dca1b478fb73953bf6806aefa39ed", "parents": ["5a64d43646f9e466abf3099a67b44f0f1c6f924b"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "THUNDERBIRD560b4_2017092101_RELBRANCH", "desc": "Bug 1350152 - Don't rely on gBrowser in nsLoginManagerPrompter.js. r=mkaply a=jorgk\n\nIn bug 1266836 we fixed this code to properly work in e10s,\nbut made the mistake of using gBrowser in toolkit code, breaking\nXUL apps that don't have a gBrowser. This solution implements\na different code-path for non-e10s and returns a chrome\nwindow for consumers that don't offer a browser.\n\nMozReview-Commit-ID: 929ahDenzu5", "files": ["toolkit/components/passwordmgr/nsLoginManagerPrompter.js"], "git_node": null, "git_parents": [null], "node": "a4a45dc98aed27c3c0f0c2cfb39e80c2b5ebc5cf", "parents": ["60699b65329dca1b478fb73953bf6806aefa39ed"], "tags": []}, {"author": "Jorg K \u003cjorgk@jorgk.com\u003e", "branch": "THUNDERBIRD560b4_2017092101_RELBRANCH", "desc": "Bug 1388166 - Handle case where chromeWin.getBrowser() doesn't exist. r=johannh a=jorgk DONTBUILD", "files": ["toolkit/components/passwordmgr/nsLoginManagerPrompter.js"], "git_node": null, "git_parents": [null], "node": "8cd303b7f40f5997a647f2b0ed08e4993551f52a", "parents": ["a4a45dc98aed27c3c0f0c2cfb39e80c2b5ebc5