rs when menubar persists. r=johannh, a=ritu\n\nMozReview-Commit-ID: CycpquSvcl2", "files": ["browser/base/content/browser.xul", "browser/themes/windows/browser.css"], "git_node": null, "git_parents": [null], "node": "120189e6b8b19df5c508e0e375e68e4e87c4b8e6", "parents": ["fd75995c4d2b684df91afe3b126859d1334a0b1c"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1403867 - Clean up indicator selector rules. r=dao, a=ritu\n\nMozReview-Commit-ID: GngibDnm4k7", "files": ["browser/themes/windows/browser.css"], "git_node": null, "git_parents": [null], "node": "a29bc48fe4172c3ef572a094d6ba83d4b7f7de54", "parents": ["120189e6b8b19df5c508e0e375e68e4e87c4b8e6"], "tags": []}, {"author": "Henri Kemppainen \u003cmozilla@guu.fi\u003e", "branch": "default", "desc": "Bug 1404716 - Hide GCLI in DOM fullscreen mode. r=Gijs, r=pbrosset, a=ritu", "files": ["browser/base/content/browser.css"], "git_node": null, "git_parents": [null], "node": "0e67208dfe247daf1f03ce4e4e0f17f59e0f04d4", "parents": ["a29bc48fe4172c3ef572a094d6ba83d4b7f7de54"], "tags": []}, {"author": "Chris Coulson \u003cchrisccoulson@ubuntu.com\u003e", "branch": "default", "desc": "Bug 1405267 - Don't stub gdk_window_get_window_type in mozgtk2. r=karlt, a=ritu", "files": ["widget/gtk/mozgtk/mozgtk.c"], "git_node": null, "git_parents": [null], "node": "48052fefc77e7a0b21af1ca87c4f9298e966e9f0", "parents": ["0e67208dfe247daf1f03ce4e4e0f17f59e0f04d4"], "tags": []}, {"author": "Prathiksha \u003cprathikshaprasadsuman@gmail.com\u003e", "branch": "default", "desc": "Bug 1368460 - Update urlbar in chromeless popups to match Photon style. r=dao, a=ritu\n\nMozReview-Commit-ID: FRMcn6gwFY1", "files": ["browser/themes/shared/urlbar-searchbar.inc.css"], "git_node": null, "git_parents": [null], "node": "b4eb5da347e5d1b1b67442f22070151c734e33c7", "parents": ["48052fefc77e7a0b21af1ca87c4f9298e966e9f0"], "tags": []}, {"author": "Manish Goregaokar \u003cmanishsmail@gmail.com\u003e", "branch": "default", "desc": "Bug 1404057 - stylo: `all` shorthand should not apply to internal properties. r=xidorn, a=ritu\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 43686a8738513db728eebcc535b5ac6e1a2f17f7", "files": ["servo/components/style/properties/properties.mako.rs"], "git_node": null, "git_parents": [null], "node": "ad8fe782efece49bc5cfb1437165b0c333ac4321", "parents": ["b4eb5da347e5d1b1b67442f22070151c734e33c7"], "tags": []}, {"author": "Manish Goregaokar \u003cmanishearth@gmail.com\u003e", "branch": "default", "desc": "Bug 1404057 - stylo: Add crashtest for text-zoom being reenabled within svg:text. r=xidorn, a=ritu\n\nMozReview-Commit-ID: 3dIDW8Tz6Mj", "files": ["layout/style/crashtests/1404057.html", "layout/style/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "d6cb9fa359e571e7aa578b1f5a06fa96ecb4ae95", "parents": ["ad8fe782efece49bc5cfb1437165b0c333ac4321"], "tags": []}, {"author": "Manish Goregaokar \u003cmanishearth@gmail.com\u003e", "branch": "default", "desc": "Bug 1404057 - stylo: Add reftest for ensuring lang is not reset by the `all` shorthand. r=xidorn, a=ritu\n\nMozReview-Commit-ID: HgjJDwUM6Ju", "files": ["layout/reftests/bugs/1404057-noref.html", "layout/reftests/bugs/1404057-ref.html", "layout/reftests/bugs/1404057.html", "layout/reftests/bugs/reftest.list"], "git_node": null, "git_parents": [null], "node": "b95ce26e04125e59009f07d498e688729c9fed62", "parents": ["d6cb9fa359e571e7aa578b1f5a06fa96ecb4ae95"], "tags": []}, {"author": "Dale Harvey \u003cdale@arandomurl.com\u003e", "branch": "default", "desc": "Bug 1403359 - Switch search bar to photon icon. r=dao, a=ritu\n\nMozReview-Commit-ID: DQT8PfZHPZa", "files": ["browser/components/search/content/search.xml", "browser/themes/linux/searchbar.css", "browser/themes/osx/searchbar.css", "browser/themes/shared/jar.inc.mn", "browser/themes/shared/search/search-indicator-badge-add.png", "browser/themes/shared/search/search-indicator-badge-add.svg", "browser/themes/shared/search/search-indicator-badge-add@2x.png", "browser/themes/shared/search/search-indicator.png", "browser/themes/shared/search/search-indicator@2x.png", "browser/themes/shared/urlbar-searchbar.inc.css", "browser/themes/windows/searchbar.css"], "git_node": null, "git_parents": [null], "node": "4499acb9b54b7112f9942d3f6f6d3d9b29a67ac9", "parents": ["b95ce26e04125e59009f07d498e688729c9fed62"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1404741 - Don't call mozJSComponentLoader::CompilationScope during URLPreloader critical section. r=mccr8, a=ritu\n\nThe URLPreloader's initialization code accesses the Omnijar cache off-main\nthread. It can do so safely only as long as the main thread is blocked, or\nrunning code which is guaranteed never to touch Omnijar, while its critical\nsection runs.\n\nWhile that was guaranteed for previous versions of the code, some invariants\nchanged when we began using the component loader's shared global for initial\ncompilation. Once the global is created, we can safely use it to initialize\ncompilation. But creating the global invokes a large amount of Gecko code,\nsome of which touches Omnijar in the process.\n\nMozReview-Commit-ID: 48WoIZtGPTo", "files": ["js/xpconnect/loader/ScriptPreloader.cpp", "js/xpconnect/loader/ScriptPreloader.h"], "git_node": null, "git_parents": [null], "node": "c953cae869d808bffeece84967fa02581cd3e3ee", "parents": ["4499acb9b54b7112f9942d3f6f6d3d9b29a67ac9"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1366420. r=standard8, a=ritu\n\nMozReview-Commit-ID: FOIqr5RdRjz", "files": ["toolkit/components/places/BookmarkHTMLUtils.jsm", "toolkit/components/places/tests/unit/test_bookmarks_html_escape_entities.js", "toolkit/components/places/tests/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "c4235f5a700c0aebf3598f217faa8687d4c38740", "parents": ["c953cae869d808bffeece84967fa02581cd3e3ee"], "tags": []}], "date": 1507574864, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7930": {"changesets": [{"author": "Scott Wu \u003cscottcwwu@gmail.com\u003e", "branch": "default", "desc": "Bug 1401876 - Part 1: Close datetime picker on popuphidden. r=mconley, a=ritu\n\nMozReview-Commit-ID: FUqbtAftQxh", "files": ["toolkit/content/tests/browser/head.js", "toolkit/content/widgets/datetimepopup.xml", "toolkit/modules/DateTimePickerHelper.jsm"], "git_node": null, "git_parents": [null], "node": "83232ecf718cf3e9eae3bb2f814519d61d12bbc0", "parents": ["c4235f5a700c0aebf3598f217faa8687d4c38740"], "tags": []}, {"author": "Scott Wu \u003cscottcwwu@gmail.com\u003e", "branch": "default", "desc": "Bug 1401876 - Part 2: Add browser-chrome test for reopening picker. r=mconley, a=ritu\n\nMozReview-Commit-ID: BjR0rVxkdT", "files": ["toolkit/content/tests/browser/browser_datetime_datepicker.js", "toolkit/content/tests/browser/head.js"], "git_node": null, "git_parents": [null], "node": "65d71d7a20bdb469d1f7b1867233451b6cc98291", "parents": ["83232ecf718cf3e9eae3bb2f814519d61d12bbc0"], "tags": []}, {"author": "Sam Foster \u003csfoster@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400831 - Use a shorter tab-drop-indicator image to fit both default and compact themes, and move its box-align to CSS. r=dao, a=ritu\n\n* Fix shadow overlap and re-optimize w. pngcrush and optipng w. -strip all to remove metadata\n\nMozReview-Commit-ID: GJJfYMUz34q", "files": ["browser/base/content/tabbrowser.css", "browser/base/content/tabbrowser.xml", "browser/themes/osx/browser.css", "browser/themes/osx/tabbrowser/tabDragIndicator.png", "browser/themes/osx/tabbrowser/tabDragIndicator@2x.png"], "git_node": null, "git_parents": [null], "node": "74c5d77fcf9d7072319f0e849481f99195c62fb0", "parents": ["65d71d7a20bdb469d1f7b1867233451b6cc98291"], "tags": []}, {"au