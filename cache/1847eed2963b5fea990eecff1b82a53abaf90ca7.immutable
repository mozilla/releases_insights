for dom/media/tests/mochitest/test_getUserMedia_addtrack_removetrack_events.html. r=me, a=test-only", "files": ["dom/media/tests/mochitest/mochitest.ini"], "git_node": null, "git_parents": [null], "node": "b7b36850c2236c909902aec9a9c67816ca5dfcce", "parents": ["a0001600282a9bb9fa28f85276f1a4d3c8ddfa71"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1374133 - Disable /html/browsers/windows/browsing-context-names/choose-_blank-003.html for frequent failures. r=me, a=test-only", "files": ["testing/web-platform/meta/html/browsers/windows/browsing-context-names/choose-_blank-003.html.ini"], "git_node": null, "git_parents": [null], "node": "eb405675a9619d230e97939c11f69b99c454e149", "parents": ["b7b36850c2236c909902aec9a9c67816ca5dfcce"], "tags": []}, {"author": "jason laster \u003cjlaster@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401573 - Fix PoE, Link, and linux issue. r=nchevobbe, a=sledru\n\nMozReview-Commit-ID: 35TA6bhW1Wr", "files": ["devtools/client/debugger/new/debugger.js", "devtools/client/debugger/new/panel.js", "devtools/client/debugger/new/test/mochitest/browser_dbg-expressions.js"], "git_node": null, "git_parents": [null], "node": "f9dc096f2d54e8f0ef860e9aa51a7ac3f4eb005f", "parents": ["eb405675a9619d230e97939c11f69b99c454e149"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401922 - P1. Ensure an error is returned when no decoder could be created. r=alwu, a=sledru\n\nPDMFactory::CreateDecoder may not always modify CreateDecoderParams::mError as not all PDM handle this optional return value.\n\nMozReview-Commit-ID: K8WFA0o778U", "files": ["dom/media/MediaFormatReader.cpp"], "git_node": null, "git_parents": [null], "node": "7cd3c4b643b04c8f15e325fa9b08b390ad170e8c", "parents": ["f9dc096f2d54e8f0ef860e9aa51a7ac3f4eb005f"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401922 - P2. Only set error when non handled. r=alwu, a=sledru\n\nMozReview-Commit-ID: CF2Iw0i0nD8", "files": ["dom/media/platforms/PDMFactory.cpp"], "git_node": null, "git_parents": [null], "node": "d2a6c60348a88fa912539f986f259ac63db5d806", "parents": ["7cd3c4b643b04c8f15e325fa9b08b390ad170e8c"], "tags": []}, {"author": "Kaku Kuo \u003ckaku@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401902 - We should use MediaDataDecoder's address as an ID instead of MFR::DecoderData's address. r=gerald, a=sledru\n\nWe misused MFR::DecoderData's address as an identity in bug 1393399 but our intention was MediaDataDecoder's address.\n\nWe report telemetry data when we get the 1st decoded frame from a new MediaDataDecoder, which is identified by its address.\n\nIf we misuse the MFR::DecoderData's address as identity, it will take longer than we expect since only when\nthe MFR is recreated will we get a new MFR::DecoderData.\n\nMozReview-Commit-ID: HOf5hTSoBed", "files": ["dom/media/MediaFormatReader.cpp"], "git_node": null, "git_parents": [null], "node": "6e817055ffedec971f3c82c583f1c8ec800a480b", "parents": ["d2a6c60348a88fa912539f986f259ac63db5d806"], "tags": []}, {"author": "Sean Stangl \u003csstangl@mozilla.com\u003e", "branch": "default", "desc": "Bug 1394146 - Avoid overflow on backwards iteration of IC entries. r=jandem, a=sledru", "files": ["js/src/jit/BaselineJIT.cpp", "js/src/jit/IonControlFlow.cpp"], "git_node": null, "git_parents": [null], "node": "c89417bb5ce904ef935563aa0e7ab9fc93f20f6f", "parents": ["6e817055ffedec971f3c82c583f1c8ec800a480b"], "tags": []}], "date": 1506533876, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7838": {"changesets": [{"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "THUNDERBIRD560b4_2017092101_RELBRANCH", "desc": "Use win32 style paths for finding xz on windows. a=tomprince DONTBUILD\n\nMozReview-Commit-ID: HxkzqXp2d0R", "file