693d"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401022 - Reduce taskcluster max-run-time for Android Debug mochitests and reftests; r=jmaher", "files": ["taskcluster/ci/test/tests.yml"], "git_node": null, "git_parents": [null], "node": "7c2ee49644722c8c2f6340ba5fa911bbb2e518df", "parents": ["7aa9a38d74bab3e0bbdc46944b4fa5ed5020db6f"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400979 - Do not run test-verify on linux64-ccov; r=gmierz", "files": ["taskcluster/ci/test/tests.yml"], "git_node": null, "git_parents": [null], "node": "454abbc380ed579a83c43bbcbda4b8757363c79d", "parents": ["7c2ee49644722c8c2f6340ba5fa911bbb2e518df"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399557: Add diagnostic asserts to interceptor creation code; r=jimm\n\nMozReview-Commit-ID: 9fJxHbxCmgh", "files": ["accessible/generic/DocAccessible.cpp", "accessible/ipc/win/COMPtrTypes.cpp", "accessible/ipc/win/COMPtrTypes.h", "ipc/mscom/Interceptor.cpp"], "git_node": null, "git_parents": [null], "node": "282b2976adfdb47f3756af5c4ce11c6d9d0ae798", "parents": ["454abbc380ed579a83c43bbcbda4b8757363c79d"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1400878 - Don't show keyboard on Android unless the user caused it r=jchen\n\nMozReview-Commit-ID: KURh08X4Q4U\n", "files": ["mobile/android/geckoview/src/main/aidl/org/mozilla/gecko/IGeckoEditableParent.aidl", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoEditable.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoEditableChild.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoEditableListener.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoInputConnection.java", "widget/IMEData.h", "widget/android/GeckoEditableSupport.cpp", "widget/android/GeneratedJNIWrappers.cpp", "widget/android/GeneratedJNIWrappers.h"], "git_node": null, "git_parents": [null], "node": "7e16f505b25f498935afa0dbc893cb9eef2d1207", "parents": ["282b2976adfdb47f3756af5c4ce11c6d9d0ae798"], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401668 - Change ImageBridgeParent to acquire a compositor thread reference on construction. r=dvander", "files": ["gfx/layers/ipc/ImageBridgeParent.cpp", "gfx/layers/ipc/ImageBridgeParent.h"], "git_node": null, "git_parents": [null], "node": "74608fbc8d5686c76fbc3f115ef04931be808451", "parents": ["7e16f505b25f498935afa0dbc893cb9eef2d1207"], "tags": []}, {"author": "Bas Schouten \u003cbschouten@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400573: Back out initial fix for bug 1392453. r=mchang\n\nMozReview-Commit-ID: 3c3vJbL4kXS", "files": ["gfx/2d/DrawTargetD2D1.cpp", "gfx/2d/DrawTargetD2D1.h"], "git_node": null, "git_parents": [null], "node": "c041f734d59f73ad77d0efc511e3b16b3860ac6c", "parents": ["74608fbc8d5686c76fbc3f115ef04931be808451"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "servo: Merge #18569 - Bug 1398393 - Add a way to initialize a cooperative thread in servo (from mrbkap:1398393-cooperative-thread-tagging); r=emilio\n\n\u003c!-- Please describe your changes on the following line: --\u003e\n\nOver in [bug 1398393](https://bugzilla.mozilla.org/show_bug.cgi?id=1398393), I found that when we turn Quantum DOM's cooperative threads on, we hit a Servo panic because we assume that we've set some state in the TLD. The cooperative threads currently have no way of doing this without also re-initializing the log module and some other static data. This small patch gives the cooperative threads a way of informing Servo about themselves.\n\n---\n\u003c!-- Thank you for contributing to Servo! Please replace each `[ ]` by `[X]` when the step is complete, and replace `__` with appropriate data: --\u003e\n- [X] `./mach build -d` does not report any errors\n- [X] `./mach test-tidy` does not report any errors\n\n\u003c!-- Either: --\u003e\n- [X] These changes do not require tests because they will be tested on Gecko's tinderbox once we get cooperative threading working.\n\n\u003c!-- Also, please make sure that \"Allow edits from maintainers\" checkbox is checked, so that we can help you if you get stuck somewhere along the way.--\u003e\n\n\u003c!-- Pull requests that do not address these steps are welcome, but they will require additional verification as part of the review process. --\u003e\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 8000efac75c96f87a5e242be84b246f98a1b61e5", "files": ["servo/ports/geckolib/glue.rs"], "git_node": null, "git_parents": [null], "node": "45c37f5287f762b99c07daebf8d3c17d3bc6bddf", "parents": ["c0769d228dd3ba666d6e9b02896bebef7e996ad5"], "tags": []}, {"author": "Andi-Bogdan Postelnicu \u003cbpostelnicu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1328454 - Run static analysis based on clang-tidy from mach. r=glandium\n\nMozReview-Commit-ID: 7H1HvYE9umf", "files": ["python/mozbuild/mozbuild/mach_commands.py"], "git_node": null, "git_parents": [null], "node": "b8a7df0b3a46603083eaba1e5d09b1f20ee81e5c", "parents": ["45c37f5287f762b99c07daebf8d3c17d3bc6bddf"], "tags": []}, {"author": "abhinav \u003cabhinav.koppula@gmail.com\u003e", "branch": "default", "desc": "Bug 1379442 - Fix styling of nodeinfobar on RTL sites by setting writing-mode/direction to 'initial'. r=pbro\n\nMozReview-Commit-ID: 3fg7F80CXWe", "files": ["devtools/server/actors/highlighters.css"], "git_node": null, "git_parents": [null], "node": "3da75f798507be65851fc426a205767c230a0787", "parents": ["b8a7df0b3a46603083eaba1e5d09b1f20ee81e5c"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401460 - update principals in OnStartRequest(). r=gerald\n\nSee comment 0 for the rationale.\nThe principal will not change after OnStartRequest().\n\nMozReview-Commit-ID: K2HyWBBzGmC", "files": ["dom/media/ChannelMediaResource.cpp"], "git_node": null, "git_parents": [null], "node": "d74f41e430657e24ffed9209e21f2a97909a94e1", "parents": ["3da75f798507be65851fc426a205767c230a0787"], "tags": []}, {"author": "Ting-Yu Lin \u003ctlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1289049 Part 1 - Use shape source instead of clip path in naming. r=boris\n\nThis function can be used to implement animation for \u003cbasic-shape\u003e for\nshape-outside, so I remove the clip path in naming to make it more general.\n\nMozReview-Commit-ID: LwVe0Dk5Web", "files": ["layout/style/StyleAnimationValue.cpp"], "git_node": null, "git_parents": [null], "node": "1d5f95ad941eedae37a240fe2a4217b4ea54448c", "parents": ["d74f41e430657e24ffed9209e21f2a97909a94e1"], "tags": []}, {"author": "Ting-Yu Lin \u003ctlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1289049 Part 2 - Extract a helper function ExtractComputedValueFromShapeSource(). r=boris\n\nMozReview-Commit-ID: IhHaKhQTWbo", "files": ["layout/style/StyleAnimationValue.cpp"], "git_node": null, "git_parents": [null], "node": "132a940e3e5f3d069cde7f4d04c178f14f43e918", "parents": ["1d5f95ad941eedae37a240fe2a4217b4ea54448c"], "tags": []}, {"author": "Ting-Yu Lin \u003ctlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1289049 Part 3 - Add CSS_PROPERTY_STORES_CALC flag to \"shape-outside\" property. r=boris\n\nThis makes \"shape-outside\" be able to transition between percent and pixel\nshape-coordinates. This patch is similar to what bug 1266570 fixed for\n\"clip-path\".\n\nThis will fix failures in layout/style/test/test_transitions_per_property.html\nafter introducing Part 4.\n\nMozReview-Commit-ID: CAgXG39nUIl", "files": ["layout/style/nsCSSPropList.h"], "git_node": null, "git_parents": [null], "node": "92bb93a96a44b37be998a7a1536e2f8751d528f7", "parents": ["132a940e3e5f3d069cde7f4d04c178f14f43e918"], "tags": []}, {"author": "Ting-Yu Lin \u003ctlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1289049 Part 4 - Make \u003cbasic-shape\u003e animatable for shape-outside for gecko style system. r=boris\n\nMozReview-Commit-ID: 7x0jdqWqkpL", "files": ["layout/style/StyleAnimationValue.cpp", "layout/style/nsCSSPropList.h", "layout/style/test/test_transitions_per_property.html"], "git_node": null, "git_parents": [null], "node": "f599f522b02ec1e7c4b7302ba8e31a716832b0c9", "parents": ["92bb93a96a44b37be998a7a1536e2f8751d528f7"], "tags": []}, {"author": "Evan Tseng \u003cevan@tseng.io\u003e", "branch": "default", "desc": "Bug 1398050 - Polish preferences page to match visual spec. r=mconley\n\n* Remove transparency from the menu icons and labels in Normal state.\n* Adding Firefox Support's hover state.\n* Make the size of radio buttons as 20x20 px.\n* Make minimum width of action buttons as 150px.\n* Fix margin issues of When Nightly starts and Nightly Updates sections.\n\nMozReview-Commit-ID: DHwdKTO1wxM", "files": ["browser/components/preferences/in-content/main.xul", "browser/components/preferences/in-content/privacy.xul", "browser/extensions/formautofill/FormAutofillPreferences.jsm", "browser/extensions/shield-recipe-client/lib/ShieldPreferences.jsm", "browser/themes/linux/preferences/in-content/preferences.css", "browser/themes/shared/incontentprefs/preferences.inc.css", "browser/themes/windows/preferences/in-content/preferences.css", "toolkit/themes/linux/global/in-content/common.css", "toolkit/themes/osx/global/in-content/common.css", "toolkit/themes/shared/in-content/common.inc.css", "toolkit/themes/windows/global/in-content/common.css"], "git_node": null, "git_parents": [null], "node": "8918870e7a2028ff664d553bb3c78e001160cf52", "parents": ["f599f522b02ec1e7c4b7302ba8e31a716832b0c9"], "tags": []}, {"author": "Sean Lee \u003cselee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400147 - Ignore the credit card regexps when extensions.formautofill.