s as well).\n\nMozReview-Commit-ID: FoyKQzhAV6M", "files": ["security/sandbox/linux/broker/SandboxBrokerPolicyFactory.cpp"], "git_node": null, "git_parents": [null], "node": "0d4f0c6d3fd205d5da5d1d53079ea5cdd638d521", "parents": ["e4c1277e5d2cb18fd16ba6b0d22d3a652bf030f6"], "tags": []}], "date": 1506099306, "git_changesets": [null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7802": {"changesets": [{"author": "Robert Strong \u003crobert.bugzilla@gmail.com\u003e", "branch": "default", "desc": "Bug 1402376 - client code - Add whether the client has an incompatible version of JAWS to the update url. r=jimm, a=sledru", "files": ["toolkit/modules/UpdateUtils.jsm"], "git_node": null, "git_parents": [null], "node": "a5cb7f20d1e360670e305faa5b10cea541cb8949", "parents": ["0d4f0c6d3fd205d5da5d1d53079ea5cdd638d521"], "tags": []}, {"author": "Robert Strong \u003crobert.bugzilla@gmail.com\u003e", "branch": "default", "desc": "Bug 1402376 - test code - Add whether the client has an incompatible version of JAWS to the update url. r=jimm, a=sledru", "files": ["testing/modules/AppInfo.jsm", "toolkit/modules/tests/xpcshell/test_UpdateUtils_url.js"], "git_node": null, "git_parents": [null], "node": "0a202bb2e249bfd06e3b705feb84561264c10516", "parents": ["a5cb7f20d1e360670e305faa5b10cea541cb8949"], "tags": []}], "date": 1506110487, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "7803": {"changesets": [{"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "THUNDERBIRD560b4_2017092101_RELBRANCH", "desc": "Don't use Cwd::abs_path which is broken on old perls. a=jorgk DONTBUILD\n\nMozReview-Commit-ID: HRnmz9DhRcv", "files": ["tools/update-packaging/unwrap_full_update.pl"], "git_node": null, "git_parents": [null], "node": "34e421e834210f92aaf25ea26c6ccfcfeb47a08d", "parents": ["8cd303b7f40f5997a647f2b0ed08e4993551f52a"], "tags": []}], "date": 1506135413, "git_changesets": [null], "user": "mozilla@jorgk.com"}, "7804": {"changesets": [{"author": 