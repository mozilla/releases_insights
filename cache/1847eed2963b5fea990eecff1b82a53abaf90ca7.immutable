, r=jmaher\n\nMozReview-Commit-ID: FqmgeKc1b9o", "files": ["taskcluster/ci/test/test-sets.yml", "taskcluster/ci/test/tests.yml"], "git_node": null, "git_parents": [null], "node": "008e877ffdaa277796a9f1b6195732b368cb1157", "parents": ["bb89cd6f5507d9bbe763998757d1ae3537fe53c6"], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1389021 - Force CompositorManagerParent to close before shutting down the compositor thread. r=dvander,me", "files": ["gfx/layers/ipc/CompositorBridgeChild.cpp", "gfx/layers/ipc/CompositorManagerParent.cpp", "gfx/layers/ipc/CompositorManagerParent.h", "gfx/layers/ipc/CompositorThread.cpp"], "git_node": null, "git_parents": [null], "node": "4dd86bbce6496319e18e00d0aa81112e01f273a9", "parents": ["0a153e23338712dbf042771d77dea5027b5296e9"], "tags": []}, {"author": "Jeff Gilbert \u003cjgilbert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1396704 - Remove assert, which was the whole point of this bug.\n\nMozReview-Commit-ID: HB5p6Kt0zTb\n", "files": ["gfx/gl/GLBlitHelper.cpp"], "git_node": null, "git_parents": [null], "node": "2a002b031156b3cf26081952df602aafc609803e", "parents": ["4dd86bbce6496319e18e00d0aa81112e01f273a9"], "tags": []}, {"author": "Alan Jeffrey \u003cajeffrey@mozilla.com\u003e", "branch": "default", "desc": "servo: Merge #18523 - Make pipeline ids non-zero so that optional ids take no extra space (from asajeffrey:pipeline-id-nonzero); r=mbrubeck\n\n\u003c!-- Please describe your changes on the following line: --\u003e\n\nUse the NonZero trait to reduce space usage of `Option\u003cPipelineId\u003e`.\n\nThis needs a bump of serde to get https://github.com/serde-rs/serde/pull/1003.\n\n---\n\u003c!-- Thank you for contributing to Servo! Please replace each `[ ]` by `[X]` when the step is complete, and replace `__` with appropriate data: --\u003e\n- [X] `./mach build -d` does not report any errors\n- [X] `./mach test-tidy` does not report any errors\n- [X] There are tests for these changes OR\n\n\u003c!-- Also, please make sure that \"Allow edits from maintainers\" checkbox is checked, so that we can help you if you get stuck somewhere along the way.--\u003e\n\n\u003c!-- Pull requests that do not address these steps are welcome, but they will require additional verification as part of the review process. --\u003e\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 7256a05d74596269ca50dd42888b790016ff25af", "files": ["servo/Cargo.lock", "servo/components/compositing/compositor.rs", "servo/components/compositing/lib.rs", "servo/components/msg/Cargo.toml", "servo/components/msg/constellation_msg.rs", "servo/components/msg/lib.rs", "servo/ports/servo/Cargo.toml", "servo/tests/unit/metrics/paint_time.rs", "servo/tests/unit/msg/Cargo.toml", "servo/tests/unit/msg/lib.rs", "servo/tests/unit/msg/size_of.rs"], "git_node": null, "git_parents": [null], "node": "488548b1af4ac6ea97ddcb192d7edd14877751a0", "parents": ["008e877ffdaa277796a9f1b6195732b368cb1157"], "tags": []}, {"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 1400628 - Add test for non existing ID in select[aria-owns]. r=surkov", "files": ["accessible/tests/browser/tree/browser_aria_owns.js"], "git_node": null, "git_parents": [null], "node": "d783881ff2472e19a826a17ed9a4b6de05df4a38", "parents": ["2a002b031156b3cf26081952df602aafc609803e"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1400976 - remove dead tracking protection strings, r=bgrins\n\nMozReview-Commit-ID: 4EnV74fzjUS", "files": ["browser/locales/en-US/chrome/browser/browser.dtd"], "git_node": null, "git_parents": [null], "node": "888be4b177b9c4484fee2ddab35d84b5872fd05c", "parents": ["488548b1af4ac6ea97ddcb192d7edd14877751a0"], "tags": []}, {"author": "Alexis Beingessner \u003ca.beingessner@gmail.com\u003e", "branch": "default", "desc": "Bug 1399564 - properly thread through selection-specific decorations to WR. r=jrmuizel\n\nMozReview-Commit-ID: 7prde0BsOFL", "files": ["layout/generic/nsTextFrame.cpp", "layout/generic/nsTextFrame.h"], "git_node": null, "git_parents": [null], "node": "5f5730a85852f85c6bfa2886d2272c7d7f691fd7", "parents": ["888be4b177b9c4484fee2ddab35d84b5872fd05c"], "tags": []}, {"author": "Andrew Swan \u003caswan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1395892 Fix legacy badge in details view r=andym\n\nMozReview-Commit-ID: 2RQOvJYHLzm", "files": ["toolkit/mozapps/extensions/content/extensions.js"], "git_node": null, "git_parents": [null], "node": "acdf05e3a34170c7a6244ee2f015c61f2f4ed499", "parents": ["5f5730a85852f85c6bfa2886d2272c7d7f691fd7"], "tags": []}, {"author": "Alan Jeffrey \u003cajeffrey@mozilla.com\u003e", "branch": "default", "desc": "servo: Merge #17862 - Implemented paint worklets drawing to a border (from asajeffrey:script-paint-worklet-border); r=pcwalton\n\n\u003c!-- Please describe your changes on the following line: --\u003e\n\nAllow paint worklets to draw to a border.\n\n---\n\u003c!-- Thank you for contributing to Servo! Please replace each `[ ]` by `[X]` when the step is complete, and replace `__` with appropriate data: --\u003e\n- [X] `./mach build -d` does not report any errors\n- [X] `./mach test-tidy` does not report any errors\n- [X] These changes fix #17451.\n- [X] These changes do not require tests because the existing css-paint-api test check this (but annoyingly, all fail for other reasons)\n\n\u003c!-- Also, please make sure that \"Allow edits from maintainers\" checkbox is checked, so that we can help you if you get stuck somewhere along the way.--\u003e\n\n\u003c!-- Pull requests that do not address these steps are welcome, but they will require additional verification as part of the review process. --\u003e\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: a5282cabe04ac836458652bcb2b5e40214d36390", "files": ["servo/components/layout/display_list_builder.rs"], "git_node": null, "git_parents": [null], "node": "6602fcf1da4280b8372796ffefff315962f494f1", "parents": ["acdf05e3a34170c7a6244ee2f015c61f2f4ed499"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1400397: Use Icons if overridePageURL fails to load. r=liuche\n\nIcons apparently doesn't fade images, however, so it looks bad. Also, we try to\nrequest the image each time we bind, so scrolling up and down will create\nadditional pop-in, which also sucks.\n\nMozReview-Commit-ID: 246pokTMFl7", "files": ["mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/stream/StreamOverridablePageIconLayout.java"], "git_node": null, "git_parents": [null], "node": "b4a4b9fa2cfc418e6c03294c266c36e0d4a075f6", "parents": ["6602fcf1da4280b8372796ffefff315962f494f1"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1400397: Do not try to reload failed highlight images. r=liuche\n\nMozReview-Commit-ID: FnLcSfDrytS", "files": ["mobile/android/base/java/org/mozilla/gecko/BrowserApp.java", "mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/stream/StreamOverridablePageIconLayout.java"], "git_node": null, "git_parents": [null], "node": "73f00193147b08865fa3d049aca5214df14c6276", "parents": ["b4a4b9fa2cfc418e6c03294c266c36e0d4a075f6"], "tags": []}, {"author": "Wes Kocher \u003cwkocher@mozilla.com\u003e", "branch": "default", "desc": "Merge m-c to autoland, a=merge\n\nMozReview-Commit-ID: 7Z1eEWwhzZC", "files": ["browser/extensions/screenshots/test/browser/.eslintrc.js", "taskcluster/ci/test/tests.yml", "taskcluster/docker/android-gradle-build/Dockerfile", "taskcluster/docker/android-gradle-build/README.md", "taskcluster/docker/android-gradle-build/REGISTRY", "taskcluster/docker/android-gradle-build/VERSION", "taskcluster/docker/android-gradle-build/buildprops.json", "taskcluster/docker/android-gradle-build/dot-config/pip/pip.conf", "taskcluster/docker/android-gradle-build/oauth.txt"], "git_node": null, "git_parents": [null, null], "node": "cb2b8b4f4e04feade93e494cc5ea9d12eb3b2017", "parents": ["73f00193147b08865fa3d049aca5214df14c6276", "30a386ff1192cba08a2f899343f81f6946bc6148"], "tags": []}, {"author": "Wes Kocher \u003cwkocher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1391123 - Add a newline to the end of try_task_config.json r=gps\n\nMozReview-Commit-ID: BtQntIHOo2G", "files": ["tools/tryselect/test/test_fuzzy.t", "tools/tryselect/test/test_preset.t", "tools/tryselect/vcs.py"], "git_node": null, "git_parents": [null], "node": "6835fc2e493bf7af55ee65b48153e80be2f0ee33", "parents": ["cb2b8b4f4e04feade93e494cc5ea9d12eb3b2017"], "tags": []}, {"author": "David Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "bug 1400913 - back out the functionality changes from bug 1364159 (but keep the test) r=jcj\n\nBug 1364159 introduced an optimization that attempted to avoid reading from the\nuser's cached certificate database as much as possible when building a verified\ncertificate chain. Unfortunately this had the side-effect of not preferring root\ncertificates in path building, which can result in unnecessarily long chains\n(which rather defeats the purpose, since it means more signature verifications).\nThis patch reverts the functionality changes from that bug but keeps the test\nthat was added (the test didn't directly test the functionality changes - it's\nmore of a check that path building will query the cached certificate db when\nnecessary).\n\nMozReview-Commit-ID: I56THTLUytH", "files": ["security/certverifier/CertVerifier.cpp", "security/certverifier/CertVerifier.h", "security/certverifier/NSSCertDBTrustDomain.cpp", "security/certverifier/NSSCertDBTrustDomain.h", "security/manager/ssl/SSLServerCertVerification.cpp", "security/manager/ssl/nsNSSCallbacks.cpp", "security/manager/ssl/nsNSSCertificate.cpp", "security/manager/ssl/nsNSSCertificateDB.cpp", "security/manager/ssl/nsNSSIOLayer.cpp", "security/manager/ssl/nsSiteSecurityService.cpp"], "git_node": null, "git_parents": [null], "node": "11b46d2109c423c10ad890282acd9da08c00a409", "parents": ["6835fc2e493bf7af55ee65b48153e80be2f0ee33"], "tags": []}, {"author": "sebastian@ifyouwantblood.de", "branch": "default", "desc": "bug 1400839 use -1 instead of 0 to indicate absent glxtest_pipe fd r=karlt\n\nEnglightenment closes fd 0 on child processes and so pipe() can return a zero fd.\n\nMozReview-Commit-ID: 5d9xQXgwgfv", "files": ["widget/GfxInfoX11.cpp"], "git_node": null, "git_parents": [null], "node": "fd4481cbbd2958bd2b6339f1bb58ab8ef33b11bf", "parents": ["11b46d2109c423c10ad890282acd9da08c00a409"], "tags": []}, {"author": "Wes Kocher \u003cwkocher@mozilla.com\u003e", "branch": "default", "desc": "Merge m-c to inbound, a=merge\n\nMozReview-Commit-ID: FOmIgsEP2fb", "files": [], "git_node": null, "git_parents": [null, null], "node": "7742383e9492e747b2b79757a969b51770c0fba7", "parents": ["d783881ff2472e19a826a17ed9a4b6de05df4a38", "30a386ff1192cba08a2f899343f81f6946bc6148"], "tags": []}, {"author": "Karl Tomlinson \u003ckarlt+@karlt.net\u003e", "branch": "default", "desc": "bug 1401052 label GfxInfo files as Graphics BUG_COMPONENT r=jrmuizel\n\nMozReview-Commit-ID: ANeqbmNDSsy", "files": ["widget/moz.build"], "git_node": null, "git_parents": [null], "node": "b2e85eb4879dafd1533fff1e106307caf38672c8", "parents": ["fd4481cbbd2958bd2b6339f1bb58ab8ef33b11bf"], "tags": []}, {"author": "Kevin Hsieh \u003ckevin.hsieh@ucla.edu\u003e", "branch": "default", "desc": "Bug 1395777 (part 1) - Allow rtc to use its own writing mode. r=xidorn\n\nMozReview-Commit-ID: EkYL53YxGQV", "files": ["layout/generic/nsLineLayout.cpp", "layout/generic/nsRubyBaseContainerFrame.cpp", "layout/generic/nsRubyFrame.cpp", "layout/generic/nsRubyTextContainerFrame.cpp"], "git_node": null, "git_parents": [null], "node": "044422a93db9435ea419f895f77a5352a81aa3e2", "parents": ["b2e85eb4879dafd1533fff1e106307caf38672c8"], "tags": []}, {"author": "Kevin Hsieh \u003ckevin.hsieh@ucla.edu\u003e", "branch": "default", "desc": "Bug 1395777 (part 2) - Make orthogonal ruby annotations inter-character. r=xidorn\n\nMozReview-Commit-ID: JjpEnQI9Dmv", "files": ["layout/base/nsLayoutUtils.cpp", "layout/base/nsLayoutUtils.h", "layout/generic/nsRubyFrame.cpp", "layout/reftests/css-ruby/reftest.list", "layout/reftests/css-ruby/ruby-intercharacter-1-ref.htm", "layout/reftests/css-ruby/ruby-intercharacter-1.htm", "layout/reftests/css-ruby/ruby-intercharacter-2-ref.htm", "layout/reftests/css-ruby/ruby-intercharacter-2.htm", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "ad20c4bf0d579b3d998a2775b5d52dce42520d15", "parents": ["044422a93db9435ea419f895f77a5352a81aa3e2"], "tags": []}, {"author": "J.C. Jones \u003cjjones@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400019 - Don't assert on illegal WebAuthn algo names r=keeler\n\nThe algorithm names provided to the WebAuthn methods have to either be a\nstring, or (potentially) a WebCrypto object. Right now we only work with\nstrings, but there's no good reason to assert that, we can just let the\naction fail.\n\nThis patch removes the assert to help out the fuzzing team.\n\nMozReview-Commit-ID: 9dc8m0a2gZK", "files": ["dom/webauthn/WebAuthnManager.cpp"], "git_node": null, "git_parents": [null], "node": "a8b326d7a918386e14077be9b5f8b27463a5c8f4", "parents": ["ad20c4bf0d579b3d998a2775b5d52dce42520d15"], "tags": []}, {"author": "J.C. Jones \u003cjjones@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399959 - Prefer hardware instead of software U2F tokens r=keeler\n\nBug 1388851 adds hardware U2F support to Gecko; the instructions to test\ninvolve flipping two prefs, but the common case will be using harwdare tokens,\nso this patch makes users only haave to flip the \"security.webauth.u2f\" or\n\"security.webauth.webauthn\" prefs as they choose.\n\nMozReview-Commit-ID: 346120ZI8p4", "files": ["security/manager/ssl/security-prefs.js"], "git_node": null, "git_parents": [null], "node": "b406b52fd2e315c0faa2e454d1558e58be4e7241", "parents": ["a8b326d7a918386e14077be9b5f8b27463a5c8f4"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400166. P1 - move re-initialization code to Flush() for it is confusing to call Init() twice. r=gerald\n\nMozReview-Commit-ID: 6KolHyGkqXo", "files": ["dom/media/FileBlockCache.cpp", "dom/media/FileBlockCache.h", "dom/media/MediaBlockCacheBase.h", "dom/media/MediaCache.cpp", "dom/media/MemoryBlockCache.cpp", "dom/media/MemoryBlockCache.h"], "git_node": null, "git_parents": [null], "node": "18b7334918f0c1bfbd1fabd691eb6e3ff4e2a1c7", "parents": ["b406b52fd2e315c0faa2e454d1558e58be4e7241"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400166. P2 - Flush() should dispatch a task to clear arrays. r=gerald\n\nIf mBlockChanges is cleared when PerformBlockIOs() is dropping the data lock,\nblockIndex will become an invalid index after it acquire the data lock again.\n\nMozReview-Commit-ID: 5Cu2TgEO3F5", "files": ["dom/media/FileBlockCache.cpp"], "git_node": null, "git_parents": [null], "node": "45461d47b376357160c5a5768797b1a2ca03d40b", "parents": ["18b7334918f0c1bfbd1fabd691eb6e3ff4e2a1c7"], "tags": []}, {"author": "Munro Mengjue Chiang \u003cmchiang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1389534 - Enable continuous auto focus mode. r=jib\n\nMozReview-Commit-ID: DrTkb9CxjlA", "files": ["media/webrtc/trunk/webrtc/modules/video_capture/android/java/src/org/webrtc/videoengine/VideoCaptureAndroid.java"], "git_node": null, "git_parents": [null], "node": "93a1630a8911d78425c0acdec656d9229378131e", "parents": ["45461d47b376357160c5a5768797b1a2ca03d40b"], "tags": []}, {"author": "Jonathan Kingston \u003cjkt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397100 - Disable container about:preference checkbox if a container addon is enabled. r=bsilverberg,Felipe\n\nMozReview-Commit-ID: DtJX3FiE0e0", "files": ["browser/app/profile/firefox.js", "browser/components/preferences/in-content/main.js", "browser/components/preferences/in-content/main.xul", "browser/components/preferences/in-content/privacy.js", "browser/locales/en-US/chrome/browser/preferences/preferences.properties", "toolkit/components/extensions/ext-contextualIdentities.js"], "git_node": null, "git_parents": [null], "node": "b2bc48a42a394ce548cca585b193d8bc49feda91", "parents": ["93a1630a8911d78425c0acdec656d9229378131e"], "tags": []}, {"author": "Ting-Yu Lin \u003ctlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1341009 - Remove nsReflowStatus::Reset() in BlockReflowInput's constructor. r=dholbert\n\nnsReflowStatus's constructor will be called before BlockReflowInput's\nconstructor. No need to invoke Reset().\n\nMozReview-Commit-ID: EhYe8u1ksvD", "files": ["layout/generic/BlockReflowInput.cpp"], "git_node": null, "git_parents": [null], "node": "a6211a66f585f19fbe96e19fb9debff6898ce982", "parents": ["b2bc48a42a394ce548cca585b193d8bc49feda91"], "tags": []}, {"author": "Ting-Yu Lin \u003ctlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1341009 - Pass const reference instead of value for nsReflowStatus. r=dholbert\n\nIt's good to save a copy constructor call.\n\nAlso, make nsBlockFrame::SplitFloat() return void because the only\ncaller (BlockReflowInput::FlowAndPlaceFloat()) doesn't check its return\nvalue, and (more importantly) because it only ever returns NS_OK.\n\nMozReview-Commit-ID: 9LmDCXd7xGS", "files": ["layout/generic/nsBlockFrame.cpp", "layout/generic/nsBlockFrame.h", "layout/generic/nsBlockReflowContext.cpp", "layout/generic/nsBlockReflowContext.h", "layout/generic/nsFrame.cpp", "layout/generic/nsFrame.h"], "git_node": null, "git_parents": [null], "node": "25757b404bb6823183dd8f67302752b4076875c3", "parents": ["a6211a66f585f19fbe96e19fb9debff6898ce982"], "tags": []}, {"author": "Ting-Yu Lin \u003ctlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1341009 - Add nsReflowStatus::IsEmpty() assertion to nsAbsoluteContainingBlock::ReflowAbsoluteFrame(). r=dholbert\n\nThe only caller (nsAbsoluteContainingBlock::Reflow()) declares\nnsReflowStatus before passing it in. Add an assertion to record this\nknowledge.\n\nMozReview-Commit-ID: 8M3Oi38nDyG", "files": ["layout/generic/nsAbsoluteContainingBlock.cpp"], "git_node": null, "git_parents": [null], "node": "5b661188c6031eecf6e0088af7e10afec1310301", "parents": ["25757b404bb6823183dd8f67302752b4076875c3"], "tags": []}, {"author": "Ting-Yu Lin \u003ctlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1341009 - Reset aStatus before calling nsLineLayout::ReflowFrame(). r=dholbert\n\nThis ensures the nsIFrame::Reflow() call in nsLineLayout::ReflowFrame() is\nusing an empty reflow status.\n\nMozReview-Commit-ID: EBHs8xX7MI1", "files": ["layout/generic/nsInlineFrame.cpp"], "git_node": null, "git_parents": [null], "node": "b500a58183a46c76e09b2f2f86ae06193af87131", "parents": ["5b661188c6031eecf6e0088af7e10afec1310301"], "tags": []}, {"author": "Ting-Yu Lin \u003ctlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1341009 - Reset aStatus before calling nsContainerFrame::ReflowChild(). r=dholbert\n\nThis ensures the Reflow() call in nsContainerFrame::ReflowChild() is using\nan empty reflow status.\n\nMozReview-Commit-ID: K2Ln2i4XkB5", "files": ["layout/generic/nsColumnSetFrame.cpp", "layout/tables/nsTableFrame.cpp"], "git_node": null, "git_parents": [null], "node": "d85071e23dac815c379357dd4830e0053a6be675", "parents": ["b500a58183a46c76e09b2f2f86ae06193af87131"], "tags": []}, {"author": "Ting-Yu Lin \u003ctlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1341009 - Add nsReflowStatus::IsEmpty() assertions to all nsIFrame::Reflow() methods and some reflow helpers, and remove unneeded Reset(). r=dholbert\n\nnsReflowStatus::IsEmpty() assertions are added after DISPLAY_REFLOW in the\nbeginning of the Reflow().\n\nA few Reflow() implementations have Reset() calls at the end which are left\nin place by this patch (with an explanatory comment added to each). These\nending Reset()s are only needed for cases where a non-splittable frame\npasses its own nsReflowStatus to a child's reflow method. Just in case the\nchild leaves a \"not fully complete\" value in the nsReflowStatus, the\nnon-splittable parent frame must clear out the nsReflowStatus before\nreturning, so that its own parent doesn't then try to split it.\n\nMozReview-Commit-ID: 6Jj3jfMAqj4", "files": ["layout/forms/nsComboboxControlFrame.cpp", "layout/forms/nsDateTimeControlFrame.cpp", "layout/forms/nsFieldSetFrame.cpp", "layout/forms/nsFormControlFrame.cpp", "layout/forms/nsHTMLButtonControlFrame.cpp", "layout/forms/nsImageControlFrame.cpp", "layout/forms/nsLegendFrame.cpp", "layout/forms/nsListControlFrame.cpp", "layout/forms/nsMeterFrame.cpp", "layout/forms/nsNumberControlFrame.cpp", "layout/forms/nsProgressFrame.cpp", "layout/forms/nsRangeFrame.cpp", "layout/forms/nsSelectsAreaFrame.cpp", "layout/forms/nsTextControlFrame.cpp", "layout/generic/BRFrame.cpp", "layout/generic/ViewportFrame.cpp", "layout/generic/nsBackdropFrame.cpp", "layout/generic/nsBlockFrame.cpp", "layout/generic/nsBulletFrame.cpp", "layout/generic/nsCanvasFrame.cpp", "layout/generic/nsColumnSetFrame.cpp", "layout/generic/nsFirstLetterFrame.cpp", "layout/generic/nsFlexContainerFrame.cpp", "layout/generic/nsFrame.cpp", "layout/generic/nsFrameSetFrame.cpp", "layout/generic/nsGfxScrollFrame.cpp", "layout/generic/nsGridContainerFrame.cpp", "layout/generic/nsHTMLCanvasFrame.cpp", "layout/generic/nsImageFrame.cpp", "layout/generic/nsInlineFrame.cpp", "layout/generic/nsPageContentFrame.cpp", "layout/generic/nsPageFrame.cpp", "layout/generic/nsPlaceholderFrame.cpp", "layout/generic/nsPluginFrame.cpp", "layout/generic/nsRubyBaseContainerFrame.cpp", "layout/generic/nsRubyFrame.cpp", "layout/generic/nsRubyTextContainerFrame.cpp", "layout/generic/nsSimplePageSequenceFrame.cpp", "layout/generic/nsSubDocumentFrame.cpp", "layout/generic/nsTextFrame.cpp", "layout/generic/nsVideoFrame.cpp", "layout/mathml/nsMathMLContainerFrame.cpp", "layout/mathml/nsMathMLSelectedFrame.cpp", "layout/mathml/nsMathMLTokenFrame.cpp", "layout/mathml/nsMathMLmfencedFrame.cpp", "layout/mathml/nsMathMLmoFrame.cpp", "layout/mathml/nsMathMLmpaddedFrame.cpp", "layout/mathml/nsMathMLmrootFrame.cpp", "layout/mathml/nsMathMLmspaceFrame.cpp", "layout/mathml/nsMathMLmtableFrame.cpp", "layout/svg/nsSVGForeignObjectFrame.cpp", "layout/svg/nsSVGOuterSVGFrame.cpp", "layout/tables/nsTableCellFrame.cpp", "layout/tables/nsTableColFrame.cpp", "layout/tables/nsTableColGroupFrame.cpp", "layout/tables/nsTableFrame.cpp", "layout/tables/nsTableRowFrame.cpp", "layout/tables/nsTableRowGroupFrame.cpp", "layout/tables/nsTableWrapperFrame.cpp", "layout/xul/nsBoxFrame.cpp", "layout/xul/nsLeafBoxFrame.cpp", "layout/xul/nsRootBoxFrame.cpp", "layout/xul/nsScrollbarFrame.cpp"], "git_node": null, "git_parents": [null], "node": "c0b4af15d17a5377f3d554129338747ad709d5d5", "parents": ["d85071e23dac815c379357dd4830e0053a6be675"], "tags": []}, {"author": "Ting-Yu Lin \u003ctlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1341009 - Convert nsReflowStatus::Reset() to nsReflowStatus::IsEmpty() assertion in ReflowText(). r=dholbert\n\nMozReview-Commit-ID: Fa1Dq7xLP3n", "files": ["layout/generic/nsTextFrame.cpp"], "git_node": null, "git_parents": [null], "node": "f6c6f4f6bd3431d8d6d209ee9f89f08efec56e60", "parents": ["c0b4af15d17a5377f3d554129338747ad709d5d5"], "tags": []}, {"author": "Daisuke Akatsuka \u003cdakatsuka@mozilla.com\u003e", "branch": "default", "desc": "Bug 1366989 - Part 1: Avoid to refresh whole panel. r=pbro\n\nCurrently the animation inspector re-generates the entire animation timeline\nwhenever an animation is added, changed, etc.\nTo avoid this, averts to re-render the component which no needs.\n\nIn this implementation, premises the actorID can be used as unique id for each\nanimations. The mechanism is below.\n\nAt initial time, renders all actors  as normally. In this time, holds actorID\nand related components to componentsMap.\nNext, in case of that needs to update the UI, gets animation actors from server,\nand compares actorID of both the actors and componentsMap. If retrieved actorID\nexists in componentsMap, updates the view area only without re-rendering.\nFor example, supposes, has an animation (actid-1) when opens the inspector, and\na new animation (actid-2) was added a little later.\nAt initial rendering, holds \"actid-1\u201d of first animation as key and related\ncomponents to componentsMap. Next, when \u201cactid-2\u201d animation is added to document,\ncan get animation actors that are \u201cactid-1\u201d and \u201cactid-2\u201d from server. Because\n\u201cactid-1\u201d is already held in componentsMap, updates \u201cactid-1\u201d\u2019s view area. This\nis because TimeScale will be updated. Then \"actid-2\u201d render as normally since\ncomponentMap does not have the actorID. After rendered, holds \u201cactid-2\u201d and\nrelated components.\n\nHowever, even if actorID exists, if keyframes (tracks) and effect timing\n(state) differ, re-render that. Also, if iterationCount of effect timing\nrepresents Infinity, do re-rendering. Because the display area expands by the\nend of the currently displayed time.\n\nAnd, if actorID in componentsMap is not in retrieved actors, removes related\ncomponents.\n\nMozReview-Commit-ID: GmifRX3GzYd", "files": ["devtools/client/animationinspector/components/animation-time-block.js", "devtools/client/animationinspector/components/animation-timeline.js"], "git_node": null, "git_parents": [null], "node": "f391fb90181c5d230f3a8052829727e019be082a", "parents": ["f6c6f4f6bd3431d8d6d209ee9f89f08efec56e60"], "tags": []}, {"author": "Daisuke Akatsuka \u003cdakatsuka@mozilla.com\u003e", "branch": "default", "desc": "Bug 1366989 - Part 2: Modify tests to correspond with changing the animation-timeline. r=pbro\n\nMozReview-Commit-ID: GN5oS5KRfrc", "files": ["devtools/client/animationinspector/test/browser_animation_animated_properties_path.js", "devtools/client/animationinspector/test/browser_animation_controller_exposes_document_currentTime.js", "devtools/client/animationinspector/test/browser_animation_empty_on_invalid_nodes.js", "devtools/client/animationinspector/test/browser_animation_mutations_with_same_names.js", "devtools/client/animationinspector/test/browser_animation_playerWidgets_target_nodes.js", "devtools/client/animationinspector/test/browser_animation_pseudo_elements.js", "devtools/client/animationinspector/test/browser_animation_refresh_on_added_animation.js", "devtools/client/animationinspector/test/browser_animation_refresh_on_removed_animation.js", "devtools/client/animationinspector/test/browser_animation_refresh_when_active.js", "devtools/client/animationinspector/test/browser_animation_spacebar_toggles_node_animations.js", "devtools/client/animationinspector/test/browser_animation_summarygraph_for_multiple_easings.js", "devtools/client/animationinspector/test/browser_animation_target_highlight_select.js", "devtools/client/animationinspector/test/browser_animation_target_highlighter_lock.js", "devtools/client/animationinspector/test/browser_animation_timeline_iterationStart.js", "devtools/client/animationinspector/test/browser_animation_timeline_pause_button_03.js", "devtools/client/animationinspector/test/browser_animation_timeline_setCurrentTime.js", "devtools/client/animationinspector/test/browser_animation_timeline_short_duration.js", "devtools/client/animationinspector/test/browser_animation_timeline_shows_delay.js", "devtools/client/animationinspector/test/browser_animation_timeline_shows_endDelay.js", "devtools/client/animationinspector/test/head.js"], "git_node": null, "git_parents": [null], "node": "7d8f842fe47c707a4b5bb9e3bd7ea422bfd5246d", "parents": ["f391fb90181c5d230f3a8052829727e019be082a"], "tags": []}, {"author": "Daisuke Akatsuka \u003cdakatsuka@mozilla.com\u003e", "branch": "default", "desc": "Bug 1366989 - Part 3: Add test for updating the bounds of summary graph, delay and endDelay element. r=pbro\n\nMozReview-Commit-ID: Dwa2n471M64", "files": ["devtools/client/animationinspector/test/browser.ini", "devtools/client/animationinspector/test/browser_animation_timeline_add_animation.js", "devtools/client/animationinspector/test/doc_add_animation.html"], "git_node": null, "git_parents": [null], "node": "5fc5a88872adb1ca891b85bcdd072b8159a26c05", "parents": ["7d8f842fe47c707a4b5bb9e3bd7ea422bfd5246d"], "tags": []}, {"author": "Boris Chiou \u003cboris.chiou@gmail.com\u003e", "branch": "default", "desc": "Bug 1388601 - Part 1: Add tests of distance for Basic Shape. r=hiro\n\nMozReview-Commit-ID: 8m5km7hVNvR", "files": ["dom/animation/test/mochitest.ini", "dom/animation/test/mozilla/test_distance_of_basic_shape.html", "dom/animation/test/mozilla/test_distance_of_transform.html", "dom/animation/test/testcommon.js"], "git_node": null, "git_parents": [null], "node": "499c7061d5b6ef9e2495abd7a443f281108d2603", "parents": ["5fc5a88872adb1ca891b85bcdd072b8159a26c05"], "tags": []}, {"author": "Boris Chiou \u003cboris.chiou@gmail.com\u003e", "branch": "default", "desc": "Bug 1388601 - Part 2: Add tests of distance for Filter lists. r=hiro\n\nMozReview-Commit-ID: 1asVvBnV93r", "files": ["dom/animation/test/mochitest.ini", "dom/animation/test/mozilla/test_distance_of_filter.html"], "git_node": null, "git_parents": [null], "node": "7c12af6fd620adc74e9dfb622d17966bdebdf2ac", "parents": ["499c7061d5b6ef9e2495abd7a443f281108d2603"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "merge mozilla-inbound to mozilla-central. r=merge a=merge\n\nMozReview-Commit-ID: gZsJeZjJjm", "files": [], "git_node": null, "git_parents": [null, null], "node": "e4261f5b96ebfd63e7cb8af3035ff9fea90c74a5", "parents": ["7c12af6fd620adc74e9dfb622d17966bdebdf2ac", "7742383e9492e747b2b79757a969b51770c0fba7"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Merge mozilla-central to beta. a=merge, l10n=me on a CLOSED TREE", "files": [], "git_node": null, "git_parents": [null, null], "node": "60a702a06b11a12298fc7fca463b6abcaa067582", "parents": ["a0f805dbe65da9f2d2283912248ab6267f441004", "e4261f5b96ebfd63e7cb8af3035ff9fea90c74a5"], "tags": []}], "date": 1505828488, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7778": {"changesets": [{"author": "Rail Aliiev \u003crail@mozilla.com\u003e", "branch": "FIREFOX_56b13_RELBRANCH", "desc": "Bug 1395697 - Use BZ2 MAR compression for versions less than 56.0 r=sfraser a=release on a CLOSED TREE DONTBUILD\n\nMozReview-Commit-ID: LutFJRayTOX", "files": ["taskcluster/docker/funsize-update-generator/scripts/funsize.py"], "git_node": null, "git_parents": [null], "node": "2538d4542a52405a58a5f7d7a673e695cac62b21", "parents": ["821c84cc35b0a829d141c847d21003bc7fffa90b"], "tags": []}], "date": 1505837847, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "7779": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "FIREFOX_56b13_RELBRANCH", "desc": "Automatic version bump. CLOSED TREE NO BUG DONTBUILD a=release\n\nMozReview-Commit-ID: 9PK2N14KQ3G", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "418902381c4b85d62c1c067a5e7a0df56bcc6fea", "parents": ["2538d4542a52405a58a5f7d7a673e695cac62b21"], "tags": []}, {"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "FIREFOX_56b13_RELBRANCH", "desc": "No bug - Tagging 678bea28fe03daa91c40f50a5a9d5fc3a9dc57f8 with FENNEC_56_0b13_BUILD1, FENNEC_56_0b13_RELEASE a=release CLOSED TREE DONTBUILD\n\nMozReview-Commit-ID: 3OYm5r3Hl3D", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "c1d523fa0f5a0262bb4433ef3ca314daa8f75fc5", "parents": ["418902381c4b85d62c1c067a5e7a0df56bcc6fea"], "tags": []}], "date": 1505842693, "git_changesets": [null, null], "user": "jlorenzo@mozilla.com"}, "7780": {"changesets": [{"author": "Felipe Gomes \u003cfelipc@gmail.com\u003e", "branch": "FIREFOX_56b13_RELBRANCH", "desc": "Bug 1401249 - Fix getStringPref usage in clicktoplay-rollout. r=Gijs a=lizzard\n\ngetStringPref(.., undefined) actually returns null instead of undefined.\n\nMozReview-Commit-ID: Lor44Q891Hg", "files": ["browser/extensions/clicktoplay-rollout/bootstrap.js"], "git_node": null, "git_parents": [null], "node": "b138397a13432047a91a1976c7c8c9ef0f3ae518", "parents": ["c1d523fa0f5a0262bb4433ef3ca314daa8f75fc5"], "tags": []}, {"author": "Michael Kelly \u003cmkelly@mozilla.com\u003e", "branch": "FIREFOX_56b13_RELBRANCH", "desc": "Bug 1399936: Migrate active preference experiment values to new storage. r=Gijs a=lizzard\n\nIf a user is enrolled in a preference experiment when Firefox upgrades, the\npref branch for storing experiment values will be empty on startup, causing no\nprefs to be set. This, in turn, triggers the check in PreferenceExperiments.init\nfor prefs that differ from their experimental value, and unenrolls the user.\n\nThe solution is to store a pref flag marking if the user has been migrated. If\nthey have not, we take a one-time hit to startup perf and load the experiment\nstorage, saving it to the new pref storage and marking the user as migrated.\n\nSince initExperimentPrefs is now async, by the time we decide to add an observer\nfor UI_AVAILABLE_NOTIFICATION, the event may have already fired. We now instead\nadd the observer before the first wait, so that it is added synchronously\nwhen startup is called.\n\nIn addition, startup now sets a deferred when called, and shutdown waits for\nit to be resolved before doing anything. This avoids issues when shutdown\noccurs while startup is still executing, since shutdown now waits until startup\nis complete.\n\n\nMozReview-Commit-ID: 74VHHt18qnw", "files": ["browser/extensions/shield-recipe-client/bootstrap.js", "browser/extensions/shield-recipe-client/test/browser/browser_PreferenceExperiments.js", "browser/extensions/shield-recipe-client/test/browser/browser_bootstrap.js", "browser/extensions/shield-recipe-client/test/browser/head.js"], "git_node": null, "git_parents": [null], "node": "05b18d3ca801b6f4223f2dfcf3785286c947c8a0", "parents": ["b138397a13432047a91a1976c7c8c9ef0f3ae518"], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "FIREFOX_56b13_RELBRANCH", "desc": "Bug 1389021 - CompositorBridgeChild::ActorDestroy should not prevent CompositorBridgeChild::ShutDown from returning. r=nical, a=lizzard", "files": ["gfx/layers/ipc/CompositorBridgeChild.cpp"], "git_node": null, "git_parents": [null], "node": "df0c3f4fc23f8d115d7368f5b33c0c15e255458c", "parents": ["05b18d3ca801b6f4223f2dfcf3785286c947c8a0"], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "FIREFOX_56b13_RELBRANCH", "desc": "Bug 1389021 - Force CompositorManagerParent to close before shutting down the compositor thread. r=dvander, a=lizzard on a CLOSED TREE", "files": ["gfx/layers/ipc/CompositorBridgeChild.cpp", "gfx/layers/ipc/CompositorManagerParent.cpp", "gfx/layers/ipc/CompositorManagerParent.h", "gfx/layers/ipc/CompositorThread.cpp"], "git_node": null, "git_parents": [null], "node": "03a307b9d5d632a4a427797060cc64391d2ebe42", "parents": ["df0c3f4fc23f8d115d7368f5b33c0c15e255458c"], "tags": []}], "date": 1505855776, "git_changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "7781": {"changesets": [{"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1380649 - Part 1. Ensure SurfaceCache::CollectSizeOfSurfaces removes purged volatile buffer-backed surfaces. r=tnikkel\n\nWhen we lookup a surface in the cache, we are careful to remove any\nsurfaces which were backed by volatile memory and got purged before we\ncould reacquire the buffer. We were not so careful in doing that when\ngenerating memory reports. ISurfaceProvider::AddSizeOfExcludingThis will\ncause us to acquire the buffer, and if it was purged, forget about its\npurged status. Later when we performed a lookup, we would forget the\npurged status, and assume we have the right data. This would appear as\ncompletely transparent for BGRA surfaces, and completely black for BGRX\nsurfaces.\n\nWith this patch, we now properly remove purged surfaces instead of\nincluding them in the report. This ensures that the cache state is\nconsistent. This also resolves memory reports of surfaces which reported\nusing no data -- they were purged when the report was generated.\n\nAdditionally, there was a bug in SurfaceCache::PruneImage where we did\nnot discard surfaces outside the module lock. Both PruneImage and\nCollectSizeOfSurfaces now free any discarded surfaces outside the lock.", "files": ["image/SurfaceCache.cpp"], "git_node": null, "git_parents": [null], "node": "d4f5756b1d1247656cad910c1f19b7ea600d4ec1", "parents": ["7742383e9492e747b2b79757a969b51770c0fba7"], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1380649 - Part 2. Ensure SourceSurfaceVolatileData does not forget its purged state. r=jrmuizel\n\nCurrently if SourceSurfaceVolatileData::Map fails due to being purged,\nwe expect that the surface will be discarded by the caller. This has not\nconsistently been the case, and as such, we should ensure we do not\nforget if a buffer was previously purged when we reacquire it. Since we\ndo not at this time support repopulating an already allocated buffer\nwith new data, we cannot reset this state once it has been set.", "files": ["gfx/layers/SourceSurfaceVolatileData.h"], "git_node": null, "git_parents": [null], "node": "58844e6f37b22655881a733e9812bb873ba81b0e", "parents": ["d4f5756b1d1247656cad910c1f19b7ea600d4ec1"], "tags": []}, {"author": "Rail Aliiev \u003crail@mozilla.com\u003e", "branch": "default", "desc": "Bug 1395697 - Syntax fix r=nthomas", "files": ["testing/mozharness/configs/releases/bouncer_firefox_release.py"], "git_node": null, "git_parents": [null], "node": "5fb440d47ab9ebfa9633ff88274f221924f3cc3a", "parents": ["58844e6f37b22655881a733e9812bb873ba81b0e"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 991271.  Restore our assertions about how wrapping failure should mean an exception was thrown.  r=mccr8\n\nNow that Gecko controls error reporting and the JS engine is no longer doing\nJS_IsRunning checks, we should consistently have exceptions here.\n\nMozReview-Commit-ID: IqBe5ArJc2l", "files": ["dom/bindings/Codegen.py"], "git_node": null, "git_parents": [null], "node": "98f9bde465d29db215f7d39da0efb4d202edbb8c", "parents": ["5fb440d47ab9ebfa9633ff88274f221924f3cc3a"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1400139 part 1.  Add infrastructure for marking WebIDL interface members as non-enumerable.  r=qdot\n\nMozReview-Commit-ID: 9F0ZNverS63", "files": ["dom/bindings/Codegen.py", "dom/bindings/parser/WebIDL.py", "dom/bindings/test/TestBindingHeader.h", "dom/bindings/test/TestCodeGen.webidl", "dom/bindings/test/TestExampleGen.webidl", "dom/bindings/test/TestJSImplGen.webidl"], "git_node": null, "git_parents": [null], "node": "6ecbba14b2f30e3784afab23ba5b614b2b108cad", "parents": ["98f9bde465d29db215f7d39da0efb4d202edbb8c"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1400139 part 2.  Make window.content non-enumerable.  r=mystor\n\nMozReview-Commit-ID: LQkEkdG8wKf", "files": ["dom/base/test/mochitest.ini", "dom/base/test/test_window_content.html", "dom/webidl/Window.webidl"], "git_node": null, "git_parents": [null], "node": "5bc10c68bbf72597a2d54a756c28e5ee40a3e2f9", "parents": ["6ecbba14b2f30e3784afab23ba5b614b2b108cad"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1400139 part 3.  Add a use counter when the window.content getter is called from untrusted code.  r=mystor\n\nMozReview-Commit-ID: LFMK7lxs46Z", "files": ["dom/base/nsDeprecatedOperationList.h", "dom/base/nsGlobalWindow.cpp", "dom/locales/en-US/chrome/dom/dom.properties"], "git_node": null, "git_parents": [null], "node": "df23db5d453e546bfd3f09cd9da4e6de60dfcb20", "parents": ["5bc10c68bbf72597a2d54a756c28e5ee40a3e2f9"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1400501.  Store a list of ancestor principals on docshell and document.  r=mystor\n\nRight now every document in a docshell makes a copy of the list.  In practice,\nthis list is usually pretty short (limited by depth of iframe nesting), so this\nis probably not a problem.  We could add a bit of complexity and have a\nrefcounted struct that contains the list... I wish we had something as simple\nas Rust's Arc that we could use here.\n\nMozReview-Commit-ID: 8jGIlkhp1DU", "files": ["docshell/base/nsDocShell.h", "dom/base/nsDocument.cpp", "dom/base/nsFrameLoader.cpp", "dom/base/nsIDocument.h"], "git_node": null, "git_parents": [null], "node": "fe05bde7b58f5b63726404bc141d68de49cb04a5", "parents": ["df23db5d453e546bfd3f09cd9da4e6de60dfcb20"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1400599.  Make sure to properly handle removal of the root when the body propagates scrollbar styles to the viewport.  r=dholbert\n\nMozReview-Commit-ID: FixsFFtNOfQ", "files": ["layout/base/crashtests/1400