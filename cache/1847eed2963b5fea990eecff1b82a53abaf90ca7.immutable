selector/shooter.js"], "git_node": null, "git_parents": [null], "node": "fa1052b9a9529e7e7ccee343475ed3d5c0ac7674", "parents": ["9072e9c0d0aa2bd790634bb0a5c49713b6e27c79"], "tags": []}, {"author": "Kai Engert \u003ckaie@kuix.de\u003e", "branch": "default", "desc": "Bug 1393854, NSPR_4_17_BETA2\nUPGRADE_NSPR_RELEASE", "files": ["nsprpub/TAG-INFO", "nsprpub/config/prdepend.h", "nsprpub/pr/include/prinet.h", "nsprpub/pr/src/nspr.def"], "git_node": null, "git_parents": [null], "node": "777af9e19f70bb0a382daeed84db4c6fb3da75ff", "parents": ["fa1052b9a9529e7e7ccee343475ed3d5c0ac7674"], "tags": []}, {"author": "Kai Engert \u003ckaie@kuix.de\u003e", "branch": "default", "desc": "Bug 1399100, temporarily expose an NSPR helper function, only for Firefox 57, feedback+=mcmanus, r=fkiefer\nThis is an exception from the usual NSPR release upgrade process and essentially an agreed temporary fork, which will be undone for Firefox 58.\nThis change isn't causing any harm, because the temporary API is used only for Windows, and only accessed using dynamic symbol lookup, so it will not cause any issue on operating systems that use a system-wide install copy of NSPR without the symbol.\nUPGRADE_NSPR_RELEASE", "files": ["nsprpub/patches/README.TXT", "nsprpub/patches/bug1399100-temporary.patch", "nsprpub/pr/src/nspr.def"], "git_node": null, "git_parents": [null], "node": "63281179bfe0ddbdfc3e03b746252a52e2f8ce3b", "parents": ["777af9e19f70bb0a382daeed84db4c6fb3da75ff"], "tags": []}, {"author": "Kai Engert \u003ckaie@kuix.de\u003e", "branch": "default", "desc": "Bug 1399100, enhance client.py to warn when a local patch is registered for nspr/nss, based on feedback from glandium, r=fkiefer", "files": ["client.py"], "git_node": null, "git_parents": [null], "node": "6f71235ab648e765dfe898a730b197b5cc46f6e3", "parents": ["63281179bfe0ddbdfc3e03b746252a52e2f8ce3b"], "tags": []}, {"author": "Rail Aliiev \u003crail@mozilla.com\u003e", "branch": "default", "desc": "Bug 1395697 - Do not generate bouncer entries for BZ2-compressed MAR files for beta and devedition. r=catlee\n\nMozReview-Commit-ID: 5L1Tk1dnicT", "files": ["testing/mozharness/configs/releases/bouncer_firefox_beta.py", "testing/mozharness/configs/releases/bouncer_firefox_devedition.py"], "git_node": null, "git_parents": [null], "node": "7ee0accd38eefc04b056b83562685aa472300be3", "parents": ["6f71235ab648e765dfe898a730b197b5cc46f6e3"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1399486 - show downloads auto hide panel after changing the pref instead of before, r=mak\n\nNote that we will no longer show the panel if you use the context menu to move the item in one\nwindow and have customize mode open in the other. I don't think that edgecase matters.\n\nMozReview-Commit-ID: 3dzGr3cs2oQ", "files": ["browser/components/customizableui/CustomizeMode.jsm"], "git_node": null, "git_parents": [null], "node": "ab576fa6f89694ce1e70ebf89c83204444d8b106", "parents": ["cffcb90edf577f060ddfc737f548a093b1df605c"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1399935 - use horizontal panel for downloads checkbox panel at all times, r=mak\n\nRather than using left-hand-side at all times (which can go over the edge of the window\nin some cases) this uses left or right-hand-side panels, always opening towards the\ncenter of the window.\n\nMozReview-Commit-ID: EvjDmKR1G5A", "files": ["browser/components/customizableui/CustomizeMode.jsm"], "git_node": null, "git_parents": [null], "node": "7d298491612835153b33357fd9edf04753d98f84", "parents": ["ab576fa6f89694ce1e70ebf89c83204444d8b106"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset cb09c5099e51 (bug 1397229)", "files": ["taskcluster/ci/test/test-sets.yml", "taskcluster/ci/test/tests.yml"], "git_node": null, "git_parents": [null], "node": "87b0d