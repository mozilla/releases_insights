003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1407925 - Don't use application name but ID to determine Firefox. r=ato, a=test-only\n\nMozReview-Commit-ID: 9TZrs4nk31y", "files": ["testing/marionette/assert.js", "testing/marionette/driver.js", "testing/marionette/modal.js", "testing/marionette/server.js"], "git_node": null, "git_parents": [null], "node": "13bdb1a613e51ec8f1ad9ae3c53e30f2903b4325", "parents": ["860c47bcfc10f6c7162dc48587ba5fb60f8e861f"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1391141 - Reenable test_docload.html on stylo Windows. r=xidorn, a=test-only\n\nMozReview-Commit-ID: FAlrc8mwmGi", "files": ["accessible/tests/mochitest/events/a11y.ini"], "git_node": null, "git_parents": [null], "node": "f7fd0e6a425aca3d5b523a5a22416d1de7905a50", "parents": ["13bdb1a613e51ec8f1ad9ae3c53e30f2903b4325"], "tags": []}, {"author": "Ting-Yu Lin \u003ctlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399204 - Update test_long_press_to_select_when_partial_visible_word_is_selected(). r=mtseng, a=test-only\n\nThis test fails to test what it designed to test because the \u003cinput\u003e is not\nnarrow enough to let 'b's overflow.\n\nI added an \u003cinput\u003e that have a fixed size to ensure 'B's overflows, and\nremove the first long press on the first word.\n\nMozReview-Commit-ID: 83zBj4yBXVk", "files": ["layout/base/tests/marionette/test_accessiblecaret_selection_mode.py", "testing/marionette/harness/marionette_harness/www/test_carets_selection.html"], "git_node": null, "git_parents": [null], "node": "3098eb13218908aed87917d26d50975a5496aedb", "parents": ["f7fd0e6a425aca3d5b523a5a22416d1de7905a50"], "tags": []}, {"author": "David Parks \u003cdparks@mozilla.com\u003e", "branch": "default", "desc": "Bug 1339259 - Hold Windows AudioSession object while recycling registration. r=jimm, a=ritu\n\nWhen we UnregisterAudioSessionNotification in response to an OnSessionDisconnected\nmessage, we unintentionally decrement the refcount before restoring it. This KungFu\ngrips us for the duration of that operation.", "files": ["widget/windows/AudioSession.cpp"], "git_node": null, "git_parents": [null], "node": "37d735e5ed3bdea17e3017c26bef8fcd381f9f3a", "parents": ["3098eb13218908aed87917d26d50975a5496aedb"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1407953 - Fix invalidation collection for XBL when quirks modes don't match. r=heycam, a=ritu\n\nMozReview-Commit-ID: 7BL20YHN8EU", "files": ["servo/components/style/invalidation/element/invalidator.rs"], "git_node": null, "git_parents": [null], "node": "8bdee6ba385a5ad969561d9c12754f5c7d398701", "parents": ["37d735e5ed3bdea17e3017c26bef8fcd381f9f3a"], "tags": []}], "date": 1507910378, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7967": {"changesets": [{"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1407872 - Use Python yes-like pipe for --no-interactive in |mach bootstrap|. r=gbrown, a=test-only\n\nThe old system was simply in place because I couldn't figure out how\nto pipe `yes | ...` in Python.  This is good enough to replace it, and\nmuch less fragile since the license hashes change frequently.\n\nMozReview-Commit-ID: AhJJPqMKfUh", "files": ["python/mozboot/mozboot/android.py"], "git_node": null, "git_parents": [null], "node": "451bfe2c80bb0e783b931f518a969f07c0eb02ae", "parents": ["8bdee6ba385a5ad969561d9c12754f5c7d398701"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1407375 - Make sure to call NodeInfoChanged whenever we change the nodeinfo on a node. r=peterv, a=ritu\n\nMozReview-Commit-ID: 71k1jv8thFA", "files": ["dom/base/nsNodeUtils.cpp"], "git_node": null, "git_parents": [null], "node": "544de21bc0602fa2a95cfd0491e499ca2ae27d52", "parents": ["451bfe2c80bb0e783b931f518a969f07c0eb02ae"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1407751 - DefineOSFileConstants should return false if OSFileConstants service is not initialized. r=froydnj, a=ritu", "files": ["dom/system/OSFileConstants.cpp"], "git_node": null, "git_parents": [null], "node": "95e2671a811d131c93a862bf6266394d60a8e5d3", "parents": ["544de21bc0602fa2a95cfd0491e499ca2ae27d52"], "tags": []}], "date": 1507925814, "git_changesets": [null, null, null], "user": "ryanvm@gmail.com"}, "7968": {"changesets": [{"author": "tbirdbld", "branch": "THUNDERBIRD560b4_2017101316_RELBRANCH", "desc": "Automated checkin: version bump for thunderbird 56.0b4 release. DONTBUILD CLOSED TREE a=release", "files": [], "git_node": null, "git_parents": [null], "node": "4108b50889b6724bdfeb2a889739311b43e30fcb", "parents": ["fc8717f81711e1c12f7fd4a2ebe419dadaec1ed2"], "tags": ["THUNDERBIRD_56_0b4_BUILD13"]}, {"author": "tbirdbld", "branch": "THUNDERBIRD560b4_2017101316_RELBRANCH", "desc": "Added THUNDERBIRD_56_0b4_RELEASE THUNDERBIRD_56_0b4_BUILD13 tag(s) for changeset 4108b50889b6. DONTBUILD CLOSED TREE a=release", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "5d2f6f498e28b774a603e5da65722126ccd15cc3", "parents": ["4108b50889b6724bdfeb2a889739311b43e30fcb"], "tags": []}], "date": 1507927257, "git_changesets": [null, null], "user": "tbirdbld"}, "7969": {"changesets": [{"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1402582 - Make shell's EnvironmentPreparer grab cx from TLS. r=bhackett, a=NPOTB", "files": ["js/src/shell/js.cpp"], "git_node": null, "git_parents": [null], "node": "d1ca9be4e5210cec58daaad6deb5003d299274d9", "parents": ["95e2671a811d131c93a862bf6266394d60a8e5d3"], "tags": []}, {"author": "Peter Major \u003cmajorpetya@gmail.com\u003e", "branch": "default", "desc": "Bug 1407675 - Fix cookie creation via Marionette using IP address. r=ato, a=test-only\n\nThe issue here was that the cookie domain was always prepended with\n'.' character. To resolve this edge-case Marionette now first checks\nwhether the cookie domain is in fact an IP address.\n\nMozReview-Commit-ID: 4xBd4rscXxx", "files": ["testing/marionette/cookie.js", "testing/marionette/driver.js", "testing/marionette/test_cookie.js", "testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/webdriver/tests/cookies/add_cookie.py", "testing/web-platform/tests/webdriver/tests/cookies/get_named_cookie.py"], "git_node": null, "git_parents": [null], "node": "025fd4ef0173ab04e2782efb518fbc3c542b9f3a", "parents": ["d1ca9be4e5210cec58daaad6deb5003d299274d9"], "tags": []}, {"author": "Alex Chronopoulos \u003cachronop@gmail.com\u003e", "branch": "default", "desc": "Bug 1405258 - Uplift part of cubeb import ba2a896. r=padenot, a=ritu", "files": ["media/libcubeb/bug-1405258-beta-uplift.patch", "media/libcubeb/src/cubeb_audiounit.cpp", "media/libcubeb/update.sh"], "git_node": null, "git_parents": [null], "node": "2b831e7a64bfc9ed5dfce1f793368f2207e7a761", "parents": ["025fd4ef0173ab04e2782efb518fbc3c542b9f3a"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1405025 - Part 1: Ensure 'seeking' is fired before 'waiting'. r=jya, a=ritu\n\nUse MediaEventSource instead of state-mirroring to notify nextFrameStatus\nchanges so we have more control over the order of events.\n\nMozReview-Commit-ID: 3DGtMbghEQm", "files": ["dom/media/MediaDecoder.cpp", "dom/media/MediaDecoder.h", "dom/media/MediaDecoderStateMachine.cpp", "dom/media/MediaDecoderStateMachine.h"], "git_node": null, "git_parents": [null], "node": "57c10a793a8019df491a18109954fc16212931b3", "parents": ["2b831e7a64bfc9ed5dfce1f793368f2207e7a761"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1405025 - Part 2: Revert Bug 1390443 P1. r=jya, a=ritu\n\nSince we don't use state-mirroring to dispatch nextFrameStatus changes, we\ncan now revert the workaround of bug 1390443 P1. See bug 1390443 comment 0\nfor more details.\n\nMozReview-Commit-ID: FRxXUnGC3x2", "files": ["dom/media/MediaDecoder.h", "dom/media/MediaDecoderStateMachine.cpp"], "git_node": null, "git_parents": [null], "node": "4dd7832a9238a3c3c77e05e7be016d9d6fe70cce", "parents": ["57c10a793a8019df491a18109954fc16212931b3"], "tags": []}, {"author": "Randell Jesup \u003crjesup@jesup.org\u003e", "branch": "default", "desc": "Bug 1400563 - Clean up SCTP shutdown. r=drno, a=ritu", "files": ["netwerk/sctp/datachannel/DataChannel.cpp"], "git_node": null, "git_parents": [null], "node": "e38d82884ae80288798e4cb548d0cbd95977e9f6", "parents": ["4dd7832a9238a3c3c77e05e7be016d9d6fe70cce"], "tags": []}, {"author": "Cameron McCormack \u003ccam@mcc.id.au\u003e", "branch": "default", "desc": "Bug 1407522 - style: Support more selectors in the style sheet invalidator. r=emilio, a=ritu\n\nIn addition to being able to invalidate just based on local name, this\nalso adds support for invalidating based on selectors with no ancestor\ncombinator in them (resulting in a RESTYLE_SELF for those elements that\nmatch).\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 2f3bc0de499a9d301459dbb27978051a9a7d5f4a", "files": ["servo/components/style/invalidation/stylesheets.rs"], "git_node": null, "git_parents": [null], "node": "b74c46c59b207b6deb3addcdb98b3d136f6dffe7", "parents": ["e38d82884ae80288798e4cb548d0cbd95977e9f6"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1383593 - Noticeable delay when opening of new tabs if activity stream is enabled. r=k88hudson, a=ritu\n\nMozReview-Commit-ID: EjZhPfhX80v", "files": ["browser/extensions/activity-stream/data/content/activity-stream.css"], "git_node": null, "git_parents": [null], "node": "b94e49969f70ea29c7c999ba1d3aca04e53abf51", "parents": ["b74c46c59b207b6deb3addcdb98b3d136f6dffe7"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1407243 - Don't immediately fire canplaythrough for infinite/live streams. r=jwwang, a=ritu\n\nMozReview-Commit-ID: 2LQFa8PHvO5", "files": ["dom/media/mediasource/MediaSourceDecoder.cpp"], "git_node": null, "git_parents": [null], "node": "e54dfb628cfa43c9529341368c25ee7bea0db920", "parents": ["b94e49969f70ea29c7c999ba1d3aca04e53abf51"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1404583 - Make openLinkIn not steal focus from the address bar when loading the New Tab page. r=florian, a=ritu\n\nMozReview-Commit-ID: IgO8FrSv2l3", "files": ["browser/base/content/utilityOverlay.js"], "git_node": null, "git_parents": [null], "node": "81ae808baaf18909fda8ebae8a713a4a0560a1c1", "parents": ["e54dfb628cfa43c9529341368c25ee7bea0db920"], "tags": []}, {"author": "J. Ryan Stinnett \u003cjryans@gmail.com\u003e", "branch": "default", "desc": "Bug 1406254 - servo: Clear visited rules for text inheritance. r=emilio, a=ritu\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: dbf0991f8cab54516c5b0211e1818a16cfbf9e19", "files": ["servo/components/style/properties/gecko.mako.rs", "servo/components/style/properties/properties.mako.rs"], "git_node": null, "git_parents": [null], "node": "704d8010a876103c4efadc220714bdccd65de35a", "parents": ["81ae808baaf18909fda8ebae8a713a4a0560a1c1"], "tags": []}, {"author": "J. Ryan Stinnett \u003cjryans@gmail.com\u003e", "branch": "default", "desc": "Bug 1406254 - Visited reftest for ::first-line inheritance. r=emilio, a=ritu\n\nMozReview-Commit-ID: 4ZOlVvBuSfT", "files": ["layout/reftests/css-visited/color-on-visited-text-1-ref.html", "layout/reftests/css-visited/color-on-visited-text-1.html", "layout/style/test/moz.build", "layout/style/test/test_visited_reftests.html"], "git_node": null, "git_parents": [null], "node": "e71e4cda4c2d8456a3240862ed29141f6275c693", "parents": ["704d8010a876103c4efadc220714bdccd65de35a"], "tags