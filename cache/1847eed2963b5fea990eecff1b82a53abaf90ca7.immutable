"git_parents": [null], "node": "ef7b496eda7321b9f00cd7701cfa03afb0a68a17", "parents": ["90114b31c54b30a1debb7f2ed56524ae616e28b1"], "tags": []}, {"author": "Bryce Van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1336367 - Move AudioTrackEncoder Segment init logic into new method. r=pehrsons\n\nThe AudioTrackEncoder has logic to attempt to init when given an AudioSegment.\nThis logic has previously been part of NotifyQueuedTrackChanges. This\nchangeset moves the logic to its own method. This allows for finer testing of\nthe init attempt behaviour.\n\nMozReview-Commit-ID: Der1iM9J8fr", "files": ["dom/media/encoder/TrackEncoder.cpp", "dom/media/encoder/TrackEncoder.h"], "git_node": null, "git_parents": [null], "node": "b843181a1be76873aaac84f25a51ebb4314c2d22", "parents": ["ef7b496eda7321b9f00cd7701cfa03afb0a68a17"], "tags": []}, {"author": "Bryce Van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1336367 - Add gtest for new AudioTrackEncoder init method and behaviour. r=pehrsons\n\nMozReview-Commit-ID: 1IWPu2lD2u6", "files": ["dom/media/gtest/TestTrackEncoder.cpp"], "git_node": null, "git_parents": [null], "node": "9438b1661ccd7048c015180a7c3ce652d0c6cf0b", "parents": ["b843181a1be76873aaac84f25a51ebb4314c2d22"], "tags": []}, {"author": "Bryce Van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1336367 - Rename TestTrackEncoder to TestAudioTrackEncoder. r=pehrsons\n\nThe TestTrackEncoder file only contained audio encoder tests. This makes the\ndistinction between the already existing TestVideoTrackEncoder and these audio\ntests clearer.\n\nMozReview-Commit-ID: KmM616S72Gm", "files": ["dom/media/gtest/TestAudioTrackEncoder.cpp", "dom/media/gtest/TestTrackEncoder.cpp", "dom/media/gtest/moz.build"], "git_node": null, "git_parents": [null], "node": "41efa509e924c30838b955fadbe6e73763e3e909", "parents": ["9438b1661ccd7048c015180a7c3ce652d0c6cf0b"], "tags": []}, {"author": "Bryce Van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1336367 - Fix unified build issues from previous changes. r=pehrsons\n\nMozReview-Commit-ID: E82sCwkCxGT", "files": ["dom/media/gtest/TestMediaMIMETypes.cpp"], "git_node": null, "git_parents": [null], "node": "4cdf5e40be84ebc8ae528d670ac028d9a3037b39", "parents": ["41efa509e924c30838b955fadbe6e73763e3e909"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1400063 - Automatically declare jemalloc_* functions in mozmemory.h. r=njn\n\nThere is a lot of churn involved in adding new API surface to\nmozjemalloc, and mozmemory.h is one. Instead of declaring\neverything manually in there, \"generate\" the declarations through\nmalloc_decls.h.", "files": ["memory/build/malloc_decls.h", "memory/build/moz.build", "memory/build/mozmemory.h"], "git_node": null, "git_parents": [null], "node": "849f008bce82bd547dd4e092efcce43c3f89f61c", "parents": ["4cdf5e40be84ebc8ae528d670ac028d9a3037b39"], "tags": []}, {"author": "Anthony Ramine \u003cn.oxyde@gmail.com\u003e", "branch": "default", "desc": "servo: Merge #18503 - Simplify WorkerGlobalScope::process_event (from servo:globalism); r=emilio\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 42680374245c149b9bccc3ee5ea65f36d58c6d9e", "files": ["servo/components/script/dom/dedicatedworkerglobalscope.rs", "servo/components/script/dom/serviceworkerglobalscope.rs", "servo/components/script/dom/workerglobalscope.rs"], "git_node": null, "git_parents": [null], "node": "28d266b1cc870fc1bf6c91fdbc38ef85e7006d50", "parents": ["849f008bce82bd547dd4e092efcce43c3f89f61c"], "tags": []}, {"author": "Thom Chiovoloni \u003ctchiovoloni@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400075 - Cleanup async handling for tab engine in TPS. r=markh\n\nMozReview-Commit-ID: BQ0aJodErWy", "files": ["services/sync/tps/extensions/tps/resource/tps.jsm"], "git_node": null, "git_parents": [null], "node": "9db826022521f825d9332ba560139836667d8bab", "parents": ["28d266b1cc870fc1bf6c91fdbc38ef85e7006d50"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "merge mozilla-central to mozilla-inbound. r=merge a=merge on a CLOSED TREE", "files": ["devtools/client/inspector/webpack/rewrite-browser-require.js", "devtools/client/inspector/webpack/rewrite-css-logic-importer.js", "devtools/client/inspector/webpack/rewrite-event-emitter.js", "devtools/client/inspector/webpack/rewrite-lazy-require.js", "devtools/client/inspector/webpack/rewrite-react-redux.js", "devtools/client/inspector/webpack/rewrite-sdk-lazy-require.js", "devtools/client/webconsole/webpack/rewrite-raw.js", "gfx/webrender/src/mask_cache.rs", "gfx/webrender_bindings/src/bindings.rs", "mobile/android/base/java/org/mozilla/gecko/BrowserApp.java", "toolkit/library/gtest/rust/Cargo.lock", "toolkit/library/rust/Cargo.lock"], "git_node": null, "git_parents": [null, null], "node": "c006eaf460bb5bf3120913fa154106ebaded8069", "parents": ["f01cd7cd431c204e8792e2ddf961eb6891072706", "8e818b5e9b6bef0fc1a5c527ecf30b0d56a02f14"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1399997: Part 1 - Fix eval usage in Redux.jsm. r=Mossop\n\nMozReview-Commit-ID: KHeTEy4Os6U", "files": ["browser/extensions/activity-stream/vendor/Redux.jsm"], "git_node": null, "git_parents": [null], "node": "81e5e9200b41b827addbecfe34736bfd13249ab9", "parents": ["c006eaf460bb5bf3120913fa154106ebaded8069"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1399997: Part 3 - Update module environment tests with TODOs for shared module eval bindings. r=tcampbell\n\nMozReview-Commit-ID: LVTNnN3HlKK", "files": ["js/xpconnect/tests/unit/test_ComponentEnvironment.js", "js/xpconnect/tests/unit/test_SubscriptLoaderJSMEnvironment.js"], "git_node": null, "git_parents": [null], "node": "216079d767e7fd9351abf09e605ae63c2948bd53", "parents": ["81e5e9200b41b827addbecfe34736bfd13249ab9"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1398974: Part 7 - Update and sign talos webext extension. r=me\n\nMozReview-Commit-ID: 2oHgSuBHKoY", "files": ["testing/talos/talos/webextensions/dummy/background.js", "testing/talos/talos/webextensions/dummy/dummy-signed.xpi", "testing/talos/talos/webextensions/dummy/dummy.xpi", "testing/talos/talos/webextensions/dummy/manifest.json"], "git_node": null, "git_parents": [null], "node": "aca18d5ec8efca82f3e94db8f31cff578e69fa10", "parents": ["216079d767e7fd9351abf09e605ae63c2948bd53"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399751. P1 - pass a block index to AllocateAndWriteBlock() so it doesn't depend on mChannelOffset. r=gerald\n\nMozReview-Commit-ID: EJmxrE5X6nA", "files": ["dom/media/MediaCache.cpp"], "git_node": null, "git_parents": [null], "node": "22dbe1bf55a0c34901cc837dccc44d6153f7f713", "parents": ["9db826022521f825d9332ba560139836667d8bab"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399751. P2 - pass a block index to FindBlockForIncomingData() so it doesn't depend on mChannelOffset. r=gerald\n\nMozReview-Commit-ID: 7VltaDyxndl", "files": ["dom/media/MediaCache.cpp"], "git_node": null, "git_parents": [null], "node": "f85b473c49649a55da330e9bffefa90ca0344923", "parents": ["22dbe1bf55a0c34901cc837dccc44d6153f7f713"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399751. P3 - pass the offset of range request to ChannelMediaResource::OnStartRequest(). r=gerald\n\nSo we don't have to look at GetOffset(). We want to reduce the use of\nMediaCacheStream::mChannelOffset so it is easier to fix data races about it.\n\nMozReview-Commit-ID: 3GAbKYA9xi4", "files": ["dom/media/MediaResource.cpp", "dom/media/MediaResource.h"], "git_node": null, "git_parents": [null], "node": "9f86654073e285d5af2a7250873c7701b53ce22c", "parents": ["f85b473c49649a55da330e9bffefa90ca0344923"], "tags": []}, {"author": "Jeremy Chen \u003cjeremychen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399805 - fix the default path of fix_macosx_stack.py for running wpt tests. r=jgraham\n\nWe try to find fix_macosx_stack.py on the wrong path, which leads us can't run\nwpt tests without setting stack fix directory manually (--stackfix-dir).\nIn this patch, we fix this issue by pointing the path to @topobjdir/dist/bin.\n\nMozReview-Commit-ID: 8JzWWgVM6fM", "files": ["testing/web-platform/mach_commands.py"], "git_node": null, "git_parents": [null], "node": "18928907d9bc40c2a7f4a3f320d1c4865a286553", "parents": ["9f86654073e285d5af2a7250873c7701b53ce22c"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1399921 - Register zone allocator independently, and delay jemalloc initialization on mac. r=njn\n\nIn bug 1361258, we unified the initialization sequence on mac, and\nchose to make the zone registration happen after jemalloc\ninitialization.\n\nThe order between jemalloc init and zone registration shouldn't actually\nmatter, because jemalloc initializes the first time the allocator is\nactually used.\n\nOn the other hand, in some build setups (e.g. with light optimization),\nthe initialization of the thread_arena thread local variable can happen\nafter the forced jemalloc initialization because of the order the\ncorresponding static initializers run. In some levels of optimization,\nthe thread_arena initializer resets the value the jemalloc\ninitialization has set, which subsequently makes choose_arena() return\na bogus value (or hit an assertion in ThreadLocal.h on debug builds).\n\nSo instead of initializing jemalloc from a static initializer, which\nthen registers the zone, we instead register the zone and let jemalloc\ninitialize itself when used, which increases the chances of the\nthread_arena initializer running first.", "files": ["memory/build/mozjemalloc.cpp", "memory/build/zone.c"], "git_node": null, "git_parents": [null], "node": "0e349b74bfc6e12a3e7177a908484e0418a01725", "parents": ["18928907d9bc40c2a7f4a3f320d1c4865a286553"], "tags": []}, {"author": "Myk Melez \u003cmyk@mykzilla.org\u003e", "branch": "default", "desc": "Bug 1399963 - set a wider explicit width on the 'default font' menulist; r=nhnt11\n", "files": ["browser/themes/shared/incontentprefs/preferences.inc.css"], "git_node": null, "git_parents": [null], "node": "686f19f222263517c8598ef2bd009772aab447b8", "parents": ["aca18d5ec8efca82f3e94db8f31cff578e69fa10"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1399997: Part 2 - Fix eval usage in PhoneNumber.jsm. r=MattN\n\nMozReview-Commit-ID: 3u3oaw6HUOb", "files": ["browser/extensions/formautofill/phonenumberutils/PhoneNumber.jsm", "browser/extensions/formautofill/phonenumberutils/PhoneNumberMetaData.jsm"], "git_node": null, "git_parents": [null], "node": "2a05fcf72a3a061d94fdb867c934e8f2c4bd3dde", "parents": ["686f19f222263517c8598ef2bd009772aab447b8"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1398974: Follow-up: Skip adding request filters to favicon.ico requests. r=me\n\nWe're getting relatively frequent intermittent shutdown crashes when stream\nfilters are added during ts_paint tests. Skipping favicon.ico stream filters\nshould prevent that until we have a more reliable fix.", "files": ["testing/talos/talos/webextensions/dummy/background.js", "testing/talos/talos/webextensions/dummy/dummy-signed.xpi", "testing/talos/talos/webextensions/dummy/dummy.xpi", "testing/talos/talos/webextensions/dummy/manifest.json"], "git_node": null, "git_parents": [null], "node": "edd825dd3b1f017ca18b1eb50e2d439e02425240", "parents": ["2a05fcf72a3a061d94fdb867c934e8f2c4bd3dde"], "tags": []}, {"author": "Jeff Gilbert \u003cjgilbert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400073 - Hide MOZ_debug from getSupportedExtensions. - r=daoshengmu\n\nMozReview-Commit-ID: LFTrUOGLh36\n", "files": ["dom/canvas/WebGLContextExtensions.cpp"], "git_node": null, "git_parents": [null], "node": "3947ec46871535ef97a419fd6e4d891f796fa797", "parents": ["edd825dd3b1f017ca18b1eb50e2d439e02425240"], "tags": []}, {"author": "Phil Ringnalda \u003cphilringnalda@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset 0e349b74bfc6 (bug 1399921) for failure to thrive on Mac\n\nMozReview-Commit-ID: HoBhxzIzn2d", "files": ["memory/build/mozjemalloc.cpp", "memory/build/zone.c"], "git_node": null, "git_parents": [null], "node": "f36106f3f52a9bb2769860d20568c589fc2498d0", "parents": ["0e349b74bfc6e12a3e7177a908484e0418a01725"], "tags": []}, {"author": "Anthony Ramine \u003cn.oxyde@gmail.com\u003e", "branch": "default", "desc": "servo: Merge #18504 - Some minor HTMLMediaElement improvements (from servo:media); r=emilio\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 1b9a5ea7197cb59f48b2010895ad2a98fef08bc4", "files": ["servo/components/script/dom/htmlmediaelement.rs"], "git_node": null, "git_parents": [null], "node": "004c28e9a39e1d804e7d4ce62a7cbfcc231c89b9", "parents": ["f36106f3f52a9bb2769860d20568c589fc2498d0"], "tags": []}, {"author": "Shane Caraveo \u003cscaraveo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1393150 prevent remote extensions when e10s is off, r=bz,kmag\n\nMozReview-Commit-ID: HjLLa9vx2UW", "files": ["browser/modules/E10SUtils.jsm", "devtools/server/tests/mochitest/chrome.ini", "dom/webidl/WebExtensionPolicy.webidl", "toolkit/components/extensions/Extension.jsm", "toolkit/components/extensions/ExtensionPolicyService.cpp", "toolkit/components/extensions/ExtensionPolicyService.h", "toolkit/components/extensions/WebExtensionPolicy.cpp", "toolkit/components/extensions/WebExtensionPolicy.h"], "git_node": null, "git_parents": [null], "node": "eae22389b267d0603db9162d878881505dd94519", "parents": ["004c28e9a39e1d804e7d4ce62a7cbfcc231c89b9"], "tags": []}, {"author": "Andrew Swan \u003caswan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1384608 Show complete themes with legacy extensions r=rhelmer\n\nMozReview-Commit-ID: 6jiQZ8SQpzI", "files": ["toolkit/locales/en-US/chrome/mozapps/extensions/extensions.dtd", "toolkit/locales/en-US/chrome/mozapps/extensions/extensions.properties", "toolkit/mozapps/extensions/content/extensions.js", "toolkit/mozapps/extensions/content/extensions.xml", "toolkit/mozapps/extensions/content/extensions.xul", "toolkit/mozapps/extensions/test/browser/browser.ini", "toolkit/mozapps/extensions/test/browser/browser_legacy.js", "toolkit/mozapps/extensions/test/browser/browser_legacy_themes.js"], "git_node": null, "git_parents": [null], "node": "f2aa9d36be3f30e79a76277ab5dc88e2ed7c7d64", "parents": ["eae22389b267d0603db9162d878881505dd94519"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "servo: Merge #18515 - Measure ImageValue objects (from nnethercote:bug-1399758); r=heycam\n\nWe have about 11,500 of these when loading gmail in a Stylo-enabled build, from\nSpecifiedUrls; the objects themselves account for about 1.3 MiB of memory, and\nthe strings within them about 2.9 MiB.\n\nWe also have a very small number of them on the Gecko side.\n\n\u003c!-- Please describe your changes on the following line: --\u003e\n\n---\n\u003c!-- Thank you for contributing to Servo! Please replace each `[ ]` by `[X]` when the step is complete, and replace `__` with appropriate data: --\u003e\n- [X] `./mach build -d` does not report any errors\n- [X] `./mach test-tidy` does not report any errors\n- [ ] These changes fix #__ (github issue number if applicable).\n\n\u003c!-- Either: --\u003e\n- [ ] There are tests for these changes OR\n- [X] These changes do not require tests because tested on Gecko side.\n\n\u003c!-- Also, please make sure that \"Allow edits from maintainers\" checkbox is checked, so that we can help you if you get stuck somewhere along the way.--\u003e\n\n\u003c!-- Pull requests that do not address these steps are welcome, but they will require additional verification as part of the review process. --\u003e\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: db689094f1413f542961cbe0d19a3ed82a11f682", "files": ["servo/components/style/gecko/generated/bindings.rs", "servo/components/style/gecko/url.rs"], "git_node": null, "git_parents": [null], "node": "e2f8c9f76b711c89b04ca0e2f2ac324e638ac704", "parents": ["f2aa9d36be3f30e79a76277ab5dc88e2ed7c7d64"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399758 - Measure ImageValue objects. r=heycam.\n\nWe have about 11,500 of these when loading gmail in a Stylo-enabled build, from\nSpecifiedUrls; the objects themselves account for about 1.3 MiB of memory, and the\nstrings within them about 2.9 MiB.\n\nWe also have a very small number of them on the Gecko side.\n\nMozReview-Commit-ID: AduCIaDIzGG", "files": ["layout/style/ServoBindings.cpp", "layout/style/ServoBindings.h", "layout/style/nsCSSValue.cpp", "layout/style/nsCSSValue.h"], "git_node": null, "git_parents": [null], "node": "1536fa69bad4d6ee7f1f4c265fab57504f6263d9", "parents": ["e2f8c9f76b711c89b04ca0e2f2ac324e638ac704"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397307 - P1. Make method const. r=gerald\n\nMozReview-Commit-ID: 2UrTZroXpRG", "files": ["dom/media/MediaInfo.h"], "git_node": null, "git_parents": [null], "node": "c60b5da550ea3b664a9a81fb5dd9708bf7491657", "parents": ["1536fa69bad4d6ee7f1f4c265fab57504f6263d9"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397307 - P2. Wrap boolean in structure to prevent unwanted conversion. r=gerald\n\nAutomatic conversion (say from int to bool) makes DecoderParam difficult to extend.\n\nMozReview-Commit-ID: G0T7jPogskN", "files": ["dom/media/MediaFormatReader.cpp", "dom/media/platforms/PDMFactory.cpp", "dom/media/platforms/PlatformDecoderModule.h"], "git_node": null, "git_parents": [null], "node": "70899b90b6fe4a1be0650318a14ad40bcb604948", "parents": ["c60b5da550ea3b664a9a81fb5dd9708bf7491657"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397307 - P3. Remove unused method. r=gerald\n\nCode was incorrect anyway.\n\nMozReview-Commit-ID: Bf0O4Mhu1P6", "files": ["dom/media/platforms/wmf/DXVA2Manager.cpp", "dom/media/platforms/wmf/DXVA2Manager.h"], "git_node": null, "git_parents": [null], "node": "9d597b2bcf3518432ec8325b07b0a8b85b1666ca", "parents": ["70899b90b6fe4a1be0650318a14ad40bcb604948"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397307 - P4. Fix style. r=gerald\n\nMozReview-Commit-ID: 1Q3kwsDlAhI", "files": ["dom/media/TimeUnits.h"], "git_node": null, "git_parents": [null], "node": "3fa8d29b3026c85ee6b0e956e2db1a490d0aefc7", "parents": ["9d597b2bcf3518432ec8325b07b0a8b85b1666ca"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397307 - P5. Avoid creating two decoders on first sample. r=gerald\n\nDon't unnecessarily, create a decoder, flush, shutdown and create a new one on the first sample.\n\nMozReview-Commit-ID: 8utEX5JEmq8", "files": ["dom/media/MediaFormatReader.cpp"], "git_node": null, "git_parents": [null], "node": "768bf2920dab786813f9a698bd5c5b1778f09508", "parents": ["3fa8d29b3026c85ee6b0e956e2db1a490d0aefc7"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397307 - P6. Calculate average video frame rate as video is playing. r=gerald\n\nWe unfortunately can't store this information in the VideoInfo as typically the framerate isn't found in the container's metadata. Additionally, the VideoInfo object is readable-only as it is shared across threads.\n\nAs such, we can only estimate it as we demux samples.\n\nMozReview-Commit-ID: 5HB33ubfGAs", "files": ["dom/media/MediaFormatReader.cpp", "dom/media/MediaFormatReader.h", "dom/media/platforms/PlatformDecoderModule.h"], "git_node": null, "git_parents": [null], "node": "3fbbe2c4ec7be1057bbca4eab35bfbb4bad8de9c", "parents": ["768bf2920dab786813f9a698bd5c5b1778f09508"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397307 - P7. Display video resolution and frame rate in debug data. r=gerald\n\nMozReview-Commit-ID: 9vsheKkAm4p", "files": ["dom/media/MediaFormatReader.cpp"], "git_node": null, "git_parents": [null], "node": "1df89fb6ff5d24981157557a82de345b6da3f100", "parents": ["3fbbe2c4ec7be1057bbca4eab35bfbb4bad8de9c"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397307 - P8. Pass averaged video frame rate to constructor. r=mattwoodrow\n\nMozReview-Commit-ID: FMFz3RdFsHA", "files": ["dom/media/platforms/wmf/WMFDecoderModule.cpp", "dom/media/platforms/wmf/WMFVideoMFTManager.cpp", "dom/media/platforms/wmf/WMFVideoMFTManager.h"], "git_node": null, "git_parents": [null], "node": "0cf29b887325d88990f8c6b3ff77ba28e416424a", "parents": ["1df89fb6ff5d24981157557a82de345b6da3f100"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397307 - P9. Pass video frame rate to RemoteVideoDecoder and GPU process. r=mattwoodrow\n\nMozReview-Commit-ID: BDSO332f3B6", "files": ["dom/media/ipc/PVideoDecoderManager.ipdl", "dom/media/ipc/RemoteVideoDecoder.cpp", "dom/media/ipc/VideoDecoderChild.cpp", "dom/media/ipc/VideoDecoderChild.h", "dom/media/ipc/VideoDecoderManagerChild.cpp", "dom/media/ipc/VideoDecoderManagerChild.h", "dom/media/ipc/VideoDecoderManagerParent.cpp", "dom/media/ipc/VideoDecoderManagerParent.h", "dom/media/ipc/VideoDecoderParent.cpp", "dom/media/ipc/VideoDecoderParent.h"], "git_node": null, "git_parents": [null], "node": "7558fb4b16997621dab4b82e3dd0a5d81e0c4488", "parents": ["0cf29b887325d88990f8c6b3ff77ba28e416424a"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397307 - P10. Remove uncessary loop. r=gerald\n\nWe only process a demuxed sample at a time. Waiting until one is decoded to do the next pending ones.\n\nMozReview-Commit-ID: JlXhyPzso8U", "files": ["dom/media/MediaFormatReader.cpp"], "git_node": null, "git_parents": [null], "node": "ba8d3ecc2412f0025e715a8ecd9a527ca44ef5e0", "parents": ["7558fb4b16997621dab4b82e3dd0a5d81e0c4488"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1400096 - Remove mozmem_malloc_impl wrapping for operator methods exposed in mozmemory_wrap.c. r=njn\n\nThis used to be necessary because those functions might be prefixed with\n__wrap_, and linked against with -Wl,--wrap, but that's not been the case\nsince bug 1077366. Furthermore, mozmem_malloc_impl nowadays only does\nsomething on Windows, and those operators are only exposed on Android.", "files": ["memory/build/mozmemory_wrap.c"], "git_node": null, "git_parents": [null], "node": "6cf651d919d1aa049d0b88c1ca8f91c0c33ee56b", "parents": ["ba8d3ecc2412f0025e715a8ecd9a527ca44ef5e0"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1400096 - Annotate mozmemory_wrap.c windows functions as MOZ_MEMORY_API. r=njn\n\nIt happens to work because of mozglue.def, but we might as well have the\nright annotations (which will also make things correct when building this\nfile to C++)", "files": ["memory/build/mozmemory_wrap.c"], "git_node": null, "git_parents": [null], "node": "092857175e36c1c9c0d8d74436f432dc57deba11", "parents": ["6cf651d919d1aa049d0b88c1ca8f91c0c33ee56b"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1400096 - Build mozmemory_wrap as C++. r=njn\n\nAnd since the build system doesn't handle transitions from foo.c to\nfoo.cpp properly without a clobber, we work around the issue by\nswitching to unified sources.", "files": ["memory/build/moz.build", "memory/build/mozmemory_wrap.c", "memory/build/mozmemory_wrap.cpp"], "git_node": null, "git_parents": [null], "node": "09aa9fae62808374cf8d78e01a8e7ac8c428b3d2", "parents": ["092857175e36c1c9c0d8d74436f432dc57deba11"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1400096 - Don't define the operator new/delete functions as mangled in mozmem_wrap.cpp. r=njn\n\nNow that this is a C++ file, and that the function names are not\nmangled, we can just use the actual C++ names.\n\nWe do however need to replace MOZ_MEMORY_API, which implies extern \"C\",\nwith MFBT_API.\n\nAlso use the correct type for the size given to operator new. It\nhappened to work before because the generated code would just jump to\nmalloc without touching any register, but on aarch64, unsigned int was\nthe wrong type.", "files": ["memory/build/mozmemory_wrap.cpp"], "git_node": null, "git_parents": [null], "node": "738de4c495b950a459772024a74ba9bc32d0c68f", "parents": ["09aa9fae62808374cf8d78e01a8e7ac8c428b3d2"], "tags": []}, {"author": "Scott Wu \u003cscottcwwu@gmail.com\u003e", "branch": "default", "desc": "Bug 1399382 - Add a pref to hide credit card autofill feature, r=lchang\n\nMozReview-Commit-ID: 2GIOrLBmFKR", "files": ["browser/app/profile/firefox.js", "browser/extensions/formautofill/FormAutofillParent.jsm", "browser/extensions/formautofill/FormAutofillPreferences.jsm", "browser/extensions/formautofill/FormAutofillUtils.jsm", "browser/extensions/formautofill/test/browser/browser_privacyPreferences.js", "browser/extensions/formautofill/test/browser/head.js"], "git_node": null, "git_parents": [null], "node": "7f7d9a165b2fd988d4c8153352e0301dc9f364c5", "parents": ["738de4c495b950a459772024a74ba9bc32d0c68f"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1400146 - Gracefully handle the allocator not being initialized in isalloc_validate. r=njn\n\nisalloc_validate is the function behind malloc_usable_size. If for some\nreason malloc_usable_size is called before mozjemalloc is initialized,\nthis can lead to an unexpected crash.\n\nThe chance of this actually happening is rather slim on Linux\nand Windows (although still possible), and impossible on Mac, due to the\nfact the earlier something can end up calling it is after the\nmozjemalloc zone is registered, which happens after initialization.\n\n... except with bug 1399921, which reorders that initialization, and\nputs the zone registration first. There's then a slim chance for the\nzone allocator to call into zone_size, which calls malloc_usable_size,\nto determine whether a pointer allocated by some other zone belongs to\nmozjemalloc's.\n\nAnd it turns out that does happen, during the startup of the\nplugin-container process on OSX 10.10 (but not more recent versions).", "files": ["memory/build/mozjemalloc.cpp"], "git_node": null, "git_parents": [null], "node": "013516394a9cd0ccfed501b78f796cfdf877654d", "parents": ["7f7d9a165b2fd988d4c8153352e0301dc9f364c5"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1399921 - Register zone allocator independently, and delay jemalloc initialization on mac. r=njn\n\nIn bug 1361258, we unified the initialization sequence on mac, and\nchose to make the zone registration happen after jemalloc\ninitialization.\n\nThe order between jemalloc init and zone registration shouldn't actually\nmatter, because jemalloc initializes the first time the allocator is\nactually used.\n\nOn the other hand, in some build setups (e.g. with light optimization),\nthe initialization of the thread_arena thread local variable can happen\nafter the forced jemalloc initialization because of the order the\ncorresponding static initializers run. In some levels of optimization,\nthe thread_arena initializer resets the value the jemalloc\ninitialization has set, which subsequently makes choose_arena() return\na bogus value (or hit an assertion in ThreadLocal.h on debug builds).\n\nSo instead of initializing jemalloc from a static initializer, which\nthen registers the zone, we instead register the zone and let jemalloc\ninitialize itself when used, which increases the chances of the\nthread_arena initializer running first.", "files": ["memory/build/mozjemalloc.cpp", "memory/build/zone.c"], "git_node": null, "git_parents": [null], "node": "50770364778192f030136c3ac91528fbe994df28", "parents": ["013516394a9cd0ccfed501b78f796cfdf877654d"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 1536fa69bad4 (bug 1399758) for Hazard failures. r=backout", "files": ["layout/style/ServoBindings.cpp", "layout/style/ServoBindings.h", "layout/style/nsCSSValue.cpp", "layout/style/nsCSSValue.h"], "git_node": null, "git_parents": [null], "node": "a7f12e31f7e02368b00d72ac73bf3c661d55d0ad", "parents": ["50770364778192f030136c3ac91528fbe994df28"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset e2f8c9f76b71 for Hazard failure. r=backout", "files": ["servo/components/style/gecko/generated/bindings.rs", "servo/components/style/gecko/url.rs"], "git_node": null, "git_parents": [null], "node": "f7b896fc877805e3d3a51376f5f22b522f2e448a", "parents": ["a7f12e31f7e02368b00d72ac73bf3c661d55d0ad"], "tags": []}, {"author": "Rex Lee \u003crexboy@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399846 - [onboarding] Don't show speech bubble upon hovering watermark. r=gasolin\n\nMozReview-Commit-ID: 43FLUQMsZ9q", "files": ["browser/extensions/onboarding/content/onboarding.css"], "git_node": null, "git_parents": [null], "node": "afdef583daff4df2e52a9259906978c1bcdf1b52", "parents": ["f7b896fc877805e3d3a51376f5f22b522f2e448a"], "tags": []}, {"author": "Mason Chang \u003cmchang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399692 - Copy the front buffer to the back buffer on the paint thread with OMTP enabled. r=bas", "files": ["gfx/layers/PaintThread.cpp", "gfx/layers/PaintThread.h", "gfx/layers/RotatedBuffer.cpp", "gfx/layers/RotatedBuffer.h", "gfx/layers/client/ClientPaintedLayer.cpp", "gfx/layers/client/ContentClient.cpp", "gfx/layers/client/ContentClient.h"], "git_node": null, "git_parents": [null], "node": "46f0b004bdd23afdf5201fc7801e81897cb7c349", "parents": ["3947ec46871535ef97a419fd6e4d891f796fa797"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "merge mozilla-inbound to mozilla-central. r=merge a=merge\n\nMozReview-Commit-ID: 4dRrVdftJVy", "files": ["layout/generic/nsTextFrame.cpp", "layout/painting/nsDisplayList.cpp", "layout/painting/nsDisplayList.h", "toolkit/library/gtest/rust/Cargo.lock", "toolkit/library/rust/Cargo.lock", "widget/cocoa/nsChildView.h", "widget/cocoa/nsChildView.mm"], "git_node": null, "git_parents": [null, null], "node": "893fe1549e1e7342a66514b65960f08d40810a34", "parents": ["f36106f3f52a9bb2769860d20568c589fc2498d0", "46f0b004bdd23afdf5201fc7801e81897cb7c349"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "merge mozilla-central to autoland. r=merge a=merge", "files": [], "git_node": null, "git_parents": [null, null], "node": "426ca730d7a28a9d4c77c8a7b203822b187df16c", "parents": ["afdef583daff4df2e52a9259906978c1bcdf1b52", "893fe1549e1e7342a66514b65960f08d40810a34"], "tags": []}, {"author": "gasolin \u003cgasolin@gmail.com\u003e", "branch": "default", "desc": "Bug 1399983 - Firefox logo should float in place;r=rexboy\n\nMozReview-Commit-ID: 6pw9oqcCO6b", "files": ["browser/extensions/onboarding/content/onboarding.css"], "git_node": null, "git_parents": [null], "node": "f9bf0e04b9342150ac022d9ebbf680484f6c43d7", "parents": ["426ca730d7a28a9d4c77c8a7b203822b187df16c"], "tags": []}, {"author": "gasolin \u003cgasolin@gmail.com\u003e", "branch": "default", "desc": "Bug 1399421 - change onboarding library description;r=Fischer\n\nMozReview-Commit-ID: KMZD8ZwUwRd", "files": ["browser/extensions/onboarding/content/onboarding.js", "browser/extensions/onboarding/locales/en-US/onboarding.properties"], "git_node": null, "git_parents": [null], "node": "5c947934d2858a5e5c19e8cf073da9167e4071ed", "parents": ["f9bf0e04b9342150ac022d9ebbf680484f6c43d7"], "tags": []}, {"author": "Scott Wu \u003cscottcwwu@gmail.com\u003e", "branch": "default", "desc": "Bug 1367322 - Preferences search support for address autofill. r=evanxd,lchang\n\nMozReview-Commit-ID: 8r0BhqAPC0A", "files": ["browser/extensions/formautofill/FormAutofillPreferences.jsm", "browser/extensions/formautofill/FormAutofillUtils.jsm", "browser/extensions/formautofill/content/manageAddresses.xhtml", "browser/extensions/formautofill/content/manageDialog.js"], "git_node": null, "git_parents": [null], "node": "ef45a78e74f22d2873a57d8ab95ad67280c93b1a", "parents": ["5c947934d2858a5e5c19e8cf073da9167e4071ed"], "tags": []}, {"author": "Scott Wu \u003cscottcwwu@gmail.com\u003e", "branch": "default", "desc": "Bug 1367322 - Preferences search support for credit card autofill. r=evanxd,lchang\n\nMozReview-Commit-ID: L8sSQkQUvq4", "files": ["browser/extensions/formautofill/FormAutofillPreferences.jsm", "browser/extensions/formautofill/FormAutofillUtils.jsm", "browser/extensions/formautofill/content/manageCreditCards.xhtml", "browser/extensions/formautofill/content/manageDialog.js"], "git_node": null, "git_parents": [null], "node": "5e160c22afe711581ab9d7428ac7d7d9dd439b84", "parents": ["ef45a78e74f22d2873a57d8ab95ad67280c93b1a"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1384686 - Use currentColor with a fill-opacity for toolbar button icons. r=ntim\n\nMozReview-Commit-ID: G5G9i29KIac", "files": ["browser/modules/test/browser/browser_PageActions.js", "browser/themes/linux/browser.css", "browser/themes/osx/browser.css", "browser/themes/shared/compacttheme.inc.css", "browser/themes/shared/downloads/download-icons.svg", "browser/themes/shared/downloads/indicator.inc.css", "browser/themes/shared/icons/arrow-left.svg", "browser/themes/shared/icons/back-12.svg", "browser/themes/shared/icons/back.svg", "browser/themes/shared/icons/bookmark-animation.svg", "browser/themes/shared/icons/bookmark-hollow.svg", "browser/themes/shared/icons/bookmark-star-on-tray.svg", "browser/themes/shared/icons/bookmark.svg", "browser/themes/shared/icons/characterEncoding.svg", "browser/themes/shared/icons/check.svg", "browser/themes/shared/icons/chevron-animation.svg", "browser/themes/shared/icons/chevron.svg", "browser/themes/shared/icons/containers.svg", "browser/themes/shared/icons/customize.svg", "browser/themes/shared/icons/developer.svg", "browser/themes/shared/icons/device-desktop.svg", "browser/themes/shared/icons/device-mobile.svg", "browser/themes/shared/icons/device-tablet.svg", "browser/themes/shared/icons/edit-copy.svg", "browser/themes/shared/icons/edit-cut.svg", "browser/themes/shared/icons/edit-paste.svg", "browser/themes/shared/icons/email-link.svg", "browser/themes/shared/icons/feed.svg", "browser/themes/shared/icons/find.svg", "browser/themes/shared/icons/folder.svg", "browser/themes/shared/icons/forget.svg", "browser/themes/shared/icons/forward.svg", "browser/themes/shared/icons/fullscreen-exit.svg", "browser/themes/shared/icons/fullscreen.svg", "browser/themes/shared/icons/history.svg", "browser/themes/shared/icons/home.svg", "browser/themes/shared/icons/library-bookmark-animation.svg", "browser/themes/shared/icons/library.svg", "browser/themes/shared/icons/link.svg", "browser/themes/shared/icons/mail.svg", "browser/themes/shared/icons/menu.svg", "browser/themes/shared/icons/new-tab.svg", "browser/themes/shared/icons/new-window.svg", "browser/themes/shared/icons/open.svg", "browser/themes/shared/icons/page-action.svg", "browser/themes/shared/icons/print.svg", "browser/themes/shared/icons/privateBrowsing.svg", "browser/themes/shared/icons/quit.svg", "browser/themes/shared/icons/reload-to-stop.svg", "browser/themes/shared/icons/reload.svg", "browser/themes/shared/icons/restore-session.svg", "browser/themes/shared/icons/save.svg", "browser/themes/shared/icons/settings.svg", "browser/themes/shared/icons/sidebars-right.svg", "browser/themes/shared/icons/sidebars.svg", "browser/themes/shared/icons/stop-to-reload.svg", "browser/themes/shared/icons/stop.svg", "browser/themes/shared/icons/sync.svg", "browser/themes/shared/icons/synced-tabs.svg", "browser/themes/shared/icons/toolbar.svg", "browser/themes/shared/icons/webIDE.svg", "browser/themes/shared/icons/window.svg", "browser/themes/shared/icons/zoom-in.svg", "browser/themes/shared/icons/zoom-out.svg", "browser/themes/shared/jar.inc.mn", "browser/themes/shared/tabbrowser/newtab.svg", "browser/themes/shared/tabs.inc.css", "browser/themes/shared/toolbarbutton-icons.inc.css", "browser/themes/shared/urlbar-searchbar.inc.css", "browser/themes/windows/browser.css"], "git_node": null, "git_parents": [null], "node": "7de50f562f6f542a1adbce4a39d533a898ea9afc", "parents": ["5e160c22afe711581ab9d7428ac7d7d9dd439b84"], "tags": []}, {"author": "Andrew Halberstadt \u003cahalberstadt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399522 - [mozlint] Properly handle directories in LineLinters, r=bc\n\nCurrently line linters (linters that open a file and process it line by line,\nby applying a regex for example), don't handle directories. If a directory is\npassed in, it will try to 'open' it, which fails. Directories can get hit  if\nthe linter has a directory in its include directive or if the user passes in\n--no-filter.\n\nThis patch modifies LineLinters so that if a directory is detected, we search\nfor all relevant files under that directory. If 'extensions' is used, we'll\nlook for only files with appropriate extensions. Otherwise we assume the\nlinter wants every file.\n\nMozReview-Commit-ID: D9lzTNuQTob", "files": ["python/mozlint/mozlint/types.py", "python/mozlint/test/files/irrelevant/file.txt", "python/mozlint/test/linters/external.py", "python/mozlint/test/test_types.py"], "git_node": null, "git_parents": [null], "node": "3a173bcf1984255d88d8165a3798b7ae23db930c", "parents": ["7de50f562f6f542a1adbce4a39d533a898ea9afc"], "tags": []}, {"author": "James Cheng \u003cjacheng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400180 - Fix CID 1417508 Uninitialized members of TextTrackCue::mLine and mPosition by giving them default values. r=alwu\n\nMozReview-Commit-ID: CB6980MNqP1", "files": ["dom/media/TextTrackCue.cpp", "dom/media/TextTrackCue.h"], "git_node": null, "git_parents": [null], "node": "2bf1aae5795a74407c9aad2dd8962aae433b03fc", "parents": ["3a173bcf1984255d88d8165a3798b7ae23db930c"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1399628 - Disable Shield extension in Marionette and geckodriver. r=ato\n\nShield experiments interfer with core features of Firefox which can\ncause tests run via Marionette or geckodriver to fail. Resetting the\nAPI URL will make sure that no experiments can be downloaded.\n\nMozReview-Commit-ID: HnE49jfnen7", "files": ["testing/geckodriver/src/prefs.rs", "testing/marionette/client/marionette_driver/geckoinstance.py", "testing/marionette/server.js"], "git_node": null, "git_parents": [null], "node": "3baecf7b25f2d4a0d8cda5f773878a0f9d941ea5", "parents": ["2bf1aae5795a74407c9aad2dd8962aae433b03fc"], "tags": []}, {"author": "Jing-wei Wu \u003ctopwu.tw@gmail.com\u003e", "branch": "default", "desc": "Bug 1400101 - [robocop] Find toolbar first and use it to find menu button. r=JanH,nechen\n\nSometimes Robocop is confused when are multiple `R.id.menu` UI components shown on screen,\none is the menu button on toolbar and otehrs are context menus on Activity Stream.\n\nTo access the menu on toolbar, a simple fix is access toolbar first and use it to find its child.\n\nMozReview-Commit-ID: Jw4sTLeR3li", "files": ["mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/components/AppMenuComponent.java"], "git_node": null, "git_parents": [null], "node": "08d09442ab4b8efb8104b2ba0d6f4eee8818efb9", "parents": ["3baecf7b25f2d4a0d8cda5f773878a0f9d941ea5"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 3baecf7b25f2 (bug 1399628) for build bustage. r=backout", "files": ["testing/geckodriver/src/prefs.rs", "testing/marionette/client/marionette_driver/geckoinstance.py", "testing/marionette/server.js"], "git_node": null, "git_parents": [null], "node": "5500f432a88828303595de17bf31d127baa12ff9", "parents": ["08d09442ab4b8efb8104b2ba0d6f4eee8818efb9"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399630 - Update webrender to commit 878914aaf4d230fa449ff7800b529fe9023fc3c5. r=jrmuizel\n\nMozReview-Commit-ID: IuNfqTZ57Tb", "files": ["gfx/doc/README.webrender", "gfx/webrender/res/base.glsl", "gfx/webrender/res/ps_box_shadow.fs.glsl", "gfx/webrender/res/ps_box_shadow.glsl", "gfx/webrender/res/ps_box_shadow.vs.glsl", "gfx/webrender/res/ps_image.fs.glsl", "gfx/webrender/res/ps_image.glsl", "gfx/webrender/res/ps_image.vs.glsl", "gfx/webrender/res/ps_rectangle.fs.glsl", "gfx/webrender/res/ps_rectangle.glsl", "gfx/webrender/res/ps_rectangle.vs.glsl", "gfx/webrender/res/ps_text_run.fs.glsl", "gfx/webrender/res/ps_text_run.glsl", "gfx/webrender/res/ps_text_run.vs.glsl", "gfx/webrender/res/ps_yuv_image.fs.glsl", "gfx/webrender/res/ps_yuv_image.glsl", "gfx/webrender/res/ps_yuv_image.vs.glsl", "gfx/webrender/res/shared.glsl", "gfx/webrender/src/tiling.rs", "gfx/webrender_api/src/display_item.rs"], "git_node": null, "git_parents": [null], "node": "31adad19ac0c360ecab9ac66787e07e3c66c13a6", "parents": ["5500f432a88828303595de17bf31d127baa12ff9"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399630 - Re-enable talos-g1 on linux64-qr as it works again. r=jrmuizel\n\nMozReview-Commit-ID: KiI4rWU21eS", "files": ["taskcluster/ci/test/test-sets.yml"], "git_node": null, "git_parents": [null], "node": "2e6f093af5981da3ca2802f4dd6f7de1ee0b25ce", "parents": ["31adad19ac0c360ecab9ac66787e07e3c66c13a6"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1399628 - Disable Shield extension in Marionette and geckodriver. r=ato\n\nShield experiments interfer with core features of Firefox which can\ncause tests run via Marionette or geckodriver to fail. Resetting the\nAPI URL will make sure that no experiments can be downloaded.\n\nMozReview-Commit-ID: HnE49jfnen7", "files": ["testing/geckodriver/src/prefs.rs", "testing/marionette/client/marionette_driver/geckoinstance.py", "testing/marionette/server.js"], "git_node": null, "git_parents": [null], "node": "e5660fb96ca6a97dfd255d2df8e0aa2f8f076fbe", "parents": ["2e6f093af5981da3ca2802f4dd6f7de1ee0b25ce"], "tags": []}, {"author": "Steve Armand \u003cstevea1@mac.com\u003e", "branch": "default", "desc": "Bug 1397852 - Enable flake8 linter on testing/xpcshell. r=ahal\n\nMozReview-Commit-ID: CvZVXQPx8jF", "files": ["testing/xpcshell/mach_commands.py", "testing/xpcshell/remotexpcshelltests.py", "testing/xpcshell/runxpcshelltests.py", "testing/xpcshell/selftest.py", "testing/xpcshell/xpcshellcommandline.py", "tools/lint/flake8.yml"], "git_n