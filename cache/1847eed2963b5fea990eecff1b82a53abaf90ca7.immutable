ocAccessibleChild.h", "accessible/ipc/win/PDocAccessible.ipdl", "accessible/tests/mochitest/treeupdate/test_ariaowns.html"], "git_node": null, "git_parents": [null], "node": "ca2f2ff689cc282c77f3a5d7f9725be7273519e2", "parents": ["4566eb0d57603d7958c28baf70a2b48bd65620c1"], "tags": []}, {"author": "Andrew Halberstadt \u003cahalberstadt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1324961 - [reftest] Process stdout/stderr separately on Windows. r=gbrown, a=test-only\n\nOn Windows log lines are buffered in 4kb chunks instead of line buffered. This\nmeans when a log on stdout exceeds this limit, a log from stderr can be\ninterleaved in the middle. This was causing frequent intermittent failures on\nWindows when logging the suite_start message (which is much larger than 4kb).\n\nThis patch ensures that instead of redirecting stderr to stdout, we process\nthat stream independtly (though still using the same output handler). This\nmeans we are guaranteed not to have any log interleaving, but it comes at the\ncost of potentially losing the true log ordering. For that reason, this\nbehaviour is only enabled on Windows. Only the ordering between streams can be\ndifferent, and in practice this difference should be really small.\n\nThere is currently no good solution for both separating stdout/stderr and\npreserving exact log ordering. See bug 798300 for more details.\n\nMozReview-Commit-ID: 5W8I4u15uyM", "files": ["layout/tools/reftest/runreftest.py"], "git_node": null, "git_parents": [null], "node": "21e3f04ae989fd57b7a4acfa948e8587784dcf4b", "parents": ["ca2f2ff689cc282c77f3a5d7f9725be7273519e2"], "tags": []}], "date": 1507394534, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "7915": {"changesets": [{"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1406150 - Always throw exceptions by using 'new'. r=maja_zf, a=test-only\n\nMozReview-Commit-ID: GmI1PuSQwWU", "files": ["testing/marionette/driver.js", "testing/marionette/navigate.js", "testing/marionette/packets.js"], "git_node": null, "git_parents": [null], "node": "9802ea8f6220173617b75cb0ab740f1e1f88f8ad", "parents": ["21e3f04ae989fd57b7a4acfa948e8587784dcf4b"], "tags": []}], "date": 1507396197, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "7916": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nhu -\u003e c113d68bb93e\nlt -\u003e 36ce7bfa21e3\nne-NP -\u003e e0edfc85b833\nnn-NO -\u003e 8d9577daa698\nsv-SE -\u003e acdb6f0c8e1a\nth -\u003e 913cdefbce4e\ntr -\u003e f5c5880c6c32\nur -\u003e beae275c47f7", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "7a2a6f27fb5ba8bc72a9ea3c8ef8556bb5beebb7", "parents": ["9802ea8f6220173617b75cb0ab740f1e1f88f8ad"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nbn-BD -\u003e be84e9954df8\nfr -\u003e b22eee1ddd0c\ngu-IN -\u003e fde59e0638e8\nhu -\u003e c113d68bb93e\nis -\u003e bf686a5dd634\nit -\u003e 6e48c2e2b103\nkk -\u003e 38e0c2d0a2d0\nlt -\u003e 36ce7bfa21e3\nnn-NO -\u003e 8d9577daa698\nsr -\u003e 089052c512b7\nsv-SE -\u003e 66537619aa3a\nth -\u003e 0232ba6432ab\ntr -\u003e 3f3985130eb4", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "6c41354d9fa7d317845d70befa8bab88fc9a235d", "parents": ["7a2a6f27fb5ba8bc72a9ea3c8ef8556bb5beebb7"], "tags": []}], "date": 1507396849, "git_changesets": [null, null], "user": "ffxbld"}, "7917": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nru -\u003e 34fc5faea30a\nsk -\u003e d0b1a1cf1208\ntr -\u003e 7f392bff0891