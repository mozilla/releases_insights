/marionette/harness/marionette_harness/tests/unit/unit-tests.ini"], "git_node": null, "git_parents": [null], "node": "fd9981ab28fc3fadf79d0171722e177a43f012d8", "parents": ["5d3f98983448a831397b33be10febb4ad9267a35"], "tags": []}, {"author": "Bryce Van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1367955 - Remove onended handler during ended handling to avoid video.ended race issues. r=pehrsons, a=test-only\n\nBug 1386489 means that ended is not reliably set in relation to the test\nseeking machinery. This results in the following behaviour being possible:\n- seekToNextFrame seeks to last frame\n- the seek promise resolves and invokes check to see if video has ended\n- ended is not yet set (race), so another seekToNextFrame is setup\n- onended handler is invoked at some point (1st time)\n- seekToNextFrame seeks again, remains at last frame\n- oneended handler is invoked again due to the seek (2nd time)\n- finish() has been called twice\n\nThis changeset should bandaid the above being possible.\n\nMozReview-Commit-ID: BkskWUnaJQ9", "files": ["dom/media/test/test_mediarecorder_record_changing_video_resolution.html"], "git_node": null, "git_parents": [null], "node": "c90b8de0f6c7788386cc1e11b92480a1ad66e01a", "parents": ["fd9981ab28fc3fadf79d0171722e177a43f012d8"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1409761 - Create dom.serviceWorkers.disable_open_click_delay and set it to a larger value on fennec. r=smaug, a=ritu", "files": ["dom/workers/ServiceWorkerPrivate.cpp", "dom/workers/test/serviceworkers/test_notificationclick_focus.html", "dom/workers/test/serviceworkers/test_openWindow.html", "mobile/android/app/mobile.js", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "bde9007b5de95632d12388fbebaba527051b409e", "parents": ["c90b8de0f6c7788386cc1e11b92480a1ad66e01a"], "tags": []}, {"author": "Nils Ohlmeier [:drno] \u003cdrno@ohlmeier.org\u003e", "branch": "default", "desc": "Bug 1410654 - Extend WebRTC Scalar Telemetry probes to 62. r=francois, r=mjf, a=ritu\n\nMozReview-Commit-ID: JbXfJdIHN1a", "files": ["toolkit/components/telemetry/Scalars.yaml"], "git_node": null, "git_parents": [null], "node": "3abd8b94efc9a1f44593586ef5a900155215105c", "parents": ["bde9007b5de95632d12388fbebaba527051b409e"], "tags": []}, {"author": "dw-dev \u003cdw-dev@gmx.com\u003e", "branch": "default", "desc": "Bug 1404681 - Change to FrameLoader.print(). r=smaug, a=ritu\n\nChanges FrameLoader.print() WebIDL declaration to allow 3rd argument\n(print progress listener) to be null or omitted.\n\nThis change allows tabs.saveAsPDF(), which calls FrameLoader.print()\nwith a null 3rd argument, to work correctly in Firefox 57.\n\nMozReview-Commit-ID: AAHgPuMTvDe", "files": ["dom/webidl/FrameLoader.webidl"], "git_node": null, "git_parents": [null], "node": "362e0a86dac7d2cab5c059dad21baf5b1f7e6e40", "parents": ["3abd8b94efc9a1f44593586ef5a900155215105c"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411060 - Don't show extension controlled message if add-on isn't installed. r=bsilverberg, a=ritu\n\nMozReview-Commit-ID: Fxo4sKgEWPd", "files": ["browser/components/preferences/in-content/main.js", "browser/components/preferences/in-content/tests/browser_homepages_filter_aboutpreferences.js", "toolkit/components/extensions/ExtensionSettingsStore.jsm"], "git_node": null, "git_parents": [null], "node": "ea74ebdb0dc7ac37507daf66db0f224c53c3420f", "parents": ["362e0a86dac7d2cab5c059dad21baf5b1f7e6e40"], "tags": []}, {"author": "Edouard Oger \u003ceoger@fastmail.com\u003e", "branch": "default", "desc": "Bug 1411714 - Handle action=email in about:accounts. r=tcsc, a=ritu\n\nMozReview-Commit-ID: 5U6Qy78S1Nl", "files": ["browser/app/profile/firefox.js", "browser/base/content/aboutaccounts/aboutaccounts.js", "browser/base/content/test/sync/browser_aboutAccounts.js", "services/fxaccounts/FxAccounts.jsm", "services/fxaccounts/FxAccountsConfig.jsm"], "git_node": null, "git_parents": [null], "node": "f5458aea49dc3b1488912ff711bfcaff59a99d38", "parents": ["ea74ebdb0dc7ac37507daf66db0f224c53c3420f"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1409155 - IMEHandler should not associate IMC with any window if active IME is ATOK 2010 or earlier with x64 build on Win8 or later. r=m_kato, a=ritu\n\nATOK started to be TIP of TSF since 2011.  Older than it, i.e., ATOK 2010 and\nearlier have a lot of problems even for daily use.  Perhaps, the reason is\nWin 8 has a lot of changes around IMM-IME support and TSF, and ATOK 2010 is\nreleased earlier than Win 8.\n\nATOK 2006 crashes while converting a word with candidate window.\nATOK 2007 doesn't paint and resize suggest window and candidate window\ncorrectly (showing white window or too big window).\nATOK 2008 and ATOK 2009 crash when user just opens their open state.\nATOK 2010 isn't installable newly on Win 7 or later, but we have a lot of\ncrash reports.\n\nNote that ATOK 2006 is the first version supporting Win XP x64.  So, ATOK 2005\nmust not support x64 apps.\n\nUnfortunately, we cannot block loading DLLs of them.  Therefore, IMEHandler\nshould disassociate IMC from active window when user changes active keyboard\nlayout to the legacy ATOK and not associate IME with any window when\nSetInputContext() is called even with \"enabled\".  Additionally, when user\nchanges active keyboard layout from the legacy ATOK to one of the other\nkeyboard layouts, IMEHandler should associate IMC with current window for\nnew active IME.\n\nMozReview-Commit-ID: RVYwmYxzO7", "files": ["widget/windows/IMMHandler.cpp", "widget/windows/IMMHandler.h", "widget/windows/WinIMEHandler.cpp", "widget/windows/WinIMEHandler.h", "widget/windows/nsWindowBase.h"], "git_node": null, "git_parents": [null], "node": "5faabed7438613b088c5d5020b93b63cafd3dc7b", "parents": ["f5458aea49dc3b1488912ff711bfcaff59a99d38"], "tags": []}, {"author": "Jeremy Chen \u003cjeremychen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411517 - stylo: \"layout.css.stylo-blocklist.enabled\" pref's default value should be false. r=xidorn, a=ritu\n\nAt present, the \"layout.css.stylo-blocklist.blocked_domains\" pref is empty. It\nis probably meaningless to set \"layout.css.stylo-blocklist.enabled\" pref to true\nby default. We can set \"layout.css.stylo-blocklist.enabled\" pref to true by the\nstyloblocklist system add-on once the \"layout.css.stylo-blocklist.blocked_domains\"\npref is non-empty.\n\nMozReview-Commit-ID: 2B5JnGEafLo", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "4465ffadaee29e821fe0e448fe6277c87f3f36d2", "parents": ["5faabed7438613b088c5d5020b93b63cafd3dc7b"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1412011 - selectors: Be consistent about how we get a parent element for selector matching. r=xidorn, a=ritu\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: de7595f16fa41c32ca5654aef53c60ad19bb108a", "files": ["servo/components/selectors/matching.rs"], "git_node": null, "git_parents": [null], "node": "815223882b4c199b2fba87e9784cbff1998e1868", "parents": ["4465ffadaee29e821fe0e448fe6277c87f3f36d2"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1412011 - Test SVG \u003cuse\u003e element matching rules. r=dholbert, a=ritu\n\nMozReview-Commit-ID: 9syd1Nlx2Iv", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/svg/linking/reftests/use-descendant-combinator-001.html", "testing/web-platform/tests/svg/linking/reftests/use-descendant-combinator-002.html", "testing/web-platform/tests/svg/linking/reftests/use-descendant-combinator-ref.html"], "git_node": null, "git_parents": [null], "node": "ccd297b281ffeab4110e30d3130dccc