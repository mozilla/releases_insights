owser/extensions/activity-stream/data/content/activity-stream.css", "browser/extensions/activity-stream/data/content/activity-stream.html", "browser/extensions/activity-stream/data/locales.json", "browser/extensions/activity-stream/install.rdf.in", "browser/extensions/activity-stream/lib/ActivityStream.jsm", "browser/extensions/activity-stream/lib/HighlightsFeed.jsm", "browser/extensions/activity-stream/test/unit/lib/HighlightsFeed.test.js"], "git_node": null, "git_parents": [null], "node": "12d215a0f9524e8ab82a609f7b414860f2aab8cb", "parents": ["7ddc2c24550bcc5be6f00823bd7f6cd9ff77fbc4"], "tags": []}, {"author": "Nico Grunbaum", "branch": "default", "desc": "Bug 1393095 - remote audio receiver stats missing;r=dminor,jesup\n\nMozReview-Commit-ID: 9izPPOqybcK", "files": ["media/webrtc/signaling/src/media-conduit/AudioConduit.cpp", "media/webrtc/trunk/webrtc/voice_engine/channel.cc", "media/webrtc/trunk/webrtc/voice_engine/channel.h", "media/webrtc/trunk/webrtc/voice_engine/channel_proxy.cc", "media/webrtc/trunk/webrtc/voice_engine/channel_proxy.h"], "git_node": null, "git_parents": [null], "node": "e354373c68a2853b8b1553b74da2e93c9a99a492", "parents": ["12d215a0f9524e8ab82a609f7b414860f2aab8cb"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1399546: Remove broken code for handling the body text color. r=bholley,Manishearth\n\nMozReview-Commit-ID: AfAT9DgzvI7\n", "files": ["layout/style/ServoStyleSet.cpp"], "git_node": null, "git_parents": [null], "node": "cd3a11354b72de2b9001c2ad83b6f1b7663fd4a0", "parents": ["e354373c68a2853b8b1553b74da2e93c9a99a492"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1399546: Add an API to know if an element is it's document body element. r=heycam\n\nMozReview-Commit-ID: 8mtd4CsoSlU\n", "files": ["layout/style/ServoBindings.cpp", "layout/style/ServoBindings.h"], "git_node": null, "git_parents": [null], "node": "f6de9a593c3c3913b483a6606dbcb493369eb3f6", "parents": ["cd3a11354b72de2b9001c2ad83b6f1b7663fd4a0"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1400072: Move TOP_SITE_COLUMNS/ROWS -\u003e TopSitesPage. r=liuche\n\nThe TopSitesPage should really own details about the appearance of top sites.\n\nMozReview-Commit-ID: LPfHGcUTv00", "files": ["mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/ActivityStreamPanel.java", "mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/topsites/TopSitesPage.java"], "git_node": null, "git_parents": [null], "node": "c710d47517a28487160978de88f76e586fafd449", "parents": ["f6de9a593c3c3913b483a6606dbcb493369eb3f6"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1400072: Make num tiles a constant. r=liuche\n\nSince it's a constant, there's no reason to keep passing it around everywhere.\nAlso, the code that relied on it being a dynamic value is probably broken so\nthere's no reason to continue passing it around.\n\nThat being said, there is bug 1397854, which would have TopSites be 4 rows with\nno pages, but this code is quite messy so I think it'd be worth trying to\nrefactor this code further before trying to implement that.\n\nMozReview-Commit-ID: IoMNHVt67c4", "files": ["mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/ActivityStreamPanel.java", "mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/StreamRecyclerAdapter.java", "mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/stream/TopPanelRow.java", "mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/topsites/TopSitesPage.java", "mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/topsites/TopSitesPageAdapter.java", "mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/topsites/TopSitesPagerAdapter.java"], "git_node": null, "git_parents": [null], "node": "fea444196dee6a021d70f38f5e6884f87f2aa64e", "parents": ["c710d47517a28487160978de88f76e586fafd449"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1400072: Pass in tilesSize when needed, rather than caching. r=liuche\n\nThis will help prevent the cache from going out of date.\n\nMozReview-Commit-ID: GdUXF0oOSiK", "files": ["mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/stream/TopPanelRow.java", "mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/topsites/TopSitesPagerAdapter.java"], "git_node": null, "git_parents": [null], "node": "ec4dcc7799ad8fa5beb6e728b0801e55dd616e0a", "parents": ["fea444196dee6a021d70f38f5e6884f87f2aa64e"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1400072: Cache tilesSize in swapCursor. r=liuche\n\nIn this sense, it acts as a refresh function, binding all of our UI state at\nthe same time, helping to prevent bugs where the UI gets out of sync.\n\nFor example, this fixes this bug because now the tileSize gets updated when we\nswap the cursor, not just when we the page is initially constructed.\n\nMozReview-Commit-ID: 7V2gFyiOJ1R", "files": ["mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/topsites/TopSitesPageAdapter.java", "mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/topsites/TopSitesPagerAdapter.java"], "git_node": null, "git_parents": [null], "node": "45f33d2b572218950d819c0341774d45a40c7bb5", "parents": ["ec4dcc7799ad8fa5beb6e728b0801e55dd616e0a"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1400072: Rm unused variable tilesMargin. r=liuche\n\nMozReview-Commit-ID: G6Z3dUnKWLl", "files": ["mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/topsites/TopSitesPageAdapter.java"], "git_node": null, "git_parents": [null], "node": "cd4c24e98e044705b210d8bb0beb0b93c7016e84", "parents": ["45f33d2b572218950d819c0341774d45a40c7bb5"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1400072: Specify card size in onBind instead of onCreate. r=liuche\n\nI believe this doesn't affect this bug because I think the ViewHolders are\nrecreated on rotation but for any other type of change, only bind will be\ncalled so for correctness, we should update the size in bind.\n\nMozReview-Commit-ID: 3ojO4TF89i4", "files": ["mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/topsites/TopSitesPageAdapter.java"], "git_node": null, "git_parents": [null], "node": "62f03c05db7827f2dcc242bb4b58049e09e1398c", "parents": ["cd4c24e98e044705b210d8bb0beb0b93c7016e84"], "tags": []}, {"author": "Martin Robinson \u003cmrobinson@igalia.com\u003e", "branch": "default", "desc": "servo: Merge #18510 - Properly handle stacking context collection for truncated fragments (from mrobinson:truncated-fragment-stacking-context-collection); r=emilio\n\nBefore we did not properly descend intro truncated fragments when\ncollecting stacking contexts. This change makes sure that we descend\nproperly\n\nFixes #18254.\nFixes #17072.\n\n\u003c!-- Please describe your changes on the following line: --\u003e\n\n---\n\u003c!-- Thank you for contributing to Servo! Please replace each `[ ]` by `[X]` when the step is complete, and replace `__` with appropriate data: --\u003e\n- [x] `./mach build -d` does not report any errors\n- [x] `./mach test-tidy` does not report any errors\n- [x] These changes fix #18254,  #17072 (github issue number if applicable).\n\n\u003c!-- Either: --\u003e\n- [x] There are tests for these changes OR\n- [ ] These changes do not require tests because _____\n\n\u003c!-- Also, please make sure that \"Allow edits from maintainers\" checkbox is checked, so that we can help you if you get stuck somewhere along the way.--\u003e\n\n\u003c!-- Pull requests that do not address these steps are welcome, but they will require additional verification as part of the review process. --\u003e\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 4911706f755f558529cb08f44b0e96be397874ee", "files": ["servo/components/layout/display_list_builder.rs"], "git_node": null, "git_parents": [null], "node": "e8d66b5b8f6ba7ea489e8546b5b7603a4cf4f693", "parents": ["62f03c05db7827f2dcc242bb4b58049e09e1398c"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "servo: Merge #18531 - Reland #18519 (from emilio:body-quirk); r=heycam\n\nThis relands #18519 as-is.\n\nIt was backed-out because some Gecko changes hadn't landed yet, but I just pushed them in a way they wouldn't break the build.\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 3d2dccf1f3e7bf99cb750ee9fd245c24255ad9e2", "files": ["servo/components/layout_thread/dom_wrapper.rs", "servo/components/style/dom.rs", "servo/components/style/gecko/generated/bindings.rs", "servo/components/style/gecko/media_queries.rs", "servo/components/style/gecko/wrapper.rs", "servo/components/style/matching.rs", "servo/components/style/servo/media_queries.rs", "servo/components/style/values/specified/color.rs"], "git_node": null, "git_parents": [null], "node": "68a115ea40024978a64f01782e86f6bc53074bdb", "parents": ["e8d66b5b8f6ba7ea489e8546b5b7603a4cf4f693"], "tags": []}, {"author": "Matt Brubeck \u003cmbrubeck@limpet.net\u003e", "branch": "default", "desc": "servo: Merge #18511 - Update to smallbitvec 1.0.6 (from mbrubeck:always-be-updating); r=KiChjang\n\nIncludes servo/smallbitvec#2, a performance fix that is useful for Stylo.\n\n---\n- [x] `./mach build -d` does not report any errors\n- [x] `./mach test-tidy` does not report any errors\n- [x] These changes do not require tests because they update external code only\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: fac923395e6785dc89a0b9982506476c43d7d175", "files": ["servo/Cargo.lock", "servo/components/style/Cargo.toml"], "git_node": null, "git_parents": [null], "node": "5062ee0a6174aaf097fac02f811193b0ae0aa2b5", "parents": ["68a115ea40024978a64f01782e86f6bc53074bdb"], "tags": []}, {"author": "Matt Brubeck \u003cmbrubeck@mozilla.com\u003e", "branch": "default", "desc": "Bug 1341102 - Revendor Rust dependencies.\n\nMozReview-Commit-ID: 49YebxPbiR5", "files": ["third_party/rust/smallbitvec/.cargo-checksum.json", "third_party/rust/smallbitvec/Cargo.toml", "third_party/rust/smallbitvec/benches/bench.rs", "third_party/rust/smallbitvec/src/lib.rs", "toolkit/library/gtest/rust/Cargo.lock", "toolkit/library/rust/Cargo.lock"], "git_node": null, "git_parents": [null], "node": "b020722d08c09d44e64c3f89a0108820de76b676", "parents": ["5062ee0a6174aaf097fac02f811193b0ae0aa2b5"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1400489: Restrict global sharing to desktop Firefox. r=tcampbell\n\nMozReview-Commit-ID: Gese366rNCH", "files": ["browser/app/profile/firefox.js", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "a2832e30d3549b88a43fd545786672904ef22b9f", "parents": ["b020722d08c09d44e64c3f89a0108820de76b676"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1395688 - Update jsshell for minifying Fennec JS code; r=nalexander\n\nUpdate the host jsshell, which is used for minifying Fennec JS code, to\nthe one from the 56 release, so minification works again.\n\nMozReview-Commit-ID: K87XQrAbC9p", "files": ["mobile/android/config/tooltool-manifests/android-x86/releng.manifest", "mobile/android/config/tooltool-manifests/android/releng.manifest"], "git_node": null, "git_parents": [null], "node": "f90546e2947f1cc8381b4faf2c61e6cedc85831e", "parents": ["a2832e30d3549b88a43fd545786672904ef22b9f"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 70f5f23a429f (bug 1397407) for letting Talos g1 timeout and spam its log on Linux x64 QuantumRender opt. r=backout a=backout\n\nMozReview-Commit-ID: DOv1JPa2f7U", "files": ["gfx/layers/wr/WebRenderLayerManager.cpp"], "git_node": null, "git_parents": [null], "node": "c99a1520c7a5af8f3769d3a4fce38697ce47cbb2", "parents": ["6be5c7d30d2def62a762ac187252eba626b23a92"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "merge autoland to mozilla-central. r=merge a=merge\n\nMozReview-Commit-ID: DStzDVD5j1G", "files": ["browser/extensions/onboarding/content/img/watermark64.png", "services/common/modules-testing/utils.js", "services/common/tests/unit/test_utils_deepCopy.js", "third_party/rust/libudev-sys/target/build/check_udev_hwdb_new", "third_party/rust/libudev-sys/target/build/check_udev_hwdb_new.rs", "toolkit/locales/en-US/chrome/global/aboutTelemetry.properties"], "git_node": null, "git_parents": [null, null], "node": "6c1b45e7e94dbf343813eda03f1fd0b3259b59b1", "parents": ["c99a1520c7a5af8f3769d3a4fce38697ce47cbb2", "f90546e2947f1cc8381b4faf2c61e6cedc85831e"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "merge mozilla-central to mozilla-inbound. r=merge a=merge", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null, null], "node": "7bd452a934baa2c1f907bb7d5846aba51242afbc", "parents": ["5657bd411b28daebe0cbb5c170279fa4065c2a89", "6be5c7d30d2def62a762ac187252eba626b23a92"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400181 - Return mochitests to structured logging; r=ahal\n\nRemoval of jetpack in bug 1371065 accidentally switched all remaining\nmochitest flavors to unstructured; let's switch it back.", "files": ["testing/mozharness/configs/unittests/linux_unittest.py", "testing/mozharness/configs/unittests/mac_unittest.py", "testing/mozharness/configs/unittests/win_unittest.py"], "git_node": null, "git_parents": [null], "node": "8a5a46b8c9d195bcc68f796ba63d8a80c209402a", "parents": ["7bd452a934baa2c1f907bb7d5846aba51242afbc"], "tags": []}, {"author": "Andrew Sutherland \u003casutherland@asutherland.org\u003e", "branch": "default", "desc": "Bug 1378949 - Fix SW notification tests that assumed activated SW to wait for activation. r=bkelly\n\nBug 1378949 found test_notificationclick_focus.html timing out because the\nServiceWorker activation raced the creation of an iframe document that wanted\nto be controlled by the serviceworker.\n\nThe documents that wanted to be controlled had a half-hearted attempt at\ndealing with this by using navigator.serviceWorker.ready, but that would only\nwork if the SW's attempted to claim the clients if they already existed, which\nthey did not.\n\nThis patch cleans up the defective test and its sibling tests that follow the\nsame idioms.", "files": ["dom/workers/test/serviceworkers/test_notificationclick-otherwindow.html", "dom/workers/test/serviceworkers/test_notificationclick.html", "dom/workers/test/serviceworkers/test_notificationclick_focus.html", "dom/workers/test/serviceworkers/test_notificationclose.html"], "git_node": null, "git_parents": [null], "node": "9eea474dfa80304f40f9c12c277e9c731da744cc", "parents": ["8a5a46b8c9d195bcc68f796ba63d8a80c209402a"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397058 - Fix reftest annotations for box-decoration-break-with-outset-box-shadow-1.html", "files": ["layout/reftests/css-break/reftest.list"], "git_node": null, "git_parents": [null], "node": "4e8d6d2c8216a3805d354bdaa0e92d81debd662a", "parents": ["9eea474dfa80304f40f9c12c277e9c731da744cc"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1385512 - Do not race with gcBytes, r=jonco", "files": ["js/src/jit-test/tests/debug/bug1109328.js"], "git_node": null, "git_parents": [null], "node": "c385f15231d2a6dbbf8ffcbc3bf49fa18ee51282", "parents": ["4e8d6d2c8216a3805d354bdaa0e92d81debd662a"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1391877 - Restrict Windows to a single test worker for jit-tests, r=jonco", "files": ["js/src/devtools/automation/autospider.py"], "git_node": null, "git_parents": [null], "node": "5d86f27fe905246f8a3211da099f5e546315188b", "parents": ["c385f15231d2a6dbbf8ffcbc3bf49fa18ee51282"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 906b8bdd2002 (bug 1400347) for failing talos tpaint. r=backout", "files": ["mobile/android/components/extensions/test/mochitest/file_ext_tabs_captureVisibleTab.html", "mobile/android/components/extensions/test/mochitest/mochitest.ini", "mobile/android/components/extensions/test/mochitest/test_ext_tabs_captureVisibleTab.html"], "git_node": null, "git_parents": [null], "node": "1a6381a51810fed75d99cdf04b6735abfe78922a", "parents": ["5d86f27fe905246f8a3211da099f5e546315188b"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 4360d673edef (bug 1380959) for failing talos tpaint. r=backout", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "2d5650ab1aeca067c7b21584e73813761ffc4dca", "parents": ["1a6381a51810fed75d99cdf04b6735abfe78922a"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1373852 - Map font-kerning:normal to the appropriate low-level feature depending on orientation. r=jrmuizel", "files": ["gfx/src/nsFont.cpp", "gfx/src/nsFont.h", "gfx/src/nsFontMetrics.cpp"], "git_node": null, "git_parents": [null], "node": "28ee946c28686298dacd8b782eb21335c017eb3b", "parents": ["2d5650ab1aeca067c7b21584e73813761ffc4dca"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1373852 - Update WPT metadata now that font-kerning-03 is no longer expected to fail. r=me", "files": ["testing/web-platform/meta/css/css-fonts-3/font-kerning-03.html.ini"], "git_node": null, "git_parents": [null], "node": "7e5b28819e5b382bea8cbcccf0c6402fe0e90192", "parents": ["28ee946c28686298dacd8b782eb21335c017eb3b"], "tags": []}, {"author": "Florian Qu\u00e8ze \u003cflorian@queze.net\u003e", "branch": "default", "desc": "Bug 1379587 - Avoid white flash when opening new windows, r=mconley.", "files": ["browser/base/content/browser.js", "browser/base/content/tab-content.js", "browser/base/content/tabbrowser.xml"], "git_node": null, "git_parents": [null], "node": "95af17933c45ca0b02ea4e1cfe0c675cc95f11b8", "parents": ["7e5b28819e5b382bea8cbcccf0c6402fe0e90192"], "tags": []}, {"author": "Florian Qu\u00e8ze \u003cflorian@queze.net\u003e", "branch": "default", "desc": "Bug 1379587 - fix tests that rely on scrolling on a not-yet-painted browser, r=mconley.", "files": ["dom/events/test/test_bug574663.html", "dom/events/test/window_wheel_default_action.html"], "git_node": null, "git_parents": [null], "node": "0533dbf2956818762fbbe7dbcfad738fe8383d89", "parents": ["95af17933c45ca0b02ea4e1cfe0c675cc95f11b8"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset 963bf9d85732 (bug 1398646) for causing bug 1400288. r=backout\n\nMozReview-Commit-ID: Ivc7RmGx0j5", "files": ["netwerk/dns/nsDNSService2.cpp"], "git_node": null, "git_parents": [null], "node": "5473323817b8b412f492307ce3b7a2bd72f59b21", "parents": ["0533dbf2956818762fbbe7dbcfad738fe8383d89"], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397214 - Prevent ContentChild::RecvSetXPCOMProcessAttributes from running after shutdown. r=ehsan\n\nSince ContentChild itself may be created before the observer service is\nstarted, we cannot create an observer to simply listen for the\nxpcom-shutdown event. Thankfully we do not need to do anything special\nupon receiving the event -- we just need to know if it has been fired\nwhen we called RecvSetXPCOMProcessAttributes. As such, this patch\ncreates a canary using ClearOnShutdown. If the canary is cleared, then\nwe know xpcom-shutdown has been issued, and we should abort the\ninitialization process.\n\nfixup", "files": ["dom/ipc/ContentChild.cpp", "dom/ipc/ContentChild.h"], "git_node": null, "git_parents": [null], "node": "47901a63dd2befc5c202cd8466e5ef9947215d71", "parents": ["5473323817b8b412f492307ce3b7a2bd72f59b21"], "tags": []}, {"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 1400319 - Implement the photon styles for the rule view search highlights. r=jdescottes", "files": ["devtools/client/themes/rules.css", "devtools/client/themes/toolbars.css", "devtools/client/themes/variables.css"], "git_node": null, "git_parents": [null], "node": "0d93c364b753c9ecde20ab8e961bba61a9bb894d", "parents": ["47901a63dd2befc5c202cd8466e5ef9947215d71"], "tags": []}, {"author": "Christoph Kerschbaumer \u003cckerschb@christophkerschbaumer.com\u003e", "branch": "default", "desc": "Bug 1400347 - Update test_ext_tabs_captureVisibleTab.html to comply with new toplevel data: URI navigation policy. r=bz", "files": ["mobile/android/components/extensions/test/mochitest/file_ext_tabs_captureVisibleTab.html", "mobile/android/components/extensions/test/mochitest/mochitest.ini", "mobile/android/components/extensions/test/mochitest/test_ext_tabs_captureVisibleTab.html"], "git_node": null, "git_parents": [null], "node": "0659ef1d09b286d37fbbf88a3d2c202a0c63fcc2", "parents": ["0d93c364b753c9ecde20ab8e961bba61a9bb894d"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 864845 part 1.  Stop using 'content' in devtools tests.  r=ochameau\n\nMozReview-Commit-ID: 5PppAzRx5JG", "files": ["devtools/client/inspector/boxmodel/test/browser_boxmodel_update-after-navigation.js", "devtools/client/inspector/boxmodel/test/head.js", "devtools/client/inspector/grids/test/browser_grids_grid-list-on-mutation-element-added.js", "devtools/client/inspector/grids/test/browser_grids_grid-list-on-mutation-element-removed.js", "devtools/client/inspector/grids/test/browser_grids_grid-outline-updates-on-grid-change.js", "devtools/client/inspector/markup/test/browser_markup_copy_image_data.js", "devtools/client/inspector/markup/test/browser_markup_html_edit_02.js", "devtools/client/inspector/markup/test/browser_markup_html_edit_03.js", "devtools/client/inspector/markup/test/browser_markup_keybindings_scrolltonode.js", "devtools/client/inspector/markup/test/browser_markup_mutation_01.js", "devtools/client/inspector/markup/test/browser_markup_mutation_02.js", "devtools/client/inspector/markup/test/browser_markup_node_not_displayed_02.js", "devtools/client/inspector/markup/test/browser_markup_update-on-navigtion.js", "devtools/client/inspector/markup/test/head.js", "devtools/client/inspector/rules/test/browser_rules_grid-highlighter-on-mutation.js", "devtools/client/inspector/rules/test/browser_rules_shapes-toggle_05.js", "devtools/client/inspector/rules/test/head.js", "devtools/client/inspector/test/browser_inspector_menu-06-other.js"], "git_node": null, "git_parents": [null], "node": "cd97f24d9ae779f1cb7808c2133df29e05a62b2f", "parents": ["0659ef1d09b286d37fbbf88a3d2c202a0c63fcc2"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 864845 part 2.  Make window.content chromeonly in nightly.  r=mystor\n\nMozReview-Commit-ID: Q7hTmngEgI", "files": ["dom/tests/mochitest/bugs/test_bug440572.html", "dom/webidl/Window.webidl", "testing/talos/talos/pageloader/chrome/tscroll.js"], "git_node": null, "git_parents": [null], "node": "0f52a45c01dc0f1cb55a01434e36e75337228b1c", "parents": ["cd97f24d9ae779f1cb7808c2133df29e05a62b2f"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1398500 part 1.  Switch the viewport scrollbar override stuff to use Element, not nsIContent.  r=dholbert\n\nMozReview-Commit-ID: FU0Afemj4XD", "files": ["dom/base/Element.cpp", "layout/base/RestyleManager.cpp", "layout/base/nsPresContext.cpp", "layout/base/nsPresContext.h"], "git_node": null, "git_parents": [null], "node": "4553f8ff4114c0a9c742564da3b1122c89429e58", "parents": ["0f52a45c01dc0f1cb55a01434e36e75337228b1c"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1398500 part 2.  Make sure that if we start propagating scroll to viewport from a new body element we reframe it as needed.  r=dholbert\n\nMozReview-Commit-ID: K54u9NmAlpn", "files": ["layout/base/crashtests/1398500.html", "layout/base/crashtests/crashtests.list", "layout/base/nsCSSFrameConstructor.cpp", "layout/reftests/bugs/1398500-1-ref.html", "layout/reftests/bugs/1398500-1.html", "layout/reftests/bugs/reftest.list"], "git_node": null, "git_parents": [null], "node": "28bdfd821210b61b8d0196cbc3c99dd06b3730e9", "parents": ["4553f8ff4114c0a9c742564da3b1122c89429e58"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1400275.  Ensure we create reflectors for JS-implemented webidl interfaces with the right prototype when those interfaces are subclassed.  r=qdot\n\nMozReview-Commit-ID: 5yYD92NVVFQ", "files": ["dom/bindings/Codegen.py", "dom/bindings/test/mochitest.ini", "dom/bindings/test/test_jsimplemented_subclassing.html"], "git_node": null, "git_parents": [null], "node": "06ee47ac7e4d5d256639874421a550f957792a5f", "parents": ["28bdfd821210b61b8d0196cbc3c99dd06b3730e9"], "tags": []}, {"author": "Randell Jesup \u003crjesup@jesup.org\u003e", "branch": "default", "desc": "Bug