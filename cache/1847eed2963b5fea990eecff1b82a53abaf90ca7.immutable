se a startup_timeout of 180s for Marionette on all platforms. r=gbrown\n\nCurrently only the Mochitests on Linux use a startup_timeout of 180s\nfor Marionette. This would also be necessary for the other platforms\n(MacOS and Windows).\n\nMozReview-Commit-ID: TGO7XDLXdI", "files": ["testing/mozharness/configs/unittests/mac_unittest.py", "testing/mozharness/configs/unittests/win_taskcluster_unittest.py"], "git_node": null, "git_parents": [null], "node": "58ddccff074b04b4f0db5640595882e42fb91017", "parents": ["e2043e1c37471e839548473bd5529fc697795683"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399946 - Bump version number of eslint-plugin-mozilla for releasing the dependency fixes from bug 1395879. r=ahal\n\nMozReview-Commit-ID: 79nDcgcvm0c", "files": ["tools/lint/eslint/eslint-plugin-mozilla/package-lock.json", "tools/lint/eslint/eslint-plugin-mozilla/package.json"], "git_node": null, "git_parents": [null], "node": "07684fbf1ab2b5cfcaf4eb43593f43c176e9db7b", "parents": ["58ddccff074b04b4f0db5640595882e42fb91017"], "tags": []}, {"author": "Luke Wagner \u003cluke@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400383 - clamp HelperThreadState.cpuCount to 8 (r=lth,jandem)\n\nMozReview-Commit-ID: 2SswWMPKqHX", "files": ["js/src/vm/HelperThreads.cpp"], "git_node": null, "git_parents": [null], "node": "06dfdd5999997878e7eff2d3a11fb8d54ef81bd5", "parents": ["026e90a816383c339b5b1eb55a0afe87054165b7"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399471 part 1 - Disable the full_debug_checks jit pref by default in browser builds. r=nbp", "files": ["js/src/builtin/RegExp.cpp", "js/src/irregexp/RegExpMacroAssembler.cpp", "js/src/irregexp/RegExpStack.cpp", "js/src/jit-test/tests/wasm/integer.js", "js/src/jit/Bailouts.cpp", "js/src/jit/BaselineDebugModeOSR.cpp", "js/src/jit/CodeGenerator.cpp", "js/src/jit/IonCacheIRCompiler.cpp", "js/src/jit/MacroAssembler-inl.h", "js/src/jit/MacroAssembler.cpp", "js/src/jit/MacroAssembler.h", "js/src/jit/SharedIC.cpp", "js/src/jit/VMFunctions.cpp", "js/src/jit/arm/CodeGenerator-arm.cpp", "js/src/jit/arm/MacroAssembler-arm.cpp", "js/src/jit/arm/SharedIC-arm.cpp", "js/src/jit/arm/Trampoline-arm.cpp", "js/src/jit/arm64/MacroAssembler-arm64.cpp", "js/src/jit/arm64/Trampoline-arm64.cpp", "js/src/jit/mips32/MacroAssembler-mips32.cpp", "js/src/jit/mips32/Trampoline-mips32.cpp", "js/src/jit/mips64/MacroAssembler-mips64.cpp", "js/src/jit/mips64/Trampoline-mips64.cpp", "js/src/jit/x64/MacroAssembler-x64.cpp", "js/src/jit/x64/Trampoline-x64.cpp", "js/src/jit/x86/CodeGenerator-x86.cpp", "js/src/jit/x86/MacroAssembler-x86.cpp", "js/src/jit/x86/Trampoline-x86.cpp", "js/src/jsarray.cpp", "js/src/jsboolinlines.h", "js/src/jscntxt.cpp", "js/src/jscntxt.h", "js/src/jslibmath.h", "js/src/jsmath.cpp", "js/src/vm/ArgumentsObject.cpp", "js/src/vm/NativeObject.cpp"], "git_node": null, "git_parents": [null], "node": "e758012cf5b3eadc98f2c5428724e483338ec11b", "parents": ["06dfdd5999997878e7eff2d3a11fb8d54ef81bd5"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset e758012cf5b3 for landing with the wrong commit message.", "files": ["js/src/builtin/RegExp.cpp", "js/src/irregexp/RegExpMacroAssembler.cpp", "js/src/irregexp/RegExpStack.cpp", "js/src/jit-test/tests/wasm/integer.js", "js/src/jit/Bailouts.cpp", "js/src/jit/BaselineDebugModeOSR.cpp", "js/src/jit/CodeGenerator.cpp", "js/src/jit/IonCacheIRCompiler.cpp", "js/src/jit/MacroAssembler-inl.h", "js/src/jit/MacroAssembler.cpp", "js/src/jit/MacroAssembler.h", "js/src/jit/SharedIC.cpp", "js/src/jit/VMFunctions.cpp", "js/src/jit/arm/CodeGenerator-arm.cpp", "js/src/jit/arm/MacroAssembler-arm.cpp", "js/src/jit/arm/SharedIC-arm.cpp", "js/src/jit/arm/Trampoline-arm.cpp", "js/src/jit/arm64/MacroAssembler-arm64.cpp", "js/src/jit/arm64/Trampoline-arm64.cpp", "js/src/jit/mips32/MacroAssembler-mips32.cpp", "js/src/jit/mips32/Trampoline-mips32.cpp", "js/src/jit/mips64/MacroAssembler-mips64.cpp", "js/src/jit/mips64/Trampoline-mips64.cpp", "js/src/jit/x64/MacroAssembler-x64.cpp", "js/src/jit/x64/Trampoline-x64.cpp", "js/src/jit/x86/CodeGenerator-x86.cpp", "js/src/jit/x86/MacroAssembler-x86.cpp", "js/src/jit/x86/Trampoline-x86.cpp", "js/src/jsarray.cpp", "js/src/jsboolinlines.h", "js/src/jscntxt.cpp", "js/src/jscntxt.h", "js/src/jslibmath.h", "js/src/jsmath.cpp", "js/src/vm/ArgumentsObject.cpp", "js/src/vm/NativeObject.cpp"], "git_node": null, "git_parents": [null], "node": "09c4c37841280b3db24839e129254865e2409976", "parents": ["e758012cf5b3eadc98f2c5428724e483338ec11b"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399471 part 1 - Disable the full_debug_checks jit pref by default in browser builds. r=nbp", "files": ["js/src/jit/CodeGenerator.cpp", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "d51f41589301e2dc28d3e4390567fa3d31d247af", "parents": ["09c4c37841280b3db24839e129254865e2409976"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400691 - Minor changes to logging for test-verify; r=jmaher", "files": ["testing/mozharness/mozharness/mozilla/testing/verify_tools.py", "testing/mozharness/scripts/desktop_unittest.py"], "git_node": null, "git_parents": [null], "node": "d296dbfbf6cc8f8f1ddee4dbf571d7d80255a91b", "parents": ["d51f41589301e2dc28d3e4390567fa3d31d247af"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Bug 1397083 - Don't use CopySurface when drawing theme with nsNativeThemeGTK. r=lsalzman\n\nCopySurface doesn't respect any existing clips that are applied to the draw\ntarget. It doesn't look like nsNativeThemeGTK uses CopySurface normally, but\nwhen OMTP is enabled the draw target is a DrawTargetCapture which can't\nLockBits() which causes us to use CopySurface. This can cause a reftest failure.\n\nMozReview-Commit-ID: 1mYMhQB0r3M", "files": ["widget/gtk/nsNativeThemeGTK.cpp"], "git_node": null, "git_parents": [null], "node": "05ad12b87422ca2c3cfb14a9c1834d4aece72f31", "parents": ["d296dbfbf6cc8f8f1ddee4dbf571d7d80255a91b"], "tags": []}, {"author": "Randall Barker \u003crbarker@mozilla.com\u003e", "branch": "default", "desc": "Bug 1392705 - part 1: Make UiCompositorControllerChild::Destroy synchronous r=dvander\n\nEnsure the UiCompositorControllerChild is shutdown in the UI thread\nbefore the compositor thread is shutdown by the main thread.\n\nMozReview-Commit-ID: 4hXYxSi9tzz", "files": ["gfx/ipc/InProcessCompositorSession.cpp", "gfx/layers/ipc/UiCompositorControllerChild.cpp"], "git_node": null, "git_parents": [null], "node": "706c7baf6e58484a26cf0fb45d5f23865057c26f", "parents": ["07684fbf1ab2b5cfcaf4eb43593f43c176e9db7b"], "tags": []}, {"author": "Randall Barker \u003crbarker@mozilla.com\u003e", "branch": "default", "desc": "Bug 1392705 - part 2: Ensure LayerManagerComposite::RenderToPresentationSurface checks the compositor widget before using it r=kats\n\nMozReview-Commit-ID: 6EP9Pp4h5cP", "files": ["gfx/layers/composite/LayerManagerComposite.cpp"], "git_node": null, "git_parents": [null], "node": "07751873d49f64a37b27a46fb1d9ca141f1f0127", "parents": ["706c7baf6e58484a26cf0fb45d5f23865057c26f"], "tags": []}, {"author": "Randall Barker \u003crbarker@mozilla.com\u003e", "branch": "default", "desc": "Bug 1392705 - part 3: Call nsBaseWidget::DestroyLayerManager() in nsWindow::Destroy to ensure IPC is not shutdown in the destructor for Android  r=jchen\n\nDue to the indeterminate nature of Gecko shutdown, the ref count of the\nnsWindow on Android would sometimes go to zero before the XPCOM shutdown\nobserver was called in nsBaseWindow which is where the compositor thread\nIPC is shutdown. If nsBaseWindow::Shutdown does not get called, then the\ncompositor thread IPC is shutdown in the nsBaseWindow destructor.\nUnfortunately while the nsWindow is being deleted, it can be accessed in\nthe compositor thread and cause a crash in\nLayerManagerComposite::RenderToPresentationSurface.\nCalling nsBaseWidget::DestroyLayerManager() in nsWindow::Destroy()\nensures it gets called before the destructor gets invoked typically in\nthe Destroy() call.\n\nMozReview-Commit-ID: KCv8SCmEjnb", "files": ["widget/android/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "68c789e404f040b66a8b902b8dff0932e350affc", "parents": ["07751873d49f64a37b27a46fb1d9ca141f1f0127"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400440 - Apply scroll shift for dynamic toolbar to the composited scroll offset right away. r=kats\n\nMozReview-Commit-ID: 1I7C0lFx4WP", "files": ["gfx/layers/apz/src/AsyncPanZoomController.cpp"], "git_node": null, "git_parents": [null], "node": "6d2c4c8a298206a3e0d8905ff2d1e697e8ec22b9", "parents": ["68c789e404f040b66a8b902b8dff0932e350affc"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400440 - Re-enable apz.frame_delay.enabled on Fennec Nightly. r=kats\n\nMozReview-Commit-ID: E7Ukb76vMep", "files": ["mobile/android/app/mobile.js"], "git_node": null, "git_parents": [null], "node": "cffcb90edf577f060ddfc737f548a093b1df605c", "parents": ["6d2c4c8a298206a3e0d8905ff2d1e697e8ec22b9"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1282262 - Disable dom/media/tests/mochitest/test_getUserMedia_mediaStreamClone.html for frequent failures. r=me, a=test-only", "files": ["dom/media/tests/mochitest/mochitest.ini"], "git_node": null, "git_parents": [null], "node": "550b6ae2740fcff21d9d0e8f35d4693ba65a0778", "parents": ["05ad12b87422ca2c3cfb14a9c1834d4aece72f31"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1373347 - Disable /XMLHttp