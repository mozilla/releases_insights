ne by CSSOM. r=birtles, a=sledru\n\nMozReview-Commit-ID: FaBSP4g4FnP", "files": ["layout/reftests/web-animations/child-in-animating-element-display-none-ref.html", "layout/reftests/web-animations/child-in-animating-element-display-none.html", "layout/reftests/web-animations/reftest.list"], "git_node": null, "git_parents": [null], "node": "0da6b667a44dc48788f517e213f680e78c87e0c5", "parents": ["9458811cd8ba36e9cc7bdd9ae315227acf0eb9da"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401801 - Crash test. r=birtles, a=sledru\n\nMozReview-Commit-ID: 4fuwnHtYcBY", "files": ["layout/style/crashtests/1401801.html", "layout/style/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "4320c131a141e90615af4e0e7178172ce5b9b68a", "parents": ["0da6b667a44dc48788f517e213f680e78c87e0c5"], "tags": []}, {"author": "Cameron McCormack \u003ccam@mcc.id.au\u003e", "branch": "default", "desc": "Bug 1403030 - stylo: Fix some mismatching FFI declarations. r=xidorn, a=sledru\n\nMozReview-Commit-ID: C5iBTR0OZKy", "files": ["layout/style/ServoBindingList.h", "layout/style/nsCSSValue.cpp"], "git_node": null, "git_parents": [null], "node": "012dbe7d4f1985b8b54775237ff53d0135e50b54", "parents": ["4320c131a141e90615af4e0e7178172ce5b9b68a"], "tags": []}, {"author": "Cameron McCormack \u003ccam@mcc.id.au\u003e", "branch": "default", "desc": "Bug 1403073 - stylo: Fix some bindgen object layout issues. r=xidorn, a=sledru\n\nMozReview-Commit-ID: CnW4J2ZlmfJ", "files": ["layout/style/ServoBindings.toml", "layout/style/nsCSSValue.h"], "git_node": null, "git_parents": [null], "node": "b21b199adf72fc9b208073fc887e2e50fa82681a", "parents": ["012dbe7d4f1985b8b54775237ff53d0135e50b54"], "tags": []}], "date": 1506537571, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7840": {"changesets": [{"author": "Mike de Boer \u003cmdeboer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401383 - Remove anchor state after transition even if the transition is canceled, and always set main view as current. r=Gijs, a=sledru\n\nWe weren't removing the 'open' attribute from the anchor if the transition didn't complete.\nThis patch fixes this by moving the addition of 'open' into _transitionViews, and its removal into\n_cleanupTransitionPhase.\n\nMozReview-Commit-ID: TS0CcwsHVN", "files": ["browser/components/customizableui/PanelMultiView.jsm", "browser/components/extensions/ext-browserAction.js", "browser/components/extensions/test/browser/browser-common.ini", "browser/components/extensions/test/browser/browser_ext_browserAction_popup_resize.js"], "git_node": null, "git_parents": [null], "node": "d8d8a5dde5bb7cac88081dfe5880e6c3d021f26f", "parents": ["b21b199adf72fc9b208073fc887e2e50fa82681a"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401607 - Photon style console follow-up. r=Honza, a=sledru\n\nRemove the specific console font-size, forces string color to currentColor and\nchange dark theme location filename color.\n\nMozReview-Commit-ID: 842kpNVzN6l", "files": ["devtools/client/themes/components-frame.css", "devtools/client/themes/webconsole.css"], "git_node": null, "git_parents": [null], "node": "d9df1ee777a3c447b7f27d7f781f22cece32ad95", "parents": ["d8d8a5dde5bb7cac88081dfe5880e6c3d021f26f"], "tags": []}, {"author": "Mike de Boer \u003cmdeboer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1402023 - Limit the 'Recent Activity' list in the Library to a maximum of 6 items. r=Gijs, a=sledru\n\nMozReview-Commit-ID: AVHRKvAJjWe", "files": ["browser/components/customizableui/content/panelUI.js"], "git_node": null, "git_parents": [null], "node": "4e9b841f77f14fec64a5aaf390c15fffff3bca33", "parents": ["d9df1ee777a3c447b7f27d7f781f22cece32ad95"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc"