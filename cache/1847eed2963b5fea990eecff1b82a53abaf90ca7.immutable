 ["7d28b5b2217d909d2ea1b820f23112531d1cdf83"], "tags": []}, {"author": "Dragana Damjanovic dd.mozilla@gmail.com", "branch": "default", "desc": "Bug 1410146 - Fix UnknownDecoder. r=mayhemer, a=ritu", "files": ["netwerk/streamconv/converters/nsUnknownDecoder.cpp"], "git_node": null, "git_parents": [null], "node": "5f5a87b7958692cc9713194f1d2fea0675dd1926", "parents": ["ce6aa85a6c1167f412ed202df163cd2959cc1fdb"], "tags": []}], "date": 1509031441, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8057": {"changesets": [{"author": "Rail Aliiev \u003crail@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411981 - Can't schedule publishing in balrog: balrog-release-shipper.py: error: unrecognized arguments: --suffix r=jlorenzo a=release DONTBUILD\n\nMozReview-Commit-ID: LJyn0uifJSQ", "files": ["testing/mozharness/scripts/release/publish_balrog.py"], "git_node": null, "git_parents": [null], "node": "8be6ac878d991a2f15b9f44ffa3695f869220f5e", "parents": ["5f5a87b7958692cc9713194f1d2fea0675dd1926"], "tags": []}], "date": 1509034281, "git_changesets": [null], "user": "raliiev@mozilla.com"}, "8058": {"changesets": [{"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1405177 - Install (slightly) newer pip to install boto. r=nthomas, a=test-only\n\nThis is to avoid hitting https://github.com/pypa/pip/issues/510.\n\nMozReview-Commit-ID: 7TK4DdbpKRD", "files": ["testing/mozharness/scripts/release/antivirus.py", "testing/mozharness/scripts/release/push-candidate-to-releases.py"], "git_node": null, "git_parents": [null], "node": "747911087c22b438e0095b9e5c49ddc54cde4ade", "parents": ["8be6ac878d991a2f15b9f44ffa3695f869220f5e"], "tags": []}], "date": 1509035561, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "8059": {"changesets": [{"author": "Rob Wood \u003crwood@mozilla.com\u003e", "branch": "default", "desc": "Bug 1390908 - Make mitmproxy osx binary available on tooltool and update talos tp6 accordingly. r=jmaher, a=test-only\n\nMozReview-Commit-ID: 4YfZMifpq2p", "files": ["testing/mozharness/mozharness/mozilla/testing/talos.py", "testing/talos/talos.json", "testing/talos/talos/mitmproxy/mitmproxy-rel-bin-osx.manifest"], "git_node": null, "git_parents": [null], "node": "433a682865c1eb4bd7e1e150f0d1dc7619ba3e19", "parents": ["747911087c22b438e0095b9e5c49ddc54cde4ade"], "tags": []}, {"author": "Andrew Halberstadt \u003cahalberstadt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1297515 - Make a copy of third_party/python/virtualenv under testing/mozharness. r=jlund, a=test-only\n\nThis adds a second copy of virtualenv to the tree. We need to do this because\nbuildbot is downloading the 'testing/mozharness' directory directly from\nhg.m.o. It would be hard and risky to also get it to download\n'third_party/python/virtualenv'. So instead, we simply copy it to avoid the\nissue.\n\nBug 1408051 is filed to remove this extra copy once everything is using\ntaskcluster.\n\nMozReview-Commit-ID: GWxkmaZVpsZ", "files": ["testing/mozharness/external_tools/virtualenv/AUTHORS.txt", "testing/mozharness/external_tools/virtualenv/LICENSE.txt", "testing/mozharness/external_tools/virtualenv/MANIFEST.in", "testing/mozharness/external_tools/virtualenv/PKG-INFO", "testing/mozharness/external_tools/virtualenv/README.rst", "testing/mozharness/external_tools/virtualenv/bin/rebuild-script.py", "testing/mozharness/external_tools/virtualenv/docs/Makefile", "testing/mozharness/external_tools/virtualenv/docs/changes.rst", "testing/mozharness/external_tools/virtualenv/docs/conf.py", "testing/mozharness/external_tools/virtualenv/docs/development.rst", "testing/mozharness/external_tools/virtualenv/docs/index.rst", "testing/mozharness/external_tools/virtualenv/docs/installation.rst", "testing/mozharness/external_tools/virtualenv/docs/make.bat", "testing/mozharness/external_tools/virtualenv/docs/reference.rst", "testing/mozharness/external_tools/virtualenv/docs/userguide.rst", "testing/mozharness/external_tools/virtualenv/scripts/virtualenv", "testing/mozharness/external_tools/virtualenv/setup.cfg", "testing/mozharness/external_tools/virtualenv/setup.py", "testing/mozharness/external_tools/virtualenv/site.py", "testing/mozharness/external_tools/virtualenv/tests/__init__.py", "testing/mozharness/external_tools/virtualenv/tests/test_activate.sh", "testing/mozharness/external_tools/virtualenv/tests/test_activate_output.expected", "testing/mozharness/external_tools/virtualenv/tests/test_cmdline.py", "testing/mozharness/external_tools/virtualenv/tests/test_virtualenv.py", "testing/mozharness/external_tools/virtualenv/virtualenv.py", "testing/mozharness/external_tools/virtualenv/virtualenv_embedded/activate.bat", "testing/mozharness/external_tools/virtualenv/virtualenv_embedded/activate.csh", "testing/mozharness/external_tools/virtualenv/virtualenv_embedded/activate.fish", "testing/mozharness/external_tools/virtualenv/virtualenv_embedded/activate.ps1", "testing/mozharness/external_tools/virtualenv/virtualenv_embedded/activate.sh", "testing/mozharness/external_tools/virtualenv/virtualenv_embedded/activate_this.py", "testing/mozharness/external_tools/virtualenv/virtualenv_embedded/deactivate.bat", "testing/mozharness/external_tools/virtualenv/virtualenv_embedded/distutils-init.py", "testing/mozharness/external_tools/virtualenv/virtualenv_embedded/distutils.cfg", "testing/mozharness/external_tools/virtualenv/virtualenv_embedded/python-config", "testing/mozharness/external_tools/virtualenv/virtualenv_embedded/site.py", "testing/mozharness/external_tools/virtualenv/virtualenv_support/__init__.py", "testing/mozharness/external_tools/virtualenv/virtualenv_support/argparse-1.4.0-py2.py3-none-any.whl", "testing/mozharness/external_tools/virtualenv/virtualenv_support/pip-8.1.2-py2.py3-none-any.whl", "testing/mozharness/external_tools/virtualenv/virtualenv_support/setuptools-25.2.0-py2.py3-none-any.whl", "testing/mozharness/external_tools/virtualenv/virtualenv_support/wheel-0.29.0-py2.py3-none-any.whl"], "git_node": null, "git_parents": [null], "node": "073a2a43a15cd103d2671b7e77d6700ddf3690f6", "parents": ["433a682865c1eb4bd7e1e150f0d1dc7619ba3e19"], "tags": []}, {"author": "Andrew Halberstadt \u003cahalberstadt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1297515 - Always use the mozharness vendored copy of virtualenv. r=jlund, a=test-only\n\nThis removes the option to pass in a custom virtualenv binary and gets\nmozharness to always use the copy in 'external_tools'. Because this is now\ndeterministic, we don't need to do things like check what version of pip is\nbeing used.\n\nMozReview-Commit-ID: GWxkmaZVpsZ", "files": ["testing/mozharness/mozharness/base/python.py"], "git_node": null, "git_parents": [null], "node": "c5ed62b37c2e346ff2660eab13efa5c8657c6487", "parents": ["073a2a43a15cd103d2671b7e77d6700ddf3690f6"], "tags": []}], "date": 1509036303, "git_changesets": [null, null, null], "user": "ryanvm@gmail.com"}, "8060": {"changesets": [{"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1404108 - Change the accent color for the Web Browser Renaissance theme. r=nhnt11, a=ritu\n\nMozReview-Commit-ID: 4oBKIrHXmMe", "files": ["browser/app/profile/firefox.js", "browser/components/nsBrowserGlue.js"], "git_node": null, "git_parents": [null], "node": "d87eb6ee94579001e9729d91208c7c6df9dc4e06", "parents": ["c5ed62b37c2e346ff2660eab13efa5c8657c6487"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411518 - Update follow-on search add-on to 0.9.6. r=past, a=ritu", "files": ["browser/extensions/followonsearch/content/followonsearch-fs.js", "browser/extensions/followonsearch/install.rdf"], "git_node": null, "git_parents": [null], "node": "18fc5fc8bf7c695329cbb92f2e2d04e630398d79", "parents": ["d87eb6ee94579001e9729d91208c7c6df9dc4e06"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1411657 - Use resources when getting default Pocket value. r=liuche, a=ritu\n\nThis is an existing bug that previously had no impact because the values were\nduplicated. Now that I'm going to change the value, the bug has to be fixed.\n\nI opted not to fix the bug for the other top sites features in order to\nminimize the scope of this change.\n\nMozReview-Commit-ID: L9bnEMfvpDG", "files": ["mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/ActivityStreamPanel.java"], "git_node": null, "git_parents": [null], "node": "f99471c1c261403be073cb2fe516f58affedb9ae", "parents": ["18fc5fc8bf7c695329cbb92f2e2d04e630398d79"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1411657 - Disable Pocket by default. r=liuche, a=ritu\n\nFrom product (bug 1411657 comment 0):\n\nActivity Stream may be pushed to a later release on desktop.  With that, we want\nthe Pocket stories feature to be put behind a feature flag on Firefox Android,so\nwe can launch the feature across all platforms simultaneously.\n\nMozReview-Commit-ID: 3KmZir3tGPc", "files": ["mobile/android/app/src/main/res/values/bool.xml"], "git_node": null, "git_parents": [null], "node": "ae4b19c61dc754940b570be2dcef2464429d032b", "parents": ["f99471c1c261403be073cb2fe516f58affedb9ae"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1395409 - Add testActivityStreamPocketReferrer. r=liuche, a=test-only\n\nMozReview-Commit-ID: FlcMG5IewRH", "files": ["mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/topstories/PocketStoriesLoader.java", "mobile/android/tests/browser/robocop/robocop.ini", "mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/testActivityStreamPocketReferrer.java", "mobile/android/tests/browser/robocop/testActivityStreamPocketReferrer.js"], "git_node": null, "git_parents": [null], "node": "c67963054db3716652866c4a5d192fe7cc713a7c", "parents": ["ae4b19c61dc754940b570be2dcef2464429d032b"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1411749 - Disable testActivityStreamPocketReferrer when Pocket is disabled by default. r=mcomella, a=ritu\n\nMozReview-Commit-ID: BoFaNc4eBUA", "files": ["mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/testActivityStreamPocketReferrer.java"], "git_node": null, "git_parents": [null], "node": "0153d5be6150088221ef083ba9bfa2844ee4124a", "parents": ["c67963054db3716652866c4a5d192fe7cc713a7c"], "tags": []}, {"author": "David Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "Bug 1411458 - Confirm we actually have a PKCS#7 signedData content info. r=jcj, a=ritu\n\nMozReview-Commit-ID: GKfL1C0EPWt", "files": ["security/manager/ssl/nsDataSignatureVerifier.cpp", "security/nss.symbols"], "git_node": null, "git_parents": [null], "node": "c060b92db7eefa93d70ac9df262d9b11948cde5c", "parents": ["0153d5be6150088221ef083ba9bfa2844ee4124a"], "tags": []}], "date": 1509042020, "git_changesets": [null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8061": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1297515 - Make sure Windows buildbot jobs use pypiwin32 instead of pywin32. r=ahal, a=test-only", "files": ["testing/mozharness/configs/unittests/win_unittest.py"], "git_node": null, "git_parents": [null], "node": "4868b6953a048ad6a2ccb913280244e31e1baa64", "parents": ["c060b92db7eefa93d70ac9df262d9b11948cde5c"], "tags": []}], "date": 1509051929, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "8062": {"changesets": [{"author": "Rail Aliiev \u003crail@mozilla.com\u003e", "branch": "default", "desc": "Bug 1410960 - beetmover fails with lzma.h: No such file or directory r=bhearsum a=release\n\nMozReview-Commit-ID: 1hSOgdOJ5b8", "f