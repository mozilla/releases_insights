": "default", "desc": "Bug 1389420 - [mozilla-release leftovers] Rename android-api-15 to android-api-16 once 56 reaches release r=sfraser\n\nMozReview-Commit-ID: J1sgnaH9j0p", "files": ["testing/mozharness/configs/merge_day/beta_to_release.py"], "git_node": null, "git_parents": [null], "node": "e10c49f7258a9cf281af774e9cac7d876a68c5f1", "parents": ["ff7d6888f2490cea0c3ca131c2bb37743b0006be"], "tags": []}, {"author": "Boris Chiou \u003cboris.chiou@gmail.com\u003e", "branch": "default", "desc": "Bug 1390026 - Update test_transitions_per_property.html for shape-outside. r=birtles\n\nMozReview-Commit-ID: KJKTJkM84UN", "files": ["layout/style/test/test_transitions_per_property.html"], "git_node": null, "git_parents": [null], "node": "f1327c641da9f5950c7c29f545ea9de8de8c01aa", "parents": ["e10c49f7258a9cf281af774e9cac7d876a68c5f1"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401028 - Remove the content-contextmenu observer notification; r=kmag\n\nThis was used by the add-on SDK.\n", "files": ["browser/base/content/nsContextMenu.js", "browser/modules/ContextMenu.jsm", "toolkit/components/viewsource/content/viewSource-content.js"], "git_node": null, "git_parents": [null], "node": "a67df8254927efaa4c3fad666c47fc2be0d9db89", "parents": ["cdecec06131e8a405a3eba0f5abd711032ba2c6e"], "tags": []}, {"author": "vincentliu \u003cvliu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399006 - Invoke PurgeCachedImages to release object in main thread while ServoTraversal. r=bholley", "files": ["layout/style/nsStyleStruct.h"], "git_node": null, "git_parents": [null], "node": "5fa2260faa05030380fa1d8f521db0ad092d0f14", "parents": ["a67df8254927efaa4c3fad666c47fc2be0d9db89"], "tags": []}, {"author": "Michal Novotny \u003cmichal.novotny@gmail.com\u003e", "branch": "default", "desc": "Bug 1392841 - Enable RCWN on Nightly, r=valentin", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "c1df5b677b8ad009ed98c3afd2cda7034bfbe4c4", "parents": ["5fa2260faa05030380fa1d8f521db0ad092d0f14"], "tags": []}, {"author": "Ralph Giles \u003cgiles@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400927 - Fix u2f-hid-rs cross-compilation on macOS r=jcj\n\nOne cannot use #[cfg(target_os)] checks in build.rs.\nBuild scripts can be used to generate code so the target\nis set to the host platform when they are compiled.\n\nHaving this setting exported an unconditional link\ndepencency whenever the host was macOS, which broke\ncross-compiling, in particular for fennec builds\ntargetting Android.\n\nInstead, declare the IOKit dependency on the `extern`\nblock which imports the symbol inside macOS-specific\ncode. That way final link still works, but the extra\ndependency is only enabled when appropriate for the\nfinal target, like the other platform-dependent code.", "files": ["dom/webauthn/u2f-hid-rs/Cargo.toml", "dom/webauthn/u2f-hid-rs/build.rs", "dom/webauthn/u2f-hid-rs/src/macos/iokit.rs"], "git_node": null, "git_parents": [null], "node": "3aa403d810d87aecc1cc73729b154d5ee9a7db23", "parents": ["c1df5b677b8ad009ed98c3afd2cda7034bfbe4c4"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 58844e6f37b2 (bug 1380649)", "files": ["gfx/layers/SourceSurfaceVolatileData.h"], "git_node": null, "git_parents": [null], "node": "cc0cd5f70746c4efeb84bb76ce32d19043145341", "parents": ["3aa403d810d87aecc1cc73729b154d5ee9a7db23"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset d4f5756b1d12 (bug 1380649) for frequently asserting at image/SurfaceCache.cpp:138. r=backout", "files": ["image/SurfaceCache.cpp"], "git_node": null, "git_parents": [null], "node": "b577f883dc898d203b74f7b02345a0a7dc3d32c0", "parents": ["cc0cd5f70746c4efeb84bb76ce32d19043145341"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "merge mozilla-central to mozilla-inbound. r=merge a=merge", "files": ["modules/libpref/init/all.js", "toolkit/components/viewsource/content/viewSource-content.js"], "git_node": null, "git_parents": [null, null], "node": "db7b879601c6f7a4666c3f3be2dd2dd863fd92a2", "parents": ["b577f883dc898d203b74f7b02345a0a7dc3d32c0", "e4261f5b96ebfd63e7cb8af3035ff9fea90c74a5"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399471 part 2 - Add a mechanism to check callWithABI invariants in debug builds. r=nbp", "files": ["js/src/builtin/RegExp.cpp", "js/src/irregexp/RegExpMacroAssembler.cpp", "js/src/irregexp/RegExpStack.cpp", "js/src/jit-test/tests/wasm/integer.js", "js/src/jit/Bailouts.cpp", "js/src/jit/BaselineDebugModeOSR.cpp", "js/src/jit/CodeGenerator.cpp", "js/src/jit/IonCacheIRCompiler.cpp", "js/src/jit/MacroAssembler-inl.h", "js/src/jit/MacroAssembler.cpp", "js/src/jit/MacroAssembler.h", "js/src/jit/SharedIC.cpp", "js/src/jit/VMFunctions.cpp", "js/src/jit/arm/CodeGenerator-arm.cpp", "js/src/jit/arm/MacroAssembler-arm.cpp", "js/src/jit/arm/SharedIC-arm.cpp", "js/src/jit/arm/Trampoline-arm.cpp", "js/src/jit/arm64/MacroAssembler-arm64.cpp", "js/src/jit/arm64/Trampoline-arm64.cpp", "js/src/jit/mips32/MacroAssembler-mips32.cpp", "js/src/jit/mips32/Trampoline-mips32.cpp", "js/src/jit/mips64/MacroAssembler-mips64.cpp", "js/src/jit/mips64/Trampoline-mips64.cpp", "js/src/jit/x64/MacroAssembler-x64.cpp", "js/src/jit/x64/Trampoline-x64.cpp", "js/src/jit/x86/CodeGenerator-x86.cpp", "js/src/jit/x86/MacroAssembler-x86.cpp", "js/src/jit/x86/Trampoline-x86.cpp", "js/src/jsarray.cpp", "js/src/jsboolinlines.h", "js/src/jscntxt.cpp", "js/src/jscntxt.h", "js/src/jslibmath.h", "js/src/jsmath.cpp", "js/src/vm/ArgumentsObject.cpp", "js/src/vm/NativeObject.cpp"], "git_node": null, "git_parents": [null], "node": "b481e36a995802501ade1ac839c3ecd3747e04b9", "parents": ["db7b879601c6f7a4666c3f3be2dd2dd863fd92a2"], "tags": []}, {"author": "Gabor Krizsanits \u003cgkrizsanits@mozilla.com\u003e", "branch": "default", "desc": "Bug 1336389 - Talos test for content process startup time. r=mconley", "files": ["testing/moz.build", "testing/talos/talos.json", "testing/talos/talos/test.py", "testing/talos/talos/tests/cpstartup/bootstrap.js", "testing/talos/talos/tests/cpstartup/chrome.manifest", "testing/talos/talos/tests/cpstartup/content/cpstartup.html", "testing/talos/talos/tests/cpstartup/content/target.html", "testing/talos/talos/tests/cpstartup/cpstartup-signed.xpi", "testing/talos/talos/tests/cpstartup/cpstartup.manifest", "testing/talos/talos/tests/cpstartup/install.rdf", "toolkit/content/browser-child.js"], "git_node": null, "git_parents": [null], "node": "5cd2ba3bc6c4dbdba69c295791d20d1c804d8f11", "parents": ["b481e36a995802501ade1ac839c3ecd3747e04b9"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1396613 - Update the object moved hook to allow it to be called when tenuring nursery objects r=sfink r=mccr8", "files": ["dom/base/nsGlobalWindow.cpp", "dom/bindings/Codegen.py", "dom/bindings/SimpleGlobalObject.cpp", "dom/plugins/base/nsJSNPRuntime.cpp", "js/ipc/WrapperOwner.cpp", "js/public/Class.h", "js/public/Proxy.h", "js/src/builtin/MapObject.cpp", "js/src/builtin/MapObject.h", "js/src/gc/Marking.cpp", "js/src/jsapi-tests/testWeakMap.cpp", "js/src/proxy/BaseProxyHandler.cpp", "js/src/proxy/Proxy.cpp", "js/src/vm/ArrayBufferObject.cpp", "js/src/vm/ArrayBufferObject.h", "js/src/vm/TypedArrayObject.cpp", "js/src/vm/TypedArrayObject.h", "js/src/vm/UnboxedObject.cpp", "js/src/vm/UnboxedObject.h", "js/xpconnect/src/Sandbox.cpp", "js/xpconnect/src/SandboxPrivate.h", "js/xpconnect/src/XPCWrappedNativeJSOps.cpp"], "git_node": null, "git_parents": [null], "node": "353300cbbf52fc65a5e4f463ca42eade3790b549", "parents": ["5cd2ba3bc6c4dbdba69c295791d20d1c804d8f11"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1396613 - Replace special cases with use of objectMoved hook when tenuring r=sfink", "files": ["js/src/builtin/TypedObject.cpp", "js/src/builtin/TypedObject.h", "js/src/gc/Marking.cpp", "js/src/gc/Nursery.h", "js/src/vm/ArgumentsObject.cpp", "js/src/vm/ArgumentsObject.h", "js/src/vm/TypedArrayObject.cpp", "js/src/vm/TypedArrayObject.h", "js/src/vm/UnboxedObject.cpp", "js/src/vm/UnboxedObject.h"], "git_node": null, "git_parents": [null], "node": "70a52e791eb7160b0c4130cc8f0bb6f58d34d101", "parents": ["353300cbbf52fc65a5e4f463ca42eade3790b549"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1396613 - Make proxy objects override handler's objectMoved method rather than using class hook r=sfink r=mccr8 r=peterv", "files": ["dom/base/nsGlobalWindow.cpp", "dom/bindings/Codegen.py", "dom/plugins/base/nsJSNPRuntime.cpp", "js/public/Proxy.h", "js/src/gc/Marking.cpp", "js/src/jsapi-tests/testBug604087.cpp", "js/src/proxy/Proxy.cpp", "js/src/proxy/Proxy.h"], "git_node": null, "git_parents": [null], "node": "55fc35f2a57d0394d88df593ad694f81e97487be", "parents": ["70a52e791eb7160b0c4130cc8f0bb6f58d34d101"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1396613 - Update rust glue with new objectMoved hook signature r=fitzgen", "files": ["js/rust/src/glue.rs", "js/rust/src/jsglue.cpp"], "git_node": null, "git_parents": [null], "node": "69536041f010d547faafcc0e9a96468ed68d42c5", "parents": ["55fc35f2a57d0394d88df593ad694f81e97487be"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399944 - Check for valid GC cell pointers in various places r=sfink", "files": ["js/public/GCPolicyAPI.h", "js/public/GCVariant.h", "js/public/HeapAPI.h", "js/public/Id.h", "js/public/Realm.h", "js/public/RootingAPI.h", "js/public/Value.h", "js/src/gc/Heap.h", "js/src/gc/Policy.h", "js/src/jit/RematerializedFrame.h", "js/src/jsapi-tests/testGCGrayMarking.cpp", "js/src/jsgc.cpp", "js/src/vm/Scope.h"], "git_node": null, "git_parents": [null], "node": "74faaba5ecd2fae75df27f3186f9f6eb8d1fa4bc", "parents": ["69536041f010d547faafcc0e9a96468ed68d42c5"], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1380649 - Part 1. Ensure SurfaceCache::CollectSizeOfSurfaces removes purged volatile buffer-backed surfaces. r=tnikkel\n\nWhen we lookup a surface in the cache, we are careful to remove any\nsurfaces which were backed by volatile memory and got purged before we\ncould reacquire the buffer. We were not so careful in doing that when\ngenerating memory reports. ISurfaceProvider::AddSizeOfExcludingThis will\ncause us to acquire the buffer, and if it was purged, forget about its\npurged status. Later when we performed a lookup, we would forget the\npurged status, and assume we have the right data. This would appear as\ncompletely transparent for BGRA surfaces, and completely black for BGRX\nsurfaces.\n\nWith this patch, we now properly remove purged surfaces instead of\nincluding them in the report. This ensures that the cache state is\nconsistent. This also resolves memory reports of surfaces which reported\nusing no data -- they were purged when the report was generated.\n\nAdditionally, there was a bug in SurfaceCache::PruneImage where we did\nnot discard surfaces outside the module lock. Both PruneImage and\nCollectSizeOfSurfaces now free any discarded surfaces outside the lock.", "files": ["image/SurfaceCache.cpp"], "git_node": null, "git_parents": [null], "node": "a23a810d95855a42f009ccd72604935db0680bd3", "parents": ["74faaba5ecd2fae75df27f3186f9f6eb8d1fa4bc"], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1380649 - Part 2. Ensure SourceSurfaceVolatileData does not forget its purged state. r=jrmuizel\n\nCurrently if SourceSurfaceVolatileData::Map fails due to being purged,\nwe expect that the surface will be discarded by the caller. This has not\nconsistently been the case, and as such, we should ensure we do not\nforget if a buffer was previously purged when we reacquire it. Since we\ndo not at this time support repopulating an already allocated buffer\nwith new data, we cannot reset this state once it has been set.", "files": ["gfx/layers/SourceSurfaceVolatileData.h"], "git_node": null, "git_parents": [null], "node": "3ff9cd026e70eacb71f9a182f633834eb837b24d", "parents": ["a23a810d95855a42f009ccd72604935db0680bd3"], "tags": []}, {"author": "Nicolas Silva \u003cnsilva@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397407 - Apply deferred image key deletions to the next transaction. r=Gankro", "files": ["gfx/layers/wr/WebRenderLayerManager.cpp", "gfx/layers/wr/WebRenderLayerManager.h"], "git_node": null, "git_parents": [null], "node": "9f8c6be7d2f4216d3f87e091f8cfe238bab8ca1a", "parents": ["3ff9cd026e70eacb71f9a182f633834eb837b24d"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399320 - Update rich icons to be httpdisabled:// to prevent network connections. r=jmaher\n\nMozReview-Commit-ID: K3Cz0FxmFC6", "files": ["testing/talos/tp5n-pageset.manifest"], "git_node": null, "git_parents": [null], "node": "6c1c2d8301199f5f755382e4a4526beee5a1d6d7", "parents": ["f1327c641da9f5950c7c29f545ea9de8de8c01aa"], "tags": []}, {"author": "Nick Thomas \u003cnthomas@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400141 - Use redo params from nightly with a jitter r=bhearsum\n\nMozReview-Commit-ID: BjU6A9pOpKE", "files": ["taskcluster/docker/funsize-balrog-submitter/scripts/funsize-balrog-submitter.py"], "git_node": null, "git_parents": [null], "node": "762071fc48dda899efa95501e531cc5a39e09aff", "parents": ["9f8c6be7d2f4216d3f87e091f8cfe238bab8ca1a"], "tags": []}, {"author": "Vedant Chakravadhanula \u003cvedantc98@gmail.com\u003e", "branch": "default", "desc": "Bug 1359289 - Add a \"Learn More\" link to Safe Browsing checkbox in about:preferences. r=jhofmann", "files": ["browser/components/preferences/in-content/privacy.js", "browser/components/preferences/in-content/privacy.xul", "browser/locales/en-US/chrome/browser/preferences/privacy.dtd"], "git_node": null, "git_parents": [null], "node": "9016e255c36ced248b09b1745a293dee6981db81", "parents": ["762071fc48dda899efa95501e531cc5a39e09aff"], "tags": []}, {"author": "Ekanan Ketunuti \u003cananuti@gmail.com\u003e", "branch": "default", "desc": "Bug 1401050 - Add vanishingly to the en-US dictionary. r=ehsan", "files": ["extensions/spellcheck/locales/en-US/hunspell/en-US.dic"], "git_node": null, "git_parents": [null], "node": "9cabdd061402b2dda590d2a102a4b2d32b67f346", "parents": ["9016e255c36ced248b09b1745a293dee6981db81"], "tags": []}, {"author": "Tim Taubert \u003cttaubert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400559 - Move runloop code into its own crate r=jcj\n\nThe runloop seems like a good candidate for moving into its own crate.\n\nI wasn't sure whether we want it under the Mozilla org on GitHub, so I pushed\nit to ttaubert/rust-runloop for a start. Moving the repository to mozilla/*\nis easy, and we'd just need to bump the crate version with the updated\nrepository, if you think we should.\n\nBug #: 1400559\n\nDifferential Revision: https://phabricator.services.mozilla.com/D62", "files": ["dom/webauthn/u2f-hid-rs/Cargo.toml", "dom/webauthn/u2f-hid-rs/src/lib.rs", "dom/webauthn/u2f-hid-rs/src/linux/mod.rs", "dom/webauthn/u2f-hid-rs/src/linux/monitor.rs", "dom/webauthn/u2f-hid-rs/src/macos/mod.rs", "dom/webauthn/u2f-hid-rs/src/macos/monitor.rs", "dom/webauthn/u2f-hid-rs/src/manager.rs", "dom/webauthn/u2f-hid-rs/src/runloop.rs", "dom/webauthn/u2f-hid-rs/src/windows/mod.rs", "dom/webauthn/u2f-hid-rs/src/windows/monitor.rs", "third_party/rust/runloop/.cargo-checksum.json", "third_party/rust/runloop/.cargo-ok", "third_party/rust/runloop/.travis.yml", "third_party/rust/runloop/Cargo.toml", "third_party/rust/runloop/LICENSE", "third_party/rust/runloop/README.md", "third_party/rust/runloop/rustfmt.toml", "third_party/rust/runloop/src/lib.rs", "toolkit/library/gtest/rust/Cargo.lock", "toolkit/library/rust/Cargo.lock"], "git_node": null, "git_parents": [null], "node": "9e0e34d815597d581777f822f591301e174c06ff", "parents": ["9cabdd061402b2dda590d2a102a4b2d32b67f346"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 5cd2ba3bc6c4 (bug 1336389) for failing new talos test cpstartup. r=backout", "files": ["testing/moz.build", "testing/talos/talos.json", "testing/talos/talos/test.py", "testing/talos/talos/tests/cpstartup/bootstrap.js", "testing/talos/talos/tests/cpstartup/chrome.manifest", "testing/talos/talos/tests/cpstartup/content/cpstartup.html", "testing/talos/talos/tests/cpstartup/content/target.html", "testing/talos/talos/tests/cpstartup/cpstartup-signed.xpi", "testing/talos/talos/tests/cpstartup/cpstartup.manifest", "testing/talos/talos/tests/cpstartup/install.rdf", "toolkit/content/browser-child.js"], "git_node": null, "git_parents": [null], "node": "b2e90060a137b10b38ad7a394dab802841094861", "parents": ["9e0e34d815597d581777f822f591301e174c06ff"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1400898 part 1.  Remove the one script use of nsIDOMChromeWindow.  r=farre\n\nMozReview-Commit-ID: I31eceiJP55", "files": ["browser/components/downloads/content/downloads.js", "dom/interfaces/base/nsIDOMChromeWindow.idl"], "git_node": null, "git_parents": [null], "node": "a4ef5b6299e59859a0dec1996db87a717518db43", "parents": ["b2e90060a137b10b38ad7a394dab802841094861"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1400898 part 2.  Get rid of the interface constants on nsIDOMChromeWindow.  r=farre\n\nMozReview-Commit-ID: 4FuJSgha5y3", "files": ["dom/base/nsGlobalWindow.cpp", "dom/interfaces/base/nsIDOMChromeWindow.idl", "dom/webidl/Window.webidl"], "git_node": null, "git_parents": [null], "node": "aa4d0a9412c0bc4fe131115aa002ad2b7f2c7927", "parents": ["a4ef5b6299e59859a0dec1996db87a717518db43"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1400898 part 3.  Make nsIDOMChromeWindow.browserDOMWindow readonly.  r=farre\n\nC++ code only reads this attribute.  Code that sets it comes via WebIDL bindings.\n\nMozReview-Commit-ID: 2itFAxUVTBo", "files": ["dom/base/nsGlobalWindow.cpp", "dom/interfaces/base/nsIDOMChromeWindow.idl"], "git_node": null, "git_parents": [null], "node": "081034bdc4d4f0ac15877565a805b737c8d91b5d", "parents": ["aa4d0a9412c0bc4fe131115aa002ad2b7f2c7927"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1400898 part 4.  Get rid of nsIDOMChromeWindow methods that are unused from C++, and mark the rest [noscript].  r=farre\n\nMozReview-Commit-ID: GtYmfg6XiaQ", "files": ["dom/base/nsGlobalWindow.cpp", "dom/interfaces/base/nsIDOMChromeWindow.idl"], "git_node": null, "git_parents": [null], "node": "5af3e3b70198dac5501d159d8d808ed738de9c06", "parents": ["081034bdc4d4f0ac15877565a805b737c8d91b5d"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1401204 - Make nsIMultiplexInputStream not inherit from nsIInputStream.  r=bkelly\n\nThis is a preexisting issue that makes nsMultiplexInputStream multiple-inherit\nfrom nsIInputStream: once via nsIMultipartInputStream and once via\nnsIAsyncInputStream.  This causes problems once we end up with more multiplex\nstreams that are async streams, because then some assingments to\nnsCOMPtr\u003cnsIInputStream\u003e start asserting.  This patch just removes the footgun\nby getting rid of the multiple inheritance.", "files": ["dom/file/MultipartBlobImpl.cpp", "dom/html/HTMLFormSubmission.cpp", "dom/html/HTMLFormSubmission.h", "dom/network/TCPSocket.cpp", "dom/presentation/PresentationTCPSessionTransport.cpp", "dom/workers/FileReaderSync.cpp", "netwerk/protocol/http/nsHttpTransaction.cpp", "xpcom/io/nsIMultiplexInputStream.idl", "xpcom/io/nsMultiplexInputStream.cpp", "xpcom/tests/gtest/TestCloneInputStream.cpp", "xpcom/tests/gtest/TestMultiplexInputStream.cpp"], "git_node": null, "git_parents": [null], "node": "3c9e25405f596871f714a8c3b10e6e9de9188554", "parents": ["5af3e3b70198dac5501d159d8d808ed738de9c06"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 3c9e25405f59 (bug 1401204) an request from baku for landing with wrong bug number. r=backout", "files": ["dom/file/MultipartBlobImpl.cpp", "dom/html/HTMLFormSubmission.cpp", "dom/html/HTMLFormSubmission.h", "dom/network/TCPSocket.cpp", "dom/presentation/PresentationTCPSessionTransport.cpp", "dom/workers/FileReaderSync.cpp", "netwerk/protocol/http/nsHttpTransaction.cpp", "xpcom/io/nsIMultiplexInputStream.idl", "xpcom/io/nsMultiplexInputStream.cpp", "xpcom/tests/gtest/TestCloneInputStream.cpp", "xpcom/tests/gtest/TestMultiplexInputStream.cpp"], "git_node": null, "git_parents": [null], "node": "bb274a08887161806afe21ec1916d48cda1199d7", "parents": ["3c9e25405f596871f714a8c3b10e6e9de9188554"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1401171 - Make nsIMultiplexInputStream not inherit from nsIInputStream.  r=bkelly\n\nThis is a preexisting issue that makes nsMultiplexInputStream multiple-inherit\nfrom nsIInputStream: once via nsIMultipartInputStream and once via\nnsIAsyncInputStream.  This causes problems once we end up with more multiplex\nstreams that are async streams, because then some assingments to\nnsCOMPtr\u003cnsIInputStream\u003e start asserting.  This patch just removes the footgun\nby getting rid of the multiple inheritance.", "files": ["dom/file/MultipartBlobImpl.cpp", "dom/html/HTMLFormSubmission.cpp", "dom/html/HTMLFormSubmission.h", "dom/network/TCPSocket.cpp", "dom/presentation/PresentationTCPSessionTransport.cpp", "dom/workers/FileReaderSync.cpp", "netwerk/protocol/http/nsHttpTransaction.cpp", "xpcom/io/nsIMultiplexInputStream.idl", "xpcom/io/nsMultiplexInputStream.cpp", "xpcom/tests/gtest/TestCloneInputStream.cpp", "xpcom/tests/gtest/TestMultiplexInputStream.cpp"], "git_node": null, "git_parents": [null], "node": "425b1969478e417db21ac1e35cdf481c1cd0be32", "parents": ["bb274a08887161806afe21ec1916d48cda1199d7"], "tags": []}, {"author": "Tim Taubert \u003cttaubert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400559 - [u2f-hid-rs] rustfmt followup r=me", "files": ["dom/webauthn/u2f-hid-rs/src/linux/monitor.rs", "dom/webauthn/u2f-hid-rs/src/windows/monitor.rs"], "git_node": null, "git_parents": [null], "node": "c8277ab2befdd4c5027741f12bc94a0870925542", "parents": ["425b1969478e417db21ac1e35cdf481c1cd0be32"], "tags": []}, {"author": "Tim Taubert \u003cttaubert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401019 - Cancel the current U2F API request before starting a new one r=jcj\n\nI wasn't sure what the right behavior for the U2F API is when `.sign()`\nor `.register()` is called but there's an ongoing request that wasn't fulfilled\nyet.\n\nI think it makes sense to deny the request (as we currently do) when a request\nof the same type is currently active. When however sign() -\u003e register() or\nvice-versa is called then we should cancel the previous request and start\nthe new one. From what I understand from reading the spec we definitely should\ncall the callback before starting the new request.\n\nBug #: 1401019\n\nDifferential Revision: https://phabricator.services.mozilla.com/D70", "files": ["dom/u2f/U2F.cpp", "dom/u2f/U2F.h"], "git_node": null, "git_parents": [null], "node": "8d3d707fe0485a8900c4794a0c55018ad722c6de", "parents": ["c8277ab2befdd4c5027741f12bc94a0870925542"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400466 - Implement minimum necessary to allow saving and loading structured clone data, r=jonco", "files": ["js/src/builtin/TestingFunctions.cpp", "js/src/shell/OSObject.cpp"], "git_node": null, "git_parents": [null], "node": "383a2f567cebe59b0212e414b9a27d46123040bf", "parents": ["8d3d707fe0485a8900c4794a0c55018ad722c6de"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400466 - Cache the information loaded from src_comp.xdb into a structured clone buffer, r=jonco\n\nNote that this requires some enhancements to the JS engine to support reading and writing structured clone data from/to files.", "files": ["js/src/devtools/rootAnalysis/analyzeHeapWrites.js", "js/src/devtools/rootAnalysis/callgraph.js"], "git_node": null, "git_parents": [null], "node": "18af2ea42a1e01e98273101fd7ed8dc0291e7a2d", "parents": ["383a2f567cebe59b0212e414b9a27d46123040bf"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400468 - Trim output, r=jonco", "files": ["js/src/devtools/rootAnalysis/analyzeHeapWrites.js"], "git_node": null, "git_parents": [null], "node": "6d5acbf01f1deb321693aac8330ce6e75f7f6cac", "parents": ["18af2ea42a1e01e98273101fd7ed8dc0291e7a2d"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400468 - Port hazard analysis test scripts to python3, r=jonco", "files": ["js/src/devtools/rootAnalysis/analyze.py", "js/src/devtools/rootAnalysis/run-test.py", "js/src/devtools/rootAnalysis/t/suppression/test.py", "js/src/devtools/rootAnalysis/t/testlib.py"], "git_node": null, "git_parents": [null], "node": "e793ea43500790c39a4cf69bd9b5014c32e3f524", "parents": ["6d5acbf01f1deb321693aac8330ce6e75f7f6cac"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400468 - Control verbosity, r=jonco", "files": ["js/src/devtools/rootAnalysis/analyze.py", "js/src/devtools/rootAnalysis/t/testlib.py"], "git_node": null, "git_parents": [null], "node": "a4e41e4876ef49a5ff03322f5254753438f0d758", "parents": ["e793ea43500790c39a4cf69bd9b5014c32e3f524"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400442 - CFG dumping utility, handy for debugging, r=me", "files": ["js/src/devtools/rootAnalysis/analyzeHeapWrites.js", "js/src/devtools/rootAnalysis/dumpCFG.js"], "git_node": null, "git_parents": [null], "node": "9a3d18f5faeee9f0bd78397898fb606addeb95aa", "parents": ["a4e41e4876ef49a5ff03322f5254753438f0d758"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400442 - Propagate safety through RefPtr, r=bhackett", "files": ["js/src/devtools/rootAnalysis/analyzeHeapWrites.js"], "git_node": null, "git_parents": [null], "node": "6696c7a9ed71d2292030c3610081d6ca29fd6aab", "parents": ["9a3d18f5faeee9f0bd78397898fb606addeb95aa"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400442 - Annotate atof as not doing any racy writes, r=me", "files": ["js/src/devtools/rootAnalysis/analyzeHeapWrites.js"], "git_node": null, "git_parents": [null], "node": "4901b60d01263465f5bc4b8f14703362f4659b8a", "parents": ["6696c7a9ed71d2292030c3610081d6ca29fd6aab"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400442 - Targeted annotation for static local array of member pointers in LangGroupFontPrefs::Initialize, r=bhackett\n\nThe code is\n\n    void\n    LangGroupFontPrefs::Initialize(nsIAtom* aLangGroupAtom)\n    {\n        nsFont* fontTypes[] = {\n            &mDefaultVariableFont,\n            &mDefaultFixedFont,\n            &mDefaultSerifFont,\n            &mDefaultSansSerifFont,\n            &mDefaultMonospaceFont,\n            &mDefaultCursiveFont,\n            &mDefaultFantasyFont\n        };\n\n        nsFont* font = fontTypes[3];\n        font-\u003esize = 42;\n    }\n\n'this' is known to be a safe pointer (exclusively owned by the current thread), so a pointer to one of its members is also safe. But the analysis can't track safety across all that, so I have a special-case annotation here that says that fontTypes[3] returns a safe pointer if and only if 'this' is safe.\n\nNote that all of those fields (eg mDefaultVariableFont) are nsFont structs, not pointers, so although you'd expect this to be one dereference away from a safe pointer's memory, it is not; assigning to font-\u003esize ends up being a write to some offset within the 'this' pointer, which is known to be safe here.", "files": ["js/src/devtools/rootAnalysis/analyzeHeapWrites.js"], "git_node": null, "git_parents": [null], "node": "c5239fd503f2c277f2dc185ce8c55789fbefcad2", "parents": ["4901b60d01263465f5bc4b8f14703362f4659b8a"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400442 - Annotate MOZ_CrashPrintf, r=jonco", "files": ["js/src/devtools/rootAnalysis/analyzeHeapWrites.js"], "git_node": null, "git_parents": [null], "node": "84018f3951f95a70b86760382a00aad570d8bec0", "parents": ["c5239fd503f2c277f2dc185ce8c55789fbefcad2"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400442 - Broaden the annotation for string appending functions to handle more types, r=jonco", "files": ["js/src/devtools/rootAnalysis/analyzeHeapWrites.js"], "git_node": null, "git_parents": [null], "node": "46c262a38922c88052e4fc75f93927fa43e7276d", "parents": ["84018f3951f95a70b86760382a00aad570d8bec0"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400442 - Fix handling of parameterNames, r=jonco\n\nThis is for nicer output only, and does not affect the computation. A WorkListEntry contains a stack of CallSites, and the top of the stack represents the entry itself and so should share parameterNames. This changes fixes cases where some names were being registered in a different table than ended up being used by printouts.", "files": ["js/src/devtools/rootAnalysis/analyzeHeapWrites.js"], "git_node": null, "git_parents": [null], "node": "410efc5458e07cc3a04e96b0a6c533791379a4a7", "parents": ["46c262a38922c88052e4fc75f93927fa43e7276d"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400442 - Refactor the --function debugging command line option (and alias it to -f) to analyzeHeapWrites.js, r=me", "files": ["js/src/devtools/rootAnalysis/analyzeHeapWrites.js"], "git_node": null, "git_parents": [null], "node": "c37bd96f868a281c0eb288a85d7f6a33dc32f0cd", "parents": ["410efc5458e07cc3a04e96b0a6c533791379a4a7"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400442 - analyzeHeapWrites: implement a cache for checking whether local variables are safe pointers, r=jonco", "files": ["js/src/devtools/rootAnalysis/analyzeHeapWrites.js"], "git_node": null, "git_parents": [null], "node": "3835877e5870ac4f4034fc8d97f8284d59519091", "parents": ["c37bd96f868a281c0eb288a85d7f6a33dc32f0cd"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400442 - analyzeHeapWrites: getter_Copies preserves safety (similar to getter_AddRefs), r=bhackett", "files": ["js/src/devtools/rootAnalysis/analyzeHeapWrites.js"], "git_node": null, "git_parents": [null], "node": "4ff3e372de3d54aadf62d9ad97eae7cd9a6dafd9", "parents": ["3835877e5870ac4f4034fc8d97f8284d59519091"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400442 - Backward-compatible js::Class[Ops].trace annotation, r=me", "files": ["js/src/devtools/rootAnalysis/annotations.js"], "git_node": null, "git_parents": [null], "node": "8fe39aef352a049563f1444d5e1798b383d7d716", "parents": ["4ff3e372de3d54aadf62d9ad97eae7cd9a6dafd9"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400442 - Annotate border colors array as being thread-owned by container, r=bhackett\n\nnsStyleStruct has the field:\n\n  nsBorderColors** mBorderColors;\n\nIt starts out nullptr, and when it is needed, it allocates an array of 4 nsBorderColors pointers. But the nsStyleStruct exclusively owns the array; nothing else can get at it. This change teaches the analysis that if 'this' is a safe nsStyleStruct*, then it should treat mBorderColors as if it were an inline length-4 array.", "files": ["js/src/devtools/rootAnalysis/analyzeHeapWrites.js"], "git_node": null, "git_parents": [null], "node": "eb2b0c8fa756eec150b4c3c9c6254083ac4a37dc", "parents": ["8fe39aef352a049563f1444d5e1798b383d7d716"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400442 - Annotate nsTArray::InsertElementAt as returning a value that propagates safety of the array, r=jonco", "files": ["js/src/devtools/rootAnalysis/analyzeHeapWrites.js"], "git_node": null, "git_parents": [null], "node": "8ec91b85f043b8c16a80fed32da48d8eaa6e70e7", "parents": ["eb2b0c8fa756eec150b4c3c9c6254083ac4a37dc"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400442 - Annotate Servo_ComputedValues_EqualCustomProperties as safe, r=manishearth", "files": ["js/src/devtools/rootAnalysis/analyzeHeapWrites.js"], "git_node": null, "git_parents": [null], "node": "08c0fdb95713ca020011565022b253ee7cc8243d", "parents": ["8ec91b85f043b8c16a80fed32da48d8eaa6e70e7"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400442 - stylo heap write analysis: Miscellaneous minor annotations, r=jonco", "files": ["js/src/devtools/rootAnalysis/analyzeHeapWrites.js"], "git_node": null, "git_parents": [null], "node": "239eedb24ef258870ac5d2316e03451a01cbfef8", "parents": ["08c0fdb95713ca020011565022b253ee7cc8243d"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400442 - Assert that Gecko_ShouldCreateStyleThreadPool is only called on the main thread, r=emilio", "files": ["layout/style/ServoBindings.cpp"], "git_node": null, "git_parents": [null], "node": "696b8f10fcf33b103f8c4ef84c8976531643b603", "parents": ["239eedb24ef258870ac5d2316e03451a01cbfef8"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400442 - Special-case annotation for a-\u003eb-\u003eemplace(); a-\u003eb-\u003eInit(), r=bhackett", "files": ["js/src/devtools/rootAnalysis/analyzeHeapWrites.js"], "git_node": null, "git_parents": [null], "node": "d7209c7f31af92b0c006a6b320e4afcad2bc7887", "parents": ["696b8f10fcf33b103f8c4ef84c8976531643b603"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400442 - Trim down whitelists to only what is required, and mark all known issues with bug numbers, r=jonco\n\nI also snuck in some last-minute assertions and minor fixes into this patch:\n\n- don't stop reporting for a callee if we've seen it already (or rather, make the reachable set local to a root rather than global to all roots). This slows down runs with hundreds of hazards, but results in every problematic root being reported, for a more accurate count.\n\n- annotate away some thread assertions\n\n- special-case annotation for bug 1400435 since it's a whole family of hazards", "files": ["js/src/devtools/rootAnalysis/analyzeHeapWrites.js", "taskcluster/scripts/builder/hazard-analysis.sh"], "git_node": null, "git_parents": [null], "node": "1a53a959fd021f7cc31c6e0b0e5d869d5a23949a", "parents": ["d7209c7f31af92b0c006a6b320e4afcad2bc7887"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401184 - migrate mochitest-chrome from buildbot hardware to taskcluster VM. r=ahal", "files": ["layout/base/tests/chrome/chrome.ini", "taskcluster/ci/test/tests.yml"], "git_node": null, "git_parents": [null], "node": "c6b6fd015439f68a36cae903c5e6a771a33ba3c1", "parents": ["1a53a959fd021f7cc31c6e0b0e5d869d5a23949a"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397258 - migrate mochitest-webgl to windows 10. r=ahal", "files": ["taskcluster/ci/test/test-sets.yml", "taskcluster/ci/test/tests.yml"], "git_node": null, "git_parents": [null], "node": "0bf0ba5d68492c7e3f37279532d59337c99facd5", "parents": ["c6b6fd015439f68a36cae903c5e6a771a33ba3c1"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1398910 - make reftest-no-accel run on windows 10 (hardware) instead of windows 8. r=ahal,jet", "files": ["layout/reftests/abs-pos/reftest.list", "layout/reftests/columns/reftest.list", "layout/reftests/forms/fieldset/reftest.list", "layout/reftests/forms/input/text/reftest.list", "layout/reftests/forms/reftest.list", "layout/reftests/position-dynamic-changes/relative/reftest.list", "layout/reftests/scrolling/reftest.list", "layout/reftests/svg/svg-integration/reftest.list", "layout/reftests/text-overflow/reftest.list", "taskcluster/ci/test/test-platforms.yml", "taskcluster/ci/test/test-sets.yml", "taskcluster/ci/test/tests.yml"], "git_node": null, "git_parents": [null], "node": "ba27e91673d0fc9fab21c24f021203dcb9c5903f", "parents": ["0bf0ba5d68492c7e3f37279532d59337c99facd5"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401204 - Get rid of NS_BackgroundInputStream and NS_BackgroundOutputStream, r=valentin", "files": ["netwerk/base/nsNetUtil.cpp", "netwerk/base/nsNetUtil.h"], "git_node": null, "git_parents": [null], "node": "5b0de4548020931ddfa01b531b1b3e4cf2015d0b", "parents": ["ba27e91673d0fc9fab21c24f021203dcb9c5903f"], "tags": []}, {"author": "Tim Taubert \u003cttaubert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400940 - Fix WebAuthn deadlock when cancelling a request on tab switch r=jcj\n\nThis should be an easy solution. We can't stop the sign() or register()\nrunloop from calling the callback, so we need the callback to simply return\nearly when the U2FHIDTokenManager shuts down.\n\nBug #: 1400940\n\nDifferential Revision: https://phabricator.services.mozilla.com/D67", "files": ["dom/webauthn/U2FHIDTokenManager.cpp"], "git_node": null, "git_parents": [null], "node": "efa6750d4e133a6631af705dffb0ba98a7c75cd0", "parents": ["5b0de4548020931ddfa01b531b1b3e4cf2015d0b"], "tags": []}, {"author": "Rail Aliiev \u003crail@mozilla.com\u003e", "branch": "default", "desc": "Bug 1395697 - Use BZ2 MAR compression for versions less than 56.0 r=sfraser\n\nMozReview-Commit-ID: LutFJRayTOX", "files": ["taskcluster/docker/funsize-update-generator/scripts/funsize.py"], "git_node": null, "git_parents": [null], "node": "6c0e0f992f335b37ad70f6818b3e528c106455ee", "parents": ["efa6750d4e133a6631af705dffb0ba98a7c75cd0"], "tags": []}, {"author": "ffxbld", "branch": "default", "desc": "No bug, Automated HSTS preload list update from host bld-linux64-spot-304 - a=hsts-update", "files": ["security/manager/ssl/nsSTSPreloadList.errors", "security/manager/ssl/nsSTSPreloadList.inc"], "git_node": null, "git_parents": [null], "node": "44f69e2140e214353c040fc0846da0b346dbd4b5", "parents": ["e4261f5b96ebfd63e7cb8af3035ff9fea90c74a5"], "tags": []}, {"author": "ffxbld", "branch": "default", "desc": "No bug, Automated HPKP preload list update from host bld-linux64-spot-304 - a=hpkp-update", "files": ["security/manager/ssl/StaticHPKPins.h"], "git_node": null, "git_parents": [null], "node": "ba69e294fc80f23d54fc68050f1b7d63d341aa9c", "parents": ["44f69e2140e214353c040fc0846da0b346dbd4b5"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1370783 - Disable netwerk/test/browser/browser_child_resource.js on debug for frequent failures. r=me, a=test-only", "files": ["netwerk/test/browser/browser.ini"], "git_node": null, "git_parents": [null], "node": "14e8c355a0393ddfd01d34a68e32e25f4b161e67", "parents": ["6c0e0f992f335b37ad70f6818b3e528c106455ee"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1398766 - Disable toolkit/mozapps/extensions/test/browser/browser_gmpProvider.js on linux debug for frequent failures. r=me, a=test-only", "files": ["toolkit/mozapps/extensions/test/browser/browser.ini"], "git_node": null, "git_parents": [null], "node": "cfe8e6261a46182f214e7e8e3e790b9f9ab5ed57", "parents": ["14e8c355a0393ddfd01d34a68e32e25f4b161e67"], "tags": []}, {"author": "Stephen A Pohl \u003cspohl.mozilla.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1398582: Prevent drawing titles in title bars on macOS 10.13 when we don't want them. r=mstange", "files": ["widget/cocoa/nsCocoaWindow.mm"], "git_node": null, "git_parents": [null], "node": "e4ac2e4268c75afeb6c3428bf0e7957287f2bd9f", "parents": ["cfe8e6261a46182f214e7e8e3e790b9f9ab5ed57"], "tags": []}, {"author": "Michal Novotny \u003cmichal.novotny@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset from bug 1392841 due to speedometer regression. r=backout", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "8ec345b71a6e775d9ba65b2e770f98253492b8a9", "parents": ["e4ac2e4268c75afeb6c3428bf0e7957287f2bd9f"], "tags": []}, {"author": "Kai Engert \u003ckaie@kuix.de\u003e", "branch": "default", "desc": "Bug 1393854, land NSPR_4_18_RTM, no code change, only version numbers, r=me\nUPGRADE_NSPR_RELEASE\nDONTBUILD", "files": ["nsprpub/TAG-INFO", "nsprpub/config/prdepend.h", "nsprpub/pr/include/prinit.h", "old-configure.in"], "git_node": null, "git_parents": [null], "node": "331bcdb4167c725609e9fadf41f7815a42dd7e3f", "parents": ["8ec345b71a6e775d9ba65b2e770f98253492b8a9"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1386344 - JS shell: implement help(/pattern/), r=tcampbell", "files": ["js/src/builtin/TestingFunctions.cpp", "js/src/shell/js.cpp", "js/src/shell/jsshell.cpp"], "git_node": null, "git_parents": [null], "node": "254e42b6acf0b011bd62e815ec57aecca0a7a487", "parents": ["331bcdb4167c725609e9fadf41f7815a42dd7e3f"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401156 - Cleanup ini files for WPT FileAPI, r=qdot", "files": ["testing/web-platform/meta/FileAPI/idlharness.html.ini", "testing/web-platform/meta/FileAPI/idlharness.worker.js.ini", "testing/web-platform/meta/FileAPI/url/url_createobjecturl_blob.html.ini"], "git_node": null, "git_parents": [null], "node": "e904b06ef3b36246b3d691146dd88fc39e9365a9", "parents": ["254e42b6acf0b011bd62e815ec57aecca0a7a487"], "tags": []}, {"author": "Tobias Schneider \u003cschneider@jancona.com\u003e", "branch": "default", "desc": "Bug 1399605 - [intersection-observer] Check if target is actually being observed when unobserving. r=mrbkap", "files": ["dom/base/DOMIntersectionObserver.cpp", "dom/base/test/mochitest.ini", "dom/base/test/test_bug1399605.html"], "git_node": null, "git_parents": [null], "node": "76e4f11cc7a69a57f9a94265c3079079a442bad3", "parents": ["e904b06ef3b36246b3d691146dd88fc39e9365a9"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1396098 - part 1 - base `android-build` on Debian instead of CentOS; r=glandium,dustin\n\nCentOS 6 is pinned to glibc 2.12, but newer Android build-tools (like\naapt) require glibc 2.14.  It's not possible to safely upgrade CentOS\n6 distributions to glibc 2.14.\n\nCentOS 7 is pinned to glibc 2.17, which is new enough for newer\nAndroid build-tools. However, I had great difficulty bringing forward\nour existing centos:6 Docker image to centos:7.  In particular,\ninstalling recent enough Mercurial, git, Python, and pip versions was\ndifficult enough that I elected to not pursue this approach.\n\nInstead, I've elected to follow glandium's suggestion from\nhttps://bugzilla.mozilla.org/show_bug.cgi?id=1370119#c5: base on\nDebian with snapshots.debian.org for reproducibility.\n\nThe most significant changes here:\n\n- using Debian's snapshots repository\n- using Python and related tools provided by Debian and baked into the\n  build image\n- using the JDK and JRE provided by Debian and baked into the build\n  image, rather than versions from tooltool (or eventually a toolchain\n  build)\n\nMoving the builds over to use this image will follow in the patches\nahead.", "files": ["taskcluster/docker/android-build/Dockerfile", "taskcluster/docker/android-build/buildprops.json", "taskcluster/docker/android-build/oauth.txt", "taskcluster/docker/android-build/sources.list", "taskcluster/docker/recipes/debian-build-system-setup.sh", "taskcluster/docker/recipes/install-mercurial.sh", "taskcluster/scripts/builder/build-android-dependencies/after.sh", "taskcluster/scripts/builder/build-android-dependencies/before.sh"], "git_node": null, "git_parents": [null], "node": "9435244890be0054e5e13efc5d79345cf60ce47d", "parents": ["76e4f11cc7a69a57f9a94265c3079079a442bad3"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1396098 - part 2 - make android-* fire off of mozconfig changes; r=nalexander\n\nThis seems like the obvious thing to want to happen.", "files": ["taskcluster/ci/build/android-stuff.yml"], "git_node": null, "git_parents": [null], "node": "960c59ace16545af7614a3c92863e33eb1dfb95a", "parents": ["9435244890be0054e5e13efc5d79345cf60ce47d"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1396098 - part 3 - move android builds to new docker image; r=glandium\n\nNow that we have a Docker image with newer library versions on it, we\ncan move our builds over.  The new images differ from the old\nCentOS-based images in two important ways, though:\n\n1) The system compilers in the new image are new enough to be used as\n   host compilers; additionally, our CentOS-built GCC compilers will not\n   work.  We need to change the Android mozconfigs to reflect that.  We\n   also need to change the Android tasks to not depend on the GCC\n   toolchain builds.\n\n2) In a similar fashion, we can use the system JDK; we no longer need to\n   use the JDK from the Android NDK, which we had packaged up via the\n   Android dependencies task.\n\nBoth of these changes come with caveats: our l10n repack jobs continue\nto run on the CentOS-based images; l10n repacks have not been completely\nconverted to Taskcluster.  So we need to:\n\n1) Retain the use of our custom GCC toolchain for HOST_CC/HOST_CXX on\n   the CentOS-based images.\n\n2) Retain the JDK packages in the tooltool manifests, and referencing\n   them when we build on the CentOS-based images.", "files": ["mobile/android/config/mozconfigs/common", "taskcluster/ci/build/android-stuff.yml", "taskcluster/ci/build/android.yml"], "git_node": null, "git_parents": [null], "node": "3e7baf957e1d6af69aad895871fc3ed5ab2801f5", "parents": ["960c59ace16545af7614a3c92863e33eb1dfb95a"], "tags": []}, {"author": "J.C. Jones \u003cjjones@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399334 - Add more debugging to see why certificates aren't valid. r=ttaubert\n\nThere's an intermittent that is showing up now that test_register_sign.html\nchecks state.attestationCert.verify(); to ensure hte SoftToken's certificate\nis valid. This patch prints the offending certificate when it's encountered,\nto help diagnose the root cause.\n\nMozReview-Commit-ID: 4QSobq9fBGK", "files": ["dom/u2f/tests/frame_register_sign.html"], "git_node": null, "git_parents": [null], "node": "0902f7275334aeb271d494b6aac1ee2730add627", "parents": ["3e7baf957e1d6af69aad895871fc3ed5ab2801f5"], "tags": []}, {"author": "John Lin \u003cjolin@mozilla.com\u003e", "branch": "default", "desc": "servo: Merge #18558 - Update angle to address Android build error on macOS (from jhlin:update-angle); r=emilio\n\n\u003c!-- Please describe your changes on the following line: --\u003e\nPlease see servo/angle#27\n\n---\n\u003c!-- Thank you for contributing to Servo! Please replace each `[ ]` by `[X]` when the step is complete, and replace `__` with appropriate data: --\u003e\n- [X] `./mach build -d` does not report any errors\n- [X] `./mach test-tidy` does not report any errors\n- [ ] These changes fix #__ (github issue number if applicable).\n\n\u003c!-- Either: --\u003e\n- [ ] There are tests for these changes OR\n- [X] These changes do not require tests because it's a fix to build errors.\n\n\u003c!-- Also, please make sure that \"Allow edits from maintainers\" checkbox is checked, so that we can help you if you get stuck somewhere along the way.--\u003e\n\n\u003c!-- Pull requests that do not address these steps are welcome, but they will require additional verification as part of the review process. --\u003e\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 55588ce30d9ccb17379b65826671fbb0a58f55b8", "files": ["servo/Cargo.lock"], "git_node": null, "git_parents": [null], "node": "2c920ffd1d7c9480355be7e56e14e21eb9806185", "parents": ["6c1c2d8301199f5f755382e4a4526beee5a1d6d7"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1391293 - Reduce Address Bar results flickering when typing additional chars. r=adw\n\nMozReview-Commit-ID: HaIK8YJho1y", "files": ["toolkit/components/autocomplete/nsAutoCompleteSimpleResult.cpp", "toolkit/components/autocomplete/nsIAutoCompleteSimpleResult.idl", "toolkit/components/autocomplete/tests/unit/test_removeMatchAt.js", "toolkit/components/autocomplete/tests/unit/xpcshell.ini", "toolkit/components/places/UnifiedComplete.js", "toolkit/components/places/tests/unifiedcomplete/test_search_suggestions.js"], "git_node": null, "git_parents": [null], "node": "33a41b9cf92a2505b124353e83d15a39917a6977", "parents": ["2c920ffd1d7c9480355be7e56e14e21eb9806185"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1391293 - Remove some hundreds reflows and adapt reflow tests to the new insert method. r=florian\n\nMozReview-Commit-ID: 1a25ZHo2L8n", "files": ["browser/base/content/test/performance/browser_urlbar_keyed_search_reflows.js", "browser/base/content/test/performance/browser_urlbar_search_reflows.js", "browser/base/content/test/performance/head.js", "toolkit/content/widgets/autocomplete.xml"], "git_node": null, "git_parents": [null], "node": "a03036beafc062febf8c52c281e2e26c63ee63c5", "parents": ["33a41b9cf92a2505b124353e83d15a39917a6977"], "tags": []}, {"author": "Tom Tromey \u003ctom@tromey.com\u003e", "branch": "default", "desc": "Bug 1371849 - remove style editor's source-map pref; r=gl\n\nThis changes the style editor and inspector to use the same pref that\nthe other tools are using.  This pref is a bit of a misnomer for now,\nbecause the inspector and style editor aren't actually using the\nclient-side service; but I think the name is not very important, and\nunifying the prefs is worthwhile.\n\nMozReview-Commit-ID: FlwCICnoaX4", "files": ["devtools/client/framework/toolbox-options.xhtml", "devtools/client/inspector/computed/computed.js", "devtools/client/inspector/computed/test/browser_computed_original-source-link.js", "devtools/client/inspector/rules/rules.js", "devtools/client/inspector/rules/test/browser_rules_inline-source-map.js", "devtools/client/inspector/rules/test/browser_rules_invalid-source-map.js", "devtools/client/inspector/rules/test/browser_rules_original-source-link.js", "devtools/client/inspector/rules/test/browser_rules_original-sour