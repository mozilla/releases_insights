, "git_node": null, "git_parents": [null], "node": "f094ee5cc7b336a81ff8258a4dd93c1492926a87", "parents": ["4f28ecc3075147ee2aa29e50a6c1f57ef1becf37"], "tags": []}, {"author": "Towkir Ahmed \u003ctowkir17@gmail.com\u003e", "branch": "default", "desc": "Bug 1394933 - Bookmarks toolbar dropzone icon updated. r=dao, a=sledru\n\nMozReview-Commit-ID: A9vO96djx99", "files": ["browser/themes/shared/icons/bookmarks-toolbar.svg", "browser/themes/shared/icons/toolbar.svg", "browser/themes/shared/jar.inc.mn", "browser/themes/shared/menupanel.inc.css", "browser/themes/shared/toolbarbutton-icons.inc.css"], "git_node": null, "git_parents": [null], "node": "af868f36e4b6e295cad9fc2b134db1ca11dab1af", "parents": ["f094ee5cc7b336a81ff8258a4dd93c1492926a87"], "tags": []}, {"author": "Kaku Kuo \u003ckaku@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401909 - Turn on preference of ShutdownDecoder feature on desktop version release and beta channel. r=bwu, a=sledru\n\nMozReview-Commit-ID: JB3RmyjhvK9", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "01cad263a6050e1ed5f58a04bf0fda1464211aef", "parents": ["af868f36e4b6e295cad9fc2b134db1ca11dab1af"], "tags": []}], "date": 1506540271, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7841": {"changesets": [{"author": "tbirdbld", "branch": "THUNDERBIRD560b4_2017092717_RELBRANCH", "desc": "Automated checkin: version bump for thunderbird 56.0b4 release. DONTBUILD CLOSED TREE a=release", "files": [], "git_node": null, "git_parents": [null], "node": "431ed468719b99bb6e73ad0240b24fe15d90a978", "parents": ["a7ce97c49d67207368802cdba6c7862d8d4b0cd8"], "tags": ["THUNDERBIRD_56_0b4_BUILD7"]}, {"author": "tbirdbld", "branch": "THUNDERBIRD560b4_2017092717_RELBRANCH", "desc": "Added THUNDERBIRD_56_0b4_RELEASE THUNDERBIRD_56_0b4_BUILD7 tag(s) for changeset 431ed468719b. DONTBUILD CLOSED TREE a=release", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "d1f2ecabe6f3459a361950d8795aa8e115a14547", "parents": ["431ed468719b99bb6e73ad0240b24fe15d90a978"], "tags": []}], "date": 1506549082, "git_changesets": [null, null], "user": "tbirdbld"}, "7842": {"changesets": [{"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1403616 - Defer logging of Marionette IOError to after post-test checks. r=gbrown, a=test-only\n\nIf Firefox crashes while mochitests or reftests are running, Marionette\nwill trigger an IOError exception which currently gets logged immediately,\nand causes no post-test checks to be performed. This results in missing\ncrash and leak checks, and an unclear failure message on Treeherder.\n\nWith this change only the IOError from Marionette gets deferred until\nall post-test checks are done. This fixes the failure messages, and will\nput PROCESS_CRASH or leak log output first.\n\nMozReview-Commit-ID: JCYP5LlPE1m", "files": ["layout/tools/reftest/runreftest.py", "testing/mochitest/runtests.py"], "git_node": null, "git_parents": [null], "node": "2fbad6a28964d529b8d9c15cab56c882ba446d9a", "parents": ["01cad263a6050e1ed5f58a04bf0fda1464211aef"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397728 - Use waitForCondition to avoid intermittent failures in browser_searchbar_openpopup.js. r=florian, a=test-only\n\nMozReview-Commit-ID: K62zPje3Hnj", "files": ["browser/components/search/test/browser_searchbar_openpopup.js"], "git_node": null, "git_parents": [null], "node": "bdb29efa6bee6a1b8b2213f3829506a6c3217caf", "parents": ["2fbad6a28964d529b8d9c15cab56c882ba446d9a"], "tags": []}, {"author": "Jing-wei Wu \u003ctopwu.tw@gmail.com\u003e", "branch": "default", "desc": "Bug 1399378 - Update Fennec logo icons for 57 beta/release. r=nechen, a=sledru\n\nMozReview-Commit-ID: CUy4RSuiRnD", "files": ["mobile/android/branding/beta/content/about.png", "mobile/android/brandin