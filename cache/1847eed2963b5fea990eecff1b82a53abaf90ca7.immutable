df", "testing/talos/talos/pageloader/pageloader-signed.xpi", "testing/talos/talos/results.py", "testing/talos/talos/run_tests.py", "testing/talos/talos/test.py", "testing/talos/talos/tests/perf-reftest/.eslintrc.json", "testing/talos/talos/tests/perf-reftest/bloom-basic-2.html", "testing/talos/talos/tests/perf-reftest/bloom-basic-ref.html", "testing/talos/talos/tests/perf-reftest/bloom-basic.html", "testing/talos/talos/tests/perf-reftest/bloom_basic.manifest", "testing/talos/talos/tests/perf-reftest/bloom_basic_ref.manifest", "testing/talos/talos/tests/perf-reftest/coalesce-1.html", "testing/talos/talos/tests/perf-reftest/coalesce-ref.html", "testing/talos/talos/tests/perf-reftest/perf_reftest.manifest", "testing/talos/talos/tests/perf-reftest/util.js"], "git_node": null, "git_parents": [null], "node": "47f7b6c64265bc7bdd22eef7ab71abc97cf3f8bf", "parents": ["f8dd3f21e434be32fe5901849f1723b0e64cf668"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Merge m-c to inbound. a=merge", "files": ["testing/talos/talos/tests/perf-reftest/.eslintrc.json", "testing/talos/talos/tests/perf-reftest/bloom-basic-2.html", "testing/talos/talos/tests/perf-reftest/coalesce-1.html", "testing/talos/talos/tests/perf-reftest/coalesce-ref.html", "testing/talos/talos/tests/perf-reftest/perf_reftest.manifest"], "git_node": null, "git_parents": [null, null], "node": "6169cd08ca7d5912648e2f640d17d556355eb7a8", "parents": ["540d10078b32f3f2426dc208df2fd710bb5c7ca1", "47f7b6c64265bc7bdd22eef7ab71abc97cf3f8bf"], "tags": []}, {"author": "Sam Foster \u003csfoster@mozilla.com\u003e", "branch": "default", "desc": "Bug 1388832 - Fix right-click on searchbar when in overflow menu. r=jaws\n\n* Swap margins for paddings around the searchbar when in a menu. Elements that could precede and follow the searchbar all have margin: 0, and define top/bottom padding as 4px, so this seems reasonable\n* Replace the loop that looks for an appropriate trigger node to use element.closest. A click on the outside a toolbarbutton/item was climbing to the document node and throwing as it has no getAttribute method.\n\nMozReview-Commit-ID: LuniL3gdLWR", "files": ["browser/base/content/browser.js", "browser/themes/shared/customizableui/panelUI.inc.css"], "git_node": null, "git_parents": [null], "node": "6de16b8f63dcd2667b307ccb9d2c44783fb646f4", "parents": ["fc0e284fb21bbb2524a16f60a04a806d3b905d1f"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1391421 - Part 1 - Switch nsAndroidHistory to Unicode domains. r=esawin\n\nMozReview-Commit-ID: FoxZhwdg4ao", "files": ["mobile/android/components/build/nsAndroidHistory.cpp"], "git_node": null, "git_parents": [null], "node": "c9bfc364426e39047b46dea407839ff3b75c7897", "parents": ["6de16b8f63dcd2667b307ccb9d2c44783fb646f4"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1391421 - Part 2 - Make script dialogues use the Unicode domain as title. r=baku\n\nAt least on Android, the domain still appears in the dialogue box's title, so we want to pretty-print IDN domains there.\n\nMozReview-Commit-ID: 3MCeR4IUsuF", "files": ["dom/base/nsGlobalWindow.cpp"], "git_node": null, "git_parents": [null], "node": "2394625be48336e05eefb2aa3baf78b659a6b461", "parents": ["c9bfc364426e39047b46dea407839ff3b75c7897"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1391421 - Part 3 - Switch various places that can end up being user-visible to use Unicode domains. r=esawin,jwu\n\nAmongst others, this includes some prompts, as well as various progress messages sent to the Java UI.\n\nWe also fix getTabWithURL to be able to find tabs regardless of whether the given URL to search is written in Punycode or with Unicode characters.\n\nMozReview-Commit-ID: K7xhgz2IK2h", "files": ["mobile/android/chrome/content/browser.js", "mobile/android/components/PromptService.js", "mobile/android/components/TabSource.js", "mobile/android/components/geckoview/GeckoViewPermission.js", "mobile/android/components/geckoview/GeckoViewPrompt.js", "mobile/android/modules/HelperApps.jsm", "mobile/android/modules/geckoview/GeckoViewNavigation.jsm", "mobile/android/modules/geckoview/GeckoViewProgress.jsm"], "git_node": null, "git_parents": [null], "node": "458c41e006705917c1e189385422d000b405288e", "parents": ["2394625be48336e05eefb2aa3baf78b659a6b461"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1391421 - Part 4 - Switch Session Store to save the \"display\" URL. r=mikedeboer\n\nThe URL can end up being user-visible for \"Recently closed tabs\" (certainly on Android, and also when hovering over an entry on Desktop, at least in the old menu bar), so we should use pretty URLs instead of Punycode.\n\nMozReview-Commit-ID: Kil2ChToYa8", "files": ["mobile/android/chrome/content/browser.js", "toolkit/modules/sessionstore/SessionHistory.jsm"], "git_node": null, "git_parents": [null], "node": "89aa265c6be94b04701a4b6ecc3a51f135f42030", "parents": ["458c41e006705917c1e189385422d000b405288e"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1391421 - Part 5 - Normalise the saved \"appOrigin\" to Unicode. r=jwu\n\nTo avoid mismatches between the Unicode and Punycode versions of a domain, we should normalise the \"appOrigin\" that can get stored as part of a tab's extra session store data.\n\nTo that extent, we move the code that stores the appOrigin into the Tab object's constructor, so we don't have to parse the URL twice.\n\nMozReview-Commit-ID: KFr8CeeOYTe", "files": ["mobile/android/chrome/content/browser.js"], "git_node": null, "git_parents": [null], "node": "0f3603bb20458ab0419ffa8df7e4a2a8c7fd5d12", "parents": ["89aa265c6be94b04701a4b6ecc3a51f135f42030"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1391421 - Part 6 - Switch context menus to Unicode domains. r=jwu\n\nMozReview-Commit-ID: 6yjtRGI6Aui", "files": ["mobile/android/chrome/content/browser.js"], "git_node": null, "git_parents": [null], "node": "7707e5ec573c6bfadde7e3e7812a56603bbc38e8", "parents": ["0f3603bb20458ab0419ffa8df7e4a2a8c7fd5d12"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1391421 - Part 7 - Switch addon/theme install prompts to Unicode domains. r=jwu\n\nMozReview-Commit-ID: HlQKTJRu0FT", "files": ["mobile/android/chrome/content/browser.js"], "git_node": null, "git_parents": [null], "node": "77084cd51869771c19d8c8e5af2ea13ce3cf66c8", "parents": ["7707e5ec573c6bfadde7e3e7812a56603bbc38e8"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1391421 - Part 8 - Fix site identity handling. r=jwu\n\n\"getEffectiveHost\" further down expects the URI to be available - apparently this was broken ever since the original implementation.\n\nMozReview-Commit-ID: C1Q6PBYcvk3", "files": ["mobile/android/chrome/content/browser.js"], "git_node": null, "git_parents": [null], "node": "3cb0b289475c028cc9c532ed277e74d09946f906", "parents": ["77084cd51869771c19d8c8e5af2ea13ce3cf66c8"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1391421 - Part 9 - Add a basic Robocop test for IDN domain support. r=gbrown\n\nMozReview-Commit-ID: HAT9Imh9YVf", "files": ["mobile/android/tests/browser/robocop/robocop.ini", "mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/components/ToolbarComponent.java", "mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/testIdnSupport.java"], "git_node": null, "git_parents": [null], "node": "65537efd1f7262c7c43aa552fc2660a3e9960c81", "parents": ["3cb0b289475c028cc9c532ed277e74d