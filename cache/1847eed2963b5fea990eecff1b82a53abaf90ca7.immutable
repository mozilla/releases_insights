eric/nsImageFrame.cpp", "layout/generic/nsPluginFrame.cpp", "layout/generic/nsVideoFrame.cpp", "layout/painting/nsCSSRendering.cpp", "layout/painting/nsCSSRendering.h", "layout/painting/nsDisplayList.cpp", "layout/painting/nsDisplayList.h", "layout/painting/nsImageRenderer.cpp", "layout/painting/nsImageRenderer.h", "layout/xul/nsImageBoxFrame.cpp"], "git_node": null, "git_parents": [null], "node": "8291145f092011aa98367f4818042a1c51e61d1d", "parents": ["67ca40453027d20fc50a475828f7b8089ff6cbeb"], "tags": []}, {"author": "Nicolas Silva \u003cnsilva@mozilla.com\u003e", "branch": "default", "desc": "Bug 1393031 - Remove OpAddExternalImage from WebRenderParentCommands. r=sotaro", "files": ["gfx/layers/ipc/WebRenderMessages.ipdlh", "gfx/layers/wr/WebRenderBridgeParent.cpp"], "git_node": null, "git_parents": [null], "node": "980729ab6e94e8c887bf3031f7f742a6a5ea17e7", "parents": ["8291145f092011aa98367f4818042a1c51e61d1d"], "tags": []}, {"author": "Nicolas Silva \u003cnsilva@mozilla.com\u003e", "branch": "default", "desc": "Bug 1393031 - Remove unused nsTArray\u003cWebRenderParentCommand\u003e& parameter all over the place. r=jrmuizel", "files": ["gfx/layers/wr/WebRenderDisplayItemLayer.cpp", "gfx/layers/wr/WebRenderDisplayItemLayer.h", "gfx/layers/wr/WebRenderLayerManager.cpp", "layout/forms/nsButtonFrameRenderer.cpp", "layout/generic/nsBulletFrame.cpp", "layout/generic/nsCanvasFrame.cpp", "layout/generic/nsCanvasFrame.h", "layout/generic/nsColumnSetFrame.cpp", "layout/generic/nsHTMLCanvasFrame.cpp", "layout/generic/nsImageFrame.cpp", "layout/generic/nsImageFrame.h", "layout/generic/nsPluginFrame.cpp", "layout/generic/nsPluginFrame.h", "layout/generic/nsTextFrame.cpp", "layout/generic/nsVideoFrame.cpp", "layout/ipc/RenderFrameParent.cpp", "layout/ipc/RenderFrameParent.h", "layout/painting/nsCSSRendering.cpp", "layout/painting/nsCSSRendering.h", "layout/painting/nsDisplayList.cpp", "layout/painting/nsDisplayList.h", "layout/painting/nsImageRenderer.cpp", "layout/painting/nsImageRenderer.h", "layout/tables/nsTableFrame.cpp", "layout/tables/nsTableFrame.h", "layout/xul/nsImageBoxFrame.cpp", "layout/xul/nsImageBoxFrame.h"], "git_node": null, "git_parents": [null], "node": "f34a52244cf9f7d75b55edb2ca4bbe28ce5717ee", "parents": ["980729ab6e94e8c887bf3031f7f742a6a5ea17e7"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1399646: Part 2 - Use the async shutdown service for ServiceWorkerRegistrar. r=baku\n\nThe current shutdown handling code is susceptible to deadlocks, since it spins\nthe event loop while it holds mMonitor, and other main thread methods which\ntry to acquire mMonitor can be called from code that runs while the event loop\nis spinning.\n\nMy initial solution was just to release mMonitor before spinning the event\nloop, but at this point I think it makes more sense to switch to the\nstandardized AsyncShutdown routines, which provide better diagnostics and\nallow us to avoid one more nested event loop during shutdown.\n\nMozReview-Commit-ID: 1RtFN585IR7", "files": ["browser/base/content/test/performance/browser_startup.js", "dom/workers/ServiceWorkerRegistrar.cpp", "dom/workers/ServiceWorkerRegistrar.h"], "git_node": null, "git_parents": [null], "node": "4890481365e66c1ef2f7126481908b64002c113f", "parents": ["f34a52244cf9f7d75b55edb2ca4bbe28ce5717ee"], "tags": []}, {"author": "Tim Taubert \u003cttaubert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1388851 - Implement U2FHIDTokenManager r=jcj,qdot,keeler", "files": ["dom/webauthn/U2FHIDTokenManager.cpp", "dom/webauthn/U2FHIDTokenManager.h", "dom/webauthn/U2FTokenTransport.h", "dom/webauthn/moz.build"], "git_node": null, "git_parents": [null], "node": "c89dde5d6274c859c0fefe000a3c1ad59c13eece", "parents": ["4890481365e66c1ef2f7126481908b64002c113f"], "tags": []}, {"author": "Josh Matthews \u003cjosh@joshmatthews.net\u003e", "branch": "default", "desc": "servo: Merge #18415 - More codesize reductions for generated code (from jdm:moar-codesize); r=SimonSapin\n\nBloaty says this shaves off another 20kb from style::properties-based functions. The more limited Debug implementations enable sharing the property name strings between more functions, which saves on code size in the end.\n\n---\n- [x] `./mach build -d` does not report any errors\n- [x] `./mach test-tidy` does not report any errors\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: ddf7ad4814a956ea866cd76da6ccda6b33af438b", "files": ["servo/components/style/properties/helpers/animated_properties.mako.rs", "servo/components/style/properties/properties.mako.rs"], "git_node": null, "git_parents": [null], "node": "7e21e2a22358d3e1b1f9abcd1fd3592c7b023d08", "parents": ["7b5261e3f38e230e1bacad15b31352c110193692"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1398895: Part 1 - Initialize user prefs before loading any JS components. r=florian\n\nMozReview-Commit-ID: BAH7m0nLiIT", "files": ["toolkit/xre/nsAppRunner.cpp", "toolkit/xre/nsXREDirProvider.cpp", "toolkit/xre/nsXREDirProvider.h"], "git_node": null, "git_parents": [null], "node": "b51e0600fdc414552dd9dd7e4eefe4534b5dd73c", "parents": ["c89dde5d6274c859c0fefe000a3c1ad59c13eece"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1398895: Part 2 - Ensure component loader initialization after user prefs load. r=mccr8\n\nThe script precompiler needs to begin its work very early in the startup\nprocess in order to be effective. At the moment, this means before user\npreferences are loaded. It also needs to be able to compile scripts into\nthe shared JSM global when that's in use, in order to avoid unnecessary script\nclones.\n\nSince we can't know whether global sharing is enabled by that point, instead,\nwe just always compile module scripts into the shared module global rather\nthan the XPC compillation scope.\n\nThis also changes the global sharing tests to make a failure to respect the\nuser preference value a fatal error.\n\nMozReview-Commit-ID: G0NkSOl2vU9", "files": ["js/xpconnect/loader/mozJSComponentLoader.cpp", "js/xpconnect/loader/mozJSComponentLoader.h", "js/xpconnect/tests/marionette/test_loader_global_sharing.py"], "git_node": null, "git_parents": [null], "node": "97fbaf813dc6aaf4c1cb59d38268f4fe91950c54", "parents": ["b51e0600fdc414552dd9dd7e4eefe4534b5dd73c"], "tags": []}, {"author": "Olli Pettay \u003cOlli.Pettay@helsinki.fi\u003e", "branch": "default", "desc": "Bug 1398605, keep nsContentList objects alive for awhile when generating state keys so that new objects don't need to be created all the time, r=ehsan", "files": ["dom/base/nsContentUtils.cpp", "dom/html/nsHTMLDocument.cpp", "dom/html/nsHTMLDocument.h"], "git_node": null, "git_parents": [null], "node": "90dd92f271f5cc3209b7231a6d2f96ee32c8ae7d", "parents": ["97fbaf813dc6aaf4c1cb59d38268f4fe91950c54"], "tags": []}, {"author": "Florian Qu\u00e8ze \u003cflorian@queze.net\u003e", "branch": "default", "desc": "Bug 1356153 - when closing multiple tabs, remove the tabs without beforeunload listener first, and then close what remains from left to right for immediate user feedback, r=mconley.", "files": ["browser/base/content/tabbrowser.xml"], "git_node": null, "git_parents": [null], "node": "bb57f4702727f87e3bf578e3938075c095b3b0bd", "parents": ["90dd92f271f5cc3209b7231a6d2f96ee32c8ae7d"], "tags": []}, {"author": "Nicolas Silva \u003cnsilva@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397407 - Apply deferred image key deletions to the next transaction. r=Gankro", "files": ["gfx/layers/wr/WebRenderLayerManager.cpp"], "git_node": null, "git_parents": [null], "node": "5dff64340068f7e61dcbd239841ddbafe0693329", "parents": ["bb57f4702727f87e3bf578e3938075c095b3b0bd"], "tags": []}, {"author": "jason laster \u003cjlaster@mozilla.com\u003e", "branch": "default", "desc": "Bug 1398210 - WebExtension eval's fail to load in the debugger. r=jdescottes\n\nMozReview-Commit-ID: 7gBu9U7g2kw", "files": ["devtools/server/actors/utils/TabSources.js"], "git_node": null, "git_parents": [null], "node": "952bd76f99bcbfc6b22cc9083a8804b940c67051", "parents": ["5dff64340068f7e61dcbd239841ddbafe0693329"], "tags": []}, {"author": "Christian Holler (:decoder) \u003ccholler@mozilla.com\u003e", "branch": "default", "desc": "Bug 1318548 - Experimental image decoder code for LibFuzzer. r=aosmond", "files": ["image/moz.build", "image/test/fuzzing/TestDecoders.cpp", "image/test/fuzzing/moz.build"], "git_node": null, "git_parents": [null], "node": "4a850ded2e3e31f86b183dbf1071e92842c6428d", "parents": ["952bd76f99bcbfc6b22cc9083a8804b940c67051"], "tags": []}, {"author": "SingingTree \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1385241 - Remove mozilla-build specific rust install. r=ted.mielczarek\n\nThe MozillaBuildBootstrapper specific rust install code in not needed as\nmozbase already includes genertic code to achieve the same outcome. The\nmozilla-build specific code also leads to issues where it tries to add already\nexisting targets and fails the bootstrap. This changeset removes the\nmozilla-build specific step.\n\nMozReview-Commit-ID: G0BqKZrF40A", "files": ["python/mozboot/mozboot/mozillabuild.py"], "git_node": null, "git_parents": [null], "node": "a54ba2e89fe093f416814fe5e261d2d9957261bb", "parents": ["7e21e2a22358d3e1b1f9abcd1fd3592c7b023d08"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1397888: Remove pin icon from top sites title. r=liuche\n\nMozReview-Commit-ID: GTmfUzvD0k2", "files": ["mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/topsites/TopSitesCard.java"], "git_node": null, "git_parents": [null], "node": "5289d258b56541f4cb5ddcf4496b899c23b1ce38", "parents": ["a54ba2e89fe093f416814fe5e261d2d9957261bb"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1397888: Add top site pin assets. r=liuche\n\nMozReview-Commit-ID: IeBj25W9Jde", "files": ["mobile/android/app/src/photon/res/drawable-hdpi/topsite_pin.png", "mobile/android/app/src/photon/res/drawable-xhdpi/topsite_pin.png", "mobile/android/app/src/photon/res/drawable-xxhdpi/topsite_pin.png"], "git_node": null, "git_parents": [null], "node": "adab05485ec5f7966ef626981374f10ce54295f3", "parents": ["5289d258b56541f4cb5ddcf4496b899c23b1ce38"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1397888: Display pin icon in top-left of top sites card if pinned. r=liuche\n\nI don't scale the pin size/margins based on the dynamic tile size. This could\nmean we get into situations where the pin crowds out the top site tile but I\ndon't know if this would happen in practice.\n\nMozReview-Commit-ID: Ct8EP3dPr6N", "files": ["mobile/android/app/src/main/res/layout/activity_stream_topsites_card.xml", "mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/topsites/TopSitesCard.java"], "git_node": null, "git_parents": [null], "node": "e94744cad7d84baedd5065d725f887468504ecf0", "parents": ["adab05485ec5f7966ef626981374f10ce54295f3"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1397888 - review: Rename topsite_pin -\u003e as_pin_with_background. r=mcomella\n\nMozReview-Commit-ID: 60KvwxhSmKN", "files": ["mobile/android/app/src/main/res/layout/activity_stream_topsites_card.xml", "mobile/android/app/src/photon/res/drawable-hdpi/as_pin_with_background.png", "mobile/android/app/src/photon/res/drawable-hdpi/topsite_pin.png", "mobile/android/app/src/photon/res/drawable-xhdpi/as_pin_with_background.png", "mobile/android/app/src/photon/res/drawable-xhdpi/topsite_pin.png", "mobile/android/app/src/photon/res/drawable-xxhdpi/as_pin_with_background.png", "mobile/android/app/src/photon/res/drawable-xxhdpi/topsite_pin.png"], "git_node": null, "git_parents": [null], "node": "736023670ba84b9f3cd6f5b2eb303e2a62f7c79b", "parents": ["e94744cad7d84baedd5065d725f887468504ecf0"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1393099 - Wrap category titles in about:addons r=rhelmer\n\nMozReview-Commit-ID: I2IOA4u14KY", "files": ["toolkit/mozapps/extensions/content/extensions.js", "toolkit/mozapps/extensions/content/extensions.xul"], "git_node": null, "git_parents": [null], "node": "e0fe9ab6917b31d8188de3b9e3755a3f5800b402", "parents": ["736023670ba84b9f3cd6f5b2eb303e2a62f7c79b"], "tags": []}, {"author": "Miko Mynttinen \u003cmikokm@gmail.com\u003e", "branch": "default", "desc": "Bug 1399977 - Allocate some DisplayClipChains using nsDisplayListBuilder arena r=mattwoodrow\n\nMozReview-Commit-ID: 9TB4S6G4rJR", "files": ["layout/base/PresShell.cpp", "layout/generic/nsGfxScrollFrame.cpp"], "git_node": null, "git_parents": [null], "node": "a387ab8e47528b103d21caaee2085b3435066635", "parents": ["e0fe9ab6917b31d8188de3b9e3755a3f5800b402"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1396307 - Make sure we only set mRaceCacheWithNetwork to true when the feature is enabled r=michal\n\nMozReview-Commit-ID: FrLjfuExmYV", "files": ["netwerk/protocol/http/nsHttpChannel.cpp"], "git_node": null, "git_parents": [null], "node": "77cd8fa838bacdf3e3b79930cfcae8c37aa4e41e", "parents": ["a387ab8e47528b103d21caaee2085b3435066635"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1396307 - Add null check in nsHttpChannel::OnAuthAvailable r=michal\n\nMozReview-Commit-ID: L9zaroxJ72i", "files": ["netwerk/protocol/http/nsHttpChannel.cpp"], "git_node": null, "git_parents": [null], "node": "d4ec49c6206d95b85414f4780340afaec72c52c8", "parents": ["77cd8fa838bacdf3e3b79930cfcae8c37aa4e41e"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1396307 - Set mCacheAsyncOpenCalled back to flase when AsyncOpenURI fails r=michal\n\nMozReview-Commit-ID: VnwI3ERHVt", "files": ["netwerk/protocol/http/nsHttpChannel.cpp"], "git_node": null, "git_parents": [null], "node": "ea0aae8835feea76c41414ccb79782e370fa53be", "parents": ["d4ec49c6206d95b85414f4780340afaec72c52c8"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "servo: Merge #18508 - style: Add system colors from bug 1387594 (from mstange:add-fsbgc-system-colors); r=emilio\n\n\u003c!-- Please describe your changes on the following line: --\u003e\n\nThese are the necessary servo changes for https://bugzilla.mozilla.org/show_bug.cgi?id=1387594 .\n\nI'm also re-importing the generated Gecko bindings from my object directory:\n - servo/components/style/gecko/generated/structs_debug.rs\n - servo/components/style/gecko/generated/structs_release.rs\n\nBut the number of changes to those files surprises me.\n\n---\n\u003c!-- Thank you for contributing to Servo! Please replace each `[ ]` by `[X]` when the step is complete, and replace `__` with appropriate data: --\u003e\n- [X] `./mach build -d` does not report any errors\n- [X] `./mach test-tidy` does not report any errors\n- [ ] These changes fix #__ (github issue number if applicable).\n\n\u003c!-- Either: --\u003e\n- [ ] There are tests for these changes OR\n- [X] These changes do not require tests because they're tested by compiling mozilla-central once the patches from https://bugzilla.mozilla.org/show_bug.cgi?id=1387594 land - without this patch, Firefox won't compile.\n\n\u003c!-- Also, please make sure that \"Allow edits from maintainers\" checkbox is checked, so that we can help you if you get stuck somewhere along the way.--\u003e\n\n\u003c!-- Pull requests that do not address these steps are welcome, but they will require additional verification as part of the review process. --\u003e\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 28b1c3818f81f593e691ded1109cfaab829825ae", "files": ["servo/components/style/gecko/generated/atom_macro.rs", "servo/components/style/gecko/generated/bindings.rs", "servo/components/style/gecko/generated/structs_debug.rs", "servo/components/style/gecko/generated/structs_release.rs", "servo/components/style/properties/longhand/color.mako.rs"], "git_node": null, "git_parents": [null], "node": "f574820b65cffd6b8e3dd86adef7ac19e93c72a4", "parents": ["ea0aae8835feea76c41414ccb79782e370fa53be"], "tags": []}, {"author": "Grigory Kruglov \u003cgkruglov@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399904 - Surface detailed profile unpickling exceptions r=nalexander\n\nMozReview-Commit-ID: Cr7F7haUpog", "files": ["mobile/android/services/src/main/java/org/mozilla/gecko/fxa/authenticator/AccountPickler.java", "mobile/android/services/src/main/java/org/mozilla/gecko/fxa/authenticator/AndroidFxAccount.java", "mobile/android/services/src/main/java/org/mozilla/gecko/sync/Utils.java"], "git_node": null, "git_parents": [null], "node": "57348c4c72880d4c28838a3c2f0683dc0c014f28", "parents": ["f574820b65cffd6b8e3dd86adef7ac19e93c72a4"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1387594 - Add a chrome-only CSS property called -moz-font-smoothing-background-color. r=dbaron\n\nThis property accepts a color. It's inherited and defaults to transparent.\nIts value is respected on macOS when rendering text into transparent pixels.\nThis property should be used for text that is placed on top of \"vibrant\"\n-moz-appearances, in order to achieve high quality text rendering for such text.\n\nIn most cases, the property should be set to a named system color; an upcoming\npatch in this patch series will add one such color for each vibrant\n-moz-appearance value.\nHowever, in some cases it can also be useful to use a custom color: If text\nis rendered into an intermediate surface, for example because a mask is applied\nto it, and the background color behind that intermediate surface is known, then\nthis property can be set to that background color in order to achieve subpixel\nAA for the text inside the mask effect. In that case, the font smoothing\nbackground color is respected because text is rendered into transparent pixels\n*inside the intermediate surface*. At the moment, the only example of that use\ncase is the text of the active tab in the state where the text is overflowing.\n\nMozReview-Commit-ID: D98qQnxoFaq\n", "files": ["devtools/shared/css/generated/properties-db.js", "layout/style/nsCSSPropList.h", "layout/style/nsComputedDOMStyle.cpp", "layout/style/nsComputedDOMStyle.h", "layout/style/nsComputedDOMStylePropertyList.h", "layout/style/nsRuleNode.cpp", "layout/style/nsStyleStruct.cpp", "layout/style/nsStyleStruct.h", "layout/style/test/ListCSSProperties.cpp", "layout/style/test/property_database.js"], "git_node": null, "git_parents": [null], "node": "67ab42945b98077a04937fc348b8f0b6d9a54f34", "parents": ["57348c4c72880d4c28838a3c2f0683dc0c014f28"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1387594 - Stop getting the font smoothing background color from the theme. r=mattwoodrow\n\nMozReview-Commit-ID: 2r1B8SvEkEl\n", "files": ["gfx/src/nsITheme.h", "layout/painting/FrameLayerBuilder.cpp", "layout/painting/nsDisplayList.cpp", "layout/painting/nsDisplayList.h", "layout/xul/tree/nsTreeBodyFrame.cpp", "widget/cocoa/VibrancyManager.h", "widget/cocoa/VibrancyManager.mm", "widget/cocoa/nsChildView.h", "widget/cocoa/nsChildView.mm", "widget/cocoa/nsNativeThemeCocoa.h", "widget/cocoa/nsNativeThemeCocoa.mm"], "git_node": null, "git_parents": [null], "node": "45225685bdbc8f6df8552db00d9b2fa4004603f6", "parents": ["67ab42945b98077a04937fc348b8f0b6d9a54f34"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1387594 - Set the font smoothing background color based on the -moz-font-smoothing-background-color property. r=mattwoodrow\n\nMozReview-Commit-ID: B3PVIvMswf8\n", "files": ["layout/generic/nsTextFrame.cpp", "layout/xul/nsTextBoxFrame.cpp", "layout/xul/tree/nsTreeBodyFrame.cpp"], "git_node": null, "git_parents": [null], "node": "7fae5971e174f433a1f41922602af7de2ccb9aad", "parents": ["45225685bdbc8f6df8552db00d9b2fa4004603f6"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1387594 - Respect the font smoothing background color in pushed layers again. This backs out bug 1386643. r=jrmuizel\n\nMozReview-Commit-ID: KNsd7tKuRk1\n", "files": ["gfx/2d/DrawTargetSkia.cpp"], "git_node": null, "git_parents": [null], "node": "cc52c89aeb32bab11a5c121828e8b5d72cc6d937", "parents": ["7fae5971e174f433a1f41922602af7de2ccb9aad"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1387594 - Add system colors for use in conjunction with -moz-font-smoothing-background-color and vibrant -moz-appearances. r=dbaron\n\nMozReview-Commit-ID: IxXZwONxy41\n", "files": ["layout/style/nsCSSKeywordList.h", "layout/style/nsCSSProps.cpp", "widget/LookAndFeel.h", "widget/cocoa/nsLookAndFeel.mm", "widget/nsXPLookAndFeel.cpp", "widget/nsXPLookAndFeel.h"], "git_node": null, "git_parents": [null], "node": "b049c00f7a8f9310c4e9855a668c9d67fd9ebd49", "parents": ["cc52c89aeb32bab11a5c121828e8b5d72cc6d937"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1387594 - Sprinkle -moz-font-smoothing-background-color declarations over the CSS. r=dao\n\nThere's only one interesting case here: the active tab. When rendering the label\nof an overflowing active tab into the fadeout mask surface, text rendering must\nnot use the font smoothing background color for dark vibrancy. Instead, it needs\nto use the color of the tab itself for best results.\nAlternatively, we could set the font smoothing background color of the active\ntab to \"transparent\", because this text is not on top of a vibrant background.\nHowever, doing so would lose the subpixel AA and would not look as crisp.\n\nMozReview-Commit-ID: 28MKCz1vmb9\n", "files": ["browser/themes/osx/browser.css", "browser/themes/osx/places/organizer.css", "browser/themes/osx/places/places.css", "browser/themes/osx/syncedtabs/sidebar.css", "toolkit/themes/osx/global/menu.css", "toolkit/themes/osx/global/popup.css"], "git_node": null, "git_parents": [null], "node": "3dcafbdc27cf956aaddf2a0997c8c2ac02829b28", "parents": ["b049c00f7a8f9310c4e9855a668c9d67fd9ebd49"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset 754d3df0517d (bug 1378153)", "files": ["browser/branding/aurora/pref/firefox-branding.js"], "git_node": null, "git_parents": [null], "node": "ca18e7c2cadce9c93ea3eb89cc129dc37ca4c091", "parents": ["3dcafbdc27cf956aaddf2a0997c8c2ac02829b28"], "tags": []}, {"author": "Olli Pettay \u003cOlli.Pettay@helsinki.fi\u003e", "branch": "default", "desc": "Bug 1398196, flush layout before hittesting when handling mousedown/up, r=ehsan", "files": ["view/nsViewManager.cpp"], "git_node": null, "git_parents": [null], "node": "b3820db371aee902b4b903483b02ba79082951bd", "parents": ["4a850ded2e3e31f86b183dbf1071e92842c6428d"], "tags": []}, {"author": "Tim Taubert \u003cttaubert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1388851 - Follow-up to disable parts of browser_webauthn_telemetry.js r=bustage", "files": ["dom/webauthn/tests/browser/browser_webauthn_telemetry.js"], "git_node": null, "git_parents": [null], "node": "c115eec567a65b4045b7fce9765525cf79e24042", "parents": ["b3820db371aee902b4b903483b02ba79082951bd"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399503 - Use font family list passed from the chrome process to initialize the platform font family list on macOS, to avoid expensive Core Text font iteration code path. r=mconley", "files": ["dom/ipc/ContentChild.cpp", "dom/ipc/ContentChild.h", "dom/ipc/ContentParent.cpp", "dom/ipc/PContent.ipdl"], "git_node": null, "git_parents": [null], "node": "0bdbc08e691cff577004591c5d20350941759b96", "parents": ["c115eec567a65b4045b7fce9765525cf79e24042"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset f34a52244cf9 (bug 1393031)", "files": ["gfx/layers/wr/WebRenderDisplayItemLayer.cpp", "gfx/layers/wr/WebRenderDisplayItemLayer.h", "gfx/layers/wr/WebRenderLayerManager.cpp", "layout/forms/nsButtonFrameRenderer.cpp", "layout/generic/nsBulletFrame.cpp", "layout/generic/nsCanvasFrame.cpp", "layout/generic/nsCanvasFrame.h", "layout/generic/nsColumnSetFrame.cpp", "layout/generic/nsHTMLCanvasFrame.cpp", "layout/generic/nsImageFrame.cpp", "layout/generic/nsImageFrame.h", "layout/generic/nsPluginFrame.cpp", "layout/generic/nsPluginFrame.h", "layout/generic/nsTextFrame.cpp", "layout/generic/nsVideoFrame.cpp", "layout/ipc/RenderFrameParent.cpp", "layout/ipc/RenderFrameParent.h", "layout/painting/nsCSSRendering.cpp", "layout/painting/nsCSSRendering.h", "layout/painting/nsDisplayList.cpp", "layout/painting/nsDisplayList.h", "layout/painting/nsImageRenderer.cpp", "layout/painting/nsImageRenderer.h", "layout/tables/nsTableFrame.cpp", "layout/tables/nsTableFrame.h", "layout/xul/nsImageBoxFrame.cpp", "layout/xul/nsImageBoxFrame.h"], "git_node": null, "git_parents": [null], "node": "e1d623b0acedbc5ebc19a7a43a09a30d8e2af702", "parents": ["0bdbc08e691cff577004591c5d20350941759b96"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 980729ab6e94 (bug 1393031)", "files": ["gfx/layers/ipc/WebRenderMessages.ipdlh", "gfx/layers/wr/WebRenderBridgeParent.cpp"], "git_node":