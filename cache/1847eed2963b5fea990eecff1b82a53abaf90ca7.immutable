odules/freetype2/src/pfr/pfrobjs.c", "modules/freetype2/src/psaux/psconv.c", "modules/freetype2/src/psaux/t1decode.c", "modules/freetype2/src/raster/ftrend1.c", "modules/freetype2/src/sfnt/pngshim.c", "modules/freetype2/src/sfnt/sfobjs.c", "modules/freetype2/src/sfnt/ttcmap.c", "modules/freetype2/src/sfnt/ttcmap.h", "modules/freetype2/src/sfnt/ttkern.c", "modules/freetype2/src/sfnt/ttpost.c", "modules/freetype2/src/sfnt/ttsbit.c", "modules/freetype2/src/smooth/ftgrays.c", "modules/freetype2/src/smooth/ftsmooth.c", "modules/freetype2/src/tools/ftfuzzer/README", "modules/freetype2/src/truetype/ttgload.c", "modules/freetype2/src/truetype/ttgxvar.c", "modules/freetype2/src/truetype/ttinterp.c", "modules/freetype2/src/truetype/ttinterp.h", "modules/freetype2/src/truetype/ttobjs.c", "modules/freetype2/src/truetype/ttpload.c", "modules/freetype2/src/type1/t1load.c", "modules/freetype2/src/type1/t1objs.c", "modules/freetype2/src/type42/t42objs.c", "modules/freetype2/src/winfonts/winfnt.c", "modules/freetype2/vms_make.com"], "git_node": null, "git_parents": [null], "node": "c4f1d0d1852b6e61c7a3e78ec8c0e33879c20d95", "parents": ["1edc0d159982f6befa8c6e38f8af7e1f39c73e92"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset cc0acc00d769 (bug 1394233) for frequently failing own test usercss-uppercase.html on Windows 7 debug. r=backout a=backout\n\nMozReview-Commit-ID: GwVKJKGPzDS", "files": ["layout/reftests/usercss/reftest.list", "layout/reftests/usercss/usercss-uppercase.html", "layout/tools/reftest/chrome/userContent.css"], "git_node": null, "git_parents": [null], "node": "80494b13f4928660229d6c39d409cc4094a6b35a", "parents": ["faa897d7948b7e2439573f39c34366c138913663"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 7d0893f1b6ce (bug 1389021) for leaking in mda2 on Linux x64 asan (bug 1374856). r=backout a=backout\n\nMozReview-Commit-ID: AeaKVgSJTmt", "files": ["gfx/layers/ipc/CompositorManagerParent.cpp", "gfx/layers/ipc/CompositorManagerParent.h", "gfx/layers/ipc/CompositorThread.cpp"], "git_node": null, "git_parents": [null], "node": "877d536658e644bd0d1662d608cc2ca3a9fa8d9f", "parents": ["80494b13f4928660229d6c39d409cc4094a6b35a"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "merge mozilla-central to mozilla-inbound. r=merge a=merge", "files": ["layout/reftests/usercss/usercss-uppercase.html"], "git_node": null, "git_parents": [null, null], "node": "34434390f6dce43baa530ee02200640ee176cc73", "parents": ["c4f1d0d1852b6e61c7a3e78ec8c0e33879c20d95", "877d536658e644bd0d1662d608cc2ca3a9fa8d9f"], "tags": []}, {"author": "Mats Palmgren \u003cmats@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400623 - Add missing ClearOnShutdown.h #include.  r=aosmond\n\nMozReview-Commit-ID: 7AY4eGIOdv", "files": ["dom/ipc/ContentChild.cpp"], "git_node": null, "git_parents": [null], "node": "a190e5b26bb11910bb5a6d180c51d3deb8f2dde6", "parents": ["34434390f6dce43baa530ee02200640ee176cc73"], "tags": []}, {"author": "Neerja Pancholi \u003cnpancholi@mozilla.com\u003e", "branch": "default", "desc": "Bug 1381157 - Cache 'mContent-\u003eGetPrimaryFrame == this' with a flag on nsIFrame and replace these calls to GetPrimaryFrame. r=mats\n\nMozReview-Commit-ID: 3VoxYlean52", "files": ["dom/base/nsIContent.h", "dom/base/nsIContentInlines.h", "layout/generic/nsFrame.cpp", "layout/generic/nsIFrame.h"], "git_node": null, "git_parents": [null], "node": "97a042be82e5d16e97004376438cc8b6ec228c4e", "parents": ["a190e5b26bb11910bb5a6d180c51d3deb8f2dde6"], "tags": []}, {"author": "Eden Chuang \u003cechuang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1398991 - Set PaymentRequest.ShippingOption only if options.requestShipping is true. r=baku\n\nThis patch implements the following changes according to the spec change.\nSee https://w3c.github.io/payment-request/#constructor step 8 for more\ndetails.\n\n1. Return TypeError during PaymentRequest construction with duplicate\n   shippingOption id.\n2. Set PaymentRequest.shippingOption with the selected shippingOption only\n   if options.requestShipping is true.", "files": ["dom/payments/PaymentRequest.cpp", "dom/payments/PaymentRequestManager.cpp"], "git_node": null, "git_parents": [null], "node": "080349a1a6214fb01f40c40daa3c961a285a22ca", "parents": ["97a042be82e5d16e97004376438cc8b6ec228c4e"], "tags": []}, {"author": "Eden Chuang \u003cechuang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1398991 - Mochitest for spec change on PaymentRequest.shippingOption. r=baku\n\nThis patch changes the test_construction.html with following modification.\n1. Modify the test testWithDuplicateShippingOptionsParameters to expect a\n   TypeError when constructing wiht duplicate shippingOption ids.\n2. Add test testShippingOtpionAttribute for shippingOption setting checking\n   with following conditions\n   1. No selected shippingOption and PaymentOptions.requestShipping is false\n   2. One selected shippingOption and PaymentOptions.requestShipping is false\n   3. One selected shippingOption and PaymentOptions.requestShipping is true\n   4. Multiple selected shippingOptions and PaymentOptions.requestShipping is\n      true.", "files": ["dom/payments/test/ConstructorChromeScript.js", "dom/payments/test/test_constructor.html"], "git_node": null, "git_parents": [null], "node": "26289fa4d71ac9a6fefde68643a17cd0517a81d9", "parents": ["080349a1a6214fb01f40c40daa3c961a285a22ca"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400614 - P1. Handle case where we have no video track. r=gerald\n\nMozReview-Commit-ID: KcHMH3pOouc", "files": ["dom/media/MediaFormatReader.cpp"], "git_node": null, "git_parents": [null], "node": "92224fd4468ac84b2193a97f0ac61288ad86d2df", "parents": ["faa897d7948b7e2439573f39c34366c138913663"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400614 - P2. Change string output content. r=gerald\n\nDoesn't look as nice as I had hoped.\n\nMozReview-Commit-ID: 6GAXsVKC2sQ", "files": ["dom/media/MediaFormatReader.cpp"], "git_node": null, "git_parents": [null], "node": "0806dedfeae9b2af24698cb9d004bd0e5e46ba23", "parents": ["92224fd4468ac84b2193a97f0ac61288ad86d2df"], "tags": []}, {"author": "Tim Huang \u003ctihuang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1384330 - Part 1: Blocking the mozAddonManager when pref 'privacy.resistFingerprinting.block_mozAddonManager' is true. r=arthuredelstein,mossop\n\nThis patch adds a hidden pref 'privacy.resistFingerprinting.block_mozAddonManager',\nwhich is false by default. When this is true, the navigator.mozAddonManager will\nbe blocked even the website is AMO.\n\nThe purpose of this pref is for Tor browser can disable navigator.mozAddonManager\nthrough this.\n\nMozReview-Commit-ID: Lf37gHXETCz", "files": ["toolkit/mozapps/extensions/AddonManagerWebAPI.cpp"], "git_node": null, "git_parents": [null], "node": "bb14bbb30c4150b69d541d4c9f32762721a9ccc2", "parents": ["0806dedfeae9b2af24698cb9d004bd0e5e46ba23"], "tags": []}, {"author": "Tim Huang \u003ctihuang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1384330 - Part 2: Add a test case for testing that navigator.mozAddonManager is correctly blocked when pref 'privacy.resistFingerprinting.block_mozAddonManager' is true. r=arthuredelstein,mossop\n\nThe patch adds a test case which will first test with the pref off to see that\nnavigator.mozAddonManager can be accessed successfully. And then turn the pref\non to see that whether navigator.mozAddonManager is blocked.\n\nMozReview-Commit-ID: 3nptUqdg7p7", "files": ["browser/components/resistfingerprinting/test/browser/browser.ini", "browser/components/resistfingerprinting/test/browser/browser_block_mozAddonManager.js"], "git_node": null, "git_parents": [null], "node": "2189a968511ee8f51eb2deb046bd7914a76a693b", "parents": ["bb14bbb30c4150b69d541d4c9f32762721a9ccc2"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399930 - Add drag space padding to the tabs toolbar on OSX. r=Gijs\n\nThe previous drag space was only set as min-height on the titlebar,\nwhich led tabsintitlebar.js to not account that extra space for moving\nthe titlebar to the bottom (because it calculates that height from\ntab strip height). So while it looked fine visually, the titlebar did\nnot stretch all the way to the bottom, so that e.g. double-clicks aren't\nregistered correctly.\n\nMozReview-Commit-ID: 1mHFDBUe3sC", "files": ["browser/themes/osx/browser.css"], "git_node": null, "git_parents": [null], "node": "6bd0d9d8bc16a931642be34c54dd3522a4dce6d3", "parents": ["2189a968511ee8f51eb2deb046bd7914a76a693b"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "merge mozilla-central to autoland. r=merge a=merge", "files": ["layout/reftests/usercss/usercss-uppercase.html"], "git_node": null, "git_parents": [null, null], "node": "7ae99bcbaac4c84a727d4c81de529f5714b5c2cd", "parents": ["6bd0d9d8bc16a931642be34c54dd3522a4dce6d3", "877d536658e644bd0d1662d608cc2ca3a9fa8d9f"], "tags": []}, {"author": "Paul Rouget \u003cme@paulrouget.com\u003e", "branch": "default", "desc": "servo: Merge #18540 - Use BluetoothAdapter mock when bluetooth is disabled (from paulrouget:no_bt); r=nox\n\nToday, only the DOM API is disabled.\nWhen bluetooth is disabled, can we also disable bluetooth device code?\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 06628d2f6090e069b3447ad1ff09a1158e0836ab", "files": ["servo/components/bluetooth/lib.rs"], "git_node": null, "git_parents": [null], "node": "727e7ea0e10d5b58fdba437f358ef7bc6b4168c7", "parents": ["7ae99bcbaac4c84a727d4c81de529f5714b5c2cd"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400598 - P1. Stop parsing bytesteam as soon as we have found the necessary data. r=gerald\n\nMozReview-Commit-ID: 9APhbRHIMUP", "files": ["dom/media/mediasource/ContainerParser.cpp"], "git_node": null, "git_parents": [null], "node": "15e338118aa22edfb3297728fc4017613bdc2f68", "parents": ["727e7ea0e10d5b58fdba437f358ef7bc6b4168c7"], "tags": []}, {"author": "Simon Sapin \u003csimon.sapin@exyr.org\u003e", "branch": "default", "desc": "servo: Merge #18541 - Upgrade to rustc 1.22.0-nightly (277476c4f 2017-09-16) (from servo:rustup); r=SimonSapin\n\nhttps://github.com/rust-lang/rust/pull/43017\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: c28cf7490f2def7335c7c12e70e12e343eb1ec05", "files": ["servo/Cargo.lock", "servo/components/script/lib.rs", "servo/rust-toolchain"], "git_node": null, "git_parents": [null], "node": "14d7326af64d60a6be900427b468f94c7a2d2fda", "parents": ["15e338118aa22edfb3297728fc4017613bdc2f68"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "servo: Merge #18538 - stylo: Don't add a font-size dependency to the rule cache if the reference size is not our current style (from emilio:font-size-dep-correct); r=heycam\n\nWe enter the Custom(..) code path from other random places, like to remove the\nrelative lengths from a calc expression while zooming, or whatever craziness\nMathML font-size uses, and we don't want to set the dependency on those cases.\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 4b4a744265d1bd79f731ff7b9160af9f6af7db2b", "files": ["servo/components/style/values/specified/length.rs"], "git_node": null, "git_parents": [null], "node": "0ee945271889dc4a2b7650aa7edf9159d732837a", "parents": ["14d7326af64d60a6be900427b468f94c7a2d2fda"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1399546: Remove unused binding function. r=me\n\nMozReview-Commit-ID: 9FN3j5zNHQe\n", "files": ["layout/style/ServoBindings.cpp", "layout/style/ServoBindings.h"], "git_node": null, "git_parents": [null], "node": "f7b1daacf69d8d8b49fb881ec53e91667b372354", "parents": ["0ee945271889dc4a2b7650aa7edf9159d732837a"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1399546: Crashtest. r=me\n\nMozReview-Commit-ID: 5L8vYI6lRqd\n", "files": ["layout/style/crashtests/1399546.html", "layout/style/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "001d0020adccd2fa9e84ee97d5ca01d0f8ee6a7e", "parents": ["f7b1daacf69d8d8b49fb881ec53e91667b372354"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1400325: crashtest. r=me\n\nMozReview-Commit-ID: EW2rx0cc6Xs\n", "files": ["layout/style/crashtests/1400325.html", "layout/style/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "64b53d09febf538db91d4791a549680f43a2b57c", "parents": ["001d0020adccd2fa9e84ee97d5ca01d0f8ee6a7e"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "servo: Merge #18539 - script: a couple DOM conversion fixes (from emilio:dom-conversion-fixes); r=nox\n\nFixes https://github.com/servo/servo/issues/18535\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 6f97dd1c96dbe4389d818995e2b4965b87383b61", "files": ["servo/components/script/dom/bindings/codegen/CodegenRust.py", "servo/components/script/dom/bindings/conversions.rs", "servo/components/script/dom/bindings/utils.rs"], "git_node": null, "git_parents": [null], "node": "bec354d845873082a5d2c00e23500262c2cc89e5", "parents": ["64b53d09febf538db91d4791a549680f43a2b57c"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1400556 - apply padding to the tabs toolbar too to avoid other items moving when dragging tabs, r=johannh\n\nMozReview-Commit-ID: FXAYmACbYt1", "files": ["browser/base/content/browser.css"], "git_node": null, "git_parents": [null], "node": "af7271ca580b12a3b043a5c566917c9bb26a19aa", "parents": ["bec354d845873082a5d2c00e23500262c2cc89e5"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1400681 - remove footer inline start padding explicitly instead of not setting non-icon inline start padding, r=johannh\n\nUsing ':not' would unduly increase the specificity of the '.subviewbutton \u003e .toolbarbutton-text' rule,\nso I went with overriding it instead.\n\nMozReview-Commit-ID: 85o0IcjCgbQ", "files": ["browser/themes/shared/customizableui/panelUI.inc.css"], "git_node": null, "git_parents": [null], "node": "f5e1eb39daf0c6f606f1aa41483702656922672c", "parents": ["af7271ca580b12a3b043a5c566917c9bb26a19aa"], "tags": []}, {"author": "Chris Peterson \u003ccpeterson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400705 - cairo: Fix -Wunknown-warning-option clang warning about gcc flag (and suppress some other warnings). r=lsalzman\n\n* The -Wno-unused-but-set-variable flag is supported by gcc but not clang, so move it to a gcc-only CFLAGS.\n\n* The -Wno-error=uninitialized flag is supported by both gcc and clang, so move it to CFLAGS shared by gcc and clang.\n\n* Also suppress -Wunreachable-code and -Wshift-negative-value clang warnings. gcc supports -Wshift-negative-value, but only starting in gcc 6.1 and we are still using gcc 4.9 in automation.\n\nwarning: unknown warning option '-Wno-unused-but-set-variable'; did you mean '-Wno-unused-const-variable'? [-Wunknown-warning-option]\ngfx/cairo/cairo/src/cairo-quartz-surface.c:1908:6: warning: code will never be executed [-Wunreachable-code]\ngfx/cairo/libpixman/src/pixman-bits-image.c:268:32: warning: shifting a negative signed value is undefined [-Wshift-negative-value]\n\nMozReview-Commit-ID: AnQAsfDaZbk", "files": ["gfx/cairo/cairo/src/moz.build"], "git_node": null, "git_parents": [null], "node": "e4dad276a5231fd8a0a6428a94565598b35392b0", "parents": ["f5e1eb39daf0c6f606f1aa41483702656922672c"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "servo: Merge #18537 - style: Spring cleanup (from emilio:spring-cleanup); r=nox\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 14529da2a3c9a84cdec5735fca09d0bcb5995348", "files": ["servo/components/layout/construct.rs", "servo/components/layout/display_list_builder.rs", "servo/components/style/properties/data.py", "servo/components/style/properties/gecko.mako.rs", "servo/components/style/properties/helpers.mako.rs", "servo/components/style/properties/helpers/animated_properties.mako.rs", "servo/components/style/properties/longhand/background.mako.rs", "servo/components/style/properties/longhand/border.mako.rs", "servo/components/style/properties/longhand/box.mako.rs", "servo/components/style/properties/longhand/color.mako.rs", "servo/components/style/properties/longhand/column.mako.rs", "servo/components/style/properties/longhand/font.mako.rs", "servo/components/style/properties/longhand/inherited_box.mako.rs", "servo/components/style/properties/longhand/inherited_text.mako.rs", "servo/components/style/properties/longhand/outline.mako.rs", "servo/components/style/properties/longhand/svg.mako.rs", "servo/components/style/properties/longhand/text.mako.rs", "servo/components/style/properties/properties.mako.rs", "servo/components/style/servo/restyle_damage.rs", "servo/components/style/stylist.rs"], "git_node": null, "git_parents": [null], "node": "cee0aab185bf8c7259a32668e9ee59d34efe5c2f", "parents": ["e4dad276a5231fd8a0a6428a94565598b35392b0"], "tags": []}, {"author": "Daniel Holbert \u003cdholbert@cs.stanford.edu\u003e", "branch": "default", "desc": "Bug 1400421 part 1: Annotate class 'nsPageBreakFrame' as final, to reflect reality. r=mats\n\n(This was the only concrete nsLeafBoxFrame subclass that was missing this\nannotation.  So, after this patch, all concrete nsLeafBoxFrame subclasses will\nhave this annotation. Nice!)\n\nMozReview-Commit-ID: Iu1LaLTTqzu", "files": ["layout/generic/nsPageFrame.h"], "git_node": null, "git_parents": [null], "node": "c20a1a0d01ff475ff8db96f9e1d81c579029fa77", "parents": ["cee0aab185bf8c7259a32668e9ee59d34efe5c2f"], "tags": []}, {"author": "Daniel Holbert \u003cdholbert@cs.stanford.edu\u003e", "branch": "default", "desc": "Bug 1400421 part 2: Delete unused nsLeafFrame::Reflow override (and its DoReflow helper). r=mats\n\nnsLeafFrame only exists as an abstract superclass, and every subclass actually\nbrings along its own Reflow impl, so nsLeafFrame's own impl is just dead code.\n\nThis patch makes sure it's really dead code by leaving in the Reflow() decl\nwith \" = 0;\" so the compiler will enforce that all concrete subclasses *do*\nhave a more specific override (and that they don't just inherit the stub\nnsFrame impl from further up the ancestor chain, for example).\n\nMozReview-Commit-ID: Co36IpuaeOc", "files": ["layout/generic/nsLeafFrame.cpp", "layout/generic/nsLeafFrame.h"], "git_node": null, "git_parents": [null], "node": "5393e4f9885842009679d8b74faf5c7a22e0c45c", "parents": ["c20a1a0d01ff475ff8db96f9e1d81c579029fa77"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400254 - Don't apply fuzz workaround when appendWindowEnd is set. r=gerald\n\nSomeone changing the attribute appendWindowStart and appendWindowEnd can be expected to know what they are doing. As such, we don't need to make sure playback starts when content timestamps are broken.\n\nMozReview-Commit-ID: EcPORuDHpF5", "files": ["dom/media/mediasource/TrackBuffersManager.cpp"], "git_node": null, "git_parents": [null], "node": "601946972c4419825c21a42c7a0e673107677994", "parents": ["5393e4f9885842009679d8b74faf5c7a22e0c45c"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "servo: Merge #18525 - style: various serialization fixes (from emilio:border-spacing); r=nox\n\nThis should close https://github.com/servo/servo/pull/18458, and fix https://bugzilla.mozilla.org/show_bug.cgi?id=1397619.\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: f95da332a388cc7a94ddfc363872f5c570c27885", "files": ["servo/components/layout/model.rs", "servo/components/layout/table.rs", "servo/components/layout/table_row.rs", "servo/components/layout/table_rowgroup.rs", "servo/components/script/dom/element.rs", "servo/components/style/gecko/conversions.rs", "servo/components/style/properties/gecko.mako.rs", "servo/components/style/properties/helpers.mako.rs", "servo/components/style/properties/longhand/background.mako.rs", "servo/components/style/properties/longhand/border.mako.rs", "servo/components/style/properties/longhand/font.mako.rs", "servo/components/style/properties/longhand/inherited_table.mako.rs", "servo/components/style/properties/longhand/outline.mako.rs", "servo/components/style/properties/shorthand/border.mako.rs", "servo/components/style/properties/shorthand/outline.mako.rs", "servo/components/style/values/animated/mod.rs", "servo/components/style/values/computed/background.rs", "servo/components/style/values/computed/border.rs", "servo/components/style/values/computed/mod.rs", "servo/components/style/values/generics/background.rs", "servo/components/style/values/generics/border.rs", "servo/components/style/values/generics/mod.rs", "servo/components/style/values/generics/rect.rs", "servo/components/style/values/generics/size.rs", "servo/components/style/values/specified/background.rs", "servo/components/style/values/specified/border.rs", "servo/components/style/values/specified/mod.rs", "servo/ports/geckolib/glue.rs", "servo/tests/unit/style/parsing/border.rs"], "git_node": null, "git_parents": [null], "node": "446fa630c6ca22485cddeb9303f92af1d2a3239b", "parents": ["601946972c4419825c21a42c7a0e673107677994"], "tags": []}, {"author": "ffxbld", "branch": "default", "desc": "No bug, Automated HSTS preload list update from host bld-linux64-spot-302 - a=hsts-update", "files": ["security/manager/ssl/nsSTSPreloadList.errors", "security/manager/ssl/nsSTSPreloadList.inc"], "git_node": null, "git_parents": [null], "node": "8cec2ff21d14c594a91d283a0d70add33a512a93", "parents": ["877d536658e644bd0d1662d608cc2ca3a9fa8d9f"], "tags": []}, {"author": "ffxbld", "branch": "default", "desc": "No bug, Automated HPKP preload list update from host bld-linux64-spot-302 - a=hpkp-update", "files": ["security/manager/ssl/StaticHPKPins.h"], "git_node": null, "git_parents": [null], "node": "0408418cdef3a7ed4f72cdaaf5540b07b70021fd", "parents": ["8cec2ff21d14c594a91d283a0d70add33a512a93"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "merge autoland to mozilla-central. r=merge a=merge\n\nMozReview-Commit-ID: BVrawNPrB4h", "files": [], "git_node": null, "git_parents": [null, null], "node": "dd87b8587fc1d63e57ebdadcbabba89c6d172969", "parents": ["0408418cdef3a7ed4f72cdaaf5540b07b70021fd", "15e338118aa22edfb3297728fc4017613bdc2f68"], "tags": []}, {"author": "Tim Taubert \u003cttaubert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400662 - Prefer the USB token if the softtoken is enabled as well r=jcj\n\nBug #: 1400662\n\nDifferential Revision: https://phabricator.services.mozilla.com/D63", "files": ["dom/webauthn/U2FTokenManager.cpp"], "git_node": null, "git_parents": [null], "node": "a2ed201095ea183c4657aae5d961d8c978b06a9d", "parents": ["26289fa4d71ac9a6fefde68643a17cd0517a81d9"], "tags": []}, {"author": "Tim Taubert \u003cttaubert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400513 - u2f-hid-rs: fuzzers should use a deterministic cmd byte r=jcj\n\nSummary: We're currently using the thread_rng to derive a cmd byte for the U2F protocol fuzzers. That of course should rather be derived deterministically from the input handed to the fuzzing target.\n\nBug #: 1400513\n\nDifferential Revision: https://phabricator.services.mozilla.com/D61", "files": ["dom/webauthn/u2f-hid-rs/fuzz/corpus/u2f_read/3031b026f0eb80bc03d05be97b3cef550913a3d4", "dom/webauthn/u2f-hid-rs/fuzz/corpus/u2f_read/3e28ec02ceb803efa105dc82fcfc9cb4014d7ced", "dom/webauthn/u2f-hid-rs/fuzz/corpus/u2f_read/60c1a897bef5145eb977461d13f789e1ddfa4a69", "dom/webauthn/u2f-hid-rs/fuzz/corpus/u2f_read/7dc504e4505d6b4d3465aeb7bdf59702676a54cd", "dom/webauthn/u2f-hid-rs/fuzz/corpus/u2f_read/7f960b178bcf3adf082da7c632b4e1366ba22274", "dom/webauthn/u2f-hid-rs/fuzz/corpus/u2f_read/a05810d808f44249ae8ecfeadc59e5d8f7e55fb8", "dom/webauthn/u2f-hid-rs/fuzz/corpus/u2f_read/a22d2b1daa9483abc026fa2f75290aa51be59ca9", "dom/webauthn/u2f-hid-rs/fuzz/corpus/u2f_read_write/62b74bc0ad2433f77a007b95eaf964ea719d21e2", "dom/webauthn/u2f-hid-rs/fuzz/corpus/u2f_read_write/afcb12f9dddb1ed0bb06d6372e91b2707cd764d1", "dom/webauthn/u2f-hid-rs/fuzz/fuzz_targets/u2f_read.rs", "dom/webauthn/u2f-hid-rs/fuzz/fuzz_targets/u2f_read_write.rs"], "git_node": null, "git_parents": [null], "node": "8a9f6ef5c3d444dd96d1d90602906a3fd62947e0", "parents": ["a2ed201095ea183c4657aae5d961d8c978b06a9d"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "merge mozilla-inbound to mozilla-central. r=merge a=merge\n\nMozReview-Commit-ID: ExAoHf5iXNn", "files": ["dom/webauthn/u2f-hid-rs/fuzz/corpus/u2f_read/3e28ec02ceb803efa105dc82fcfc9cb4014d7ced", "dom/webauthn/u2f-hid-rs/fuzz/corpus/u2f_read/60c1a897bef5145eb977461d13f789e1ddfa4a69", "dom/webauthn/u2f-hid-rs/fuzz/corpus/u2f_read/7f960b178bcf3adf082da7c632b4e1366ba22274", "dom/webauthn/u2f-hid-rs/fuzz/corpus/u2f_read/a22d2b1daa9483abc026fa2f75290aa51be59ca9", "dom/webauthn/u2f-hid-rs/fuzz/corpus/u2f_read_write/62b74bc0ad2433f77a007b95eaf964ea719d21e2"], "git_node": null, "git_parents": [null, null], "node": "ae39864562c6048fdc2950c5dfedb48e247c3300", "parents": ["dd87b8587fc1d63e57ebdadcbabba89c6d172969", "8a9f6ef5c3d444dd96d1d90602906a3fd62947e0"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "merge mozilla-central to autoland. r=merge a=merge", "files": ["dom/webauthn/u2f-hid-rs/fuzz/corpus/u2f_read/3e28ec02ceb803efa105dc82fcfc9cb4014d7ced", "dom/webauthn/u2f-hid-rs/fuzz/corpus/u2f_read/60c1a897bef5145eb977461d13f789e1ddfa4a69", "dom/webauthn/u2f-hid-rs/fuzz/corpus/u2f_read/7f960b178bcf3adf082da7c632b4e1366ba22274", "dom/webauthn/u2f-hid-rs/fuzz/corpus/u2f_read/a22d2b1daa9483abc026fa2f75290aa51be59ca9", "dom/webauthn/u2f-hid-rs/fuzz/corpus/u2f_read_write/62b74bc0ad2433f77a007b95eaf964ea719d21e2"], "git_node": null, "git_parents": [null, null], "node": "7a01959c80e135bf948946fd2d09ad52f6c5672d", "parents": ["446fa630c6ca22485cddeb9303f92af1d2a3239b", "ae39864562c6048fdc2950c5dfedb48e247c3300"], "tags": []}, {"author": "Maya Messinger \u003cmaya.messinger@duke.edu\u003e", "branch": "default", "desc": "Bug 1387846 change print button command to print instead of print preview on all platforms r=Gijs\n\nMozReview-Commit-ID: IIxhCx4N362", "files": ["browser/components/customizableui/content/panelUI.inc.xul"], "git_node": null, "git_parents": [null], "node": "1aaa09eb300ce1763d516f6c4238e5acdbc20961", "parents": ["7a01959c80e135bf948946fd2d09ad52f6c5672d"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400100 - Shrink css::ImageValue. r=njn.\n\nThis reduces sizeof(ImageValue) from 104 to 96. When heap-allocated, this moves\nit from the 112 byte bin to the 96 byte bin. Loading gmail with Stylo, there\nare about 11,500 ImageValues on the heap, so this saves about 184,000 bytes.\n\nMozReview-Commit-ID: JLe2cJ54IlL", "files": ["layout/style/nsCSSValue.h"], "git_node": null, "git_parents": [null], "node": "7ca486b28b99167b8ee033a5c0d3d6cba5ad0f87", "parents": ["1aaa09eb300ce1763d516f6c4238e5acdbc20961"], "tags": []}, {"author": "James Cheng \u003cjacheng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399754 - [Part1] Replace CDM_LOG with GMP_LOG. r=cpearce\n\nMozReview-Commit-ID: IG3qsRGW42E", "files": ["dom/media/gmp/ChromiumCDMAdapter.cpp", "dom/media/gmp/ChromiumCDMChild.cpp", "dom/media/gmp/widevine-adapter/WidevineFileIO.cpp", "dom/media/gmp/widevine-adapter/WidevineUtils.cpp", "dom/media/gmp/widevine-adapter/WidevineUtils.h", "dom/media/gmp/widevine-adapter/WidevineVideoFrame.cpp"], "git_node": null, "git_parents": [null], "node": "0e9ac37163ea228b2145777b9f817802df52418e", "parents": ["7ca486b28b99167b8ee033a5c0d3d6cba5ad0f87"], "tags": []}, {"author": "James Cheng \u003cjacheng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399754 - [Part2] Fix wrong format string. r=cpearce\n\nMozReview-Commit-ID: 5oXE0UvGeFt", "files": ["dom/media/gmp/widevine-adapter/WidevineVideoFrame.cpp"], "git_node": null, "git_parents": [null], "node": "9779ff0008041b0ca1fa531d1d42437834896e81", "parents": ["0e9ac37163ea228b2145777b9f817802df52418e"], "tags": []}, {"author": "John Lin \u003cjolin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1394239 - don't return video frames that MDSM won't show. r=jya\n\nIn some Android ROMs, MediaCodec doesn't allocate additional buffers to reduce\nconsumer starvation and will not work when MDSM grips most recently returned\nframe before rearching seek target. Implement SetSeekThreshold() to get actual\nseek target to check if video buffers can be released back to remote decoder\nimmediately.\n\nMozReview-Commit-ID: 7IetuVxCXc0", "files": ["dom/media/platforms/android/RemoteDataDecoder.cpp", "dom/media/platforms/android/RemoteDataDecoder.h"], "git_node": null, "git_parents": [null], "node": "c86dac25f66fc0e7703bd27f99895ba3922c288b", "parents": ["9779ff0008041b0ca1fa531d1d42437834896e81"], "tags": []}, {"author": "Alexis Beingessner \u003ca.beingessner@gmail.com\u003e", "branch": "default", "desc": "Bug 1400411 - stop mocking most of DrawTarget. r=jrmuizel\n\nAlso fixes a bad debug assertion\n\nMozReview-Commit-ID: 5OV5KkvbRwZ", "files": ["layout/generic/TextDrawTarget.h"], "git_node": null, "git_parents": [null], "node": "8a0b8dfa2d7df3e13bea7f81ed7a17c360eef5d7", "parents": ["c86dac25f66fc0e7703bd27f99895ba3922c288b"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "servo: Merge #18547 - style: Resolver cleanup and sharing by rule node fixes (from emilio:self-sharing); r=heycam\n\nSee the individual commits for details.\n\nThis is the only coherent story I have for crashes like:\n\n  https://crash-stats.mozilla.com/report/index/bcdfe629-ca1f-4e4d-aa17-27f890170917\n\n(And the fact that there are crashes like it on the main thread kinda indicates it's the case)\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 2387dbedbb27629cd9e8c4657e8328ae04ff6d58", "files": ["servo/components/style/data.rs", "servo/components/style/matching.rs", "servo/components/style/sharing/mod.rs", "servo/components/style/style_resolver.rs", "servo/components/style/traversal.rs", "servo/ports/geckolib/glue.rs"], "git_node": null, "git_parents": [null], "node": "7df304758224132097e865e6b7c056f1892744e9", "parents": ["8a0b8dfa2d7df3e13bea7f81ed7a17c360eef5d7"], "tags": []}, {"author": "Bharat Raghunathan \u003cbharatraghunthan9767@gmail.com\u003e", "branch": "default", "desc": "Bug 1396794 - Removed aPacket and aLength change r=kentuckyfriedtakahe\n\nMozReview-Commit-ID: JG9vo3dbMB", "files": ["dom/media/flac/FlacFrameParser.cpp"], "git_node": null, "git_parents": [null], "node": "24833bf7fb61ad0809c5c85b7204ff1a1a5a3768", "parents": ["7df304758224132097e865e6b7c056f1892744e9"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400537 - P1. Don't assume that the PDM will properly report an error. r=alwu\n\nOnly the Windows H264 decoder supports CreateDecoderParam::mError, all the other PDM leave the value untouched.\n\nAs such, it can't be assumed that in case of failure, the mError attribute will be set.\n\nMozReview-Commit-ID: GWHGP6Wv3fl", "files": ["dom/media/platforms/wrappers/H264Converter.cpp"], "git_node": null, "git_parents": [null], "node": "f59c34720c8037e17f2205f65a2c8cad85455b93", "parents": ["24833bf7fb61ad0809c5c85b7204ff1a1a5a3768"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400537 - P2. Pass video framerate to decoder. r=gerald\n\nContinuation on bug 1397307 which was incomplete.\n\nMozReview-Commit-ID: JGGHQyjnALI", "files": ["dom/media/platforms/wrappers/H264Converter.cpp", "dom/media/platforms/wrappers/H264Converter.h"], "git_node": null, "git_parents": [null], "node": "14eff5fba2f12b7eb9e699b67b643115a3d2200d", "parents": ["f59c34720c8037e17f2205f65a2c8cad85455b93"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "servo: Merge #18549 - Fix a panic in Stylo memory reporting (from nnethercote:fix-enclosing-crash); r=heycam\n\n`MallocSizeOfOps::enclosing_size_of_op` is an `Option\u003c\u003e` type, and the panic in\nquestion is caused by not providing a value in a case where it's needed for\nmeasuring a HashSet.\n\nHashMaps and HashSets are common enough that it makes sense to make\n`enclosing_size_of_op` non-optional, which this patch does.\n\n\u003c!-- Please describe your changes on the following line: --\u003e\n\n---\n\u003c!-- Thank you for contributing to Servo! Please replace each `[ ]` by `[X]` when the step is complete, and replace `__` with appropriate data: --\u003e\n- [X] `./mach build -d` does not report any errors\n- [X] `./mach test-tidy` does not report any errors\n- [ ] These changes fix #__ (github issue number if applicable).\n\n\u003c!-- Either: --\u003e\n- [ ] There are tests for these changes OR\n- [X] These changes do not require tests because tests are on the Gecko side.\n\n\u003c!-- Also, please make sure that \"Allow edits from maintainers\" checkbox is checked, so that we can help you if you get stuck somewhere along the way.--\u003e\n\n\u003c!-- Pull requests that do not address these steps are welcome, but they will require additional verification as part of the review process. --\u003e\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: bb998dbdf31920d5ddc2a91d6bdfe8a880e11604", "files": ["servo/components/malloc_size_of/lib.rs", "servo/components/style/gecko/generated/bindings.rs", "servo/ports/geckolib/glue.rs"], "git_node": null, "git_parents": [null], "node": "5e7579eb651d4c0ac2300e8da2aa0ac09ee84b7b", "parents": ["14eff5fba2f12b7eb9e699b67b643115a3d2200d"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400624 - Fix a panic in Stylo memory reporting. r=heycam.\n\n`MallocSizeOfOps::enclosing_size_of_op` is an `Option\u003c\u003e` type, and the panic in\nquestion is caused by not providing a value in a case where it's needed for\nmeasuring a HashSet.\n\nHashMaps and HashSets are common enough that it makes sense to make\n`enclosing_size_of_op` non-optional, which this patch does.\n\nMozReview-Commit-ID: IB2aRuXHj8E", "files": ["dom/base/Element.cpp", "layout/style/ServoBindingList.h", "layout/style/ServoStyleSheet.cpp"], "git_node": null, "git_parents": [null], "node": "cd29ce68eefee0ceb49c9f909c27e545267dc221", "parents": ["5e7579eb651d4c0ac2300e8da2aa0ac09ee84b7b"], "tags": []}, {"author": "Ting-Yu Lin \u003ctlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399767 - Remove preference \"layout.css.clip-path-shapes.enabled\". r=heycam\n\nThe variables (basicShapeSVGBoxValues, etc.) in property_database.js are\nmoved to the beginning of the file so that they're defined before usage.\n\nMozReview-Commit-ID: 7L3obIY1alP", "files": ["layout/base/nsLayoutUtils.cpp", "layout/base/nsLayoutUtils.h", "layout/reftests/svg/reftest.list", "layout/reftests/svg/smil/reftest.list", "layout/reftests/svg/svg-integration/clip-path/reftest.list", "layout/reftests/w3c-css/submitted/masking/reftest.list", "layout/reftests/w3c-css/submitted/shapes1/reftest.list", "layout/style/nsCSSParser.cpp", "layout/style/test/property_database.js", "layout/style/test/test_clip-path_polygon.html", "layout/style/test/test_transitions_per_property.html", "modules/libpref/init/all.js", "testing/web-platform/meta/css-shapes/__dir__.ini"], "git_node": null, "git_parents": [null], "node": "c452e8622329018257c34641e21f747337ecaebe", "parents": ["cd29ce68eefee0ceb49c9f909c27e545267dc221"], "tags": []}, {"author": "abhinav \u003cabhinav.koppula@gmail.com\u003e", "branch": "default", "desc": "Bug 1394323 - Remove overflow css rule for 'response-panel' as it prevents scrolling in Console 'Response' tab. r=nchevobbe\n\nMozReview-Commit-ID: GHbYuCfs9L", "files": ["devtools/client/themes/webconsole.css"], "git_node": null, "git_parents": [null], "node": "4ef69bbd6816d95ade430640785971f587e2d5bc", "parents": ["c452e8622329018257c34641e21f747337ecaebe"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "servo: Merge #18550 - Measure ImageValue objects (take 2) (from nnethercote:bug-1399758-take-2); r=heycam\n\nWe have about 11,500 of these when loading gmail in a Stylo-enabled build, from\nSpecifiedUrls; the objects themselves account for about 1.3 MiB of memory, and\nthe strings within them about 2.9 MiB.\n\nWe also have a very small number of them on the Gecko side.\n\n\u003c!-- Please describe your changes on the following line: --\u003e\n\n---\n\u003c!-- Thank you for contributing to Servo! Please replace each `[ ]` by `[X]` when the step is complete, and replace `__` with appropriate data: --\u003e\n- [X] `./mach build -d` does not report any errors\n- [X] `./mach test-tidy` does not report any errors\n- [ ] These changes fix #__ (github issue number if applicable).\n\n\u003c!-- Either: --\u003e\n- [ ] There are tests for these changes OR\n- [X] These changes do not require tests because testing is on the Gecko side.\n\n\u003c!-- Also, please make sure that \"Allow edits from maintainers\" checkbox is checked, so that we can help you if you get stuck somewhere along the way.--\u003e\n\n\u003c!-- Pull requests that do not address these steps are welcome, but they will require additional verification as part of the review process. --\u003e\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 8397c5b0a210a33a0991d369e88016dd51f521fd", "files": ["servo/components/style/gecko/generated/bindings.rs", "servo/components/style/gecko/url.rs"], "git_node": null, "git_parents": [null], "node": "112dba6948d388a6154f073c4f09c2c6a9addcf7", "parents": ["4ef69bbd6816d95ade430640785971f587e2d5bc"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399758 - Measure ImageValue objects. r=heycam.\n\nWe have about 11,500 of these when loading gmail in a Stylo-enabled build, from\nSpecifiedUrls; the objects themselves account for about 1.3 MiB of memory, and\nthe strings within them about 2.9 MiB.\n\nWe also have a very small number of them on the Gecko side.", "files": ["layout/style/ServoBindings.cpp", "layout/style/ServoBindings.h", "layout/style/nsCSSValue.cpp", "layout/style/nsCSSValue.h"], "git_node": null, "git_parents": [null], "node": "3816b3b4f793fc3d02b8e22af1a4ddeceff3ea09", "parents": ["112dba6948d388a6154f073c4f09c2c6a9addcf7"], "tags": []}, {"author": "Shane Caraveo \u003cscaraveo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400391 fix e10s xpcshell-test for remote webextensions, r=kmag\n\nMozReview-Commit-ID: AgdmUNWLGaq", "files": ["toolkit/components/extensions/test/xpcshell/head.js", "toolkit/components/