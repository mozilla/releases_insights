], "git_node": null, "git_parents": [null], "node": "0d5b3f16219c3780c33c1804613a00b77263f7b8", "parents": ["be5bddf32db0a1ed27251295b7711d06f9189b11"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1400128 - Link thumb library of libc++ when using MOZ_THUMB=1 and NDK r11c. r=froydnj\n\ncpu_arch_dir isn't absolute path, we cannot always detect thumb library for c++ library.  Our build tool still uses NDK r11c, so we should check thumb library correctly.\n\nMozReview-Commit-ID: 912ZDNeUcKc", "files": ["build/autoconf/android.m4"], "git_node": null, "git_parents": [null], "node": "faa897d7948b7e2439573f39c34366c138913663", "parents": ["be5bddf32db0a1ed27251295b7711d06f9189b11"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "merge mozilla-central to mozilla-inbound. r=merge a=merge", "files": [], "git_node": null, "git_parents": [null, null], "node": "1edc0d159982f6befa8c6e38f8af7e1f39c73e92", "parents": ["0d5b3f16219c3780c33c1804613a00b77263f7b8", "faa897d7948b7e2439573f39c34366c138913663"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1400602 - Update Freetype to version 2.8.1. r=jfkthame", "files": ["modules/freetype2/CMakeLists.txt", "modules/freetype2/ChangeLog", "modules/freetype2/ChangeLog.24", "modules/freetype2/ChangeLog.25", "modules/freetype2/Jamfile", "modules/freetype2/LICENSE.TXT", "modules/freetype2/README", "modules/freetype2/builds/mac/ftmac.c", "modules/freetype2/builds/unix/config.guess", "modules/freetype2/builds/unix/config.sub", "modules/freetype2/builds/unix/configure", "modules/freetype2/builds/unix/configure.ac", "modules/freetype2/builds/unix/configure.raw", "modules/freetype2/builds/unix/freetype-config.in", "modules/freetype2/builds/unix/unix-def.in", "modules/freetype2/builds/wince/vc2005-ce/freetype.vcproj", "modules/freetype2/builds/wince/vc2005-c