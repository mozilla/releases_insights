olkit/themes/windows/mozapps/plugins/pluginBlocked.png"], "git_node": null, "git_parents": [null], "node": "029958b424815e19434006ddecfefe68fd3a78b5", "parents": ["ff2d35ad0649e8d3be8fbddd88df1ff36dbacb35"], "tags": []}, {"author": "Dale Harvey \u003cdale@arandomurl.com\u003e", "branch": "default", "desc": "Bug 1402290 - Update notification alignment. r=dao, a=ritu\n\nMozReview-Commit-ID: 4Oxqtl9wEig", "files": ["toolkit/themes/shared/notification.inc.css"], "git_node": null, "git_parents": [null], "node": "2220c5f79afbc969f367d3082eb009c7ec8f8687", "parents": ["029958b424815e19434006ddecfefe68fd3a78b5"], "tags": []}], "date": 1507746768, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7948": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nan -\u003e 9fa689237879\nar -\u003e 9a7347120daf\nbg -\u003e 1b0b11b34950\nbn-BD -\u003e e3ce87ac65c9\nit -\u003e d0a20b8be323\nkab -\u003e eec9c643f986\nnl -\u003e 715142d1d48a\npl -\u003e 6d7373d26405\npt-BR -\u003e 4510f97a3864\npt-PT -\u003e b5de4d1ca97d", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "d9f38ffcbcc8499ff3fd0ee66582594602d62a19", "parents": ["2220c5f79afbc969f367d3082eb009c7ec8f8687"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nan -\u003e c68cc31d3490\nar -\u003e 9a7347120daf\nbg -\u003e 4cd3d08fe7f9\nbn-BD -\u003e 53b6cc53d5d7\nes-AR -\u003e a7eca57b73ae\nfr -\u003e 3e58f2d6bb94\nid -\u003e 0b68fae85794\nit -\u003e d0a20b8be323\nka -\u003e fc473ecf091e\nkab -\u003e cb2b3a7de50e\nko -\u003e 8869a4b89c5d\nnl -\u003e 715142d1d48a\npl -\u003e 6d7373d26405\npt-BR -\u003e 4510f97a3864\npt-PT -\u003e b5de4d1ca97d\nzh-CN -\u003e 0cabbef1401e", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "c0121c274860c83b7b674e804fd0e80234c7db37", "parents": ["d9f38ffcbcc8499ff3fd0ee66582594602d62a19"], "tags": []}], "date": 1507749668, "git_changesets": [null, null], "user": "ffxbld"}, "7949": {"changesets": [{"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1405065 - Implement accNavigate in Windows a11y LazyInstantiator. r=MarcoZ, a=ritu\n\nThe first accessibility client to ask for the root accessible will get a surrogate LazyInstantiator object. That instantiates accessibility if appropriate and then passes calls through.\nHowever, it previously didn't implement accNavigate, which broke things for clients that used this on the root.\nIn particular, this was bad for NAVRELATION_EMBEDS, which is used by some clients to retrieve the tab document.\nThis patch simply passes accNavigate through to the real accessible, just as is already done for other methods.\n\nMozReview-Commit-ID: KIoA9BwMDhc", "files": ["accessible/windows/msaa/LazyInstantiator.cpp"], "git_node": null, "git_parents": [null], "node": "614027e7d4e3ee97eaaaeccc9b46ca9cf048007b", "parents": ["c0121c274860c83b7b674e804fd0e80234c7db37"], "tags": []}, {"author": "Henri Sivonen \u003chsivonen@hsivonen.fi\u003e", "branch": "default", "desc": "Bug 1405568 - Return false from nsHtml5String::LowerCaseStartsWithASCII when this string is shorter than the literal. r=smaug, a=ritu\n\nMozReview-Commit-ID: AfPZ3nnOGQu", "files": ["parser/html/nsHtml5String.cpp", "testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/html/syntax/parsing/empty-doctype-ids.html"], "git_node": null, "git_parents": [null], "node": "1fa3a14b4612da51cf645cc521c74afc03b96560", "parents": ["614027e7d4e3ee97eaaaeccc9b46ca9cf048007b"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400003 - Mark Heap\u003cT\u003e and barrier classes as MOZ_NON_MEMMOVABLE. r=sfink, r=froydnj, a=lizzard", "files": ["js/public/RootingAPI.h", "js/src/gc/Barrier.h", "xpcom/ds/nsTArray.h"], "git_node": null, "git_parents": [null], "node": "238145ba52b8a392edfc0d0c20d121ca1b2e1420", "parents": ["1fa3a14b4612da51cf645cc521c74afc03b96560"], "tags": []}, {"author": "James Cheng \u003cjacheng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1365894 - Make SystemGroupImpl be a normal ref-counted object. r=ehsan, a=ritu\n\nMozReview-Commit-ID: LUcoBhNx2M5", "files": ["xpcom/threads/SystemGroup.cpp"], "git_node": null, "git_parents": [null], "node": "a4dfb0e4ad97ec2f9b535f8232b063a9f151eaa4", "parents": ["238145ba52b8a392edfc0d0c20d121ca1b2e1420"], "tags": []}, {"author": "Grigory Kruglov \u003cgkruglov@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401318 - Fix some of the 'shared-state' access problems around Account. r=nalexander, a=ritu\n\nThis patch fixes several symptoms of shared state (internal 'account' instance) getting\nout-of-sync with the world.\n\nWe maintain a representation of an internal Account in the AndroidFxAccount, but nothing is\npreventing that representation to become irrelevant in certain situations. This patch ensures\nwe 'update our internal cache', so to speak, before trying to act upon it.\n\nChanges in the 'profile JSON fetched' flow are necessary to support the 'email might change' case.\nLocking is necessary to ensure correct behaviour in case of overlapping syncing and profile fetching.\n\nChanges in 'getState' are necessary to ensure we behave correctly when a long-lived AndroidFxAccount\ninstance is interrogated (as in the Sync Prefs UI) after internal account changes.\n\nThere are likely to be other \"symptoms\", but this patch aims to be safely upliftable in order to\nsupport changing of a primary email.\n\nSee Bug 1407316 for further root-cause analysis and proposed solution.\n\nMozReview-Commit-ID: AXmTBMzL2cf", "files": ["mobile/android/services/src/main/java/org/mozilla/gecko/fxa/authenticator/AndroidFxAccount.java"], "git_node": null, "git_parents": [null], "node": "9ea0df8dba2b238113abe30d7522358748a4c1f4", "parents": ["a4dfb0e4ad97ec2f9b535f8232b063a9f151eaa4"], "tags": []}, {"author": "Nihanth Subramanya \u003cnhnt11@gmail.com\u003e", "branch": "default", "desc": "Bug 1407021 - Ensure in-content button font-size is not overridden by widget styling (e.g. in forms.css). r=johannh, a=ritu\n\nMozReview-Commit-ID: 2CRNOWClWmZ", "files": ["toolkit/themes/shared/in-content/common.inc.css"], "git_node": null, "git_parents": [null], "node": "7185be26d0db4223860238d50600cffb9e1f2c00", "parents": ["9ea0df8dba2b238113abe30d7522358748a4c1f4"], "tags": []}], "date": 1507755043, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7950": {"changesets": [{"author": "Thomas Nguyen \u003ctnguyen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1356854 - Check mFD is not null before PR_Write. r=mcmanus, a=ritu\n\nMozReview-Commit-ID: INoTUvPpPrs", "files": ["netwerk/base/nsFileStreams.cpp"], "git_node": null, "git_parents": [null], "node": "469b8b2974ebdf05d58ab8589fa8107e8f2bee7f", "parents": ["7185be26d0db4223860238d50600cffb9e1f2c00"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1404126 - Upgrade Follow-on search add-on to 0.9.5. r=past, a=ritu", "files": ["browser/extensions/followonsearch/bootstrap.js", "browser/extensions/followonsearch/content/followonsearch-fs.js", "browser/extensions/followonsearch/install.rdf"], "git_node": null, "git_parents": [null], "node": "d055ef797ede4146175553810e4630031d2254ce", "parents": ["469b8b2974ebdf05d58ab8589fa8107e8f2bee7f"], "tags": []}, {"author": "Jing-wei Wu \u003ctopwu.tw@gmail.com\u003e", "branch": "default", "desc": "Bug 1405954 - Part 1: Increase progress bar height from 2dp to 3dp. r=nechen, a=ritu\n\nMozReview-Commit-ID: CKLzo7SWKiX", "files": ["mobile/android/app/src/main/res/layout/customtabs_activity.xml", "mobile/android/app/src/main/res/layout/gecko_app.xml"], "git_node": null, "git_parents": [null], "node": "c3e64c4579b503e68b63ff6205ae6da60987d6bc", "parents": ["d055ef797ede4146175553810e4630031d2254ce"], "tags": []}, {"author": "Jing-wei Wu \u003ctopwu.tw@gmail.com\u003e", "branch": "default", "desc": "Bug 1405954 - Part 2: Change status bar background color to #F9F9FA. r=nechen, a=ritu\n\nMozReview-Commit-ID: 2vrGayqw5zp", "files": ["mobile/android/app/src/photon/res/values/colors.xml"], "git_node": null, "git_parents": [null], "node": "81f073b87c2a702d38305bfef0d3161e0048a82a", "parents": ["c3e64c4579b503e68b63ff6205ae6da60987d6bc"], "tags": []}, {"author": "Jing-wei Wu \u003ctopwu.tw@gmail.com\u003e", "branch": "default", "desc": "Bug 1405954 - Part 3: Change placeholder colors on URL bar. r=nechen, a=ritu\n\nMozReview-Commit-ID: 1ulc7LS906Q", "files": ["mobile/android/app/src/photon/res/values/colors.xml"], "git_node": null, "git_parents": [null], "node": "f9a13d4d62b64b82555300447695c33036856def", "parents": ["81f073b87c2a702d38305bfef0d3161e0048a82a"], "tags": []}, {"author": "Marina Samuel \u003cmsamuel@mozilla.com\u003e", "branch": "default", "desc": "Bug 1406087 - All PingCentre pings should go to production by default. r=ursula, a=ritu\n\nMozReview-Commit-ID: 9ZmAG9fBWqX", "files": ["browser/modules/PingCentre.jsm"], "git_node": null, "git_parents": [null], "node": "8278598e288cd21d10106e4b7535974b6c0df11e", "parents": ["f9a13d4d62b64b82555300447695c33036856def"], "tags": []}, {"author": "Honza Bambas \u003chonzab.moz@firemni.cz\u003e", "branch": "default", "desc": "Bug 1405199 - Update result principal URI on the new channel when nsBaseChannel redirects. r=bz, a=ritu", "files": ["netwerk/base/nsBaseChannel.cpp"], "git_node": null, "git_parents": [null], "node": "361361c9a042452fdad9c4dbe0343d3d8d7f2065", "parents": ["8278598e288cd21d10106e4b7535974b6c0df11e"], "tags": []}, {"author": "sole \u003cspenades@mozilla.com\u003e", "branch": "default", "desc": "Bug 1391738 - Screenshot with filename fails with unknown error in Linux. r=jwalker, a=ritu\n\nMozReview-Commit-ID: 7XLXyNkL4Le", "files": ["devtools/shared/gcli/commands/screenshot.js"], "git_node": null, "git_parents": [null], "node": "0c7a2975f0a63bb2826b6b556c7bdfc345fddcaf", "parents": ["361361c9a042452fdad9c4dbe0343d3d8d7f2065"], "tags": []}, {"author": "Mike de Boer \u003cmdeboer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397989 - Make sure to only set non-empty values as the content-type of a document in the remote browser binding. r=mconley, a=ritu\n\nWhat happens is the following:\n - browser-child.js sends a statechange up to RemoteWebProgress.jsm that contains\n   a `documentContentType` value of `null`, along with `requestURI` and `originalRequestURI`\n   _after_ other state changes that did send a valid content-type.\n - The content-type is used by the WebProgressListener in browser.js to toggle the\n   disabled state of the 'isImage' broadcaster.\n - The 'isImage' broadcaster is used by the 'cmd_find' and 'cmd_findAgain' commands to\n   determine whether they should be enabled. In this case: not.\nThe fix here is to _not_ set the documentContentType in the browser binding when\nit's `null`.\n\nMozReview-Commit-ID: IELoCrnOH0j", "files": ["toolkit/modules/RemoteWebProgress.jsm"], "git_node": null, "git_parents": [null], "node": "250948dc4a6bd4316f128c089ba43abf3d1e87bf", "parents": ["0c7a2975f0a63bb2826b6b556c7bdfc345fddcaf"], "tags": []}, {"author": "Mike de Boer \u003cmdeboer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403466 - Don't set a max-height on panelviews used by WebExtensions, because it causes browser contents to be cut-off. r=Gijs, a=ritu\n\nSetting a max-height caused the '_handleDOMChange' method in ext-browser-content.js\nto consistently lie about the scrollHeight, since it was never allowed to grow\nbeyond the maxHeight - even when the document needs to be larger to fit its contents.\nWe don't need this aggressiveness in Photon panels anyway, so that makes it\ndoubly safe to remove this code.\n\nMozReview-Commit-ID: HJVMXXHS4By", "files": ["browser/components/extensions/ExtensionPopups.jsm"], "git_node": null, "git_parents": [null], "node": "c609f1155d1633d0a9540fad22e6abec3fe59278", "parents": ["250948dc4a6bd4316f128c089ba43abf3d1e87bf"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1405110 - Part 1: Lock device when allocating D3D11 surface. r=mattwoodrow, a=ritu\n\nMozReview-Commit-ID: 8qWPIj3hdZW", "files": ["gfx/layers/D3D11YCbCrImage.cpp"], "git_node": null, "git_parents": [null], "node": "d0b15c72dfcd7139763f1a6637416153e5028db9", "parents": ["c609f1155d1633d0a9540fad22e6abec3fe59278"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1405110 - Part 2: Never attempts to upload to D3D11 surface in parent process. r=mattwoodrow, a=ritu\n\nAccessing the graphic device driver from the parent process, should the drivers crash have serious consequences (the whole browser dies).\n\nMozReview-Commit-ID: EXXRBnDobQw", "files": ["dom/media/MediaData.cpp"], "git_node": null, "git_parents": [null], "node": "98a72bed57b730ae8d79d151666deafa4e3caa53", "parents": ["d0b15c72dfcd7139763f1a6637416153e5028db9"], "tags": []}], "date": 1507771049, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7951": {"changesets": [{"author": "Jing-wei Wu \u003ctopwu.tw@gmail.com\u003e", "branch": "default", "desc": "Bug 1406828 - Update back/forward icons for RTL on tablet. r=nechen, a=ritu\n\nMozReview-Commit-ID: DidBVCe4h1m", "files": ["mobile/android/app/src/main/res/drawable-ldrtl-large-hdpi/ic_menu_back.png", "mobile/android/app/src/main/res/drawable-ldrtl-large-hdpi/ic_menu_forward.png", "mobile/android/app/src/main/res/drawable-ldrtl-large-xhdpi/ic_menu_back.png", "mobile/android/app/src/main/res/drawable-ldrtl-large-xhdpi/ic_menu_forward.png", "mobile/android/app/src/main/res/drawable-ldrtl-large-xxhdpi/ic_menu_back.png", "mobile/android/app/src/main/res/drawable-ldrtl-large-xxhdpi/ic_menu_forward.png", "mobile/android/app/src/photon/res/drawable-ldrtl-large-hdpi/ic_menu_back.png", "mobile/android/app/src/photon/res/drawable-ldrtl-large-hdpi/ic_menu_forward.png", "mobile/android/app/src/photon/res/drawable-ldrtl-large-xhdpi/ic_menu_back.png", "mobile/android/app/src/photon/res/drawable-ldrtl-large-xhdpi/ic_menu_forward.png", "mobile/android/app/src/photon/res/drawable-ldrtl-large-xxhdpi/ic_menu_back.png", "mobile/android/app/src/photon/res/drawable-ldrtl-large-xxhdpi/ic_menu_forward.png"], "git_node": null, "git_parents": [null], "node": "b619b2660aa85fe3fbab1c73b2087eac3cf5207e", "parents": ["98a72bed57b730ae8d79d151666deafa4e3caa53"], "tags": []}, {"author": "Jing-wei Wu \u003ctopwu.tw@gmail.com\u003e", "branch": "default", "desc": "Bug 1406874 - Show a color indicator for the selected tab strip on tablet. r=nechen, a=ritu\n\nMozReview-Commit-ID: 9vYGxkI9swX", "files": ["mobile/android/app/src/photon/res/layout/tab_strip_item_view.xml", "mobile/android/app/src/photon/res/values-v17/styles.xml", "mobile/android/app/src/photon/res/values/colors.xml", "mobile/android/app/src/photon/res/values/styles.xml", "mobile/android/base/java/org/mozilla/gecko/tabs/TabStripItemView.java"], "git_node": null, "git_parents": [null], "node": "d724d34784dacc9505cfd46a5e906b075d789c9b", "parents": ["b619b2660aa85fe3fbab1c73b2087eac3cf5207e"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1400023 - Switch logins handling to use \"display\" URIs. r=MattN, a=ritu\n\nSince the pref flip in bug 1380617, the default nsUri attributes have been returning punycode for IDN-based domain names, so we need to switch to using the \"display\"-prefixed variants as a simple fix to\n- preserve compatibility with previously stored logins\n- pretty-print unicode domains in the login manager UI instead of showing punycode\n\nThis patch is more or less a straight (DXR-)search and replace and has hopefully caught all relevant instance of nsUri access related to logins.\n\nFor test_disabled_hosts, we're basically reverting bug 1380617, since the login service will now once again return IDN domains in Unicode where allowed.\n\nMozReview-Commit-ID: 5SvW0MuTrGu", "files": ["mobile/android/chrome/content/PermissionsHelper.js", "mobile/android/chrome/content/browser.js", "toolkit/components/passwordmgr/LoginManagerContent.jsm", "toolkit/components/passwordmgr/LoginManagerContextMenu.jsm", "toolkit/components/passwordmgr/nsLoginManager.js", "toolkit/components/passwordmgr/nsLoginManagerPrompter.js", "toolkit/components/passwordmgr/storage-mozStorage.js", "toolkit/components/passwordmgr/test/unit/test_disabled_hosts.js"], "git_node": null, "git_parents": [null], "node": "5118e4f0839cdd2586874ee3eaf56a15618c1575", "parents": ["d724d34784dacc9505cfd46a5e906b075d789c9b"], "tags": []}, {"author": "Ursula Sarracini", "branch": "default", "desc": "Bug 1400562 - BackgroundPageThumbs.captureIfMissing leaks when hidden capturing_disabled pref is true. r=Mardak, a=ritu\n\nMozReview-Commit-ID: 6zb3uBCYTk5", "files": ["toolkit/components/thumbnails/BackgroundPageThumbs.jsm"], "git_node": null, "git_parents": [null], "node": "613890f7fb2f3de95d55d768f3fe3efa797373a7", "parents": ["5118e4f0839cdd2586874ee3eaf56a15618c1575"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1405781 - Don't constrain the width of the overflow panel in customize mode to avoid the scrollbar being placed outside it. r=mikedeboer, a=ritu\n\nMozReview-Commit-ID: GfT7LB9abBR", "files": ["browser/themes/shared/customizableui/panelUI.inc.css"], "git_node": null, "git_parents": [null], "node": "b50526883dd5eeff65e11337c7af100ecd7caf6a", "parents": ["613890f7fb2f3de95d55d768f3fe3efa797373a7"], "tags": []}, {"author": "Jing-wei Wu \u003ctopwu.tw@gmail.com\u003e", "branch": "default", "desc": "Bug 1406338 - Part 1: Support applying specific text size while creating a favicon. r=nechen, a=ritu\n\nMozReview-Commit-ID: Dcx1RgcRdka", "files": ["mobile/android/base/java/org/mozilla/gecko/icons/IconRequest.java", "mobile/android/base/java/org/mozilla/gecko/icons/IconRequestBuilder.java", "mobile/android/base/java/org/mozilla/gecko/icons/loader/IconGenerator.java"], "git_node": null, "git_parents": [null], "node": "cfafb2da1e661170ef34550e237ebaf98cb23f00", "parents": ["b50526883dd5eeff65e11337c7af100ecd7caf6a"], "tags": []}, {"author": "Jing-wei Wu \u003ctopwu.tw@gmail.com\u003e", "branch": "default", "desc": "Bug 1406338 - Part 2: Show favicons in tabs tray page. r=nechen, a=ritu\n\nMozReview-Commit-ID: BXOFuxwI0sl", "files": ["mobile/android/app/src/main/res/layout-large/tabs_layout_item_view.xml", "mobile/android/app/src/main/res/layout/tabs_layout_item_view.xml", "mobile/android/app/src/main/res/layout/tabs_list_item_view.xml", "mobile/android/app/src/photon/res/values-v17/styles.xml", "mobile/android/app/src/photon/res/values/dimens.xml", "mobile/android/app/src/photon/res/values/styles.xml", "mobile/android/base/java/org/mozilla/gecko/tabs/TabsLayoutItemView.java"], "git_node": null, "git_parents": [null], "node": "10ac938d97d5175ed0bc130aeae4a2158bcd5f70", "parents": ["cfafb2da1e661170ef34550e237ebaf98cb23f00"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1407092 - style: Fix ex computation with more than one operand. r=jdm, a=ritu\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: b1926b465671ce56474fc24827eb9562ff7b575b", "files": ["servo/components/style/values/specified/calc.rs"], "git_node": null, "git_parents": [null], "node": "65861c4a6ba487c1c4e8206c4c67ccb6f3037699", "parents": ["10ac938d97d5175ed0bc130aeae4a2158bcd5f70"], "tags": []}, {"author": "Honza Bambas \u003chonzab.moz@firemni.cz\u003e", "branch": "default", "desc": "Bug 1401538 - Drop mTimerScheduledAt at RequestContext::CancelTailedRequest when tail queue is empty. r=kershaw, a=ritu", "files": ["netwerk/base/RequestContextService.cpp"], "git_node": null, "git_parents": [null], "node": "6fcfa157e5b834d167abaf8c7a695bbf3ed16adf", "parents": ["65861c4a6ba487c1c4e8206c4c67ccb6f3037699"], "tags": []}, {"author": "Benjamin Bouvier \u003cbenj@benj.me\u003e", "branch": "default", "desc": "Bug 1406897 - Use JitFrameIter::operator++ in OnlyJSJitFrameIter::settle. r=luke, a=ritu", "files": ["js/src/jit-test/tests/wasm/regress/onlyjsiter-while-wasm.js", "js/src/vm/Stack.h"], "git_node": null, "git_parents": [null], "node": "fc014302c515e1900b5f6cef82f190e30b3e7534", "parents": ["6fcfa157e5b834d167abaf8c7a695bbf3ed16adf"], "tags": []}, {"author": "Rail Aliiev \u003crail@mozilla.com\u003e", "branch": "default", "desc": "Bug 1407279 - Docker image changes on mozilla-beta result in failed decision tasks, Backed out changeset 83fdd1638d8e. r=dustin, a=ritu\n\nMozReview-Commit-ID: LYorA5QSOib", "files": ["taskcluster/taskgraph/util/taskcluster.py"], "git_node": null, "git_parents": [null], "node": "4c2e84704183f3c2c7d8f5d69d20d587ff3fb66c", "parents": ["fc014302c515e1900b5f6cef82f190e30b3e7534"], "tags": []}], "date": 1507773278, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7952": {"changesets": [{"author": "Rail Aliiev \u003crail@mozilla.com\u003e", "branch": "default", "desc": "Bug 1402015 - Submit re-compressed MAR metadata to Balrog r=sfraser a=release\n\nMozReview-Commit-ID: DuJxPBErAhg", "files": ["taskcluster/docker/funsize-balrog-submitter/Dockerfile", "taskcluster/docker/funsize-balrog-submitter/scripts/funsize-balrog-submitter-complete.py", "taskcluster/docker/funsize-balrog-submitter/scripts/funsize-balrog-submitter.py", "taskcluster/docker/funsize-balrog-submitter/submit_complete.sh", "taskcluster/docker/funsize-update-generator/scripts/recompress.py", "testing/mozharness/configs/releases/dev_updates_firefox_beta.py", "testing/mozharness/configs/releases/dev_updates_firefox_release.py", "testing/mozharness/configs/releases/updates_firefox_release.py", "testing/mozharness/scripts/release/publish_balrog.py", "testing/mozharness/scripts/release/updates.py"], "git_node": null, "git_parents": [null], "node": "7e991d4124cd3c10d3b8d87d55eeed8d1b4e522f", "parents": ["4c2e84704183f3c2c7d8f5d69d20d587ff3fb66c"], "tags": []}], "date": 1507774121, "git_changesets": [null], "user": "raliiev@mozilla.com"}, "7953": {"changesets": [{"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1405325 - Rename wdspec cookies test to match command name. r=maja_zf\n\nMozReview-Commit-ID: CYVo0n3mLbB", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/webdriver/tests/cookies/cookies.py", "testing/web-platform/tests/webdriver/tests/cookies/get_named_cookie.py"], "git_node": null, "git_parents": [null], "node": "b15dc7b3b413bcaeb27322688d552aa2f7d93ea8", "parents": ["7e991d4124cd3c10d3b8d87d55eeed8d1b4e522f"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1405325 - Fix webdriver.transport.HTTPWireProtocol#url. r=maja_zf\n\nThe self.path_prefix attribute does not exist.  It should be\nself.url_prefix.\n\nMozReview-Commit-ID: 8LGES8GsTsm", "files": ["testing/web-platform/tests/tools/webdriver/webdriver/transport.py"], "git_node": null, "git_parents": [null], "node": "62b8da6295535e65dac66b18d7654cc4a014c261", "parents": ["b15dc7b3b413bcaeb27322688d552aa2f7d93ea8"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1405325 - Use HTTPWireProtocol#url to build full URL. r=maja_zf\n\nInstead of using string concatentation for building the command URL,\nrely on self.url which internally uses urlparse.urljoin.\n\nMozReview-Commit-ID: DqakZJIgdJF", "files": ["testing/web-platform/tests/tools/webdriver/webdriver/transport.py"], "git_node": null, "git_parents": [null], "node": "b817f99334fa42aa949d0c2da4a76bafb881dd4d", "parents": ["62b8da6295535e65dac66b18d7654cc4a014c261"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1405325 - Assign actual response to variable. r=maja_zf\n\nThis is a non-functional change, but if anything should be assigned\nto the \"response\" value, it should be the actual response.  I had\nto do this because I was debugging a low-level HTTP problem with\ngeckodriver, so this will be more useful in the future.  In any case,\nwe can return the webdriver.transport.Response representation directly\nbecause the finally clause is always called.\n\nMozReview-Commit-ID: 8JKNKAEbOAe", "files": ["testing/web-platform/tests/tools/webdriver/webdriver/transport.py"], "git_node": null, "git_parents": [null], "node": "d06884758cb64b0226a0811fda273ff41f35ae51", "parents": ["b817f99334fa42aa949d0c2da4a76bafb881dd4d"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1405325 - Correct HTTPWireProtocol#send documentation. r=maja_zf\n\nMozReview-Commit-ID: 3ZfXYHOaKRC", "files": ["testing/web-platform/tests/tools/webdriver/webdriver/transport.py"], "git_node": null, "git_parents": [null], "node": "bd809f9f27e00566e114900b6d057f87733b352a", "parents": ["d06884758cb64b0226a0811fda273ff41f35ae51"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1405325 - Align WebDriver:DeleteCookie with specification. r=maja_zf, a=test-only\n\nThe Delete Cookie command should not return an error if the cookie\ndoes not exist.\n\nThe variable names \"toDelete\" and \"candidateName\" was also\njuxtapositioned and wrong.  Here I am using the approximate names\nused in the specification prose for clarity.\n\nFixes: https://github.com/mozilla/geckodriver/issues/989\nMozReview-Commit-ID: 6IIGGpB1JWn", "files": ["testing/marionette/driver.js", "testing/web-platform/meta/MANIFEST.json", "testing/web-platform/meta/webdriver/tests/cookies/delete_cookie.py.ini", "testing/web-platform/tests/webdriver/tests/cookies/delete_cookie.py"], "git_node": null, "git_parents": [null], "node": "9a13140630882d966dc1e41f23d6540d54afcc6a", "parents": ["bd809f9f27e00566e114900b6d057f87733b352a"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1405018 - Move Get Active Element test to the tests directory. r=maja_zf\n\nMozReview-Commit-ID: KoblLlmFein", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/meta/webdriver/elements/active.py.ini", "testing/web-platform/meta/webdriver/tests/element_retrieval/get_active_element.py.ini", "testing/web-platform/tests/webdriver/elements/active.py", "testing/web-platform/tests/webdriver/tests/element_retrieval/get_active_element.py"], "git_node": null, "git_parents": [null], "node": "fdcd4aa54eae1f7d699a12ff441c9e2ebaf99d76", "parents": ["9a13140630882d966dc1e41f23d6540d54afcc6a"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1405018 - Add support helper for generating inline \u003ciframe\u003e elements. r=whimboo\n\nMozReview-Commit-ID: FSs7haU0a5z", "files": ["testing/web-platform/tests/webdriver/tests/support/inline.py"], "git_node": null, "git_parents": [null], "node": "e287f4cad6d4b3a3584b26526b6fa2018875efd5", "parents": ["fdcd4aa54eae1f7d699a12ff441c9e2ebaf99d76"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1405018 - Consider current browsing context on staleness check. r=whimboo\n\nThe element.isStale function does not take into account the current\nbrowsing context when checking an element\u2019s staleness.  This means,\nfor example, that an element in an \u003ciframe\u003e that gets retrieved, will\nstill be considered valid for as long as its associated document lives.\n\nIn WebDriver the expected behaviour is for the element reference to\nonly be valid for the current browsing context, meaning retrieving\nthe element reference when another browsing context is chosen should\nreturn a stale element error.\n\nFixes: https://github.com/mozilla/geckodriver/issues/934\nMozReview-Commit-ID: JpQVt78u5AN", "files": ["testing/marionette/action.js", "testing/marionette/element.js", "testing/marionette/evaluate.js", "testing/marionette/listener.js"], "git_node": null, "git_parents": [null], "node": "5d8a54db7749d6371ad772857e01a59f69e9f430", "parents": ["e287f4cad6d4b3a3584b26526b6fa2018875efd5"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1405018 - Add test for stale frame element. r=maja_zf, a=test-only\n\nThe \u003cp\u003e element inside the \u003ciframe\u003e should be considered stale when\ninteracting with it after the current browsing context is switched\nback to the top level browsing context.\n\nMozReview-Commit-ID: 1zrnBowSpxt", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/webdriver/tests/switch_to_parent_frame.py"], "git_node": null, "git_parents": [null], "node": "39d11cbd38ebc6f4a6d9a58dd80ccec094944cf8", "parents": ["5d8a54db7749d6371ad772857e01a59f69e9f430"], "tags": []}, {"author": "Lars T Hansen \u003clhansen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1361526 - Merge from upstream test262 to kill intermittents. r=me, a=test-only", "files": ["js/src/tests/test262/built-ins/Atomics/wait/did-timeout.js", "js/src/tests/test262/built-ins/Atomics/wait/no-spurious-wakeup.js"], "git_node": null, "git_parents": [null], "node": "10279b6ebdf8f0547d786ceda1f5e5d368991f6c", "parents": ["39d11cbd38ebc6f4a6d9a58dd80ccec094944cf8"], "tags": []}, {"author": "Jeremy Chen \u003cjeremychen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403077 - Part 1: Implement the stylo blocklist mechanism. r=heycam, a=ritu\n\nIn this patch, we read the stylo blocklist into nsLayoutUtils's global static\nvariable during nsLayoutUtils::Initialize(). So, we can decide if we should\nfallback to use Gecko backend while updating style backend for a document.\n\nWe add \"layout.css.stylo-blocklist.blocked_domains\" and\n\"layout.css.stylo-blocklist.enabled\" to ContentPrefs.cpp because they are read\nvery early (during nsLayoutUtils::Initialize).\n\nMozReview-Commit-ID: IiTVf6qD9uO", "files": ["dom/base/nsDocument.cpp", "dom/ipc/ContentPrefs.cpp", "layout/base/nsLayoutUtils.cpp", "layout/base/nsLayoutUtils.h", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "c2c10508ec8d9e50eba1db0137d4509fe7d9af19", "parents": ["10279b6ebdf8f0547d786ceda1f5e5d368991f6c"], "tags": []}, {"author": "Jeremy Chen \u003cjeremychen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403077 - Part 2: Add two test-only helper functions to access the stylo blocklist. r=heycam, a=ritu\n\nIn the current blocklist implementation, we read the stylo blocklist from the user\npreferences very early and only once, even earlier than the test preferences\nupdating happens.\n\nSo, to be able to test the functionality of the stylo blocklist, we add these two\nnsIDOMWindowUtils APIs to be able to add/remove a mock domain to the existing\nblocklist.\n\nMozReview-Commit-ID: 1iRnGmyTJgC", "files": ["dom/base/nsDOMWindowUtils.cpp", "dom/interfaces/base/nsIDOMWindowUtils.idl", "layout/base/nsLayoutUtils.cpp", "layout/base/nsLayoutUtils.h"], "git_node": null, "git_parents": [null], "node": "1059f19c81364d89cbdfedcacf50e06998d87e7d", "parents": ["c2c10508ec8d9e50eba1db0137d4509fe7d9af19"], "tags": []}, {"author": "Jeremy Chen \u003cjeremychen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403077 - Part 3: Add tests for the stylo blocklist mechanism. r=heycam, a=ritu\n\nIn this patch, we add 3 tests:\n1. test for blocked domain\n2. test for blocked sub-domain\n3. test for non-blocked domain\n\nMozReview-Commit-ID: 54DDxE77Yif", "files": ["build/pgo/server-locations.txt", "layout/style/test/mochitest.ini", "layout/style/test/stylo_blocked_domain_page.html", "layout/style/test/stylo_non_blocked_domain_page.html", "layout/style/test/test_stylo_blocklist-01.html", "layout/style/test/test_stylo_blocklist-02.html", "layout/style/test/test_stylo_blocklist-03.html"], "git_node": null, "git_parents": [null], "node": "f4ba99b411837e4b16b134cbab5bcc355ddd6b22", "parents": ["1059f19c81364d89cbdfedcacf50e06998d87e7d"], "tags": []}], "date": 1507817158, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7954": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nbe -\u003e df0b372401c2\ncs -\u003e 0b92624cf4ca\nka -\u003e 4aa3e34c771b\nms -\u003e b0ed4d408f69\nne-NP -\u003e a2c5e0083f7a\npl -\u003e e6a7bcadb0dd\npt-BR -\u003e 5fc531c24b4d\nzh-CN -\u003e ddd7aebff4d1", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "8eb20bcd4198231facd775b7e0f7d1c8026eb549", "parents": ["f4ba99b411837e4b16b134cbab5bcc355ddd6b22"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nan -\u003e 4b1d38428418\nar -\u003e a9b077bf5a1f\nbe -\u003e df0b372401c2\nbg -\u003e b357c79f1a84\ncs -\u003e 0b92624cf4ca\ngu-IN -\u003e e73a466adc58\nka -\u003e 4aa3e34c771b\nkab -\u003e 64bda4e12f9a\nms -\u003e b0ed4d408f69\nnl -\u003e b172610d06ee\npl -\u003e e6a7bcadb0dd\npt-BR -\u003e 5fc531c24b4d\npt-PT -\u003e 4018175fdd6d\nzh-CN -\u003e ddd7aebff4d1", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "91de7a930a6867b48a00d8850b5589a0d5a074b1", "parents": ["8eb20bcd4198231facd775b7e0f7d1c8026eb549"], "tags": []}], "date": 1507825345, "git_changesets": [null, null], "user": "ffxbld"}, "7955": {"changesets": [{"author": "Haik Aftandilian \u003chaftandilian@mozilla.com\u003e", "branch": "default", "desc": "Bug 1393805 - Part 1: Add XRE_USER_SYS_EXTENSION_DEV_DIR XRESysExtDev Key. r=bobowen, r=gcp, a=ritu\n\nAdds a new directory provider key \"XRESysExtDev\" to be used by system extension\ndevelopers needing to load system extensions from a directory readable by\nsandboxed content processes.\n\nMozReview-Commit-ID: 4BKOZoPzCC3", "files": ["toolkit/xre/nsXREDirProvider.cpp", "toolkit/xre/nsXREDirProvider.h", "xpcom/build/nsXULAppAPI.h"], "git_node": null, "git_parents": [null], "node": "2e90942f919ff5f62d869c2ee21f7d08fdcf8e54", "parents": ["91de7a930a6867b48a00d8850b5589a0d5a074b1"], "tags": []}, {"author": "Haik Aftandilian \u003chaftandilian@mozilla.com\u003e", "branch": "default", "desc": "Bug 1393805 - Part 2: Add Mac whitelisted directory for system extensions development. r=Alex_Gaynor, a=ritu\n\nMozReview-Commit-ID: ADkcqFAsKaY", "files": ["security/sandbox/mac/SandboxPolicies.h"], "git_node": null, "git_parents": [null], "node": "895ccb3cf6595306459f7a3c022455df353b6aef", "parents": ["2e90942f919ff5f62d869c2ee21f7d08fdcf8e54"], "tags": []}, {"author": "Haik Aftandilian \u003chaftandilian@mozilla.com\u003e", "branch": "default", "desc": "Bug 1393805 - Part 3: Add Windows whitelisted directory for system extensions development. r=bobowen, a=ritu\n\nMozReview-Commit-ID: 8K5c3mUlqna", "files": ["security/sandbox/win/src/sandboxbroker/sandboxBroker.cpp"], "git_node": null, "git_parents": [null], "node": "6c62f6086493e250e6f77a466192a769724e352b", "parents": ["895ccb3cf6595306459f7a3c022455df353b6aef"], "tags": []}, {"author": "Haik Aftandilian \u003chaftandilian@mozilla.com\u003e", "bra