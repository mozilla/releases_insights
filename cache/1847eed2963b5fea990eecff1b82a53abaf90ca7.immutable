ll], "node": "978e6322ec4c1c38e1d4eaf04ca0490bc5a427ee", "parents": ["f24a44f212b067dbf36366d0bbad292b8a75a08d"], "tags": []}, {"author": "Oriol Brufau \u003coriol-bugzilla@hotmail.com\u003e", "branch": "default", "desc": "Bug 1400297 - Increase color contrast for JSON Viewer and Netmonitor headers. r=Honza, a=ritu\n\nMozReview-Commit-ID: DmdzPesJEo", "files": ["devtools/client/jsonview/css/headers-panel.css", "devtools/client/netmonitor/src/assets/styles/netmonitor.css"], "git_node": null, "git_parents": [null], "node": "4905b457c84c9184ef9866228c1c36419680d0e5", "parents": ["978e6322ec4c1c38e1d4eaf04ca0490bc5a427ee"], "tags": []}, {"author": "Thom Chiovoloni \u003ctchiovoloni@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403052 - Limit tab sync max_record_payload_size to 512k. r=markh, a=ritu\n\nAlso fixes an issue where we wouldn't encode to utf8 when comparing the actual\nsize to the limit after the first time.\n\nMozReview-Commit-ID: Cf3byjI1FTZ", "files": ["services/sync/modules/engines/tabs.js", "services/sync/tests/unit/test_tab_store.js"], "git_node": null, "git_parents": [null], "node": "68551d5aa88beafd80d5d96aa524883d889bea4f", "parents": ["4905b457c84c9184ef9866228c1c36419680d0e5"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1404497 - Don't hide the post-tabs titlebar placeholder in maximized windows. r=dao, a=ritu\n\nMozReview-Commit-ID: 39x18t1GBRP", "files": ["browser/base/content/browser.css"], "git_node": null, "git_parents": [null], "node": "da520dfb9456bcda3e3b7098d5eee5e733f2c020", "parents": ["68551d5aa88beafd80d5d96aa524883d889bea4f"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1404674 - Clicking the home button should focus the content area. r=florian, a=ritu\n\nMozReview-Commit-ID: GZlXyVuUbix", "files": ["browser/base/content/browser.js"], "git_node": null, "git_parents": [null], "node": "29c2c1ade870f5da5f8767a285e668eb98b454ba", "parents": ["da520dfb9456bcda3e3b7098d5eee5e733f2c020"], "tags": []}, {"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1402272 - Replace adjustSiteIconStart with padding on all richlistitems. r=mak, a=ritu\n\nMozReview-Commit-ID: 8JyJWLL0nJU", "files": ["browser/base/content/test/performance/browser_urlbar_keyed_search_reflows.js", "browser/base/content/test/performance/browser_urlbar_search_reflows.js", "browser/base/content/urlbarBindings.xml", "browser/extensions/formautofill/content/formautofill.xml", "browser/themes/shared/urlbar-autocomplete.inc.css", "toolkit/content/widgets/autocomplete.xml", "toolkit/themes/linux/global/autocomplete.css", "toolkit/themes/osx/global/autocomplete.css", "toolkit/themes/windows/global/autocomplete.css"], "git_node": null, "git_parents": [null], "node": "1dd75dca0442c5c0a27b8eb3225af70ecd5e3545", "parents": ["29c2c1ade870f5da5f8767a285e668eb98b454ba"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1403755 - Rm code to insert blanks into top sites. r=liuche, a=ritu\n\nThis code was being mistakenly activated when getting top sites for Activity\nStream.\n\nThis is the first removal of old top sites code and will mean we can't go back\nto old top sites by flipping the `ActivityStream.isEnabled` flag. Since we're\nplanning to ship AS, this shouldn't matter.\n\n\nMozReview-Commit-ID: 9VB0RqNHmE0", "files": ["mobile/android/base/java/org/mozilla/gecko/activitystream/ActivityStream.java", "mobile/android/base/java/org/mozilla/gecko/db/BrowserProvider.java"], "git_node": null, "git_parents": [null], "node": "ca0a6d284f987bb238be5a45bc28ac27773ab677", "parents": ["1dd75dca0442c5c0a27b8eb3225af70ecd5e3545"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1405009 - Show a critters postcard when searching for firefox-emoji. r=mconley, a=ritu\n\nThis patch doesn't perform any transitions or animations on the postcard. Those could be handled in a follow-up, though I tried to implement it transitioning background-size but that isn't possible using 'contain' (or any keywords for that matter).\n\nMozReview-Commit-ID: 4fpGaLK3oFK", "files": ["browser/components/preferences/in-content/findInPage.js", "browser/components/preferences/in-content/searchResults.xul", "browser/themes/shared/incontentprefs/critters-postcard.png", "browser/themes/shared/incontentprefs/preferences.inc.css", "browser/themes/shared/jar.inc.mn"], "git_node": null, "git_parents": [null], "node": "701860612ef43c21cedc713ce604e67ba05d8296", "parents": ["ca0a6d284f987bb238be5a45bc28ac27773ab677"], "tags": []}, {"author": "Ricky Chien \u003cricky060709@gmail.com\u003e", "branch": "default", "desc": "Bug 1393415 - Highlight help icon in high contrast theme. r=jaws, a=ritu\n\nMozReview-Commit-ID: ByEZKJzhIUM", "files": ["browser/components/preferences/in-content/preferences.xul", "browser/themes/shared/incontentprefs/preferences.inc.css", "toolkit/themes/shared/in-content/common.inc.css"], "git_node": null, "git_parents": [null], "node": "ecf9a5a692354b23e9d5d5fa1e607b8bbac207ed", "parents": ["701860612ef43c21cedc713ce604e67ba05d8296"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1405377 - Remove trailing separator in recently closed tabs/windows subviews. r=mikedeboer, a=ritu\n\nThe third param of 'getTabsFragment' and 'getWindowsFragment' toggles whether the 'restore all' item\ngets prefixed (true) or suffixed (false). The prefixed version doesn't get a separator, so this\nseems like the simplest fix.\n\nMozReview-Commit-ID: BzKWvndWUMp", "files": ["browser/components/customizableui/CustomizableWidgets.jsm"], "git_node": null, "git_parents": [null], "node": "3d3e597d3b96eca3163c70ff0d2a263e2d7e9cf5", "parents": ["ecf9a5a692354b23e9d5d5fa1e607b8bbac207ed"], "tags": []}], "date": 15