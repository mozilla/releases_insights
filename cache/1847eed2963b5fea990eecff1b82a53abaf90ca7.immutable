t since it doesn't need to access .anonymous-div anymore. r=Gijs\n\nMozReview-Commit-ID: 5qutEsTojVt", "files": ["browser/base/content/browser.css", "browser/base/content/urlbarBindings.xml", "layout/style/res/forms.css"], "git_node": null, "git_parents": [null], "node": "753a7798aae8b33ac4d09ee1eb63c140ee5d257b", "parents": ["43bf2195c59018db339183cab5e1b28a542c343e"], "tags": []}, {"author": "FSeita \u003cfranckseita@googlemail.com\u003e", "branch": "default", "desc": "Bug 1376333 - Improve naming of accumulation types & variables r=Dexter\n\nMozReview-Commit-ID: F9w7CLUOP6r", "files": ["dom/ipc/ContentParent.cpp", "dom/ipc/ContentParent.h", "dom/ipc/PContent.ipdl", "gfx/ipc/GPUChild.cpp", "gfx/ipc/GPUChild.h", "gfx/ipc/PGPU.ipdl", "toolkit/components/telemetry/Telemetry.h", "toolkit/components/telemetry/TelemetryHistogram.cpp", "toolkit/components/telemetry/TelemetryHistogram.h", "toolkit/components/telemetry/ipc/TelemetryComms.h", "toolkit/components/telemetry/ipc/TelemetryIPC.cpp", "toolkit/components/telemetry/ipc/TelemetryIPC.h", "toolkit/components/telemetry/ipc/TelemetryIPCAccumulator.cpp"], "git_node": null, "git_parents": [null], "node": "d196551463abb98db706e1dcca29b400792a7f50", "parents": ["753a7798aae8b33ac4d09ee1eb63c140ee5d257b"], "tags": []}, {"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1387582 - Add toolbar_text color property to theming API. r=dao,mikedeboer\n\nMozReview-Commit-ID: KjKVjFD4axN", "files": ["browser/themes/linux/browser.css", "browser/themes/osx/browser.css", "browser/themes/shared/tabs.inc.css", "browser/themes/windows/browser.css", "toolkit/components/extensions/ext-theme.js", "toolkit/components/extensions/schemas/theme.json", "toolkit/components/extensions/test/browser/browser_ext_themes_toolbars.js", "toolkit/modules/LightweightThemeConsumer.jsm"], "git_node": null, "git_parents": [null], "node": "7bda9cc7b79882ff5986a1e6192f64fe2aca1bb5", "parents": ["d196551463abb98db706e1dcca29b400792a7f50"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399460 - Release: Update reps bundle to 0.13.0. r=nchevobbe\n\nAll the changes here were already reviewed in Github.\n\nMozReview-Commit-ID: GmQ3BOFIXPh", "files": ["devtools/client/shared/components/reps/reps.css", "devtools/client/shared/components/reps/reps.js"], "git_node": null, "git_parents": [null], "node": "e843a11f6fde1526554af64f36c9df0d77eb1fad", "parents": ["7bda9cc7b79882ff5986a1e6192f64fe2aca1bb5"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399460 - Adapt the console to the new Reps bundle. r=Honza.\n\nThis is mainly changing the props we pass to the ObjectInspector,\nand removing actions, state properties and reducers that we used to\nhandle in the console but are now managed by the ObjectInspector\nitself.\n\nMozReview-Commit-ID: F2GabDqDjPe", "files": ["devtools/client/webconsole/new-console-output/actions/messages.js", "devtools/client/webconsole/new-console-output/components/console-output.js", "devtools/client/webconsole/new-console-output/components/console-table.js", "devtools/client/webconsole/new-console-output/components/grip-message-body.js", "devtools/client/webconsole/new-console-output/components/message-container.js", "devtools/client/webconsole/new-console-output/components/message-types/console-api-call.js", "devtools/client/webconsole/new-console-output/components/message-types/evaluation-result.js", "devtools/client/webconsole/new-console-output/constants.js", "devtools/client/webconsole/new-console-output/new-console-output-wrapper.js", "devtools/client/webconsole/new-console-output/reducers/messages.js", "devtools/client/webconsole/new-console-output/selectors/messages.js", "devtools/client/webconsole/new-console-output/test/fixtures/serviceContainer.js", "devtools/client/webconsole/new-console-output/test/store/messages.test.js", "devtools/client/webconsole/new-console-output/test/store/release-actors.test.js"], "git_node": null, "git_parents": [null], "node": "0f78304723803b6debe7f5cfacf5ad4cd45390d6", "parents": ["e843a11f6fde1526554af64f36c9df0d77eb1fad"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399460 - Fix browser_ext_devtools_inspectedWindow_eval_bindings.js failure. r=rpl\n\nThe bug was failing because we were calling the server but the connection was already closed.\nIn order to prevent such things, we check the number of nodes of the tree, and if it has only\none, then we wait on a mutation that will ensure that server calls are done.\n\nMozReview-Commit-ID: 7kHAkYs2I4K", "files": ["browser/components/extensions/test/browser/browser_ext_devtools_inspectedWindow_eval_bindings.js"], "git_node": null, "git_parents": [null], "node": "e7d1f0e04aaef260f2acd9f998eacf245ea2c363", "parents": ["0f78304723803b6debe7f5cfacf5ad4cd45390d6"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399460 - Fix for browser_webconsole_check_stubs_console_api. r=Honza\n\nThe test that checked console api stubs was failing because we were trying\nto reach the server while the connection was closed, which throws an error.\nThis patch filters-out log messages in the console output so we don't get\nunwanted server communication. The output is not important here since we\nare only listening to the consoleAPICall event.\n\nMozReview-Commit-ID: Ay5fQ1CSbLx", "files": ["devtools/client/webconsole/new-console-output/test/fixtures/stub-generators/head.js"], "git_node": null, "git_parents": [null], "node": "8b0058e2a4a8a123e09470b7ee975963be88a158", "parents": ["e7d1f0e04aaef260f2acd9f998eacf245ea2c363"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400232 - Hide the menu button separator in compact mode. r=johannh\n\nMozReview-Commit-ID: CKuXX6QZ3W5", "files": ["browser/themes/shared/customizableui/panelUI.inc.css"], "git_node": null, "git_parents": [null], "node": "9253681974414228318eacfdcaafdaae333855bb", "parents": ["8b0058e2a4a8a123e09470b7ee975963be88a158"], "tags": []}, {"author": "abhinav \u003cabhinav.koppula@gmail.com\u003e", "branch": "default", "desc": "Bug 1347833 - Add support to wrap long request parameters/cookies in the netmonitor sidebar. r=Honza\n\nMozReview-Commit-ID: LYQvQzxRC5G", "files": ["devtools/client/netmonitor/src/assets/styles/netmonitor.css", "devtools/client/netmonitor/src/components/properties-view.js"], "git_node": null, "git_parents": [null], "node": "a71dd9ce8a166bf5781ecbc53ead54bd50f4f8f2", "parents": ["9253681974414228318eacfdcaafdaae333855bb"], "tags": []}, {"author": "Mike de Boer \u003cmdeboer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1354536 - Part 1 - Introduce a string for the 'Recent Highlights' section soon the be added to the Library view. r=Gijs\n\nMozReview-Commit-ID: J1tcBxspjuI", "files": ["browser/locales/en-US/chrome/browser/browser.dtd"], "git_node": null, "git_parents": [null], "node": "16edc2f1ada8f6f22ae8c36dda417522ac4fa25c", "parents": ["46f0b004bdd23afdf5201fc7801e81897cb7c349"], "tags": []}, {"author": "J.C. Jones \u003cjjones@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400080 - Remove impossible telemetry test from WebAuthn r=ttaubert\n\nNow that there are actual hardware devices, this test can't be run: it\ndepended on there being a deliberately-erroring implementation of WebAuthn\nwhich would instantly reject promises. Fortunately, this test was really more\na test that telemetry scalars work properly than really the functionality\nof WebAuthn.\n\nSadly, I don't see any way to re-enable this test without adding a new test-\nonly pref to the tree, which doesn't seem worth it for the telemetry.\n\nSo this patch removes the offending test completely which was backed out in\nhttps://hg.mozilla.org/integration/mozilla-inbound/rev/c115eec567a6 .\n\nMozReview-Commit-ID: LiLuQHbPU1z", "files": ["dom/webauthn/tests/browser/browser_webauthn_telemetry.js"], "git_node": null, "git_parents": [null], "node": "0aed7d43efe295f6086cb3d1cb96326da5c2ebac", "parents": ["16edc2f1ada8f6f22ae8c36dda417522ac4fa25c"], "tags": []}, {"author": "J.C. Jones \u003cjjones@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400066 - Gracefully handle unsupported platforms for U2F HID support r=ttaubert\n\nFreeBSD isn't currently support for FIDO U2F support, similar to Android, so\nthis patch [1] from Jan Beich \u003cjbeich@FreeBSD.org\u003e treats Android and FreeBSD\nthe same. With luck, someone will add in the platform support for both, soon!\n\n[1] https://github.com/jcjones/u2f-hid-rs/pull/44\n\nMozReview-Commit-ID: DU7Rco2NLb3", "files": ["dom/webauthn/u2f-hid-rs/src/android/mod.rs", "dom/webauthn/u2f-hid-rs/src/lib.rs", "dom/webauthn/u2f-hid-rs/src/stub/mod.rs"], "git_node": null, "git_parents": [null], "node": "07b93c7fec6c83f53a3bdce9becbb13f0fc397e5", "parents": ["0aed7d43efe295f6086cb3d1cb96326da5c2ebac"], "tags": []}, {"author": "Gabriele Svelto \u003cgsvelto@mozilla.com\u003e", "branch": "default", "desc": "Bug 1393716 - Don't run minidump analysis on content crashes if the browser is quitting r=ted.mielczarek\n\nWhen a content crash is detected we run the minidump analyzer on it to extract\na stack trace that will be sent with the crash ping. Since this operation can\npotentially take a long time this patch prevents it from happening if the\nbrowser is already quitting. Already running instances of the minidump\nanalyzer are also killed. The patch includes test coverage for both the new\ncodepaths.\n\nMozReview-Commit-ID: 4CQBp0v5KxE", "files": ["toolkit/components/crashes/CrashService.js", "toolkit/components/crashes/tests/xpcshell/test_crash_service.js"], "git_node": null, "git_parents": [null], "node": "d1a21fb93a04f252365cfb02b32535cc7665eadd", "parents": ["07b93c7fec6c83f53a3bdce9becbb13f0fc397e5"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "merge mozilla-central to mozilla-inbound. r=merge a=merge", "files": ["browser/base/content/test/about/browser_aboutHome.js", "browser/extensions/activity-stream/data/content/assets/glyph-search-16.svg", "browser/extensions/activity-stream/data/content/assets/glyph-settings-16.svg", "dom/media/gtest/TestTrackEncoder.cpp", "third_party/rust/arraydeque/.cargo-checksum.json", "third_party/rust/arraydeque/.cargo-ok", "third_party/rust/arraydeque/.travis.yml", "third_party/rust/arraydeque/Cargo.toml", "third_party/rust/arraydeque/LICENSE", "third_party/rust/arraydeque/README.md", "third_party/rust/arraydeque/src/array.rs", "third_party/rust/arraydeque/src/lib.rs"], "git_node": null, "git_parents": [null, null], "node": "c4a244ec50df3b2fe64dad024275a9789ef113d0", "parents": ["d1a21fb93a04f252365cfb02b32535cc7665eadd", "893fe1549e1e7342a66514b65960f08d40810a34"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399933 - Replace use of ObjectValueCrashOnTouch with PoisonedObjectValue r=sfink", "files": ["js/public/Value.h", "js/src/jsapi-tests/testGCStoreBufferRemoval.cpp", "js/src/jsutil.h", "js/src/vm/NativeObject.h"], "git_node": null, "git_parents": [null], "node": "5c1007b062e3a2b3d2571983603ccc67a144f8b6", "parents": ["c4a244ec50df3b2fe64dad024275a9789ef113d0"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399928 - RegExpShared::source should be a GCPtr r=sfink", "files": ["js/src/vm/RegExpShared.h"], "git_node": null, "git_parents": [null], "node": "53d445528ef226c188bc39bee82dd4cefd1940d4", "parents": ["5c1007b062e3a2b3d2571983603ccc67a144f8b6"], "tags": []}, {"author": "Christoph Kerschbaumer \u003cckerschb@christophkerschbaumer.com\u003e", "branch": "default", "desc": "Bug 1399848 - Update failing windows tests within dom/browser-element to comply with new toplevel data: URI navigation policy. r=smaug", "files": ["dom/browser-element/mochitest/browserElement_PromptCheck.js", "dom/browser-element/mochitest/browserElement_PromptConfirm.js", "dom/browser-element/mochitest/browserElement_RemoveBrowserElement.js", "dom/browser-element/mochitest/browserElement_ScrollEvent.js", "dom/browser-element/mochitest/browserElement_Titlechange.js"], "git_node": null, "git_parents": [null], "node": "6487b7e332d64d438976a19030bb94e639480391", "parents": ["53d445528ef226c188bc39bee82dd4cefd1940d4"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1387937 - Part 1. Import changeset 40324. r=jfkthame\n\nMozReview-Commit-ID: 86oFSd6ifc7", "files": ["intl/icu/source/i18n/zonemeta.cpp"], "git_node": null, "git_parents": [null], "node": "a9bf7b6cf6d4ed4f467e261d771281498b626cc6", "parents": ["6487b7e332d64d438976a19030bb94e639480391"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1387937 - Part 2. Add patch file. r=jfkthame\n\nMozReview-Commit-ID: Ej5YLm9dz57", "files": ["intl/icu-patches/bug-1387937.diff", "intl/update-icu.sh"], "git_node": null, "git_parents": [null], "node": "92c830b99fe97c2970f0a58ecef8c8d8b6a2fa85", "parents": ["a9bf7b6cf6d4ed4f467e261d771281498b626cc6"], "tags": []}, {"author": "Stone Shih \u003csshih@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399876: Relax the assertion about sending multiple eMouseEnterIntoWidget in TabParent. r=baku.\n\nWe may create a browser element and replace it while the TabChild isn't ready to handle input events.", "files": ["dom/ipc/TabParent.cpp"], "git_node": null, "git_parents": [null], "node": "d26e31b70dae473c5a13804b5c761b10765251a1", "parents": ["92c830b99fe97c2970f0a58ecef8c8d8b6a2fa85"], "tags": []}, {"author": "Nicolas Silva \u003cnsilva@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397407 - Apply deferred image key deletions to the next transaction. r=Gankro", "files": ["gfx/layers/wr/WebRenderLayerManager.cpp"], "git_node": null, "git_parents": [null], "node": "70f5f23a429f3d621e44307c191fa84c77fb2f61", "parents": ["d26e31b70dae473c5a13804b5c761b10765251a1"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397823 - part 1 - move work into _generateMessageConstructor; r=kanru\n\n_generateMessageConstructor takes a lot of `md.FOO`-style parameters,\nwhich could be derived inside the function by simply passing `md`.\nEspecially with the upcoming changes to calculate things like reply-ness\nof messages, sync-ness, etc, we'd be wanting to pass even more\nparameters like `md.FOO`.  So let's just pass `md` in, and then we can\nmake all the necessary future changes in a single place.", "files": ["ipc/ipdl/ipdl/lower.py"], "git_node": null, "git_parents": [null], "node": "1607f6d53f5273361ce35e47f94d3966c26611c6", "parents": ["70f5f23a429f3d621e44307c191fa84c77fb2f61"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397823 - part 2 - tidy _generateMessageConstructor enums a little; r=kanru\n\nThere's no need to be repeating 'IPC::Message::' prefixes or spreading\naround more ExprVar calls than we need here.  Let's try to improve the\nsignal-to-noise ratio of this code by introducing a helper function to\ninject some of the boilerplate for us.", "files": ["ipc/ipdl/ipdl/lower.py"], "git_node": null, "git_parents": [null], "node": "6e7da31ab0b11eb3b4f2e372b350652b8b3e3597", "parents": ["1607f6d53f5273361ce35e47f94d3966c26611c6"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397823 - part 3 - do a better job setting IPC::Message flags; r=kanru\n\nThe current IPC::Message constructor takes a large number of arguments,\nthree of which--the nesting level, the priority, and the\ncompression--are almost always constant by virtue of the vast majority\nof Message construction being done by auto-generated IPDL code.  But\nthen we take these constant values into the Message constructor, we\ncheck them for various values, and then based on those values, we\nperform a bunch of bitfield operations to store flags based on those\nvalues.  This is wasted work.\n\nFurthermore, for replies to IPDL messages, we'll construct a Message\nobject, and then call mutating setters on the Message object that will\nperform even more bitfield manipulations.  Again, these operations are\nperforming tasks at runtime that are the same every single time, and use\ninformation we already have at compile time.\n\nThe impact of these extra operations is not large, maybe 15-30K of extra\ncode, depending on platform.  Nonetheless, we can easily make them go\naway, and make everything cleaner to boot.\n\nThis patch adds a HeaderFlags class that encapsulates all the knowledge\nabout the various kinds of flags Message needs to know about.  We can\nconstruct HeaderFlags objects with strongly-typed enum arguments for the\nvarious kinds of flags, and the compiler can take care of folding all of\nthose flags together into a constant when possible (and it is possible\nfor all the IPDL-generated code that instantiates Messages).  The upshot\nis that we do no unnecessary work in the Message constructor itself.  We\ncan also remove various mutating operations on Message, as those\noperations were only there to support post-constructor flag twiddling,\nwhich is no longer necessary.", "files": ["ipc/chromium/src/chrome/common/ipc_message.cc", "ipc/chromium/src/chrome/common/ipc_message.h", "ipc/glue/MessageChannel.cpp", "ipc/glue/ProtocolUtils.cpp", "ipc/glue/Shmem.cpp", "ipc/ipdl/ipdl/lower.py"], "git_node": null, "git_parents": [null], "node": "14acffc2e1eca99806bda3099cdf12938772cd52", "parents": ["6e7da31ab0b11eb3b4f2e372b350652b8b3e3597"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397823 - part 4 - reduce codesize for IPDL IPC::Message creation; r=kanru\n\nEach protocol in IPDL has a bunch of autogenerated functions that\ninstantiate IPC::Message with various parameters.  Each of these\nfunctions, then:\n\n1) Pays the cost of calling malloc()\n2) Setting up various parameters\n3) Calling IPC::Message()\n\nThere's no reason that we should be duplicating 1) across all of these\nautogenerated functions.  In step 2), several of the parameters we're\nsetting up are common across all or nearly all calls: the message\nsegment size is almost always zero, and we're always indicating that\nIPDL-generated messages should be recorded in telemetry.\n\nInstead of duplicating that code several thousand times, we can add a\nsmall helper function that takes the only interesting parameters for an\nIPDL message.  This helper function can then deal with calling malloc in\na single place and setting up the common parameters.  For messages that\nrequire a custom segment size, we'll have to use the old scheme, but\nsuch messages are uncommon.\n\nThe previous changes are not required for this scheme to work, but they\ndo help significantly, as the helper function (Message::IPDLMessage) can\nnow take four parameters, which ensures that its arguments are passed\nsolely in registers on Win64 and ARM.  The wins from this change are\nalso larger than they would be without the previous parts: ~100K on\nx86-64 Linux (!)  and ~80K on ARM Android.", "files": ["ipc/chromium/src/chrome/common/ipc_message.cc", "ipc/chromium/src/chrome/common/ipc_message.h", "ipc/ipdl/ipdl/lower.py"], "git_node": null, "git_parents": [null], "node": "447eaf2c0578d43d58c856e2e5664c9cda35eef2", "parents": ["14acffc2e1eca99806bda3099cdf12938772cd52"], "tags": []}, {"author": "jason laster \u003cjlaster@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399673 - Update Debugger Frontend and upgrade Source Map Worker to v0.13.0. r=jdescottes\n\nMozReview-Commit-ID: L7igSLIa5GX", "files": ["devtools/client/debugger/new/debugger.css", "devtools/client/debugger/new/debugger.js", "devtools/client/debugger/new/parser-worker.js", "devtools/client/debugger/new/pretty-print-worker.js", "devtools/client/debugger/new/search-worker.js", "devtools/client/framework/test/browser_source_map-01.js", "devtools/client/framework/test/browser_source_map-absolute.js", "devtools/client/locales/en-US/debugger.properties", "devtools/client/preferences/debugger.js", "devtools/client/shared/source-map/index.js", "devtools/client/shared/source-map/worker.js"], "git_node": null, "git_parents": [null], "node": "ee8939119c172f5e2c4b101ed17a23ea35897782", "parents": ["447eaf2c0578d43d58c856e2e5664c9cda35eef2"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1391694 - Avoid false shutdown leaks in browser-chrome tests with --repeat; r=jmaher\n\nThis patch re-organizes control flow in the browser-chrome harness so that\nextra memory cleanup only happens just before the browser is closed, even\nwhen running with --repeat.", "files": ["testing/mochitest/browser-test.js"], "git_node": null, "git_parents": [null], "node": "670be1db5eeddc43fb7a36342f1c97bf6c3a5103", "parents": ["ee8939119c172f5e2c4b101ed17a23ea35897782"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397060 - Don't call ComputeOpaqueRect unless we're going to make use of the result. r=mstange\n\nMozReview-Commit-ID: 2yGybisiLcx", "files": ["layout/painting/FrameLayerBuilder.cpp"], "git_node": null, "git_parents": [null], "node": "8384b2a43a1bbbdb6468483d55d2331ddd1cf2ab", "parents": ["670be1db5eeddc43fb7a36342f1c97bf6c3a5103"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397058 - Make display item type flags compulsary and add them for all item types. r=mstange\n\nMozReview-Commit-ID: Jp00rblsm7B", "files": ["layout/painting/nsDisplayItemTypes.h", "layout/painting/nsDisplayItemTypesList.h", "layout/reftests/css-break/reftest.list"], "git_node": null, "git_parents": [null], "node": "160e7920634dbba36c550fec9655bb7ecd5cd535", "parents": ["8384b2a43a1bbbdb6468483d55d2331ddd1cf2ab"], "tags": []}, {"author": "Dylan Roeh \u003cdroeh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400059 - Replace strings in ProgressListener.SecurityInformation with ints. r=snorp", "files": ["mobile/android/base/java/org/mozilla/gecko/customtabs/ActionBarPresenter.java", "mobile/android/base/java/org/mozilla/gecko/customtabs/CustomTabsSecurityPopup.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoView.java", "mobile/android/modules/geckoview/GeckoViewProgress.jsm"], "git_node": null, "git_parents": [null], "node": "ff8b9eddddc4068a878fd561ea734a1531382406", "parents": ["160e7920634dbba36c550fec9655bb7ecd5cd535"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399968 - Ensure the inNavBar search pref really does get set correctly on startup. r=Gijs\n\nDelay the initialisation of the pref until the toolbar has been initialised.\n\nMozReview-Commit-ID: JxQajZ4wrCR", "files": ["browser/components/customizableui/SearchWidgetTracker.jsm"], "git_node": null, "git_parents": [null], "node": "956bc408307c40ffc9a307a7affe8377e04842aa", "parents": ["a71dd9ce8a166bf5781ecbc53ead54bd50f4f8f2"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1398729 - Share devtools.inspectedWindow.eval helper methods in ext-devtools API module. r=aswan\n\nMozReview-Commit-ID: 9ezZNjEOdUY", "files": ["browser/components/extensions/ext-devtools-inspectedWindow.js", "browser/components/extensions/ext-devtools.js"], "git_node": null, "git_parents": [null], "node": "d3df8bc53dcb46cd30426d14f668cb5ab36c85c9", "parents": ["956bc408307c40ffc9a307a7affe8377e04842aa"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1398729 - Support devtools.panels.elements sidebar.setExpression API method. r=aswan\n\nMozReview-Commit-ID: 2tRLF59o8Bg", "files": ["browser/components/extensions/ext-c-devtools-panels.js", "browser/components/extensions/ext-devtools-panels.js", "browser/components/extensions/schemas/devtools_panels.json", "browser/components/extensions/test/browser/browser_ext_devtools_panels_elements_sidebar.js"], "git_node": null, "git_parents": [null], "node": "7ef7bcbd8884ababc8461fa3fe18d649526227d7", "parents": ["d3df8bc53dcb46cd30426d14f668cb5ab36c85c9"], "tags": []}, {"author": "Erica Wright \u003cewright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1394461 - Update illustration and copy for about:rights. ui-r=shorlander r=dao\n\nMozReview-Commit-ID: 3kxO8DYG6R8", "files": ["browser/themes/shared/aboutRights.css", "browser/themes/shared/jar.inc.mn", "toolkit/content/aboutRights.xhtml", "toolkit/themes/shared/illustrations/about-rights.svg", "toolkit/themes/shared/jar.inc.mn"], "git_node": null, "git_parents": [null], "node": "a35cf697567ab04735f1def1b399c03f40f35f39", "parents": ["7ef7bcbd8884ababc8461fa3fe18d649526227d7"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1391605 - Update CHANGES.md for changes in geckodriver 0.19.0. r=ato\n\nMozReview-Commit-ID: D1AAN8iWsuP", "files": ["testing/geckodriver/CHANGES.md", "testing/geckodriver/README.md"], "git_node": null, "git_parents": [null], "node": "7f5db3c919582c4b8fdbf35007b48d0005fd3007", "parents": ["a35cf697567ab04735f1def1b399c03f40f35f39"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1391605 - Bump geckodriver to 0.19.0. r=ato\n\nMozReview-Commit-ID: 4ai3ShcNhdS", "files": ["testing/geckodriver/Cargo.lock", "testing/geckodriver/Cargo.toml"], "git_node": null, "git_parents": [null], "node": "26275c18b48c2aa4e64e8bb54062469fb63c0296", "parents": ["7f5db3c919582c4b8fdbf35007b48d0005fd3007"], "tags": []}, {"author": "Stephen A Pohl \u003cspohl.mozilla.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1398582: Prevent drawing titles in title bars on macOS 10.13 when we don't want them. r=mstange", "files": ["widget/cocoa/nsCocoaWindow.mm"], "git_node": null, "git_parents": [null], "node": "f89ae3c450ce33915e4d2fff0b11b942dec17f1a", "parents": ["ff8b9eddddc4068a878fd561ea734a1531382406"], "tags": []}, {"author": "Florian Qu\u00e8ze \u003cflorian@queze.net\u003e", "branch": "default", "desc": "Bug 1379587 - White flash when opening new tabs, r=mconley, ui-r=phlsa.", "files": ["browser/base/content/tabbrowser.xml", "browser/themes/shared/tabs.inc.css"], "git_node": null, "git_parents": [null], "node": "0e14317d2f6c454e86549fe84d6067e1745a76c5", "parents": ["f89ae3c450ce33915e4d2fff0b11b942dec17f1a"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1399592 - Increase Marionette startup timeout for mochitest/reftest. r=gbrown\n\nCurrently the mochitest and reftest runners are forcing a timeout of 60s\n(or 900s for valgrind or debug builds) when calling `start_session` of\nMarionette. While this method still offers a timeout parameter, the\ntimeout should be set via the `startup_timeout` argument for Marionette.\n\nReason is that Marionette doesn't control the browser instance and\nis getting called right after the application gets launched. As such\nslow running builds can cause timeouts once it takes longer than 60s\nfor the Marionette server to get started.\n\nBy using `startup_timeout` the timeout will even be configurable via\nthe command line and mozharness config files.\n\nMozReview-Commit-ID: EV7GklBcJjU", "files": ["layout/tools/reftest/reftestcommandline.py", "layout/tools/reftest/runreftest.py", "testing/mochitest/mochitest_options.py", "testing/mochitest/runtests.py"], "git_node": null, "git_parents": [null], "node": "880d772e282e47a015605622ca0046569c80bd71", "parents": ["26275c18b48c2aa4e64e8bb54062469fb63c0296"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1398820 - Do not add duplicate rtp extensions; r=bwc\n\nMozReview-Commit-ID: G6wLXW7z05d", "files": ["media/webrtc/signaling/gtest/jsep_session_unittest.cpp", "media/webrtc/signaling/src/jsep/JsepSessionImpl.cpp"], "git_node": null, "git_parents": [null], "node": "f73a6867afeead095c1804adb63815fb885af2f3", "parents": ["880d772e282e47a015605622ca0046569c80bd71"], "tags": []}, {"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging mozilla-central 8e818b5e9b6bef0fc1a5c527ecf30b0d56a02f14 with FIREFOX_BETA_57_BASE a=release DONTBUILD CLOSED TREE\n\nMozReview-Commit-ID: 1pATPHYzcpf", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "22ed219fb63a53c96daa5e957539a8f2393189d4", "parents": ["893fe1549e1e7342a66514b65960f08d40810a34"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1397128 P1 Make CacheReadStream ipdl struct contain an OptionalIPCStream. r=tt", "files": ["dom/cache/CacheTypes.ipdlh", "dom/cache/ReadStream.cpp"], "git_node": null, "git_parents": [null], "node": "3f1e68da9634ed661ff2b4b1b128c43bf3e831bb", "parents": ["0e14317d2f6c454e86549fe84d6067e1745a76c5"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1397128 P2 Refactor StreamList::Add() to use move constructors and accept a nullptr stream. r=tt", "files": ["dom/cache/Manager.cpp", "dom/cache/StreamList.cpp", "dom/cache/StreamList.h"], "git_node": null, "git_parents": [null], "node": "15edfaab92f6d812256252e8efc6b8574cd7c381", "parents": ["3f1e68da9634ed661ff2b4b1b128c43bf3e831bb"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1397128 P3 Add an OpenStreamAction class to open the file stream on the io thread. r=tt", "files": ["dom/cache/Manager.cpp", "dom/cache/Manager.h"], "git_node": null, "git_parents": [null], "node": "bfbcc07fcb4bdb198e42424702c90d128c0ffaa7", "parents": ["15edfaab92f6d812256252e8efc6b8574cd7c381"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1397128 P4 Add a PCacheStreamControl message to open a stream based on its body ID. r=tt", "files": ["dom/cache/CacheStreamControlChild.cpp", "dom/cache/CacheStreamControlChild.h", "dom/cache/CacheStreamControlParent.cpp", "dom/cache/CacheStreamControlParent.h", "dom/cache/Manager.cpp", "dom/cache/Manager.h", "dom/cache/PCacheStreamControl.ipdl", "dom/cache/StreamControl.h", "dom/cache/StreamList.cpp", "dom/cache/StreamList.h", "dom/cache/Types.h"], "git_node": null, "git_parents": [null], "node": "389e9f39d6b8b2e7614511281ede2d7ce83839b5", "parents": ["bfbcc07fcb4bdb198e42424702c90d128c0ffaa7"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1397128 P5 Add ReadStream::Inner::EnsureStream() to synchronously open stream when Availabe/Read/ReadSegments is called. r=tt", "files": ["dom/cache/ReadStream.cpp"], "git_node": null, "git_parents": [null], "node": "5988716b66bba7ad38f8fe0cc7956d2120569ee5", "parents": ["389e9f39d6b8b2e7614511281ede2d7ce83839b5"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1397128 P6 Allow ReadStream to be created with an initially nullptr base stream. r=tt", "files": ["dom/cache/AutoUtils.cpp", "dom/cache/CacheStreamControlChild.cpp", "dom/cache/CacheStreamControlParent.cpp", "dom/cache/ReadStream.cpp"], "git_node": null, "git_parents": [null], "node": "bb52082d2d3c860253a90a6606f1fff7dc864aef", "parents": ["5988716b66bba7ad38f8fe0cc7956d2120569ee5"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bu