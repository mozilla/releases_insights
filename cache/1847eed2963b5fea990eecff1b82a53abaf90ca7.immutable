r/extensions/activity-stream/common/Actions.jsm", "browser/extensions/activity-stream/common/PrerenderData.jsm", "browser/extensions/activity-stream/common/Reducers.jsm", "browser/extensions/activity-stream/data/content/activity-stream-initial-state.js", "browser/extensions/activity-stream/data/content/activity-stream-prerendered.html", "browser/extensions/activity-stream/data/content/activity-stream.bundle.js", "browser/extensions/activity-stream/data/content/activity-stream.css", "browser/extensions/activity-stream/data/locales.json", "browser/extensions/activity-stream/install.rdf.in", "browser/extensions/activity-stream/lib/HighlightsFeed.jsm", "browser/extensions/activity-stream/lib/PlacesFeed.jsm", "browser/extensions/activity-stream/lib/PrefsFeed.jsm", "browser/extensions/activity-stream/lib/SnippetsFeed.jsm", "browser/extensions/activity-stream/lib/TelemetryFeed.jsm", "browser/extensions/activity-stream/lib/TopSitesFeed.jsm", "browser/extensions/activity-stream/test/unit/common/Reducers.test.js", "browser/extensions/activity-stream/test/unit/lib/HighlightsFeed.test.js", "browser/extensions/activity-stream/test/unit/lib/PlacesFeed.test.js", "browser/extensions/activity-stream/test/unit/lib/PrefsFeed.test.js", "browser/extensions/activity-stream/test/unit/lib/TopSitesFeed.test.js", "browser/extensions/activity-stream/test/unit/unit-entry.js", "browser/modules/PingCentre.jsm"], "git_node": null, "git_parents": [null], "node": "79375774e4fef77d6f2fee7aac680a65bb5f6fed", "parents": ["75d3f197fc949a11626199530083b64ddb551882"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400920 - The pocket section briefly shows up and causes the scrollbar to make the whole page flicker. r=ursula, a=ritu\n\nMozReview-Commit-ID: DJk6cctA3nm", "files": ["browser/extensions/activity-stream/data/content/activity-stream.css", "browser/extensions/activity-stream/data/locales.json", "browser/extensions/activity-stream/install.rdf.in"], "git_node": null, "git_parents": [null], "node": "46771933d922bb991abd4fe72796b009aadd6653", "parents": ["79375774e4fef77d6f2fee7aac680a65bb5f6fed"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1404345 - Users are upset and confused about how to turn off Pocket or other sections. r=ursula, a=ritu\n\nMozReview-Commit-ID: DMfmvv2czC3", "files": ["browser/extensions/activity-stream/common/Actions.jsm", "browser/extensions/activity-stream/common/Reducers.jsm", "browser/extensions/activity-stream/data/content/activity-stream-initial-state.js", "browser/extensions/activity-stream/data/content/activity-stream-prerendered.html", "browser/extensions/activity-stream/data/content/activity-stream.bundle.js", "browser/extensions/activity-stream/data/content/activity-stream.css", "browser/extensions/activity-stream/data/locales.json", "browser/extensions/activity-stream/install.rdf.in", "browser/extensions/activity-stream/lib/SectionsManager.jsm", "browser/extensions/activity-stream/test/unit/common/Reducers.test.js"], "git_node": null, "git_parents": [null], "node": "eefa10510e3ba576789e6c41973053ea41a5edfe", "parents": ["46771933d922bb991abd4fe72796b009aadd6653"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1404460 - Only show Pocket stories in specified locales. r=liuche, a=ritu\n\nIdeally, we'd centralize all queries as to which options are user specified.\nHowever, I wanted to do the smallest change so we can uplift so I filed\nbug 1405161 for this centralization.\n\nI opted not to include the \"de\" locale that is included on desktop because it\ndoes not appear we ever get the \"de\" locale on Firefox for Android [1].\n\nI tested this patch by changing the system locale between locales with Pocket\non my device (en-US, en-GB, de-DE) and locales without Pocket (ko-KR). The\nlocale switching system makes this refresh automatically without extra code.\n\nI also intend to test via the in-app locale switcher but that will take time\nbecause I can't do artifact builds with multi-locale so I'm pushing this for\nreview before I'm finished.\n\nFollow-up changes:\n- Add to telemetry\n- Hiding the preference in the undesired locales.\n- A test for isPocketEnabledByLocaleInner (useful to document how this is\nintended to work for locales with variants, different scripts, etc.)\n\n[1]: https://sql.telemetry.mozilla.org/queries/4613#table\n\nMozReview-Commit-ID: 7AVQ8fWub8I", "files": ["mobile/android/base/java/org/mozilla/gecko/activitystream/ActivityStreamTelemetry.java", "mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/ActivityStreamConfiguration.java", "mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/ActivityStreamPanel.java", "mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/StreamRecyclerAdapter.java", "mobile/android/base/moz.build"], "git_node": null, "git_parents": [null], "node": "416989ade5b5b66dae90f45648f3ac2a53c6fb43", "parents": ["eefa10510e3ba576789e6c41973053ea41a5edfe"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1404460 - Add POCKET_ENABLED_TO_LOCALE to asUserPrefs telemetry. r=liuche, a=ritu\n\nAfter speaking with liuche, we decided it'd be better to add a bit to determine\nthis rather than combining it with the isPocketEnabled field (which would be\nloss of data) or cross-referencing the locale of the submitted event when\nchecking the Pocket value during telemetry analysis (which is hard to get right\nand likely to get out of date).\n\nMozReview-Commit-ID: JKFrdEsEbyp", "files": ["mobile/android/base/java/org/mozilla/gecko/activitystream/ActivityStreamTelemetry.java", "mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/ActivityStreamHomeFragment.java", "mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/ActivityStreamPanel.java", "mobile/android/docs/activitystreamtelemetry.rst"], "git_node": null, "git_parents": [null], "node": "bc71eb47ec4ed24eb6bd373abb9767d88cfad170", "parents": ["416989ade5b5b66dae90f45648f3ac2a53c6fb43"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1404460 - Hide Pocket preference if Pocket not available in locale. r=liuche, a=ritu\n\nWhen changing locales, an open dialog will not refresh but clicking on the\n\"Top sites\" preference again (to display the dialog) will show the correct\ndialog for the current locale.\n\nMozReview-Commit-ID: 6UJvDIJZJtc", "files": ["mobile/android/app/src/main/res/layout/preference_topsites_panel_dialog.xml", "mobile/android/base/java/org/mozilla/gecko/preferences/TopSitesPanelsPreference.java"], "git_node": null, "git_parents": [null], "node": "5f3019ce2cfa7c22c92513cd73629a73f6080393", "parents": ["bc71eb47ec4ed24eb6bd373abb9767d88cfad170"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1404460 - Add test for pocket locale enabling. r=liuche, a=ritu\n\nMozReview-Commit-ID: LHdQuICvVjE", "files": ["mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/ActivityStreamConfiguration.java", "mobile/android/tests/background/junit4/src/org/mozilla/gecko/activitystream/homepanel/TestActivityStreamConfiguration.java"], "git_node": null, "git_parents": [null], "node": "ab96b1b8fe4098206ad44119dcd44afcb5be439d", "parents": ["5f3019ce2cfa7c22c92513cd73629a73f6080393"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1405404 - Add 'de' to list of pocket whitelisted locales. r=liuche, a=ritu, l10n=flod\n\nThis is used in multi-locale builds, e.g. [1] where all German is \"de\" but in\n[2], we have a separate l10n repo for en-GB.\n\n[1]: https://hg.mozilla.org/releases/l10n/mozilla-beta/de\n[2]: https://hg.mozilla.org/releases/l10n/mozilla-beta/en-GB\n\nMozReview-Commit-ID: CXw9aFH9psz", "files": ["mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/ActivityStreamConfiguration.java", "mobile/android/tests/background/junit4/src/org/mozilla/gecko/activitystream/homepanel/TestActivityStreamConfiguration.java"], "git_node": null, "git_parents": [null], "node": "6e3b901aec51bc57a41941837271eb71665b128a", "parents": ["ab96b1b8fe4098206ad44119dcd44afcb5be439d"], "tags": []}], "date": 1507068728, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7888": {"changesets": [{"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1384829 - Always perform shadow text actions. r=esawin, a=ritu\n\nWe want to always perform actions on the shadow text side even if a\nparticular GeckoEditable instance is disconnected from Gecko, because\nthere could be other users of Editable that still expect the object to\nperform valid actions.\n\nMozReview-Commit-ID: 48OIEaPZqUE", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoEditable.java"], "git_node": null, "git_parents": [null], "node": "77a84867b31b82a9be8baa6d02de5f188ae66964", "parents": ["6e3b901aec51bc57a41941837271eb71665b128a"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1384829 - Add test case to testInputConnection. r=esawin, a=ritu\n\nAdd a test case to testInputConnection that makes sure GeckoEditable's\nEditable interface still behaves correctly even after disconnecting from\nGecko due to a blur.\n\nMozReview-Commit-ID: 7Z6Kpv2tpRy", "files": ["mobile/android/tests/browser/robocop/robocop_input.html", "mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/testInputConnection.java"], "git_node": null, "git_parents": [null], "node": "52db05e860d867ee1fd0d69637809c8a6ed1c5c9", "parents": ["77a84867b31b82a9be8baa6d02de5f188ae66964"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1404678 - Update cssparser to 0.21.3 and revendor. a=ritu\n\nMozReview-Commit-ID: EAgdFq6CJbx", "files": ["third_party/rust/cssparser/.cargo-checksum.json", "third_party/rust/cssparser/Cargo.toml", "third_party/rust/cssparser/build/match_byte.rs", "third_party/rust/cssparser/src/nth.rs", "toolkit/library/gtest/rust/Cargo.lock", "toolkit/library/rust/Cargo.lock"], "git_node": null, "git_parents": [null], "node": "dd575194b4f1e73c089ebe9fa71b6b2515d81dcb", "parents": ["52db05e860d867ee1fd0d69637809c8a6ed1c5c9"], "tags": []}, {"author": "Bobby Holley \u003cbobbyholley@gmail.com\u003e", "branch": "default", "desc": "Bug 1404316 - Use the nsContentUtils machinery for identifying document-level NAC in GetFlattenedTreeParentNodeInternal. r=emilio, a=ritu\n\nMozReview-Commit-ID: 74UMBeZBZcw", "files": ["dom/base/FragmentOrElement.cpp"], "git_node": null, "git_parents": [null], "node": "999ba109c2fb5e0e5376565b95785ab3e53ca877", "parents": ["dd575194b4f1e73c089ebe9fa71b6b2515d81dcb"], "tags": []}, {"author": "Bobby Holley \u003cbobbyholley@gmail.com\u003e", "branch": "default", "desc": "Bug 1404316 - Crashtest. r=me, a=ritu\n\nMozReview-Commit-ID: LCbXnY8nqmJ", "files": ["layout/style/crashtests/1404316.html", "layout/style/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "5eccbe7a7bf822d3d3c1c0f4735bf9d1c4bbe594", "parents": ["999ba109c2fb5e0e5376565b95785ab3e53ca877"], "tags": []}, {"author": "Kirk Steuber \u003cksteuber@mozilla.com\u003e", "branch": "default", "desc": "Bug 1402025 - Ensure form submission flush when unsetting relevant attributes. r=bz, a=ritu\n\nIt seems that we were flushing any pending submission when changing the action or target attributes of a form, but not when unsetting those attributes.\n\nMozReview-Commit-ID: E6aUnokg54k", "files": ["dom/html/HTMLFormElement.cpp", "dom/html/test/browser.ini", "dom/html/test/browser_submission_flush.js", "dom/html/test/post_action_page.html", "dom/html/test/submission_flush.html"], "git_node": null, "git_parents": [null], "node": "5e1c7f03e3366d56ba69e69ed67c59ca349afb10", "parents": ["5eccbe7a7bf822d3d3c1c0f4735bf9d1c4bbe594"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1404134 - Drop assertion that can be hit mid-unbind. r=heycam, a=ritu\n\nOn that test-case we have something like:\n\n  \u003cbody restyle-root\u003e\n    \u003celement dirty-descendants\u003e\n      \u003celement-2\u003e\n    \u003c/element\u003e\n  \u003c/body\u003e\n\nIf we change the state of element-2 after unbinding the \u003cbody\u003e, which clears the\nbody's flags, but not the children's flags, there'll be no restyle root, even\nthough our parent has the relevant flags anyway.\n\nThis doesn't compromise correctness in any way, so I'd rather drop the assertion\nthat shuffle a bunch of stuff so it holds.\n\nMozReview-Commit-ID: KFVTkXclKST", "files": ["dom/base/Element.cpp"], "git_node": null, "git_parents": [null], "node": "711cce0acdcc3b42b2aba9cc03b04ddf8aec3512", "parents": ["5e1c7f03e3366d56ba69e69ed67c59ca349afb10"], "tags": []}, {"author": "Cameron McCormack \u003ccam@mcc.id.au\u003e", "branch": "default", "desc": "Bug 1404180 - Don't allow associating form elements by ID to \u003cform\u003es across anonymous subtree boundaries. r=smaug, a=ritu\n\nMozReview-Commit-ID: KRJjrkL4FgZ", "files": ["dom/html/nsGenericHTMLElement.cpp", "layout/style/crashtests/1404180-1.html", "layout/style/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "717f66b3515eba313257eb4463bd0d99082c239d", "parents": ["711cce0acdcc3b42b2aba9cc03b04ddf8aec3512"], "tags": []}, {"author": "Luke Chang \u003clchang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1404531 - [Form Autofill] Features on submission should be disabled when the prefs are set to false. r=steveck, a=ritu\n\nMozReview-Commit-ID: F1DfnpFUVYg", "files": ["browser/extensions/formautofill/FormAutofillContent.jsm", "browser/extensions/formautofill/FormAutofillHandler.jsm", "browser/extensions/formautofill/test/unit/test_onFormSubmitted.js"], "git_node": null, "git_parents": [null], "node": "780761b37a04077fdada8cd521d0b438983ce0f5", "parents": ["717f66b3515eba313257eb4463bd0d99082c239d"], "tags": []}, {"author": "Ricky Chien \u003cricky060709@gmail.com\u003e", "branch": "default", "desc": "Bug 1404665 - Extend font family menulist by removing spacer in Preferences font & color section. r=jaws, a=ritu\n\nMozReview-Commit-ID: 4KXWtq2YHrN", "files": ["browser/components/preferences/in-content/main.xul"], "git_node": null, "git_parents": [null], "node": "d6424c273328be0288dc61072719959ca4901130", "parents": ["780761b37a04077fdada8cd521d0b438983ce0f5"], "tags": []}], "date": 1507077455, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7889": {"changesets": [{"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1385882 - Intermittent browser/base/content/test/urlbar/browser_page_action_menu.js | Test timed out. r=Gijs, a=test-only\n\nMozReview-Commit-ID: 8uzQAPQEldP", "files": ["browser/base/content/test/urlbar/head.js", "browser/modules/test/browser/browser_PageActions.js"], "git_node": null, "git_parents": [null], "node": "3e3b262ee4354478c8494e78a5ef1ffa74e1bccf", "parents": ["d6424c273328be0288dc61072719959ca4901130"], "tags": []}, {"author": "Gabor Krizsanits \u003cgkrizsanits@mozilla.com\u003e", "branch": "default", "desc": "Bug 1404383 - Delay nsStringBundle preloading in content processes. r=smaug, a=ritu\n\nEarly in the startup the channel creation might fail,\nin nsStringBundle load and any further attempts are prevented which\nleads to broken ocaization support for the process. Let's wait until\nthe child process learns about the chrome URLs registered on the parent\nside with the preloads.", "files": ["dom/base/nsContentUtils.cpp", "dom/base/nsContentUtils.h", "dom/ipc/ContentChild.cpp"], "git_node": null, "git_parents": [null], "node": "a88f9115bb9c4cfed04db0e73af6168d2150fced", "parents": ["3e3b262ee4354478c8494e78a5ef1ffa74e1bccf"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1404478 - For reals send the right CPU ABI in the core ping. r=jchen, a=ritu\n\nMozReview-Commit-ID: 9tM8723iqMH", "files": ["mobile/android/base/java/org/mozilla/gecko/telemetry/pingbuilders/TelemetryCorePingBuilder.java"], "git_node": null, "git_parents": [null], "node": "ff5e822324fcea8ecd483d2c681c52318cd7eebb", "parents": ["a88f9115bb9c4cfed04db0e73af6168d2150fced"], "tags": []}, {"author": "Honza Bambas \u003chonzab.moz@firemni.cz\u003e", "branch": "default", "desc": "Bug 1403998 - Make view-source channels return correct resultPrincipalURI via LoadInfo after redirect. r=bz, a=ritu", "files": ["netwerk/protocol/viewsource/nsViewSourceChannel.cpp", "netwerk/protocol/viewsource/nsViewSourceChannel.h"], "git_node": null, "git_parents": [null], "node": "f22fa49006ca02468eb0fc51341f9f666f136179", "parents": ["ff5e822324fcea8ecd483d2c681c52318cd7eebb"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1391736 - Relax the ExpectedOwnerForChild assert in the ServoRestyleState constructor. r=emilio, a=ritu", "files": ["layout/base/ServoRestyleManager.cpp", "layout/base/crashtests/1391736.html", "layout/base/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "0b73ed645d56a811110085e047d28bb09ae6af5f", "parents": ["f22fa49006ca02468eb0fc51341f9f666f136179"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1402476 - ExpectedOwnerForChild should not return a first-letter frame for a text child. r=emilio, a=ritu\n\nThe expected owner is the DOM parent.  The first-letter then does some reparenting of the text style later.", "files": ["layout/base/ServoRestyleManager.cpp", "layout/base/crashtests/1402476.html", "layout/base/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "1338d62a031f45f833169b65264b56880609bff0", "parents": ["0b73ed645d56a811110085e047d28bb09ae6af5f"], "tags": []}], "date": 1507078269, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7890": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump\n\nfa -\u003e 091a7dd5e36f", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "d2d205a6f0548ac1bcd8c0bb63a11e65793b1bd0", "parents": ["1338d62a031f45f833169b65264b56880609bff0"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump\n\nes-AR -\u003e 859ccf3772fa\nfa -\u003e 091a7dd5e36f\nfy-NL -\u003e 8fa9d1892463\nit -\u003e fc60cb1f8831\npl -\u003e 611eebba811f\nvi -\u003e f8506b560240\nzh-CN -\u003e 6d3acd04dd4a", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "3f97c1571aac47968c562f066ffbffe9ff23425f", "parents": ["d2d205a6f0548ac1bcd8c0bb63a11e65793b1bd0"], "tags": []}], "date": 1507101643, "git_changesets": [null, null], "user": "ffxbld"}, "7891": {"changesets": [{"author": "ffxbld", "branch": "default", "desc": "No bug, Automated blocklist update from host bld-linux64-spot-327 - a=blocklist-update", "files": ["browser/app/blocklist.xml"], "git_node": null, "git_parents": [null], "node": "6f4c9e5ce96e09bfea4d5d1c9188e5fac8f4ed6b", "parents": ["3f97c1571aac47968c562f066ffbffe9ff23425f"], "tags": []}], "date": 1507112250, "git_changesets": [null], "user": "ffxbld"}, "7892": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@m