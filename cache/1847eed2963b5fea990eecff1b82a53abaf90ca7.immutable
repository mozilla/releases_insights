es/dimens.xml", "mobile/android/base/java/org/mozilla/gecko/tabs/TabsListLayout.java"], "git_node": null, "git_parents": [null], "node": "781a9f653d279753f4ac046f468b51f662509571", "parents": ["569e325d3ee192000bc5a8f6aea2c124b46e069a"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1404495 - Back out changeset 3e7cd55f6cb9 to go back to different colors for connecting and loading on unselected tabs. r=Gijs, a=ritu\n\nMozReview-Commit-ID: JTVjsavmob6", "files": ["browser/base/content/tabbrowser.xml", "browser/themes/shared/tabs.inc.css"], "git_node": null, "git_parents": [null], "node": "96e446025dc6b9e01520d63889d94e5cfebca795", "parents": ["781a9f653d279753f4ac046f468b51f662509571"], "tags": []}, {"author": "Jared Hirsch \u003cohai@6a68.net\u003e", "branch": "default", "desc": "Bug 1405166 - Remove system-disabled pref from Screenshots. r=kmag, a=ritu\n\nMozReview-Commit-ID: KuDfW6EZMWZ", "files": ["browser/extensions/screenshots/bootstrap.js"], "git_node": null, "git_parents": [null], "node": "96eb7bfcdaf849394a11e6477dddf36c52674f5c", "parents": ["96e446025dc6b9e01520d63889d94e5cfebca795"], "tags": []}, {"author": "Jared Hirsch \u003cohai@6a68.net\u003e", "branch": "default", "desc": "Bug 1405166 - Update occurrences of system-disabled pref outside screenshots system addon. r=kmag, a=ritu\n\nMozReview-Commit-ID: 24PV53VM6te", "files": ["browser/base/content/test/general/contextmenu_common.js", "browser/components/uitour/test/browser_UITour_availableTargets.js", "browser/extensions/screenshots/test/browser/head.js", "testing/profiles/prefs_general.js", "toolkit/components/telemetry/TelemetryEnvironment.jsm"], "git_node": null, "git_parents": [null], "node": "487b6f758af6d9ca4827a9efff463bb6bdc2d4ae", "parents": ["96eb7bfcdaf849394a11e6477dddf36c52674f5c"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1403348 - Include details about AsyncShutdown failure in crash reason. r=baku, data-r=rweiss, a=ritu\n\nMozReview-Commit-ID: L6U2MVshZl8", "files": ["dom/workers/ServiceWorkerRegistrar.cpp"], "git_node": null, "git_parents": [null], "node": "84e078bb2ba3e4c0eb924123cb155b3009fe0bdf", "parents": ["487b6f758af6d9ca4827a9efff463bb6bdc2d4ae"], "tags": []}], "date": 1507568116, "git_changesets": [null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7927": {"changesets": [{"author": "Towkir Ahmed \u003ctowkir17@gmail.com\u003e", "branch": "default", "desc": "Bug 1403851 - Fixed fill and fill-opacity of Bookmark toolbar icons. r=johannh, a=ritu", "files": ["browser/themes/shared/places/bookmarksMenu.svg", "browser/themes/shared/places/bookmarksToolbar.svg", "browser/themes/shared/places/folder-live.svg", "browser/themes/shared/places/folder-smart.svg", "browser/themes/shared/places/folder.svg", "browser/themes/shared/places/unfiledBookmarks.svg", "browser/themes/shared/toolbarbutton-icons.inc.css"], "git_node": null, "git_parents": [null], "node": "d6473a55aa1e8b3910321f5793043b4570f308f9", "parents": ["84e078bb2ba3e4c0eb924123cb155b3009fe0bdf"], "tags": []}, {"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399068 - Send the context menu target node up to the parent as an explicit CPOW to fix login selection. r=Felipe, a=ritu\n\nLoginManagerParent expects either a CPOW or a DOM node (in the non-e10s case) to\nbe passed as the inputElement for LoginManagerParent.fillForm. In bug 1360406,\nwe serialized the target in the content process so that the parent didn't have\naccess to the CPOW anymore.\n\nThis patch adds a targetAsCPOW property to the nsContextMenu solely for passing\nback and forth between the parent and content processes in order to refer to\nthe target DOM node.\n\nMozReview-Commit-ID: IMwVK0Ewlhy", "files": ["browser/base/content/nsContextMenu.js", "browser/modules/ContextMenu.jsm"], "git_node": null, "git_parents": [null], "node": "d40416856dd2cf8b87a2191c81a5c70cba0fc301", "parents": ["d6473a55aa1e8b3910321f5793043b4570f308f9"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1383501 - Do not crash when TabParent::RecvPDocAccessibleConstructor receives a null COM proxy sent to the parent process. r=jimm, a=ritu\n\nMozReview-Commit-ID: 5IOuLXc375T", "files": ["accessible/ipc/win/ProxyAccessible.cpp", "accessible/ipc/win/ProxyAccessible.h", "dom/ipc/TabParent.cpp"], "git_node": null, "git_parents": [null], "node": "fce8e9263a0116456ba6f0b9a7b66b4b7ff8801d", "parents": ["d40416856dd2cf8b87a2191c81a5c70cba0fc301"], "tags": []}, {"author": "Lars T Hansen \u003clhansen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1404760 - wasm baseline, disable branch optimization for int64 on x86 to avoid register starvation. r=bbouvier, a=ritu", "files": ["js/src/jit-test/tests/wasm/regress/baseline-i64-opt-cmp.js", "js/src/wasm/WasmBaselineCompile.cpp"], "git_node": null, "git_parents": [null], "node": "8193fe6b6fdbf775f59f07bb5b47a104b5c0c426", "parents": ["fce8e9263a0116456ba6f0b9a7b66b4b7ff8801d"], "tags": []}, {"author": "Stephen Horlander \u003cshorlander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1406276 - Update Folder Icon to fix some overlapping areas. r=jhofmann, a=ritu", "files": ["browser/themes/shared/places/folder.svg"], "git_node": null, "git_parents": [null], "node": "14dabb8eeb17c280a827143521ffbcca21328d73", "parents": ["8193fe6b6fdbf775f59f07bb5b47a104b5c0c426"], "tags": []}, {"author": "Prathiksha \u003cprathikshaprasadsuman@gmail.com\u003e", "branch": "default", "desc": "Bug 1388107 - Support unknown capability values in the sitePermissions.xul dialog. r=johannh, a=ritu\n\nMozReview-Commit-ID: 94mG93fe5OY", "files": ["browser/components/preferences/sitePermissions.js"], "git_node": null, "git_parents": [null], "node": "8eb38d9ed82c6d6fee159fa4de01de5f6923135a", "parents": ["14dabb8eeb17c280a827143521ffbcca21328d73"], "tags": []}, {"author": "Nevin Chen \u003ccnevinchen@gmail.com\u003e", "branch": "default", "desc": "Bug 1389343 - Make default background grey so it can occupied the entire favicon. r=jwu, a=ritu\n\nMozReview-Commit-ID: 93ZWdpnlIuX", "files": ["mobile/android/base/java/org/mozilla/gecko/icons/processing/ColorProcessor.java"], "git_node": null, "git_parents": [null], "node": "5a9fd7c02662defd7104381efb2c321908215ca9", "parents": ["8eb38d9ed82c6d6fee159fa4de01de5f6923135a"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399500 - Light and Dark themes should use the same toolbar borders as the default theme. r=johannh, a=ritu\n\nMozReview-Commit-ID: Cs6a7AZiOrV", "files": ["browser/base/content/browser-tabsintitlebar.js", "browser/themes/windows/browser-aero.css", "browser/themes/windows/browser.css", "browser/themes/windows/compacttheme.css"], "git_node": null, "git_parents": [null], "node": "55322dd4aa31c646f6d85be14f1e73692bad9225", "parents": ["5a9fd7c02662defd7104381efb2c321908215ca9"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1405635 - style: Use the flattened tree parent to find the closest non-nac ancestor of an element. r=bzbarsky, a=ritu\n\nThis only matters for document level NAC like canvas custom content, in which\ncase otherwise we inherit from the document element (which is wrong).\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 35e84c5cdf9cad0f16f94525d425a3b881b3b524", "files": ["servo/components/style/gecko/wrapper.rs"], "git_node": null, "git_parents": [null], "node": "39cdbeea096e47dfa67f60434bf33ca5c22452f2", "parents": ["55322dd4aa31c646f6d85be14f1e73692bad9225"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1405635 - Test that custom content doesn't inherit from the root element. r=bholley, a=ritu\n\nMozReview-Commit-ID: GvjsdQk5Wt4", "files": ["layout/style/test/mochitest.ini", "layout/style/test/test_custom_content_inheritance.html"], "git_node": null, "git_parents": [null], "node": "81ac511f7ff47d2ff75dd68ad967086414db8e3e", "parents": ["39cdbeea096e47dfa67f60434bf33ca5c22452f2"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1405720 - Ensure only 1 theme is ever shown as selected in customize mode. r=jaws, r=johannh, a=ritu\n\nThe previous code here always set the `isActive` property on all themes. When writing the\npatch for bug 1402981 I ran into issues because the default theme has an `isActive` property\nanyway (it's a different type of object). So I tried to avoid setting `isActive` if it was\nalready present. Unfortunately, the result was that `isActive` values, once set, weren't\ncorrectly updated. Worse, these values are (and were, prior to bug 1402981) persisted in\nsome cases.\n\nThere's no point persisting these values, all that will happen is that they'll start\nmismatching the 'real' state of the world (LightweightThemeManager.currentTheme). So instead,\nlet's just not set the `isActive` property at all, and rely solely on the ID of the current\ntheme (or the default theme's ID, now that we no longer support non-lightweight-themes) to\nestablish whether any of the themes should appear selected or not.\n\nMozReview-Commit-ID: 7rajS71FoQR", "files": ["browser/components/customizableui/CustomizeMode.jsm", "browser/components/customizableui/test/browser_1007336_lwthemes_in_customize_mode.js"], "git_node": null, "git_parents": [null], "node": "6081f387494bc6e1a902cbeb8d202c80e0749fa2", "parents": ["81ac511f7ff47d2ff75dd68ad967086414db8e3e"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1406096 - Fix flash of untranslated content on Activity Stream search bar. r=k88hudson, a=ritu\n\nMozReview-Commit-ID: H7ebg6plOvc", "files": ["browser/extensions/activity-stream/data/content/activity-stream-initial-state.js", "browser/extensions/activity-stream/data/content/activity-stream-prerendered.html", "browser/extensions/activity-stream/install.rdf.in", "browser/extensions/activity-stream/test/unit/activity-stream-prerender.test.jsx"], "git_node": null, "git_parents": [null], "node": "3fecc15c4d2901ce619de5468dac32b3c10f256e", "parents": ["6081f387494bc6e1a902cbeb8d202c80e0749fa2"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1406120 - Remove fade delay for about:home. r=k88hudson, a=ritu\n\nMozReview-Commit-ID: 3pRRdxwukx2", "files": ["browser/extensions/activity-stream/data/content/activity-stream.css", "browser/extensions/activity-stream/install.rdf.in"], "git_node": null, "git_parents": [null], "node": "7f3c0f8c3973662cfb47b8e762e4094cae405c1c", "parents": ["3fecc15c4d2901ce619de5468dac32b3c10f256e"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1347984 - Check for dead object proxies in TriggerPromiseReactions. r=till, a=ritu", "files": ["js/src/builtin/Promise.cpp", "js/src/jit-test/tests/basic/bug908915.js", "js/src/jit-test/tests/promise/bug1347984.js", "js/src/shell/js.cpp"], "git_node": null, "git_parents": [null], "node": "b9e89e842081ae083a6583a518b1730611d1ac90", "parents": ["7f3c0f8c3973662cfb47b8e762e4094cae405c1c"], "tags": []}], "date": 1507572637, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7928": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\ncs -\u003e 9a6a04462a96\ncy -\u003e 8fcbba1d8818\nes-AR -\u003e 1c710092279b\nkab -\u003e 80458771474e\nkk -\u003e 4b836c5d8fed\nnn-NO -\u003e 974bbd129aa0\nsr -\u003e ab76ba46a8fd\nsv-SE -\u003e 6be0f18c518c", "files": ["browse