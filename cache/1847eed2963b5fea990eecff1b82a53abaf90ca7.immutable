 ["6fa856a4da2f32f8178d30daa69d47528557b2af"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1261175. r=tnikkel, a=ritu", "files": ["view/nsViewManager.cpp"], "git_node": null, "git_parents": [null], "node": "04f51b690e8c69eb9e0abd6a85389bfaf91313bf", "parents": ["f7d30f17af0defa3c530e6572368fe705aab3a1d"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Bug 1333056 - Don't crash in SendBuildID when MessageChannel isn't connected. r=dvander, a=ritu\n\nxpcshell can sometimes create and then almost immediately kill the GPU process. This can\ncause the connection state of GPUParent's message channel to be in error or closed\nwhen it attempts to send its build ID. In this case we should ignore the request\nbecause the process will soon close.\n\nMozReview-Commit-ID: EAupU844iFo", "files": ["ipc/glue/MessageChannel.cpp"], "git_node": null, "git_parents": [null], "node": "208bf788e80c094022fcadcb7970c141846e3e71", "parents": ["04f51b690e8c69eb9e0abd6a85389bfaf91313bf"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1408672 - Disable the hover / active quirk for invalidation. r=heycam, a=ritu\n\nMozReview-Commit-ID: 6wlDm8cNEYD", "files": ["servo/components/selectors/matching.rs"], "git_node": null, "git_parents": [null], "node": "64170e5081cd17e543004e7194da4ccb2444b9ad", "parents": ["208bf788e80c094022fcadcb7970c141846e3e71"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1408672 - Test that hover quirk is handled properly during invalidation. r=heycam, a=ritu\n\nMozReview-Commit-ID: 9PaVx2pP2HB", "files": ["layout/style/test/test_hover_quirk.html"], "git_node": null, "git_parents": [null], "node": "51ee30adc28a355a9516a8a83c255d6b6ebf4bc1", "parents": ["64170e5081cd17e543004e7194da4ccb2444b9ad"], "tags": []}, {"author": "Matt