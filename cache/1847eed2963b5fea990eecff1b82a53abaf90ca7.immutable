 [null], "node": "216d7126983b46cf7ddc8b522781386cdb8a9077", "parents": ["26f341039c20f9279b034d04a67227f47c7b4dc9"], "tags": []}, {"author": "Kaku Kuo \u003ckaku@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403412 - Disable VP9 estimizer on Mac. r=jya, a=sledru\n\nMozReview-Commit-ID: 8RTe7lVSRwl", "files": ["dom/media/Benchmark.cpp"], "git_node": null, "git_parents": [null], "node": "452ca306a258e8b18c4a2eb3295b37b58a8ecd8b", "parents": ["216d7126983b46cf7ddc8b522781386cdb8a9077"], "tags": []}, {"author": "Thomas Nguyen \u003ctnguyen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403473 - Init loggingEnable for hashcompleter. r=dimi, a=sledru\n\nMozReview-Commit-ID: 1BpErwmbgCM", "files": ["toolkit/components/url-classifier/nsUrlClassifierHashCompleter.js"], "git_node": null, "git_parents": [null], "node": "e4a0c97b413f2515c26a7022b60dffa89172955b", "parents": ["452ca306a258e8b18c4a2eb3295b37b58a8ecd8b"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403550 - Update the X offset of the library button when the window is resized. r=sfoster, a=sledru\n\nMozReview-Commit-ID: J3XpTOZwO1Y", "files": ["browser/base/content/browser-places.js"], "git_node": null, "git_parents": [null], "node": "f8ac35ccd7007d01591c17dc1bab835ef45e1664", "parents": ["e4a0c97b413f2515c26a7022b60dffa89172955b"], "tags": []}, {"author": "Ricky Chien \u003cricky060709@gmail.com\u003e", "branch": "default", "desc": "Bug 1393417 - Make Preferences Android and iOS icons highlight in high contrast themes. r=dao, a=sledru\n\nMozReview-Commit-ID: 86Yh5djkvOP", "files": ["browser/themes/shared/incontentprefs/logo-android.svg", "browser/themes/shared/incontentprefs/logo-ios.svg", "browser/themes/shared/incontentprefs/preferences.inc.css"], "git_node": null, "git_parents": [null], "node": "2445f6df733d9a17c87546d23b3b4ed21c0c7c05", "parents": ["f8ac35ccd7007d01591c17dc1bab835ef45e1664"], "tags": []}, {"author": "Ting-Yu Lin \u003ctlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401807 - Part 1: Give unconstrained block size when reflowing mPosterImage. r=dholbert, a=sledru\n\nAlso, added MOZ_ASSERT to ensure all the video frame's children are fully\ncomplete after reflowing (except for the mVideoControls special case on\nAndroid).\n\nThis fixed aStatus.IsEmpty() assertion for the test case added in Part 2.\n\nMozReview-Commit-ID: HKze4EZoaJY", "files": ["layout/generic/nsVideoFrame.cpp"], "git_node": null, "git_parents": [null], "node": "792634630d29963ba3f7d209b56be5cbd56ceb3e", "parents": ["2445f6df733d9a17c87546d23b3b4ed21c0c7c05"], "tags": []}, {"author": "Ting-Yu Lin \u003ctlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401807 - Part 2: Add a crashtest. r=dholbert, a=sledru\n\nMozReview-Commit-ID: 18oPdP1OplJ", "files": ["layout/generic/crashtests/1401807.html", "layout/generic/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "3c55cc6a76f28eba2e84f87450cb0503fdd658f2", "parents": ["792634630d29963ba3f7d209b56be5cbd56ceb3e"], "tags": []}, {"author": "Ting-Yu Lin \u003ctlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401807 - Part 3: Use a local reflow status when reflowing nsVideoFrame's children. r=dholbert, a=sledru\n\nThis ensures the video frame's reflow status is not affect by its children's\nreflow result.\n\nMozReview-Commit-ID: 4WwLFyIyV4q", "files": ["layout/generic/nsVideoFrame.cpp"], "git_node": null, "git_parents": [null], "node": "d9f70ecf91d3188bfb15a97b97ca1d5d1309aac8", "parents": ["3c55cc6a76f28eba2e84f87450cb0503fdd658f2"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1402094 - Blacklist about:reader from using stylo. r=bholley, a=sledru\n\nMozReview-Commit-ID: 6cG1x1tcOwn", "files": ["dom/base/nsDocument.cpp"], "git_node": null, "git_parents": [null], "node": "35bae846b62970fc2faa9c0979c2544eff3c04da", "parents": ["d9f70ecf91d3188bfb15a97b97ca1d5d1309aac8"], "tags": []}], "date": 1506954481, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7872": {"changesets": [{"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403110 - Fix disabled button color on Windows 7 aero. r=nhnt11, a=sledru\n\nMozReview-Commit-ID: INfoRsLNPT9", "files": ["browser/themes/windows/browser.css", "browser/themes/windows/compacttheme.css"], "git_node": null, "git_parents": [null], "node": "96181880ab720123d9f7c4309b999abfc1166e10", "parents": ["35bae846b62970fc2faa9c0979c2544eff3c04da"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1391227 - Make buttons in the tab toolbar more opaque. r=dao, a=sledru\n\nMozReview-Commit-ID: AHtVrDXxTLe", "files": ["browser/themes/windows/browser-aero.css", "browser/themes/windows/compacttheme.css"], "git_node": null, "git_parents": [null], "node": "6508bce1106dffe39c131f2217abf514235c90b6", "parents": ["96181880ab720123d9f7c4309b999abfc1166e10"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1402416 - Use the correct font smoothing background color for disabled menuitems. r=dao, a=sledru\n\nMozReview-Commit-ID: 9EmcppE2rDE", "files": ["toolkit/themes/osx/global/menu.css"], "git_node": null, "git_parents": [null], "node": "d19abce87a20a5c33cc2831c4a50e3c8a6d72aaa", "parents": ["6508bce1106dffe39c131f2217abf514235c90b6"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1402896 - Make the url bar strip javascript even when preceded by control characters. r=mak, a=sledru\n\nMozReview-Commit-ID: 5ZO8n5lfvnl", "files": ["browser/base/content/browser.js", "browser/base/content/test/urlbar/browser_removeUnsafeProtocolsFromURLBarPaste.js"], "git_node": null, "git_parents": [null], "node": "04e56dc5714e1b5d71dedc47ab372f03a2fcc19b", "parents": ["d19abce87a20a5c33cc2831c4a50e3c8a6d72aaa"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1403127 - Don't try to pass fullscreen element through IPC. r=jaws, a=sledru\n\nMozReview-Commit-ID: DaiBNVdqAOh", "files": ["browser/base/content/nsContextMenu.js", "browser/modules/ContextMenu.jsm"], "git_node": null, "git_parents": [null], "node": "c786424818eae74178d9412cf999507be271d3cd", "parents": ["04e56dc5714e1b5d71dedc47ab372f03a2fcc19b"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1403592 - Never flush the user font set when getting font metrics from style resolution. r=Manishearth, a=sledru\n\nIn this case, the caller doesn't go through all the PreTraverseSync stuff (we\ndon't really want it to do so), via GetComputedStyleNoFlush.\n\nIt makes sense to not flush the user font set that case, we'll schedule a\nrestyle properly if / when needed.\n\nSince the set should be flushed otherwise, let's just not flush it from the\nstyling code.\n\nMozReview-Commit-ID: LLHfxemJ8QQ", "files": ["layout/style/ServoBindings.cpp", "layout/style/nsRuleNode.cpp", "layout/style/nsRuleNode.h"], "git_node": null, "git_parents": [null], "node": "1322c11127a063fc0172f8519b06e04380917163", "parents": ["c786424818eae74178d9412cf999507be271d3cd"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1403592 - Crashtest. r=Manishearth, a=sledru\n\nI've made it crash at least once, though it's intermittent-y. I guess it's\nbetter than no crashtest.\n\nMozReview-Commit-ID: 5m2VCrEs8lM", "files": ["layout/style/crashtests/1403592.html", "layout/style/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "f98a2bd7044165abb4e6244e1f6448596897fba8", "parents": ["1322c11127a063fc0172f8519b06e04380917163"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1403615 - Also follow the NODE_DESCENDANTS_NEED_FRAMES bit in ClearRestyleStateFromSubtree. r=bholley, a=sledru\n\nWe don't follow this bit intentionally because we know that even if it's set,\nwhen none of the other two bits are set there are no other restyle / change\nhints down the tree.\n\nWe rely on the frame constructor to clean the mess up, though, and it doesn't\nreally do a good work about it.\n\nIn particular, the case we're hitting on the test-case is:\n\n\u003cbody descendant-need-frames change=reconstruct style=\"display: table-column-group\"\u003e\n  \u003cdiv descendant-need-frames\u003e\n    \u003cdiv descendant-need-frames\u003e\n      \u003cspan needs-frame\u003e\u003c/span\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n\u003c/body\u003e\n\nWhen we see we need to reconstruct the body, we call\nClearRestyleStateFromSubtree, but that doesn't do much now, since we don't\nfollow the descendant-need-frames bits.\n\nThen, when we reconstruct the content, we arrive at[1] when constructing the\nfirst child \u003cdiv\u003e. The \u003cdiv\u003e flags have been cleared, but not the children's!\n\nThen a text-node is inserted in a \u003cdiv\u003e, breaking all sorts of invariants.\n\nThis is the easiest fix. Other fixes include clearing the flags on\nSetAsUndisplayedContent. But that implies not clearing them in\nShouldCreateItemsForChild, and doing that somewhere more sensible.\n\nI suspect it's not too hard, but that's a slightly more risky change, will do it\nif you prefer it.\n\n[1]: http://searchfox.org/mozilla-central/rev/3dbb47302e114219c53e99ebaf50c5cb727358ab/layout/base/nsCSSFrameConstructor.cpp#6092\n\nMozReview-Commit-ID: 7026wkQLQkz", "files": ["layout/base/ServoRestyleManager.cpp", "layout/style/crashtests/1403615.html", "layout/style/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "dade9951a461fef6a6af9265760861e86c9b06ca", "parents": ["f98a2bd7044165abb4e6244e1f6448596897fba8"], "tags": []}, {"author": "Michael Cooper \u003cmcooper@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403758 - Sync shield-recipe-client v76 from GitHub (commit 2419d02). r=Gijs, a=sledru\n\n- #1070: Use the correct attribute name when comparing telemetry timestamps.\n  https://github.com/mozilla/normandy/pull/1070\n\n- #1071: Fix #957: Use UpdateUtils.jsm to determine the update channel.\n  https://github.com/mozilla/normandy/pull/1071\n\nMozReview-Commit-ID: Jdpc02PBQRv", "files": ["browser/extensions/shield-recipe-client/install.rdf.in", "browser/extensions/shield-recipe-client/lib/ClientEnvironment.jsm", "browser/extensions/shield-recipe-client/lib/NormandyDriver.jsm", "browser/extensions/shield-recipe-client/test/browser/browser_ClientEnvironment.js", "browser/extensions/shield-recipe-client/vendor/LICENSE_THIRDPARTY", "browser/extensions/shield-recipe-client/vendor/PropTypes.js", "browser/extensions/shield-recipe-client/vendor/React.js", "browser/extensions/shield-recipe-client/vendor/ReactDOM.js", "browser/extensions/shield-recipe-client/vendor/classnames.js", "browser/extensions/shield-recipe-client/vendor/mozjexl.js"], "git_node": null, "git_parents": [null], "node": "ccce663812da531d339710da3901fc8b4bc64ab8", "parents": ["dade9951a461fef6a6af9265760861e86c9b06ca"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403853 - Hide the menu button separator in popup windows. r=nhnt11, a=sledru\n\nMozReview-Commit-ID: HxAC8oXcQOn", "files": ["browser/themes/shared/customizableui/panelUI.inc.css"], "git_node": null, "git_parents": [null], "node": "0460ea0333f964f3ff09093260dc648933f43e67", "parents": ["ccce663812da531d339710da3901fc8b4bc64ab8"], "tags": []}, {"author": "Milan Sreckovic \u003cmilan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403945 - Add utility functions to recognize OS X 10.13. r=mstange, a=sledru\n\nMozReview-Commit-ID: Bw0jkyWrIzD", "files": ["widget/GfxDriverInfo.h", "widget/GfxInfoBase.cpp", "widget/cocoa/GfxInfo.mm", "widget/cocoa/nsCocoaFeatures.h", "widget/cocoa/nsCocoaFeatures.mm"], "git_node": null, "git_parents": [null], "node": "9bd05768af69c88d44b84ffcaa9a2644d9a0a6ec", "parents": ["0460ea0333f964f3ff09093260dc648933f43e67"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1402503 - Part 1: Fix slow script add-on ID detection. r=mixedpuppy, a=sledru\n\nMozReview-Commit-ID: EYhOn2TQCq1", "files": ["js/xpconnect/src/XPCJSContext.cpp"], "git_node": null, "git_parents": [null], "node": "41942dc5a92f1fef3f2f8ec78bafb5d9a87b1951", "parents": ["9bd05768af69c88d44b84ffcaa9a2644d9a0a6ec"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1402503 - Part 2: Add test for extension slow script dialog. r=mixedpuppy, a=sledru\n\nMozReview-Commit-ID: BknBhAttKHS", "files": ["browser/components/extensions/test/browser/browser-common.ini", "browser/components/extensions/test/browser/browser_ext_slow_script.js"], "git_node": null, "git_parents": [null], "node": "0b50c7250aa635957c72a9e49eddc8b7cd65cdf6", "parents": ["41942dc5a92f1fef3f2f8ec78bafb5d9a87b1951"], "tags": []}], "date": 1506956872, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7873": {"changesets": [{"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1403023 - Set mSentCommitOrAbort to true when HoldWorker call fails to silence the destructor assertion (this is a followup fix for bug 1399322). r=asuth, a=debug-only", "files": ["dom/indexedDB/IDBTransaction.cpp"], "git_node": null, "git_parents": [null], "node": "6cbe936e07c21d7920976a10c764fcb9bd9b574c", "parents": ["0b50c7250aa635957c72a9e49eddc8b7cd65cdf6"], "tags": []}, {"author": "Christian Holler \u003ccholler@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403962 - Add JS test for FillWithUndefined special-case. r=anba, a=test-only\n\nMozReview-Commit-ID: FBa8qw3kUSU", "files": ["js/src/jit-test/tests/arrays/fillwithundefined-length-nonwriteable.js"], "git_node": null, "git_parents": [null], "node": "d1bb539f6325eb1f58d819316e9b99e46b1eaccc", "parents": ["6cbe936e07c21d7920976a10c764fcb9bd9b574c"], "tags": []}, {"author": "Stephen A Pohl \u003cspohl.mozilla.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1402740 - Position modal sheets correctly on macOS now that titlebars are being hidden by bug 1401297. r=mstange, a=sledru", "files": ["widget/cocoa/nsChildView.mm"], "git_node": null, "git_parents": [null], "node": "8d89adbab6e645c5a8725da163ebe7c47f67d4ec", "parents": ["d1bb539f6325eb1f58d819316e9b99e46b1eaccc"], "tags": []}, {"author": "Stephen Horlander \u003cshorlander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403202 - Update macOS DMG Backgrounds for label reability. r=dolske, a=sledru", "files": ["browser/branding/aurora/background.png", "browser/branding/nightly/background.png", "browser/branding/official/background.png"], "git_node": null, "git_parents": [null], "node": "abbc7bcb54e365d56c0abd70cbb7c48f97ddb08a", "parents": ["8d89adbab6e645c5a8725da163ebe7c47f67d4ec"], "tags": []}, {"author": "Towkir Ahmed \u003ctowkir17@gmail.com\u003e", "branch": "default", "desc": "Bug 1403875 - Add missing fill and fill-opacity attributes to bookmarks-toolbar.svg. r=dao, a=sledru\n\nMozReview-Commit-ID: IHqDu1ceNTV", "files": ["browser/themes/shared/icons/bookmarks-toolbar.svg"], "git_node": null, "git_parents": [null], "node": "675fb0ab7887e791f3b64d02c27c946c2861e3d3", "parents": ["abbc7bcb54e365d56c0abd70cbb7c48f97ddb08a"], "tags": []}, {"author": "Stephen A Pohl \u003cspohl.mozilla.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1404036 - Display window titles in non-default themes when titlebars are showing on macOS. r=mstange, a=sledru", "files": ["widget/cocoa/nsCocoaWindow.mm"], "git_node": null, "git_parents": [null], "node": "55da6c78301249430edcbc84ed0a739eb06af788", "parents": ["675fb0ab7887e791f3b64d02c27c946c2861e3d3"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1403293 - Make sure that anonymous table columns and column groups never affect hit testing. r=heycam, a=sledru\n\nPer spec, these boxes shouldn't even exist.\n\nMozReview-Commit-ID: 9tQdqSgXg76", "files": ["layout/style/res/ua.css"], "git_node": null, "git_parents": [null], "node": "282e28b451d508e2c58e4f7592ca0a5dc0f3f7e5", "parents": ["55da6c78301249430edcbc84ed0a739eb06af788"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1403293 - Add a test. r=kats, a=sledru\n\nMozReview-Commit-ID: GyWZGiT6xeG", "files": ["gfx/layers/apz/test/mochitest/helper_scroll_tables_perspective.html", "gfx/layers/apz/test/mochitest/mochitest.ini", "gfx/layers/apz/test/mochitest/test_group_wheelevents.html"], "git_node": null, "git_parents": [null], "node": "154153211b83353c8c5ff7fe11b653cad7fc2292", "parents": ["282e28b451d508e2c58e4f7592ca0a5dc0f3f7e5"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399111 - Tabs that start loading in the background and haven't been selected before completing loading will show a lighter tab burst. r=Gijs, a=sledru\n\nMozReview-Commit-ID: FdXwaQr7Glt", "files": ["browser/base/content/tabbrowser.xml", "browser/themes/shared/tabs.inc.css"], "git_node": null, "git_parents": [null], "node": "66cc570df716f149096f16a8f8f5cbaafa659dc1", "parents": ["154153211b83353c8c5ff7fe11b653cad7fc2292"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399111 - Keep the loading indicator gray for tabs that have been unselected since load. r=Gijs, a=sledru\n\nMozReview-Commit-ID: JPEy3XDsGmb", "files": ["browser/base/content/tabbrowser.xml", "browser/themes/shared/tabs.inc.css"], "git_node": null, "git_parents": [null], "node": "c53c961ce40713f348b443b4517179b0c6c96f93", "parents": ["66cc570df716f149096f16a8f8f5cbaafa659dc1"], "tags": []}, {"author": "Ricky Chien \u003cricky060709@gmail.com\u003e", "branch": "default", "desc": "Bug 1402244 - Recover broken treecol & treechildren font-size. r=jaws, a=sledru\n\nMozReview-Commit-ID: 1ojLbVo5hg8", "files": ["toolkit/themes/shared/in-content/common.inc.css"], "git_node": null, "git_parents": [null], "node": "3ee864914db4caa935a2ac922dff57c60ee2cb8e", "parents": ["c53c961ce40713f348b443b4517179b0c6c96f93"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1403465 - style: Avoid creating element data in Servo_ResolvePseudoStyle. r=bholley, a=sledru\n\nThe reason the patch in bug 1402285 doesn't work is that we call this function\nmultiple times with the same element. This fixes it.\n\nMozReview-Commit-ID: Ko9zirCOzTR", "files": ["servo/ports/geckolib/glue.rs"], "git_node": null, "git_parents": [null], "node": "5a5d0e596c1d8130b58ce899c21918293505c465", "parents": ["3ee864914db4caa935a2ac922dff57c60ee2cb8e"], "tags": []}, {"author": "J. Ryan Stinnett \u003cjryans@gmail.com\u003e", "branch": "default", "desc": "Bug 1403465 - Crashtest. r=emilio, a=sledru\n\nMozReview-Commit-ID: 9jYSE2oErnH", "files": ["layout/style/crashtests/1403465.html", "layout/style/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "3c2c7b00d6ab3cde86839defdb08007c475a7f41", "parents": ["5a5d0e596c1d8130b58ce899c21918293505c465"], "tags": []}, {"author": "Andreas Pehrson \u003cpehrsons@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403714 - Only regard max_fs when set explicitly. r=dminor, a=sledru\n\nMozReview-Commit-ID: DczP0bq96AW", "files": ["media/webrtc/signaling/src/media-conduit/VideoConduit.cpp"], "git_node": null, "git_parents": [null], "node": "98673c4c15cc0410fd9da916055615bf21151719", "parents": ["3c2c7b00d6ab3cde86839defdb08007c475a7f41"], "tags": []}], "date": 1506959007, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7874": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1378524 - Skip browser_inspector_extension_sidebar.js on Linux debug/asan due to frequent failures. a=test-only", "files": ["devtools/client/inspector/extensions/test/browser.ini"], "git_node": null, "git_parents": [null], "node": "ab0fd6d075a606d41e668036687d2232d71783db", "parents": ["98673c4c15cc0410fd9da916055615bf21151719"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1397557 - Skip browser_pdfjs_zoom.js on debug builds due to frequent failures. a=test-only", "files": ["browser/extensions/pdfjs/test/browser.ini"], "git_node": null, "git_parents": [null], "node": "c8b1590db5646e2f201f82e60e88c1d5513c5649", "parents": ["ab0fd6d075a606d41e668036687d2232d71783db"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1403712 - Make some assertions not assert for conditions that may happen mid-unbind. r=bholley, a=sledru\n\nMozReview-Commit-ID: DNSphdMismy\nSigned-off-by: Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "files": ["dom/base/Element.cpp", "dom/base/nsIDocumentInlines.h"], "git_node": null, "git_parents": [null], "node": "c5ae2d14772f7a6083b3bccefc887aebbd1928c0", "parents": ["c8b1590db5646e2f201f82e60e88c1d5513c5649"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1403712 - Clear the restyle root at the end of UnbindFromTree too. r=bholley, a=sledru\n\nMozReview-Commit-ID: 7swfspMWUe6\nSigned-off-by: Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "files": ["dom/base/Element.cpp"], "git_node": null, "git_parents": [null], "node": "fd9bd6556ea886a9fbe1cba7ab20e83b7b4a552c", "parents": ["c5ae2d14772f7a6083b3bccefc887aebbd1928c0"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1403712 - Crashtest. r=bholley, a=sledru\n\nMozReview-Commit-ID: DtOKa8V4deq\nSigned-off-by: Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "files": ["layout/style/crashtests/1403712.html", "layout/style/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "1c7e7fda6b0d6419da86c47bb1e35fdda6776144", "parents": ["fd9bd6556ea886a9fbe1cba7ab20e83b7b4a552c"], "tags": []}, {"author": "Grigory Kruglov \u003cgkruglov@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403787 - Register FxA device with a default client name if we fail to obtain one. r=nalexander, a=sledru\n\nMozReview-Commit-ID: 85uXkFhMPFG", "files": ["mobile/android/services/src/main/java/org/mozilla/gecko/fxa/devices/FxAccountDeviceRegistrator.java", "mobile/android/services/src/main/java/org/mozilla/gecko/fxa/sync/FxAccountSyncAdapter.java"], "git_node": null, "git_parents": [null], "node": "98e63bbec000a2a2dc23a7d90380770077932db0", "parents": ["1c7e7fda6b0d6419da86c47bb1e35fdda6776144"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1403841 - IsSelectionEditable should check whether focus node and anchor node aren't null. r=masayuki, a=sledru\n\nThis might be regression by bug 1319340, but there is crash signature from old version.  We should check whether focus node and anchor node aren't null.\n\nMozReview-Commit-ID: J7npxN5kC9G", "files": ["editor/libeditor/EditorBase.cpp"], "git_node": null, "git_parents": [null], "node": "274c04f3c5657a44bc593d76d2cb7b60123a5b2f", "parents": ["98e63bbec000a2a2dc23a7d90380770077932db0"], "tags": []}, {"author": "Grigory Kruglov \u003cgkruglov@mozilla.com\u003e", "branch": "default", "desc": "Bug 1404124 - Pickle account right after it's created. r=eoger, a=sledru\n\nThis is a relative of Bug 988605, with an exception that instead of going the whole way\nand ensuring pickled data is kept up-to-date as Nick proposed, this patch simply ensures that\nwe pickle as soon as possible, with a goal of eliminating pickle races. The end goal is to kill\noff pickling entirely, and so the assumption here is that this workaround is good enough\nin the meantime.\n\nMozReview-Commit-ID: 7IjRH7KE2Z9", "files": ["mobile/android/services/src/main/java/org/mozilla/gecko/fxa/authenticator/AndroidFxAccount.java"], "git_node": null, "git_parents": [null], "node": "57e49b668005f60dea19b8eda37836a23b9994e0", "parents": ["274c04f3c5657a44bc593d76d2cb7b60123a5b2f"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1402218 - Make sure to clone our CSSDeclaration as needed when removing properties. r=emilio, a=sledru\n\nMozReview-Commit-ID: 6LRjLU3QQok", "files": ["layout/style/DeclarationBlockInlines.h", "layout/style/crashtests/1402218-1.html", "layout/style/crashtests/crashtests.list", "layout/style/nsDOMCSSDeclaration.cpp"], "git_node": null, "git_parents": [null], "node": "af6b3f0fdb60d6ef99b96927396d1c2912af8d11", "parents": ["57e49b668005f60dea19b8eda37836a23b9994e0"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1403646 - Make sure dead object proxies have the same background-finalization status as the wrapper they replace. r=jonco, a=sledru\n\nMozReview-Commit-ID: GTKbR0azcRy", "files": ["js/src/proxy/DeadObjectProxy.cpp", "js/src/proxy/DeadObjectProxy.h"], "git_node": null, "git_parents": [null], "node": "2f1496c1455f4a122dfe50a024da0ae297dd9673", "parents": ["af6b3f0fdb60d6ef99b96927396d1c2912af8d11"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1393843 - Add telemetry for page action items and the context menu that enables/disables them. data-review=rweiss, r=adw, a=sledru\n\nMozReview-Commit-ID: E52TGDLgjCC", "files": ["browser/base/content/browser-pageActions.js", "browser/base/content/browser.xul", "browser/extensions/pocket/bootstrap.js", "browser/extensions/webcompat-reporter/content/WebCompatReporter.jsm", "browser/modules/PageActions.jsm", "toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "a438ffa660b724ef79eb06e12f07bfbc28f74d8e", "parents": ["2f1496c1455f4a122dfe50a024da0ae297dd9673"], "tags": []}, {"author": "Mike de Boer \u003cmdeboer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1398346 - Hide the 'Open File' status label for failed downloads and/ or downloads where the file went missing for items in the Downloads subview in the Library panel. r=Paolo, a=sledru\n\nMozReview-Commit-ID: 1j9tkqydyVZ", "files": ["browser/components/downloads/content/downloads.css"], "git_node": null, "git_parents": [null], "node": "d932d07adaf09fb853d302cfe2adb4aa5287a009", "parents": ["a438ffa660b724ef79eb06e12f07bfbc28f74d8e"], "tags": []}, {"author": "Mike de Boer \u003cmdeboer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1398346 - Follow up patch to correct one of the selectors to be more precise and avoid potential issues. rs=Paolo, a=sledru\n\nMozReview-Commit-ID: 4nZ16XB7xQA", "files": ["browser/components/downloads/content/downloads.css"], "git_node": null, "git_parents": [null], "node": "8e780926710a7e4c8c5e966f62e8c51c29cba488", "parents": ["d932d07adaf09fb853d302cfe2adb4aa5287a009"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1399939 - Switch to highly restrictive profile for IDN. r=dveditz, r=jfkthame, a=sledru\n\nMozReview-Commit-ID: E5LRuQVfIZP", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "49cc08c809f76b10dffdbf7d040ab2559aa44875", "parents": ["8e780926710a7e4c8c5e966f62e8c51c29cba488"], "tags": []}, {"author": "Nihanth Subramanya \u003cnhnt11@gmail.com\u003e", "branch": "default", "desc": "Bug 1400165 - Increase padding of sidebar search container, adjust sidebar font-size on MacOS. r=dao, a=sledru\n\nMozReview-Commit-ID: 1c1s9eqt1Ri", "files": ["browser/themes/linux/places/places.css", "browser/themes/osx/browser.css", "browser/themes/osx/places/places.css", "browser/themes/windows/places/places.css"], "git_node": null, "git_parents": [null], "node": "c7b47e1282c2b96e8d440da60784e6dbae234770", "parents": ["49cc08c809f76b10dffdbf7d040ab2559aa44875"], "tags": []}], "date": 1506961796, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7875": {"changesets": [{"author": "Prathiksha \u003cprathikshaprasadsuman@gmail.com\u003e", "branch": "default", "desc": "Bug 1400219 - Align permission status menulists in the permission dialog with the header and adjust the menulist margin. r=johannh, a=ritu\n\nMozReview-Commit-ID: LaY1YaNZydg", "files": ["browser/components/preferences/sitePermissions.css", "browser/components/preferences/sitePermissions.js"], "git_node": null, "git_parents": [null], "node": "5fba16e588e6616d20ae3ba638bd42a50a4e2f43", "parents": ["c7b47e1282c2b96e8d440da60784e6dbae234770"], "tags": []}, {"author": "Prathiksha \u003cprathikshaprasadsuman@gmail.com\u003e", "branch": "default", "desc": "Bug 1402287 - Stop the separator in the permissions dialog header from moving. r=johannh, a=ritu\n\nMozReview-Commit-ID: LuEoUZ4K5Cz", "files": ["browser/components/preferences/sitePermissions.xul"], "git_node": null, "git_parents": [null], "node": "092cc740306c0817739e9b64a8edef56cfa29168", "parents": ["5fba16e588e6616d20ae3ba638bd42a50a4e2f43"], "tags": []}, {"author": "Dylan Roeh \u003cdroeh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399504 - Pass more information to Intent:OpenNoHandler callback so that fallback urls may always be handled correctly. r=jchen, a=ritu", "files": ["mobile/android/base/java/org/mozilla/gecko/IntentHelper.java", "mobile/android/components/ContentDispatchChooser.js"], "git_node": null, "git_parents": [null], "node": "8306dea5fd57a0621d7686bd471bcce2ea628609", "parents": ["092cc740306c0817739e9b64a8edef56cfa29168"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1402493 - Don't prevent switching back to Reload for top level about: loads. r=Gijs, a=ritu\n\nIn the steps to reproduce of this bug, we get see a load start for about:blank that is not top level. We then see a following load complete (STATE_STOP) that has aWebProgress.isTopLevel=true. This code is really here to prevent flickering from reload-\u003estop-\u003ereload for about:home and other about: pages. I don't see any harm in being more agressive when switching back to Reload since that is the default state.\n\nMozReview-Commit-ID: 3LygnRLcbA9", "files": ["browser/base/content/browser.js"], "git_node": null, "git_parents": [null], "node": "0fe06c5dd3958544f851cbbe9360a4fb934c66eb", "parents": ["8306dea5fd57a0621d7686bd471bcce2ea628609"], "tags": []}, {"author": "David Anderson \u003cdanderson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403353 - Block D3D11 when using Intel drivers on Windows 7 systems with partial AVX support. r=jrmuizel, a=ritu", "files": ["widget/windows/GfxInfo.cpp"], "git_node": null, "git_parents": [null], "node": "f01e95e090c5179382f9c3ba814ad89a0515ba61", "parents": ["0fe06c5dd3958544f851cbbe9360a4fb934c66eb"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1390885 - Remove code that adjusts the titlebar to drawing lwthemes inside the titlebar. r=nhnt11, a=ritu\n\nWe got rid of drawing lwthemes inside the titlebar on OSX in bug 1392219 but\nthere was still some code that adjusted the titlebar, which we forgot\nremove. Incidentally, that code was also causing a bug (even before we\nremoved the in-titlebar drawing) which we now don't need to worry about\nanymore now.\n\nMozReview-Commit-ID: 44HR25Uyp8B", "files": ["browser/base/content/browser-tabsintitlebar.js", "toolkit/modules/LightweightThemeConsumer.jsm"], "git_node": null, "git_parents": [null], "node": "10c0c1c42bfd72fe2ba097308060f568d3db0ed9", "parents": ["f01e95e090c5179382f9c3ba814ad89a0515ba61"], "tags": []}, {"author": "Sean Lee \u003cselee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401411 - All name related fields should be counted as 1 field only when creating the records. r=lchang, a=sledru\n\nMozReview-Commit-ID: 468B9tlFH3p", "files": ["browser/extensions/formautofill/FormAutofillHandler.jsm", "browser/extensions/formautofill/test/unit/test_createRecords.js"], "git_node": null, "git_parents": [null], "node": "e28be96825217be0417ca5e3bc27d5d6eb83c2eb", "parents": ["10c0c1c42bfd72fe2ba097308060f568d3db0ed9"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1401943 - Make reload button work immediately after a tab detach. r=jaws, a=sledru\n\nMozReview-Commit-ID: 58Tvbz6RrnO", "files": ["browser/base/content/browser.js"], "git_node": null, "git_parents": [null], "node": "307f151ecf046ba6b31000f5c704484326401ca5", "parents": ["e28be96825217be0417ca5e3bc27d5d6eb83c2eb"], "tags": []}, {"author": "Nihanth Subramanya \u003cnhnt11@gmail.com\u003e", "branch": "default", "desc": "Bug 1402614 - Ensure findbar buttons inherit foreground color. r=johannh, a=sledru\n\nMozReview-Commit-ID: 9eHwwkX9tMF", "files": ["browser/themes/shared/compacttheme.inc.css"], "git_node": null, "git_parents": [null], "node": "049d652d6d74206d16fd1af64fcad57e662799a8", "parents": ["307f151ecf046ba6b31000f5c704484326401ca5"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1402981 - Add light and dark themes to the list of themes in customize mode by default. r=jaws, a=sledru\n\nMozReview-Commit-ID: 4GxPEm119Yc", "files": ["browser/components/customizableui/CustomizeMode.jsm", "browser/components/customizableui/test/browser_1007336_lwthemes_in_customize_mode.js"], "git_node": null, "git_parents": [null], "node": "0ceab176791157db123c2cf05a8dfd759c366e68", "parents": ["049d652d6d74206d16fd1af64fcad57e662799a8"], "tags": []}, {"author": "J.C. Jones \u003cjjones@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403279 - Set U2F version field on RegisterResponse. r=keeler, a=sledru\n\nThe U2F specification defines the RegisterResponse.Version field as being set to\n\"U2F_V2\" [1] on successful registrations, which we appear to have overlooked.\n\nThis sets the field and adds a few checks to the register test.\n\n\n[1] https://www.fidoalliance.org/specs/fido-u2f-v1.1-id-20160915/fido-u2f-javascript-api-v1.1-id-20160915.html#idl-def-RegisterResponse\n\nMozReview-Commit-ID: 9YqhM0x9itd", "files": ["dom/u2f/U2F.cpp", "dom/u2f/U2FAuthenticator.h", "dom/u2f/U2FManager.cpp", "dom/u2f/tests/frame_register.html"], "git_node": null, "git_parents": [null], "node": "cfde20f68c1fa8cfdb09fc8d3dc996a3f9a94b3e", "parents": ["0ceab176791157db123c2cf05a8dfd759c366e68"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403433 - Add another variant of SchedulePaint that does not call InvalidateRenderingObservers for PendingAnimationTracker. r=birtles, a=sledru\n\nnsFrame::SchedulePaint() invokes InvalidateRenderingObservers, and\nInvalidateRenderingObservers ends up posting change hints during we are\nprocessing sequential tasks for animations, but we don't allow posting any\nchange hints while we are in the middle of restyling process.\n\nThough the change hints posted by InvalidateRenderingObservers are not harmful\nin this case since the change hints will be processed in a second post\ntraversal without problems.  That's said, InvalidateRenderingObservers stuff\nshould be processed in display list based invalidation anyway (bug 1284053).\n\nMozReview-Commit-ID: GKVRZ98lvEN", "files": ["dom/animation/PendingAnimationTracker.cpp", "layout/generic/nsFrame.cpp", "layout/generic/nsIFrame.h", "layout/style/crashtests/1403433.html", "layout/style/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "f4e84e6ed76d2fa4459cedc83bd2a3764767fcc7", "parents": ["cfde20f68c1fa8cfdb09fc8d3dc996a3f9a94b3e"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "Bug 1404098 - Don't disable multi for extensions. r=krizsa, a=sledru\n\nNow that the addons code will refuse to allow any non-webextension that hasn't\nbeen vetted to work with e10s-multi, we can allow all extensions in the\nrollout addon.\n\nMozReview-Commit-ID: L8RVJDTo7Ir", "files": ["browser/extensions/e10srollout/bootstrap.js", "browser/extensions/e10srollout/install.rdf.in"], "git_node": null, "git_parents": [null], "node": "8d3464b1fd54fa48bc42ae51bdd365bbb40d1c1d", "parents": ["f4e84e6ed76d2fa4459cedc83bd2a3764767fcc7"], "tags": []}], "date": 1506964619, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7876": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1397557 - Skip the pdf.js browser-chrome tests on debug builds due to shutdown leaks. a=test-only", "files": ["browser/extensions/pdfjs/test/browser.ini"], "git_node": null, "git_parents": [null], "node": "3b5a6259ec274e37dffcc5e05a63c319d15ff3c7", "parents": ["8d3464b1fd54fa48bc42ae51bdd365bbb40d1c1d"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1404246 - Fix disabled scroll buttons in the tabs toolbar on Windows properly. r=dao, a=ritu\n\nMozReview-Commit-ID: AjBDcRXjoFt", "files": ["browser/themes/shared/tabs.inc.css", "browser/themes/windows/browser.css", "browser/themes/windows/compacttheme.css"], "git_node": null, "git_parents": [null], "node": "f4474cbb84b465508a6e0cb8df5038486397f765", "parents": ["3b5a6259ec274e37dffcc5e05a63c319d15ff3c7"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1404248 - Remove excess space between the address bar and the menu button in popups. r=nhnt11, a=sledru\n\nMozReview-Commit-ID: 8lY9wNO2kKH", "files": ["browser/themes/shared/urlbar-searchbar.inc.css"], "git_node": null, "git_parents": [null], "node": "03e6331a76b5d90e43375cae07f61f4585967806", "parents": ["f4474cbb84b465508a6e0cb8df5038486397f765"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1402309 - Fix titlebar-fullscreen-button vertical alignment. r=johannh, a=sledru\n\nMozReview-Commit-ID: 1UXqWriWSaL", "files": ["browser/themes/osx/browser.css"], "git_node": null, "git_parents": [null], "node": "2ad2dfbbb93af990374c13b63810d71792016ed0", "parents": ["03e6331a76b5d90e43375cae07f61f4585967806"], "tags": []}, {"author": "Alessio Placitelli \u003calessio.placitelli@gmail.com\u003e", "branch": "default", "desc": "Bug 1403978 - Add 'browser.search.widget.inNavBar' to TelemetryEnvironment. r=chutten, data-review=rweiss, a=sledru\n\nMozReview-Commit-ID: 1N0wK6M0bXu", "files": ["toolkit/components/telemetry/TelemetryEnvironment.jsm"], "git_node": null, "git_parents": [null], "node": "cd59a9732166353a0e9528f2e7f1cf5f1f8380d0", "parents": ["2ad2dfbbb93af990374c13b63810d71792016ed0"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1404167 - Properly update the styles of first-letter childs of anon boxes. r=bz, a=sledru\n\nMozReview-Commit-ID: Cyxs4FxGj6B\nSigned-off-by: Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "files": ["layout/base/ServoRestyleManager.cpp", "layout/generic/nsBlockFrame.cpp", "layout/reftests/first-letter/1404167-1-ref.html", "layout/reftests/first-letter/1404167-1.html", "layout/reftests/first-letter/1404167-2-ref.html", "layout/reftests/first-letter/1404167-2.html", "layout/reftests/first-letter/1404167-3-ref.html", "layout/reftests/first-letter/1404167-3.html", "layout/reftests/first-letter/1404167-4-ref.html", "layout/reftests/first-letter/1404167-4.html", "layout/reftests/first-letter/reftest.list"], "git_node": null, "git_parents": [null], "node": "3f6b01c6cc57d3133065c89c1ea29a6093482a81", "parents": ["cd59a9732166353a0e9528f2e7f1cf5f1f8380d0"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1396423 - Make it possible to drop items in what visually looks like the palette but isn't. r=mikedeboer, a=sledru\n\nMozReview-Commit-ID: AqBwn9ovTjT", "files": ["browser/components/customizableui/CustomizeMode.jsm", "browser/components/customizableui/test/browser.ini", "browser/components/customizableui/test/browser_drag_outside_palette.js"], "git_node": null, "git_parents": [null], "node": "2a998e14f67b14a22be169b3f428bab496db76d6", "parents": ["3f6b01c6cc57d3133065c89c1ea29a6093482a81"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1400189 - Give same priority to composition events and selectionset event as keyboard events at sending those events from the main process to a remote process. r=stone, a=sledru\n\nWhen sending keyboard events from TabParent to its remote process, TabParent\nmay give higher priority to them than composition events and selectionset event.\n\nTherefore, the event order between keyboard events and composition events (and\nselection set event) may be broken.  Keyboard events which should cause\ninputting some characters are ignored if keyboard events are fired before\ncompositionend event accidentally.\n\nThis patch gives same priority to composition events and selectionset event\nas keyboard event for avoiding breaking the event order.\n\nMozReview-Commit-ID: 53jubwuHVvw", "files": ["dom/ipc/PBrowser.ipdl", "dom/ipc/TabChild.cpp", "dom/ipc/TabChild.h", "dom/ipc/TabParent.cpp"], "git_node": null, "git_parents": [null], "node": "89d8e11182d28d1114fdb5dd1ed70c9a0fc7836b", "parents": ["2a998e14f67b14a22be169b3f428bab496db76d6"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1400057 - Override _wantsFloatingTitlebar to return NO in order to avoid titlebar glitches on 10.13. r=spohl, a=sledru\n\nMozReview-Commit-ID: 4HffFOSqWxl", "files": ["widget/cocoa/nsCocoaWindow.mm"], "git_node": null, "git_parents": [null], "node": "ba626b811d73e72eb422a462645434feaf26f4da", "parents": ["89d8e11182d28d1114fdb5dd1ed70c9a0fc7836b"], "tags": []}, {"author": "Christoph Kerschbaumer \u003cckerschb@christophkerschbaumer.com\u003e", "branch": "default", "desc": "Bug 1402363 - Explicitly cancel channel after mixed content redirect. r=honza, r=kate, a=ritu", "files": ["dom/security/nsMixedContentBlocker.cpp"], "git_node": null, "git_parents": [null], "node": "e28505bd7c0402f9b778956c214becf896032799", "parents": ["ba626b811d73e72eb422a462645434feaf26f4da"], "tags": []}, {"author": "Christoph Kerschbaumer \u003cckerschb@christophkerschbaumer.com\u003e", "branch": "default", "desc": "Bug 1402363 - Test Mixed Content Redirect Blocking. r=tanvi, r=kate, a=ritu", "files": ["dom/security/test/mixedcontentblocker/file_redirect.html", "dom/security/test/mixedcontentblocker/file_redirect_handler.sjs", "dom/security/test/mixedcontentblocker/mochitest.ini", "dom/security/test/mixedcontentblocker/test_redirect.html"], "git_node": null, "git_parents": [null], "node": "37d18f6628dcecba2f3f59a3d853071b7ca799e0", "parents": ["e28505bd7c0402f9b778956c214becf896032799"], "tags": ["DEVEDITION_57_0b5_RELEASE", "FIREFOX_57_0b5_BUILD1", "FIREFOX_57_0b5_RELEASE"]}], "date": 1506968126, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7877": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump\n\nda -\u003e 7eedc20f6fb9\npl -\u003e 17cd815214ab", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "2cc69216f323ea33c977f7186b0b5668707c88f1", "parents": ["37d18f6628dcecba2f3f59a3d853071b7ca799e0"], "tags": ["FENNEC_57_0b5_BUILD1", "FENNEC_57_0b5_RELEASE"]}], "date": 1506974424, "git_changesets": [null], "user": "ffxbld"}, "7878": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump\n\naz -\u003e e7a0f15cfbf1\nda -\u003e 8653d93fb625\nfa -\u003e f18ac2114d19\nka -\u003e c1012cabf0ef", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "1d3559680c3ec9916e08f10c0007ed476ccfdff1", "parents": ["2cc69216f323ea33c977f7186b0b5668707c88f1"], "tags": []}], "date": 1507006858, "git_changesets": [null], "user": "ffxbld"}, "7879": {"changesets": [{"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "THUNDERBIRD560b4_2017092101_RELBRANCH", "desc": "Bug 1405177: Install (slightly) newer pip to install boto. r=nthomas a=jorgk DONTBUILD", "files": ["testing/mozharness/scripts/release/antivirus.py", "testing/mozharness/scripts/release/push-candidate-to-releases.py"], "git_node": null, "git_parents": [null], "node": "fc8717f81711e1c12f7fd4a2ebe419dadaec1ed2", "parents": ["dc62e9442e97c77e852794130fe42fcb7d639ec6"], "tags": []}], "date": 1507025512, "git_changesets": [null], "user": "mozilla@jorgk.com"}, "7880": {"changesets": [{"author": "J.C. Jones \u003cjjones@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399334 - Workaround buggy pki.js cert verifier implementation. r=keeler, a=test-only\n\nThere's an intermittent on the call attestationCert.verify() to test the self-\nsigned cert from our not-shipped software U2F implementation. Collection of the\nintermittents shows these certs are fine, and should verify correctly, but they\ndon't. The bug must be in pki.js, which is out-of-scope as we only use it for\nmochitests.\n\nThis patch removes the offending call to xxxx.verify(), because it doesn't\nreally matter whether the self-signed-cert looks OK to pki.js; we just need\nthe public key from inside it to proceed with the rest of the tests.\n\nAs an example of a so-called \"invalid\" self-signed cert that failed, we have:\n\nhttps://treeherder.mozilla.org/logviewer.html#?repo=mozilla-central&job_id=134282931&lineNumber=2673\n\n-----BEGIN CERTIFICATE-----\nMIIBMTCB2aADAgECAgUA55x6LTAKBggqhkjOPQQDAjAhMR8wHQYDVQQDExZGaXJl\nZm94IFUyRiBTb2Z0IFRva2VuMB4XDTE3MDkzMDE5MjIzMloXDTE3MTAwMjE5MjIz\nMlowITEfMB0GA1UEAxMWRmlyZWZveCBVMkYgU29mdCBUb2tlbjBZMBMGByqGSM49\nAgEGCCqGSM49AwEHA0IABIWu4L8ky7s8I7qVv+JwMRHpippH4b6h7rN0jlKpFbHK\nhnEwaCPLrTx04Eh9xT4GK9JWuuP759hnAxsWD5wk0H0wCgYIKoZIzj0EAwIDRwAw\nRAIgRIeRcn6LkwU8VOmX+mdQ3jUQrUOp5f2xH/qBECGi5EcCIADBjsm/EDKkAwLZ\npGdX7+N+kgf9No4uuLV4dsNVJ1pa\n-----END CERTIFICATE-----\n\nThere's nothing wrong with this cert, actually. Checking it with OpenSSL shows\nall OK:\n\nopenssl verify -purpose any -CAfile /tmp/cert2.pem /tmp/cert2.pem\n/tmp/cert2.pem: OK\n\nSo this intermittent is a bug outside of our U2F and U2F test soft token code.\n\nMozReview-Commit-ID: K142toVWtcv", "files": ["dom/u2f/tests/frame_register_sign.html"], "git_node": null, "git_parents": [null], "node": "f66ff4d9ddbe3b16d9cbd7850f48e17ec0a7a3f6", "parents": ["1d3559680c3ec9916e08f10c0007ed476ccfdff1"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1388764 - Skip test_iframe_sandbox_plugins.html on debug builds for frequent mozilla::ipc::MessageChannel::WillDestroyCurrentMessageLoop() shutdown crashes. r=qdot, a=test-only", "files": ["dom/html/test/mochitest.ini"], "git_node": null, "git_parents": [null], "node": "de6b8900aa7becfb2dd025c5850e32cb1500d22d", "parents": ["f66ff4d9ddbe3b16d9cbd7850f48e17ec0a7a3f6"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1394963 - Skip browser_newtab_fullscreen_focus.js on osx/debug for 200+ failures. a=test-only", "files": ["browser/base/content/test/newtab/browser.ini"], "git_node": null, "git_parents": [null], "node": "b91a3fcbb6c6fb2c2e8ef8faaa2717ee52636e81", "parents": ["de6b8900aa7becfb2dd025c5850e32cb1500d22d"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1392396 - Skip xpcshell test_IE_bookmarks.js on Windows for 200+ failures. a=test-only", "files": ["browser/components/migration/tests/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "5cc64824d09156b007edc54d2189a62566f3ff78", "parents": ["b91a3fcbb6c6fb2c2e8ef8faaa2717ee52636e81"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399854 - Skip test browser_newtab_overrides.js for 200+ failures. a=test-only", "files": ["browser/components/newtab/tests/browser/browser.ini"], "git_node": null, "git_parents": [null], "node": "b359993bc563d9610f4ffe2ea86193428704ad08", "parents": ["5cc64824d09156b007edc54d2189a62566f3ff78"], "tags": []}], "date": 1507035315, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7881": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "Automatic version bump. CLOSED TREE NO BUG a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "3fa22ee09c85846feca5cb066c060dc0d6448f6d", "parents": ["b359993bc563d9610f4ffe2ea86193428704ad08"], "tags": []}, {"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging 3