Highlights title. r=mcomella\n\nMozReview-Commit-ID: GHXKAhlbc7I", "files": ["mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/HighlightsDividerItemDecoration.java"], "git_node": null, "git_parents": [null], "node": "802042e3b5e061a3e832289021e02e6ac7718377", "parents": ["517ccb27a05c7dd0fa5bc16488cfe6c24106de62"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 6aa63fcf5c4e (bug 1373853) for leaking preferences windows, e.g. after browser-chrome's browser/base/content/test/general/browser_bug735471.js ran. r=backout", "files": ["browser/components/preferences/in-content/main.js", "browser/components/preferences/in-content/main.xul", "browser/components/preferences/in-content/tests/addons/set_newtab.xpi", "browser/components/preferences/in-content/tests/browser.ini", "browser/components/preferences/in-content/tests/browser_extension_controlled.js", "browser/components/preferences/in-content/tests/browser_homepages_filter_aboutpreferences.js", "browser/locales/en-US/chrome/browser/preferences/preferences.properties", "browser/themes/shared/incontentprefs/preferences.inc.css"], "git_node": null, "git_parents": [null], "node": "50ed4d668bf776fc022d8306fe90e2c6e6eca0b8", "parents": ["802042e3b5e061a3e832289021e02e6ac7718377"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401651 - Remove obsolete documentation entries. r=cpeterson\n\nMozReview-Commit-ID: FNmqm8cjj15", "files": ["build/docs/mozinfo.rst"], "git_node": null, "git_parents": [null], "node": "a88a995faeedd735e3d3e737e17de2e2e46ea6ee", "parents": ["50ed4d668bf776fc022d8306fe90e2c6e6eca0b8"], "tags": []}, {"author": "Kearwood \"Kip\" Gilbert \u003ckgilbert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1381085 - Submit VR frames with a separate ID3DDeviceContextState r=daoshengmu\n- Using a separate ID3DDeviceContextState ensures\n  that the WebVR context does not stomp over the\n  mirrored state used by the MLGPU \"Advanced\" Layers rendering.\nMozReview-Commit-ID: 99mfdsjFrMI", "files": ["gfx/vr/VRDisplayHost.cpp", "gfx/vr/VRDisplayHost.h", "gfx/vr/gfxVROculus.cpp", "gfx/vr/gfxVROculus.h", "gfx/vr/gfxVRPuppet.cpp", "gfx/vr/gfxVRPuppet.h"], "git_node": null, "git_parents": [null], "node": "8e98f894a8a322859c307c84778eada9444a5dfd", "parents": ["a88a995faeedd735e3d3e737e17de2e2e46ea6ee"], "tags": []}, {"author": "Tom Tromey \u003ctom@tromey.com\u003e", "branch": "default", "desc": "Bug 1399911 - preserve sourceURL comment directive on style sheets; r=bz,heycam\n\nIn addition to the sourceMappingURL comment, there is a second special\ncomment, \"sourceURL\", that can be used to set the \"display name\" of a\nstyle sheet for developer tools.  This name is also used as the base\nURL for the source-map URL resolution algorithm.  sourceURL is\ndescribed here:\nhttps://blog.getfirebug.com/2009/08/11/give-your-eval-a-name-with-sourceurl/\n\nThis patch changes Firefox to record this URL, if specified, and to\nexpose it (chrome-only) vai StyleSheet.webidl.\n\nMozReview-Commit-ID: 7NwXsOf7nbY", "files": ["dom/webidl/StyleSheet.webidl", "layout/style/ServoBindingList.h", "layout/style/ServoStyleSheet.cpp", "layout/style/StyleSheet.cpp", "layout/style/StyleSheet.h", "layout/style/StyleSheetInfo.h", "layout/style/nsCSSParser.cpp", "layout/style/nsCSSScanner.cpp", "layout/style/nsCSSScanner.h", "layout/style/test/browser.ini", "layout/style/test/browser_sourceurl_comment.js"], "git_node": null, "git_parents": [null], "node": "2d5c378f56108610c674b8ba8147f969c166ef48", "parents": ["8e98f894a8a322859c307c84778eada9444a5dfd"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "servo: Merge #18572 - Handle !important in keyframe (from hiikezoe:immportant-in-keyframe); r=emilio\n\n\u003c!-- Please describe your changes on the following line: --\u003e\nhttps://bugzilla.mozilla.org/show_bug.cgi?id=1400926\n\n---\n- [X] `./mach build -d` does not report any errors\n- [X] `./mach test-tidy` does not report any errors\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 46ae11b5d03a4935f5a8594269ea14ae2594c2c2", "files": ["servo/components/style/animation.rs", "servo/components/style/properties/declaration_block.rs", "servo/components/style/stylesheets/keyframes_rule.rs", "servo/ports/geckolib/glue.rs"], "git_node": null, "git_parents": [null], "node": "89b1fac5342d401365727928dedc87254a7ec748", "parents": ["2d5c378f56108610c674b8ba8147f969c166ef48"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401683 - Add section deduping, about:home telemetry and bug fixes to Activity Stream. r=k88hudson\n\nMozReview-Commit-ID: FYICIp1oVNf", "files": ["browser/extensions/activity-stream/common/Actions.jsm", "browser/extensions/activity-stream/common/PerfService.jsm", "browser/extensions/activity-stream/common/Reducers.jsm", "browser/extensions/activity-stream/data/content/activity-stream-initial-state.js", "browser/extensions/activity-stream/data/content/activity-stream.bundle.js", "browser/extensions/activity-stream/data/content/activity-stream.css", "browser/extensions/activity-stream/data/locales.json", "browser/extensions/activity-stream/install.rdf.in", "browser/extensions/activity-stream/lib/ActivityStream.jsm", "browser/extensions/activity-stream/lib/HighlightsFeed.jsm", "browser/extensions/activity-stream/lib/LinksCache.jsm", "browser/extensions/activity-stream/lib/Screenshots.jsm", "browser/extensions/activity-stream/lib/SectionsManager.jsm", "browser/extensions/activity-stream/lib/Store.jsm", "browser/extensions/activity-stream/lib/TelemetryFeed.jsm", "browser/extensions/activity-stream/lib/TopSitesFeed.jsm", "browser/extensions/activity-stream/test/schemas/pings.js", "browser/extensions/activity-stream/test/unit/common/Reducers.test.js", "browser/extensions/activity-stream/test/unit/lib/ActivityStream.test.js", "browser/extensions/activity-stream/test/unit/lib/HighlightsFeed.test.js", "browser/extensions/activity-stream/test/unit/lib/SectionsManager.test.js", "browser/extensions/activity-stream/test/unit/lib/Store.test.js", "browser/extensions/activity-stream/test/unit/lib/TelemetryFeed.test.js", "browser/extensions/activity-stream/test/unit/lib/TopSitesFeed.test.js", "browser/modules/PingCentre.jsm"], "git_node": null, "git_parents": [null], "node": "dc35a4abe1305e0ab3638b695d2734e8de7d2329", "parents": ["89b1fac5342d401365727928dedc87254a7ec748"], "tags": []}, {"author": "Justin Wood \u003cCallek@gmail.com\u003e", "branch": "default", "desc": "Bug 1401546 - Flip windows spidermonkey jobs in taskcluster to tier 1. r=sfink\n\nMozReview-Commit-ID: Ejcb0P5moju", "files": ["taskcluster/ci/spidermonkey/kind.yml"], "git_node": null, "git_parents": [null], "node": "ebf0a7b3181733d31d75e2498255782580ec147b", "parents": ["dc35a4abe1305e0ab3638b695d2734e8de7d2329"], "tags": []}, {"author": "Mehdi Soleimannejad \u003cmehdisolamannejad@gmail.com\u003e", "branch": "default", "desc": "Bug 1401336 - Make user-initiated syncs ignore account sync settings. r=Grisha Kruglov\n\nMozReview-Commit-ID: JkMQb5f0yVM", "files": ["mobile/android/base/java/org/mozilla/gecko/home/CombinedHistoryPanel.java", "mobile/android/base/java/org/mozilla/gecko/overlays/service/sharemethods/SendTab.java", "mobile/android/services/src/main/java/org/mozilla/gecko/fxa/FirefoxAccounts.java", "mobile/android/services/src/main/java/org/mozilla/gecko/fxa/FxAccountPushHandler.java", "mobile/android/services/src/main/java/org/mozilla/gecko/fxa/activities/FxAccountStatusFragment.java", "mobile/android/services/src/main/java/org/mozilla/gecko/fxa/authenticator/AndroidFxAccount.java", "mobile/android/services/src/main/java/org/mozilla/gecko/fxa/receivers/FxAccountUpgradeReceiver.java", "mobile/android/services/src/main/java/org/mozilla/gecko/fxa/sync/FxAccountSyncAdapter.java"], "git_node": null, "git_parents": [null], "node": "e740ebb21e460f2882d72829258fdb0e9075e67b", "parents": ["ebf0a7b3181733d31d75e2498255782580ec147b"], "tags": []}, {"author": "Alan Jeffrey \u003cajeffrey@mozilla.com\u003e", "branch": "default", "desc": "servo: Merge #18578 - Window should own Location, Document shouldn't (from asajeffrey:script-window-owns-location); r=KiChjang\n\n\u003c!-- Please describe your changes on the following line: --\u003e\n\nDocument shouldn't own location, Window should.\n\n---\n\u003c!-- Thank you for contributing to Servo! Please replace each `[ ]` by `[X]` when the step is complete, and replace `__` with appropriate data: --\u003e\n- [X] `./mach build -d` does not report any errors\n- [X] `./mach test-tidy` does not report any errors\n- [X] These changes fix #18438\n- [X] These changes do not require tests because it's an intermittent\n\n\u003c!-- Also, please make sure that \"Allow edits from maintainers\" checkbox is checked, so that we can help you if you get stuck somewhere along the way.--\u003e\n\n\u003c!-- Pull requests that do not address these steps are welcome, but they will require additional verification as part of the review process. --\u003e\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 6a791cd7f26b42a6688099bea203c21fb3c9cc12", "files": ["servo/components/script/dom/document.rs", "servo/components/script/dom/window.rs"], "git_node": null, "git_parents": [null], "node": "6a151f43cb3f70917bde1ace58a9d118776e70b9", "parents": ["e740ebb21e460f2882d72829258fdb0e9075e67b"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399505 - Expose the API to add sticky frames to the WR display list. r=mstange\n\nMozReview-Commit-ID: Dunn5AeTJiw", "files": ["gfx/layers/LayersLogging.cpp", "gfx/layers/LayersLogging.h", "gfx/webrender_bindings/WebRenderAPI.cpp", "gfx/webrender_bindings/WebRenderAPI.h", "gfx/webrender_bindings/WebRenderTypes.h", "gfx/webrender_bindings/src/bindings.rs", "gfx/webrender_bindings/webrender_ffi_generated.h"], "git_node": null, "git_parents": [null], "node": "40af6e459538e579da800aebb6520cdaa9b30e40", "parents": ["6a151f43cb3f70917bde1ace58a9d118776e70b9"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399505 - Generate WR sticky frames from nsDisplayStickyPosition display items. r=mstange\n\nMozReview-Commit-ID: 4eKZRitTDqu", "files": ["gfx/layers/wr/StackingContextHelper.cpp", "gfx/layers/wr/StackingContextHelper.h", "layout/painting/nsDisplayList.cpp", "layout/painting/nsDisplayList.h", "layout/reftests/async-scrolling/reftest.list"], "git_node": null, "git_parents": [null], "node": "fd7e2ce2fc920893e864191b19477cd2a9f5cd89", "parents": ["40af6e459538e579da800aebb6520cdaa9b30e40"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "Bug 1401412 - Destroy this singleton during XPCOM shutdown. r=smaug\n\nUnfortunately, this needed some additional trickery in order to keep its\nconstructor \"private\". I stole this trick from [1]. With this patch, we tear\ndown the statistics object during XPCOM shutdown intead of after it. I don't\nbelieve that we need the object to live past the ClearOnShutdown destructors.\n\n[1] http://rienajouter.blogspot.com/2014/10/makeshared-and-makeunique-for-classes.html\n\nMozReview-Commit-ID: JsiN6Bq9Yp4", "files": ["xpcom/threads/InputEventStatistics.cpp", "xpcom/threads/InputEventStatistics.h"], "git_node": null, "git_parents": [null], "node": "5a44548cb570c0cc7fd5c188f5f7694a11e66fa4", "parents": ["fd7e2ce2fc920893e864191b19477cd2a9f5cd89"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 335545 - Use nsAnonymousTemporaryFile for clipboard cache r=mstange\n\nThe cache file is never directly exposed to consumers of DataStruct,\nso it does not make sense to keep the clipboardcache file around\nforever.\n\nThe only change in this commit is to switch from using a filename to\nusing a file descriptor. In the destructor, the FD is explicitly closed\n(which releases the file data).  nsAnonymousTemporaryFile takes care\nof removing the file when the destructor is not called (e.g. crashes).\n\nPreviously, the clipboard cache was stored in a file called:\nTmpD/clipboardcache-N\n\nAs of this commit, the clipboard cache is stored at:\nTmpD/mozilla-temp-randomN (macOS and Linux)\nTmpD/mozilla-temp-files/mozilla-temp-randomN (Windows)\n(see xpcom/io/nsAnonymousTemporaryFile.{h,cpp} for more details)\n\nTo verify that these files are really gone:\n1. Create a document with 500k+ characters, open it in Firefox.\n2. Copy its content - this will trigger the clipboard cache.\n3. Look for the open file descriptor of the deleted file:\n   ( macOS and Linux: )\n   lsof +L1 | grep mozilla-temp\n4. Copy anything (under the 500k threshold), or quit/kill Firefox.\n5. Repeat step 3 and observe that the number of file descriptors\n   has decreased.\n\nMozReview-Commit-ID: 85GlKQrNUl5", "files": ["widget/nsTransferable.cpp", "widget/nsTransferable.h"], "git_node": null, "git_parents": [null], "node": "dff1e1774422c12aacff69538936e88f0ff95c85", "parents": ["5a44548cb570c0cc7fd5c188f5f7694a11e66fa4"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 335545 - Store clipboard data in memory XOR file r=mstange\n\nEnsure that only DataStruct::mData + mDataLen, XOR\nDataStruct::mCacheFD is used.\n(Previously it was possible that all of these members were populated,\n which is a waste of memory.)\n\nThe effect of this change is visible when SetTransferData is called\nmultiple times with the same flavor, but with one below the threshold\nfor storing in-memory, and the other above (=store in a file).\n\nMozReview-Commit-ID: 4UlkKAYsjf", "files": ["widget/nsTransferable.cpp", "widget/nsTransferable.h"], "git_node": null, "git_parents": [null], "node": "e96494792b66b2b7d8199d532164a3d23f66b004", "parents": ["dff1e1774422c12aacff69538936e88f0ff95c85"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1401394: Add missing gecko:itemType to non-phone configurations. r=liuche\n\nI don't know the greater context of this code and if this will cause any problems: I'm just following the patterns in Android menus to fix this code.\n\n:aswan is expected to test this patch for me (or provide me steps to test\nwhether or not it's working correctly).\n\nMozReview-Commit-ID: 9WrqUokwmXT", "files": ["mobile/android/app/src/main/res/menu-large-v26/browser_app_menu.xml", "mobile/android/app/src/main/res/menu-large/browser_app_menu.xml", "mobile/android/app/src/main/res/menu-v26/browser_app_menu.xml", "mobile/android/app/src/main/res/menu-xlarge-v26/browser_app_menu.xml", "mobile/android/app/src/main/res/menu-xlarge/browser_app_menu.xml"], "git_node": null, "git_parents": [null], "node": "b5be4a3d9f13e924f02cbb2ee6d5871c6f026486", "parents": ["e96494792b66b2b7d8199d532164a3d23f66b004"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "Bug 1398393 - Set Servo thread state on cooperative threads. r=billm\n\nBy doing this we avoid triggering assertions in the Servo code that ensure\nwe have registered the thread with Servo and set the proper state on it.\n\nMozReview-Commit-ID: K6qHrYoQDLm", "files": ["layout/style/ServoBindingList.h", "xpcom/threads/CooperativeThreadPool.cpp", "xpcom/threads/Scheduler.cpp"], "git_node": null, "git_parents": [null], "node": "785910c8bee719b14fd14a2fe64b260429449b3a", "parents": ["b5be4a3d9f13e924f02cbb2ee6d5871c6f026486"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400926 - Filter out !important property in keyframes for stylo. r=emilio\n\nMozReview-Commit-ID: 76AUpKLVL2n", "files": ["layout/style/crashtests/1400926.html", "layout/style/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "26f3a378ff0e95a74320d1dbe905776e30b67bda", "parents": ["785910c8bee719b14fd14a2fe64b260429449b3a"], "tags": []}, {"author": "Chris Manchester \u003ccmanchester@mozilla.com\u003e", "branch": "default", "desc": "Bug 1398897 - Do not emit compile flags for directories only containing rust libraries. r=glandium\n\nMozReview-Commit-ID: 94PFyi5VQux", "files": ["python/mozbuild/mozbuild/frontend/emitter.py", "python/mozbuild/mozbuild/test/frontend/test_emitter.py"], "git_node": null, "git_parents": [null], "node": "82f0e87bd0ef416dd878f992ab6a61376060d45a", "parents": ["26f3a378ff0e95a74320d1dbe905776e30b67bda"], "tags": []}, {"author": "Chris Manchester \u003ccmanchester@mozilla.com\u003e", "branch": "default", "desc": "Bug 1398897 - Move defines to computed compile flags. r=glandium\n\nMozReview-Commit-ID: CgQv79dYj7Y", "files": ["config/config.mk", "python/mozbuild/mozbuild/backend/recursivemake.py", "python/mozbuild/mozbuild/compilation/database.py", "python/mozbuild/mozbuild/frontend/context.py", "python/mozbuild/mozbuild/frontend/data.py", "python/mozbuild/mozbuild/frontend/emitter.py", "python/mozbuild/mozbuild/test/frontend/data/compile-defines/moz.build", "python/mozbuild/mozbuild/test/frontend/data/compile-defines/test1.c", "python/mozbuild/mozbuild/test/frontend/data/resolved-flags-error/moz.build", "python/mozbuild/mozbuild/test/frontend/data/resolved-flags-error/test1.c", "python/mozbuild/mozbuild/test/frontend/test_emitter.py"], "git_node": null, "git_parents": [null], "node": "300708364bfb309249b537f652887d0518ca1df2", "parents": ["82f0e87bd0ef416dd878f992ab6a61376060d45a"], "tags": []}, {"author": "Chris Manchester \u003ccmanchester@mozilla.com\u003e", "branch": "default", "desc": "Bug 1398897 - Move includes to computed flags. r=glandium\n\nMozReview-Commit-ID: Ec0wZfoV63B", "files": ["config/config.mk", "config/rules.mk", "python/mozbuild/mozbuild/compilation/database.py", "python/mozbuild/mozbuild/frontend/context.py", "python/mozbuild/mozbuild/frontend/emitter.py", "python/mozbuild/mozbuild/test/frontend/data/compile-includes/moz.build", "python/mozbuild/mozbuild/test/frontend/data/compile-includes/subdir/header.h", "python/mozbuild/mozbuild/test/frontend/data/compile-includes/test1.c", "python/mozbuild/mozbuild/test/frontend/test_emitter.py"], "git_node": null, "git_parents": [null], "node": "9b5a00094c49b9b85e1fb5ff13921c52a1975cd0", "parents": ["300708364bfb309249b537f652887d0518ca1df2"], "tags": []}, {"author": "Chris Manchester \u003ccmanchester@mozilla.com\u003e", "branch": "default", "desc": "Bug 1398897 - Move breakpad include munging to moz.build r=glandium\n\nUnfortunately this also needs to be kept in Makefile.in to handle\nother consumers of INCLUDES while we transition them.\n\nMozReview-Commit-ID: 9OYlu6Jv1XZ", "files": ["python/mozbuild/mozbuild/compilation/database.py", "toolkit/crashreporter/google-breakpad/src/common/moz.build"], "git_node": null, "git_parents": [null], "node": "ae4d0410545f5a85746dc7869e48b386f13b7032", "parents": ["9b5a00094c49b9b85e1fb5ff13921c52a1975cd0"], "tags": []}, {"author": "Chris Manchester \u003ccmanchester@mozilla.com\u003e", "branch": "default", "desc": "Bug 1398897 - Move includes associated with CPP_UNIT_TESTS to the CppUnitTests template. r=glandium\n\nMozReview-Commit-ID: DhjnzhAjoyy", "files": ["build/templates.mozbuild", "python/mozbuild/mozbuild/frontend/emitter.py"], "git_node": null, "git_parents": [null], "node": "e4ac1e17ffe51b34721a569b259d57cb6f965628", "parents": ["ae4d0410545f5a85746dc7869e48b386f13b7032"], "tags": []}, {"author": "Chris Manchester \u003ccmanchester@mozilla.com\u003e", "branch": "default", "desc": "Bug 1398897 - Move os includes to computed flags. r=glandium\n\nMozReview-Commit-ID: Ef1wu5fQo7M", "files": ["config/config.mk", "python/mozbuild/mozbuild/compilation/database.py", "python/mozbuild/mozbuild/frontend/context.py", "python/mozbuild/mozbuild/frontend/emitter.py", "python/mozbuild/mozbuild/frontend/gyp_reader.py", "python/mozbuild/mozbuild/test/frontend/test_emitter.py"], "git_node": null, "git_parents": [null], "node": "b4c11ce9704c7c358cb5d352e452f8dc8fd6f38e", "parents": ["e4ac1e17ffe51b34721a569b259d57cb6f965628"], "tags": []}, {"author": "Edouard Oger \u003ceoger@fastmail.com\u003e", "branch": "default", "desc": "Bug 1359279 - Renew GCM token/Push registration/FxA Registration on push registration expired. r=Grisha\n\nMozReview-Commit-ID: HFDjBBt9CBA", "files": ["mobile/android/services/src/main/java/org/mozilla/gecko/fxa/devices/FxAccountDevice.java", "mobile/android/services/src/main/java/org/mozilla/gecko/fxa/devices/FxAccountDeviceListUpdater.java", "mobile/android/services/src/main/java/org/mozilla/gecko/fxa/devices/FxAccountDeviceRegistrator.java", "mobile/android/services/src/main/java/org/mozilla/gecko/fxa/sync/FxAccountSyncAdapter.java", "mobile/android/tests/background/junit4/src/org/mozilla/gecko/fxa/devices/TestFxAccountDeviceListUpdater.java", "mobile/android/tests/background/junit4/src/org/mozilla/gecko/fxa/login/MockFxAccountClient.java"], "git_node": null, "git_parents": [null], "node": "53e599ac1ed77ef24763069261996f916255edc2", "parents": ["b4c11ce9704c7c358cb5d352e452f8dc8fd6f38e"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1401453 - Don't keep libmemory.a separate anymore. r=gps\n\nThis was done in bug 736564 for the xulrunner SDK, which later became\nthe firefox SDK, which is now gone. So we don't actually need to keep it\nseparate anymore (except for logalloc/replay, which still needs to link\nit directly, so we keep the library definition intact so it can be\nreferenced ; we just don't DIST_INSTALL it anymore, and always make it\nlinked into mozglue)", "files": ["build/gecko_templates.mozbuild", "memory/build/moz.build"], "git_node": null, "git_parents": [null], "node": "0fb5cc4927b16358eb6fa8b6359c944ce077f1dc", "parents": ["53e599ac1ed77ef24763069261996f916255edc2"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset e96494792b66 (bug 335545)", "files": ["widget/nsTransferable.cpp", "widget/nsTransferable.h"], "git_node": null, "git_parents": [null], "node": "e8f4ef8801fbe8013a7cb0eeb5a7fae23db19edf", "parents": ["0fb5cc4927b16358eb6fa8b6359c944ce077f1dc"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset dff1e1774422 (bug 335545) for failing clipboard mochitest widget/tests/test_bug1123480.xul on Linux x64 asan. r=backout", "files": ["widget/nsTransferable.cpp", "widget/nsTransferable.h"], "git_node": null, "git_parents": [null], "node": "6694f4b93826511dd254dd36a7044891329beaf2", "parents": ["e8f4ef8801fbe8013a7cb0eeb5a7fae23db19edf"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 53e599ac1ed7 (bug 1359279) for android linting failure. r=backout", "files": ["mobile/android/services/src/main/java/org/mozilla/gecko/fxa/devices/FxAccountDevice.java", "mobile/android/services/src/main/java/org/mozilla/gecko/fxa/devices/FxAccountDeviceListUpdater.java", "mobile/android/services/src/main/java/org/mozilla/gecko/fxa/devices/FxAccountDeviceRegistrator.java", "mobile/android/services/src/main/java/org/mozilla/gecko/fxa/sync/FxAccountSyncAdapter.java", "mobile/android/tests/background/junit4/src/org/mozilla/gecko/fxa/devices/TestFxAccountDeviceListUpdater.java", "mobile/android/tests/background/junit4/src/org/mozilla/gecko/fxa/login/MockFxAccountClient.java"], "git_node": null, "git_parents": [null], "node": "e0d1b299d389229ca7d5f66dcb13663824314583", "parents": ["6694f4b93826511dd254dd36a7044891329beaf2"], "tags": []}, {"author": "Edouard Oger \u003ceoger@fastmail.com\u003e", "branch": "default", "desc": "Bug 1359279 - Renew GCM token/Push registration/FxA Registration on push registration expired. r=Grisha\n\nMozReview-Commit-ID: HFDjBBt9CBA", "files": ["mobile/android/services/src/main/java/org/mozilla/gecko/fxa/devices/FxAccountDevice.java", "mobile/android/services/src/main/java/org/mozilla/gecko/fxa/devices/FxAccountDeviceListUpdater.java", "mobile/android/services/src/main/java/org/mozilla/gecko/fxa/devices/FxAccountDeviceRegistrator.java", "mobile/android/services/src/main/java/org/mozilla/gecko/fxa/sync/FxAccountSyncAdapter.java", "mobile/android/tests/background/junit4/src/org/mozilla/gecko/fxa/devices/TestFxAccountDeviceListUpdater.java", "mobile/android/tests/background/junit4/src/org/mozilla/gecko/fxa/login/MockFxAccountClient.java"], "git_node": null, "git_parents": [null], "node": "4536d1692a1fe1c9ebb4f99f0ab511175147786e", "parents": ["e0d1b299d389229ca7d5f66dcb13663824314583"], "tags": []}, {"author": "Grigory Kruglov \u003cgkruglov@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400742 - Remove per-account in-memory cache r=nalexander\n\n1368147 added reading fxa.account.json into the unbundle() codepath for the cases\nwhen the in-memory cache isn't populated. This surfaced a race condition:\npickling of the fxa.account.json file and running unbundle() (as triggered from various\nparts of the UI, or othe SyncStatusObservers) will race, and if unbundle wins, it\nwill attempt to read a yet-to-be-created fxa.account.json file, and crash.\n\nFixing the race isn't trivial, but we can avoid it by removing the in-memory cache,\nthus avoiding having to read the cache key from the pickled file (uid).\n\nIn-memory cache was added in response to caching/invalidation issues of set/getUserData,\nsee Bug 964854 for the history. The current thinking is that those problems are pre-API16,\nwhich hopefully means that we shouldn't encounter them anymore, and thus can remove the\nworkaround entirely.\n\nMozReview-Commit-ID: AfL2Jq4IlYT", "files": ["mobile/android/base/java/org/mozilla/gecko/AccountsHelper.java", "mobile/android/services/src/main/java/org/mozilla/gecko/fxa/authenticator/AndroidFxAccount.java", "mobile/android/services/src/main/java/org/mozilla/gecko/fxa/authenticator/FxAccountAuthenticator.java", "mobile/android/services/src/main/java/org/mozilla/gecko/fxa/receivers/FxAccountDeletedService.java"], "git_node": null, "git_parents": [null], "node": "cadfde4972ab158dfe23226613c88ef5cc4252d4", "parents": ["4536d1692a1fe1c9ebb4f99f0ab511175147786e"], "tags": []}, {"author": "Daisuke Akatsuka \u003cdakatsuka@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401128 - Part 1: Change the size of time-body. r=pbro\n\nMozReview-Commit-ID: 8kERYFst4Ir", "files": ["devtools/client/themes/animationinspector.css"], "git_node": null, "git_parents": [null], "node": "01ff67e4eeb83a630835c49c1b251ba7c9e5d129", "parents": ["cadfde4972ab158dfe23226613c88ef5cc4252d4"], "tags": []}, {"author": "Daisuke Akatsuka \u003cdakatsuka@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401128 - Part 2: Modify test to change the way to send mouse event. r=pbro\n\nMozReview-Commit-ID: GOGJjRowa0W", "files": ["devtools/client/animationinspector/test/head.js"], "git_node": null, "git_parents": [null], "node": "bac4881560bfff4e2d06a63aa5663c68d6cac881", "parents": ["01ff67e4eeb83a630835c49c1b251ba7c9e5d129"], "tags": []}, {"author": "Sam Foster \u003csfoster@mozilla.com\u003e", "branch": "default", "desc": "Bug 1388832 - Fix right-click on searchbar when in overflow menu. r=jaws\n\n* Swap margins for paddings around the searchbar when in a menu. Elements that could precede and follow the searchbar all have margin: 0, and define top/bottom padding as 4px, so this seems reasonable\n* Harden the loop that looks up a matching ancestor - break before we hit the document\n\nMozReview-Commit-ID: LuniL3gdLWR", "files": ["browser/base/content/browser.js", "browser/themes/shared/customizableui/panelUI.inc.css"], "git_node": null, "git_parents": [null], "node": "72881ce767fcf80e51724c86371312e1b97d1897", "parents": ["bac4881560bfff4e2d06a63aa5663c68d6cac881"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400491 - Disable browser_aboutHome_search_composing.js for mac opt. r=ursula\n\nMozReview-Commit-ID: 2VKj6F3B71f", "files": ["browser/base/content/test/about/browser.ini"], "git_node": null, "git_parents": [null], "node": "5340cb842af889e483abed2ee2edc0aeb9327ea3", "parents": ["72881ce767fcf80e51724c86371312e1b97d1897"], "tags": []}, {"author": "Thom Chiovoloni \u003ctchiovoloni@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401686 - Handle cases where max_post_bytes is less than max_record_payload_bytes. r=kitcambridge\n\nMozReview-Commit-ID: AAiF2rD075A", "files": ["services/sync/modules/record.js", "services/sync/modules/service.js"], "git_node": null, "git_parents": [null], "node": "5fa690493eaa3a6d7993bb2f46478e94b9385e6d", "parents": ["5340cb842af889e483abed2ee2edc0aeb9327ea3"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1398223 - Add a webrender flag to mozinfo to allow using it in mochitest.ini conditions. r=gbrown\n\nMozReview-Commit-ID: IEgirFNntzS", "files": ["testing/mozbase/mozinfo/mozinfo/mozinfo.py"], "git_node": null, "git_parents": [null], "node": "36d6f521c2b20ca63bfaf2bfdd3aaa656ea17424", "parents": ["5fa690493eaa3a6d7993bb2f46478e94b9385e6d"], "tags": []}, {"author": "Grigory Kruglov \u003cgkruglov@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401773 - Revert checkboxes-\u003eswitches changeover for SyncPrefs r=nalexander\n\nMozReview-Commit-ID: 2RwcgomT5UG", "files": ["mobile/android/services/src/main/java/org/mozilla/gecko/fxa/activities/FxAccountStatusFragment.java", "mobile/android/services/src/main/res/xml/fxaccount_status_prefscreen.xml"], "git_node": null, "git_parents": [null], "node": "dc85108a0a305cff7c57d9cd6978b8312d03598f", "parents": ["36d6f521c2b20ca63bfaf2bfdd3aaa656ea17424"], "tags": []}, {"author": "Grigory Kruglov \u003cgkruglov@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401318 - Make sure account won't be null when it's processed by Android APIs r=nalexander\n\nMozReview-Commit-ID: EVHzQngUykm", "files": ["mobile/android/services/src/main/java/org/mozilla/gecko/fxa/authenticator/AndroidFxAccount.java"], "git_node": null, "git_parents": [null], "node": "dd9b01ec0df24f506d2bd2d8d09fd92694901193", "parents": ["dc85108a0a305cff7c57d9cd6978b8312d03598f"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400035 - Check the frame has opacity animations in nsSVGUtils::CanOptimizeOpacity().  r=jwatt\n\nIf the frame has opacity animation, we can't optimize it at all.\n\nMozReview-Commit-ID: JQYiPvSaxEs", "files": ["layout/svg/nsSVGUtils.cpp"], "git_node": null, "git_parents": [null], "node": "f4ae3d8fd4a4af37aa0e11cb138a4eba8e087f95", "parents": ["dd9b01ec0df24f506d2bd2d8d09fd92694901193"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400035 - Propagate RepaintFrame change hint instead of UpdateOpacityLayer for SVG geometry frames. r=jwatt\n\nWe do return RepaintFrame change hint from nsStyleEffects::CalcDifference for\nthe case where we optimize 0.99 over opacity values. We also need RepaintFrame\nchange hint for the opacity optimization in SVG, but we can't return the change\nhint from CalcDifference() since we have no way to know whether we are\ncalculating change hint for the optimized frame, so we fix it up in\nProcessRestyledFrames() instead.\n\nMozReview-Commit-ID: 5GUaN9ecfoC", "files": ["layout/base/RestyleManager.cpp"], "git_node": null, "git_parents": [null], "node": "2db87d9e38c1f4ad9eb9b42d5998c65662992899", "parents": ["f4ae3d8fd4a4af37aa0e11cb138a4eba8e087f95"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400035 - Drop InvalidateFrame() call in SVGGeometryFrame::DidSetStyleContext(). r=jwatt\n\nNow we no longer post InvalidateRenderingObservers change hint during post\ntraversal.\n\nMozReview-Commit-ID: H3jJ1LKgJyV", "files": ["layout/style/crashtests/1400035.html", "layout/style/crashtests/crashtests.list", "layout/svg/SVGGeometryFrame.cpp"], "git_node": null, "git_parents": [null], "node": "26228016eeae1527811bd2ad8e4a57149f57a29d", "parents": ["2db87d9e38c1f4ad9eb9b42d5998c65662992899"], "tags": []}, {"author": "Grigory Kruglov \u003cgkruglov@mozilla.com\u003e", "branch": "default", "desc": "Bug 1351673 - Use a single-threaded work queue to process batching downloader work items r=rnewman\n\nBefore we'd recurse instead while fetching multiple batches, overflowing the stack on older devices.\n\nMozReview-Commit-ID: 37BG6zGBdn0", "files": ["mobile/android/services/src/main/java/org/mozilla/gecko/sync/DelayedWorkTracker.java", "mobile/android/services/src/main/java/org/mozilla/gecko/sync/repositories/downloaders/BatchingDownloader.java"], "git_node": null, "git_parents": [null], "node": "96dab44be3bab04b2b56f29b6a2749630735d382", "parents": ["26228016eeae1527811bd2ad8e4a57149f57a29d"], "tags": []}, {"author": "Wes Kocher \u003cwkocher@mozilla.com\u003e", "branch": "default", "desc": "Merge m-c to autoland, a=merge\n\nMozReview-Commit-ID: AHxJvcR2Tpa", "files": ["browser/extensions/formautofill/test/mochitest/test_basic_creditcard_autocomplete_form.html", "layout/painting/nsDisplayList.cpp", "layout/painting/nsDisplayList.h"], "git_node": null, "git_parents": [null, null], "node": "554aa0b7b531346f04ac326cbe1caa8aa7f5ddf0", "parents": ["96dab44be3bab04b2b56f29b6a2749630735d382", "f8dd3f21e434be32fe5901849f1723b0e64cf668"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1401448 - Remove libstdc++ support from Android buildconfig. r=froydnj\n\nlibstdc++ support is broken after moving to moz.configure.  No one uses this option and NDK will remove GCC, so we should remove this and --with-android-cxx-stl option.\n\nMozReview-Commit-ID: 3mqyHoRCE00", "files": ["build/autoconf/android.m4", "build/moz.configure/old.configure", "mobile/android/config/mozconfigs/common", "toolkit/content/moz.build"], "git_node": null, "git_parents": [null], "node": "cdeac7bb864103f319b04f0a588a5194d3f02c71", "parents": ["554aa0b7b531346f04ac326cbe1caa8aa7f5ddf0"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1401733: Make StreamOverridablePageIconLayout caches static. r=liuche\n\nUnfortunately, I can't reproduce so I'm unable to verify this fix works for\nsure. However, I verified the behavior of the StreamOverridablePageIconLayout\nremained the same after these changes.\n\nAs per my bug comments, using the new version of onCreateView may fix this\nproblem and is \"more correct\" than this fix but it's speculative and it's too\ndangerous to make speculative fixes this close to the 57 merge. Instead, we do\nthis surefire fix and lose a little correctness.\n\nThe onCreateView fix moved to bug 1401779.\n\nMozReview-Commit-ID: DSq9jEgz6gL", "files": ["mobile/android/base/java/org/mozilla/gecko/BrowserApp.java", "mobile/android/base/java/org/mozilla/gecko/activitystream/homepanel/stream/StreamOverridablePageIconLayout.java"], "git_node": null, "git_parents": [null], "node": "7bb527a1748fad509712d02775c2637c2e3172aa", "parents": ["cdeac7bb864103f319b04f0a588a5194d3f02c71"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1401779: Use HC+ Actvitiy.onCreateView. r=liuche\n\nIn the docs [1], the version of onCreateView we've been using states:\n\nThis implementation does nothing and is for pre-HONEYCOMB apps. Newer apps\nshould use onCreateView(View, String, Context, AttributeSet).\n\nSince we no longer support pre-HC devices, this patch moves us to the new\nversion.\n\n[1]: https://developer.android.com/reference/android/app/Activity.html#onCreateView(java.lang.String,%20android.content.Context,%20android.util.AttributeSet)\n\nMozReview-Commit-ID: 4ISOLHZC4XJ", "files": ["mobile/android/base/java/org/mozilla/gecko/BrowserApp.java"], "git_node": null, "git_parents": [null], "node": "22f5e644534bfc2296e5d76785ad511436456269", "parents": ["7bb527a1748fad509712d02775c2637c2e3172aa"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "servo: Merge #18583 - Fix MallocSizeOf for TypedSize2D (from nnethercote:fix-TypedSize2D); r=mbrubeck\n\nTypedSize2D's MallocSizeOf impl has two problems.\n\n- It measures `width` twice, and `height` not at all.\n\n- It erroneously asserts that `width` and `height` are scalars. This\n  seems reasonable at first blush, but Stylo uses\n  `BorderRadius\u003cLengthAndPercentage\u003e` which contains a\n  `TypedSize2D\u003cLengthAndPercentage, UnknownUnit\u003e`, and\n  `LengthAndPercentage` is non-scalar.\n\nThis patch fixes both of these problems, and also removes a low-value\n`use` statement.\n\n\u003c!-- Please describe your changes on the following line: --\u003e\n\n---\n\u003c!-- Thank you for contributing to Servo! Please replace each `[ ]` by `[X]` when the step is complete, and replace `__` with appropriate data: --\u003e\n- [X] `./mach build -d` does not report any errors\n- [X] `./mach test-tidy` does not report any errors\n- [ ] These changes fix https://bugzilla.mozilla.org/show_bug.cgi?id=1401692\n\n\u003c!-- Either: --\u003e\n- [ ] There are tests for these changes OR\n- [ ] These changes do not require tests because tested on the Gecko side.\n\n\u003c!-- Also, please make sure that \"Allow edits from maintainers\" checkbox is checked, so that we can help you if you get stuck somewhere along the way.--\u003e\n\n\u003c!-- Pull requests that do not address these steps are welcome, but they will require additional verification as part of the review process. --\u003e\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: dfb80f07539298d5972c8ca108dda5f83d8e009f", "files": ["servo/components/malloc_size_of/lib.rs"], "git_node": null, "git_parents": [null], "node": "1bf51e25a57b34f579979a1f5dea8cf013a9ce21", "parents": ["22f5e644534bfc2296e5d76785ad511436456269"], "tags": []}, {"author": "Phil Ringnalda \u003cphilringnalda@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset 96dab44be3ba (bug 1351673) for Android build bustage\nCLOSED TREE\n\nMozReview-Commit-ID: 4XV7Be9AXmB", "files": ["mobile/android/services/src/main/java/org/mozilla/gecko/sync/DelayedWorkTracker.java", "mobile/android/services/src/main/java/org/mozilla/gecko/sync/repositories/downloaders/BatchingDownloader.java"], "git_node": null, "git_parents": [null], "node": "1465ade89bff04c8bd2cba9d5a172f6eb03b6381", "parents": ["1bf51e25a57b34f579979a1f5dea8cf013a9ce21"], "tags": []}, {"author": "Phil Ringnalda \u003cphilringnalda@gmail.com\u003e", "branch": "default", "desc": "Backed out 2 changesets (bug 1399505) for build bustage when it met a merge from m-c\nCLOSED TREE\n\nBacked out changeset fd7e2ce2fc92 (bug 1399505)\nBacked out changeset 40af6e459538 (bug 1399505)\n\nMozReview-Commit-ID: 5bGfy88JRUb", "files": ["gfx/layers/LayersLogging.cpp", "gfx/layers/LayersLogging.h", "gfx/layers/wr/StackingContextHelper.cpp", "gfx/layers/wr/StackingContextHelper.h", "gfx/webrender_bindings/WebRenderAPI.cpp", "gfx/webrender_bindings/WebRenderAPI.h", "gfx/webrender_bindings/WebRenderTypes.h", "gfx/webrender_bindings/src/bindings.rs", "gfx/webrender_bindings/webrender_ffi_generated.h", "layout/painting/nsDisplayList.cpp", "layout/painting/nsDisplayList.h", "layout/reftests/async-scrolling/reftest.list"], "git_node": null, "git_parents": [null], "node": "433c120883e9f7be3b943195e97887c34af871a4", "parents": ["1465ade89bff04c8bd2cba9d5a172f6eb03b6381"], "tags": []}, {"author": "Phil Ringnalda \u003cphilringnalda@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset 8e98f894a8a3 (bug 1381085) for Windows 7 failures in draw_rect.html and change_size.html\nCLOSED TREE\n\nMozReview-Commit-ID: D8RWiRfUPL9", "files": ["gfx/vr/VRDisplayHost.cpp", "gfx/vr/VRDisplayHost.h", "gfx/vr/gfxVROculus.cpp", "gfx/vr/gfxVROculus.h", "gfx/vr/gfxVRPuppet.cpp", "gfx/vr/gfxVRPuppet.h"], "git_node": null, "git_parents": [null], "node": "7864172bddf6409c2e68ff7b1bd0dc0d730202d9", "parents": ["433c120883e9f7be3b943195e97887c34af871a4"], "tags": []}, {"author": "Louis Chang \u003clochang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399723 - Draw a grey background color when event state is active instead of hover. r=mats\n\nMozReview-Commit-ID: CSX6xn1qy19", "files": ["widget/android/AndroidColors.h", "widget/android/nsNativeThemeAndroid.cpp"], "git_node": null, "git_parents": [null], "node": "4a59e79b7e947915bae60d7c37bffebf99ff3ef8", "parents": ["7864172bddf6409c2e68ff7b1bd0dc0d730202d9"], "tags": []}, {"author": "Grigory Kruglov \u003cgkruglov@mozilla.com\u003e", "branch": "default", "desc": "Bug 1351673 - Use a single-threaded work queue to process batching downloader work items r=rnewman\n\nBefore we'd recurse instead while fetching multiple batches, overflowing the stack on older devices.\n\nMozReview-Commit-ID: 37BG6zGBdn0", "files": ["mobile/android/base/android-services.mozbuild", "mobile/android/services/src/main/java/org/mozilla/gecko/sync/DelayedWorkTracker.java", "mobile/android/services/src/main/java/org/mozilla/gecko/sync/repositories/downloaders/BatchingDownloader.java"], "git_node": null, "git_parents": [null], "node": "9767e159a7018465824b7f6e4d504875cfa5cc6b", "parents": ["4a59e79b7e947915bae60d7c37bffebf99ff3ef8"], "tags": []}, {"author": "Dustin J. Mitchell \u003cdustin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1383880: allow only one optimization per task; r=ahal,glandium\n\nIt is not at *all* clear how multiple optimizations for a single task should\ninteract. No simple logical operation is right in all cases, and in fact in\nmost imaginable cases the desired behavior turns out to be independent of all\nbut one of the optimizations. For example, given both `seta` and\n`skip-unless-files-changed` optimizations, if SETA says to skip a test, it is\nlow value and should be skipped regardless of what files have changed. But if\nSETA says to run a test, then it has likely been skipped in previous pushes, so\nit should be run regardless of what has changed in this push.\n\nThis also adds a bit more output about optimization, that may be useful for\nanyone wondering why a particular job didn't run.\n\nMozReview-Commit-ID: 3OsvRnWjai4", "files": ["taskcluster/ci/build/android-stuff.yml", "taskcluster/taskgraph/generator.py", "taskcluster/taskgraph/optimize.py", "taskcluster/taskgraph/task.py", "taskcluster/taskgraph/test/test_optimize.py", "taskcluster/taskgraph/test/test_taskgraph.py", "taskcluster/taskgraph/transforms/docker_image.py", "taskcluster/taskgraph/transforms/job/__init__.py", "taskcluster/taskgraph/transforms/job/toolchain.py", "taskcluster/taskgraph/transforms/task.py", "taskcluster/taskgraph/transforms/tests.py"], "git_node": null, "git_parents": [null], "node": "7c07cb7985302e288a56c29c3fac22cacc4096d2", "parents": ["9767e159a7018465824b7f6e4d504875cfa5cc6b"], "tags": []}, {"author": "Dustin J. Mitchell \u003cdustin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1383880: add Graph.visit_preorder; r=ahal\n\nMozReview-Commit-ID: BWGqLUuWlN9", "files": ["taskcluster/taskgraph/graph.py", "taskcluster/taskgraph/test/test_graph.py"], "git_node": null, "git_parents": [null], "node": "b3eb0c93972084fd856a6d6f1bdadf8035478162", "parents": ["7c07cb7985302e288a56c29c3fac22cacc4096d2"], "tags": []}, {"author": "Dustin J. Mitchell \u003cdustin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1383880: optimize in three phases; r=ahal\n\nIn preparation for much more thorough optimization of task-graphs, this\nmakes a few changes:\n\n * optimization is split into thre phases, with task removal in one phase\n   (following dependency links) and task replacement in the next (in the\n   reverse order).\n * optimization uses class instances instead of functions for optimizations;\n   this allows different functions for different phases, and also leaves open\n   the possibility of composing optimizations.\n * the replacement phase can also support removal; this is when utility tasks\n   like symbol uploads can be optimized away iff their parent task is\n   optimized.\n\nMozReview-Commit-ID: C5QznNpwqXn", "files": ["taskcluster/docs/optimization.rst", "taskcluster/taskgraph/optimize.py", "taskcluster/taskgraph/task.py", "taskcluster/taskgraph/test/test_optimize.py", "taskcluster/taskgraph/test/test_util_parameterization.py"], "git_node": null, "git_parents": [null], "node": "a3116da52b4e3e58fbdc1da33c47e18a2e371bae", "parents": ["b3eb0c93972084fd856a6d6f1bdadf8035478162"], "tags": []}, {"author": "Dustin J. Mitchell \u003cdustin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1383880: parse try config during the decision task; r=ahal\n\nThis sets the try_mode property, and parses the try message (if given), early\nin the decision task and puts the results into the parameters.\n\nThe proximate need is to set optimze_target_tasks for some try modes and not\nothers. This also replaces the existing logic for parsing messages for certain\nkinds, and makes the distinction between the different try modes a little\nclearer.\n\nMozReview-Commit-ID: AXJEGLh6pEV", "files": ["taskcluster/ci/build/kind.yml", "taskcluster/ci/test/kind.yml", "taskcluster/docs/loading.rst", "taskcluster/docs/parameters.rst", "taskcluster/taskgraph/decision.py", "taskcluster/taskgraph/generator.py", "taskcluster/taskgraph/morph.py", "taskcluster/taskgraph/parameters.py", "taskcluster/taskgraph/target_tasks.py", "taskcluster/taskgraph/test/test_decision.py", "taskcluster/taskgraph/test/test_generator.py", "taskcluster/taskgraph/test/test_target_tasks.py", "taskcluster/taskgraph/test/test_try_option_syntax.py", "taskcluster/taskgraph/transforms/build.py", "taskcluster/taskgraph/transforms/tests.py", "taskcluster/taskgraph/try_option_syntax.py"], "git_node": null, "git_parents": [null], "node": "97eedc84d6e8f7b1128cd29a90ab4a72963bb851", "parents": ["a3116da52b4e3e58fbdc1da33c47e18a2e371bae"], "tags": []}, {"author": "Dustin J. Mitchell \u003cdustin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1383880: add support for SCHEDULES in moz.build; r=gps\n\nMozReview-Commit-ID: 2pfLr0VTy2J", "files": ["python/mozbuild/mozbuild/frontend/context.py", "python/mozbuild/mozbuild/frontend/mach_commands.py", "python/mozbuild/mozbuild/schedules.py", "python/mozbuild/mozbuild/test/frontend/data/schedules/moz.build", "python/mozbuild/mozbuild/test/frontend/data/schedules/subd/moz.build", "python/mozbuild/mozbuild/test/frontend/test_reader.py", "python/mozbuild/mozbuild/util.py"], "git_node": null, "git_parents": [null], "node": "ebcc9d20981a491ab1cb6b71bff43225a90169e8", "parents": ["97eedc84d6e8f7b1128cd29a90ab4a72963bb851"], "tags": []}, {"author": "Dustin J. Mitchell \u003cdustin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1383880: add support for optimizing tasks based on SCHEDULES; r=ahal\n\nThis adds some new optimization strategies.  For tests, we use Either(SETA,\nSkipUnlessSchedules), thereby giving both mechanisms a chance to skip tasks. On\ntry, SETA is omitted.\n\nMozReview-Commit-ID: GL4tlwyeBa6", "files": ["build/sparse-profiles/taskgraph", "taskcluster/taskgraph/optimize.py", "taskcluster/taskgraph/transforms/task.py"], "git_node": null, "git_parents": [null], "node": "ebdd6ccbcfca7f7672040f7227da31594d60f737", "parents": ["ebcc9d20981a491ab1cb6b71bff43225a90169e8"], "tags": []}, {"author": "Dustin J. Mitchell \u003cdustin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1383880: Annotate builds and tests with SCHEDULES-related optimizations; r=ahal\n\nThis means that a push to try affecting only Android will only run android builds\nand tests, for example.\n\nMozReview-Commit-ID: HVUvIg0EUZn", "files": ["taskcluster/taskgraph/transforms/build_attrs.py", "taskcluster/taskgraph/transforms/tests.py", "taskcluster/taskgraph/util/platforms.py"], "git_node": null, "git_parents": [null], "node": "b354fdf6e233ae06118ac8f1a975d0d4a53db4a9", "parents": ["ebdd6ccbcfca7f7672040f7227da31594d60f737"], "tags": []}, {"author": "Dustin J. Mitchell \u003cdustin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1383880: annotate source files with what they SCHEDULE; r=ahal\n\nMozReview-Commit-ID: CR70dSg5R79", "files": ["browser/themes/moz.build", "mobile/android/moz.build", "moz.build"], "git_node": null, "git_parents": [null], "node": "8e5847d9acda6349226b37fbbfc79ef2c01d7614", "parents": ["b354fdf6e233ae06118ac8f1a975d0d4a53db4a9"], "tags": []}, {"author": "Dustin J. Mitchell \u003cdustin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1383880: add only-if-dependencies-run optimization for follow-ons; r=ahal\n\nMozReview-Commit-ID: JuhwyQIx3Mh", "files": ["taskcluster/ci/upload-generated-sources/kind.yml", "taskcluster/ci/upload-symbols/kind.yml", "taskcluster/taskgraph/optimize.py", "taskcluster/taskgraph/transforms/task.py"], "git_node": null, "git_parents": [null], "node": "ec2b8ba5a949c3b899a647dbad93aa60b653e745", "parents": ["8e5847d9acda6349226b37fbbfc79ef2c01d7614"], "tags": []}, {"author": "Dustin J. Mitchell \u003cdustin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1383880: use a vcs-compatible reader in decision tasks; r=gps\n\nThis continues to use a file-based reader when run locally.\n\nMozReview-Commit-ID: CJuYKDj2E3n", "files": ["taskcluster/taskgraph/optimize.py"], "git_node": null, "git_parents": [null], "node": "571a6c9054a540e0bf40baf837da9175f21796b9", "parents": ["ec2b8ba5a949c3b899a647dbad93aa60b653e745"], "tags": []}, {"author": "Dustin J. Mitchell \u003cdustin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1383880: adjust mach artifact toolchain --from-build; r=glandium\n\nMozReview-Commit-ID: AhGS54jB8Wl", "files": ["python/mozbuild/mozbuild/mach_commands.py"], "git_node": null, "git_parents": [null], "node": "8cceb6a82bfb079e93005d120f540f0877a0eaf3", "parents": ["571a6c9054a540e0bf40baf837da9175f21796b9"], "tags": []}, {"author": "Dustin J. Mitchell \u003cdustin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1383880: --from-build is a dev tool, not for automation; r=glandium\n\nMozReview-Commit-ID: EGs3Zy012JA", "files": ["python/mozbuild/mozbuild/mach_commands.py"], "git_node": null, "git_parents": [null], "node": "fd3615e7e0a3a85ba58616396468229bce30f957", "parents": ["8cceb6a82bfb079e93005d120f540f0877a0eaf3"], "tags": []}, {"author": "Tomislav Jovanovic \u003ctomica@gmail.com\u003e", "branch": "default", "desc": "Bug 1386427 - Part 1: Add XRE*NativeManifests locations to dirsvc r=kmag\n\nMozReview-Commit-ID: DoJIP6QZ5AX", "files": ["toolkit/components/extensions/NativeMessaging.jsm", "toolkit/components/extensions/test/mochitest/test_chrome_native_messaging_paths.html", "toolkit/components/extensions/test/xpcshell/head_native_messaging.js", "toolkit/components/extensions/test/xpcshell/test_native_messaging.js", "toolkit/xre/nsXREDirProvider.cpp", "xpcom/build/nsXULAppAPI.h"], "git_node": null, "git_parents": [null], "node": "05ff50abca055f92132141bc25eeb053ac71c52e", "parents": ["fd3615e7e0a3a85ba58616396468229bce30f957"], "tags": []}, {"author": "Tomislav Jovanovic \u003ctomica@gmail.com\u003e", "branch": "default", "desc": "Bug 1386427 - Part 2: Extract HostManifestManager to NativeManifests.jsm r=kmag\n\nMozReview-Commit-ID: GrVBZbkTfrB", "files": ["toolkit/components/extensions/NativeManifests.jsm", "toolkit/components/extensions/NativeMessaging.jsm", "toolkit/components/extensions/moz.build", "toolkit/components/extensions/test/xpcshell/test_native_manifests.js", "toolkit/components/extensions/test/xpcshell/test_native_messaging.js", "toolkit/components/extensions/test/xpcshell/xpcshell-common.ini", "tools/lint/eslint/modules.json"], "git_node": null, "git_parents": [null], "node": "660f2242c95f7804448f4d09e3d030e6eb1d9d06", "parents": ["05ff50abca055f92132141bc25eeb053ac71c52e"], "tags": []}, {"author": "Tomislav Jovanovic \u003ctomica@gmail.com\u003e", "branch": "default", "desc": "Bug 1386427 - Part 3: Add `storage` and `pkcs11` NativeManifest types r=kmag\n\nMozReview-Commit-ID: 62MoqNLTxic", "files": ["toolkit/components/extensions/NativeManifests.jsm", "toolkit/components/extensions/NativeMessaging.jsm", "toolkit/components/extensions/extensions-toolkit.manifest", "toolkit/components/extensions/schemas/jar.mn", "toolkit/components/extensions/schemas/native_host_manifest.json", "toolkit/components/extensions/schemas/native_manifest.json", "toolkit/components/extensions/schemas/runtime.json", "toolkit/components/extensions/test/xpcshell/head_native_messaging.js", "toolkit/components/extensions/test/xpcshell/test_ext_native_messaging.js", "toolkit/components/extensions/test/xpcshell/test_native_manifests.js"], "git_node": null, "git_parents": [null], "node": "603d09a85dd63adb4a8f3927b7d8dacc440437d0", "parents": ["660f2242c95f7804448f4d09e3d030e6eb1d9d06"], "tags": []}, {"author": "Tomislav Jovanovic \u003ctomica@gmail.com\u003e", "branch": "default", "desc": "Bug 1386427 - Part 4: Implement basic storage.managed functionality r=kmag\n\nMozReview-Commit-ID: Auy1ujS8wyz", "files": ["toolkit/components/extensions/ExtensionStorage.jsm", "toolkit/components/extensions/ext-c-storage.js", "toolkit/components/extensions/ext-storage.js", "toolkit/components/extensions/schemas/native_manifest.json", "toolkit/components/extensions/schemas/storage.json", "toolkit/components/extensions/test/xpcshell/test_ext_storage_managed.js", "toolkit/components/extensions/test/xpcshell/xpcshell-common.ini"], "git_node": null, "git_parents": [null], "node": "a439e2ac43058989193daa201b764b96821bd