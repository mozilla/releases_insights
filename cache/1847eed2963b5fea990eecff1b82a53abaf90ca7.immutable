arents": ["8e76d0006eebd158996c46bc72c87346a414bdf5"], "tags": []}], "date": 1506193222, "git_changesets": [null], "user": "ffxbld"}, "7810": {"changesets": [{"author": "tbirdbld", "branch": "THUNDERBIRD560b4_2017092319_RELBRANCH", "desc": "Automated checkin: version bump for thunderbird 56.0b4 release. DONTBUILD CLOSED TREE a=release", "files": [], "git_node": null, "git_parents": [null], "node": "d4224244e154fcebaee2fc69657242a0aa334b82", "parents": ["34e421e834210f92aaf25ea26c6ccfcfeb47a08d"], "tags": ["THUNDERBIRD_56_0b4_BUILD5"]}, {"author": "tbirdbld", "branch": "THUNDERBIRD560b4_2017092319_RELBRANCH", "desc": "Added THUNDERBIRD_56_0b4_RELEASE THUNDERBIRD_56_0b4_BUILD5 tag(s) for changeset d4224244e154. DONTBUILD CLOSED TREE a=release", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "99022e32ce886a256ae0def0ec6a470e2ba507bd", "parents": ["d4224244e154fcebaee2fc69657242a0aa334b82"], "tags": []}], "date": 1506209409, "git_changesets": [null, null], "user": "tbirdbld"}, "7811": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump\n\nes-AR -\u003e 776a3623b297\nes-CL -\u003e 0576a9b78a90\nes-ES -\u003e 40025d7e9b15\nhe -\u003e c32148d68699\npl -\u003e c3f809d1afbe\npt-BR -\u003e f481036051c0\nrm -\u003e c275c110e246\nro -\u003e d59dd8b61c87\nru -\u003e 64f7d7962845\nsk -\u003e 4e4e5cb58f4d\nsr -\u003e 66364cd449e3\nsv-SE -\u003e 3e6ef449ecad\nta -\u003e a3b48893d89f\nth -\u003e a5c3b2b21533\ntr -\u003e c38003def107\nuk -\u003e 18d5264ca571\nur -\u003e a2a2d750431f\nzh-CN -\u003e 474cf47b4703", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "b494556a75c95f3121aa6ed0218385aae3fb6adc", "parents": ["6c495bb9e72c5033cf9584851c10b508655bcf31"], "tags": []}], "date": 1506229223, "git_changesets": [null], "user": "ffxbld"}, "7812": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump\n\nkk -\u003e d16610c5b335\nth -\u003e e480860e432d", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "7e5027f096f546cf46a4a5c4b140ead547c87740", "parents": ["b494556a75c95f3121aa6ed0218385aae3fb6adc"], "tags": []}], "date": 1506247224, "git_changesets": [null], "user": "ffxbld"}, "7813": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump\n\nda -\u003e d22d97bdf99a\nth -\u003e 652919cf4463\nuk -\u003e 7dc85fcfd6d3", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "430b63b3ae195c97c8318f81b904561daec4be40", "parents": ["7e5027f096f546cf46a4a5c4b140ead547c87740"], "tags": []}], "date": 1506250822, "git_changesets": [null], "user": "ffxbld"}, "7814": {"changesets": [{"author": "James Graham \u003cjames@hoppipolla.co.uk\u003e", "branch": "default", "desc": "Bug 1397912 - Split wdspec session creation tests for intermittent timeouts. r=ato, a=test-only\n\nThis test was timing out, so split it into firstMatch and alwaysMatch files.\n\nMozReview-Commit-ID: 8E9wZQqdajG", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/webdriver/tests/sessions/new_session/create.py", "testing/web-platform/tests/webdriver/tests/sessions/new_session/create_alwaysMatch.py", "testing/web-platform/tests/webdriver/tests/sessions/new_session/create_firstMatch.py", "testing/web-platform/tests/webdriver/tests/sessions/new_session/support/create.py"], "git_node": null, "git_parents": [null], "node": "a6d9c15124a8e6f60795d2df156da70b61a63662", "parents": ["430b63b3ae195c97c8318f81b904561daec4be40"], "tags": []}, {"author": "James Graham \u003cjames@hoppipolla.co.uk\u003e", "branch": "default", "desc": "Bug 1393366 - Increase the marionette connect timeout in wptrunner. r=maja_zf, a=test-only\n\nThis switches to using a timeout of 120s * timeout_multplier, which is\ntwice the current value. The Marionette startup_timout value is\nremoved because it turns out that's only used when marionette starts\nthe Firefox instance and therefore is ignored in this case.\n\nMozReview-Commit-ID: 4VA8yB6M1d5", "files": ["testing/marionette/client/marionette_driver/marionette.py", "testing/web-platform/tests/tools/wptrunner/wptrunner/executors/executormarionette.py"], "git_node": null, "git_parents": [null], "node": "a9142fa50a345d724e3cd5686832c13c642ad560", "parents": ["a6d9c15124a8e6f60795d2df156da70b61a63662"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1361476 - Change instance type for linux64-asan mochitest-devtools tests. r=ryanvm, a=test-only\n\nFor the last month or so, asan mochitest-devtools tests have been running on\nxlarge instances, in an experiment. Since there is no conclusive evidence that\nxlarge improved results, I am putting this back the way I found it.", "files": ["taskcluster/ci/test/tests.yml"], "git_node": null, "git_parents": [null], "node": "628445067e7ca141cc539f54fab050aa7a464844", "parents": ["a9142fa50a345d724e3cd5686832c13c642ad560"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401501 - Ensure windows10 resolution is 1280x1024. r=ahal, a=test-only", "files": ["testing/mozharness/configs/unittests/win_taskcluster_unittest.py", "testing/mozharness/external_tools/mouse_and_screen_resolution.py"], "git_node": null, "git_parents": [null], "node": "5cf8c1979ea119ec6b413d026c933bd45b6953b8", "parents": ["628445067e7ca141cc539f54fab050aa7a464844"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1402301 - Run preflight setup on windows for web-platform-tests to adjust screen resolution, also adjust tests that are affected. r=jgraham, a=test-only", "files": ["testing/mozharness/configs/web_platform_tests/prod_config_windows_taskcluster.py", "testing/web-platform/meta/cssom-view/CaretPosition-001.html.ini", "testing/web-platform/meta/html/browsers/the-window-object/apis-for-creating-and-navigating-browsing-contexts-by-name/open-features-non-integer-screeny.html.ini", "testing/web-platform/meta/html/semantics/embedded-content/the-img-element/usemap-casing.html.ini", "testing/web-platform/meta/html/semantics/embedded-content/the-object-element/usemap-casing.html.ini"], "git_node": null, "git_parents": [null], "node": "d0556b492297ba52e150830d555fccdbc12215c1", "parents": ["5cf8c1979ea119ec6b413d026c933bd45b6953b8"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1402347 - Be more exact in Android tests when checking run time. r=jmaher, a=test-only", "files": ["build/mobile/remoteautomation.py"], "git_node": null, "git_parents": [null], "node": "06f90b83cf2062b568c529b21b5920c1ee4ddca6", "parents": ["d0556b492297ba52e150830d555fccdbc12215c1"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401287 - Skip sandbox check for test plug-in on Android. r=dbaron, a=test-only\n\nThe test plugins - dom/plugins/test/testplugin - are not built on Android.\nBy assuming that the test plugin is not available on Android, a per-manifest\ncheck and warning can be avoided.", "files": ["layout/tools/reftest/reftest.jsm"], "git_node": null, "git_parents": [null], "node": "ea5136a2af4465baf84904ca6184d2ea7966c044", "parents": ["06f90b83cf2062b568c529b21b5920c1ee4ddca6"], "tags": []}, {"author": "Jan-Ivar Bruaroey \u003cjib@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399922 - Use a static mutex for getting deviceId keys in MediaParent. r=jesup, a=sledru\n\nMozReview-Commit-ID: E6pzyAM4jOQ", "files": ["dom/media/systemservices/MediaParent.cpp"], "git_node": null, "git_parents": [null], "node": "eea4ead4541fac7668535b1f9ac4e39e1d6deef7", "parents": ["ea5136a2af4465baf84904ca6184d2ea7966c044"], "tags": []}, {"author": "J. Ryan Stinnett \u003cjryans@gmail.com\u003e", "branch": "default", "desc": "Bug 1401256 - servo: Update inherited prop state for animation (from jryans:stylo-anim-inherit-context). r=heycam, a=sledru\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 83705a8fa8992a974b32acc6635c7dfeed1afa50", "files": ["servo/components/style/properties/helpers/animated_properties.mako.rs"], "git_node": null, "git_parents": [null], "node": "61dd4d2e2a789916cbb49ca2625c5dca3b2c972d", "parents": ["eea4ead4541fac7668535b1f9ac4e39e1d6deef7"], "tags": []}, {"author": "J. Ryan Stinnett \u003cjryans@gmail.com\u003e", "branch": "default", "desc": "Bug 1401256 - Crashtest for animating lengths. r=heycam, a=sledru\n\nMozReview-Commit-ID: HiVfx9cg4ZZ", "files": ["layout/style/crashtests/1401256.html", "layout/style/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "46a47d4a1f5c1d453069b158d12e255114d312b0", "parents": ["61dd4d2e2a789916cbb49ca2625c5dca3b2c972d"], "tags": []}, {"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397918 - Don't use versions of libxcb before 1.11.1. r=karlt, a=sledru\n\nMozReview-Commit-ID: Ec8ZhCBlPj2", "files": ["widget/nsShmImage.cpp"], "git_node": null, "git_parents": [null], "node": "103c51cbee81e6f0670cd007a05a1a169bae33f8", "parents": ["46a47d4a1f5c1d453069b158d12e255114d312b0"], "tags": []}, {"author": "Chris H-C \u003cchutten@mozilla.com\u003e", "branch": "default", "desc": "Bug 1391531 - Make TelemetrySession idle callbacks cancellable. r=Dexter, a=sledru\n\nTelemetrySession schedules some activities on idle, to avoid hogging resources.\nSometimes we're forced to handle these situations on a more rigid timeline than\n\"wait for idle\". In those cases we should cancel the idle timeout so it doesn't\ndouble-perform the operations.\n\nUnfortunately idleDispatchToMainThread doesn't have a cancel mechanism, so we\nneed to bolt one over it.\n\nMozReview-Commit-ID: JpUfb9rK2Od", "files": ["toolkit/components/telemetry/TelemetrySession.jsm"], "git_node": null, "git_parents": [null], "node": "f26cc2bf3694d1e9e633f894a65872b85a055d20", "parents": ["103c51cbee81e6f0670cd007a05a1a169bae33f8"], "tags": []}, {"author": "Doug Thayer \u003cdothayer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399177 - Pull label out of description in update popups. r=Gijs, a=sledru\n\nThe margin rules for labels mean that if the See what's new link\nstarts its own line, the alignment looks off. We could override this,\nbut matching the styling for \"Learn more\" links, which get their own\nline, seemed the better option.\n\nMozReview-Commit-ID: 4WK9QtRMUQs", "files": ["browser/components/customizableui/content/panelUI.inc.xul"], "git_node": null, "git_parents": [null], "node": "bc83af76203e62c7b61040630538a6d7d07458e3", "parents": ["f26cc2bf3694d1e9e633f894a65872b85a055d20"], "tags": []}, {"author": "Alessio Placitelli \u003calessio.placitelli@gmail.com\u003e", "branch": "default", "desc": "Bug 1400870 - Keep the attribution code on environment changes. r=chutten, a=sledru\n\nThis patch makes sure |_updateSettings| carries over the attribution code,\nif present. Without this patch the whole \"environment.settings\" section\nis replaced and the attribution code disppears after the first environment\nchange/subsession split.\n\nMozReview-Commit-ID: 8bxjVOl2mUp", "files": ["toolkit/components/telemetry/TelemetryEnvironment.jsm", "toolkit/components/telemetry/tests/unit/test_TelemetryEnvironment.js"], "git_node": null, "git_parents": [null], "node": "7e35ed4a8c47909b300a79079ea05fba53cf80fe", "parents": ["bc83af76203e62c7b61040630538a6d7d07458e3"], "tags": []}, {"author": "Kevin Hsieh \u003ckevin.hsieh@ucla.edu\u003e", "branch": "default", "desc": "Bug 1401709 - Do attach base line layout to orthogonal rtc. r=xidorn, a=sledru\n\nMozReview-Commit-ID: JCgaXWD43m5", "files": ["layout/generic/crashtests/1401709.html", "layout/generic/crashtests/crashtests.list", "layout/generic/nsLineLayout.cpp", "layout/generic/nsRubyBaseContainerFrame.cpp"], "git_node": null, "git_parents": [null], "node": "ced074245173c8b2eb9890aa7208eeece6757986", "parents": ["7e35ed4a8c47909b300a79079ea05fba53cf80fe"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401851 - Skip masked favicons in ContentLinkHandler until we support them. r=nanj, a=sledru\n\nMozReview-Commit-ID: 99du7AD11x7", "files": ["browser/modules/ContentLinkHandler.jsm"], "git_node": null, "git_parents": [null], "node": "e0b02b146664ac071a59fbd1709f1d1a843cfcc4", "parents": ["ced074245173c8b2eb9890aa7208eeece6757986"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1401840 - Make sure to not end up with infinite recursion when reframing a \u003cbody\u003e that has a table pseudo parent coming from the root \u003chtml\u003e. r=dholbert, a=sledru\n\nMozReview-Commit-ID: EJiO8Nq5Frb", "files": ["layout/base/crashtests/1401840.html", "layout/base/crashtests/crashtests.list", "layout/base/nsCSSFrameConstructor.cpp"], "git_node": null, "git_parents": [null], "node": "ca9795c9066e8a8ea06157428b7d3e07482e5338", "parents": ["e0b02b146664ac071a59fbd1709f1d1a843cfcc4"], "tags": []}], "date": 1506287778, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7815": {"changesets": [{"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400357 - Whitelist maximize.svg in browser_startup_images. r=florian, a=test-only\n\nThere have been changes to our Windows infrastructure that cause the\nwindow to be maximized when running tests so the maximize.svg/restore.svg\ncombination will show restore instead of maximize, though maximize is\nstill loaded. I think it could be prevented by trying to set the sizemode\nattribute a little earlier or not defaulting to maximize in the stylesheet,\nbut I don't think that's a necessary optimization at this point. We can\njust whitelist it.\n\nI also set the intermittentShown flag in case the Windows machines go back\nto non-maximized windows.\n\nMozReview-Commit-ID: Gwi0jRBBtGg", "files": ["browser/base/content/test/performance/browser_startup_images.js", "browser/base/content/test/performance/hidpi/browser.ini"], "git_node": null, "git_parents": [null], "node": "00b34310a5c5d84a518d1528803229c4968952bb", "parents": ["ca9795c9066e8a8ea06157428b7d3e07482e5338"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1402070 - Put explicit line-breaks in browser_bug970746.xhtml to avoid test fragility due to potential line-breaks within test elements. r=philor, a=test-only\n\nMozReview-Commit-ID: FFDx9pSM1HC", "files": ["browser/base/content/test/general/browser.ini", "browser/base/content/test/general/browser_bug970746.xhtml"], "git_node": null, "git_parents": [null], "node": "b59f1cc4bd56e0bf39cc21aad008ea65ae95c791", "parents": ["00b34310a5c5d84a518d1528803229c4968952bb"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1402079 - browser/base/content/test/performance/browser_windowopen_reflows.js fails on different screen resolutions. r=mconley, a=test-only", "files": ["browser/base/content/test/performance/browser_windowopen_reflows.js"], "git_node": null, "git_parents": [null], "node": "40f2d25d78c0ce6e23c932c27aae833916a2041b", "parents": ["b59f1cc4bd56e0bf39cc21aad008ea65ae95c791"], "tags": []}], "date": 1506297844, "git_changesets": [null, null, null], "user": "ryanvm@gmail.com"}, "7816": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "defau