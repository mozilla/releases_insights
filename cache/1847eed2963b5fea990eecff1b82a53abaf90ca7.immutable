=l10n-bump\n\nff -\u003e a33f5a580815\ngd -\u003e e008b6400e44\nhi-IN -\u003e d3fbe1578b68\nid -\u003e fdfa51c72d56\nit -\u003e 7dcb73029caf\nkn -\u003e 232e1ed1eed2\npl -\u003e ddc6b786c9ea", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "73f66ceb9305cc86a6aba8424a874449d23b7f5e", "parents": ["29d78558d32165ee3508fb967871556a6669191d"], "tags": []}], "date": 1508952167, "git_changesets": [null, null], "user": "ffxbld"}, "8050": {"changesets": [{"author": "Gabriele Svelto \u003cgsvelto@mozilla.com\u003e", "branch": "default", "desc": "Bug 1393800 - Have mochitests expecting crashes wait for the crashes to be recorded before clean up. r=mconley, a=test-only\n\nThis patch includes a bunch of somewhat related fixes, these are:\n\n- Ensuring that when a mochitest calls SimpleTest.expectChildProcessCrash()\n  the harness will wait for the crashes to be recorded before deleting the\n  dump files. This involves a message round-trip between the content and\n  parent process so to minimize its performance impact on all the non-crashing\n  tests it is done only when required.\n- As an additional optimization, the SimpleTest harness will not send a\n  message to the content process anymore whenever it receives an\n  ipc:content-shutdown event, instead it does it only for abnormal shutdowns.\n- Manually fixing remaining mochitests causing crashes to wait for crashes to\n  be recorded before finishing and deleting the dump files.\n- Modifying BrowserTestUtils.crashBrowser() so that it optionally does not\n  delete the dump files, this is useful for tests that submit their dumps and\n  thus delete them on their own.\n\n\nMozReview-Commit-ID: 4SLJ8BjJ18n", "files": ["browser/base/content/test/plugins/browser_pluginCrashReportNonDeterminism.js", "browser/base/content/test/tabcrashed/browser_clearEmail.js", "dom/ipc/tests/chrome.ini", "dom/ipc/tests/process_error.xul", "dom/ipc/tests/process_error_contentscript.js", "dom/plugins/test/mochitest/hang_test.js", "dom/plugins/test/mochitest/test_busy_hang.xul", "dom/plugins/test/mochitest/test_crash_notify.xul", "dom/plugins/test/mochitest/test_idle_hang.xul", "testing/mochitest/BrowserTestUtils/BrowserTestUtils.jsm", "testing/mochitest/tests/SimpleTest/TestRunner.js", "testing/specialpowers/content/SpecialPowersObserver.jsm", "testing/specialpowers/content/SpecialPowersObserverAPI.js", "testing/specialpowers/content/specialpowers.js", "testing/specialpowers/content/specialpowersAPI.js"], "git_node": null, "git_parents": [null], "node": "4005ce92f03ea6c8dc2a7a0e60756c43ce66427f", "parents": ["73f66ceb9305cc86a6aba8424a874449d23b7f5e"], "tags": []}, {"author": "Gabriele Svelto \u003cgsvelto@mozilla.com\u003e", "branch": "default", "desc": "Bug 1410165 - Make the test harness properly listen to crash events when running a test more than once. r=mconley, a=test-only\n\nMozReview-Commit-ID: C3PDtOfaz0v", "files": ["testing/mochitest/tests/SimpleTest/TestRunner.js"], "git_node": null, "git_parents": [null], "node": "036b6ffa94c9852463c0726ce70ac79a6f65427e", "parents": ["4005ce92f03ea6c8dc2a7a0e60756c43ce66427f"], "tags": []}, {"author": "James Graham \u003cjames@hoppipolla.co.uk\u003e", "branch": "default", "desc": "Bug 1404733 - Handle non-utf8 better in wpt logging. r=maja_zf, a=test-only\n\nMozReview-Commit-ID: GMofBbKUtt0", "files": ["testing/web-platform/tests/tools/wptrunner/wptrunner/wptlogging.py"], "git_node": null, "git_parents": [null], "node": "119fd95b6e842a6cba502cf849fddfe558ee38bc", "parents": ["036b6ffa94c9852463c0726ce70ac79a6f65427e"], "tags": []}, {"author": "Boris Chiou \u003cboris.chiou@gmail.com\u003e", "branch": "default", "desc": "Bug 1303235 - stylo: Add an FFI to get the ServoStyleContext with an extra animation value. r=hiro, a=ritu\n\nThis is an inter-dependent patch of Bug 1303235. We add an FFI\nto create a temporary ServoStyleContext with the animation value.\nWe need this because we calculate the Cumulative change hints to check\nif we can ignore this animation segment.", "files": ["servo/components/style/gecko/generated/bindings.rs", "servo/components/style/rule_tree/mod.rs", "servo/ports/geckolib/glue.rs"], "git_node": null, "git_parents": [null], "node": "df3cc0ef0e479d928dc4d1e75bdd81089fe109af", "parents": ["119fd95b6e842a6cba502cf849fddfe558ee38bc"], "tags": []}, {"author": "Boris Chiou \u003cboris.chiou@gmail.com\u003e", "branch": "default", "desc": "Bug 1303235 - Part 1: Add ResolveServoStyleByAddingAnimation. r=hiro, a=ritu\n\nWe need to create a temporary ServoStyleContext with the animation value for\ncalculating the Cumulative change hints.\n\nMozReview-Commit-ID: JzArnaGqVeV", "files": ["layout/style/ServoBindingList.h", "layout/style/ServoStyleSet.cpp", "layout/style/ServoStyleSet.h"], "git_node": null, "git_parents": [null], "node": "a3f558c2926173a6ff6adcf6f9f641662ed0fce8", "parents": ["df3cc0ef0e479d928dc4d1e75bdd81089fe109af"], "tags": []}, {"author": "Boris Chiou \u003cboris.chiou@gmail.com\u003e", "branch": "default", "desc": "Bug 1303235 - Part 2: Templatize CalculateCumulativeChangeHint. r=hiro, a=ritu\n\nMozReview-Commit-ID: JHSn7FoRPpW", "files": ["dom/animation/KeyframeEffectReadOnly.cpp", "dom/animation/KeyframeEffectReadOnly.h"], "git_node": null, "git_parents": [null], "node": "167961e9d88e1c3e2a2bf442c5c3df1a76b50fee", "parents": ["a3f558c2926173a6ff6adcf6f9f641662ed0fce8"], "tags": []}, {"author": "Boris Chiou \u003cboris.chiou@gmail.com\u003e", "branch": "default", "desc": "Bug 1303235 - Part 3: Enable test_restyle.html and remove the early return in CanIgnoreIfNotVisible. r=hiro, a=ritu\n\nMozReview-Commit-ID: LMKSVW2sh5N", "files": ["dom/animation/KeyframeEffectReadOnly.cpp", "dom/animation/test/chrome/test_restyles.html"], "git_node": null, "git_parents": [null], "node": "921ae95a11f5bc29a129892d88e69e70264e20cf", "parents": ["167961e9d88e1c3e2a2bf442c5c3df1a76b50fee"], "tags": []}], "date": 1508956756, "git_changesets": [null, null, null, nul