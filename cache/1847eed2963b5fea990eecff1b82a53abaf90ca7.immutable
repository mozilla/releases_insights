arents": ["ca18e7c2cadce9c93ea3eb89cc129dc37ca4c091"], "tags": []}, {"author": "Andy McKay \u003camckay@mozilla.com\u003e", "branch": "default", "desc": "Bug 1350277 - Remove duplicates when showing host permissons. r=aswan\n\nMozReview-Commit-ID: 2GzUwFHuEe6", "files": ["browser/base/content/test/webextensions/browser_webext_permissions.xpi", "toolkit/components/extensions/Extension.jsm"], "git_node": null, "git_parents": [null], "node": "41effc9b8c27c21a98dc995143a3f7562c9258a6", "parents": ["f36eefa1beee2978d546ae7c8b9177779b1988dd"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1398133 - Simplify gfxCoreTextShaper code by removing legacy code only needed on 10.7 and earlier. r=jrmuizel", "files": ["gfx/thebes/gfxCoreTextShaper.cpp", "gfx/thebes/gfxCoreTextShaper.h"], "git_node": null, "git_parents": [null], "node": "0aa8826fa414d39fa7d5e661792a5c4ab83fe228", "parents": ["ac08b84acbcc781b4542ceca12bf417da73ac563"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1367077 - 1. Move startup utility functions into GeckoViewUtils; r=snorp\n\nMove `addLazyGetter` and `addLazyEventListener` utility functions from\nGeckoViewStartup.js into GeckoViewUtils.jsm, so they can be used for\nboth Fennec and standalone GeckoView.\n\nAlso switch to \"chrome-document-loaded\" for loading\nDownloadNotifications because that's later in the startup sequence.\n\nMozReview-Commit-ID: 1caMtufkHGR", "files": ["mobile/android/chrome/content/WebrtcUI.js", "mobile/android/components/BrowserCLH.js", "mobile/android/components/geckoview/GeckoViewStartup.js", "mobile/android/modules/DownloadNotifications.jsm", "mobile/android/modules/geckoview/GeckoViewUtils.jsm", "mobile/android/modules/geckoview/moz.build"], "git_node": null, "git_parents": [null], "node": "682c9d79073c383b52731d20fa81edd1c9755fb8", "parents": ["0aa8826fa414d39fa7d5e661792a5c4ab83fe228"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1367077 - 2. Move PromptService startup to BrowserCLH; r=snorp\n\nUse the BrowserCLH for PromptService startup, to consolidate startup\nhandling code and also to delay loading PromptService.\n\nMozReview-Commit-ID: 25UgVH7wrrs", "files": ["mobile/android/chrome/content/InputWidgetHelper.js", "mobile/android/chrome/content/SelectHelper.js", "mobile/android/components/BrowserCLH.js", "mobile/android/components/MobileComponents.manifest", "mobile/android/components/PromptService.js", "mobile/android/tests/browser/chrome/test_hidden_select_option.html", "mobile/android/tests/browser/chrome/test_select_disabled.html"], "git_node": null, "git_parents": [null], "node": "72e591f41777329d56c686ba778f3e3c8b0dce20", "parents": ["682c9d79073c383b52731d20fa81edd1c9755fb8"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1367077 - 3. Move form fill event listeners out of browser.js; r=sebastian\n\nMove the form fill event listeners out of browser.js and into\nBrowserCLH.js, and update them to support chrome windows, so we can\nhandle form fill events for Fennec, custom tabs, and PWAs.\n\nMozReview-Commit-ID: Fb5gWmGvxfE", "files": ["mobile/android/chrome/content/browser.js", "mobile/android/components/BrowserCLH.js", "mobile/android/modules/DelayedInit.jsm"], "git_node": null, "git_parents": [null], "node": "17f9dd20314af009f328e920f68008885ab8cb73", "parents": ["72e591f41777329d56c686ba778f3e3c8b0dce20"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1367077 - 4. Remove LoginManagerParent.login; r=kmag\n\nMobile code now loads LoginManagerParent lazily, similar to\nnsBrowserGlue on desktop, so we no longer need LoginManagerParent.login.\n\nMozReview-Commit-ID: 8tnWnev344", "files": ["browser/components/nsBrowserGlue.js", "toolkit/components/passwordmgr/LoginManagerParent.jsm", "toolkit/components/passwordmgr/test/pwmgr_common.js"], "git_node": null, "git_parents": [null], "node": "5bb25516598f08df439fb16c69d60555b406d353", "parents": ["17f9dd20314af009f328e920f68008885ab8cb73"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1398409 - 1. Move FormAssistant out of browser.js; r=sebastian\n\nTo support FormAssistPopup in custom tabs, we need to move the\nFormAssitant object out of browser.js and into its own separate file.\nBrowserCLH.h in turn loads FormAssistant.js when necessary.\n\nMozReview-Commit-ID: 7CFQ9R16P4J", "files": ["mobile/android/chrome/content/FormAssistant.js", "mobile/android/chrome/content/browser.js", "mobile/android/chrome/jar.mn", "mobile/android/components/BrowserCLH.js"], "git_node": null, "git_parents": [null], "node": "a99a2486f70c65b2411caef9898c05680b374499", "parents": ["5bb25516598f08df439fb16c69d60555b406d353"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1398409 - 2. Use event callback to communicate FormAssistPopup actions; r=sebastian\n\nUse event callbacks instead of separate events to deliver\nFormAssistPopup replies back to FormAssistant. This lets us better\nhandle having multiple FormAssistPopup instances across Fennec, custom\ntabs, and PWAs.\n\nFormAssistant._currentInputElement is removed because it does not allow\nus to have multiple concurrent popups. Instead, we track the current\nelement through the event callback closure.\nFormAssistant._currentInputValue is also removed for similar reasons,\nand I don't think it was really necessary.\n\nMozReview-Commit-ID: DdeMBGCxDou", "files": ["mobile/android/base/java/org/mozilla/gecko/BrowserApp.java", "mobile/android/base/java/org/mozilla/gecko/FormAssistPopup.java", "mobile/android/base/java/org/mozilla/gecko/GeckoApp.java", "mobile/android/chrome/content/FormAssistant.js", "mobile/android/components/BrowserCLH.js", "mobile/android/modules/geckoview/Messaging.jsm"], "git_node": null, "git_parents": [null], "node": "b1de7fdaa3835f5469206fc120ecb74616534291", "parents": ["a99a2486f70c65b2411caef9898c05680b374499"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1398409 - 3. Add FormAssistPopup to custom tabs; r=snorp\n\nAdd and use FormAssistPopup in custom tabs to show autocomplete lists\nand form validation messages.\n\nMozReview-Commit-ID: AvK70MLQNVN", "files": ["mobile/android/app/src/main/res/layout/customtabs_activity.xml", "mobile/android/base/java/org/mozilla/gecko/customtabs/CustomTabsActivity.java"], "git_node": null, "git_parents": [null], "node": "d190ba5c8b7f8cf619276f55dc93c8908b156788", "parents": ["b1de7fdaa3835f5469206fc120ecb74616534291"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1367079 - 1. Update TextSelection implementations for GeckoView; r=snorp\n\nMake TextSelection implementations not depend on GeckoApp. Instead, make\nthem use GeckoView's EventDispatcher directly for communicating with\nGecko.\n\nMozReview-Commit-ID: EygAt3D9HMI", "files": ["mobile/android/base/java/org/mozilla/gecko/ActionBarTextSelection.java", "mobile/android/base/java/org/mozilla/gecko/GeckoApp.java", "mobile/android/base/java/org/mozilla/gecko/text/FloatingActionModeCallback.java", "mobile/android/base/java/org/mozilla/gecko/text/FloatingToolbarTextSelection.java", "mobile/android/base/java/org/mozilla/gecko/text/TextSelection.java"], "git_node": null, "git_parents": [null], "node": "58e575edf398a9657282842eb798512b023f16df", "parents": ["d190ba5c8b7f8cf619276f55dc93c8908b156788"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1367079 - 2. Move Share:Text listener to GeckoApplication; r=snorp\n\nMove the \"Share:Text\" event listener from GeckoApp to GeckoApplication,\nso ActionBarHandler.js can use it for the Share action from any window.\n\nMozReview-Commit-ID: 8w1llJy4pwy", "files": ["mobile/android/base/java/org/mozilla/gecko/GeckoApp.java", "mobile/android/base/java/org/mozilla/gecko/GeckoApplication.java"], "git_node": null, "git_parents": [null], "node": "1af8aae9f13783e8497f9a0ca91a07e0524503de", "parents": ["58e575edf398a9657282842eb798512b023f16df"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1367079 - 3. Add utility for registering lazy WindowEventDispatcher listener; r=snorp\n\nAdd `GeckoViewUtils.registerLazyWindowEventListener` that, similar to\n`addLazyEventListener`, will register a lazy event listener with the\nper-window EventDispatcher.\n\nMozReview-Commit-ID: AX3EQGpmdw", "files": ["mobile/android/modules/geckoview/GeckoViewUtils.jsm", "mobile/android/modules/geckoview/Messaging.jsm"], "git_node": null, "git_parents": [null], "node": "7f1d3a461631ba73c54fc3079dbc933889a711b3", "parents": ["1af8aae9f13783e8497f9a0ca91a07e0524503de"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1367079 - 4. Move ActionBarHandler usage out of browser.js; r=snorp\n\nUse ActionBarHandler in BrowserCLH.js instead of browser.js, so it can\nhandle text selection for all windows. Also update ActionBarHandler to\nreflect the new usage and to support multiple windows.\n\nMozReview-Commit-ID: G8sKu2XyAAG", "files": ["mobile/android/chrome/content/ActionBarHandler.js", "mobile/android/chrome/content/browser.js", "mobile/android/chrome/geckoview/geckoview.js", "mobile/android/components/BrowserCLH.js"], "git_node": null, "git_parents": [null], "node": "c185dd417782d8e8a1d9ab7c75211d6b09ac8573", "parents": ["7f1d3a461631ba73c54fc3079dbc933889a711b3"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1367079 - 5. Add TextSelection support in custom tabs and PWA; r=snorp\n\nAdd TextSelection support in custom tabs and PWA.\n\nMozReview-Commit-ID: AcHjMfJ8onU", "files": ["mobile/android/base/java/org/mozilla/gecko/customtabs/CustomTabsActivity.java", "mobile/android/base/java/org/mozilla/gecko/webapps/WebAppActivity.java"], "git_node": null, "git_parents": [null], "node": "5dae173f8fe8567970e9f97143ab635b8de8acea", "parents": ["c185dd417782d8e8a1d9ab7c75211d6b09ac8573"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1367079 - 6. Fix testAccessibleCarets; r=me\n\nFix testAccessibleCarets and enable it for non-Nightly builds. r=me for\ntest changes.\n\nMozReview-Commit-ID: EjNwzb5bETy", "files": ["mobile/android/components/BrowserCLH.js", "mobile/android/components/MobileComponents.manifest", "mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/testAccessibleCarets.java", "mobile/android/tests/browser/robocop/testAccessibleCarets.js"], "git_node": null, "git_parents": [null], "node": "69521f759e299849c0ae9ab0f7f11ea322730aea", "parents": ["5dae173f8fe8567970e9f97143ab635b8de8acea"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1383501: Modify a11y::IsHandlerRegistered to include check of path to handler binary; r=eeejay", "files": ["accessible/windows/msaa/Platform.cpp"], "git_node": null, "git_parents": [null], "node": "9e895d32653b939602552eb859c319b50457afba", "parents": ["69521f759e299849c0ae9ab0f7f11ea322730aea"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "servo: Merge #18502 - style: Unify how servo and Gecko handle UA sheets (from emilio:ua-sheets-unify); r=simonsapin\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 75e126f139197c447686242082d9e7f61ba92c3f", "files": ["servo/components/layout_thread/lib.rs", "servo/components/script/dom/bindings/trace.rs", "servo/components/script/dom/document.rs", "servo/components/style/gecko/data.rs", "servo/components/style/shared_lock.rs", "servo/components/style/stylesheet_set.rs", "servo/compone