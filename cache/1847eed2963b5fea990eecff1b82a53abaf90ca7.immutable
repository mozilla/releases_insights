g 1397128 P5 Add ReadStream::Inner::EnsureStream() to synchronously open stream when Availabe/Read/ReadSegments is called. r=tt", "files": ["dom/cache/ReadStream.cpp"], "git_node": null, "git_parents": [null], "node": "afc46e4aa18cf8c4f305aa7155eacbf9259c6e30", "parents": ["faa7c0f91b4ed79995e66f121244dd805b825dd2"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1397128 P6 Allow ReadStream to be created with an initially nullptr base stream. r=tt", "files": ["dom/cache/AutoUtils.cpp", "dom/cache/CacheStreamControlChild.cpp", "dom/cache/CacheStreamControlParent.cpp", "dom/cache/ReadStream.cpp"], "git_node": null, "git_parents": [null], "node": "c02de0753e45c68e432dde1ee3826776429abd0e", "parents": ["afc46e4aa18cf8c4f305aa7155eacbf9259c6e30"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1397128 P7 Add an OpenMode enumeration to control if individual Cache API requests eagerly or lazily opens bodies. r=tt", "files": ["dom/cache/Cache.cpp", "dom/cache/CacheStorage.cpp", "dom/cache/CacheTypes.ipdlh", "dom/cache/IPCUtils.h", "dom/cache/Manager.cpp", "dom/cache/Types.h"], "git_node": null, "git_parents": [null], "node": "882ab64141403a04a6f3c178e6531948ec7ea71b", "parents": ["c02de0753e45c68e432dde1ee3826776429abd0e"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1397128 P8 Track which storage \"namespace\" each Cache object is associated with. r=tt", "files": ["dom/cache/Cache.cpp", "dom/cache/Cache.h", "dom/cache/CacheOpChild.cpp", "dom/cache/CacheTypes.ipdlh", "dom/cache/Manager.cpp"], "git_node": null, "git_parents": [null], "node": "7650e58c8b52d3e4384073b3fd794c715bf76a04", "parents": ["882ab64141403a04a6f3c178e6531948ec7ea71b"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1397128 P9 Make content script usage of Cache API use lazy body loading. r=tt", "files": ["dom/cache/Cache.cpp", "dom/cache/Cache.h", "dom/cache/CacheStorage.cpp", "dom/cache/CacheStorage.h"], "git_node": null, "git_parents": [null], "node": "5657bd411b28daebe0cbb5c170279fa4065c2a89", "parents": ["7650e58c8b52d3e4384073b3fd794c715bf76a04"], "tags": []}, {"author": "Josh Matthews \u003cjosh@joshmatthews.net\u003e", "branch": "default", "desc": "Bug 1397971 - Share strings in URLDataValue with Rust. r=heycam", "files": ["dom/base/nsAttrValue.cpp", "dom/base/nsContentUtils.cpp", "dom/base/nsContentUtils.h", "layout/style/ServoBindingList.h", "layout/style/ServoBindingTypes.h", "layout/style/ServoBindings.cpp", "layout/style/ServoBindings.h", "layout/style/ServoBindings.toml", "layout/style/nsCSSValue.cpp", "layout/style/nsCSSValue.h"], "git_node": null, "git_parents": [null], "node": "6159e19a7c0fffd202134027abff82b6e0bd22e6", "parents": ["aa02aa853d370a776efc59c699895a34a8671777"], "tags": []}, {"author": "John Lin \u003cjolin@mozilla.com\u003e", "branch": "default", "desc": "servo: Merge #18031 - Fix Android build errors on macOS (from jhlin:android-build-on-macos); r=mbrubeck\n\n- Add sysroot path to environment variable 'CPPFLAGS':\n  When checking C preprocessor, the 'configure' script of libbacktrace uses 'CPPFLAGS' rather than 'CFLAGS' and doesn't get the correct search path. (#15758)\n  This check passes on Linux because the '/lib/cpp' fallback is available there.\n\n- Introduce CMake toolchain file for Android cross compiling:\n  CMake needs several variables [1] to cross compile for Android.\n  It works (accidentally) on Linux because cmake-rs sets compilers correctly and binutils for Linux & Android are pretty much the same.\n\n[1] https://cmake.org/cmake/help/v3.7/manual/cmake-toolchains.7.html#cross-compiling-for-android-with-the-ndk\n\n\u003c!-- Please describe your changes on the following line: --\u003e\n\n---\n\u003c!-- Thank you for contributing to Servo! Please replace each `[ ]` by `[X]` when the step is complete, and replace `__` with appropriate data: --\u003e\n- [x] `./mach build -d` does not report any errors\n- [x] `./mach test-tidy` does not report any errors\n- [x] These changes fix #15758 (github issue number if applicable).\n\n\u003c!-- Either: --\u003e\n- [ ] There are tests for these changes OR\n- [x] These changes do not require tests because it's a fix to build errors.\n\n\u003c!-- Also, please make sure that \"Allow edits from maintainers\" checkbox is checked, so that we can help you if you get stuck somewhere along the way.--\u003e\n\n\u003c!-- Pull requests that do not address these steps are welcome, but they will require additional verification as part of the review process. --\u003e\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: a3b85cbd6cd74090b6e9f09e3d0980045e8f6a1b", "files": ["servo/python/servo/build_commands.py", "servo/support/android/toolchain.cmake"], "git_node": null, "git_parents": [null], "node": "f083cad6e8e6e96157ea3648062d62869caf04ef", "parents": ["6159e19a7c0fffd202134027abff82b6e0bd22e6"], "tags": []}, {"author": "Edouard Oger \u003ceoger@fastmail.com\u003e", "branch": "default", "desc": "Bug 1392874 - Force gSync initialization in browser_sync.js test. r=markh\n\nMozReview-Commit-ID: 9ZEK4dc6QEe", "files": ["browser/base/content/test/sync/browser_sync.js"], "git_node": null, "git_parents": [null], "node": "9cc10d12de94bda1dee61a03e0681f5e73df5ee6", "parents": ["f083cad6e8e6e96157ea3648062d62869caf04ef"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400378 - Add layers logging support for Point3D. r=mattwoodrow\n\nMozReview-Commit-ID: 9W3gDi7wyQF", "files": ["gfx/2d/BasePoint3D.h", "gfx/layers/LayersLogging.h"], "git_node": null, "git_parents": [null], "node": "a6d9e37a9122e0848b67c072b7a101fe4b058716", "parents": ["9cc10d12de94bda1dee61a03e0681f5e73df5ee6"], "tags": []}, {"author": "Wes Kocher \u003cwkocher@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 67769dac78c4 for busting builds CLOSED TREE\n\nMozReview-Commit-ID: 82QTBjYc0jC", "files": ["servo/components/layout_thread/dom_wrapper.rs", "servo/components/style/dom.rs", "servo/components/style/gecko/generated/bindings.rs", "servo/components/style/gecko/media_queries.rs", "servo/components/style/gecko/wrapper.rs", "servo/components/style/matching.rs", "servo/components/style/servo/media_queries.rs", "servo/components/style/values/specified/color.rs"], "git_node": null, "git_parents": [null], "node": "d6a3a83d9ce3c16773a5c818b5f754ff7728f665", "parents": ["a6d9e37a9122e0848b67c072b7a101fe4b058716"], "tags": []}, {"author": "Ted Mielczarek \u003cted@mielczarek.org\u003e", "branch": "default", "desc": "bug 1399870 - Make DEFFILE a Path instead of a string. r=gps\n\nDEFFILE is currently just used as a passthrough variable. All but one of\nthe current uses of it use `SRCDIR + '/file.def'` to get a srcdir-relative\npath anyway, and the other one wants an objdir-relative path, so using\nPath makes everything clearer.\n\nThis makes it more straightforward to translate the paths for the WSL\nbuild.\n\nMozReview-Commit-ID: IRokABaZW2c", "files": ["accessible/interfaces/ia2/moz.build", "accessible/interfaces/msaa/moz.build", "accessible/ipc/win/handler/moz.build", "build/win32/crashinjectdll/moz.build", "config/external/lgpllibs/moz.build", "config/rules.mk", "dom/plugins/test/testplugin/testplugin.mozbuild", "gfx/angle/src/libEGL/moz.build", "gfx/angle/src/libGLESv2/moz.build", "modules/pdfium/moz.build", "mozglue/build/moz.build", "python/mozbuild/mozbuild/frontend/context.py", "python/mozbuild/mozbuild/frontend/emitter.py"], "git_node": null, "git_parents": [null], "node": "52e6fce3e6f625f08e0fc9b8b76222e8c7f8bcff", "parents": ["d6a3a83d9ce3c16773a5c818b5f754ff7728f665"], "tags": []}, {"author": "Ted Mielczarek \u003cted@mielczarek.org\u003e", "branch": "default", "desc": "bug 1399878 - Use LOCAL_INCLUDES instead of CFLAGS in some media moz.build files. r=gps\n\nMozReview-Commit-ID: 3PUOniPnt54", "files": ["media/libaom/moz.build", "media/libvpx/moz.build"], "git_node": null, "git_parents": [null], "node": "305e742634e5076bcfd0e98940879082b6f6db3a", "parents": ["52e6fce3e6f625f08e0fc9b8b76222e8c7f8bcff"], "tags": []}, {"author": "Ted Mielczarek \u003cted@mielczarek.org\u003e", "branch": "default", "desc": "bug 1399877 - Globally define DLL_PREFIX/DLL_SUFFIX. r=gps\n\nSeveral source files use DLL_PREFIX/DLL_SUFFIX defines, and they all\nset them in moz.build using `DEFINES`. This is problematic for the WSL build\nbecause the quoting gets lost somewhere between bash and cl.exe. This patch\nmakes them set globally in moz.configure with `set_define`. There was an\nexisting global `MOZ_DLL_SUFFIX` define that was only used in one place, so\nthat has been removed in favor of simply `DLL_SUFFIX`.\n\nMozReview-Commit-ID: 4ZQiqMK8Dgu", "files": ["dom/system/moz.build", "ipc/glue/moz.build", "js/src/moz.build", "moz.configure", "security/apps/moz.build", "security/certverifier/moz.build", "security/manager/ssl/moz.build", "xpcom/build/nsXPCOMPrivate.h"], "git_node": null, "git_parents": [null], "node": "d9bc6c96c492eb23bb08716607f276d1e5ea2f20", "parents": ["305e742634e5076bcfd0e98940879082b6f6db3a"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399878 - Fix case of LOCAL_INCLUDES; r=me\n\nThis fixes a typo introduced in 305e742634e5 and that broke\nmoz.build processing for MacOS.", "files": ["media/libvpx/moz.build"], "git_node": null, "git_parents": [null], "node": "6cde1d8f17ad40e50bdfaec0c7ec19fe2e6022d0", "parents": ["d9bc6c96c492eb23bb08716607f276d1e5ea2f20"], "tags": []}, {"author": "Matthew Noorenberghe \u003cmozilla@noorenberghe.ca\u003e", "branch": "default", "desc": "Bug 1400395 - Make credit card autofill available for tests. r=RyanVM\n\nThis means we're not exactly testing what we're shipping but unbreaks the tests for now to allow beta uplift.\n\nMozReview-Commit-ID: GhTGOJDKfGA", "files": ["browser/extensions/formautofill/test/browser/browser.ini"], "git_node": null, "git_parents": [null], "node": "5d68f5307724344aff045e0c35acf24ecb077b20", "parents": ["6cde1d8f17ad40e50bdfaec0c7ec19fe2e6022d0"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399870 - Fix test for DEFFILE; r=me\n\nThe test broke in 52e6fce3e6f6. The fix is to:\n\na) ensure the baz.def file exists\nb) change the checked path in the backend.mk file\n\nMozReview-Commit-ID: 1Ff3Qr5nZmD", "files": ["python/mozbuild/mozbuild/test/backend/data/variable_passthru/baz.def", "python/mozbuild/mozbuild/test/backend/test_recursivemake.py", "python/mozbuild/mozbuild/test/frontend/data/variable-passthru/baz.def", "python/mozbuild/mozbuild/test/frontend/test_emitter.py"], "git_node": null, "git_parents": [null], "node": "98e46ead352299d6e18b760535ed8195d2ce5006", "parents": ["5d68f5307724344aff045e0c35acf24ecb077b20"], "tags": []}, {"author": "Masatoshi Kimura \u003cVYV03354@nifty.ne.jp\u003e", "branch": "default", "desc": "Bug 1400207 - Remove nsIDocument::AddCharSetObserver. r=hsivonen\n\nMozReview-Commit-ID: 7uWDQvyz4yC", "files": ["dom/base/nsDocument.cpp", "dom/base/nsDocument.h", "dom/base/nsIDocument.h", "layout/base/nsPresContext.cpp", "layout/base/nsPresContext.h"], "git_node": null, "git_parents": [null], "node": "790f099a55ab69ca981b46f80d3319f38a5fdf5e", "parents": ["98e46ead352299d6e18b760535ed8195d2ce5006"], "tags": []}, {"author": "Daosheng Mu \u003cdaoshengmu@gmail.com\u003e", "branch": "default", "desc": "Bug 1400091 - Skip-if WebVR reftests for MacOSX non-Nightly build; r=kip\n\nMozReview-Commit-ID: CGYHW3n6QuX", "files": ["dom/vr/test/reftest/reftest.list"], "git_node": null, "git_parents": [null], "node": "4f37ace5eff4dd87144939764e48937469e409ca", "parents": ["790f099a55ab69ca981b46f80d3319f38a5fdf5e"], "tags": []}, {"author": "Wes Kocher \u003cwkocher@mozilla.com\u003e", "branch": "