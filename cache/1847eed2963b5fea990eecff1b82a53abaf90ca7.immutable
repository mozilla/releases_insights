": "5510bc76210e5187339a8142412ae5cf7f4b5dcd", "parents": ["9dcc1b8a0c90300039a9ac06ac45598955c58ea8"], "tags": []}], "date": 1508754019, "git_changesets": [null, null], "user": "ffxbld"}, "8028": {"changesets": [{"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1402450 - Ensure the test properly delays until the content process receives the touch events. r=botond, a=test-only\n\nIt appears that in this case just waiting for the APZ flush to complete was\ninsufficient, probably because the APZ flush and touch inputs go via different\nIPC channels and therefore do not provide ordering guarantees. So instead of\nwaiting for the APZ flush, let's just wait until the touchstart is received\nin the content process and use that to resume the test.\n\nMozReview-Commit-ID: AcPRhox1Xkg", "files": ["gfx/layers/apz/test/mochitest/helper_touch_action_regions.html"], "git_node": null, "git_parents": [null], "node": "0b53a9c798b38884635abc70b9aaf0f280c4b266", "parents": ["5510bc76210e5187339a8142412ae5cf7f4b5dcd"], "tags": []}, {"author": "Stephen A Pohl \u003cspohl.mozilla.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1406032 - Ensure that popup windows (such as the hamburger menu window) are shown on top of the browser window on macOS. r=mstange, a=jcristau", "files": ["widget/cocoa/nsCocoaWindow.mm"], "git_node": null, "git_parents": [null], "node": "337db7b083a718fcb515f5fc75a951edfe596ced", "parents": ["0b53a9c798b38884635abc70b9aaf0f280c4b266"], "tags": []}, {"author": "Stephen A Pohl \u003cspohl.mozilla.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1406032 - Backout 096247c952ea (bug 1324892) to fix popup tests because popups now work correctly again on macOS. r=mstange, a=jcristau", "files": ["toolkit/content/tests/chrome/window_largemenu.xul"], "git_node": null, "git_parents": [null], "node": "e35c137374639978334a5b33bffba0c6d9aa5c48", "parents": ["337db7b083a718fcb515f5fc75a951edfe596ced"], "tags": []}, {"author": "k88hudson \u003ckhudson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1409058 - Add pref to show or hide snippets in the pref panel. r=Mardak, a=ritu\n\nMozReview-Commit-ID: Ia1vpkBVDMn", "files": ["browser/extensions/activity-stream/data/content/activity-stream.bundle.js", "browser/extensions/activity-stream/lib/ActivityStream.jsm"], "git_node": null, "git_parents": [null], "node": "35f1d96d06e2c6dbaae61d7fbd9e288fb78443df", "parents": ["e35c137374639978334a5b33bffba0c6d9aa5c48"], "tags": []}, {"author": "Lars T Hansen \u003clhansen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1409196 - Specialize loadSafeWhenRacy and storeSafeWhenRacy on arm64 for uint8_clamped to pacify Clang. f=jbeich, r=me, a=jcristau", "files": ["js/src/jit/arm64/AtomicOperations-arm64.h"], "git_node": null, "git_parents": [null], "node": "2e937c6b36c676e9402d3bc4626f464898872e5c", "parents": ["35f1d96d06e2c6dbaae61d7fbd9e288fb78443df"], "tags": []}, {"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 1408005 - Clear gApplicationReputationService in the dtor. r=francois, a=abillings", "files": ["toolkit/components/downloads/ApplicationReputation.cpp"], "git_node": null, "git_parents": [null], "node": "9e21926958600c34dcdfec9a58986df3d7d41759", "parents": ["2e937c6b36c676e9402d3bc4626f464898872e5c"], "tags": []}], "date": 1508768469, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8029": {"changesets": [{"author": "Nathan Froyd \u003cfroydnj@gmail.com\u003e", "branch": "default", "desc": "Bug 1163171 - Remove arm-specific hacks in typed array implementation. r=lth, a=ritu\n\nclang does not have the specific problem that led to this hack in the\nfirst place, so we can remove the hack.  (The hack also causes issues\nwith clang; it complains that you can't pass `volatile T*` into the\nintrinsics that we're using for atomic operations.)", "files": ["js/src/vm/TypedArrayObject-inl.h"], "git_node": null, "git_parents": [null], "node": "8b84e5418b809672a7387975d2b780ce60be3a95", "parents": ["9e21926958600c34dcdfec9a58986df3d7d41759"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1407245 - Fix service worker update 24-hour time check conversion from microseconds. r=asuth, a=ritu", "files": ["dom/workers/ServiceWorkerRegistrationInfo.cpp"], "git_node": null, "git_parents": [null], "node": "f3db43c2871f535249156bb5e082885dbd8b2a3d", "parents": ["8b84e5418b809672a7387975d2b780ce60be3a95"], "tags": []}, {"author": "Kearwood Gilbert \u003ckgilbert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1402871 - Change VREventObserver::mWindow to a RefPtr. r=dveditz, a=ritu\n\nMozReview-Commit-ID: 79MlNMAvIQD", "files": ["dom/vr/VREventObserver.h"], "git_node": null, "git_parents": [null], "node": "c703e451d7aa32dfe9ba4b7fc262c4a69234af0b", "parents": ["f3db43c2871f535249156bb5e082885dbd8b2a3d"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1385013 - Check all vertexes for the target frame are outside of the parent frame if the target frame is empty. r=birtles, a=ritu\n\nWe create empty rectangle (zero-height or zero-width) frame for element which\nhas no content inside it, e.g.  '\u003cp\u003e\u003c/p\u003e'.  And nsRect.Intersects returns false\nif either of the rectangles are empty, so if we check\n!transformedRect.Intersects(scrollableRect) and transformedRect is empty, we\nwill end up returning true from IsFrameScrolledOutOfView even though the point\nrepresented by the empty transformedRect might be inside the\nscrollableRect.\n\nThe reftest causes timeout without this fix since the animation never updates\nafter the initial paint.\n\nMozReview-Commit-ID: FymFJfjxyGc", "files": ["layout/generic/nsFrame.cpp", "layout/reftests/css-animations/animation-on-empty-height-frame.html", "layout/reftests/css-animations/reftest.list"], "git_node": null, "git_parents": [null], "node": "fd097e21e8d61cbdb9eb6c59c4da2b2634761301", "parents": ["c703e451d7aa32dfe9ba4b7fc262c4a69234af0b"], "tags": []}, {"author": "Luke Chang \u003clchang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1360694 - [Form Autofill] Cap the length of profile fields saved in storage. r=ralin, a=ritu\n\nMozReview-Commit-ID: I9x0tnGEt1Y", "files": ["browser/extensions/formautofill/FormAutofillHandler.jsm", "browser/extensions/formautofill/FormAutofillUtils.jsm", "browser/extensions/formautofill/test/unit/test_createRecords.js"], "git_node": null, "git_parents": [null], "node": "6273b5da0f81eddc0249a3d0edb6e60ba3724e6e", "parents": ["fd097e21e8d61cbdb9eb6c59c4da2b2634761301"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1407936 - Cleaning up QuotaManagar data only when ServiceWorkers are correctly unregistered. r=bkelly, a=ritu", "files": ["browser/base/content/sanitize.js", "dom/interfaces/base/nsIServiceWorkerManager.idl"], "git_node": null, "git_parents": [null], "node": "58c1a09d1a65d3e1563dc8c479c02f1bdc67c2b0", "parents": ["6273b5da0f81eddc0249a3d0edb6e60ba3724e6e"], "tags": []}, {"author": "Marco Castelluccio \u003cmcastelluccio@mozilla.com\u003e", "branch": "default", "desc": "Bug 1407337 - Block OpenSC \u003c 0.16.0.0. r=jimm, a=ritu", "files": ["mozglue/build/WindowsDllBlocklist.cpp"], "git_node": null, "git_parents": [null], "node": "d16abfdc9433fbc12c0ee2e54a776f39d7c23ee5", "parents": ["58c1a09d1a65d3e1563dc8c479c02f1bdc67c2b0"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1410457 - Places.sqlite may be marked as corrupt if schema migration mixes up sync and async execution. r=Paolo, a=ritu\n\nMozReview-Commit-ID: 7O18MLdHU08", "files": ["toolkit/components/places/Database.cpp", "toolkit/components/places/Database.h"], "git_node": null, "git_parents": [null], "node": "4d583d584b5c3a30dd7146eae9c5b218d5eb83c6", "parents": ["d16abfdc9433fbc12c0ee2e54a776f39d7c23ee5"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1381427 - Result width should often be constrained by the width of the location bar. r=mak, a=ritu\n\nThis adds an end margin to the location bar search results that matches the end of the input field, unless doing this would be unbalanced with the start margin, in which case a symmetrical margin is chosen. This allows the location bar to be moved to the start of the navigation toolbar to reclaim space for results. This also handles gracefully other customization scenarios like having many icons on the right side of the location bar.\n\nMozReview-Commit-ID: CjvbTtn7VVh", "files": ["browser/base/content/browser.xul", "browser/base/content/urlbarBindings.xml", "browser/themes/shared/urlbar-autocomplete.inc.css", "toolkit/content/widgets/autocomplete.xml"], "git_node": null, "git_parents": [null], "node": "22ad3b8731eb021bb3c93f5992265ea88b4d7c31", "parents": ["4d583d584b5c3a30dd7146eae9c5b218d5eb83c6"], "tags": []}, {"author": "J. Ryan Stinnett \u003cjryans@gmail.com\u003e", "branch": "default", "desc": "Bug 1409277 - Ignore non-URLs for background pres attr. r=manishearth, a=ritu\n\nCheck background attribute values for the same types (URL, image) in Stylo mode\nas we do in Gecko mode.\n\nIn particular, this ignores the edge case of the empty attribute, which comes\nthrough as a string value type, and leads Stylo to trigger a load of the page\nitself as the background image (since the empty URL is interpreted as relative\nto the page).\n\nMozReview-Commit-ID: CUhq5nS8kVw", "files": ["layout/style/ServoSpecifiedValues.cpp"], "git_node": null, "git_parents": [null], "node": "938e8d1ced3df5ec4a033e8fbcaa24efef9d42e2", "parents": ["22ad3b8731eb021bb3c93f5992265ea88b4d7c31"], "tags": []}, {"author": "David Anderson \u003cdanderson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1408781 - Part 1: Store the AL render region separately from the shadow visible region. r=mattwoodrow, a=ritu", "files": ["gfx/layers/mlgpu/CanvasLayerMLGPU.cpp", "gfx/layers/mlgpu/CanvasLayerMLGPU.h", "gfx/layers/mlgpu/ImageLayerMLGPU.cpp", "gfx/layers/mlgpu/ImageLayerMLGPU.h", "gfx/layers/mlgpu/LayerMLGPU.cpp", "gfx/layers/mlgpu/LayerMLGPU.h", "gfx/layers/mlgpu/PaintedLayerMLGPU.cpp", "gfx/layers/mlgpu/PaintedLayerMLGPU.h", "gfx/layers/mlgpu/RenderPassMLGPU.cpp", "gfx/layers/mlgpu/RenderPassMLGPU.h", "gfx/layers/mlgpu/RenderViewMLGPU.cpp"], "git_node": null, "git_parents": [null], "node": "a8e9602f18f64bf021b8a91bd0d3f94afff3f8df", "parents": ["938e8d1ced3df5ec4a033e8fbcaa24efef9d42e2"], "tags": []}, {"author": "David Anderson \u003cdanderson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1408781 - Part 2: Cache invalidation properties after compositing, not before. r=mattwoodrow, a=ritu", "files": ["gfx/layers/mlgpu/LayerManagerMLGPU.cpp"], "git_node": null, "git_parents": [null], "node": "aadb38c31b0ceb80495f11793acbd68669bcf303", "parents": ["a8e9602f18f64bf021b8a91bd0d3f94afff3f8df"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403349 - Fix wrong sourceTabId on webNavigation.onCreatedTarget event. r=aswan, a=ritu\n\nThis changes fixes the regression introduced by Bug 1355120 and adds a new\ntest case which contains a browserAction popup which open and immediately\nclose a new window and ensure that the received onCreatedNavigationTarget\nis the expected one.\n\nMozReview-Commit-ID: JIcVCpBTpxj", "files": ["browser/components/extensions/test/browser/browser_ext_webNavigation_onCreatedNavigationTarget_window_open.js", "toolkit/modules/addons/WebNavigation.jsm", "toolkit/modules/addons/WebNavigationContent.js"], "git_node": null, "git_parents": [null], "node": "77cc7c8ce047990c36ec057d35b861cb7b7e67e3", "parents": ["aadb38c31b0ceb80495f11793acbd68669bcf303"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403349 - Prevent WebNavigation jsm to leak the sourceTab browser on unpaired CreatedNavigationTarget messages. r=aswan, a=ritu\n\nThis applies the following changes:\n\n- store a weak reference to the browser element in the WebNavigation.jsm Manager's map\n  of pending CreatedNavigationTarget messages\n\n- when a CreatedNavigationTarget message is received from a sourceTab\n  for a created window that is not currently tracked in the map\n  (e.g. it has been immediately closed), the message received from the sourceTab\n  is not saved in the map of the pending CreatedNavigationTarget (and a message\n  is logged in the console to make easier to investigate issues related to discarded\n  CreatedNavigationTarget events).\n\n- adds an additional assertion to the related test case to ensure that no CreatedNavigationTarget\n  message is still pending in the WebNavigation/jsm's Manager.\n\nMozReview-Commit-ID: FijQ8IqiY8L", "files": ["browser/components/extensions/test/browser/browser_ext_webNavigation_onCreatedNavigationTarget_window_open.js", "toolkit/modules/addons/WebNavigation.jsm"], "git_node": null, "git_parents": [null], "node": "30e6514351641ac8305e3a5838994ef9e7a99cc8", "parents": ["77cc7c8ce047990c36ec057d35b861cb7b7e67e3"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403349 - Add a new webNavigation test for window.open called with a named window target. r=aswan, a=ritu\n\nMozReview-Commit-ID: Aj8uMtcGwJx", "files": ["browser/components/extensions/test/browser/browser_ext_webNavigation_onCreatedNavigationTarget_window_open.js"], "git_node": null, "git_parents": [null], "node": "5ad5a62c35d20b99dfa7b4bcc54ccf76f67a2651", "parents": ["30e6514351641ac8305e3a5838994ef9e7a99cc8"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1403349 - Split webNavigation onCreatedNavigationTarget tests to prevent timeouts on linux32 debug. r=aswan, a=ritu\n\nMozReview-Commit-ID: 50JLocTVvfu", "files": ["browser/components/extensions/test/browser/browser-common.ini", "browser/components/extensions/test/browser/browser_ext_webNavigation_onCreatedNavigationTarget.js", "browser/components/extensions/test/browser/browser_ext_webNavigation_onCreatedNavigationTarget_contextmenu.js", "browser/components/extensions/test/browser/browser_ext_webNavigation_onCreatedNavigationTarget_named_window.js", "browser/components/extensions/test/browser/browser_ext_webNavigation_onCreatedNavigationTarget_subframe_window_open.js", "browser/components/extensions/test/browser/browser_ext_webNavigation_onCreatedNavigationTarget_window_open.js", "browser/components/extensions/test/browser/head_webNavigation.js"], "git_node": null, "git_parents": [null], "node": "3d0ba43d0afd86b10a25213390180c8019a103c3", "parents": ["5ad5a62c35d20b99dfa7b4bcc54ccf76f67a2651"], "tags": []}, {"author": "David Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "Bug 1406396 - Work around NSS utils potentially loading spurious root cert modules. r=mgoodwin, a=ritu, l10n=flod\n\nNSS command-line utilities may add a built-in root certificate module with the\nname \"Root Certs\" if run on a profile that has a copy of the module file (which\nis an unexpected configuration in general for Firefox). This can cause breakage.\nTo work around this, PSM now simply deletes any module named \"Root Certs\" at\nstartup. In an effort to prevent PSM from deleting unrelated modules\ncoincidentally named \"Root Certs\", we also prevent the user from using the\nFirefox UI to name modules \"Root Certs\".\n\nMozReview-Commit-ID: ABja3wpShO9", "files": ["security/certverifier/NSSCertDBTrustDomain.cpp", "security/manager/locales/en-US/chrome/pippki/pippki.properties", "security/manager/pki/resources/content/load_device.js", "security/manager/pki/resources/content/load_device.xul", "security/manager/ssl/PKCS11ModuleDB.cpp", "security/manager/ssl/tests/mochitest/browser/browser_loadPKCS11Module_ui.js", "security/manager/ssl/tests/unit/test_pkcs11_moduleDB.js", "security/manager/ssl/tests/unit/xpcshell-smartcards.ini"], "git_node": null, "git_parents": [null], "node": "86534d5daeef8066928eef910d6d5c60442b24b0", "parents": ["3d0ba43d0afd86b10a25213390180c8019a103c3"], "tags": ["DEVEDITION_57_0b11_RELEASE", "FENNEC_57_0b11_BUILD1", "FENNEC_57_0b11_RELEASE", "FIREFOX_57_0b11_BUILD1", "FIREFOX_57_0b11_RELEASE"]}], "date": 1508782120, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8030": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nan -\u003e a6cb9e55ca54\nast -\u003e 8281f2ce7f61\naz -\u003e e53e6a85563a\nbe -\u003e 21809a1774b9\nbg -\u003e 9965ee429400\nbn-BD -\u003e 8279c0802161\nbr -\u003e 923322628bb5\ncak -\u003e cbb3f18394e6\ncs -\u003e a3fc9e765c37\nel -\u003e fdf19cea5806\nes-AR -\u003e 553bb65b2855\nes-CL -\u003e ccc8d55e5dc4\nes-ES -\u003e 385b05704e12\nes-MX -\u003e 5fa2c8f091d3\net -\u003e fc5042e8d705\nfa -\u003e 262eb6f74270", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "0bf335bbd491ad87a1dfeb7d58b9b782e1d3e040", "parents": ["86534d5daeef8066928eef910d6d5c60442b24b0"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nach -\u003e fbd74cd56814\naz -\u003e e53e6a85563a\nbe -\u003e 21809a1774b9\nbs -\u003e 09db60726d90\ncak -\u003e cbb3f18394e6\neo -\u003e 4dd2a4d8d1bb\nes-MX -\u003e 5fa2c8f091d3", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "0eaf457f8cf0abdb4e574b72078e7fae