vatebrowsing-mask.png", "browser/themes/osx/browser.css", "browser/themes/osx/jar.mn", "browser/themes/osx/privatebrowsing-mask-short.png", "browser/themes/osx/privatebrowsing-mask-short@2x.png", "browser/themes/osx/privatebrowsing-mask.png", "browser/themes/osx/privatebrowsing-mask@2x.png", "browser/themes/shared/browser.inc.css", "browser/themes/shared/icons/private-browsing.svg", "browser/themes/shared/jar.inc.mn", "browser/themes/windows/browser.css", "browser/themes/windows/jar.mn", "browser/themes/windows/privatebrowsing-mask-tabstrip-win7.png", "browser/themes/windows/privatebrowsing-mask-tabstrip.png", "browser/themes/windows/privatebrowsing-mask-titlebar-win7-tall.png", "browser/themes/windows/privatebrowsing-mask-titlebar-win7.png", "browser/themes/windows/privatebrowsing-mask-titlebar.png"], "git_node": null, "git_parents": [null], "node": "aa83d846b65e8c5af0a2723926e25442ce14a7af", "parents": ["6169cd08ca7d5912648e2f640d17d556355eb7a8"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1383051 - added accessibility service indicators. r=jimm\n\nMozReview-Commit-ID: JrUlzpCDbw1\n", "files": ["browser/app/profile/firefox.js", "browser/base/content/browser.css", "browser/base/content/browser.js", "browser/base/content/browser.xul", "browser/base/content/test/tabs/browser.ini", "browser/base/content/test/tabs/browser_accessibility_indicator.js", "browser/components/preferences/in-content/privacy.js", "browser/locales/en-US/chrome/browser/browser.dtd", "browser/themes/osx/browser.css", "browser/themes/shared/browser.inc.css", "browser/themes/shared/icons/accessibility-active.svg", "browser/themes/shared/icons/accessibility.svg", "browser/themes/shared/jar.inc.mn", "browser/themes/windows/browser.css"], "git_node": null, "git_parents": [null], "node": "1d059590a69b58c613c018ff4e06c6eeeec1955b", "parents": ["aa83d846b65e8c5af0a2723926e25442ce14a7af"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1383051 - fixing windows 10 window control alignment and indicator alignment in windows 7. r=jaws\n\nMozReview-Commit-ID: 2aaYqbmjOjI\n", "files": ["browser/themes/osx/browser.css", "browser/themes/shared/browser.inc.css", "browser/themes/windows/browser.css"], "git_node": null, "git_parents": [null], "node": "0f94bac50b3701aa729b5fbc395119ce577edb87", "parents": ["1d059590a69b58c613c018ff4e06c6eeeec1955b"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "servo: Merge #18588 - Use array instead of linked list for -moz-border-*-colors (from upsuper:moz-border-colors-array); r=heycam\n\nThis is the Servo side change of [bug 1400438](https://bugzilla.mozilla.org/show_bug.cgi?id=1400438). (take 3)\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 8bc21d799f1a02b72ecac3994faf1d3e1c6d0397", "files": ["servo/components/style/gecko/generated/bindings.rs", "servo/components/style/gecko/generated/structs_debug.rs", "servo/components/style/gecko/generated/structs_release.rs", "servo/components/style/properties/gecko.mako.rs"], "git_node": null, "git_parents": [null], "node": "f4424ec0b730c80f28cd1c211bc075e74f1f699b", "parents": ["9699e1cbb1ab3bdba84d7548dcdcd6efca9d1190"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1400438 - Use array instead of linked list for -moz-border-*-colors. r=heycam,mattwoodrow\n\nMozReview-Commit-ID: LPl1Rlg5gRn", "files": ["js/src/devtools/rootAnalysis/analyzeHeapWrites.js", "layout/base/crashtests/1400438-1.html", "layout/base/crashtests/crashtests.list", "layout/painting/nsCSSRendering.cpp", "layout/painting/nsCSSRenderingBorders.cpp", "layout/painting/nsCSSRenderingBorders.h", "layout/style/ServoBindings.cpp", "layout/style/ServoBindings.h", "layout/style/ServoBindings.toml", "layout/style/nsComputedDOMStyle.cpp", "layout/style/nsRuleNode.cpp", "layout/style/nsStyleStruct.cpp", "layout/style/nsStyleStruct.h"], "git_node": null, "git_parents": [null], "node": "0f882496ac42b3f4461a7d6f078597b2e80cca9b", "parents": ["f4424ec0b730c80f28cd1c211bc075e74f1f699b"], "tags": []}, {"author": "J. Ryan Stinnett \u003cjryans@gmail.com\u003e", "branch": "default", "desc": "Bug 1399742 - Use default branch list for reftest-stylo. r=jmaher\n\nThis adds inbound as well as release branches.  This test is Linux 64 only, so\nthe added cost and load is hopefully minimized.\n\nMozReview-Commit-ID: AYSmqj0q6jB", "files": ["taskcluster/ci/test/tests.yml"], "git_node": null, "git_parents": [null], "node": "d1d44405008e744056f918457d48c0f1f714b1f2", "parents": ["0f882496ac42b3f4461a7d6f078597b2e80cca9b"], "tags": []}, {"author": "J. Ryan Stinnett \u003cjryans@gmail.com\u003e", "branch": "default", "desc": "Bug 1400329 - Run stylo-disabled for default branches. r=jmaher\n\nRemove stylo-disabled branch customizations so that it runs everywhere we expect\nfor tier 1, including beta and release.\n\nMozReview-Commit-ID: DbbiHTvCCyW", "files": ["taskcluster/ci/test/tests.yml"], "git_node": null, "git_parents": [null], "node": "2253d1020de58528b15e7e6333adc865d62a74c9", "parents": ["d1d44405008e744056f918457d48c0f1f714b1f2"], "tags": []}, {"author": "Imanol Fernandez \u003cmortimergoro@gmail.com\u003e", "branch": "default", "desc": "servo: Merge #18575 - Improve Webrender\u003c-\u003eWebGL synchronization (from MortimerGoro:webgl_flickering); r=glennw\n\n\u003c!-- Please describe your changes on the following line: --\u003e\n\n Webrender\u003c-\u003eWebGL synchronization is not perfect yet, and it has some flickering specially when adding more elements on the page than a single full-screen canvas.\n\nThis PR improves the synchronization by using the WR thread to perform the fence wait. All the flickering with multiple elements on the page is gone thanks to this change.\n\n---\n\u003c!-- Thank you for contributing to Servo! Please replace each `[ ]` by `[X]` when the step is complete, and replace `__` with appropriate data: --\u003e\n- [x] `./mach build -d` does not report any errors\n- [x] `./mach test-tidy` does not report any errors\n- [ ] These changes fix #14235 (github issue number if applicable).\n\n\u003c!-- Either: --\u003e\n- [x] There are tests for these changes OR\n- [ ] These changes do not require tests because _____\n\n\u003c!-- Also, please make sure that \"Allow edits from maintainers\" checkbox is checked, so that we can help you if you get stuck somewhere along the way.--\u003e\n\n\u003c!-- Pull requests that do not address these steps are welcome, but they will require additional verification as part of the review process. --\u003e\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 941757bafebecd8327fff66e0369c3c5f42d1366", "files": ["servo/components/canvas/webgl_mode/inprocess.rs", "servo/components/canvas/webgl_thread.rs", "servo/components/canvas_traits/webgl.rs", "servo/components/servo/lib.rs"], "git_node": null, "git_parents": [null], "node": "279ea05e310ad4d2bd028b26b80116c1128dc414", "parents": ["2253d1020de58528b15e7e6333adc865d62a74c9"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401461. P1 - remove ChannelMediaResource::Listener::Revoke(). r=gerald\n\nSee comment 0 for the rationale. We check |aRequest != mResource-\u003emChannel|\nto know if a new channel is being loaded and the call should be aborted.\n\nMozReview-Commit-ID: 6G1x7cXNvAq", "files": ["dom/media/ChannelMediaResource.cpp", "dom/media/ChannelMediaResource.h"], "git_node": null, "git_parents": [null], "node": "0ceb7e5789f4e88468c9b2c3ed43ba762aa87b16", "parents": ["279ea05e310ad4d2bd028b26b80116c1128dc414"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401461. P2 - don't call mChannelStatistics.AddBytes() if the data is from an old channel. r=gerald\n\nMozReview-Commit-ID: GIVwoGpo43R", "files": ["dom/media/ChannelMediaResource.cpp"], "git_node": null, "git_parents": [null], "node": "ddfa978c27f7125395975b1e3f6b6acfd12a753f", "parents": ["0ceb7e5789f4e88468c9b2c3ed43ba762aa87b16"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1401792 - Release assert when adopting element with style data across style backend. r=bholley\n\nMozReview-Commit-ID: 6D6bvSJHEcS", "files": ["dom/base/Element.h", "dom/base/nsDocument.cpp"], "git_node": null, "git_parents": [null], "node": "ae92b4765e63b78e24dfdf89d2c0d8c404a56da8", "parents": ["ddfa978c27f7125395975b1e3f6b6acfd12a753f"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "servo: Merge #18584 - Drop RulesChanged (from hiikezoe:drop-rule-changed); r=emilio\n\nIt's no longer used.\n\n\u003c!-- Please describe your changes on the following line: --\u003e\n\n---\n\u003c!-- Thank you for contributing to Servo! Please replace each `[ ]` by `[X]` when the step is complete, and replace `__` with appropriate data: --\u003e\n- [X] `./mach build -d` does not report any errors\n- [X] `./mach test-tidy` does not report any errors\n\n\u003c!-- Either: --\u003e\n- [X] These changes do not require tests because this just drops unused code.\n\n\u003c!-- Also, please make sure that \"Allow edits from maintainers\" checkbox is checked, so that we can help you if you get stuck somewhere along the way.--\u003e\n\n\u003c!-- Pull requests that do not address these steps are welcome, but they will require additional verification as part of the review process. --\u003e\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 7ce78164bff629395020dd4a25ea66d7dcc58e53", "files": ["servo/components/style/matching.rs"], "git_node": null, "git_parents": [null], "node": "22120272867fc10903abd0b8c1892ad98938c97d", "parents": ["ae92b4765e63b78e24dfdf89d2c0d8c404a56da8"], "tags": []}, {"author": "Julian_Chu \u003cwalkingice0204@gmail.com\u003e", "branch": "default", "desc": "Bug 1329152 - Enable custom tabs by default r=sebastian\n\nRemove related options, just use CustomTabs directly.\n\nMozReview-Commit-ID: DdcMHnsfAU1", "files": ["mobile/android/app/src/main/res/xml/preferences_advanced.xml", "mobile/android/base/AndroidManifest.xml.in", "mobile/android/base/AppConstants.java.in", "mobile/android/base/generate_build_config.py", "mobile/android/base/java/org/mozilla/gecko/LauncherActivity.java", "mobile/android/base/java/org/mozilla/gecko/preferences/GeckoPreferences.java", "mobile/android/base/locales/en-US/android_strings.dtd", "mobile/android/base/strings.xml.in", "mobile/android/moz.configure"], "git_node": null, "git_parents": [null], "node": "e692d1d1be1e51ac1b0dbd527b236bc2eef63d75", "parents": ["22120272867fc10903abd0b8c1892ad98938c97d"], "tags": []}, {"author": "Julian_Chu \u003cwalkingice0204@gmail.com\u003e", "branch": "default", "desc": "Bug 1329152 - turn on CustomTabs via SwitchBoard r=nechen,sebastian\n\nWe are going to enable Custom Tabs by default. Now it is still\ncontrolled by SwitchBoard in case of any accident.\n\nMozReview-Commit-ID: JREAhkYzVSu", "files": ["mobile/android/base/java/org/mozilla/gecko/Experiments.java", "mobile/android/base/java/org/mozilla/gecko/LauncherActivity.java"], "git_node": null, "git_parents": [null], "node": "7033e71f79294542fe45a40f591e45b06f236431", "parents": ["e692d1d1be1e51ac1b0dbd527b236bc2eef63d75"], "tags": []}, {"author": "Kearwood \"Kip\" Gilbert \u003ckgilbert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1389220 - Prevent navigator.activeVRDisplays from activating VR hardware and runtimes r=daoshengmu\n\nMozReview-Commit-ID: JYMiGyT0iVY", "files": ["dom/base/Navigator.cpp"], "git_node": null, "git_parents": [null], "node": "b37909c3b506a2196d9e7c41c8f72e23b15eb3c9", "parents": ["7033e71f79294542fe45a40f591e45b06f236431"], "tags": []}, {"author": "cku \u003ccku@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401069 - Part 1. Check the value of mPDFDoc and early return if it's invalid in both RenderPageToDC and DrawPageToFile. r=fatseng\n\nMozReview-Commit-ID: LQ9LTL8ZRKJ", "files": ["widget/windows/PDFViaEMFPrintHelper.cpp"], "git_node": null, "git_parents": [null], "node": "74f2aee990a98f2dd905fb2f62cab340dfc1b8b4", "parents": ["b37909c3b506a2196d9e7c41c8f72e23b15eb3c9"], "tags": []}, {"author": "cku \u003ccku@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401069 - Part 2. Implement ReleaseAllResource to make WindowsEMF::InitForDrawing reusable. r=fatseng\n\nCurrently, WindowsEMF::InitForDrawing can be used once. With the change in this\npatch, we can call WindowsEMF::InitForDrawing and Playback/SaveToFile in pair\nas many times as we want.\n\nMozReview-Commit-ID: 4fbY4Q6i9v5", "files": ["widget/windows/WindowsEMF.cpp", "widget/windows/WindowsEMF.h"], "git_node": null, "git_parents": [null], "node": "44ec9e64a5e3c9a8c54b441e9660621a7278d84f", "parents": ["74f2aee990a98f2dd905fb2f62cab340dfc1b8b4"], "tags": []}, {"author": "cku \u003ccku@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401069 - Part 3. Declare WindowsEMF::GetDC as const member function. r=fatseng\n\nMozReview-Commit-ID: BX7ahnIok2T", "files": ["widget/windows/WindowsEMF.h"], "git_node": null, "git_parents": [null], "node": "c5dfc2e657a4e5e455e73000215c760f29f9c170", "parents": ["44ec9e64a5e3c9a8c54b441e9660621a7278d84f"], "tags": []}, {"author": "cku \u003ccku@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401069 - Part 4. Change argument type from 'const RECT *' to reference type in WindowsEMF::Playback. r=fatseng\n\nMozReview-Commit-ID: 4StsIm9sqeC", "files": ["widget/windows/PDFViaEMFPrintHelper.cpp", "widget/windows/WindowsEMF.cpp", "widget/windows/WindowsEMF.h"], "git_node": null, "git_parents": [null], "node": "5ae21f43fbd35c91ab3d620c0803241e96a0ef8f", "parents": ["c5dfc2e657a4e5e455e73000215c760f29f9c170"], "tags": []}, {"author": "cku \u003ccku@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401069 - Part 5. Remove two local variables since we do not need them. r=fatseng\n\ndcWidth and dcHieght are used only once, we do not need to define a local\nvariable for any of them.\nMozReview-Commit-ID: Fw5rHqtUPQN", "files": ["widget/windows/PDFViaEMFPrintHelper.cpp"], "git_node": null, "git_parents": [null], "node": "66cbdf9b1df0cc4d3b51b41220c563c9fc2392e5", "parents": ["5ae21f43fbd35c91ab3d620c0803241e96a0ef8f"], "tags": []}, {"author": "cku \u003ccku@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401069 - Part 6. Fine tune ComputeScaleFactor. r=fatseng\n\nMake the implementation of it moew consice.\nMozReview-Commit-ID: J7v98HBLhT", "files": ["widget/windows/PDFViaEMFPrintHelper.cpp"], "git_node": null, "git_parents": [null], "node": "f6ec11335d524fab52de1f94d28136f5a708b6ff", "parents": ["66cbdf9b1df0cc4d3b51b41220c563c9fc2392e5"], "tags": []}, {"author": "cku \u003ccku@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401069 - Part 7. Declare GetPageCount as a const member function. r=fatseng\n\nMozReview-Commit-ID: IRM8FikStJi", "files": ["widget/windows/PDFViaEMFPrintHelper.h"], "git_node": null, "git_parents": [null], "node": "5e23e6f7d6d50d34b89157515c7246baec3c867e", "parents": ["f6ec11335d524fab52de1f94d28136f5a708b6ff"], "tags": []}, {"author": "cku \u003ccku@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401069 - Part 8. Give a detailed comment to explain how to react when hitting this assertion in OpenDocument(). r=fatseng\n\nMozReview-Commit-ID: 74UkMV3ZOWm", "files": ["widget/windows/PDFViaEMFPrintHelper.cpp"], "git_node": null, "git_parents": [null], "node": "3e576101b9d37f6ee8188af441b62adde57d65e6", "parents": ["5e23e6f7d6d50d34b89157515c7246baec3c867e"], "tags": []}, {"author": "abhinav \u003cabhinav.koppula@gmail.com\u003e", "branch": "default", "desc": "Bug 1382184 - Change text color of notification-box to 'theme-toolbar-color'. r=Honza\n\nMozReview-Commit-ID: ItSQobvasHa", "files": ["devtools/client/shared/components/notification-box.css"], "git_node": null, "git_parents": [null], "node": "870ce315712c4484f69ebe14fdc21f826c674d3f", "parents": ["3e576101b9d37f6ee8188af441b62adde57d65e6"], "tags": []}, {"author": "Glenn Watson \u003cgithub@intuitionlibrary.com\u003e", "branch": "default", "desc": "servo: Merge #18586 - Update WR (font variations, runtime dp ratio changes) (from glennw:update-wr-font-vars); r=metajack\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 5afb1b7dd280b988c6d4bb302d6b9ef77d79de35", "files": ["servo/Cargo.lock", "servo/components/compositing/compositor.rs", "servo/components/gfx/font_cache_thread.rs"], "git_node": null, "git_parents": [null], "node": "bbedfc5fd8be2f4ce3442c31b93fc658c69ff68c", "parents": ["870ce315712c4484f69ebe14fdc21f826c674d3f"], "tags": []}, {"author": "abhinav \u003cabhinav.koppula@gmail.com\u003e", "branch": "default", "desc": "Bug 1398522 - Sort 'Request-Headers' and 'Response-Headers' in 'Headers' tab. r=Honza\n\nMozReview-Commit-ID: AbRboDl5ADU", "files": ["devtools/client/netmonitor/src/components/headers-panel.js", "devtools/client/netmonitor/test/browser.ini", "devtools/client/netmonitor/test/browser_net_headers_sorted.js"], "git_node": null, "git_parents": [null], "node": "10fe5727b04f216f68515ecb832768435a39fad8", "parents": ["bbedfc5fd8be2f4ce3442c31b93fc658c69ff68c"], "tags": []}, {"author": "Bobby Holley \u003cbobbyholley@gmail.com\u003e", "branch": "default", "desc": "servo: Merge #18589 - Plumbing for the nth-index cache (from bholley:nth_index_plumbing); r=emilio\n\nhttps://bugzilla.mozilla.org/show_bug.cgi?id=1334730\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 39f8fce453f0a34751abb82485442429f06324bf", "files": ["servo/Cargo.lock", "servo/components/lru_cache/Cargo.toml", "servo/components/lru_cache/lib.rs", "servo/components/script/dom/element.rs", "servo/components/script/dom/node.rs", "servo/components/selectors/Cargo.toml", "servo/components/selectors/context.rs", "servo/components/selectors/lib.rs", "servo/components/selectors/matching.rs", "servo/components/style/Cargo.toml", "servo/components/style/cache.rs", "servo/components/style/context.rs", "servo/components/style/invalidation/element/invalidator.rs", "servo/components/style/lib.rs", "servo/components/style/sharing/checks.rs", "servo/components/style/sharing/mod.rs", "servo/components/style/style_resolver.rs", "servo/components/style/stylist.rs", "servo/ports/geckolib/glue.rs"], "git_node": null, "git_parents": [null], "node": "003763b2e7309a445e6cacc960fab82135a3c442", "parents": ["10fe5727b04f216f68515ecb832768435a39fad8"], "tags": []}, {"author": "Servo VCS Sync \u003cservo-vcs-sync@mozilla.com\u003e", "branch": "default", "desc": "No bug - Revendor rust dependencies", "files": ["toolkit/library/gtest/rust/Cargo.lock", "toolkit/library/rust/Cargo.lock"], "git_node": null, "git_parents": [null], "node": "6366369bd0d0c6e700cf1a2a1a861d36a7dc82db", "parents": ["003763b2e7309a445e6cacc960fab82135a3c442"], "tags": []}, {"author": "Oriol Brufau \u003coriol-bugzilla@hotmail.com\u003e", "branch": "default", "desc": "Bug 1391274 - Add a Symbol object previewer to the console. r=nchevobbe\n\nMozReview-Commit-ID: EDMep3IePZ3", "files": ["devtools/server/actors/object.js", "devtools/server/tests/unit/test_objectgrips-19.js", "devtools/server/tests/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "1c88655364bef6ed5fdcd4ab2c6e564da529cff1", "parents": ["6366369bd0d0c6e700cf1a2a1a861d36a7dc82db"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1401875 - Replace MALLOC_DECL_VOID with a clever use of templates. r=njn\n\nThis effectively means malloc_hook_table_t is now C++ only, which is not\na big problem.\n\nThis also makes some functions use a return construct with functions\nthat don't return a value (such as free). While that is not allowed in\nISO C, it's allowed in C++, so the simplification is welcome (although,\nretrospectively, it turns out C compilers don't complain about it\nwithout -pedantic).", "files": ["memory/build/malloc_decls.h", "memory/build/mozjemalloc.cpp", "memory/build/replace_malloc_bridge.h"], "git_node": null, "git_parents": [null], "node": "4f561b9294aec40e8219bfe46a3ea4e73dbde9e2", "parents": ["1c88655364bef6ed5fdcd4ab2c6e564da529cff1"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset ddfa978c27f7 (bug 1401461)", "files": ["dom/media/ChannelMediaResource.cpp"], "git_node": null, "git_parents": [null], "node": "58e2fc0076b728539fdfb632ae314bd911338759", "parents": ["4f561b9294aec40e8219bfe46a3ea4e73dbde9e2"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 0ceb7e5789f4 (bug 1401461) for leaking in mochitest run on Windows 7 debug. r=backout", "files": ["dom/media/ChannelMediaResource.cpp", "dom/media/ChannelMediaResource.h"], "git_node": null, "git_parents": [null], "node": "104d47ebd0d94af8ede278d9be6beb6d68f5c4e0", "parents": ["58e2fc0076b728539fdfb632ae314bd911338759"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 9767e159a701 (bug 1351673) for failing android lint. r=backout", "files": ["mobile/android/base/android-services.mozbuild", "mobile/android/services/src/main/java/org/mozilla/gecko/sync/DelayedWorkTracker.java", "mobile/android/services/src/main/java/org/mozilla/gecko/sync/repositories/downloaders/BatchingDownloader.java"], "git_node": null, "git_parents": [null], "node": "8eba074485cc441037a82b2aae44013ff29ed372", "parents": ["104d47ebd0d94af8ede278d9be6beb6d68f5c4e0"], "tags": []}, {"author": "Jeremy Chen \u003cjeremychen@mozilla.com\u003e", "branch": "default", "desc": "servo: Merge #18591 - stylo: do not handle the fallback discrete animation inside the Animate trait (from chenpighead:stylo-singular-matrix-animation); r=BorisChiou\n\nAt present, we do the fallback discrete animation for non-invertible matrices in\nComputedMatrix.animate(). However, according to the spec, we should fallback to\ndiscrete animation for cases like:\n\n1. animation between transform with single non-invertible matrix\n2. animation between transform with matched transform functions that have at least\n   one non-invertible matrix\n2. animation between transform with mismatched transform functions that have at\n   least one non-invertible matrix.\n\nThe current implementation only handles the first case.\n\nMoreover, we already have fallback discrete animation procedures in CSS Animation\nand Web Animation, so we should be able to not doing any fallback inside the\nAnimate trait.\n\nIn this patch, we let the animation between non-invertible matrices to return Err().\nSo, we can propagate the Err() to the callers, and let the fallback discrete\nanimation procedure stay at the Servo_MatrixTransform_Operate, which is ouside\nthe Animate trait.\n\nGecko bug: [Bug 1394284](https://bugzilla.mozilla.org/show_bug.cgi?id=1394284)\n\n---\n- [X] `./mach build -d` does not report any errors\n- [X] `./mach test-tidy` does not report any errors\n- [X] These changes fix [Bug 1394284](https://bugzilla.mozilla.org/show_bug.cgi?id=1394284)\n- [X] There are wpt tests for these changes, and thet will be landed in [Bug 1394284](https://bugzilla.mozilla.org/show_bug.cgi?id=1394284)\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: ce7cee75e4c0c8357b489be42589d96348870627", "files": ["servo/components/style/properties/helpers/animated_properties.mako.rs", "servo/ports/geckolib/glue.rs"], "git_node": null, "git_parents": [null], "node": "e8fabb53ad00dbc94ad2f77d3d58dbe04ca34f22", "parents": ["8eba074485cc441037a82b2aae44013ff29ed372"], "tags": []}, {"author": "Jeremy Chen \u003cjeremychen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1394284 - add fallback discrete procedure for transform animation. r=boris,hiro\n\nAccording to the spec, if one of the matrices for transform interpolation is\nnon-invertible, the used animation function must fall-back to a discrete\nanimation. However, in the current implementation, we always use an identity\nmatrix as a fallback for the non-invertible matrix.\n\nDecompose2DMatrix and Decompose3DMatrix both return a boolean, but we just\nnever use it. So, in this patch, we use the returned boolean from the matrix\ndecomposition as a condition, and do the fallback discrete procedure for the\nnon-invertible matrices case.\n\nMozReview-Commit-ID: E7i1a1MJOXN", "files": ["layout/style/nsStyleTransformMatrix.cpp"], "git_node": null, "git_parents": [null], "node": "9044841344c9af963ed30293d8c5ecea0ee23845", "parents": ["e8fabb53ad00dbc94ad2f77d3d58dbe04ca34f22"], "tags": []}, {"author": "Jeremy Chen \u003cjeremychen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1394284 - add wpt test for fallback discrete type of transform animation. r=boris,hiro\n\nAccording to the spec, if one of the matrices for transform interpolation is\nnon-invertible, the used animation function must fall-back to a discrete\nanimation. Add wpt tests so we can ensure the web compability for this behavior.\n\nNote that we don't add 'discrete' type for transform property in property-list.js.\nBecause the 'discrete' type also tests discrete addition and accumulation,\nhowever, the fallback behavior is just for interpolation and accumulation, not\nfor addition. So, we add tests in each part of transformListType in property-types.js.\n\nOne test is failing in Gecko, so annotate it for Gecko.\n\nMozReview-Commit-ID: 3JGvgqbBqZp", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/meta/web-animations/animation-model/animation-types/interpolation-per-property.html.ini", "testing/web-platform/tests/web-animations/animation-model/animation-types/property-types.js"], "git_node": null, "git_parents": [null], "node": "2d942fb27e398ba373cab9bccf7e5bc867615ec0", "parents": ["9044841344c9af963ed30293d8c5ecea0ee23845"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1350822 - Remove --with-android-gnu-compiler-version. r=glandium\n\ngcc 4.9 is the last version in Android NDK and our minimum requirement of gcc is 4.9+.  --with-android-gnu-compiler-version is unnecessary option because gcc version of Android is always 4.9.\n\nMozReview-Commit-ID: 1sutqlvbQU5", "files": ["build/moz.configure/android-ndk.configure", "mobile/android/config/mozconfigs/common"], "git_node": null, "git_parents": [null], "node": "fc5b1c09a348358cbb25b0e5ed82de73b86a0aeb", "parents": ["2d942fb27e398ba373cab9bccf7e5bc867615ec0"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1401754 - print in the hamburger panel should open preview on Windows/Linux but not suggest its shortcut is ctrl-p, r=dao\n\nMozReview-Commit-ID: K4yQB6ejGRv", "files": ["browser/components/customizableui/content/panelUI.inc.xul"], "git_node": null, "git_parents": [null], "node": "81c637ca25e6be73d98b1d864f2ffe9860710e5a", "parents": ["fc5b1c09a348358cbb25b0e5ed82de73b86a0aeb"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401908 - Completely disable the lightweight theme text-shadow for the Dark and Light themes. r=johannh\n\nMozReview-Commit-ID: IpsMvGyM1e1", "files": ["browser/themes/shared/compacttheme.inc.css"], "git_node": null, "git_parents": [null], "node": "b77ab1b8e557ad180b1ccd124b59779c4e672783", "parents": ["81c637ca25e6be73d98b1d864f2ffe9860710e5a"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "servo: Merge #18590 - Use Atom::from(nsIAtom) to increment reference count in case of dynam\u2026 (from hiikezoe:increment-ref-count-for-will-change); r=xidorn\n\n\u2026ic atom for will-change.\n\nIf we don't increment the reference count for the Atom in servo side, it's\npossible to try to release the Atom in servo side even if we have already\nreleased in gecko side.  When it happens, nsIAtom::mKind is no longer reliable.\n\nhttps://bugzilla.mozilla.org/show_bug.cgi?id=1401809\n\n\u003c!-- Please describe your changes on the following line: --\u003e\n\n---\n\u003c!-- Thank you for contributing to Servo! Please replace each `[ ]` by `[X]` when the step is complete, and replace `__` with appropriate data: --\u003e\n- [X] `./mach build -d` does not report any errors\n- [X] `./mach test-tidy` does not report any errors\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 581f0bf09a8ec35dadd5de207777f79138255e1a", "files": ["servo/components/style/properties/gecko.mako.rs"], "git_node": null, "git_parents": [null], "node": "77ce63ef82717bca47fae1f602d8208ba9f38b09", "parents": ["b77ab1b8e557ad180b1ccd124b59779c4e672783"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401809 - Use Atom::from(nsIAtom) to increment reference count in case of dynamic atom for will-change. r=xidorn\n\nIf we don't increment the reference count for the Atom in servo side, it's\npossible to try to release the Atom in servo side even if we have already\nreleased in gecko side.  When it happens, nsIAtom::mKind is no longer reliable.\n\nMozReview-Commit-ID: GrxbcYxowRB", "files": ["dom/animation/test/crashtests/1401809.html", "dom/animation/test/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "9caeafcec9982be90820e30bc699e851cb6af907", "parents": ["77ce63ef82717bca47fae1f602d8208ba9f38b09"], "tags": []}, {"author": "Seburo \u003cseburo3@gmail.com\u003e", "branch": "default", "desc": "Bug 1370613 - Update Book of Mozilla passage; r=ehsan\n", "files": ["toolkit/content/mozilla.xhtml", "toolkit/locales/en-US/chrome/global/mozilla.dtd"], "git_node": null, "git_parents": [null], "node": "276e210419d6a607666f82f5a948c98b5abd5af8", "parents": ["0f94bac50b3701aa729b5fbc395119ce577edb87"], "tags": []}, {"author": "Jeff Muizelaar \u003cjmuizelaar@mozilla.com\u003e", "branch": "default", "desc": "Bug 1401606 - Change a bunch of asserts! to debug_asserts! r=kats\n\nI saw these show up a bit in profiles and we have a better idea which\nthreads to call things on now.\n", "files": ["gfx/webrender_bindings/src/bindings.rs"], "git_node": null, "git_parents": [null], "node": "6772da37f539c4bd4afc893736a0d3637acbbdd8", "parents": ["276e210419d6a607666f82f5a948c98b5abd5af8"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1370613 follow-up: Switch the chapter number of the Book of Mozilla back to 14:11\n", "files": ["toolkit/content/mozilla.xhtml", "toolkit/locales/en-US/chrome/global/mozilla.dtd"], "git_node": null, "git_parents": [null], "node": "8a513ab0c11269d800fbd680bc57cca7530c566a", "parents": ["6772da37f539c4bd4afc893736a0d3637acbbdd8"], "tags": []}, {"author": "David Anderson \u003cdanderson@mozilla.com\u003e", "branch": "default", "desc": "Revert asynchronous window resizes on Windows. (bug 1380462, r=bas)", "files": ["gfx/thebes/gfxPrefs.h"], "git_node": null, "git_parents": [null], "node": "757ae5e740f21d0c703233173422efd4fce7b501", "parents": ["8a513ab0c11269d800fbd680bc57cca7530c566a"], "tags": []}, {"author": "Morris Tseng \u003cmtseng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1392200 - Update interfaces for backface-visibility support. r=kats\n\nMozReview-Commit-ID: 6ctGRSUI3pB", "files": ["gfx/webrender_bindings/WebRenderAPI.cpp", "gfx/webrender_bindings/WebRenderAPI.h", "gfx/webrender_bindings/src/bindings.rs", "gfx/webrender_bindings/webrender_ffi_generated.h"], "git_node": null, "git_parents": [null], "node": "525ab770ca31eaae484bbbd733d6d8524bbec718", "parents": ["757ae5e740f21d0c703233173422efd4fce7b501"], "tags": []}, {"author": "Morr