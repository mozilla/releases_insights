941810e80acdb32881", "parents": ["72aef98ac974f1836d64455b2dd46b7165663585"], "tags": []}, {"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging 013f57c8692e2da5d49288d77a78aa20db9dca24 with FIREFOX_57_0b12_BUILD2, FIREFOX_57_0b12_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "2e330fadc8d392141695b39f656026c123aec191", "parents": ["df0725e2e452d9b28a50e2941810e80acdb32881"], "tags": []}], "date": 1509109978, "git_changesets": [null, null], "user": "ffxbld"}, "8066": {"changesets": [{"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1410366 - Stop socket server from listening for new connections if told so. r=ato, a=test-only\n\nSimply checking '_acceptConnections' when clients are trying to\nconnect to Marionette, and revoking the connection request inside\nof 'onSocketAccepted' is plainly wrong, given that a connection is\nalready present.\n\nInstead put the socket server into close state, which means it\ndoes no longer listen for new connection attempts until new\nconnections are accepted again.\n\nMozReview-Commit-ID: JIpOgOjnpDY", "files": ["testing/marionette/harness/marionette_harness/tests/unit/test_marionette.py", "testing/marionette/server.js"], "git_node": null, "git_parents": [null], "node": "00c1f6c59a93cbe95b229de72ecc6ce8d34f874b", "parents": ["2e330fadc8d392141695b39f656026c123aec191"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1410366 - Improve socket handling in wait_for_port. r=ato, a=test-only\n\nThe temporarily created sockets have to be removed immediately\nby the operating system. Otherwise those enter the TIME_WAIT state,\nand will be removed about 90s later. This can cause a pile of orphaned\nsockets.\n\nMozReview-Commit-ID: BGy9ZOjhjT0", "files": ["testing/marionette/client/marionette_driver/marionette.py"], "git_node": null, "git_parents": [null], "node": "6092c6cb959de0fe3e7c5a8908e35f1d483a3653", "parents": ["00c1f6c59a93cbe95b229de72ecc6ce8d34f874b"], "tags": []}, {"author": "Jason Laster \u003cjason.laster.11@gmail.com\u003e", "branch": "default", "desc": "Bug 1409101 - Editor is occasionally empty. r=jdescottes, a=ritu", "files": ["devtools/client/debugger/new/debugger.js"], "git_node": null, "git_parents": [null], "node": "64aa5b5122f90089af082ca3cb64ec4ffcfc3b32", "parents": ["6092c6cb959de0fe3e7c5a8908e35f1d483a3653"], "tags": []}, {"author": "Julien Cristau \u003cjcristau@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397441 - Bump security preload information expiration dates to 2018-03-06 for Firefox 57. r=keeler, a=ritu", "files": ["security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc"], "git_node": null, "git_parents": [null], "node": "9d9ed1a5d9e98ef83f029c73cc08e68759da510d", "parents": ["64aa5b5122f90089af082ca3cb64ec4ffcfc3b32"], "tags": []}], "date": 1509117175, "git_changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "8067": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nbg -\u003e 8c7cacdc06b4\neo -\u003e 6f4c29485b08\nfa -\u003e cced4e3301b0\nit -\u003e 3e53249f1e59", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "0320202e4e97ad802ee92977c1790c5bf493c95a", "parents": ["9d9ed1a5d9e98ef83f029c73cc08e68759da510d"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nbg -\u003e 8c7cacdc06b4\neo -\u003e 6f4c29485b08\nfr -\u003e 291b6ca22054\nit -\u003e 55205ba4c366", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "29eb088fc67db4d21f40a5e4fa573dc