test-only", "files": ["gfx/layers/apz/test/mochitest/mochitest.ini"], "git_node": null, "git_parents": [null], "node": "499fc78f9bb5aebb5a7de3095285a90c2e278162", "parents": ["8222f6a4a5ab5160bbdbe35eb8a0af013c603a43"], "tags": []}, {"author": "Lars T Hansen \u003clhansen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1404683 - Introduce wasmCompileMode in testing functions, only run a baseline oom test when baseline-only compilation is enabled. r=bbouvier, a=test-only", "files": ["js/src/builtin/TestingFunctions.cpp", "js/src/jit-test/tests/wasm/regress/oom-masm-baseline.js"], "git_node": null, "git_parents": [null], "node": "fdd6f2f9f74dfc838866e5d6b4ac56ff5acb95bb", "parents": ["499fc78f9bb5aebb5a7de3095285a90c2e278162"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1404105 - Sanitize.js must check if QuotaManager returns an error before continuing with cleaning data. r=janv, a=ritu", "files": ["browser/base/content/sanitize.js", "browser/components/extensions/ext-browsingData.js"], "git_node": null, "git_parents": [null], "node": "9c6653abae8431df9cf4fdbf35c07444ecf8e21b", "parents": ["fdd6f2f9f74dfc838866e5d6b4ac56ff5acb95bb"], "tags": []}], "date": 1508279186, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7997": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nid -\u003e 7e8e87d5ebb8\nro -\u003e b539951b54b2", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "35f69d7d6c24e1c4e3dee0dbdd202d113c58eeed", "parents": ["9c6653abae8431df9cf4fdbf35c07444ecf8e21b"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nes-MX -\u003e 4ea636d35623\ngu-IN -\u003e 8b57331533b6\nid -\u003e 7e8e87d5ebb8\nkab -\u003e d6356d272644\nro -\u003e b539951b54b2\nzh-CN -\u003e 409ae02b8b9b", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "ab8bb7264d23996c30126f8f73948f20427892b2", "parents": ["35f69d7d6c24e1c4e3dee0dbdd202d113c58eeed"], "tags": []}], "date": 1508286021, "git_changesets": [null, null], "user": "ffxbld"}, "7998": {"changesets": [{"author": "Jeff Gilbert \u003cjgilbert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1394265 - Set MAX_COMBINED_TEXTURE_IMAGE_UNITS to 0 if GetIntegeriv fails. - r=daoshengmu a=ritu\n\nMozReview-Commit-ID: 6VDKmtVPrVO\n", "files": ["dom/canvas/WebGLContextValidate.cpp"], "git_node": null, "git_parents": [null], "node": "0cc2943b6df8540cddc1422d56251fbaebc19ae2", "parents": ["ab8bb7264d23996c30126f8f73948f20427892b2"], "tags": []}], "date": 1508286483, "git_changesets": [null], "user": "jgilbert@mozilla.com"}, "7999": {"changesets": [{"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1408782 - Force punycode display for IDNs with a \u003cdotless-i, combining mark above\u003e sequence. r=valentin a=ritu", "files": ["netwerk/dns/nsIDNService.cpp", "netwerk/test/unit/test_idn_urls.js"], "git_node": null, "git_parents": [null], "node": "660349c13c4f1785f57996b0dddd33f8eac5a957", "parents": ["0cc2943b6df8540cddc1422d56251fbaebc19ae2"], "tags": []}], "date": 1508318739, "git_changesets": [null], "user": "jkew@mozilla.com"}, "8000": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nbe -\u003e b09825bde117\nkn -\u003e 2da56588ded2", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "caab78f5e67410405c7ddef838fb76d6fd0152c2", "parents": ["660349c13c4f1785f57996b0dddd33f8eac5a957"], "tags": []}], "date": 1508325621, "git_changesets": [null], "user": "ffxbld"}, "8001": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nkn -\u003e 684e3ff40221\nms -\u003e 53eca7fc0872", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "ed4449f8912b7f7795111cba47a49ff595980d6b", "parents": ["caab78f5e67410405c7ddef838fb76d6fd0152c2"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nar -\u003e 6c8626f81411\nit -\u003e 3605a7132d25\nkn -\u003e 684e3ff40221\nms -\u003e 7b4afc57b026\npl -\u003e 9908d9f0e946", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "d64de9e6a3b2c70b6c0185970b8966adeedceece", "parents": ["ed4449f8912b7f7795111cba47a49ff595980d6b"], "tags": []}], "date": 1508340042, "git_changesets": [null, null], "user": "ffxbld"}, "8002": {"changesets": [{"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1342299 - browser_tab_close_dependent_window.js should wait for the tab to have gone away. rs=firebot, a=test-only\n\nSpeculative fix to see if this helps deal with the intermittent orange. Seems to at least not cause\nother issues locally.\n\nMozReview-Commit-ID: E1T37mgAAqy", "files": ["browser/base/content/test/general/browser_tab_close_dependent_window.js"], "git_node": null, "git_parents": [null], "node": "897d2ea37106bbf8154e8da591ec233f3deadab6", "parents": ["d64de9e6a3b2c70b6c0185970b8966adeedceece"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1396184 - Disable uriloader/exthandler/tests/mochitest/browser_ext_helper_pb.js on OSX for frequent failures. r=me, a=test-only", "files": ["uriloader/exthandler/tests/mochitest/browser.ini"], "git_node": null, "git_parents": [null], "node": "80135600be68ddf6b75f60e1d7fce344f9b80651", "parents": ["897d2ea37106bbf8154e8da591ec233f3deadab6"], "tags": []}, {"author": "Kevin Jones \u003ckevinhowjones@gmail.com\u003e", "branch": "default", "desc": "Bug 1406912 - Fix _serializeRangeData does not handle ranges found in same node properly. r=mixedpuppy, a=ritu", "files": ["browser/components/extensions/test/browser/browser_ext_find.js", "browser/components/extensions/test/browser/file_find_frames.html", "toolkit/components/extensions/FindContent.jsm"], "git_node": null, "git_parents": [null], "node": "f6eacd81d2d8b96c35a7b069845f1f3974efcc68", "parents": ["80135600be68ddf6b75f60e1d7fce344f9b80651"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1407475 - Fix IAccessible::accNavigate(NAVRELATION_EMBEDS) for e10s. r=surkov, a=ritu\n\nWhen we only have a single process, this can be (and was previously) handled the same way as any other relation.\nHowever, for multi process, the normal relation mechanism doesn't work because it can't handle remote objects.\nThis patch overrides accNavigate for the root accessible to handle this, since this is only ever used on the root.\n\nMozReview-Commit-ID: JLm5zITfG6Y", "files": ["accessible/windows/msaa/RootAccessibleWrap.cpp", "accessible/windows/msaa/RootAccessibleWrap.h"], "git_node": null, "git_parents": [null], "node": "21608c94652f308e27ee6779d23736f55e037eb2", "parents": ["f6eacd81d2d8b96c35a7b069845f1f3974efcc68"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1408638 - Ensure accessible isn't defunct in Windows RootAccessibleWrap::accNavigate. r=MarcoZ, a=ritu\n\nBug 1407475 added support for accNavigate(NAVRELATION_EMBEDS) for e10s.\nHowever, it's possible for a client to call this on the root accessible for a window which was since closed.\nTherefore, we must check whether the root accessible is defunct before trying to retrieve the tab document.\n\nMozReview-Commit-ID: 9iR6Kvzu5Mb", "files": ["accessible/windows/msaa/RootAccessibleWrap.cpp"], "git_node": null, "git_parents": [null], "node": "ce581d83a38e142e9a43a300d0748e7b736e418e", "parents": ["21608c94652f308e27ee6779d23736f55e037eb2"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1407999 - Support locked prefs for homepage. r=jaws, a=ritu\n\nMozReview-Commit-ID: FDxfKY5HvTP", "files": ["browser/components/preferences/in-content/main.js", "browser/components/preferences/in-content/tests/browser_homepages_filter_aboutpreferences.js"], "git_node": null, "git_parents": [null], "node": "8bf87cac5783dbf98819debda5e74113b7e22b5b", "parents": ["ce581d83a38e142e9a43a300d0748e7b736e418e"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1409141 - Disable D3D11 YUV buffer copy on Windows 7. r=mattwoodrow, a=ritu\n\nThe crashes on Windows 7 appear to occur due to the D3D11 device being used on two different threads simultaneously. We do query the driver to determine if multithreaded access is supported, but they obviously aren't that cluey about it.\n\nMozReview-Commit-ID: GZIk1Zf9xKQ", "files": ["dom/media/MediaData.cpp"], "git_node": null, "git_parents": [null], "node": "e0d56de2214bf49e23d5a9f80a8899ebbb464c77", "parents": ["8bf87cac5783dbf98819debda5e74113b7e22b5b"], "tags": []}, {"author": "Sylvestre Ledru \u003csledru@mozilla.com\u003e", "branch": "default", "desc": "Bug 1409382 - EnumSet.h - Initialize mVersion to silence a warning with gcc 8. r=froydnj, a=ritu\n\nMozReview-Commit-ID: CfTs6IAP1z5", "files": ["mfbt/EnumSet.h"], "git_node": null, "git_parents": [null], "node": "d4e212a2b1e1180c245dd528c39500991de311ad", "parents": ["e0d56de2214bf49e23d5a9f80a8899ebbb464c77"], "tags": []}], "date": 1508353199, "git_changesets": [null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8003": {"changesets": [{"author": "Ian Moody \u003cmoz-ian@perix.co.uk\u003e", "branch": "default", "desc": "Bug 1399429 - Properly determine if the content window is private for the contextMenu. r=Felipe, a=ritu\n\nMozReview-Commit-ID: 7kTt50k5JxM", "files": ["browser/modules/ContextMenu.jsm"], "git_node": null, "git_parents": [null], "node": "be62e8e756ba5b95455fbd4f1a11b44bae8e3912", "parents": ["d4e212a2b1e1180c245dd528c39500991de311ad"], "tags": []}, {"author": "Matt Howell \u003cmhowell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1337856 - Part 1: Use a better up/down-scaling method for the stub installer background. r=agashlin, a=ritu\n\nMozReview-Commit-ID: Ag02ni4nJ00", "files": ["browser/installer/windows/nsis/stub.nsi", "toolkit/mozapps/installer/windows/nsis/common.nsh"], "git_node": null, "git_parents": [null], "node": "628e941a223c24bb73c6e59e5700ee26234d3df0", "parents": ["be62e8e756ba5b95455fbd4f1a11b44bae8e3912"], "tags": []}, {"author": "Matt Howell \u003cmhowell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1337856 - Part 2: Swap out stub installer background images with JPEG's, and add high-res versions. r=agashlin, a=ritu\n\nMozReview-Commit-ID: AUa58uY8pKW", "files": ["browser/branding/aurora/bgstub.bmp", "browser/branding/aurora/bgstub.jpg", "browser/branding/aurora/bgstub_2x.jpg", "browser/branding/branding-common.mozbuild", "browser/branding/nightly/bgstub.bmp", "browser/branding/nightly/bgstub.jpg", "browser/branding/nightly/bgstub_2x.jpg", "browser/branding/official/bgstub.bmp", "browser/branding/official/bgstub.jpg", "browser/branding/official/bgstub_2x.jpg", "browser/branding/unofficial/bgstub.bmp", "browser/branding/unofficial/bgstub.jpg", "browser/branding/unofficial/bgstub_2x.jpg", "browser/installer/windows/Makefile.in"], "git_node": null, "git_parents": [null], "node": "808585a48181544b0badc15f03711fd5d26d1269", "parents": ["628e941a223c24bb73c6e59e5700ee26234d3df0"], "tags": []}, {"author": "JW Wang \u003cjwwang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400674 - Fix the algorithm of filling audio gaps with silence. r=jya, a=ritu\n\nMozReview-Commit-ID: Hjsboq6PdlN", "files": ["dom/media/mediasink/AudioSink.cpp"], "git_node": null, "git_parents": [null], "node": "413220444b15681a7f5af66514b4e66e9b434005", "parents": ["808585a48181544b0badc15f03711fd5d26d1269"], "tags": []}, {"author": "bechen@mozilla.com \u003cbechen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1408693 - Add a lock to protect the sGPUCrashDataMap. r=jwwang, a=ritu\n\nMozReview-Commit-ID: 7NDcoGMkKZ3", "files": ["dom/media/MediaFormatReader.cpp"], "git_node": null, "git_parents": [null], "node": "28f4ccb3c041da6497a98fbc9e291579d32c69fb", "parents": ["413220444b15681a7f5af66514b4e66e9b434005"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1398696 - Override the window background to Windows Aero Basic colors for Light/Dark theme on Windows 7. r=dao, a=ritu\n\nThis color is originally set to the accent-color of lwthemes, which is expected,\nbut we want to have the original Aero Basic look in the background on Windows 7\nfor light/dark and themes to mirror the default theme.\n\nMozReview-Commit-ID: 7KfBF9Ey27A", "files": ["browser/themes/windows/compacttheme.css"], "git_node": null, "git_parents": [null], "node": "c64932850093d2f4988528cd70344da4a0643347", "parents": ["28f4ccb3c041da6497a98fbc9e291579d32c69fb"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1408397 - FileReader should not use a bufferStream together with an async inputStream. r=smaug, a=ritu", "files": ["dom/file/FileReader.cpp", "dom/file/FileReader.h"], "git_node": null, "git_parents": [null], "node": "7819bf87d650d12a88474d60fcd306fc5aa7fbb7", "parents": ["c64932850093d2f4988528cd70344da4a0643347"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1404111 - Part 0: Fix Javadoc. r=JanH, a=ritu\n\nMozReview-Commit-ID: 69yqr7ybioX", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoView.java"], "git_node": null, "git_parents": [null], "node": "f645623441b344b2418fedfb4351989547a5f2a0", "parents": ["7819bf87d650d12a88474d60fcd306fc5aa7fbb7"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1404111 - Part 1: Work around potential InputMethodManager bug when gaining focus. r=snorp, a=ritu\n\nMozReview-Commit-ID: 2YnsMCZYckA", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoView.java"], "git_node": null, "git_parents": [null], "node": "7a9e0869a2e695ace50a38568b76d59e07249b9c", "parents": ["f645623441b344b2418fedfb4351989547a5f2a0"], "tags": []}, {"author": "Felipe Gomes \u003cfelipc@gmail.com\u003e", "branch": "default", "desc": "Bug 1405655 - Only hide Flash Activation overlay UI if the entire plugin is covered. r=dthayer, a=ritu\n\nAs opposed to right now where we hide if any of the corners or the center of the plugin is covered.\n\nMozReview-Commit-ID: 9mOVXYyV1Il", "files": ["browser/base/content/test/plugins/browser.ini", "browser/base/content/test/plugins/browser_CTP_shouldShowOverlay.js", "browser/base/content/test/plugins/plugin_shouldShowOverlay.html", "browser/modules/PluginContent.jsm"], "git_node": null, "git_parents": [null], "node": "b95894a2554fa322d53dc4aa8e7de32637b96f78", "parents": ["7a9e0869a2e695ace50a38568b76d59e07249b9c"], "tags": []}, {"author": "Jonathan Kingston \u003cjkt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1407209 - Add observer for preference changes whilst extensions are being updated. r=aswan, r=baku, r=bsilverberg, a=ritu\n\nMozReview-Commit-ID: 5CqpYDc4tCg", "files": ["toolkit/components/contextualidentity/ContextualIdentityService.jsm", "toolkit/components/extensions/ExtensionPreferencesManager.jsm", "toolkit/components/extensions/test/xpcshell/test_ext_contextual_identities.js"], "git_node": null, "git_parents": [null], "node": "2621743af55cd16af98570f306d091468d1a8e42", "parents": ["b95894a2554fa322d53dc4aa8e7de32637b96f78"], "tags": []}, {"author": "Andrew Sutherland \u003casutherland@asutherland.org\u003e", "branch": "default", "desc": "Bug 1404344 - Part 1: Alias QuotaManager schema 3.0 to 2.1. r=janv, a=ritu\n\nTo improve the Firefox 57 to 56 downgrade scenario, have 57 and 58\nre-number the version 3.0 schema introduced by bug 1290481 to\nversion 2.1.  Firefox 56's Quota Manager will recognize the minor\nschema version and accept the schema from the future.", "files": ["dom/quota/ActorsParent.cpp", "dom/quota/Client.h", "dom/quota/QuotaManager.h"], "git_node": null, "git_parents": [null], "node": "6513161002fc5715cf7996a22fb7998226073dbc", "parents": ["2621743af55cd16af98570f306d091468d1a8e42"], "tags": []}, {"author": "Andrew Sutherland \u003casutherland@asutherland.org\u003e", "branch": "default", "desc": "Bug 1404344 - Part 2: DOM Cache API schema 57-56 downgrade support. r=bkelly, a=ritu\n\nAlter 57 and 58 DOM Cache API to use an on-disk schema version of 25 again,\nas was used prior to the landing of bug 1290481 that bumped the disk schema\nversion to 26.  Patched versions will recognize this internally as schema 27\nbased on the presence of the column introduced by the 26 upgrade.", "files": ["dom/cache/DBSchema.cpp", "dom/cache/QuotaClient.cpp"], "git_node": null, "git_parents": [null], "node": "23f60d61fee7240c71b3cd01622d6be925ceb9bd", "parents": ["6513161002fc5715cf7996a22fb7998226073dbc"], "tags": []}, {"author": "Andrew Sutherland \u003casutherland@asutherland.org\u003e", "branch": "default", "desc": "Bug 1404344 - Part 3: Rename QuotaManager tests from 3_0 to 2_1. r=janv, a=ritu\n\nUpgrade the test names from 3.0/3_0 to 2.1/2_1, consistent with the changes\nmade in part 1.", "files": ["dom/quota/test/unit/test_version2_1upgrade.js", "dom/quota/test/unit/test_version3_0upgrade.js", "dom/quota/test/unit/version2_1upgrade_profile.zip", "dom/quota/test/unit/version3_0upgrade_profile.zip", "dom/quota/test/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "2a12a0f1984c90bde7bc51dc3b76077902177721", "parents": ["23f60d61fee7240c71b3cd01622d6be925ceb9bd"], "tags": []}, {"author": "Randell Jesup \u003crjesup@jesup.org\u003e", "branch": "default", "desc": "Bug 1407680 - Set DelayAgnostic and ExtendedFilter options. r=dminor, a=ritu\n\nThis was lost due to API changes in the update to upstream v57", "files": ["dom/media/webrtc/MediaEngineWebRTC.cpp", "dom/media/webrtc/MediaEngineWebRTC.h", "dom/media/webrtc/MediaEngineWebRTCAudio.cpp"], "git_node": null, "git_parents": [null], "node": "5f8523ca22a5567570ca8d173579ab80212b6190", "parents": ["2a12a0f1984c90bde7bc51dc3b76077902177721"], "tags": []}, {"author": "Stephen A Pohl \u003cspohl.mozilla.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1408701 - Ensure that we continue to show dark scrollbar thumbs on macOS 10.13 when scrollbars are always displayed. r=mstange, a=ritu", "files": ["widget/cocoa/nsNativeThemeCocoa.mm"], "git_node": null, "git_parents": [null], "node": "adc0384c565aae18fd8b2a669363ac27bd3a6676", "parents": ["5f8523ca22a5567570ca8d173579ab80212b6190"], "tags": []}], "date": 1508365395, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8004": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changesets 7a9e0869a2e6 and f645623441b3 (bug 1404111) for Android bustage.", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoView.java"], "git_node": null, "git_parents": [null], "node": "1d56d3922195efcabe9807b8ec0ea216397f90b4", "parents": ["adc0384c565aae18fd8b2a669363ac27bd3a6676"], "tags": []}], "date":