eTypes.ipdlh", "dom/cache/ReadStream.cpp"], "git_node": null, "git_parents": [null], "node": "ee4c8b6d9a083e24a6f902e9f3b3621561ab9451", "parents": ["c0a6198c2345c243a40f82220f7640ddcb755515"], "tags": []}, {"author": "Ethan \u003cettseng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397938 - Download protection whitelist and blacklist are not available for the Android platform. r=francois", "files": ["mobile/android/app/mobile.js"], "git_node": null, "git_parents": [null], "node": "8e62c82e6dacb76ac5b28bd28b1a3cf43aa2caa7", "parents": ["ee4c8b6d9a083e24a6f902e9f3b3621561ab9451"], "tags": []}, {"author": "Liang-Heng Chen \u003cxeonchen@gmail.com\u003e", "branch": "default", "desc": "Bug 1399409 - Ignore about:blank in awaitBrowserLoaded. r=kmag\n\nMozReview-Commit-ID: 8WoN86Zd6PS", "files": ["browser/components/extensions/test/browser/head.js"], "git_node": null, "git_parents": [null], "node": "fe4ce395c7ce3cbb3bf180b29fe2b93ca7a43988", "parents": ["8e62c82e6dacb76ac5b28bd28b1a3cf43aa2caa7"], "tags": []}, {"author": "Mark Collins \u003ctera_1225@hotmail.com\u003e", "branch": "default", "desc": "Bug 1398329 - Convert uses of defer to new Promise in client/shared (except in test/, vendor/ and widgets/ subdirs). r=Honza, r=nchevobbe", "files": ["devtools/client/shared/AppCacheUtils.jsm", "devtools/client/shared/developer-toolbar.js", "devtools/client/shared/doorhanger.js", "devtools/client/shared/frame-script-utils.js", "devtools/client/shared/getjson.js", "devtools/client/shared/poller.js", "devtools/client/shared/redux/middleware/promise.js"], "git_node": null, "git_parents": [null], "node": "e5d3009b7d0adc90e80530d8074b3703381dd477", "parents": ["fe4ce395c7ce3cbb3bf180b29fe2b93ca7a43988"], "tags": []}, {"author": "Francesco Lodolo (:flod) \u003cflod@lodolo.net\u003e", "branch": "default", "desc": "Bug 1399511 - Update message displayed when a section has no data in about:telemetry r=chutten\n\nMozReview-Commit-ID: 2Hb4oKKlhG7", "files": ["toolkit/content/aboutTelemetry.js", "toolkit/locales/en-US/chrome/global/aboutTelemetry.properties"], "git_node": null, "git_parents": [null], "node": "8998495d56dcb03aac5376b72ccd73ab19dbfc8c", "parents": ["f73a6867afeead095c1804adb63815fb885af2f3"], "tags": []}, {"author": "Andrew Swan \u003caswan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400129 Remove unused accessKey l10n property r=flod\n\nMozReview-Commit-ID: 3K5Mt2blZgl", "files": ["mobile/android/locales/en-US/chrome/browser.properties"], "git_node": null, "git_parents": [null], "node": "18dad63ef0c67b7bc0e8afb4c1268d5d6c30a55b", "parents": ["8998495d56dcb03aac5376b72ccd73ab19dbfc8c"], "tags": []}, {"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1399796 - UnsubmittedCrashHandler should never check for unsubmitted crash reports if disabled or suppressed. r=Felipe\n\nBug 1355492 moved the logic for scanning for unsubmitted crash reports out of the initialization\nof UnsubmittedCrashHandler, and the initialization is what decided whether or not it was\nappropriate to scan in the first place. This was done so that scanning could be deferred\nuntil idle after first paint.\n\nThis patch makes it so that the scanning logic first ensures that the UnsubmittedCrashHandler\nis actually enabled and not suppressed (which is calculated earlier).\n\nI've also taken the liberty of adding a regression test.\n\nMozReview-Commit-ID: 3Aihom5Q17R", "files": ["browser/modules/ContentCrashHandlers.jsm", "browser/modules/test/browser/browser_UnsubmittedCrashHandler.js"], "git_node": null, "git_parents": [null], "node": "1256cadba71bc9e0677e4f92174bc76ad8952eb5", "parents": ["18dad63ef0c67b7bc0e8afb4c1268d5d6c30a55b"], "tags": []}, {"author": "Ian Bicking \u003cianb@colorstudy.com\u003e", "branch": "default", "desc": "Bug 1399615 - Export Screenshots 19.0.0 to Firefox r=kmag\n\nMozReview-Commit-ID: 1QFbWCThVeg", "files": ["browser/extensions/screenshots/bootstrap.js", "browser/extensions/screen