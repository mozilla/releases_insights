 r=nox, a=sledru\n\nSee each commit for details.\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: bbb5c8436edb89235fe030e8dc965b9bef43c071", "files": ["servo/components/style/properties/gecko.mako.rs", "servo/components/style/properties/longhand/inherited_svg.mako.rs"], "git_node": null, "git_parents": [null], "node": "6e4272e16bb2ad4103900c7595643a229d9337af", "parents": ["cda60381e179196bd55dcb09ba9d114bec41c59a"], "tags": []}, {"author": "Fernando Jimenez Moreno \u003cferjmoreno@gmail.com\u003e", "branch": "default", "desc": "Bug 1397619 - stylo: test border-radius longhand specified values serialization. r=emilio, a=sledru\n\nMozReview-Commit-ID: FWN56IcctTJ\nSigned-off-by: Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "files": ["layout/style/test/test_specified_value_serialization.html"], "git_node": null, "git_parents": [null], "node": "dea074a3264f0f6526fc10c002afb7c3d8539d85", "parents": ["6e4272e16bb2ad4103900c7595643a229d9337af"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1397619 - Test border-spacing specified value serialization. r=me, a=sledru\n\nMozReview-Commit-ID: 1L5mjfvYRLQ\nSigned-off-by: Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "files": ["layout/style/test/test_specified_value_serialization.html"], "git_node": null, "git_parents": [null], "node": "772fb56b0982b210b49374b5b52aaa952987307c", "parents": ["dea074a3264f0f6526fc10c002afb7c3d8539d85"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1397619 - Test paint-order specified value serialization. r=me, a=sledru\n\nMozReview-Commit-ID: ICtzbZVix1u\nSigned-off-by: Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "files": ["layout/style/test/test_specified_value_serialization.html"], "git_node": null, "git_parents": [null], "node": "9c121063b2ae8913327355783439839a515a2cf8", "parents": ["772fb56b0982b210b49374b5b52aaa952987307c"], "tags": []}], "date": 1506604710, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7843": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1402366 - Mark datetimebox as not needing xul.css. r=bholley, r=jessica, a=sledru\n\nWe create a datetimebox in content documents that gets an XBL binding on\nnsDateTimeControlFrame::CreateAnonymousContent.\n\nThis is done during frame construction, and loading a datetimebox insert xul.css\nin the document, which causes invalidation to run.\n\ndatetimebox styles are in html.css, and there's no rule in xul.css that styles\nit, so we don't need to load the stylesheet at all.\n\nMozReview-Commit-ID: 2SbIOoER2uB", "files": ["dom/xul/nsXULElement.cpp"], "git_node": null, "git_parents": [null], "node": "12d437dedc4d2724ece4135596d4687a8fe38cd0", "parents": ["9c121063b2ae8913327355783439839a515a2cf8"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1402366 - Crashtest. r=me, a=sledru\n\nMozReview-Commit-ID: 8ZcVBHKNntj", "files": ["layout/style/crashtests/1402366.html", "layout/style/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "13e98e34ff2811f68cbee69c9b181ae2eaca3353", "parents": ["12d437dedc4d2724ece4135596d4687a8fe38cd0"], "tags": []}, {"author": "Towkir Ahmed \u003ctowkir17@gmail.com\u003e", "branch": "default", "desc": "Bug 1363028 - Update bookmark toolbar icons to photon styles. r=johannh, a=sledru", "files": ["browser/themes/linux/browser.css", "browser/themes/linux/jar.mn", "browser/themes/linux/places/calendar.png", "browser/themes/linux/places/query.png", "browser/themes/osx/browser.css", "browser/themes/osx/jar.mn", "browser/themes/osx/page-livemarks@2x.png", "browser/themes/osx/places/history.png", "browser/themes/osx/places/history@2x.png", "browser/themes/osx/places/query.png", "browser/themes/osx/places/query@2x.png", "browser/themes/shared/toolbarbutton-icons.inc.css", "browser/themes/windows/browser.css", "browser/themes/windows/jar.mn", "browser/themes/windows/livemark-folder.png", "browser/themes/windows/places/calendar.png", "browser/themes/windows/places/query.png"], "git_node": null, "git_parents": [null], "node": "995866fb3357e7fa89c7e83877a0cf9fe4e3f957", "parents": ["13e98e34ff2811f68cbee69c9b181ae2eaca3353"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1403028 - Ensure the parent is in the composed doc before marking it as dirty. r=heycam, a=sledru\n\nWe could do the check earlier, but the end result is effectively the same, and\nthis makes it easier to remove.\n\nMozReview-Commit-ID: 5c8TFHK1ciD", "files": ["layout/base/ServoRestyleManager.cpp"], "git_node": null, "git_parents": [null], "node": "c363a41fc89928a55ccd7aaf9ab835bd1299c6c1", "parents": ["995866fb3357e7fa89c7e83877a0cf9fe4e3f957"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1403028 - Crashtest. r=heycam, a=sledru\n\nMozReview-Commit-ID: 68vEodg5jzR", "files": ["layout/style/crashtests/1403028.html", "layout/style/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "f8eb0cd96943082953eca6728f70fb6e4bb430b3", "parents": ["c363a41fc89928a55ccd7aaf9ab835bd1299c6c1"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1390276 - Make the options_ui background transparent. r=rhelmer, a=sledru\n\nMozReview-Commit-ID: Imowx5I5YK4", "files": ["toolkit/mozapps/extensions/content/extensions.js"], "git_node": null, "git_parents": [null], "node": "3ab379041f96a8a4c135a72b02f8dff9935e7232", "parents": ["f8eb0cd96943082953eca6728f70fb6e4bb430b3"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1401009 - Add border between notification buttons when highlight is disabled. r=johannh, a=sledru\n\nMozReview-Commit-ID: 4YGdUZstiDk", "files": ["toolkit/themes/linux/global/notification.css", "toolkit/themes/osx/global/notification.css", "toolkit/themes/windows/global/notification.css"], "git_node": null, "git_parents": [null], "node": "2399e64d6af2cb9c8be4aff60f7d8b45c0598df6", "parents": ["3ab379041f96a8a4c135a72b02f8dff9935e7232"], "tags": []}, {"author": "Manish Goregaokar \u003cmanishearth@gmail.com\u003e", "branch": "default", "desc": "Bug 1403282 - stylo: Don't error out on trailing whitespace in attr(). r=bz, a=sledru\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 97227aaca3613e22afc832554d29f7f7fdfb7220", "files": ["servo/components/style/values/specified/mod.rs"], "git_node": null, "git_parents": [null], "node": "318aab4f559397c6e661db77f0d8f75ba6bb72e5", "parents": ["2399e64d6af2cb9c8be4aff60f7d8b45c0598df6"], "tags": []}, {"author": "Manish Goregaokar \u003cmanishearth@gmail.com\u003e", "branch": "default", "desc": "Bug 1403282 - stylo: Add reftests for whitespace in attr(). r=bz, a=sledru\n\nMozReview-Commit-ID: IMXFY7bpKGf", "files": ["layout/reftests/generated-content/attr-whitespace-ref.html", "layout/reftests/generated-content/attr-whitespace.xhtml", "layout/reftests/generated-content/reftest.list"], "git_node": null, "git_parents": [null], "node": "d37c4ff7807c023e78a0bb0cd8d52c231a89f3ed", "parents": ["318aab4f559397c6e661db77f0d8f75ba6bb72e5"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1403347 - Move initial setHidden to panel preference constructor. r=liuche, a=sledru\n\nThis is a code clean-up. Functionally, this is the same to the previous\nimplementation.\n\nsetHidden was originally called right after the constructor is called and so\nshould just be called from the constructor. If it's not called from the\nconstructor, there can be a period of confusion where a developer wonders, \"Has\nisHidden been initialized by the time this other method I care about has been\ncalled?\" This should make those questions disappear.\n\nThis commit does not need to be uplifted (to change less in 57 and that the\nother code does not depend on it) but I'm placing it first so it's clearer to\nmy reviewer when isHidden is initialized (which is relevant to my other\npatches).\n\nMozReview-Commit-ID: 80KXFDB1poY", "files": ["mobile/android/base/java/org/mozilla/gecko/preferences/PanelsPreference.java", "mobile/android/base/java/org/mozilla/gecko/preferences/PanelsPreferenceCategory.java", "mobile/android/base/java/org/mozilla/gecko/preferences/TopSitesPanelsPreference.java"], "git_node": null, "git_parents": [null], "node": "cfed66643774a87e0335d3879fa1c9a18b4a305a", "parents": ["d37c4ff7807c023e78a0bb0cd8d52c231a89f3ed"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1403347 - Set dialog titles in createDialogItems. r=liuche, a=sledru\n\nWe manipulate the data before the dialog is shown, rather than manipulating the\nViews after the dialog is shown: this is more stable.\n\nOne question is what is the value of isHidden, which we branch on, when we're\nmanipulating the data. isHidden is set:\n- When the preference is constructed (previous commit)\n- When the preference is set as the default (e.g. the default panel was hidden)\n- When \"Hide\" or \"Show\" is clicked in the preference\n\nThus the preference (and hidden state) outlives the dialog and each time we\nreread the value of isHidden to set the dialog items.\n\nThis would fix the bug but the dialog values are actually cached so we'll\nneed to fix/remove that cache: coming up in the next changeset.\n\nMozReview-Commit-ID: 86v1RDNFZHZ", "files": ["mobile/android/base/java/org/mozilla/gecko/preferences/PanelsPreference.java"], "git_node": null, "git_parents": [null], "node": "7d38c920f81ad04972bf57b4cdae91cee244cf13", "parents": ["cfed66643774a87e0335d3879fa1c9a18b4a305a"], "tags": []}, {"author": "Michael Comella \u003cmichael.l.comella@gmail.com\u003e", "branch": "default", "desc": "Bug 1403347 - Don't cache CustomListPreference dialog items. r=liuche, a=sledru\n\nWe're returning a list of only a few items that, at worst, reads from\nresources and is infrequently accessed: there is no reason to cache these\nvalues and the bugs, like this one, that caches entail.\n\nAt the end of this patch, there's no crash, but the scrolling behavior isn't\ngreat: that's bug 1403139.\n\nMozReview-Commit-ID: 3zoXWk78cM4", "files": ["mobile/android/base/java/org/mozilla/gecko/preferences/CustomListPreference.java"], "git_node": null, "git_parents": [null], "node": "04e03b0726f97c5f89db4e08e1029147d4753063", "parents": ["7d38c920f81ad04972bf57b4cdae91cee244cf13"], "tags": []}], "date": 1506606700, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7844": {"changesets": [{"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1352586 - Decrease sw timeout in about:debugging test. r=me, a=test-only\n\nMozReview-Commit-ID: Zeuh4xv5xb", "files": ["devtools/client/aboutdebugging/test/browser_service_workers_status.js"], "git_node": null, "git_parents": [null], "node": "7b06c843caadf7145926cc420f5f6fe3924f6201", "parents": ["04e03b0726f97c5f89db4e08e1029147d4753063"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1402219 - servo: Handle custom properties in keyframes. r=emilio, r=birtles, a=sledru", "files": ["servo/Cargo.lock", "servo/components/style/properties/declaration_block.rs", "servo/components/style/properties/helpers/animated_properties.mako.rs", "servo/components/style/properties/properties.mako.rs", "servo/ports/geckolib/Cargo.toml", "servo/ports/geckolib/glue.rs", "servo/ports/geckolib/lib.rs", "servo/tests/unit/stylo/Cargo.toml", "servo/tests/unit/stylo/lib.rs"], "git_node": null, "git_parents": [null], "node": "d5567d74cf89f7bf240dbdac57cc84981308c39d", "parents": ["7b06c843caadf7145926cc420f5f6fe3924f6201"], "tags": []}, {"author": "Servo VCS Sync \u003cservo-vcs-sync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1402219 - Revendor rust dependencies. a=sledru", "files": ["toolkit/library/gtest/rust/Cargo.lock", "toolkit/library/rust/Cargo.lock"], "git_node": null, "git_parents": [null], "node": "f45c539b4dd55e6e09e3c11bd6205ea9b1cfeb92", "parents": ["d5567d74cf89f7bf240dbdac57cc84981308c39d"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1402219 - Check the length of returned keyframes of getKeyframes(). r=birtles, a=sledru\n\nOtherwise, if getKeyframes() returns an empty array, we don't check each keyframes\nat all.\n\nMozReview-Commit-ID: LSBIgetZq2G", "files": ["dom/animation/test/css-animations/file_keyframeeffect-getkeyframes.html"], "git_node": null, "git_parents": [null], "node": "e2ea11f04e4f5e783c67d15a6bd16761fcb3a634", "parents": ["f45c539b4dd55e6e09e3c11bd6205ea9b1cfeb92"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1402219 - Factor custom properties in keyframes into compute values in each keyframe. r=emilio, a=sledru\n\nMozReview-Commit-ID: J4xWIbjJY69", "files": ["testing/web-platform/meta/css/css-variables-1/variable-animation-substitute-within-keyframe-fallback.html.ini", "testing/web-platform/meta/css/css-variables-1/variable-animation-substitute-within-keyframe-multiple.html.ini", "testing/web-platform/meta/css/css-variables-1/variable-animation-substitute-within-keyframe.html.ini"], "git_node": null, "git_parents": [null], "node": "36f274eacc02ce3a863344a6f654d80ee65a44ef", "parents": ["e2ea11f04e4f5e783c67d15a6bd16761fcb3a634"], "tags": []}, {"author": "Hiroyuki Ikezoe \