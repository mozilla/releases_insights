it_parents": [null], "node": "889eb5d0876bdb2fcd01282e0a4fcd789603db5c", "parents": ["6a12f053f1d0233d00362575aca2f6b9d1e28438"], "tags": []}, {"author": "Nicholas Hurley \u003churley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1409275 - Default to gssapi64 on 64-bit windows. r=valentin, a=ritu\n\nMozReview-Commit-ID: 4Y1RmMwsHPN", "files": ["extensions/auth/nsAuthGSSAPI.cpp"], "git_node": null, "git_parents": [null], "node": "8dbd91b516700e2b13f1c774dbc9325a0c41a764", "parents": ["889eb5d0876bdb2fcd01282e0a4fcd789603db5c"], "tags": []}, {"author": "Stephen A Pohl \u003cspohl.mozilla.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1373581 - Make transition into and out of native fullscreen smoother on macOS. r=mstange, a=ritu", "files": ["browser/base/content/browser-fullScreenAndPointerLock.js", "dom/base/nsGlobalWindow.cpp", "dom/base/nsGlobalWindow.h", "dom/base/nsPIDOMWindow.h", "widget/cocoa/nsCocoaWindow.h", "widget/cocoa/nsCocoaWindow.mm", "widget/nsIWidgetListener.cpp", "widget/nsIWidgetListener.h", "xpfe/appshell/nsWebShellWindow.cpp", "xpfe/appshell/nsWebShellWindow.h"], "git_node": null, "git_parents": [null], "node": "fe950d3f8ad3928a111e0a3e4bacd0d12a50715b", "parents": ["8dbd91b516700e2b13f1c774dbc9325a0c41a764"], "tags": []}, {"author": "Jessica Jong \u003cjjong@mozilla.com\u003e", "branch": "default", "desc": "Bug 1406859 - [DateTimePicker] Let the first picker close gracefully before opening a second picker. r=mconley, a=ritu\n\nIf we're trying to open a picker while one is already open, we should let the\nfirst one close gracefully, that is, we should consume the popuphidden event,\notherwise the event will be fired when we re-add the listeners.\n\nMozReview-Commit-ID: CGy86le1F4g", "files": ["toolkit/content/browser-content.js", "toolkit/modules/DateTimePickerHelper.jsm"], "git_node": null, "git_parents": [null], "node": "dfee079363e1ba600ae3d15c02b23bc8a9b35900", "parents": ["fe950d3f8ad3928a111e0a3e4bacd0d12a50715b"], "tags": []}, {"author": "Eugen Sawin \u003cesawin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1375141 - [1.0] Check for null-URI when sending view intent from Open-in menu item. r=snorp, a=ritu", "files": ["mobile/android/base/java/org/mozilla/gecko/customtabs/CustomTabsActivity.java"], "git_node": null, "git_parents": [null], "node": "8d7197e77da190d3036cdda230ec1fad603fc21d", "parents": ["dfee079363e1ba600ae3d15c02b23bc8a9b35900"], "tags": []}, {"author": "Brian Grinstead \u003cbgrinstead@mozilla.com\u003e", "branch": "default", "desc": "Bug 1400176 - Prevent extra reflows by resetting html and body to display:block. r=nchevobbe, a=ritu\n\nMozReview-Commit-ID: 38cBYjNgVZo", "files": ["devtools/client/themes/webconsole.css"], "git_node": null, "git_parents": [null], "node": "04c4413946aaad0b08926cd036a8614b999917e7", "parents": ["8d7197e77da190d3036cdda230ec1fad603fc21d"], "tags": []}, {"author": "Jan Beich \u003cjbeich@FreeBSD.org\u003e", "branch": "default", "desc": "Bug 1409680 - Extend --disable-debug-symbols to Rust code. r=glandium, a=ritu\n\nThis reduces disk I/O and memory usage during build that already lacks\ndebugging symbols from C++ code, allowing to use more jobs on 32bit hosts.\n\n--disable-debug-symbols build on FreeBSD 10.3 i386 (8 cores) host:\nMax RSS before:  libxul - 612 Mb, libgkrust - 1908 Mb\nMax RSS after:   libxul - 444 Mb, libgkrust - 1471 Mb\nBinary before:   libxul - 203 Mb, libgkrust -  732 Mb\nBinary after:    libxul - 123 Mb, libgkrust -  301 Mb\n\nMozReview-Commit-ID: 40UEYuKddZ2", "files": ["config/rules.mk"], "git_node": null, "git_parents": [null], "node": "92ec0c204c772405f58f5c8f2bb1bd3cf88ed326", "parents": ["04c4413946aaad0b08926cd036a8614b999917e7"], "tags": []}, {"author": "Francesco Lodolo (:flod) \u003cflod@lodolo.net\u003e", "branch": "default", "desc": "Bug 1410105 - Remove diri.bg broken searchplugin from Bulgarian. r=mkaply, a=ritu\n\nMozReview-Commit-ID: 6Rizc7L0DQE", "files": ["browser/locales/search/list.json", "browser/locales/searchplugins/diribg.xml"], "git_node": null, "git_parents": [null], "node": "add4a60517c0790f62bd65aa27c7bc5c1ead42cc", "parents": ["92ec0c204c772405f58f5c8f2bb1bd3cf88ed326"], "tags": []}], "date": 1508536763, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "8021": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nar -\u003e 54535f7f41e5\nit -\u003e c1747ab5a0a2\nms -\u003e 31c637a8aca5", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "14ba48095c75b4078ec19bfef0ce53501b6221f6", "parents": ["add4a60517c0790f62bd65aa27c7bc5c1ead42cc"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nar -\u003e 54535f7f41e5\nbn-BD -\u003e 27fac158f401\ncak -\u003e 0f2a4b06015c\nko -\u003e a4a76ae690f7\nms -\u003e 31c637a8aca5\npl -\u003e 255e285d1eb5", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "44f3b7566cd9d39f04d1734f9194976a2d2887f3", "parents": ["14ba48095c75b4078ec19bfef0ce53501b6221f6"], "tags": []}], "date": 1508559948, "git_changesets": [null, null], "user": "ffxbld"}, "8022": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nka -\u003e 9b84c4cc9c64\nms -\u003e 19b380a466b0\nth -\u003e cbf57c043735", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "8c2946a96020fc181635172d760064cdb0b4a3c6", "parents": ["44f3b7566cd9d39f04d1734f9194976a2d2887f3"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbum