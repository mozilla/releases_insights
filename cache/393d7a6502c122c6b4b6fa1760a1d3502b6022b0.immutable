vtools/client/accessibility/test/jest/components/badges.test.js", "devtools/client/accessibility/test/jest/components/check.test.js", "devtools/client/accessibility/test/jest/components/contrast-badge.test.js", "devtools/client/accessibility/test/jest/components/keyboard-badge.test.js", "devtools/client/accessibility/test/jest/components/keyboard-check.test.js", "devtools/client/accessibility/test/jest/components/text-label-check.test.js", "devtools/client/accessibility/test/jest/helpers.js", "devtools/client/accessibility/test/mochitest/contrast.snapshots.js", "devtools/client/accessibility/test/mochitest/test_accessible_contrast.html", "devtools/client/locales/en-US/accessibility.ftl", "devtools/client/locales/en-US/accessibility.properties", "devtools/client/themes/accessibility-color-contrast.css", "devtools/server/actors/accessibility/accessible.js", "devtools/server/actors/accessibility/audit/keyboard.js", "devtools/server/actors/accessibility/audit/moz.build", "devtools/server/actors/highlighters.css", "devtools/server/actors/highlighters/utils/accessibility.js", "devtools/server/actors/highlighters/xul-accessible.js", "devtools/server/tests/browser/browser.ini", "devtools/server/tests/browser/browser_accessibility_infobar_audit_keyboard.js", "devtools/server/tests/browser/browser_accessibility_infobar_audit_text_label.js", "devtools/server/tests/browser/browser_accessibility_keyboard_audit.js", "devtools/server/tests/browser/browser_accessibility_node_audit.js", "devtools/server/tests/browser/browser_accessibility_walker_audit.js", "devtools/server/tests/browser/doc_accessibility_keyboard_audit.html", "devtools/shared/constants.js", "devtools/shared/locales/en-US/accessibility.properties", "dom/chrome-webidl/InspectorUtils.webidl", "layout/inspector/InspectorUtils.cpp", "layout/inspector/InspectorUtils.h", "layout/inspector/tests/mochitest.ini", "layout/inspector/tests/test_is_element_themed.html"], "git_node": null, "git_parents": [null], "node": "20c9dfa0cf86c8964988ea18f23feff57dc3356d", "parents": ["3364fb1f0140b8846571747be6f1b53689d6bf3a"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576316 - Restore a bit of the Fission-incompatible code removed in bug 1575609 in order to satisfy the tests that are relying on it; r=baku\n\nThe function called in these tests of course does the wrong thing, but these\ntests aren't testing anything related to anti-tracking, so it is probably\nharmless to leave this code in until the dependencies described in the comments\nin the patch are in place.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43465", "files": ["toolkit/components/antitracking/AntiTrackingCommon.cpp"], "git_node": null, "git_parents": [null], "node": "d9790f5a3d0d0b0a4d93e4933496618b424b0b4b", "parents": ["20c9dfa0cf86c8964988ea18f23feff57dc3356d"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1577092 - Change devtools server connectors to expose connectTo functions r=nchevobbe\n\nDepends on D43618\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43728", "files": ["devtools/server/actors/descriptors/frame.js", "devtools/server/connectors/content-process-connector.js", "devtools/server/connectors/frame-connector.js", "devtools/server/connectors/worker-connector.js", "devtools/server/debugger-server.js"], "git_node": null, "git_parents": [null], "node": "e30f91bfaec9b35031a4b46067617c7863e655a9", "parents": ["d9790f5a3d0d0b0a4d93e4933496618b424b0b4b"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1577092 - Remove connectTo* helpers in debugger-server and use connectors directly r=nchevobbe\n\nDepends on D43728\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43729", "files": ["devtools/client/framework/target.js", "devtools/server/actors/descriptors/process.js", "devtools/server/actors/descriptors/webextension.js", "devtools/server/actors/inspector/node.js", "devtools/server/actors/targets/frame-proxy.js", "devtools/server/actors/targets/webextension.js", "devtools/server/actors/targets/worker.js", "devtools/server/debugger-server.js", "devtools/server/startup/content-process.js", "devtools/server/startup/content-process.jsm", "devtools/server/startup/frame.js", "devtools/server/startup/worker.js", "devtools/server/tests/mochitest/test_connectToFrame.html", "devtools/server/tests/mochitest/test_setupInParentChild.html", "devtools/shared/specs/node.js"], "git_node": null, "git_parents": [null], "node": "848ac630ed23442b071a8cb20f5f16016174ba38", "parents": ["e30f91bfaec9b35031a4b46067617c7863e655a9"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554976 - Allow network functions needed by Rust mDNS responder; r=tjr\n\nThis removes these functions: bind, getaddrinfo, recvfrom, sendto, setsockopt,\nsocket from the check_networking test to allow for their use by the Rust mDNS\nresponder.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38488", "files": ["python/mozbuild/mozbuild/action/check_binary.py"], "git_node": null, "git_parents": [null], "node": "e0fc6a1d4332dc93b9c60851f1d936ec969b9e60", "parents": ["848ac630ed23442b071a8cb20f5f16016174ba38"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554976 - Add rust mdns library to mtransport; r=ng,dragana\n\nThis adds a mdns_service to mtransport to handle responding to mDNS queries.\nAll hostnames will be generated from UUIDs, so the responder assumes that it\nis the only responder for a hostname which is registered with it. Because of\nthis, the responder does not first make a DNS query itself to see if any other\nresponder is handling a hostname, and does not wait a random amount of time\nbefore replying, both of which are required by the specification to avoid\ncollisions with other responders.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38489", "files": ["media/mtransport/mdns_service/Cargo.toml", "media/mtransport/mdns_service/mdns_service.h", "media/mtransport/mdns_service/src/lib.rs", "toolkit/library/rust/shared/Cargo.toml", "toolkit/library/rust/shared/lib.rs"], "git_node": null, "git_parents": [null], "node": "5130264150922f930374c4c6db24592bc618f187", "parents": ["e0fc6a1d4332dc93b9c60851f1d936ec969b9e60"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554976 - Run mach vendor rust; r=ng\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38491", "files": ["Cargo.lock", "third_party/rust/dns-parser/.cargo-checksum.json", "third_party/rust/dns-parser/Cargo.toml", "third_party/rust/dns-parser/LICENSE-APACHE", "third_party/rust/dns-parser/LICENSE-MIT", "third_party/rust/dns-parser/README.md", "third_party/rust/dns-parser/bulk.yaml", "third_party/rust/dns-parser/examples/sync_tcp_client.rs", "third_party/rust/dns-parser/examples/sync_udp_client.rs", "third_party/rust/dns-parser/src/builder.rs", "third_party/rust/dns-parser/src/enums.rs", "third_party/rust/dns-parser/src/error.rs", "third_party/rust/dns-parser/src/header.rs", "third_party/rust/dns-parser/src/lib.rs", "third_party/rust/dns-parser/src/name.rs", "third_party/rust/dns-parser/src/parser.rs", "third_party/rust/dns-parser/src/rdata/a.rs", "third_party/rust/dns-parser/src/rdata/aaaa.rs", "third_party/rust/dns-parser/src/rdata/all.rs", "third_party/rust/dns-parser/src/rdata/axfr.rs", "third_party/rust/dns-parser/src/rdata/cname.rs", "third_party/rust/dns-parser/src/rdata/hinfo.rs", "third_party/rust/dns-parser/src/rdata/maila.rs", "third_party/rust/dns-parser/src/rdata/mailb.rs", "third_party/rust/dns-parser/src/rdata/mb.rs", "third_party/rust/dns-parser/src/rdata/mf.rs", "third_party/rust/dns-parser/src/rdata/mg.rs", "third_party/rust/dns-parser/src/rdata/minfo.rs", "third_party/rust/dns-parser/src/rdata/mod.rs", "third_party/rust/dns-parser/src/rdata/mr.rs", "third_party/rust/dns-parser/src/rdata/mx.rs", "third_party/rust/dns-parser/src/rdata/ns.rs", "third_party/rust/dns-parser/src/rdata/nsec.rs", "third_party/rust/dns-parser/src/rdata/null.rs", "third_party/rust/dns-parser/src/rdata/opt.rs", "third_party/rust/dns-parser/src/rdata/ptr.rs", "third_party/rust/dns-parser/src/rdata/soa.rs", "third_party/rust/dns-parser/src/rdata/srv.rs", "third_party/rust/dns-parser/src/rdata/txt.rs", "third_party/rust/dns-parser/src/rdata/wks.rs", "third_party/rust/dns-parser/src/structs.rs", "third_party/rust/dns-parser/vagga.yaml"], "git_node": null, "git_parents": [null], "node": "a506bb40047ed01c84e9b70c34fedc12f65d8fb0", "parents": ["5130264150922f930374c4c6db24592bc618f187"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554976 - Add methods to register/unregister mDNS hostnames to StunAddrsRequestParent; r=mjf\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38492", "files": ["media/mtransport/ipc/PStunAddrsRequest.ipdl", "media/mtransport/ipc/StunAddrsRequestParent.cpp", "media/mtransport/ipc/StunAddrsRequestParent.h"], "git_node": null, "git_parents": [null], "node": "0e34595c2680d384a0e64a1fa9ba00868447fb0b", "parents": ["a506bb40047ed01c84e9b70c34fedc12f65d8fb0"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554976 - Generate mDNS addresses in nricectx; r=mjf\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38493", "files": ["media/mtransport/ipc/StunAddrsRequestParent.h", "media/mtransport/nricectx.cpp", "media/mtransport/nricectx.h", "media/mtransport/nricemediastream.h", "media/mtransport/test/ice_unittest.cpp", "media/mtransport/test/transport_unittests.cpp", "media/mtransport/third_party/nICEr/src/ice/ice_candidate.c"], "git_node": null, "git_parents": [null], "node": "a099e69241a0c6b5c37530c8241a2fee3b8a9412", "parents": ["0e34595c2680d384a0e64a1fa9ba00868447fb0b"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554976 - Copy actual address to CandidateInfo in MediaTransportHandler; r=mjf\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38494", "files": ["dom/media/webrtc/WebrtcIPCTraits.h", "media/webrtc/signaling/src/common/CandidateInfo.h", "media/webrtc/signaling/src/peerconnection/MediaTransportHandler.cpp"], "git_node": null, "git_parents": [null], "node": "24728144c26381ad70306b1c897a6f8c57319beb", "parents": ["a099e69241a0c6b5c37530c8241a2fee3b8a9412"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554976 - Register mDNS hostname if required; r=mjf\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38495", "files": ["media/webrtc/signaling/src/peerconnection/PeerConnectionMedia.cpp", "media/webrtc/signaling/src/peerconnection/PeerConnectionMedia.h"], "git_node": null, "git_parents": [null], "node": "e2c837d1e0a01f13e29842b9b18b81d32e799809", "parents": ["24728144c26381ad70306b1c897a6f8c57319beb"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554976 - Add plumbing to enable/disable host address obfuscation; r=mjf\n\nThis only enables mDNS on OS X for now. Some versions of Windows lack mDNS\nsupport, there are some oddities with resolving IPv6 addresses on Linux, and\nAndroid has not yet been tested. All of these will be addressed in follow on\nbugs.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38496", "files": ["dom/media/webrtc/MediaTransportParent.h", "dom/media/webrtc/PMediaTransport.ipdl", "media/mtransport/nricectx.cpp", "media/mtransport/nricectx.h", "media/mtransport/test/ice_unittest.cpp", "media/mtransport/test/transport_unittests.cpp", "media/webrtc/signaling/gtest/mediapipeline_unittest.cpp", "media/webrtc/signaling/src/peerconnection/MediaTransportHandler.cpp", "media/webrtc/signaling/src/peerconnection/MediaTransportHandler.h", "media/webrtc/signaling/src/peerconnection/MediaTransportHandlerIPC.cpp", "media/webrtc/signaling/src/peerconnection/MediaTransportHandlerIPC.h", "media/webrtc/signaling/src/peerconnection/MediaTransportParent.cpp", "media/webrtc/signaling/src/peerconnection/PeerConnectionMedia.cpp", "media/webrtc/signaling/src/peerconnection/PeerConnectionMedia.h", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "b49b4326dcfddfe241ad49a29371367a77113d2a", "parents": ["e2c837d1e0a01f13e29842b9b18b81d32e799809"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554976 - Disable host address obfuscation for simulated NAT mochitests; r=mjf\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38497", "files": ["dom/media/tests/mochitest/test_peerConnection_basicAudioNATRelay.html", "dom/media/tests/mochitest/test_peerConnection_basicAudioNATRelayTCP.html", "dom/media/tests/mochitest/test_peerConnection_basicAudioNATRelayTLS.html", "dom/media/tests/mochitest/test_peerConnection_basicAudioNATSrflx.html"], "git_node": null, "git_parents": [null], "node": "24f146b86cc49fa966ce84fdf2943cdd0b70c79b", "parents": ["b49b4326dcfddfe241ad49a29371367a77113d2a"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554976 - Obfuscate default rtp and rtcp candidates if required; r=ng\n\nThe default RTP candidate is used to populate the c= line in SDP. Rather than\nusing the mDNS address, which sipcc can not parse, we use 0.0.0.0:9, which is\nwhat Chromium has chosen as well [1].\n\nFor RTCP, the mDNS obfuscated address is used.\n\n[1] https://webrtc.googlesource.com/src.git/+/3ae59d33a310280e2f21ed4c53849950171e48e8\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38498", "files": ["dom/media/tests/mochitest/pc.js", "dom/media/tests/mochitest/sdpUtils.js", "media/webrtc/signaling/src/peerconnection/MediaTransportHandler.cpp"], "git_node": null, "git_parents": [null], "node": "77c4e76c8130cf6808bb59471ac491f9252a2773", "parents": ["24f146b86cc49fa966ce84fdf2943cdd0b70c79b"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554976 - Use mdns_service to generate UUIDs; r=mjf\n\nWith the move to the socket process, the UUID service is no longer available\nin nricectx. This adds a pair of helper functions to mdns_service to generate\nUUIDs and uses them to generate hostnames inside nricectx.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42150", "files": ["Cargo.lock", "media/mtransport/mdns_service/Cargo.toml", "media/mtransport/mdns_service/mdns_service.h", "media/mtransport/mdns_service/src/lib.rs", "media/mtransport/nricectx.cpp"], "git_node": null, "git_parents": [null], "node": "6a404fca61dc42489fcae72a8d608526b9a2846a", "parents": ["77c4e76c8130cf6808bb59471ac491f9252a2773"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554976 - Make mDNS service a singleton; r=mjf\n\nThe current code causes one mDNS service to be created for each PeerConnection.\nDue to Bug 1569311, the services persist until shutdown, which can lead to a\nlot of mDNS threads running on sites which use WebRTC for fingerprinting. This\nchange makes it so we start at most one mDNS service.\n\nI've filed Bug 1569955 to look at shutting down the mDNS service after the\nlast hostname is unregistered. As an alternative, if we fix Bug 1569311, we\ncould also use refcounting and stop the mDNS service after the last\nStunAddrsRequestParent is freed.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42151", "files": ["media/mtransport/ipc/StunAddrsRequestParent.cpp", "media/mtransport/ipc/StunAddrsRequestParent.h"], "git_node": null, "git_parents": [null], "node": "3e16c10bb9660db569563792cbbb21083bf41391", "parents": ["6a404fca61dc42489fcae72a8d608526b9a2846a"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554976 - Move thread assertion inside if statement in OnLookupComplete; r=mjf\n\nChecking this assertion outside of the if statement can result in\na use-after-free in debug builds.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42152", "files": ["media/webrtc/signaling/src/peerconnection/MediaTransportHandler.cpp"], "git_node": null, "git_parents": [null], "node": "27b4dddf9597df076caad414b27f70ba8dbc7245", "parents": ["3e16c10bb9660db569563792cbbb21083bf41391"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1554976 - Use StunAddrs to set interface for mdns_service; r=mjf\n\nThe Rust get_if_addrs library previously used does not build on Android with\nour build system. Since we're already using nICEr to determine the local\ninterface addresses, rather than fix the Rust library, we can use those\naddresses to set the interface on which mdns_service listens.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42760", "files": ["media/mtransport/ipc/StunAddrsRequestParent.cpp", "media/mtransport/ipc/StunAddrsRequestParent.h", "media/mtransport/ipc/moz.build", "media/mtransport/mdns_service/mdns_service.h", "media/mtransport/mdns_service/src/lib.rs"], "git_node": null, "git_parents": [null], "node": "a9b209d9d880443578f19dfc1de4bf1a92b37ba4", "parents": ["27b4dddf9597df076caad414b27f70ba8dbc7245"], "tags": []}, {"author": "Gurzau Raul \u003crgurzau@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 9aa911cc3fcf (bug 1558417) for failing at browser_jsterm_editor_toolbar.js on a CLOSED TREE.", "files": ["browser/app/profile/firefox.js", "devtools/client/jar.mn", "devtools/client/locales/en-US/webconsole.properties", "devtools/client/themes/images/webconsole/run.svg", "devtools/client/webconsole/actions/ui.js", "devtools/client/webconsole/components/App.css", "devtools/client/webconsole/components/Input/EditorToolbar.js", "devtools/client/webconsole/components/Input/JSTerm.js", "devtools/client/webconsole/constants.js", "devtools/client/webconsole/reducers/ui.js", "devtools/client/webconsole/store.js", "devtools/client/webconsole/test/browser/browser.ini", "devtools/client/webconsole/test/browser/browser_jsterm_editor.js", "devtools/client/webconsole/test/browser/browser_jsterm_editor_onboarding.js", "devtools/client/webconsole/test/browser/browser_jsterm_editor_resize.js", "devtools/client/webconsole/test/browser/browser_jsterm_editor_toggle_keyboard_shortcut.js", "devtools/client/webconsole/test/node/mocha-test-setup.js"], "git_node": null, "git_parents": [null], "node": "230fc45161d843f990b2d58de509ea2e45bf2ce3", "parents": ["a9b209d9d880443578f19dfc1de4bf1a92b37ba4"], "tags": []}, {"author": "Gurzau Raul \u003crgurzau@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 9b5ceca1eedf (bug 1573813) for failures at /crashtests/1113005.html on a CLOSED TREE.", "files": ["widget/gtk/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "3b09fca43df93b0f2ba1a1ada33053f504dfea16", "parents": ["230fc45161d843f990b2d58de509ea2e45bf2ce3"], "tags": []}, {"author": "Nicolas Silva \u003cnsilva@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576372 - Check the validity of the DrawTarget before rendering SVG content into it. r=aosmond\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43751", "files": ["layout/svg/SVGGeometryFrame.cpp"], "git_node": null, "git_parents": [null], "node": "4af7a75a66f2ac8918ef42d9da2eae4a62d7e6c5", "parents": ["3b09fca43df93b0f2ba1a1ada33053f504dfea16"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575238 - Remove tabs-newtab-button class. r=mikedeboer\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42656", "files": ["browser/base/content/browser.css", "browser/base/content/browser.xhtml", "browser/base/content/tabbrowser-tabs.js", "browser/themes/shared/tabs.inc.css", "testing/marionette/puppeteer/firefox/firefox_puppeteer/ui/browser/tabbar.py"], "git_node": null, "git_parents": [null], "node": "7b4acdd582e6791a6820f27b95e9d8f782fb34aa", "parents": ["4af7a75a66f2ac8918ef42d9da2eae4a62d7e6c5"], "tags": []}, {"author": "Andrew Halberstadt \u003cahalberstadt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576988 - [docs] Remove 'Indices and tables' section from doc trees, r=Standard8\n\nThe main motivation here is to get these subsections out of the main index.\nWhile changing the heading to an 'h2' or lower would suffice, I opted to remove\nthem entirely. I did this because the links in this section is for the overall\nglobal documentation. E.g, the \"Indices and tables\" section under /tools/lint,\nhas nothing to do with linting.\n\nIt is still possible to access the index and search page from the root:\nhttps://firefox-source-docs.mozilla.org/#indices-and-tables\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43653", "files": ["mobile/android/docs/index.rst", "testing/mozbase/docs/index.rst", "tools/lint/docs/index.rst"], "git_node": null, "git_parents": [null], "node": "86b52938406b2649dfe660015019c4483dcd6526", "parents": ["7b4acdd582e6791a6820f27b95e9d8f782fb34aa"], "tags": []}, {"author": "Mirko Brodesser \u003cmbrodesser@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576899: change `nsIContentSerializer` to take output string as argument in `nsIContentSerializer::Init`. r=hsivonen\n\nBefore, all `nsIContentSerializer::Append`* methods took an output\nstring. The state of `nsPlainTextSerializer` depended on the string\npointing to the same object.\n\nNow, it's ensured that the same output string is used between\n`nsIContentSerializer::Init` and `nsIContentSerializer::Finish`.\n\nMoreover, `nsHTMLCopyEncoder::EncodeToStringWithContext` re-used\n`mSerializer` without initializing it again. This was error-prone,\nbecause after serializing with `mSerializer`, it's internal state might\nhave changed to an undesirable one (e.g.\n`nsPlainTextSerializer::mWrapColumn` could've been modified).\nHence, it is now initialized again before serializing the common\nancestors.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43613", "files": ["dom/base/nsDocumentEncoder.cpp", "dom/base/nsHTMLContentSerializer.cpp", "dom/base/nsHTMLContentSerializer.h", "dom/base/nsIContentSerializer.h", "dom/base/nsPlainTextSerializer.cpp", "dom/base/nsPlainTextSerializer.h", "dom/base/nsXHTMLContentSerializer.cpp", "dom/base/nsXHTMLContentSerializer.h", "dom/base/nsXMLContentSerializer.cpp", "dom/base/nsXMLContentSerializer.h"], "git_node": null, "git_parents": [null], "node": "10716060af24e9de0ea140d3d4f8922f19379634", "parents": ["86b52938406b2649dfe660015019c4483dcd6526"], "tags": []}, {"author": "dlee \u003cdlee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575811 - Remove |IsAllowListed| check in UrlClassifierCommon::AnnotateChannel. r=Ehsan\n\nWhen URL Classifier reports a channel is a tracker, we should only notify the classification\nresult when it is a third-party channel.\nThat means, |IsAllowListed| should not take into consideation here.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43735", "files": ["netwerk/url-classifier/UrlClassifierCommon.cpp"], "git_node": null, "git_parents": [null], "node": "366ce74393fc40912937e21ff5601c0641404625", "parents": ["10716060af24e9de0ea140d3d4f8922f19379634"], "tags": []}, {"author": "James Graham \u003cjames@hoppipolla.co.uk\u003e", "branch": "default", "desc": "Bug 1576991 - Ensure expected is correctly inserted merging wpt ini files - r=maja_zf\n\nWe can't parse files where the key-value pairs are after the subtest\ndata, so ensure that we add it before. Also fix a bug when metadata is\nadded on one side of the merge but unchanged on the other; we were\naccidentially inserting the entire test rather than just the expected\nvalue.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43658", "files": ["testing/web-platform/metamerge.py", "testing/web-platform/test_metamerge.py"], "git_node": null, "git_parents": [null], "node": "a5f33d0358d3d308433110112d47fa804936373d", "parents": ["366ce74393fc40912937e21ff5601c0641404625"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1573239 - Run lower-tier tests if the build platform is of that tier r=dustin,catlee\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41636", "files": ["taskcluster/taskgraph/try_option_syntax.py"], "git_node": null, "git_parents": [null], "node": "6b46ba61a963aafd99e15166c45b7297679bb8f7", "parents": ["a5f33d0358d3d308433110112d47fa804936373d"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575645 - Fix Megabar vertical centering. r=harry\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42945", "files": ["browser/components/urlbar/UrlbarInput.jsm", "browser/themes/shared/urlbar-searchbar.inc.css"], "git_node": null, "git_parents": [null], "node": "dcd17905b58db6736299afb7700ecfd015a5f221", "parents": ["6b46ba61a963aafd99e15166c45b7297679bb8f7"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576943 - Add a label to the about:config radio buttons r=jaws\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43632", "files": ["browser/components/aboutconfig/content/aboutconfig.js"], "git_node": null, "git_parents": [null], "node": "a68f1e98cf9031f628b972c1579b2ea3bcb6e8e2", "parents": ["dcd17905b58db6736299afb7700ecfd015a5f221"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576835 - Update DAMP test writing documentation r=ochameau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43580", "files": ["devtools/docs/SUMMARY.md", "devtools/docs/backend/actor-e10s-handling.md", "devtools/docs/tests/performance-tests.md", "devtools/docs/tests/writing-perf-tests-example.md", "devtools/docs/tests/writing-perf-tests-tips.md", "devtools/docs/tests/writing-perf-tests.md"], "git_node": null, "git_parents": [null], "node": "a5bc37462cee0e6f72720336c4fffb68b2c466ec", "parents": ["a68f1e98cf9031f628b972c1579b2ea3bcb6e8e2"], "tags": []}, {"author": "Krishnal Ciccolella \u003cshellyc23@hotmail.com\u003e", "branch": "default", "desc": "Bug 1558371 - Improve tooltip readability in dark mode r=pbro\n\nChanged the color in `.devtools-tooltip-inactive-css` to match the color of the meatball menu\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43756", "files": ["devtools/client/themes/tooltips.css"], "git_node": null, "git_parents": [null], "node": "10ea0cf78737da248968dfd1404d6d2d639123dc", "parents": ["a5bc37462cee0e6f72720336c4fffb68b2c466ec"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576056 - delete all the standard library-related checks in Compiler.h; r=dmajor\n\nWe don't support stlport anymore, we don't use any of these macros, and\neven if we did, there are probably better ways to do what we want than\nby depending on the subtleties of how C++ standard libraries version\nthemselves.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43677", "files": ["mfbt/Compiler.h"], "git_node": null, "git_parents": [null], "node": "1bd0374ac4b1c2bf0fc246c2733fbb1c19b17954", "parents": ["10ea0cf78737da248968dfd1404d6d2d639123dc"], "tags": []}, {"author": "Gurzau Raul \u003crgurzau@mozilla.com\u003e", "branch": "default", "desc": "Backed out 14 changesets (bug 1554976) for Windows build bustages on a CLOSED TREE.\n\nBacked out changeset a9b209d9d880 (bug 1554976)\nBacked out changeset 27b4dddf9597 (bug 1554976)\nBacked out changeset 3e16c10bb966 (bug 1554976)\nBacked out changeset 6a404fca61dc (bug 1554976)\nBacked out changeset 77c4e76c8130 (bug 1554976)\nBacked out changeset 24f146b86cc4 (bug 1554976)\nBacked out changeset b49b4326dcfd (bug 1554976)\nBacked out changeset e2c837d1e0a0 (bug 1554976)\nBacked out changeset 24728144c263 (bug 1554976)\nBacked out changeset a099e69241a0 (bug 1554976)\nBacked out changeset 0e34595c2680 (bug 1554976)\nBacked out changeset a506bb40047e (bug 1554976)\nBacked out changeset 513026415092 (bug 1554976)\nBacked out changeset e0fc6a1d4332 (bug 1554976)", "files": ["Cargo.lock", "dom/media/tests/mochitest/pc.js", "dom/media/tests/mochitest/sdpUtils.js", "dom/media/tests/mochitest/test_peerConnection_basicAudioNATRelay.html", "dom/media/tests/mochitest/test_peerConnection_basicAudioNATRelayTCP.html", "dom/media/tests/mochitest/test_peerConnection_basicAudioNATRelayTLS.html", "dom/media/tests/mochitest/test_peerConnection_basicAudioNATSrflx.html", "dom/media/webrtc/MediaTransportParent.h", "dom/media/webrtc/PMediaTransport.ipdl", "dom/media/webrtc/WebrtcIPCTraits.h", "media/mtransport/ipc/PStunAddrsRequest.ipdl", "media/mtransport/ipc/StunAddrsRequestParent.cpp", "media/mtransport/ipc/StunAddrsRequestParent.h", "media/mtransport/ipc/moz.build", "media/mtransport/mdns_service/Cargo.toml", "media/mtransport/mdns_service/mdns_service.h", "media/mtransport/mdns_service/src/lib.rs", "media/mtransport/nricectx.cpp", "media/mtransport/nricectx.h", "media/mtransport/nricemediastream.h", "media/mtransport/test/ice_unittest.cpp", "media/mtransport/test/transport_unittests.cpp", "media/mtransport/third_party/nICEr/src/ice/ice_candidate.c", "media/webrtc/signaling/gtest/mediapipeline_unittest.cpp", "media/webrtc/signaling/src/common/CandidateInfo.h", "media/webrtc/signaling/src/peerconnection/MediaTransportHandler.cpp", "media/webrtc/signaling/src/peerconnection/MediaTransportHandler.h", "media/webrtc/signaling/src/peerconnection/MediaTransportHandlerIPC.cpp", "media/webrtc/signaling/src/peerconnection/MediaTransportHandlerIPC.h", "media/webrtc/signaling/src/peerconnection/MediaTransportParent.cpp", "media/webrtc/signaling/src/peerconnection/PeerConnectionMedia.cpp", "media/webrtc/signaling/src/peerconnection/PeerConnectionMedia.h", "modules/libpref/init/all.js", "python/mozbuild/mozbuild/action/check_binary.py", "third_party/rust/dns-parser/.cargo-checksum.json", "third_party/rust/dns-parser/Cargo.toml", "third_party/rust/dns-parser/LICENSE-APACHE", "third_party/rust/dns-parser/LICENSE-MIT", "third_party/rust/dns-parser/README.md", "third_party/rust/dns-parser/bulk.yaml", "third_party/rust/dns-parser/examples/sync_tcp_client.rs", "third_party/rust/dns-parser/examples/sync_udp_client.rs", "third_party/rust/dns-parser/src/builder.rs", "third_party/rust/dns-parser/src/enums.rs", "third_party/rust/dns-parser/src/error.rs", "third_party/rust/dns-parser/src/header.rs", "third_party/rust/dns-parser/src/lib.rs", "third_party/rust/dns-parser/src/name.rs", "third_party/rust/dns-parser/src/parser.rs", "third_party/rust/dns-parser/src/rdata/a.rs", "third_party/rust/dns-parser/src/rdata/aaaa.rs", "third_party/rust/dns-parser/src/rdata/all.rs", "third_party/rust/dns-parser/src/rdata/axfr.rs", "third_party/rust/dns-parser/src/rdata/cname.rs", "third_party/rust/dns-parser/src/rdata/hinfo.rs", "third_party/rust/dns-parser/src/rdata/maila.rs", "third_party/rust/dns-parser/src/rdata/mailb.rs", "third_party/rust/dns-parser/src/rdata/mb.rs", "third_party/rust/dns-parser/src/rdata/mf.rs", "third_party/rust/dns-parser/src/rdata/mg.rs", "third_party/rust/dns-parser/src/rdata/minfo.rs", "third_party/rust/dns-parser/src/rdata/mod.rs", "third_party/rust/dns-parser/src/rdata/mr.rs", "third_party/rust/dns-parser/src/rdata/mx.rs", "third_party/rust/dns-parser/src/rdata/ns.rs", "third_party/rust/dns-parser/src/rdata/nsec.rs", "third_party/rust/dns-parser/src/rdata/null.rs", "third_party/rust/dns-parser/src/rdata/opt.rs", "third_party/rust/dns-parser/src/rdata/ptr.rs", "third_party/rust/dns-parser/src/rdata/soa.rs", "third_party/rust/dns-parser/src/rdata/srv.rs", "third_party/rust/dns-parser/src/rdata/txt.rs", "third_party/rust/dns-parser/src/rdata/wks.rs", "third_party/rust/dns-parser/src/structs.rs", "third_party/rust/dns-parser/vagga.yaml", "toolkit/library/rust/shared/Cargo.toml", "toolkit/library/rust/shared/lib.rs"], "git_node": null, "git_parents": [null], "node": "5b1d527eacfc0ef034297435297e890f342de51f", "parents": ["1bd0374ac4b1c2bf0fc246c2733fbb1c19b17954"], "tags": []}, {"author": "Gurzau Raul \u003crgurzau@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset a5bc37462cee (bug 1576835) for codespell failure at writing-perf-tests.md on a CLOSED TREE", "files": ["devtools/docs/SUMMARY.md", "devtools/docs/backend/actor-e10s-handling.md", "devtools/docs/tests/performance-tests.md", "devtools/docs/tests/writing-perf-tests-example.md", "devtools/docs/tests/writing-perf-tests-tips.md", "devtools/docs/tests/writing-perf-tests.md"], "git_node": null, "git_parents": [null], "node": "72c7f3199f9af308b3289e7467cce41ce99e043b", "parents": ["5b1d527eacfc0ef034297435297e890f342de51f"], "tags": []}, {"author": "Haik Aftandilian \u003chaftandilian@mozilla.com\u003e", "branch": "default", "desc": "Bug 1562785 - Extend/revive the process launch telemetry r=jld\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42231", "files": ["toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "761130438aee679e64a332c3028e0dae35a4b87b", "parents": ["72c7f3199f9af308b3289e7467cce41ce99e043b"], "tags": []}, {"author": "J.C. Jones \u003cjc@mozilla.com\u003e", "branch": "default", "desc": "Bug 1564499 - land NSS NSS_3_46_BETA2 UPGRADE_NSS_RELEASE, r=kjacobs\n\n2019-08-27  Kevin Jacobs  \u003ckjacobs@mozilla.com\u003e\n\n        * automation/taskcluster/graph/src/extend.js,\n        automation/taskcluster/scripts/build_gyp.sh,\n        automation/taskcluster/windows/build_gyp.sh, fuzz/fuzz.gyp,\n        gtests/pk11_gtest/pk11_gtest.gyp,\n        gtests/softoken_gtest/softoken_gtest.gyp, tests/all.sh,\n        tests/ssl/ssl.sh:\n        Bug 1485533 - Close gaps in taskcluster SSL testing. r=mt\n\n        This patch increases SSL testing on taskcluster, specifically,\n        running an additional 395 tests on each SSL cycle (more for FIPS\n        targets), and adding a new 'stress' cycle.\n\n        Notable changes:\n\n        1) This patch removes SSL stress tests from the default\n        `NSS_SSL_RUN` list in all.sh and ssl.sh. If stress tests are needed,\n        this variable must be set to include.\n\n        2) The \"normal_normal\" case is added to `NSS_SSL_TESTS` for all\n        targets. FIPS targets also run \"normal_fips\", \"fips_normal\", and\n        \"fips_fips\".\n\n        3) `--enable-libpkix` is now set for all taskcluster \"build.sh\"\n        builds in order to support a number of OCSP tests that were\n        previously not run.\n\n        [24b0fc700203] [NSS_3_46_BETA2]\n\n2019-08-23  Edouard Oger  \u003ceoger@fastmail.com\u003e\n\n        * lib/sqlite/Makefile, lib/sqlite/sqlite.gyp:\n        Bug 1549847 - Ignore sqlite compilation warnings. r=mt\n\n        [7f146eb7adac]\n\n2019-08-23  J.C. Jones  \u003cjjones@mozilla.com\u003e\n\n        * .hgtags:\n        Added tag NSS_3_46_BETA1 for changeset 44aa330de2aa\n        [d3035cc9dc73]\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43724", "files": ["security/nss/TAG-INFO", "security/nss/automation/taskcluster/graph/src/extend.js", "security/nss/automation/taskcluster/scripts/build_gyp.sh", "security/nss/automation/taskcluster/windows/build_gyp.sh", "security/nss/coreconf/coreconf.dep", "security/nss/fuzz/fuzz.gyp", "security/nss/gtests/pk11_gtest/pk11_gtest.gyp", "security/nss/gtests/softoken_gtest/softoken_gtest.gyp", "security/nss/lib/sqlite/Makefile", "security/nss/lib/sqlite/sqlite.gyp", "security/nss/tests/all.sh", "security/nss/tests/ssl/ssl.sh"], "git_node": null, "git_parents": [null], "node": "b74918f6258e49f2d4a58c9ffea8c29aba420818", "parents": ["761130438aee679e64a332c3028e0dae35a4b87b"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576925: Make AgileReference copyable; r=Jamie\n\nUntil now, AgileReference was not copyable because it could not handle the\ncopying of global interface table cookies. By moving the cookie into its own\nreference counted object, we can enable copying on the AgileReference.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43616", "files": ["ipc/mscom/AgileReference.cpp", "ipc/mscom/AgileReference.h"], "git_node": null, "git_parents": [null], "node": "8f193119390c2a2689b7584b91ff825c5a010ff2", "parents": ["b74918f6258e49f2d4a58c9ffea8c29aba420818"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1507193 - Don't leave dangling js promises after seeking. r=jya\n\nOnly SeekToNextFrame cares about promises, but prior to this patch the common\nmethod HTMLMediaElement::Seek() would always return a promise.\n\nWhen the caller was not SeekToNextFrame (e.g., SetCurrentTime, FastSeek), the\npromise would end up *not* being exposed. When later rejected, we would catch\nthis and write an error to the js console.\n\nThis patch lifts the handling of the promise out of Seek() and into\nSeekToNextFrame() so that we avoid creating promises that would not get exposed\nto js.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42511", "files": ["dom/html/HTMLMediaElement.cpp", "dom/html/HTMLMediaElement.h", "dom/media/MediaDecoder.cpp", "dom/media/MediaDecoder.h", "dom/media/MediaDecoderOwner.h"], "git_node": null, "git_parents": [null], "node": "dd79fbdfac8d9bb645fc954ca8969df73bf5c436", "parents": ["8f193119390c2a2689b7584b91ff825c5a010ff2"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1576817 - Simplify some code added in bug 1490974. r=bradwerth\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43743", "files": ["toolkit/components/find/nsFind.cpp"], "git_node": null, "git_parents": [null], "node": "34b4dcc475d33cdd274177acbdfa593164cef97f", "parents": ["dd79fbdfac8d9bb645fc954ca8969df73bf5c436"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1576817 - Only allow finding editable anonymous nodes in form controls. r=bradwerth\n\nWe want to find the text inside the input that the user types, but not stuff\nlike the placeholder. So check that the anonymous subtree is editable, or skip\nit otherwise.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43744", "files": ["toolkit/components/find/nsFind.cpp", "toolkit/modules/tests/browser/browser_Finder_skip_invisible_and_option.js"], "git_node": null, "git_parents": [null], "node": "3192da5a883fa09987d96159f35476351fcbf404", "parents": ["34b4dcc475d33cdd274177acbdfa593164cef97f"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1576817 - Fix a regression from bug 1490974 where we'll fail to find visibility: visible descendants of visibility: hidden nodes. r=bradwerth\n\nThe split between IsDisplayedNode and IsVisibleNode is pretty intentional, since\nvisibility: visible descendants of visiblity: hidden ancestors are in fact\nvisible.\n\nWe skip fully-invisible ranges in here instead:\n\nhttps://searchfox.org/mozilla-central/rev/325c1a707819602feff736f129cb36055ba6d94f/toolkit/components/find/nsFind.cpp#776\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43745", "files": ["toolkit/components/find/nsFind.cpp", "toolkit/modules/tests/browser/browser_Finder_skip_invisible_and_option.js"], "git_node": null, "git_parents": [null], "node": "bcbd2fb36cb145358d641383eaee2efc4e09248a", "parents": ["3192da5a883fa09987d96159f35476351fcbf404"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1558417 - Add onboarding UI for Editor. r=Honza.\n\nThe onboarding UI is displayed on top of the Editor.\nA dismiss button hides it forever (this is handled via\na pref that is set to false when clicking the button).\n\nWe take this as an opportunity to polish the Editor UI/wording\na bit.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43621", "files": ["browser/app/profile/firefox.js", "devtools/client/jar.mn", "devtools/client/locales/en-US/webconsole.properties", "devtools/client/themes/images/webconsole/run.svg", "devtools/client/webconsole/actions/ui.js", "devtools/client/webconsole/components/App.css", "devtools/client/webconsole/components/Input/EditorToolbar.js", "devtools/client/webconsole/components/Input/JSTerm.js", "devtools/client/webconsole/constants.js", "devtools/client/webconsole/reducers/ui.js", "devtools/client/webconsole/store.js", "devtools/client/webconsole/test/browser/browser.ini", "devtools/client/webconsole/test/browser/browser_jsterm_editor.js", "devtools/client/webconsole/test/browser/browser_jsterm_editor_onboarding.js", "devtools/client/webconsole/test/browser/browser_jsterm_editor_resize.js", "devtools/client/webconsole/test/browser/browser_jsterm_editor_toggle_keyboard_shortcut.js", "devtools/client/webconsole/test/browser/browser_jsterm_editor_toolbar.js", "devtools/client/webconsole/test/node/mocha-test-setup.js"], "git_node": null, "git_parents": [null], "node": "1763c1b86c097acf694217e88f92824d2d04562d", "parents": ["bcbd2fb36cb145358d641383eaee2efc4e09248a"], "tags": []}, {"author": "Carolina \u003ccarolina.jimenez.g@gmail.com\u003e", "branch": "default", "desc": "Bug 1575207 - Fixes undefined strings being rendering in Certificate Polices Section.r=johannh\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42655", "files": ["toolkit/components/certviewer/content/certviewer.js", "toolkit/components/certviewer/tests/browser/browser.ini", "toolkit/components/certviewer/tests/browser/browser_checkNonUndefinedStrings.js"], "git_node": null, "git_parents": [null], "node": "aecd9439e77d17c3b67efc1e0b560e8b3f163e79", "parents": ["1763c1b86c097acf694217e88f92824d2d04562d"], "tags": []}, {"author": "Frederic Wang \u003cfred.wang@free.fr\u003e", "branch": "default", "desc": "Bug 1548524 - Remove attributes deprecated from MathML3. r=emilio\n\nSee https://github.com/mathml-refresh/mathml/issues/5#issuecomment-475506856\nand https://groups.google.com/forum/#!topic/mozilla.dev.platform/kl5c87mBlO0\n\nThis patch introduces a new preference\nmathml.deprecated_style_attributes.disabled in order to disable legacy support\nfor attributes background, color, fontfamily, fontsize, fontstyle and\nfontweight. Note that xlink:href will be handled separately in bug 1575870.\n\n* A new counter and deprecation message is introduced for these attributes.\n  In nsMathMLElement, the old WarnDeprecated calls are replaced with a single\n  call to WarnOnceAbout for the deprecate attributes. Notice that for some\n  reason, the color attribute used to send warning in both ParseAttribute and\n  MapMathMLAttributesInto.\n* sMtableStyles is removed and replaced with a simple comparison.\n* sMathML3Attributes is split into two tables: one for script attributes which\n  will be handled in bug 1548471 and one for style attributes, handled here.\n  The attributes in this second table is now ignored when the feature flag is\n  disabled.\n* test_bug553917.html is updated so that it no longer checks the old warning\n  messages for these attributes. New warning messages have been verified\n  manually.\n* Reftests checking support for these attributes are run with the support\n  enabled.\n* Finally, WPT tests are run with the support disabled and a new test\n  is added to verify that these attributes are no longer mapped to CSS.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43111", "files": ["dom/base/nsDeprecatedOperationList.h", "dom/locales/en-US/chrome/dom/dom.properties", "dom/mathml/nsMathMLElement.cpp", "layout/mathml/tests/test_bug553917.html", "layout/reftests/mathml/reftest.list", "modules/libpref/init/StaticPrefList.yaml", "testing/web-platform/meta/mathml/__dir__.ini", "testing/web-platform/tests/mathml/relations/css-styling/attribute-mapping-001.html"], "git_node": null, "git_parents": [null], "node": "69105b8565ce19ceb8c26757d0a81138854f1d13", "parents": ["aecd9439e77d17c3b67efc1e0b560e8b3f163e79"], "tags": []}, {"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1542529 - Fix and unify delete icons. r=jaws\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43732", "files": ["browser/components/aboutlogins/content/components/login-item.css", "browser/components/aboutlogins/content/icons/delete.svg", "browser/components/aboutlogins/jar.mn", "toolkit/themes/shared/icons/delete.svg"], "git_node": null, "git_parents": [null], "node": "581890147bec4ed08f1c0da4999aa877132de9bd", "parents": ["69105b8565ce19ceb8c26757d0a81138854f1d13"], "tags": []}, {"author": "Simon Giesecke \u003csgiesecke@mozilla.com\u003e", "branch": "default", "desc": "Bug 1540247 - Expose MozURL::Init to JS for QuotaManager tests r=ttung,asuth\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39207", "files": ["dom/quota/QuotaManagerService.cpp", "dom/quota/nsIQuotaManagerService.idl", "dom/quota/test/unit/head.js", "dom/quota/test/unit/test_isValidMozURL.js", "dom/quota/test/unit/test_obsoleteOrigins.js", "dom/quota/test/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "cbce223800c16c143e396a4f7cc82e57784fbc81", "parents": ["581890147bec4ed08f1c0da4999aa877132de9bd"], "tags": []}, {"author": "Edwin Gao \u003cegao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1547820 - re-enable media-source wpt tests on windows10-aarch64 r=intermittent-reviewers,jmaher\n\nRe-enabling the disabled manifest `testing/web-platform/meta/media-source/__dir__.ini` for windows10-aarch64 since the tests now pass.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43714", "files": ["testing/web-platform/meta/media-source/__dir__.ini"], "git_node": null, "git_parents": [null], "node": "f977db21c7ca393ceb48e71680d57dc6c0703c1d", "parents": ["cbce223800c16c143e396a4f7cc82e57784fbc81"], "tags": []}, {"author": "Gurzau Raul \u003crgurzau@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset cbce223800c1 (bug 1540247) for xpcshell failures at test_obsoleteOrigins.js on a CLOSED TREE.", "files": ["dom/quota/QuotaManagerService.cpp", "dom/quota/nsIQuotaManagerService.idl", "dom/quota/test/unit/head.js", "dom/quota/test/unit/test_isValidMozURL.js", "dom/quota/test/unit/test_obsoleteOrigins.js", "dom/quota/test/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "67bb50bd8b67089c001ade51d157ad8e085f3e6c", "parents": ["f977db21c7ca393ceb48e71680d57dc6c0703c1d"], "tags": []}, {"author": "Coroiu Cristina \u003cccoroiu@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset dcd17905b58d (bug 1575645) for browser-chrome failures at browser/base/content/test/static/browser_parsable_css.js on a CLOSED TREE", "files": ["browser/components/urlbar/UrlbarInput.jsm", "browser/themes/shared/urlbar-searchbar.inc.css"], "git_node": null, "git_parents": [null], "node": "3fa90607a8acbdd55cd1b7ab79611d7c8963100f", "parents": ["67bb50bd8b67089c001ade51d157ad8e085f3e6c"], "tags": []}, {"author": "Coroiu Cristina \u003cccoroiu@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset dd79fbdfac8d (bug 1507193) for wpt failures at media-source/mediasource-seek-beyond-duration.html on a CLOSED TREE", "files": ["dom/html/HTMLMediaElement.cpp", "dom/html/HTMLMediaElement.h", "dom/media/MediaDecoder.cpp", "dom/media/MediaDecoder.h", "dom/media/MediaDecoderOwner.h"], "git_node": null, "git_parents": [null], "node": "b11b42a2c23909b96a12e5de13ea00913b7285de", "parents": ["3fa90607a8acbdd55cd1b7ab79611d7c8963100f"], "tags": []}, {"author": "Andrew Creskey \u003cacreskey@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575938 Convert dom/JSEnvironment GC timing constants to StaticPref r=edgar\n\nConverted the following to StaticPrefs so that we can easily test variations:\n\nNS_GC_DELAY\nNS_SHRINK_GC_BUFFERS_DELAY\nNS_FIRST_GC_DELAY\nNS_FULL_GC_DELAY\nNS_INTERSLICE_GC_DELAY\n\nNS_USER_INTERACTION_INTERVAL\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43112", "files": ["dom/base/nsJSEnvironment.cpp", "dom/base/nsJSEnvironment.h", "dom/events/EventStateManager.cpp", "dom/events/EventStateManager.h", "layout/base/nsDocumentViewer.cpp", "modules/libpref/init/StaticPrefList.yaml"], "git_node": null, "git_parents": [null], "node": "c8b9ae708d8e1805bd68f3deb3c0fe5cd9f9e1c5", "parents": ["b11b42a2c23909b96a12e5de13ea00913b7285de"], "tags": []}, {"author": "Jason Laster \u003cjlaster@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575240 - inspect(x) should show x in the appropriate panel. r=nchevobbe\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42747", "files": ["devtools/client/framework/toolbox.js", "devtools/client/webconsole/test/browser/browser.ini", "devtools/client/webconsole/test/browser/browser_jsterm_inspect.js", "devtools/client/webconsole/test/browser/test-simple-function.html", "devtools/client/webconsole/test/browser/test-simple-function.js", "devtools/client/webconsole/webconsole-wrapper.js"], "git_node": null, "git_parents": [null], "node": "3853d8979a553067596ab19f07ed5a416ee4b358", "parents": ["c8b9ae708d8e1805bd68f3deb3c0fe5cd9f9e1c5"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1556658 - Middle-clicking on the origin should open the link. r=MattN\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43526", "files": ["browser/components/aboutlogins/content/components/login-item.js", "browser/components/aboutlogins/tests/chrome/test_login_item.html"], "git_node": null, "git_parents": [null], "node": "24f529de132fa34f322d284b94243690f0f28fad", "parents": ["3853d8979a553067596ab19f07ed5a416ee4b358"], "tags": []}, {"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1577022 - Add spacing before copy buttons in about:logins. r=jaws\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43791", "files": ["browser/components/aboutlogins/content/components/login-item.css"], "git_node": null, "git_parents": [null], "node": "b8eba4a78d42569a15f3739dbb9770fe89bd7c8a", "parents": ["24f529de132fa34f322d284b94243690f0f28fad"], "tags": []}, {"author": "Itiel \u003citiel_yn8@walla.com\u003e", "branch": "default", "desc": "Bug 1576092 - Fix the breadcrumbs' arrow border color for white theme r=gl\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43769", "files": ["devtools/client/themes/breadcrumbs.css"], "git_node": null, "git_parents": [null], "node": "86e40759a597ea71ab0edf785dacc674f72d4bf1", "parents": ["b8eba4a78d42569a15f3739dbb9770fe89bd7c8a"], "tags": []}, {"author": "Aki Sasaki \u003casasaki@mozilla.com\u003e", "branch": "default", "desc": "Bug 1566298 - fix langpack-copy dependencies. r=nthomas a=release CLOSED TREE\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43556", "files": ["taskcluster/taskgraph/transforms/release_beetmover_signed_addons.py"], "git_node": null, "git_parents": [null], "node": "fa71c787eec9b6c66ba1ab2c767e8144f0535260", "parents": ["86e40759a597ea71ab0edf785dacc674f72d4bf1"], "tags": []}, {"author": "Justin Wood \u003cCallek@gmail.com\u003e", "branch": "default", "desc": "Bug 1566298 - Followup, don't look for en-US langpacks in an 'en-US/' path. r=jlorenzo\nSign language packs via Autograph instead of AMO.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43595", "files": ["taskcluster/taskgraph/transforms/release_beetmover_signed_addons.py"], "git_node": null, "git_parents": [null], "node": "9df802613d63389a92c3ce5131d5db672742889a", "parents": ["fa71c787eec9b6c66ba1ab2c767e8144f0535260"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1562117 - Fix race in test_ext_normandyAddonStudy test cases. r=mixedpuppy\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43742", "files": ["browser/components/extensions/test/xpcshell/test_ext_normandyAddonStudy.js"], "git_node": null, "git_parents": [null], "node": "ab9a80002a622370a028ae0243a1a27cf71f923b", "parents": ["9df802613d63389a92c3ce5131d5db672742889a"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1569735.  Move almost all uses of binaryNames out of Bindings.conf and into .webidl files.  r=peterv\n\nThe one exception, apart from tests, is a place where the constructor is being\nrenamed, because there is no way to support that syntactically yet.  There will\nbe if https://github.com/heycam/webidl/issues/636 is fixed.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39792", "files": ["dom/bindings/Bindings.conf", "dom/bindings/Configuration.py", "dom/webidl/AudioNode.webidl", "dom/webidl/CSSStyleSheet.webidl", "dom/webidl/CanvasRenderingContext2D.webidl", "dom/webidl/DOMException.webidl", "dom/webidl/DynamicsCompressorNode.webidl", "dom/webidl/FetchEvent.webidl", "dom/webidl/HTMLTextAreaElement.webidl", "dom/webidl/IDBCursor.webidl", "dom/webidl/IDBIndex.webidl", "dom/webidl/IDBObjectStore.webidl", "dom/webidl/ImageCapture.webidl", "dom/webidl/MediaStreamAudioDestinationNode.webidl", "dom/webidl/NotificationEvent.webidl", "dom/webidl/Range.we