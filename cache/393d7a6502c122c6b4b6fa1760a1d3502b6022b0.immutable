ck.pdf", "widget/cocoa/touchbar/bookmark-filled.pdf", "widget/cocoa/touchbar/bookmark.pdf", "widget/cocoa/touchbar/forward.pdf", "widget/cocoa/touchbar/fullscreen.pdf", "widget/cocoa/touchbar/home.pdf", "widget/cocoa/touchbar/new.pdf", "widget/cocoa/touchbar/reader-mode.pdf", "widget/cocoa/touchbar/refresh.pdf", "widget/cocoa/touchbar/search.pdf", "widget/cocoa/touchbar/share.pdf", "widget/cocoa/touchbar/sidebar-left.pdf", "widget/cocoa/touchbar/sidebar-right.pdf", "widget/nsITouchBarHelper.idl", "widget/nsITouchBarInput.idl"], "git_node": null, "git_parents": [null], "node": "3ab29c05ea2f80400fee727500dd4563854779a3", "parents": ["4b87c3aa76fff88567560174f4bd68650d5cc5f9"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 3ab29c05ea2f (bug 1521893) build bustage in /builds/worker/workspace/build/src/widget/cocoa/nsTouchBarInputIcon.h. CLOSED TREE", "files": ["browser/components/touchbar/MacTouchBar.js", "browser/components/touchbar/tests/browser/browser_touchbar_tests.js", "browser/installer/package-manifest.in", "widget/cocoa/moz.build", "widget/cocoa/nsCocoaWindow.mm", "widget/cocoa/nsIconLoaderService.h", "widget/cocoa/nsIconLoaderService.mm", "widget/cocoa/nsMenuBarX.mm", "widget/cocoa/nsMenuItemIconX.h", "widget/cocoa/nsMenuItemIconX.mm", "widget/cocoa/nsTouchBar.h", "widget/cocoa/nsTouchBar.mm", "widget/cocoa/nsTouchBarInputIcon.h", "widget/cocoa/nsTouchBarInputIcon.mm", "widget/cocoa/nsTouchBarNativeAPIDefines.h", "widget/cocoa/nsTouchBarUpdater.mm", "widget/cocoa/touchbar/back.pdf", "widget/cocoa/touchbar/bookmark-filled.pdf", "widget/cocoa/touchbar/bookmark.pdf", "widget/cocoa/touchbar/forward.pdf", "widget/cocoa/touchbar/fullscreen.pdf", "widget/cocoa/touchbar/home.pdf", "widget/cocoa/touchbar/new.pdf", "widget/cocoa/touchbar/reader-mode.pdf", "widget/cocoa/touchbar/refresh.pdf", "widget/cocoa/touchbar/search.pdf", "widget/cocoa/touchbar/share.pdf", "widget/cocoa/touchbar/sidebar-left.pdf", "widget/cocoa/touchbar/sidebar-right.pdf", "widget/nsITouchBarHelper.idl", "widget/nsITouchBarInput.idl"], "git_node": null, "git_parents": [null], "node": "3abcd517522920b1cdd9efc21ff475d7b013e179", "parents": ["3ab29c05ea2f80400fee727500dd4563854779a3"], "tags": []}, {"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1567548 - Remove references to Lockwise FAQ page. r=jaws,fluent-reviewers,flod\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43895", "files": ["browser/app/profile/firefox.js", "browser/components/BrowserGlue.jsm", "browser/components/aboutlogins/AboutLoginsChild.jsm", "browser/components/aboutlogins/AboutLoginsParent.jsm", "browser/components/aboutlogins/content/aboutLogins.html", "browser/components/aboutlogins/content/components/login-intro.js", "browser/components/aboutlogins/content/components/menu-button.css", "browser/components/aboutlogins/tests/browser/browser_openPreferencesExternal.js", "browser/components/aboutlogins/tests/chrome/test_menu_button.html", "browser/locales/en-US/browser/aboutLogins.ftl"], "git_node": null, "git_parents": [null], "node": "198896f944642651094db5504625f1f7cecc672d", "parents": ["3abcd517522920b1cdd9efc21ff475d7b013e179"], "tags": []}, {"author": "Stephen McGruer \u003csmcgruer@chromium.org\u003e", "branch": "default", "desc": "Bug 1575918 [wpt PR 18616] - Fix font-variation-settings interpolation test, a=testonly\n\nAutomatic update from web-platform-tests\nFix font-variation-settings interpolation test\n\nfont-variation-settings is a map, not an array, so the order is\nirrelevant when comparing the actual and expected values. Add the\nability to supply a custom comparison function to\ninterpolation-testcommon.js to support properties like this.\n\nThis also exposed one test which incorrectly asserted no interpolation\nwhen there should be interpolation.\n\nBug: 900581\nChange-Id: I6c336e010c9c3642b14c945b3d7ae828f94b3f99\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1764801\nCommit-Queue: Stephen McGruer \u003csmcgruer@chromium.org\u003e\nReviewed-by: Xida Chen \u003cxidachen@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#689924}\n\n--\n\nwpt-commits: 4ccb4d2607e3c1f460e742a9e3427e61394dec73\nwpt-pr: 18616\n", "files": ["testing/web-platform/tests/css/css-fonts/animations/font-variation-settings-interpolation.html", "testing/web-platform/tests/css/support/interpolation-testcommon.js"], "git_node": null, "git_parents": [null], "node": "a19d7faf8cd9866c0dc0af5802a4e7cadd529c2e", "parents": ["4954c2f6267b17ca7dd54d22a71ef8a477fc72cf"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575918 [wpt PR 18616] - Update wpt metadata, a=testonly\n\nwpt-pr: 18616\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/css/css-fonts/animations/font-variation-settings-interpolation.html.ini", "testing/web-platform/meta/css/filter-effects/animation/filter-interpolation-002.html.ini", "testing/web-platform/meta/css/motion/animation/offset-distance-interpolation.html.ini", "testing/web-platform/meta/css/motion/animation/offset-path-interpolation-005.html.ini", "testing/web-platform/meta/css/motion/animation/offset-rotate-interpolation.html.ini"], "git_node": null, "git_parents": [null], "node": "c56a952a950c465bf8402e19c5da18da6fff86c2", "parents": ["a19d7faf8cd9866c0dc0af5802a4e7cadd529c2e"], "tags": []}, {"author": "Nicol\u00e1s Pe\u00f1a Moreno \u003cnpm@chromium.org\u003e", "branch": "default", "desc": "Bug 1575260 [wpt PR 18566] - [ResourceTiming] Fix CORS preflight ResourceTiming information, a=testonly\n\nAutomatic update from web-platform-tests\n[ResourceTiming] Fix CORS preflight ResourceTiming information\n\nThe two tests that rely on\nhttp/tests/misc/resources/resource-timing-sizes-cors-preflight.js are\nincorrect because CORS preflights should not trigger new Resource Timing\nentries. This change reverts the changes made in 793f7c3 and fixes the\ntests.\n\nBug: 982924\nChange-Id: Ic656f9fc0cd6dadfa66d1176765696817bcec8f4\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1696525\nReviewed-by: Takashi Toyoshima \u003ctoyoshim@chromium.org\u003e\nReviewed-by: Yutaka Hirano \u003cyhirano@chromium.org\u003e\nReviewed-by: Kinuko Yasuda \u003ckinuko@chromium.org\u003e\nCommit-Queue: Nicol\u00e1s Pe\u00f1a Moreno \u003cnpm@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#689940}\n\n--\n\nwpt-commits: 14daf8c5b8b55d0c343218c0606bf4f49b513f20\nwpt-pr: 18566\n", "files": ["testing/web-platform/tests/resource-timing/cors-preflight.any.js", "testing/web-platform/tests/resource-timing/resources/preflight.py"], "git_node": null, "git_parents": [null], "node": "3ce87c3957d198e92b3c304d6f65d0f0c9a56c74", "parents": ["c56a952a950c465bf8402e19c5da18da6fff86c2"], "tags": []}, {"author": "Mike Pennisi \u003cmike@mikepennisi.com\u003e", "branch": "default", "desc": "Bug 1576017 [wpt PR 18623] - [wptserve] Support `.sub.` filename w/pipe param, a=testonly\n\nAutomatic update from web-platform-tests\n[wptserve] Support `.sub.` filename w/pipe param\n\nThe substitution feature may be enabled using a filename pattern\n(`.sub`) or a query string parameter (`pipe=sub`). Prior to this commit,\nthe former approach could not be used if any other \"pipe\" commands were\nincluded in the query string. Update wptserve to interpret the `.sub.`\nfilename pattern as though it were expressed as the first \"pipe\" command\nin the query string.\n\n--\n\nwpt-commits: ef77ba9ca4f582ac49e3aa7a1569134f149696b0\nwpt-pr: 18623\n", "files": ["testing/web-platform/tests/tools/wptserve/tests/functional/test_pipes.py", "testing/web-platform/tests/tools/wptserve/wptserve/handlers.py"], "git_node": null, "git_parents": [null], "node": "32dada492485d515b8f34a1825cee62a1d6f3589", "parents": ["3ce87c3957d198e92b3c304d6f65d0f0c9a56c74"], "tags": []}, {"author": "Xiaocheng Hu \u003cxiaochengh@chromium.org\u003e", "branch": "default", "desc": "Bug 1575992 [wpt PR 18622] - Add parser and evaluation WPT \u003clength-percentage\u003e involving min/max(), a=testonly\n\nAutomatic update from web-platform-tests\nAdd parser and evaluation WPT \u003clength-percentage\u003e involving min/max()\n\nBug: 978682\nChange-Id: I5e377df4121a1ef1992a30fbeff822712b52b8ca\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1766843\nReviewed-by: Rune Lillesveen \u003cfuthark@chromium.org\u003e\nCommit-Queue: Xiaocheng Hu \u003cxiaochengh@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#690030}\n\n--\n\nwpt-commits: 86af37591b7df11a1b667874a0d818684c4dfeb6\nwpt-pr: 18622\n", "files": ["testing/web-platform/tests/css/css-values/minmax-length-percent-computed.html", "testing/web-platform/tests/css/css-values/minmax-length-percent-invalid.html"], "git_node": null, "git_parents": [null], "node": "ed25dc17f8bdfef169edcb451d3877236c70e2c7", "parents": ["32dada492485d515b8f34a1825cee62a1d6f3589"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575992 [wpt PR 18622] - Update wpt metadata, a=testonly\n\nwpt-pr: 18622\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/css/css-values/minmax-length-percent-computed.html.ini"], "git_node": null, "git_parents": [null], "node": "e39e9533d6952a487d232d92c4cad654938ec2b2", "parents": ["ed25dc17f8bdfef169edcb451d3877236c70e2c7"], "tags": []}, {"author": "Brandon Jones \u003cbajones@chromium.org\u003e", "branch": "default", "desc": "Bug 1576240 [wpt PR 18644] - Changed the WebXR required/optional features to take an array of 'any', a=testonly\n\nAutomatic update from web-platform-tests\nChanged the WebXR required/optional features to take an array of 'any'\n\nBug: 996949\nChange-Id: Ifd918931d1c4a8ad976655230efb1f5e70f53956\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1766601\nReviewed-by: Alexander Cooper \u003calc