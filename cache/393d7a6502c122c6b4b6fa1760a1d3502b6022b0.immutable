: "cee0b37108d61f3d483441ea6eb82a3b1c48b3fe", "parents": ["12ed9f35467274e38ded436a8240a449a740694a"], "tags": []}], "date": 1568908796, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "11999": {"changesets": [{"author": "Nihanth Subramanya \u003cnhnt11@gmail.com\u003e", "branch": "default", "desc": "Bug 1578187 - Reduce Protections and Identity panel scale on linux. r=dao a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44882", "files": ["browser/themes/shared/controlcenter/panel.inc.css"], "git_node": null, "git_parents": [null], "node": "c631ba284d17b58cf68bf4ded612dda8377fc571", "parents": ["cee0b37108d61f3d483441ea6eb82a3b1c48b3fe"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1578807 - Reset the cache if the count of built in search engines is different to the number in the engines cache. r=daleharvey a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45204", "files": ["toolkit/components/search/SearchService.jsm", "toolkit/components/search/tests/xpcshell/test_json_cache_broken.js", "toolkit/components/search/tests/xpcshell/test_json_cache_good.js", "toolkit/components/search/tests/xpcshell/xpcshell.ini", "toolkit/components/telemetry/Scalars.yaml"], "git_node": null, "git_parents": [null], "node": "7d5227aa9112f9f008acd76310013c00faddfd3e", "parents": ["c631ba284d17b58cf68bf4ded612dda8377fc571"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1582081 - Fix detection of builtin engines in the search cache. r=daleharvey a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46291", "files": ["toolkit/components/search/SearchService.jsm", "toolkit/components/search/tests/xpcshell/test_json_cache_broken.js", "toolkit/components/search/tests/xpcshell/test_json_cache_good.js"], "git_node": null, "git_parents": [null], "node": "7109ada30ee4f6b27f7889d484c9101606687040", "parents": ["7d5227aa9112f9f008acd76310013c00faddfd3e"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1580737 - Prevent the search service from shutting down and writing an invalid cache in the middle of (re-)initialisation. r=daleharvey a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46003", "files": ["toolkit/components/search/SearchService.jsm"], "git_node": null, "git_parents": [null], "node": "8cd0caa2a4df8651ee709644be3ddd88f664595c", "parents": ["7109ada30ee4f6b27f7889d484c9101606687040"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1582016 - When text-underline-offset is `auto`, clamp the minimum used underline-offset to 1/16em. r=dholbert a=RyanVM\n\nThis is to avoid skip-ink problems with fonts that leave the OpenType field at zero,\nwhich is unlikely to ever be what is really wanted. Authors can still avoid the clamp by\nexplicitly using text-underline-offset:from-font.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46268", "files": ["layout/generic/nsTextFrame.cpp"], "git_node": null, "git_parents": [null], "node": "64c1b75ba5a7541e5f1aa8b3843fa4c4206b105f", "parents": ["8cd0caa2a4df8651ee709644be3ddd88f664595c"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1576386 - Don't recompute the networkId during shutdown r=michal a=RyanVM\n\nCalling the windows APIs may block shutdown.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45161", "files": ["netwerk/system/win32/nsNotifyAddrListener.cpp"], "git_node": null, "git_parents": [null], "node": "3e843672eec79d1b4c239429556a99b26ba000f2", "parents": ["64c1b75ba5a7541e5f1aa8b3843fa4c4206b105f"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1576386 - Set a 2 second timeout when shutting down the Link Monitor thread r=mayhemer a=RyanVM\n\nThe thread calls into some windows APIs that may sometimes block for a long time. Since we're shutting down anyway, it is OK to sometimes leak this thread, similar to what we do for DNS resolver threads.\n\nThe patch converts nsNotifyAddrListener::mThread to a nsIThreadPool (with a max of 1 thread) so that we may call shutdownWithTimeout on it.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46002", "files": ["netwerk/system/win32/nsNotifyAddrListener.cpp", "netwerk/system/win32/nsNotifyAddrListener.h"], "git_node": null, "git_parents": [null], "node": "60219e1b3b2af2451a79cacb077797d1138e2292", "parents": ["3e843672eec79d1b4c239429556a99b26ba000f2"], "tags": []}], "date": 1568910360, "git_changesets": [null, null, null, null, null, null, null], "user": "cbrindusan@mozilla.com"}, "12000": {"changesets": [{"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1569250 - Add telemetry for mDNS use in WebRTC; r=bwc a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44888", "files": ["media/webrtc/signaling/src/peerconnection/PeerConnectionImpl.cpp", "media/webrtc/signaling/src/peerconnection/PeerConnectionImpl.h", "toolkit/components/telemetry/Histograms.json", "toolkit/components/telemetry/Scalars.yaml"], "git_node": null, "git_parents": [null], "node": "99303625d7eb8b89d362753cff99b6ee3c187df0", "parents": ["60219e1b3b2af2451a79cacb077797d1138e2292"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1581577 - Fix ICE duration telemetry high value; r=bwc a=RyanVM\n\nThe Telemetry::AccumulateTimeDelta function reports in milliseconds but I had\nassumed seconds when I added the hostname obfuscation ICE duration histogram.\nThis change adjusts the \"high\" value accordingly.\n\nWith the telemetry we've collected to date, 60% of the values are below 600\nmilliseconds, so I think that setting a high value of 30 seconds should be\nsufficient even if there is a long tail. Since this does not change the data\nbeing collected, no additional data-review is required, but it does require\nrenaming the key.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46045", "files": ["media/webrtc/signaling/src/peerconnection/PeerConnectionImpl.cpp", "toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "ea623101ca501adf6142e32957d96b3bcfbd9e3f", "parents": ["99303625d7eb8b89d362753cff99b6ee3c187df0"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1580152 - [Wayland] Fix rendering glitches on wayland , r=jhorak a=RyanVM\n\n- Recently we're missing some drawings as we disabled flushing cached images in frame callback. Let's enable it again and make sure we don't flush the drawings between Lock()/Commit() compositor calls which is controlled by mBufferCommitAllowed.\n\n- When we draw directly to wl_buffer, flush all cached drawings we have or clear them if there's fullscreen update. It prevents potential rendering of cached images over unrelevant buffer content.\n\n- Flush cached images when wl_buffer is detached by wayland compositor. It allows to paint delayed drawings and ensures they won't stay in the queue infinitely.\n\n- Use mBufferPendingCommit to indicate that the WaylandBuffer contains updates from gecko which has not been submitted to wayland compositor yet. Allows delated commit handlers (frame callback, delayed commit and when wl_buffer is detached) to send WaylandBuffer content to wayland compositor.\n\n- Record time of last finished commit to mLastCommitTime and throws warning when wayland compositor does not release wl_buffer in 200ms.\n\n- Use wl_display_sync() to synchronize wl_display events. Wait for events from wl_display until all pending events are processed before we start drawing at WindowSurfaceWayland::Lock(). There may wl_buffer release event waiting which releases wl_buffer for rendering.\n\n- Don't use XMost()/YMost() to get drawing area size.\n\n- Remove mDisplayThreadMessageLoop as it's no longer used.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45661", "files": ["widget/gtk/WindowSurfaceWayland.cpp", "widget/gtk/WindowSurfaceWayland.h", "widget/gtk/mozwayland/mozwayland.h", "widget/gtk/nsWaylandDisplay.cpp", "widget/gtk/nsWaylandDisplay.h"], "git_node": null, "git_parents": [null], "node": "3281a617f22b09aabf10f293ae12d8f9483f5bf0", "parents": ["ea623101ca501adf6142e32957d96b3bcfbd9e3f"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1581748 - [Wayland] Fixed rendering of overlapping areas, r=jhorak a=RyanVM\n\n- Don't store whole buffer update information at mWholeWindowBufferDamage but use damage region instead.\n- Check and remove overlapped images when they are stored at image cache.\n- Remove CanDrawToWaylandBufferDirectly() as it's not very useful.\n\nThis commit depends on Bug 1580152 which needs to land first.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46140", "files": ["widget/gtk/WindowSurfaceWayland.cpp", "widget/gtk/WindowSurfaceWayland.h"], "git_node": null, "git_parents": [null], "node": "45c0e8a9df93f545bfacf07e5a78bd69559c6adf", "parents": ["3281a617f22b09aabf10f293ae12d8f9483f5bf0"], "tags": ["DEVEDITION_70_0b8_BUILD1", "DEVEDITION_70_0b8_RELEASE", "FIREFOX_70_0b8_BUILD1", "FIREFOX_70_0b8_RELEASE"]}], "date": 1568911601, "git_changesets": [null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "12001": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 45c0e8a9df93f545bfacf07e5a78bd69559c6adf with DEVEDITION_70_0b8_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "5772670238747b0dc7905c06c36baaa2be8719c3", "parents": ["45c0e8a9df93f545bfacf07e5a78bd69559c6adf"], "tags": []}], "date": 1568919555, "git_changesets": [null], "user": "ffxbld"}, "12002": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 45c0e8a9df93f545bfacf07e5a78bd69559c6adf with FIREFOX_70_0b8_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "efec108c1441c20db478d4ebbc1c45b80cde2c96", "parents": ["5772670238747b0dc7905c06c36baaa2be8719c3"], "tags": []}], "date": 1568919884, "git_changesets": [null], "user": "ffxbld"}, "12003": {"changesets": [{"author": "lesley \u003clnorton@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576047: Make breach indicators accessible. r=jaws,fluent-reviewers,flod\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44913", "files": ["browser/components/aboutlogins/content/aboutLogins.html", "browser/components/aboutlogins/content/components/login-list.css", "browser/components/aboutlogins/tests/chrome/test_login_list.html", "browser/locales/en-US/browser/aboutLogins.ftl"], "git_node": null, "git_parents": [null], "node": "00f88085fc8b162ed0dd8e0b040007537f97b027", "parents": ["efec108c1441c20db478d4ebbc1c45b80cde2c96"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1567423 - Combine all synchronous messages sent at startup of about:logins. r=MattN\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45739", "files": ["browser/components/BrowserGlue.jsm", "browser/components/aboutlogins/AboutLoginsChild.jsm", "browser/components/aboutlogins/AboutLoginsParent.jsm", "browser/components/aboutlogins/content/aboutLogins.js", "browser/components/aboutlogins/content/components/login-footer.js"], "git_node": null, "git_parents": [null], "node": "23b2c24e9c80bc0ea77657504919b181a8b6da6d", "parents": ["00f88085fc8b162ed0dd8e0b040007537f97b027"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1567423 - Allow for searching passwords in about:logins when MP is disabled. r=MattN\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45016", "files": ["browser/components/aboutlogins/AboutLoginsChild.jsm", "browser/components/aboutlogins/AboutLoginsParent.jsm", "browser/components/aboutlogins/content/components/login-list.js", "browser/components/aboutlogins/tests/browser/browser_masterPassword.js", "browser/components/aboutlogins/tests/chrome/aboutlogins_common.js", "browser/components/aboutlogins/tests/chrome/test_login_filter.html", "browser/components/aboutlogins/tests/chrome/test_login_list.html", "toolkit/components/passwordmgr/content/passwordManager.js"], "git_node": null, "git_parents": [null], "node": "d625054db0cd549d82544631f2fec04bb619849e", "parents": ["23b2c24e9c80bc0ea77657504919b181a8b6da6d"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575516 - Show the Discard Changes dialog if a login is modified while being edited. r=MattN\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44910", "files": ["browser/components/aboutlogins/content/components/login-item.js", "browser/components/aboutlogins/tests/browser/browser_aaa_eventTelemetry_run_first.js", "browser/components/aboutlogins/tests/browser/browser_createLogin.js", "browser/components/aboutlogins/tests/browser/browser_openSite.js"], "git_node": null, "git_parents": [null], "node": "9f00e78551f6c0c34ddf76379fdbf710764eb0c2", "parents": ["d625054db0cd549d82544631f2fec04bb619849e"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1579184 - Login list items should be taller to match the spec. r=sfoster\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45904", "files": ["browser/components/aboutlogins/content/