ontext.cpp", "docshell/base/BrowsingContext.h", "docshell/base/BrowsingContextFieldList.h", "dom/base/nsGlobalWindowOuter.cpp", "dom/base/nsGlobalWindowOuter.h"], "git_node": null, "git_parents": [null], "node": "e5b86d2879a750e68921d9ff8b516ec526a4d5c5", "parents": ["8d251dd4a9bebaa3e72a23d795122d4b12097ffc"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1576407: Part 2 - Don't set BrowsingContext opener when forcing noopener. r=farre\n\nWe currently handler this correctly for the opener stored on the outer window,\nbut not on the BrowsingContext.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43691", "files": ["dom/ipc/ContentChild.cpp"], "git_node": null, "git_parents": [null], "node": "97e495f0b3148162bb1ef3bee30656e6104ef390", "parents": ["e5b86d2879a750e68921d9ff8b516ec526a4d5c5"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1576407: Part 3 - Return window opener as a WindowProxyHolder or BrowsingContext. r=farre\n\nAlso adds a legacy `GetSameProcessOpener()` method for callers which can only\ndeal with in-process windows and may need to be updated for Fission.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43692", "files": ["docshell/base/nsDSURIContentListener.cpp", "dom/base/Document.cpp", "dom/base/nsGlobalWindowInner.cpp", "dom/base/nsGlobalWindowInner.h", "dom/base/nsGlobalWindowOuter.cpp", "dom/base/nsGlobalWindowOuter.h", "dom/base/nsPIDOMWindow.h", "dom/websocket/WebSocket.cpp"], "git_node": null, "git_parents": [null], "node": "b64def9593e40d44971104547356ee7b44a76a44", "parents": ["97e495f0b3148162bb1ef3bee30656e6104ef390"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1576407: Part 4 - Stop storing opener redundantly on nsGlobalWindowOuter. r=farre\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43693", "files": ["docshell/base/BrowsingContext.h", "dom/base/nsFrameLoader.cpp", "dom/base/nsGlobalWindowInner.cpp", "dom/base/nsGlobalWindowOuter.cpp", "dom/base/nsGlobalWindowOuter.h", "dom/base/nsPIDOMWindow.h", "dom/ipc/ContentChild.cpp", "toolkit/components/windowwatcher/nsWindowWatcher.cpp", "xpfe/appshell/nsWebShellWindow.cpp"], "git_node": null, "git_parents": [null], "node": "7c55d3338a5b80e77b53ae3e3ed2f06f5331a438", "parents": ["b64def9593e40d44971104547356ee7b44a76a44"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1576407: Part 5 - Update test expectations to handler cross-process window.opener being available. r=farre\n\nThis also sets the fission.rebuild_frameloaders_on_remoteness_change=true\npreference for some mochitest directories which require it for cross-process\nwindow.opener to work in top-level windows, and makes a minor change to the\nhack in browser_temporary_permissions.js to keep it passing reliably in try\nruns.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43694", "files": ["browser/base/content/test/permissions/browser_temporary_permissions.js", "dom/tests/mochitest/bugs/mochitest.ini", "dom/tests/mochitest/localstorage/mochitest.ini", "dom/tests/mochitest/sessionstorage/mochitest.ini", "dom/tests/mochitest/whatwg/mochitest.ini", "toolkit/components/extensions/test/mochitest/mochitest-common.ini"], "git_node": null, "git_parents": [null], "node": "79e99efa822e3f6fc1fa483da4104f9211b62946", "parents": ["7c55d3338a5b80e77b53ae3e3ed2f06f5331a438"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1576407: Follow-up: Ignore window.opener get/set when BrowsingContext is discarded. r=nika\n\nMANUAL PUSH: Can't update patch on phabricator.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43833", "files": ["docshell/base/BrowsingContext.h", "dom/base/nsGlobalWindowInner.cpp", "dom/base/nsGlobalWindowOuter.cpp"], "git_node": null, "git_parents": [null], "node": "277b0a847f203afc93edd302f7ad1e9a4d14524c", "parents": ["79e99efa822e3f6fc1fa483da4104f9211b62946"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1576407: Follow-up: Move IsDiscarded check to BrowsingContext::GetOpener. r=nika\n\nMANUAL PUSH: Follow-up.", "files": ["docshell/base/BrowsingContext.h", "dom/base/nsGlobalWindowOuter.cpp"], "git_node": null, "git_parents": [null], "node": "e43b42cf9c65b318150af31c960faf91c35a816c", "parents": ["277b0a847f203afc93edd302f7ad1e9a4d14524c"], "tags": []}, {"author": "Mihai Alexandru Michis \u003cmalexandru@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to mozilla-inbound.", "files": ["dom/tests/mochitest/whatwg/mochitest.ini"], "git_node": null, "git_parents": [null, null], "node": "282a30908d52b22f4602eaeba1677d2fe666a46d", "parents": ["e43b42cf9c65b318150af31c960faf91c35a816c", "cae93ef1993e02a136ef64d974856071b905997f"], "tags": []}, {"author": "Alexander J. Vincent \u003cajvincent@gmail.com\u003e", "branch": "default", "desc": "Bug 1577372, restore copy command via context menu to pageInfo dialog. r=johannh\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44084", "files": ["browser/base/content/pageinfo/pageInfo.js", "browser/base/content/pageinfo/pageInfo.xul", "browser/locales/en-US/browser/pageInfo.ftl"], "git_node": null, "git_parents": [null], "node": "c8ec40f7e5d5c4fe8e14a292caf353fbfe708d42", "parents": ["282a30908d52b22f4602eaeba1677d2fe666a46d"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1577024 - [Wayland] Enable experimental wayland backend modes by widget.wayland_cache_mode pref, r=jhorak\n\nImage cache mode can be set by widget.wayland_cache_mode.\n\n- widget.wayland_cache_mode = 0 (or missing):\n  Cache and clip all drawings, default. It's slowest\n  but also without any rendered artifacts.\n\n- widget.wayland_cache_mode = 1:\n  Cache drawing only when back buffer is missing. May produce\n  some rendering artifacts and flickering when partial screen update\n  is rendered.\n\n- widget.wayland_cache_mode = 2:\n  Don't cache anything, draw only when back buffer is available.\n  Suitable for fullscreen content only like fullscreen video playback and\n  may work well with dmabuf backend.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43681", "files": ["widget/gtk/WindowSurfaceWayland.cpp", "widget/gtk/WindowSurfaceWayland.h", "widget/gtk/nsWaylandDisplay.cpp", "widget/gtk/nsWaylandDisplay.h"], "git_node": null, "git_parents": [null], "node": "893a4487b58644284f8eace41f7604d370eacc93", "parents": ["c8ec40f7e5d5c4fe8e14a292caf353fbfe708d42"], "tags": []}, {"author": "Jeff Walden \u003cjwalden@mit.edu\u003e", "branch": "default", "desc": "Bug 1447668 - Add a test.  r=jorendorff\nMANUAL PUSH: Splinter patch reviewed in the pre-phabricator days, using Lando would require posting to phabricator, generating redundant-with-history reviewspam for jorendorff, me clicking through a bunch of nonsense about it \"not being reviewed yadda yadda\" to Lando it, &c.  Doin' it old-school...", "files": ["js/src/jit-test/tests/ctypes/conversion-to-number.js"], "git_node": null, "git_parents": [null], "node": "2ce54fbea7dc53831e822d3af55871a4117b9629", "parents": ["893a4487b58644284f8eace41f7604d370eacc93"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Merge autoland to mozilla-central. a=merge", "files": ["layout/reftests/forms/input/text/line-height-1.5.html"], "git_node": null, "git_parents": [null, null], "node": "56db66978b427e18362c3d1d733f7fcb61d2912e", "parents": ["cae93ef1993e02a136ef64d974856071b905997f", "4bed9794caf24942c017d05a0d24c2c7086d3c98"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-inbound to mozilla-central. a=merge", "files": ["browser/base/content/pageinfo/pageInfo.js", "browser/base/content/pageinfo/pageInfo.xul", "browser/locales/en-US/browser/pageInfo.ftl", "dom/base/nsGlobalWindowOuter.cpp"], "git_node": null, "git_parents": [null, null], "node": "b3cc8963e8718dbd40761f14664f45320c258bbd", "parents": ["56db66978b427e18362c3d1d733f7fcb61d2912e", "2ce54fbea7dc53831e822d3af55871a4117b9629"], "tags": []}, {"author": "Bob Owen \u003cbobowencode@gmail.com\u003e", "branch": "default", "desc": "Bug 1575906: Allow the GMP process to duplicate Section handles to the main process. r=handyman\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44237", "files": ["security/sandbox/win/src/sandboxbroker/sandboxBroker.cpp"], "git_node": null, "git_parents": [null], "node": "54dcc1dc10c72771c95164cfaab03544a2e86a98", "parents": ["b3cc8963e8718dbd40761f14664f45320c258bbd"], "tags": []}, {"author": "Henri Sivonen \u003chsivonen@hsivonen.fi\u003e", "branch": "default", "desc": "Bug 1577700 - Add a function for obtaining a Span of char from a Span of uint8_t. r=froydnj\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44124", "files": ["mfbt/Span.h", "mfbt/tests/gtest/TestSpan.cpp"], "git_node": null, "git_parents": [null], "node": "fe25291a6919fda43493b21746564283ad1fa775", "parents": ["54dcc1dc10c72771c95164cfaab03544a2e86a98"], "tags": []}, {"author": "Sylvestre Ledru \u003csledru@mozilla.com\u003e", "branch": "default", "desc": "Bug 1577236 - clang-10: Fix -Wimplicit-int-float-conversion warnings in dom/vr/ r=kip\n\nDepends on D43781\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43782", "files": ["dom/vr/VRDisplay.cpp"], "git_node": null, "git_parents": [null], "node": "da9a6db4b59b15ff3805a97f1a530551acb6b27a", "parents": ["fe25291a6919fda43493b21746564283ad1fa775"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1577831 - remove `using namespace std;` from IPC glue code; r=jld\n\nJust some minor prefixing needs to be done to enable this.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44220", "files": ["ipc/glue/MessageChannel.cpp", "ipc/glue/MessageLink.cpp", "ipc/glue/Transport_posix.cpp", "ipc/glue/Transport_win.cpp"], "git_node": null, "git_parents": [null], "node": "3a41fd305c3ce85b9f534f15cd90dfd4ae82c0d1", "parents": ["da9a6db4b59b15ff3805a97f1a530551acb6b27a"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576748 - make symbolstore.py complain loudly if expected output isn't found; r=nalexander\n\nThis change surfaces errors faster, and ensures that we don't silently\nend up with empty crashreporter symbols if `dump_syms` can't run for\nsome reason.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43520", "files": ["toolkit/crashreporter/tools/symbolstore.py"], "git_node": null, "git_parents": [null], "node": "97ec7ec089c4e91acd34d7324711cc9c556b1117", "parents": ["3a41fd305c3ce85b9f534f15cd90dfd4ae82c0d1"], "tags": []}, {"author": "Dale Harvey \u003cdale@arandomurl.com\u003e", "branch": "default", "desc": "Bug 1572470 - Add wikipedia to engines.json r=Standard8\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43768", "files": ["browser/components/search/extensions/engines.json", "toolkit/components/search/SearchEngineSelector.jsm", "toolkit/components/search/docs/SearchEngineConfiguration.rst", "toolkit/components/search/tests/xpcshell/test_engine_selector.js"], "git_node": null, "git_parents": [null], "node": "19b8d6a399f60de32ca253fa497c23cbfa93d265", "parents": ["97ec7ec089c4e91acd34d7324711cc9c556b1117"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1574586 - Create separate NativeLayer objects for opaque and transparent parts of the window, and do one composite each to draw their contents. r=mattwoodrow\n\nThis means that when something changes in an opaque layer, the window server\nonly needs to copy the opaque layer to the screen and can avoid recomputing any\nwindow backgrounds for transparent parts of the window. This can save power,\nespecially when transparent parts of the window use the macOS vibrancy effect,\nwhich requires the window server to compute a blur and to composite windows\nbehind our window.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43880", "files": ["gfx/layers/composite/LayerManagerComposite.cpp", "gfx/layers/composite/LayerManagerComposite.h"], "git_node": null, "git_parents": [null], "node": "9798d276348f91a467897783525134fe2b10723a", "parents": ["19b8d6a399f60de32ca253fa497c23cbfa93d265"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1491456 - Split the window into \"compositing tiles\" sized to 1024x1024. r=mattwoodrow\n\nThe tile size is configurable with the prefs layers.compositing-tiles.width/height.\n\nOn macOS, whenever a CALayer is touched, the window server will recomposite the\nentire layer to the screen. There is no API to mark parts of a layer as damaged.\nSo if we want the window server to only redraw a small part of the screen, we\nneed to only touch small layers. This patch achieves that using tiles; whenever\nthe compositor needs to redraw an area, all tiles that overlap this area will\nbe drawn to their layers and the window server will recomposite those layers.\n\nOn Intel GPUs, compositing in tiles should also help reduce GPU times if there\nare multiple layers of overdraw: The overdraw will have better cache locality.\nHowever, the magnitude of this effect is not known and requires further research.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43881", "files": ["gfx/layers/composite/LayerManagerComposite.cpp", "modules/libpref/init/StaticPrefList.yaml"], "git_node": null, "git_parents": [null], "node": "83dba42b1853525e59efe05f361bd244937580d3", "parents": ["9798d276348f91a467897783525134fe2b10723a"], "tags": []}, {"author": "Robert Helmer \u003crhelmer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576507 - add new FirstStartup service and --first-startup post-install flag. r=mconley\n\nFirstStartup provides an optional mechanism to run synchronous services\nbefore the UI appears. This is intended to be called as a post-install\naction from an installer, such as the Windows Stub Installer, to allow\nfor downloading critical data and performance tuning before the first\nrun of a new Firefox install.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43364", "files": ["browser/components/BrowserContentHandler.jsm", "toolkit/modules/FirstStartup.jsm", "toolkit/modules/moz.build"], "git_node": null, "git_parents": [null], "node": "c547b758be35c62a4a2311443afaa7ac8dbe892e", "parents": ["83dba42b1853525e59efe05f361bd244937580d3"], "tags": []}, {"author": "Robert Helmer \u003crhelmer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576507 - skip ClientEnvironment entries unavailable on first run r=mythmon\n\nDepends on D43364\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43570", "files": ["toolkit/components/utils/ClientEnvironment.jsm"], "git_node": null, "git_parents": [null], "node": "c0422b67e5d01c87ea78ed36985dfb01c2c56a24", "parents": ["c547b758be35c62a4a2311443afaa7ac8dbe892e"], "tags": []}, {"author": "Robert Helmer \u003crhelmer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576507 - add Normandy to FirstStartup service. r=mythmon\n\nDepends on D43570\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43366", "files": ["toolkit/components/normandy/Normandy.jsm", "toolkit/components/telemetry/Scalars.yaml", "toolkit/modules/FirstStartup.jsm", "toolkit/modules/tests/xpcshell/test_firstStartup.js", "toolkit/modules/tests/xpcshell/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "797a54d2af1d9aa4a0bea8a360addea9b81dc4b7", "parents": ["c0422b67e5d01c87ea78ed36985dfb01c2c56a24"], "tags": []}, {"author": "Robert Helmer \u003crhelmer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576507 - document FirstStartup module r=mythmon\n\nDepends on D43366\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44035", "files": ["toolkit/modules/docs/FirstStartup.rst", "toolkit/modules/docs/index.rst"], "git_node": null, "git_parents": [null], "node": "7afcfc71024f568e479c243959c8c538da2f496c", "parents": ["797a54d2af1d9aa4a0bea8a360addea9b81dc4b7"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1575681 - Add policy to remove access to the password manager. r=MattN,fluent-reviewers,flod\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43673", "files": ["browser/components/enterprisepolicies/Policies.jsm", "browser/components/enterprisepolicies/schemas/policies-schema.json", "browser/components/enterprisepolicies/tests/browser/browser.ini", "browser/components/enterprisepolicies/tests/browser/browser_policy_block_about.js", "browser/components/enterprisepolicies/tests/browser/browser_policy_passwordmanager.js", "browser/locales/en-US/browser/policies/policies-descriptions.ftl"], "git_node": null, "git_parents": [null], "node": "a63410d10c7a9d06504c66338ccdeaac945a8d00", "parents": ["7afcfc71024f568e479c243959c8c538da2f496c"], "tags": []}, {"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575089 - Add a new Talos test that measures warm startup time with a number of real-world WebExtensions installed. r=rwood\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43309", "files": [".hgignore", "taskcluster/ci/test/talos.yml", "taskcluster/ci/test/test-sets.yml", "testing/mozharness/mozharness/mozilla/testing/talos.py", "testing/talos/talos.json", "testing/talos/talos/ffsetup.py", "testing/talos/talos/getinfooffline/api.js", "testing/talos/talos/getinfooffline/background.js", "testing/talos/talos/getinfooffline/manifest.json", "testing/talos/talos/getinfooffline/schema.json", "testing/talos/talos/test.py", "testing/talos/webextensions.manifest"], "git_node": null, "git_parents": [null], "node": "72edc19d4181e2086bba17f616d001771d65f098", "parents": ["a63410d10c7a9d06504c66338ccdeaac945a8d00"], "tags": []}, {"author": "Andreea Pavel \u003capavel@mozilla.com\u003e", "branch": "default", "desc": "Bug 1560378 - disabled test_bug1364364.html on android r=gbrown CLOSED TREE\n\nDifferential Revision: https://phabricator.services.mozilla.com//D44303", "files": ["docshell/test/navigation/mochitest.ini"], "git_node": null, "git_parents": [null], "node": "8e2dfb26c66ce8f6a48bb1ba2f9d2a4ca6d884fe", "parents": ["72edc19d4181e2086bba17f616d001771d65f098"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1577790 - fix dark theme best practices icon fill color. r=gl\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44234", "files": ["devtools/client/accessibility/accessibility.css", "devtools/client/accessibility/components/Check.js", "devtools/client/accessibility/test/jest/components/__snapshots__/check.test.js.snap", "devtools/client/accessibility/test/jest/components/__snapshots__/keyboard-check.test.js.snap", "devtools/client/accessibility/test/jest/components/__snapshots__/text-label-check.test.js.snap", "devtools/client/accessibility/test/jest/helpers.js"], "git_node": null, "git_parents": [null], "node": "b3a62419e1ba731f58a5ca3273ce6099c18c355d", "parents": ["8e2dfb26c66ce8f6a48bb1ba2f9d2a4ca6d884fe"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1577439 - Shutdown Servo's thread-pool in leak-checking builds, leak the atom table elsewhere. r=bholley\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44217", "files": [