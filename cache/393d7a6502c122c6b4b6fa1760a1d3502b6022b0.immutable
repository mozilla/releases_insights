ets r=release a=l10n-bump DONTBUILD\n\ndsb -\u003e 32ee146e4a52\nen-GB -\u003e 31adfb363573\ngn -\u003e 48621211f236\nhsb -\u003e 380b2e9495bd\nit -\u003e 89e576ba7532", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "610f3252fe467507e76c8e704dab3c7c80f83671", "parents": ["f73a49d90a965f10495a4070a502a347a25e0842"], "tags": []}], "date": 1570564838, "git_changesets": [null], "user": "ffxbld"}, "12140": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\ndsb -\u003e 32ee146e4a52\nen-GB -\u003e 31adfb363573\ngn -\u003e 48621211f236\nhsb -\u003e 380b2e9495bd\nit -\u003e 89e576ba7532", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "b9dd55b00736ac3b430319bb39bbb01650e77bcd", "parents": ["610f3252fe467507e76c8e704dab3c7c80f83671"], "tags": []}], "date": 1570568429, "git_changesets": [null], "user": "ffxbld"}, "12141": {"changesets": [{"author": "Gavin Lazar Suntop \u003cgavin@gsuntop.com\u003e", "branch": "default", "desc": "Bug 1584642 - Control engagment labels with a pref r=Mardak a=lizzard\n\nControl visibility of engagement labels with a pref\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48408", "files": ["browser/components/newtab/content-src/components/DiscoveryStreamBase/DiscoveryStreamBase.jsx", "browser/components/newtab/content-src/components/DiscoveryStreamComponents/CardGrid/CardGrid.jsx", "browser/components/newtab/content-src/components/DiscoveryStreamComponents/DSCard/DSCard.jsx", "browser/components/newtab/content-src/components/DiscoveryStreamComponents/DSContextFooter/DSContextFooter.jsx", "browser/components/newtab/data/content/activity-stream.bundle.js", "browser/components/newtab/lib/ActivityStream.jsm", "browser/components/newtab/test/unit/content-src/components/DiscoveryStreamComponents/DSContextFooter.test.jsx"], "git_node": null, "git_parents": [null], "node": "88ee6a1c386bf0a98b1f15ea34e96c514ac0b3c8", "parents": ["b9dd55b00736ac3b430319bb39bbb01650e77bcd"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1585882 - Fix needs_frame() check to account for the case where an ancestor of us has been reconstructed regularly, not via lazy frame construction. r=heycam a=lizzard\n\nThis is a pre-existing bug, and this would be enough to fix the website, but\nthis is still not 100% correct. More on that in a second.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48134", "files": ["servo/ports/geckolib/glue.rs", "testing/web-platform/tests/css/cssom/getComputedStyle-animations-replaced-into-ib-split.html", "testing/web-platform/tests/css/cssom/getComputedStyle-layout-dependent-replaced-into-ib-split.html"], "git_node": null, "git_parents": [null], "node": "5bc75972ab4cd548d88f64ee26ef6627b4e547bd", "parents": ["88ee6a1c386bf0a98b1f15ea34e96c514ac0b3c8"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1585882 - Fix the case where where a node with an up-to-date style loses its frame due to a DOM mutation of siblings. r=heycam a=lizzard\n\nThis fixes another edge-case that I thought of while debugging this, I think\nthis makes our behavior correct now. The comment and test-case should be\nself-descriptive.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48135", "files": ["layout/base/RestyleManager.cpp", "layout/base/RestyleManager.h", "layout/style/nsComputedDOMStyle.cpp", "layout/style/nsComputedDOMStyle.h", "servo/ports/geckolib/glue.rs", "testing/web-platform/tests/css/cssom/getComputedStyle-layout-dependent-removed-ib-sibling.html"], "git_node": null, "git_parents": [null], "node": "51a8a5cec037c89d44cea72535b443473c0d4cef", "parents": ["5bc75972ab4cd548d88f64ee26ef6627b4e547bd"], "tags": []}], "date": 1570574108, "git_changesets": [null, null, null], "user": "aiakab@mozilla.com"}, "12142": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nar -\u003e 33e2ffd36693\nnn-NO -\u003e a671ab4a205b\npt-BR -\u003e 99af08b0dc79", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "bfb7fd4ebf0d2df6418e6dc9538d83a91ad50724", "parents": ["51a8a5cec037c89d44cea72535b443473c0d4cef"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nar -\u003e 33e2ffd36693\nnn-NO -\u003e a671ab4a205b\npt-BR -\u003e 99af08b0dc79", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "7abfb3a08344a651e197320330c0973cae34c1a2", "parents": ["bfb7fd4ebf0d2df6418e6dc9538d83a91ad50724"], "tags": []}], "date": 1570600847, "git_changesets": [null, null], "user": "ffxbld"}, "12143": {"changesets": [{"author": "Punam Dahiya \u003cpunamdahiya@yahoo.com\u003e", "branch": "default", "desc": "Bug 1582242 - Modal should not close when clicked outside the dialog a=lizzard\n\nClick outside dialog should not close modal\n\nDifferential Revision: https://phabricator.services.mozilla.com//D48427", "files": ["browser/components/newtab/content-src/asrouter/components/ModalOverlay/ModalOverlay.jsx", "browser/components/newtab/content-src/asrouter/components/ModalOverlay/_ModalOverlay.scss", "browser/components/newtab/content-src/asrouter/templates/Trailhead/Trailhead.jsx", "browser/components/newtab/css/activity-stream-linux.css", "browser/components/newtab/css/activity-stream-mac.css", "browser/components/newtab/css/activity-stream-windows.css", "browser/components/newtab/data/content/activity-stream.bundle.js", "browser/components/newtab/test/unit/asrouter/ModalOverlay.test.jsx"], "git_node": null, "git_parents": [null], "node": "d4b48f0460bd65c09ef3fd9255171e0ae243a066", "parents": ["7abfb3a08344a651e197320330c0973cae34c1a2"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1581117 - Properly invalidate theme data from the media query change in LightweightThemeConsumer.jsm. a=RyanVM\n\nJust this._update() is not enough to update everything that changing the theme\nimplies. Instead, use the observer mechanism so all the pieces of code involved\nupdate properly.\n\nDifferential Revision: https://phabricator.services.mozilla.com//D45926", "files": ["toolkit/modules/LightweightThemeConsumer.jsm"], "git_node": null, "git_parents": [null], "node": "91ac17bc71eaec127fa155ece81c89ecad2b4fdf", "parents": ["d4b48f0460bd65c09ef3fd9255171e0ae243a066"], "tags": []}, {"author": "Edouard Oger \u003ceoger@fastmail.com\u003e", "branch": "default", "desc": "Bug 1579445 - Refresh the FxA device list on Send Tab menu open. a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com//D45189", "files": ["browser/base/content/browser-pageActions.js", "browser/base/content/browser-sync.js"], "git_node": null, "git_parents": [null], "node": "23bf5f0fdb544ad77ee16ecd4eb1c5d3cbe89157", "parents": ["91ac17bc71eaec127fa155ece81c89ecad2b4fdf"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1574963 - Add a policy for using legacy profiles on Windows. a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com//D47841", "files": ["browser/components/enterprisepolicies/Policies.jsm", "browser/components/enterprisepolicies/schemas/policies-schema.json", "toolkit/profile/nsToolkitProfileService.cpp"], "git_node": null, "git_parents": [null], "node": "286cdf5bc9f35f1d70aa56dcffd289a292925d7e", "parents": ["23bf5f0fdb544ad77ee16ecd4eb1c5d3cbe89157"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1574963 - Add description for LegacyProfiles policy. a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com//D48421", "files": ["browser/locales/en-US/browser/policies/policies-descriptions.ftl"], "git_node": null, "git_parents": [null], "node": "e62d13f0a325d0be38225507a93babccd76c3008", "parents": ["286cdf5bc9f35f1d70aa56dcffd289a292925d7e"], "tags": []}, {"author": "Dana Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "bug 1570222 - avoid passing unrelated certificates to mozilla::pkix from NSSCertDBTrustDomain r?kjacobs a=lizzard\n\nDuring path building, mozilla::pkix filters out candidate certificates provided\nby trust domains where the subject distinguished name does not match the issuer\ndistinguished name of the certificate it's trying to find an issuer for.\nHowever, if there's a problem decoding the candidate issuer certificate,\nmozilla::pkix will make a note of this error, regardless of if that certificate\nwas potentially a suitable issuer. If no trusted path is found, the error from\nthat unrelated certificate may ultimately be returned by mozilla::pkix,\nresulting in confusion.\n\nBefore this patch, NSSCertDBTrustDomain could cause this behavior by blithely\npassing every known 3rd party certificate to mozilla::pkix (other sources of\ncertificates already filter on subject distinguished name). This patch adds\nfiltering to 3rd party certificates as well.\n\nDifferential Revision: https://phabricator.services.mozilla.com//D48120", "files": ["security/certverifier/NSSCertDBTrustDomain.cpp"], "git_node": null, "git_parents": [null], "node": "d69eab8be1bf6f591138af54dc383748f239cfeb", "parents": ["e62d13f0a325d0be38225507a93babccd76c3008"], "tags": []}, {"author": "Vijay Budhram \u003cvbudhram@mozilla.com\u003e", "branch": "default", "desc": "Bug 1580115 - Fix fxa menu disconnected avatar a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com//D46799", "files": ["browser/base/content/browser-sync.js"], "git_node": null, "git_parents": [null], "node": "fbf79b038eb751c4f528087735e4171701334ec8", "parents": ["d69eab8be1bf6f591138af54dc383748f239cfeb"], "tags": []}, {"author": "Haik Aftandilian \u003chaftandilian@mozilla.com\u003e", "branch": "default", "desc": "Bug 1578907 - MacOS 10.15 Beta - Flash File Picker broken r?spohl a=lizzard\n\nAllow access to extra services needed to open file pickers from the Flash process on 10.15.\n\nDifferential Revision: https://phabricator.services.mozilla.com//D48145", "files": ["security/sandbox/mac/SandboxPolicyFlash.h"], "git_node": null, "git_parents": [null], "node": "ecedb785928494238ece6311e003e96e9eb763fb", "parents": ["fbf79b038eb751c4f528087735e4171701334ec8"], "tags": []}, {"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 1581589 - Return null in GetAccessibleOrContainer for text leafs of unrendered maps. r?Jamie! a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com//D47185", "files": ["accessible/generic/DocAccessible.cpp", "accessible/tests/mochitest/treeupdate/test_whitespace.html"], "git_node": null, "git_parents": [null], "node": "0d52451711522294346a175a1fac66859ad9f889", "parents": ["ecedb785928494238ece6311e003e96e9eb763fb"], "tags": []}, {"author": "Sylvestre Ledru \u003csledru@mozilla.com\u003e", "branch": "default", "desc": "Bug 1585058 - Typo in identifier causing the test to return always the same value r?tnguyen a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com//D47638", "files": ["toolkit/content/contentAreaUtils.js"], "git_node": null, "git_parents": [null], "node": "14d183a559e0c667e43c904e4740d657dcd92de9", "parents": ["0d52451711522294346a175a1fac66859ad9f889"], "tags": []}, {"author": "Nihanth Subramanya \u003cnhnt11@gmail.com\u003e", "branch": "default", "desc": "Bug 1586659 - [Protections Pa