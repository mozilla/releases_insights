6509: When a CFR doorhanger is activated via the keyboard, focus its first element. a=lizzard\n\nPreviously, keyboard users had to press f6 several times to get to the doorhanger.\nIf a user is activating the doorhanger from the keyboard, it makes sense that they'd want to interact with it using the keyboard.\n\nDifferential Revision: https://phabricator.services.mozilla.com//D47719", "files": ["browser/components/newtab/lib/CFRPageActions.jsm", "browser/components/newtab/test/browser/browser_asrouter_cfr.js"], "git_node": null, "git_parents": [null], "node": "3972e1aef6d20fdfc017fd51ed3cd83005ed83cd", "parents": ["446ced23746d4f16072941c400f0b3758a5d4ea7"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1577587 - Check the correct preference in -[ChildView shouldMinimizeOnTitlebarDoubleClick] on 10.11 and up. r=spohl a=lizzard\n\nI got these names from https://forums.developer.apple.com/thread/30166 .\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44228", "files": ["widget/cocoa/nsChildView.mm"], "git_node": null, "git_parents": [null], "node": "62883ff399ada8122821afa605d9995f3be08918", "parents": ["3972e1aef6d20fdfc017fd51ed3cd83005ed83cd"], "tags": []}, {"author": "Jonathan Watt \u003cjwatt@jwatt.org\u003e", "branch": "default", "desc": "Bug 1568968. Re-enable existing print telemetry for nightly, beta and release. r=chutten a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43435", "files": ["toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "63e23e5ce811846428807806bea9790298f3a81a", "parents": ["62883ff399ada8122821afa605d9995f3be08918"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1583267 - Restore the cached website favicon when the login is updated. r=MattN a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46808", "files": ["browser/components/aboutlogins/content/components/login-item.js"], "git_node": null, "git_parents": [null], "node": "6d2ff5bac5f784427d690e0cee598982466188b3", "parents": ["63e23e5ce811846428807806bea9790298f3a81a"], "tags": []}, {"author": "Andrei Oprea \u003candrei.br92@gmail.com\u003e", "branch": "default", "desc": "Bug 1570332 - New bookmark popup shows Firefox Sync ad, but 'Feature Recommendations' are turned off r=k88hudson a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com//D48577", "files": ["browser/components/newtab/content-src/asrouter/docs/targeting-attributes.md", "browser/components/newtab/lib/ASRouterTargeting.jsm", "browser/components/newtab/test/browser/browser_asrouter_targeting.js", "browser/components/newtab/test/unit/unit-entry.js"], "git_node": null, "git_parents": [null], "node": "c878bf8a73bbeee7b4cd21a3dd13bf395f5242a7", "parents": ["6d2ff5bac5f784427d690e0cee598982466188b3"], "tags": []}, {"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1584323 - Add more object properties to IndexedDBShutdownTimeout and LocalStorageShutdownTimeout crash annotations; r=asuth, dr=chutten a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47341", "files": ["dom/indexedDB/ActorsParent.cpp", "dom/localstorage/ActorsParent.cpp", "dom/localstorage/LSSnapshot.cpp", "dom/quota/ActorsParent.cpp", "dom/quota/PersistenceType.h", "dom/quota/QuotaCommon.cpp", "dom/quota/QuotaCommon.h", "dom/quota/QuotaManager.h", "toolkit/crashreporter/CrashAnnotations.yaml"], "git_node": null, "git_parents": [null], "node": "3bdc8805aea3f19855db5a0e55e63d5779a64b9a", "parents": ["c878bf8a73bbeee7b4cd21a3dd13bf395f5242a7"], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1581606 - Consider all screens when deciding to turn on WebRender. r=jrmuizel a=lizzard\n\nBefore this patch, we only considered the primary screen when deciding\nwhether or not WebRender should be enabled. This is problematic for\nIntel users where we don't want to turn on WebRender for large screens;\nseveral small screens are just as bad as one large screen. Now we sum\nthe pixel count for all the screens when making this decision.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46066", "files": ["gfx/thebes/gfxPlatform.cpp", "gfx/thebes/gfxPlatform.h", "widget/PuppetWidget.cpp", "widget/ScreenManager.cpp", "widget/nsIScreenManager.idl"], "git_node": null, "git_parents": [null], "node": "59ef27e0a17ac6805917c0c3e5a6711fd3bb74bc", "parents": ["3bdc8805aea3f19855db5a0e55e63d5779a64b9a"], "tags": []}, {"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1586315 - LSNG: Finish RequestHelper when LSRequestChild actor is unexpectedly destroyed; r=asuth a=lizzard\n\nIf LSRequestChild actor is unexpectedly destroyed, the nested event loop runs\nuntil the timer fires. This patch improves that by calling the callback in\nLSRequestChild::ActorDestroyed which immediatelly finishes RequestHelper and\nfinishes the nested event loop in the end too.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48194", "files": ["dom/localstorage/ActorsChild.cpp", "dom/localstorage/ActorsChild.h", "dom/localstorage/LSObject.cpp", "dom/localstorage/LocalStorageManager2.cpp"], "git_node": null, "git_parents": [null], "node": "502e28e5b6570ab1374b76aecef223c247c5aaa5", "parents": ["59ef27e0a17ac6805917c0c3e5a6711fd3bb74bc"], "tags": []}, {"author": "Barret Rennie \u003cbarret@brennie.ca\u003e", "branch": "default", "desc": "Bug 1578304 - Correctly set content title from onLocationChange event r=Ehsan a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48413", "files": ["toolkit/content/widgets/browser-custom-element.js"], "git_node": null, "git_parents": [null], "node": "5f0abbc35dd139df5b7c66da12808e9c63ac47a8", "parents": ["502e28e5b6570ab1374b76aecef223c247c5aaa5"], "tags": []}], "date": 1570663295, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "btara@mozilla.com"}, "12149": {"changesets": [{"author": "Bogdan Tara \u003cbtara@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 3bdc8805aea3 (bug 1584323) for build bustages complaining about ActorsParent.cpp a=backout", "files": ["dom/indexedDB/ActorsParent.cpp", "dom/localstorage/ActorsParent.cpp", "dom/localstorage/LSSnapshot.cpp", "dom/quota/ActorsParent.cpp", "dom/quota/PersistenceType.h", "dom/quota/QuotaCommon.cpp", "dom/quota/QuotaCommon.h", "dom/quota/QuotaManager.h", "toolkit/crashreporter/CrashAnnotations.yaml"], "git_node": null, "git_parents": [null], "node": "dc6cacfca92e92193fb0ce55b0a85b3e16a5eca6", "parents": ["5f0abbc35dd139df5b7c66da12808e9c63ac47a8"], "tags": []}], "date": 1570665433, "git_changesets": [null], "user": "btara@mozilla.com"}, "12150": {"changesets": [{"author": "Peter Van der Beken \u003cpeterv@propagandism.org\u003e", "branch": "default", "desc": "Bug 1584907 - Deny internal entities closing the doctype. r=bzbarsky a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47704", "files": ["parser/expat/lib/xmlparse.c"], "git_node": null, "git_parents": [null], "node": "71e7d47597e9eef2e9f02b1ba2dac12f43fc95b8", "parents": ["dc6cacfca92e92193fb0ce55b0a85b3e16a5eca6"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1583463 - Lock SourceMediaStream's mMutex also during shutdown. r=padenot, a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47681", "files": ["dom/media/MediaStreamGraph.cpp"], "git_node": null, "git_parents": [null], "node": "cf76c02cf9a3ed5e05fbb478755015542cdf9165", "parents": ["71e7d47597e9eef2e9f02b1ba2dac12f43fc95b8"], "tags": []}], "date": 1570665666, "git_changesets": [null, null], "user": "archaeopteryx@coole-files.de"}, "12151": {"changesets": [{"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1586387 - Don't append a device change message to a graph that is going away. r=padenot a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48553", "files": ["dom/media/MediaStreamGraph.cpp"], "git_node": null, "git_parents": [null], "node": "32bbe513637319fceff5e0af9b4b4b0ccb2c36b0", "parents": ["cf76c02cf9a3ed5e05fbb478755015542cdf9165"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1586647 - Hide the Firefox Accounts button if identity.fxaccounts.enabled=false. r=sfoster a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48416", "files": ["browser/components/aboutlogins/AboutLoginsParent.jsm", "browser/components/aboutlogins/content/components/fxaccounts-button.js", "browser/components/aboutlogins/tests/chrome/test_fxaccounts_button.html"], "git_node": null, "git_parents": [null], "node": "a754727ed64ccb04cca8ca4ef41acc2bf53d355b", "parents": ["32bbe513637319fceff5e0af9b4b4b0ccb2c36b0"], "tags": []}, {"author": "Sam Foster \u003csfoster@mozilla.com\u003e", "branch": "default", "desc": "Bug 1586304 - Increase timeout for dismissed attention notifications. r=MattN a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48605", "files": ["toolkit/components/passwordmgr/LoginManagerPrompter.jsm"], "git_node": null, "git_parents": [null], "node": "3c8eae8eea98aac7fb8b6131d39b32eb2008af6f", "parents": ["a754727ed64ccb04cca8ca4ef41acc2bf53d355b"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1581433 - Maximize or minimize the window when double clicking the titlebar. r=spohl a=lizzard\n\nThis was already working for toolbars, but it wasn't working for the titlebar in windows that\nactually have a real separate titlebar.\nAll our windows use NSFullSizeContentViewWindowMask, so we no longer get this behavior for free.\nIn windows with titlebars, the titlebar area is covered with a TitlebarGradientView, so that's\nwhere we need to handle the double clicks.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48593", "files": ["widget/cocoa/nsChildView.mm", "widget/cocoa/nsCocoaUtils.h", "widget/cocoa/nsCocoaUtils.mm", "widget/cocoa/nsCocoaWindow.mm"], "git_node": null, "git_parents": [null], "node": "1059f794155dc4ba1e0517a19d6269b655ae6dc7", "parents": ["3c8eae8eea98aac7fb8b6131d39b32eb2008af6f"], "tags": []}, {"author": "Andrew Swan \u003caswan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1579709 Fix ctrl-tab with only one tab r=bgrins a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48451", "files": ["toolkit/content/widgets/tabbox.js"], "git_node": null, "git_parents": [null], "node": "6a1daea605bf74396a0bdaa0206335d2d8d9cd65", "parents": ["1059f794155dc4ba1e0517a19d6269b655ae6dc7"], "tags": []}, {"author": "Michal Novotny \u003cmichal.novotny@gmail.com\u003e", "branch": "default", "desc": "Bug 1583204 - No Network ID is available when switching between WiFi and Lan networks, r=valentin a=lizzard\n\nThere can be multiple records for the same neighbor with different interface index when the computer is connected to the same network via multiple interfaces, e.g. LAN and WiFi. This patch adds interface index to the key, so when some interface goes down it doesn't remove records belonging to a different interface.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47017", "files": ["netwerk/system/netlink/NetlinkService.cpp", "netwerk/system/netlink/NetlinkService.h"], "git_node": null, "git_parents": [null], "node": "dfdaa3c2d20161da798554073e3a6b9371af3dcc", "parents": ["6a1daea605bf74396a0bdaa0206335d2d8d9cd65"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1586909 - Process anchor suppressions even when ignoring adjustments. r=dholbert a=lizzard\n\nOtherwise we may keep the scroll anchor around and we may try to anchor to it\nlater even though we should've really suppressed it completely.\n\nMaybe we should just call InvalidateAnchor() unconditionally from that code\npath, even if there are no suppressions pending...\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48456", "files": ["layout/generic/ScrollAnchorContainer.cpp", "testing/web-platform/tests/css/css-scroll-anchoring/heuristic-with-offset-update-from-scroll-event-listener.html"], "git_node": null, "git_parents": [null], "node": "871b65946a559bdfcd2080aa6bb525c93e33024e", "parents": ["dfdaa3c2d20161da798554073e3a6b9371af3dcc"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1586909 - followup: Appease wptlint. a=lizzard\n\nMANUAL PUSH: bustage", "files": ["testing/web-platform/tests/css/css-scroll-anchoring/heuristic-with-offset-update-from-scroll-event-listener.html"], "git_node": null, "git_parents": [null], "node": "0166812024e3762a87b3f7bc9cd287fc6027854e", "parents": ["871b65946a559bdfcd2080aa6bb525c93e33024e"], "tags": []}], "date": 1570671954, "git_changesets": [null, null, null, null, null, null, null, null], "user": "btara@mozilla.com"}, "12152": {"changesets": [{"author": "Bogdan Tara \u003cbtara@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 32bbe5136373 (bug 1586387) for bustages complaining about MediaStreamGraph.cpp a=backout", "files": ["dom/media/MediaStreamGraph.cpp"], "git_node": null, "git_parents": [null], "node": "a71242e8207fd5741a2aa981adc13bb727bd158b", "parents": ["0166812024e3762a87b3f7bc9cd287fc6027854e"], "tags": []}], "date": 1570673487, "git_changesets": [null], "user": "btara@mozilla.com"}, "12153": {"changesets": [{"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1584323 - Add more object properties to IndexedDBShutdownTimeout and LocalStorageShutdownTimeout crash annotations; r=asuth, dr=chutten, a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com//D48796", "files": ["dom/indexedDB/ActorsParent.cpp", "dom/localstorage/ActorsChild.cpp", "dom/localstorage/ActorsParent.cpp", "dom/localstorage/LSSnapshot.cpp", "dom/quota/ActorsParent.cpp", "dom/quota/PersistenceType.h", "dom/quota/QuotaCommon.cpp", "dom/quota/QuotaCommon.h", "dom/quota/QuotaManager.h", "toolkit/crashreporter/CrashAnnotations.yaml"], "git_node": null, "git_parents": [null], "node": "ace2e979811f1a196a79e0d90bbe9183a6321155", "parents": ["a71242e8207fd5741a2aa981adc13bb727bd158b"], "tags": []}, {"author": "Daniel Varga \u003cdvarga@mozilla.com\u003e", "branch": "default", "desc": "Bug 1570879 - Fix high contrast theme handling with DirectComposition and WebRender r=nical a=lizzard", "files": ["gfx/layers/CompositorTypes.h", "gfx/layers/d3d11/CompositorD3D11.cpp", "gfx/layers/d3d11/MLGDeviceD3D11.cpp", "gfx/layers/d3d11/MLGDeviceD3D11.h", "gfx/layers/ipc/CompositorBridgeParent.cpp", "gfx/layers/ipc/KnowsCompositor.h", "gfx/layers/ipc/LayersMessageUtils.h", "gfx/layers/mlgpu/LayerManagerMLGPU.cpp", "gfx/layers/mlgpu/MLGDevice.h", "gfx/layers/wr/AsyncImagePipelineManager.cpp", "gfx/layers/wr/AsyncImagePipelineManager.h", "gfx/layers/wr/WebRenderBridgeParent.cpp", "gfx/webrender_bindings/RenderCompositorANGLE.cpp", "gfx/webrender_bindings/RenderCompositorANGLE.h", "widget/windows/WinCompositorWidget.cpp", "widget/windows/WinCompositorWidget.h", "widget/windows/nsWindow.cpp", "widget/windows/nsWindowGfx.cpp"], "git_node": null, "git_parents": [null], "node": "3617fc291cc4087cb65f1f921cd63a5fe294439d", "parents": ["ace2e979811f1a196a79e0d90bbe9183a6321155"], "tags": []}, {"author": "Andrei Oprea \u003candrei.br92@gmail.com\u003e", "branch": "default", "desc": "Bug 1566505 - Update panel content when messages change r=andreio a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com//