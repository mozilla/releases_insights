ets": [{"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575208 - Fix partially hidden buttons in extension notification panels. r=dao, a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45684", "files": ["browser/components/customizableui/content/panelUI.inc.xul"], "git_node": null, "git_parents": [null], "node": "8058742d1138895a0f141a15af4589fc9eee9112", "parents": ["046074b8dd770cf62961623e2ca73de03de04678"], "tags": []}], "date": 1568571143, "git_changesets": [null], "user": "ntim.bugs@gmail.com"}, "11958": {"changesets": [{"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576889 - Ensure Quantum Bar Contextual Tip looks correct in RTL builds. r=dao. a=lizzard\n\nThe `padding-right` is the only oversight afaict. This patch is based on D45125.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45126", "files": ["browser/themes/shared/urlbar-autocomplete.inc.css"], "git_node": null, "git_parents": [null], "node": "73b1e46376d39da424761ed3c274f5e05ce91b0e", "parents": ["8058742d1138895a0f141a15af4589fc9eee9112"], "tags": []}, {"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576888 - Stop using px values for #urlbar-contextual-tip's and #urlbar-contextual-tip-button's font sizes. r=dao, a=lizzard\n\nMake #urlbar-contextual-tip inherit its font size so that it's the same as the size used for other results. Set #urlbar-contextual-tip-button's font to inherit.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45125", "files": ["browser/themes/shared/urlbar-autocomplete.inc.css"], "git_node": null, "git_parents": [null], "node": "57a4edf435a71b6a13c1217d81718391124cb2c7", "parents": ["73b1e46376d39da424761ed3c274f5e05ce91b0e"], "tags": []}], "date": 1568572294, "git_changesets": [null, null], "user": "ntim.bugs@gmail.com"}, "11959": {"changesets": [{"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1545924 - Make sure to never unhide the Picture-in-Picture toggle if the feature is disabled. r=JSON_voorhees a=lizzard\n\nThis patch centralizes the logic where the videocontrols UAWidget removes the\n\"hidden\" attribute from the Picture-in-Picture toggle, and makes sure we only\ndo this if the PiP toggle is enabled.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45196", "files": ["toolkit/content/widgets/videocontrols.js"], "git_node": null, "git_parents": [null], "node": "ceee9e2295669e3ba7cbd00ecab13e1af50361d3", "parents": ["57a4edf435a71b6a13c1217d81718391124cb2c7"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1548813 - Ensure cached mReplacementCharFallbackFamily is cleared if the font list is reinitialized. r=jrmuizel a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45347", "files": ["gfx/thebes/gfxPlatformFontList.cpp"], "git_node": null, "git_parents": [null], "node": "56a8e96ba56ce615507fa31dd8552d0b5ca2662b", "parents": ["ceee9e2295669e3ba7cbd00ecab13e1af50361d3"], "tags": []}, {"author": "Micah Tigley \u003cmtigley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1559428 - Create base Proxy card. r=ewright,fluent-reviewers,johannh,flod a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38558", "files": ["browser/app/profile/firefox.js", "browser/base/content/logos/proxy.svg", "browser/base/content/test/static/browser_parsable_script.js", "browser/base/jar.mn", "browser/components/about/AboutProtectionsHandler.jsm", "browser/components/protections/content/protections.css", "browser/components/protections/content/protections.ftl", "browser/components/protections/content/protections.html", "browser/components/protections/content/protections.js", "browser/components/protections/content/proxy-card.js", "browser/components/protections/jar.mn", "browser/components/protections/test/browser/browser.ini", "browser/components/protections/test/browser/browser_protections_proxy.js", "browser/locales/jar.mn", "toolkit/components/remotepagemanager/MessagePort.jsm"], "git_node": null, "git_parents": [null], "node": "7e4f97016b6054775ca9c84ddd34f5e642e0e6bb", "parents": ["56a8e96ba56ce615507fa31dd8552d0b5ca2662b"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1567384 - Set oneOffSearchButtons.textbox to UrlbarInput::inputField since there's no real textbox anymore. r=adw a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38677", "files": ["browser/components/urlbar/UrlbarView.jsm"], "git_node": null, "git_parents": [null], "node": "d9c4ede99bc12cbe6b7b8c3fc4ece00a13785abc", "parents": ["7e4f97016b6054775ca9c84ddd34f5e642e0e6bb"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1570645 - devtools panels registered by extension should provide an aria-label. r=jdescottes a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44677", "files": ["browser/components/extensions/parent/ext-devtools-panels.js", "browser/components/extensions/test/browser/browser_ext_devtools_panel.js"], "git_node": null, "git_parents": [null], "node": "d586c535354fab0eb451b693d778b71f61270cff", "parents": ["d9c4ede99bc12cbe6b7b8c3fc4ece00a13785abc"], "tags": []}, {"author": "Gerald Squelart \u003cgsquelart@mozilla.com\u003e", "branch": "default", "desc": "Bug 1571648 - Prevent OOMs from too many or too-big Decoder Doctor issues - r=bryce a=lizzard\n\nDecoderDoctorDiagnostics had no limitations on reported and stored issues.\n\nNew limitations, per document:\n- No more than 128 issues are kept at any time.\n- Issues older than 10 seconds are discarded.\n- Issues containing too-long text (more than 2048 characters) are ignored.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45480", "files": ["dom/media/doctor/DecoderDoctorDiagnostics.cpp"], "git_node": null, "git_parents": [null], "node": "621031e3cd33d1d7f8b2d8f82aada30661bb6be8", "parents": ["d586c535354fab0eb451b693d778b71f61270cff"], "tags": []}, {"author": "Daniel Holbert \u003cdholbert@cs.stanford.edu\u003e", "branch": "default", "desc": "Bug 1573631: Let \"text-decoration-skip-ink\", \"text-decoration-thickness\", and \"text-underline-offset\" ride the trains to release. r=jfkthame a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45233", "files": ["modules/libpref/init/StaticPrefList.yaml"], "git_node": null, "git_parents": [null], "node": "30491761865036fa42165a0ae37a8c2252553e83", "parents": ["621031e3cd33d1d7f8b2d8f82aada30661bb6be8"], "tags": []}, {"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1573751 - Fix geckoview nightly signing on try r=nalexander a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45037", "files": ["taskcluster/ci/build-fat-aar/kind.yml", "taskcluster/ci/build/kind.yml", "taskcluster/taskgraph/transforms/beetmover_geckoview.py", "taskcluster/taskgraph/transforms/build.py"], "git_node": null, "git_parents": [null], "node": "c6d28fba552176786cb5d836f60ab76718146fe4", "parents": ["30491761865036fa42165a0ae37a8c2252553e83"], "tags": []}, {"author": "Boris Chiou \u003cboris.chiou@gmail.com\u003e", "branch": "default", "desc": "Bug 1574222 - Tweak the serialization of text-decoration. r=emilio a=lizzard\n\nWe are trying to not serialize `text-decoration-line: none` if there are other\nnon-default values for the longhands.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44908", "files": ["servo/components/style/properties/shorthands/text.mako.rs", "testing/web-platform/meta/css/css-text-decor/__dir__.ini", "testing/web-platform/meta/css/css-text-decor/parsing/text-decoration-valid.html.ini", "testing/web-platform/meta/css/css-text-decor/text-decoration-thickness-001.html.ini", "testing/web-platform/meta/css/css-text-decor/text-decoration-thickness-computed.html.ini", "testing/web-platform/meta/css/css-text-decor/text-decoration-thickness-initial.html.ini", "testing/web-platform/meta/css/css-text-decor/text-decoration-thickness-invalid.html.ini", "testing/web-platform/meta/css/css-text-decor/text-decoration-thickness-linethrough-001.html.ini", "testing/web-platform/meta/css/css-text-decor/text-decoration-thickness-overline-001.html.ini", "testing/web-platform/meta/css/css-text-decor/text-decoration-thickness-scroll-001.html.ini", "testing/web-platform/meta/css/css-text-decor/text-decoration-thickness-underline-001.html.ini", "testing/web-platform/meta/css/css-text-decor/text-decoration-thickness-valid.html.ini", "testing/web-platform/meta/css/css-text-decor/text-decoration-thickness-vertical-001.html.ini", "testing/web-platform/meta/css/css-text-decor/text-decoration-thickness-vertical-002.html.ini"], "git_node": null, "git_parents": [null], "node": "b84d2fe2d2a8b0f7815bb494a22d46ea9d6b6c66", "parents": ["c6d28fba552176786cb5d836f60ab76718146fe4"], "tags": []}, {"author": "Boris Chiou \u003cboris.chiou@gmail.com\u003e", "branch": "default", "desc": "Bug 1574222 - Serialize getComputedStyle on text-decoration properly. r=emilio,dholbert a=lizzard\n\nThe wpt will be updated in\nhttps://github.com/web-platform-tests/wpt/pull/18866.\n\nBesides, there are some other test cases use text-decoration, so we\nhave to update them as well. The rule is: if the test case is not related to\nold `text-decoration` longhand, we use `text-decoration-line` instead.\nIf the test case is for testing the change of `text-decoration` from\nlonghand to shorthand, we should use the correct serialization.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44909", "files": ["devtools/client/inspector/rules/test/browser_rules_pseudo-element_01.js", "dom/smil/test/db_smilCSSFromTo.js", "dom/smil/test/db_smilCSSPropertyList.js", "dom/smil/test/db_smilMappedAttrList.js", "layout/style/nsComputedDOMStyle.cpp", "layout/style/nsComputedDOMStyle.h", "layout/style/test/bug453896_iframe.html", "layout/style/test/chrome/test_display_mode.html", "layout/style/test/test_any_dynamic.html", "layout/style/test/test_bug437915.html", "layout/style/test/test_bug534804.html", "layout/style/test/test_bug652486.html", "layout/style/test/test_bug73586.html", "layout/style/test/test_media_queries.html", "layout/style/test/test_media_queries_dynamic.html", "layout/style/test/test_rule_insertion.html", "layout/style/test/test_supports_rules.html", "testing/web-platform/meta/css/css-text-decor/parsing/text-decoration-computed.html.ini", "testing/web-platform/meta/css/css-text-decor/text-decoration-serialization.tentative.html.ini", "testing/web-platform/meta/css/css-variables/variable-presentation-attribute.html.ini", "testing/web-platform/meta/editing/run/strikethrough.html.ini", "testing/web-platform/meta/editing/run/underline.html.ini"], "git_node": null, "git_parents": [null], "node": "c5e6986c6cead088c8616ca778cb91044ee8cae1", "parents": ["b84d2fe2d2a8b0f7815bb494a22d46ea9d6b6c66"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575271 - Add crashtest. r=karlt a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45194", "files": ["dom/media/test/crashtests/1575271.html", "dom/media/test/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "7a2c20bfec7270f0de82701d23d39d97e7822338", "parents": ["c5e6986c6cead088c8616ca778cb91044ee8cae1"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575271 - Keep a SharedDummyStream in MediaEncoder for access to the MediaStreamGraph. r=karlt a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45195", "files": ["dom/media/encoder/MediaEncoder.cpp", "dom/media/encoder/MediaEncoder.h"], "git_node": null, "git_parents": [null], "node": "705b2a73e8f4a35ffebbc38bc8bbd02968dd1040", "parents": ["7a2c20bfec7270f0de82701d23d39d97e7822338"], "tags": []}], "date": 1568589291, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "apavel@mozilla.com"}, "11960": {"changesets": [{"author": "Brendan Dahl \u003cbrendan.dahl@gmail.com\u003e", "branch": "default", "desc": "Bug 1575620 - Fix refreshing session restore when using prototype cache. r=smaug a=lizzard\n\nThe session restore page keeps its restore list within a text input field\nso that the values are persisted even if the page is refreshed. When form\nelements were loaded with the prototype cache we didn't call\nDoneCreatingElement after creating the element, which means the form values\nweren't restored.\n\nThe list of elements that require DoneCreatingElement and DoneAddingChildren\nto be called was in three (now four) different places, so I moved them to\na central spot in nsIContent to share in all locations. This also highlighted\nthat the check for \u003coutput\u003e nodes is missing from the XML content sink.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44866", "files": ["dom/base/nsIContent.h", "dom/prototype/PrototypeDocumentContentSink.cpp", "dom/prototype/tests/chrome/chrome.ini", "dom/prototype/tests/chrome/form.xhtml", "dom/prototype/tests/chrome/test_prototype_document.xhtml", "dom/xml/nsXMLContentSink.cpp", "dom/xslt/xslt/txMozillaXMLOutput.cpp", "parser/html/nsHtml5TreeBuilderCppSupplement.h"], "git_node": null, "git_parents": [null], "node": "97141a6413d806d4ffc6faf29e43ece065e52126", "parents": ["705b2a73e8f4a35ffebbc38bc8bbd02968dd1040"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575820 - The \"First Run Triplets\" are not displayed on the first tab opened after logging in to \"Firefox Sync\" r=pdahiya a=lizzard\n\nhttps://github.com/mozilla/activity-stream/commit/104659d936ab4b2804ae873fb0fef6c5ddda9d4d\n\nDifferential Revision: https://phabricator.services.mozilla.com//D45610", "files": ["browser/components/newtab/lib/ASRouter.jsm"], "git_node": null, "git_parents": [null], "node": "f910d35d9d84c37ad9fa1a7b2950c368eb62cb1c", "parents": ["97141a6413d806d4ffc6faf29e43ece065e52126"], "tags": []}, {"author": "Neil Deakin \u003cneil@mozilla.com\u003e", "branch": "default", "desc": "Bug 1577388, use the top browser when receiving zoom messages, r=mconley a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45178", "files": ["toolkit/actors/ZoomParent.jsm"], "git_node": null, "git_parents": [null], "node": "eacb80079f3be6f682d810d416523880163aa416", "parents": ["f910d35d9d84c37ad9fa1a7b2950c368eb62cb1c"], "tags": []}, {"author": "Brian Hackett \u003cbhackett1024@gmail.com\u003e", "branch": "default", "desc": "Bug 1577881 - Watch out for dead windows in getAllWindowDebuggees, r=ochameau. a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45114", "files": ["devtools/server/actors/utils/event-loop.js"], "git_node": null, "git_parents": [null], "node": "1f9a07afed3e0a7ff232e987e254cc2b8fa19390", "parents": ["eacb80079f3be6f682d810d416523880163aa416"], "tags": []}, {"author": "Tim Huang \u003ctihuang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1578051 - Apply hovering effect on the info button if it gets tab focus. r=nhnt11 a=lizzard\n\nBy adding a ':-moz-focusring' on the info button.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45313", "files": ["browser/themes/shared/controlcenter/panel.inc.css"], "git_node": null, "git_parents": [null], "node": "d2cdf3047932e3986b7129ee94497834f3297f80", "parents": ["1f9a07afed3e0a7ff232e987e254cc2b8fa19390"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1578341 - MultipartBlobImpl must exclude empty Blobs when creating the inputStream, r=smaug a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44849", "files": ["dom/file/MultipartBlobImpl.cpp"], "git_node": null, "git_parents": [null], "node": "c01fbb5b691d1c7268f775c1ad812a962d0dc2ee", "parents": ["d2cdf3047932e3986b7129ee94497834f3297f80"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1578715 - Increase urlbarView's z-index. r=adw a=lizzard\n\nThis is the same value we now use for the megabar: https://searchfox.org/mozilla-central/rev/878bbf3cb8897a208454df27535f3522ab482cf2/browser/themes/shared/urlbar-searchbar.inc.css#118\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45823", "files": ["browser/themes/shared/urlbar-autocomplete.inc.css"], "git_node": null, "git_parents": [null], "node": "259a6f1dfb07717cd4fa528c744fc28025898e62", "parents": ["c01fbb5b691d1c7268f775c1ad812a962d0dc2ee"], "tags": []}, {"author": "Dragana Damjanovic \u003cdd.mozilla@gmail.com\u003e", "branch": "default", "desc": "Bug 1579047 - _NS_NEXT_TOKEN in the wrong place. r=Ehsan a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44816", "files": ["netwerk/protocol/http/AlternateServices.cpp"], "git_node": null, "git_parents": [null], "node": "a6ea7c1d4cd28bb46e57bebef5d9eb3042b1a510", "parents": ["259a6f1dfb07717cd4fa528c744fc28025898e62"], "tags": []}, {"author": "Daosheng Mu \u003cdaoshengmu@gmail.com\u003e", "branch": "default", "desc": "Bug 1579492 - Check if nullptr in DarwinGamepadService::ReportChangedCallback(). r=baku a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45135", "files": ["dom/gamepad/cocoa/CocoaGamepad.cpp"], "git_node": null, "git_parents": [null], "node": "f54c0cf514bf10e955b2dbb5f5435d1532907bb1", "parents": ["a6ea7c1d4cd28bb46e57bebef5d9eb3042b1a510"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1579526 - Allow deviceId and groupId constraints for privileged getDisplayMedia callers. r=jib a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45175", "files": ["dom/media/MediaManager.cpp"], "git_node": null, "git_parents": [null], "node": "64d8ad1c9962c4ac33a759061d0eacc7a7d5aab8", "parents": ["f54c0cf514bf10e955b2dbb5f5435d1532907bb1"], "tags": []}], "date": 1568591933, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "aciure@mozilla.com"}, "11961": {"changesets": [{"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1578494 - when checking for mouse only interactivity, add additional checks for text leafs and showlongdesc actions. r=nchevobbe a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44868", "files": ["devtools/server/actors/accessibility/audit/keyboard.js", "devtools/server/tests/browser/browser_accessibility_keyboard_audit.js", "devtools/server/tests/browser/doc_accessibility_keyboard_audit.html"], "git_node": null, "git_parents": [null], "node": "ce4d6d3f06be567ad6ea8730337dd14aeb33bf99", "parents": ["64d8ad1c9962c4ac33a759061d0eacc7a7d5aab8"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1578494 - include ROLE_PARENT_MENUITEM (currently selected/visible menu item) into a set of interactive roles. r=nchevobbe a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45214", "files": ["devtools/server/actors/accessibility/audit/keyboard.js"], "git_node": null, "git_parents": [null], "node": "a063c314523cbd49249b0049e7104ff13f0fad9d", "parents": ["ce4d6d3f06be567ad6ea8730337dd14aeb33bf99"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1578494 - separate accessible roles into the ones that are expected to be interactive from keyboard accessible ones, better account for ARIA comboboxes and listboxes. r=nchevobbe a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45215", "files": ["devtools/server/actors/accessibility/audit/keyboard.js", "devtools/server/tests/browser/browser_accessibility_keyboard_audit.js", "devtools/server/tests/browser/doc_accessibility_keyboard_audit.html"], "git_node": null, "git_parents": [null], "node": "dc043d2b3346abb16b99bc59a1291397bba55f30", "parents": ["a063c314523cbd49249b0049e7104ff13f0fad9d"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1578494 - ignore valid labels with \"label for\" relations as they are clickable. r=nchevobbe a=lizzard\n\nDepends on D45215\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45216", "files": ["devtools/server/actors/accessibility/audit/keyboard.js", "devtools/server/tests/browser/browser_accessibility_keyboard_audit.js", "devtools/server/tests/browser/doc_accessibility_keyboard_audit.html"], "git_node": null, "git_parents": [null], "node": "478dc85c82560d9aafdf9c92d851495699286549", "parents": ["dc043d2b3346abb16b99bc59a1291397bba55f30"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1578494 - ignore images inside anchors for semantic check as they get a propagated jump action. r=nchevobbe a=lizzard\n\nDepends on D45216\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45217", "files": ["devtools/server/actors/accessibility/audit/keyboard.js", "devtools/server/tests/browser/browser_accessibility_keyboard_audit.js", "devtools/server/tests/browser/doc_accessibility_keyboard_audit.html"], "git_node": null, "git_parents": [null], "node": "8e115a255dfa77c9d777c73724597800cecdf2c2", "parents": ["478dc85c82560d9aafdf9c92d851495699286549"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1578494 - make MOUSE_INTERACTIVE_ONLY failure check less strict and only look at click action. r=nchevobbe a=lizzard\n\nDepends on D45217\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45218", "files": ["devtools/server/actors/accessibility/audit/keyboard.js", "devtools/server/tests/browser/browser_accessibility_keyboard_audit.js", "devtools/server/tests/browser/doc_accessibility_keyboard_audit.html"], "git_node": null, "git_parents": [null], "node": "12c12e936df158a45fb317e6d4d9be29d59f9c7c", "parents": ["8e115a255dfa77c9d777c73724597800cecdf2c2"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1579767: Reinstate the accessibility group role for the search one-offs container. r=dao a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45151", "files": ["browser/components/search/content/search-one-offs.js"], "git_node": null, "git_parents": [null], "node": "a86e16a48e8c10e8dcada34e95c8ec8d7e2b7b8e", "parents": ["12c12e936df158a45fb317e6d4d9be29d59f9c7c"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1579794 - [Wayland] Copy pixel data for cached images, r=jhorak a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45165", "files": ["widget/gtk/WindowSurfaceWayland.cpp", "widget/gtk/WindowSurfaceWayland.h"], "git_node": null, "git_parents": [null], "node": "938228e585ebd97f96f5134c09e53bb81224964c", "parents": ["a86e16a48e8c10e8dcada34e95c8ec8d7e2b7b8e"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1579794 - [Wayland] Use wl_surface_damage_buffer() and require wl_compositor v.4, r=jhorak a=lizzard\n\nUse wl_surface_damage_buffer() to propagate wl_buffer damage to avoid rounding errors and\nrendering artifacts for HiDPI wl_buffers.\n\nDepends on D45165\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45166", "files": ["widget/gtk/WindowSurfaceWayland.cpp", "widget/gtk/WindowSurfaceWayland.h", "widget/gtk/mozcontainer.cpp", "widget/gtk/mozwayland/mozwayland.c", "widget/gtk/mozwayland/mozwayland.h", "widget/gtk/nsWaylandDisplay.cpp", "widget/gtk/nsWaylandDisplay.h"], "git_node": null, "git_parents": [null], "node": "005bb5c002cc955429b83a0e03d31109c3528619", "parents": ["938228e585ebd97f96f5134c09e53bb81224964c"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1579794 - [Wayland] Explicitly enable/disable direct rendering to wl_buffer, r=jhorak a=lizzard\n\nRecently direct wl_buffer rendering is kept enabled until we have wl_buffer available which\nproduces rendering artifacts when screen damage rects overlaps.\n\nLet's enable/disable it explicitly at every rendering cycle start to avoid\nscreen flickering.\n\nDepends on D45166\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45167", "files": ["widget/gtk/WindowSurfaceWayland.cpp"], "git_node": null, "git_parents": [null], "node": "172128453e54d529157a19b2fa5a7aa6c3967b9e", "parents": ["005bb5c002cc955429b83a0e03d31109c3528619"], "tags": []}, {"author": "Sam Foster \u003csfoster@mozilla.com\u003e", "branch": "default", "desc": "Bug 1579539 - Part 1: Share some form test helpers. r=MattN a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45238", "files": ["toolkit/components/passwordmgr/test/browser/browser_private_window.js", "toolkit/components/passwordmgr/test/browser/head.js"], "git_node": null, "git_parents": [null], "node": "d721fafad8efb65c15b3f33cca7035ea1950ba55", "parents": ["172128453e54d529157a19b2fa5a7aa6c3967b9e"], "tags": []}, {"author": "Sam Foster \u003csfoster@mozilla.com\u003e", "branch": "default", "desc": "Bug 1579539 - Part 2: Always provide autoSavedLoginGuid to promptToChangePassword when available. r=MattN a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45250", "files": ["toolkit/components/passwordmgr/LoginManagerParent.jsm", "toolkit/components/passwordmgr/test/browser/browser_generated_password_doorhangers.js", "toolkit/components/passwordmgr/test/formsubmit.sjs"], "git_node": null, "git_parents": [null], "node": "dd9d0ae5222a09c2a66e68794852703b58e2a4f0", "parents": ["d721fafad8efb65c15b3f33cca7035ea1950ba55"], "tags": []}, {"author": "Erica Wright \u003cewright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1580002 - Hide automatically scanned message when user is not subscribed to Monitor r=johannh a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45430", "files": ["browser/components/protections/content/protections.css"], "git_node": null, "git_parents": [null], "node": "8da82db17cfdb427e10463a746ce53d30d46fcd0", "parents": ["dd9d0ae5222a09c2a66e68794852703b58e2a4f0"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1580822 - a11y focus lost when selecting the first one-off search button or the search settings button. r=adw a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45692", "files": ["accessible/tests/browser/events/browser_test_focus_urlbar.js", "browser/components/search/content/search-one-offs.js"], "git_node": null, "git_parents": [null], "node": "fa69c8d6b28ba958ee2a5106795adefb99707cc1", "parents": ["8da82db17cfdb427e10463a746ce53d30d46fcd0"], "tags": []}, {"author": "Tim Huang \u003ctihuang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1580106 - Fixing the hovering color issue for the toolbarbutton in general on the protections panel on Linux. r=nhnt11 a=lizzard\n\nThis patch overrides the color of the toolbarbutton in general on\nthe protections panel on Linux for :hover and :hover:active\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45312", "files": ["browser/themes/linux/controlcenter/panel.css"], "git_node": null, "git_parents": [null], "node": "c86ad828ec2a0a0cc25c3d9cf43e7dba93a1c61b", "parents": ["fa69c8d6b28ba958ee2a5106795adefb99707cc1"], "tags": []}, {"author": "alwu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1580015 - part1 : do not reentry function 'processCues()'. r=heycam a=lizzard\n\nAccessing `offsetXXX` attributes of element, it would trigger reflow, and sometime it would result in a re-entry of `processCue()` because we would call `processCue()` when `resizecaption` occurs.\n\nOne specifical case is that, assigning CSS properties `min-width` and `max-width` at the same video element, in thise case, when we re-enter the `processCues()` and access `offsetXXX`. It seems that the layout system would reprocess those properites again and again and dispatch `resizecaption` when we access `offsetXXX`, which causes an infinite loop, starting from receving `resizecaption`, then calling `processCue()`, accessing `offSetXXX`, triggering reflow, sending `resizecaption` event again.\n\nTherefore, we should stop revisiting `processCues()` if we're already running a processing, we should run a processing once at a time.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45421", "files": ["dom/media/webvtt/vtt.jsm"], "git_node": null, "git_parents": [null], "node": "729169db4c46af7873089cb475c1620f63164f9f", "parents": ["c86ad828ec2a0a0cc25c3d9cf43e7dba93a1c61b"], "tags": []}, {"author": "alwu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1580015 - part2 : add test 'test_webvtt_infinite_processing_loop.html'. r=heycam a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45567", "files": ["dom/media/test/mochitest.ini", "dom/media/test/test_webvtt_infinite_processing_loop.html"], "git_node": null, "git_parents": [null], "node": "11d82c1441524922cbfaaa0464571a16cf4e9a8b", "parents": ["729169db4c46af7873089cb475c1620f63164f9f"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1580871 - Enable editor mode in DevEdition. r=Honza. a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45682", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "a32faba2e5e601fe9cf0f702a8b8be18444ff8ea", "parents": ["11d82c1441524922cbfaaa0464571a16cf4e9a8b"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1546984 - Add scroll restoration to about:addons r=mstriemer a=lizzard\n\n- Attach scroll offsets to history entries in about:addons.\n\n- For other views, start at the top of the page, regardless of the\n  scroll position of the (likely unrelated) previous view.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44826", "files": ["toolkit/mozapps/extensions/content/aboutaddons.js", "toolkit/mozapps/extensions/content/extensions.js", "toolkit/mozapps/extensions/test/browser/browser.ini", "toolkit/mozapps/extensions/test/browser/browser_html_scroll_restoration.js"], "git_node": null, "git_parents": [null], "node": "d45c3cd5b904bf59827b0d92949ceddf5eb6658a", "parents": ["a32faba2e5e601fe9cf0f702a8b8be18444ff8ea"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1578330 - Call GetBufferSize after BeginFrame because RenderCompositorANGLE mutates it in BeginFrame. r=mattwoodrow a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45143", "files": ["gfx/webrender_bindings/RendererOGL.cpp"], "git_node": null, "git_parents": [null], "node": "a7f28a80e29544e2546633b87bfd8501f9f3459a", "parents": ["d45c3cd5b904bf59827b0d92949ceddf5eb6658a"], "tags": []}], "date": 1568602575, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "opoprus@mozilla.com"}, "11962": {"changesets": [{"author": "Francesco Lodolo (:flod) \u003cflod@lodolo.net\u003e", "branch": "default", "desc": "Bug 1579730 -