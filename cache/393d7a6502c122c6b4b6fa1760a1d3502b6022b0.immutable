b/test/unit/lib/ActivityStream.test.js", "browser/components/newtab/test/unit/utils.js"], "git_node": null, "git_parents": [null], "node": "dc09238320eeabefc7eb37f696a4c24c026d7c24", "parents": ["322f9a02cb0ae085cce26938b5980fd76039b36e"], "tags": []}], "date": 1569404880, "git_changesets": [null, null], "user": "dvarga@mozilla.com"}, "12042": {"changesets": [{"author": "Matthew Noorenberghe \u003cmozilla@noorenberghe.ca\u003e", "branch": "default", "desc": "Bug 1550631 - Record telemetry for direct navigation to about:logins. r=jaws a=lizzard\n\nAlso remove empty `filter` query params.\n\nDifferential Revision: https://phabricator.services.mozilla.com//D46551", "files": ["browser/components/aboutlogins/AboutLoginsChild.jsm", "browser/components/aboutlogins/content/aboutLogins.js", "browser/components/aboutlogins/tests/browser/browser_aaa_eventTelemetry_run_first.js", "browser/components/preferences/in-content/tests/browser_password_management.js", "testing/mochitest/BrowserTestUtils/BrowserTestUtils.jsm", "toolkit/components/passwordmgr/LoginHelper.jsm", "toolkit/components/passwordmgr/test/LoginTestUtils.jsm", "toolkit/components/passwordmgr/test/browser/browser_autocomplete_footer.js", "toolkit/components/passwordmgr/test/browser/browser_context_menu.js", "toolkit/components/passwordmgr/test/browser/browser_entry_point_telemetry.js", "toolkit/components/passwordmgr/test/browser/browser_openPasswordManager.js", "toolkit/components/passwordmgr/test/browser/head.js", "toolkit/components/telemetry/Events.yaml", "toolkit/components/telemetry/tests/utils/TelemetryTestUtils.jsm"], "git_node": null, "git_parents": [null], "node": "5e82e67a1c66a54c7514ffd71f6111b1795762ab", "parents": ["dc09238320eeabefc7eb37f696a4c24c026d7c24"], "tags": []}, {"author": "Matthew Noorenberghe \u003cmozilla@noorenberghe.ca\u003e", "branch": "default", "desc": "Bug 1550631 - Include the entryPoint for navigations from about:protections to about:logins. r=jaws a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com//D46630\n\nDepends on D46551", "files": ["browser/components/about/AboutProtectionsHandler.jsm", "browser/components/protections/content/monitor-card.js", "browser/components/protections/content/protections.html", "browser/components/protections/test/browser/browser_protections_telemetry.js", "toolkit/components/telemetry/Events.yaml"], "git_node": null, "git_parents": [null], "node": "84476e00997cd01e99510b53405b2cb30cc2fe68", "parents": ["5e82e67a1c66a54c7514ffd71f6111b1795762ab"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1583052 - Remove an optimization introduced in bug 1555946 which is not sound. r=smaug a=lizzard\n\nTasks dispatched from RunInStableState() can be cancelled if there's a load in\nbetween, so this is not sound.\n\nSee nsSyncSection::IsCancelled().\n\nThis is the only patch in this bug that is worth uplifting IMO.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46773", "files": ["dom/html/HTMLMediaElement.cpp", "dom/html/HTMLMediaElement.h", "testing/web-platform/tests/html/semantics/embedded-content/media-elements/playing-the-media-resource/pause-remove-from-document-different-load.html"], "git_node": null, "git_parents": [null], "node": "4a7f82e133c7f742114d3b46219fda316b5c40e7", "parents": ["84476e00997cd01e99510b53405b2cb30cc2fe68"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1583052 - Don't null-check OwnerDoc() in HTMLMediaElement.cpp. r=smaug a=lizzard\n\nIt can never return null.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46774", "files": ["dom/html/HTMLMediaElement.cpp"], "git_node": null, "git_parents": [null], "node": "dc41cb4c0b3b094192f6b451f34c166c712b0064", "parents": ["4a7f82e133c7f742114d3b46219fda316b5c40e7"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1583052 - Fix a check which really wants composed doc semantics, not uncomposed. r=smaug a=lizzard\n\nI don't know why it'd want uncomposed doc semantics.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46775", "files": ["dom/html/HTMLMediaElement.cpp"], "git_node": null, "git_parents": [null], "node": "a5194d004bc2770243a4360dba5273957a3cb68a", "parents": ["dc41cb4c0b3b094192f6b451f34c166c712b0064"], "tags": []}], "date": 1569406101, "git_changesets": [null, null, null, null, null], "user": "dvarga@mozilla.com"}, "12043": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\ncy -\u003e e04ebc71c42e\nnn-NO -\u003e 045945d55f29", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "ba29ab45f1f056858ec80c7be8bedeae9ccb1ac6", "parents": ["a5194d004bc2770243a4360dba5273957a3cb68a"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\ncy -\u003e e04ebc71c42e\nnn-NO -\u003e 045945d55f29", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "27d3f22ee1be2611b8c4ae5074a4865635d43218", "parents": ["ba29ab45f1f056858ec80c7be8bedeae9ccb1ac6"], "tags": []}], "date": 1569412840, "git_changesets": [null, null], "user": "ffxbld"}, "12044": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1578700 - Rename a variable to better follow our coding style. r=smaug a=RyanVM\n\nIt's a constant, not a global. This matches both the Mozilla and Google coding\nstyles so should hopefully be uncontroversial.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44643", "files": ["dom/base/Document.cpp"], "git_node": null, "git_parents": [null], "node": "84589f69c57b55729d932ce6c06ba853c7cfd5e0", "parents": ["27d3f22ee1be2611b8c4ae5074a4865635d43218"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1578700 - Simplify SetDocumentUseCounter. r=smaug a=RyanVM\n\nIt's just a bit flag, should be no need of checking whether the bit is set\nbefore.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44644", "files": ["dom/base/Document.h"], "git_node": null, "git_parents": [null], "node": "cbb2a9654a653c4c825eb42a926654d4ccf7359f", "parents": ["84589f69c57b55729d932ce6c06ba853c7cfd5e0"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1578700 - Change use counter setup to propagate the page use counters together. r=smaug a=RyanVM\n\nThis is so that SetUseCounter is as cheap as possible.\n\nThis is in preparation for hooking the CSS use counters to telemetry. We want\nCSS use counters to be fast and be propagated at once to the parent page. This\nwill make sure to use the same setup as everywhere else.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44645", "files": ["dom/base/Document.cpp", "dom/base/Document.h", "dom/base/Navigator.cpp", "dom/base/UseCounters.conf", "dom/bindings/BindingUtils.cpp", "dom/bindings/BindingUtils.h", "dom/bindings/Codegen.py", "dom/events/EventListenerManager.cpp", "dom/html/nsHTMLDocument.h", "dom/media/MediaDevices.cpp", "dom/svg/SVGElement.cpp", "js/xpconnect/src/XPCJSRuntime.cpp", "layout/generic/nsSubDocumentFrame.cpp"], "git_node": null, "git_parents": [null], "node": "2d698478059cd1222fed66015acd22589d092d99", "parents": ["cbb2a9654a653c4c825eb42a926654d4ccf7359f"], "tags": []}, {"author": "Landry Breuil \u003clandry@openbsd.org\u003e", "branch": "default", "desc": "Bug 1579323 - Reenable sandbox by default on OpenBSD r=froydnj a=RyanVM\n\nThis was broken by bug 1375863", "files": ["old-configure.in"], "git_node": null, "git_parents": [null], "node": "e0b6137d8d2e6a17367c1516418e3a9a506a73ea", "parents": ["2d698478059cd1222fed66015acd22589d092d99"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1578661 - Remove old CSS use counters. r=boris a=lizzard\n\nWe only have two counters enabled, just for testing, and they just count from\nthe SVG mapped attribute code. That's not great, and they mostly complicate the\nnext few patches.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44695", "files": ["dom/base/UseCounter.h", "dom/base/UseCounters.conf", "dom/base/gen-usecounters.py", "dom/base/moz.build", "dom/base/usecounters.py", "dom/svg/SVGElement.cpp", "layout/style/nsCSSProps.cpp", "layout/style/nsCSSProps.h", "toolkit/components/telemetry/docs/collection/use-counters.rst"], "git_node": null, "git_parents": [null], "node": "6de47c2961fd341c57dc200194c405c762bb70f5", "parents": ["e0b6137d8d2e6a17367c1516418e3a9a506a73ea"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1578661 - Add telemetry histograms for all CSS properties. r=chutten,boris a=lizzard\n\nAnd add them to the UseCounter enum. Also add some sanity-check assertions that\nthe reporting code relies on.\n\nThis works much like the deprecated operation list.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44696", "files": ["config/recurse.mk", "dom/base/Document.cpp", "dom/base/UseCounter.h", "toolkit/components/telemetry/build_scripts/mozparsers/parse_histograms.py", "toolkit/components/telemetry/moz.build"], "git_node": null, "git_parents": [null], "node": "eca2be54980c6ef39bad499a944676ef7b4e708c", "parents": ["6de47c2961fd341c57dc200194c405c762bb70f5"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1578661 - Fix use counter test. r=boris a=lizzard\n\nBy reporting the properties in MappedAttrParser that we used to (the test relies\non counting those), and by adjusting the histogram name to the new thing.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44697", "files": ["dom/base/test/browser_use_counters.js", "dom/svg/SVGElement.cpp", "layout/style/nsCSSProps.h"], "git_node": null, "git_parents": [null], "node": "c97de3fc66fa4a11693eda7d9f4668e45ff9d790", "parents": ["eca2be54980c6ef39bad499a944676ef7b4e708c"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1578661 - Merge the stylesheet use counters, report them, and add tests. r=boris a=lizzard\n\nC'est fini. Now to do the same with the unimplemented ones remains, but it\nshould be straight-forward.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44698", "files": ["dom/base/Document.cpp", "dom/base/Document.h", "dom/base/test/browser.ini", "dom/base/test/browser_use_counters.js", "dom/base/test/file_use_counter_style.html", "servo/ports/geckolib/glue.rs"], "git_node": null, "git_parents": [null], "node": "47ceb74a4061cf6878b4bce13055a1a1c3177d64", "parents": ["c97de3fc66fa4a11693eda7d9f4668e45ff9d790"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1578661 - Add telemetry histograms for unknown counted CSS properties. r=chutten a=lizzard\n\nThis adds histograms for the stuff added in bug 1575062, which is needed for the\nwebcompat metrics project.\n\nThis also tweaks the naming to be consistent across all CSS properties. Normally\nthe method is just equivalent to the camel_case thing except for:\n\n * The css float property, whose method is CssFloat.\n * Internal properties (but we don't count those anyway).\n\nThis is so that we get consistent usage data if we ever implement some of those\nproperties.\n\nI had to increase the PHF table size to make build times sane again (for some\nreason adding the \"d\" property in there blows up the phf map generation time).\n\nBut according to Nika the binary size impact of that change is minimal /\nirrelevant:\n\n  https://mozilla.logbot.info/content/20190904#c16590376\n\nSo I think it should be fine.\nchance\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44716", "files": ["toolkit/components/telemetry/build_scripts/gen_histogram_phf.py", "toolkit/components/telemetry/build_scripts/mozparsers/parse_histograms.py", "toolkit/components/telemetry/moz.build"], "git_node": null, "git_parents": [null], "node": "60e8eaaf1ccc2991ba093bd625122576e72c66be", "parents": ["47ceb74a4061cf6878b4bce13055a1a1c3177d64"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1578661 - Report counted unknown properties as well. r=boris a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44717", "files": ["dom/base/Document.cpp", "dom/base/UseCounter.h", "dom/base/test/browser_use_counters.js", "dom/base/test/file_use_counter_style.html", "layout/style/GenerateCountedUnknownProperties.py", "layout/style/moz.build", "layout/style/nsCSSPropertyID.h.in", "servo/components/style/properties/properties.mako.rs", "servo/ports/geckolib/cbindgen.toml", "servo/ports/geckolib/glue.rs"], "git_node": null, "git_parents": [null], "node": "009960ce4b910493d3721c0997b23d9b3c34aae6", "parents": ["60e8eaaf1ccc2991ba093bd625122576e72c66be"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1578661 - Deduplicate a bit the code to add use counters for a CSS property. r=chutten a=lizzard\n\nJust some minor cleanup while I think on how to best integrate this with\nprobe-scraper.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45927", "files": ["toolkit/components/telemetry/build_scripts/mozparsers/parse_histograms.py"], "git_node": null, "git_parents": [null], "node": "21cbbd68b02cf7672ed3e00008f253d872ac0ea3", "parents": ["009960ce4b910493d3721c0997b23d9b3c34aae6"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1578661 - Add static_assert messages for use counter assertions. r=boris a=lizzard\n\nThis was a review comment which was easier to address as a separate patch.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45928", "files": ["dom/base/Document.cpp"], "git_node": null, "git_parents": [null], "node": "ebb670c31f5d5ce018bb7216a6817fedd21776b5", "parents": ["21cbbd68b02cf7672ed3e00008f253d872ac0ea3"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1578661 - Add a note about CSS use counters to the documentation. r=chutten a=lizzard\n\nNot sure how much detail does it need (it just works) but suggestions welcome.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45929", "files": ["toolkit/components/telemetry/docs/collection/use-counters.rst"], "git_node": null, "git_parents": [null], "node": "0c69c60a5aa2eff6a0f11c24bf2da59ab1e03b8b", "parents": ["ebb670c31f5d5ce018bb7216a6817fedd21776b5"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1578661 - Add a crappy histogram parser for the devtools database, for probe-scraper. r=chutten a=lizzard\n\n(And test it.)\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46111", "files": ["toolkit/components/telemetry/build_scripts/mozparsers/parse_histograms.py", "toolkit/components/telemetry/tests/python/test_histogramtools_non_strict.py"], "git_node": null, "git_parents": [null], "node": "1ebe47575917fe2a50b3ce4ae63114e050507b6e", "parents": ["0c69c60a5aa2eff6a0f11c24bf2da59ab1e03b8b"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1582814 - Let the CSS use counter prefs be independent. r=boris a=lizzard\n\n* Let layout.css.use-counters.enabled be independent from the unimplemented\n   property counters.\n\n * Always count in the style system (that is, always create\n   Document::mStyleUseCounters), so that the warning from bug 1582374 works\n   irrespective of these prefs.\n\n * Add a pref check to the SVGElement code path so that the prefs properly\n   reflect whether the histograms end up being recorded or not.\n\n * Make the pref checks consistent (check both when reporting telemetry, not\n   earlier).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46633", "files": ["dom/base/Document.cpp", "dom/svg/SVGElement.cpp", "layout/style/test/test_use_counters.html", "modules/libpref/init/StaticPrefList.yaml", "servo/components/style/properties/properties.mako.rs"], "git_node": null, "git_parents": [null], "node": "4bb822c2a23a15479e0a7e8dbc15245367e4239a", "parents": ["1ebe47575917fe2a50b3ce4ae63114e050507b6e"], "tags": []}], "date": 1569424542, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "12045": {"changesets": [{"author": "Dylan Roeh \u003cdroeh@mozilla.com\u003e", "branch": "default", "desc": "Allow blocking level 1 ETP lists in GV. r=geckoview-reviewers,snorp,agi a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45709", "files": ["mobile/android/geckoview/api.txt", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/ContentBlocking.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/doc-files/CHANGELOG.md", "mobile/android/geckoview_example/src/main/java/org/mozilla/geckoview_example/GeckoViewActivity.java"], "git_node": null, "git_parents": [null], "node": "7c06b6bd6c08b9481a89b41289586d2720540d94", "parents": ["4bb822c2a23a15479e0a7e8dbc15245367e4239a"], "tags": []}], "date": 1569426835, "