branch": "default", "desc": "No bug - Unset EARLY_BETA_OR_EARLIER. a=RyanVM", "files": ["build/defines.sh"], "git_node": null, "git_parents": [null], "node": "b9b3e10bc8fcd8c3bff7bc50a73ff950bd5e60f1", "parents": ["b1c6524d0b2b68f7004ab445ac63f9808852ae92"], "tags": []}], "date": 1568825694, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "11982": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\ndsb -\u003e 2202f34d92ae\ngn -\u003e c3577c7b6a05\nhsb -\u003e 1d282e2af986\nhu -\u003e 0f604a114142\nnb-NO -\u003e 1d376c336f33\npt-BR -\u003e 69f5af467b0f\nsl -\u003e 89bcdae106d1\nzh-TW -\u003e 4699d5480b3f", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "1969376bf14635b3e2ca2dc9e78d3f578ff34c68", "parents": ["b9b3e10bc8fcd8c3bff7bc50a73ff950bd5e60f1"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\ndsb -\u003e 2202f34d92ae\ngn -\u003e c3577c7b6a05\nhsb -\u003e 1d282e2af986\nhu -\u003e 0f604a114142\nia -\u003e 151283df2d38\nnb-NO -\u003e 1d376c336f33\npt-BR -\u003e 69f5af467b0f\nsl -\u003e 89bcdae106d1\nzh-TW -\u003e 4699d5480b3f", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "4f444a466695ff88f51a45f08e947c25f5616efa", "parents": ["1969376bf14635b3e2ca2dc9e78d3f578ff34c68"], "tags": []}], "date": 1568829645, "git_changesets": [null, null], "user": "ffxbld"}, "11983": {"changesets": [{"author": "Emily Toop \u003cetoop@mozilla.com\u003e", "branch": "default", "desc": "Bug 1565466 - Lock Window in `LayerViewSupport::OnDetach` r=snorp a=RyanVM\n\nMove lock of window inside thread in `LayerViewSupport::OnDetach` and pop the `GeckoResult` from list of waiting results while we still have the initiallock in `LayerViewSupport::RecvScreenPixels`.\n\nThis passes try, but then so did the last patch.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44800", "files": ["widget/android/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "4cdac2fc93e53e45ab5c5442e1ebe37f2e20fdac", "parents": ["4f444a466695ff88f51a45f08e947c25f5616efa"], "tags": []}, {"author": "Simon Giesecke \u003csgiesecke@mozilla.com\u003e", "branch": "default", "desc": "Bug 1093064 - Repeat garbage collection until ref count becomes 0. r=janv, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42609", "files": ["dom/indexedDB/test/file.js", "dom/indexedDB/test/helpers.js", "dom/indexedDB/test/test_file_delete.html", "dom/indexedDB/test/test_file_resurrection_delete.html", "dom/indexedDB/test/test_file_resurrection_transaction_abort.html", "dom/indexedDB/test/test_file_transaction_abort.html"], "git_node": null, "git_parents": [null], "node": "15fe899439fd2e935ed238574e3d939a5b0b2cd1", "parents": ["4cdac2fc93e53e45ab5c5442e1ebe37f2e20fdac"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1527029 - Split about:blank test from browser_ext_tabs_executeScript.js. r=zombie, a=RyanVM\n\nThe browser_ext_tabs_executeScript.js test occasionally times out.\nApparently the part of the test that opens \"about:blank\" and awaits the\nresult sometimes times out (`tabs.executeScript` does not resolve).\n\nTo avoid collateral damage by this small part of the test, the\n\"about:blank\" test has been moved to its own file.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45955", "files": ["browser/components/extensions/test/browser/browser.ini", "browser/components/extensions/test/browser/browser_ext_tabs_executeScript.js", "browser/components/extensions/test/browser/browser_ext_tabs_executeScript_about_blank.js"], "git_node": null, "git_parents": [null], "node": "98bd0bb93a0e30bf6838759878cc1c3844a7533a", "parents": ["15fe899439fd2e935ed238574e3d939a5b0b2cd1"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1572980 - Fix browser_jsterm_autocomplete-properties-with-non-alphanumeric-names intermittent. r=Honza, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46026", "files": ["devtools/client/webconsole/test/browser/browser_jsterm_autocomplete-properties-with-non-alphanumeric-names.js"], "git_node": null, "git_parents": [null], "node": "155e263039bab8eeda9f383eb3c4c89774a38024", "parents": ["98bd0bb93a0e30bf6838759878cc1c3844a7533a"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1574917 - Prevent GeckoSessions from being GC'd in tests. r=agi, a=RyanVM\n\n... and document that the onNewSession/WebExtensionController.onNewTab\ndelegates are responsible for maintaining the lifetime of the returned\nGeckoSession references.\n\nCurrently, the consequence of not keeping the reference is that the\nbrowser window can be closed at an unpredictable moment, as seen in the\nlinked bug report.\n\nThis patch has been verified using the STR at\nhttps://bugzilla.mozilla.org/show_bug.cgi?id=1574917#c13\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46074", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/TestRunnerActivity.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSession.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/WebExtensionController.java", "mobile/android/geckoview_example/src/main/java/org/mozilla/geckoview_example/GeckoViewActivity.java"], "git_node": null, "git_parents": [null], "node": "760ada8864988f50085f34b09b00e308dc9c3066", "parents": ["155e263039bab8eeda9f383eb3c4c89774a38024"], "tags": []}], "date": 1568834474, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "11984": {"changesets": [{"author": "Frederik Braun \u003cfbraun@mozilla.com\u003e", "branch": "default", "desc": "Bug 1530709 - Restrict styles to known selectors and single rules per message. r=emilio, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43945", "files": ["toolkit/actors/SelectChild.jsm", "toolkit/actors/SelectParent.jsm"], "git_node": null, "git_parents": [null], "node": "c97e152648be55d4daef8239bafa288aeb797f0e", "parents": ["760ada8864988f50085f34b09b00e308dc9c3066"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1571037 - BodyStreamHolder must release itself when unlinked, r=smaug, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45510", "files": ["dom/base/BodyStream.cpp", "dom/base/BodyStream.h"], "git_node": null, "git_parents": [null], "node": "89f6acce40bf2f2fffc3d49f21e219e9e8003123", "parents": ["c97e152648be55d4daef8239bafa288aeb797f0e"], "tags": []}], "date": 1568835156, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "11985": {"changesets": [{"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1578254 - Trick Make into running rust targets earlier again. r=nalexander a=RyanVM\n\nOne of the things bug 1567616 did was to change how .cargo/config is\npreprocessed, from it happening during configure to it happening during\nthe build. And to make things happen properly, dependencies were added\non the rust targets to ensure the .cargo/config file is created before\nthey run.\n\nUnfortunately, that changed the order in which Make would run all the\ntargets while recursing for the compile tier, when the file doesn't\nexist first. So instead of starting the compile tier with rust targets,\nit would start with most C++, then do rust... which we know to make\nbuilds slower overall because of the need to wait for those rust builds\nto finish which C++ has all been dealt with already, and lacking\nparallelism during the rust build.\n\nSo we force .cargo/config to be generated during export (which it is not\nalready because OBJDIR_PP_FILES are currently dealt with during misc).\nThat makes Make still run the rust targets early during the compile\ntier.\n\nAnd while here, we extend the if block in recurse.mk that excludes all\nthe top-level recursion dependencies when running from subdirectories.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44992", "files": ["config/recurse.mk"], "git_node": null, "git_parents": [null], "node": "9e76d7234a07d91e4ed19b53e9c7f1281bb29dbf", "parents": ["89f6acce40bf2f2fffc3d49f21e219e9e8003123"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1571234 - Change RemoveCookiesFromRootDomain to RemoveCookiesFromExactHost. r=baku a=RyanVM\n\nThis will change RemoveCookiesFromRootDomain to not remove cookies from all sub-domains but instead\nonly remove the single host that is passed. This is necessary to support removing all sub-domain\ncookie data in ForgetAboutSite without compromising on the cookie permissions that are supported by\nSanitizer.jsm\n\nAs a side effect, this also fixes the issues described in https://bugzilla.mozilla.org/show_bug.cgi?id=1515913#c24\n(which were caused by deleting sub-domains without checking their permission).\n\nSanitizer.jsm should retain its functionality even with this change, because it already collects\nall the principals we have to delete individually and tries to delete them (so it would consider\nmozilla.org and support.mozilla.org separately).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45012", "files": ["netwerk/cookie/nsCookieService.cpp", "netwerk/cookie/nsCookieService.h", "netwerk/cookie/nsICookieManager.idl", "toolkit/components/cleardata/ClearDataService.jsm"], "git_node": null, "git_parents": [null], "node": "23fb7ac85e3bc7fd327032bfe6c5777273fd49a5", "parents": ["9e76d7234a07d91e4ed19b53e9c7f1281bb29dbf"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1571234 - Manually collect hosts to delete cookies from in ForgetAboutSite. r=baku a=RyanVM\n\nThis is made necessary because ClearDataService will not delete sub-domains anymore. It\ndidn't correctly delete base domains before either, so we just switch to collecting the\ncorrect hosts entirely outside of ClearDataService.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45013", "files": ["toolkit/forgetaboutsite/ForgetAboutSite.jsm", "toolkit/forgetaboutsite/test/browser/browser_cookieDomain.js"], "git_node": null, "git_parents": [null], "node": "b5bee0284acfae898f527a7cc120ed0fa76951ff", "parents": ["23fb7ac85e3bc7fd327032bfe6c5777273fd49a5"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1576187: Don't set closed flag on discarded BrowsingContext. r=nika a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45319", "files": ["dom/base/nsGlobalWindowOuter.cpp"], "git_node": null, "git_parents": [null], "node": "c26b02326f4b7bb25dc2941d587dd2a0998e771f", "parents": ["b5bee0284acfae898f527a7cc120ed0fa76951ff"], "tags": []}, {"author": "Steven Michaud \u003csmichaud@pobox.com\u003e", "branch": "default", "desc": "Bug 1201401 - Work around a crash in CVCGDisplayLink::getDisplayTimes. r=spohl a=RyanVM", "files": ["gfx/thebes/gfxPlatformMac.cpp"], "git_node": null, "git_parents": [null], "node": "5aa1e4473e81effade0598eabcda89c45933fbd2", "parents": ["c26b02326f4b7bb25dc2941d587dd2a0998e771f"], "tags": []}, {"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1576260 - Make LSValue initialization fallible; r=asuth a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45849", "files": ["dom/localstorage/ActorsParent.cpp", "dom/localstorage/LSSnapshot.cpp", "dom/localstorage/LSValue.cpp", "dom/localstorage/LSValue.h", "dom/localstorage/SnappyUtils.cpp"], "git_node": null, "git_parents": [null], "node": "2346bba8106dfbf893edc78f24e9b22e13e72541", "parents": ["5aa1e4473e81effade0598eabcda89c45933fbd2"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1579156 - Fix binding tests after bug 1573566. r=chmanchester a=RyanVM\n\nThe build system has no clue that there is something to build in\ndom/bindings/test. It's currently all handled via make rules generated\nby the backend, but ideally, this would all be handled by the frontend\nemitting appropriate GeneratedFiles and Sources objects.\n\nIn the meanwhile, we just force the make backend to recurse through\ndom/bindings/test.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45124", "files": ["python/mozbuild/mozbuild/backend/recursivemake.py"], "git_node": null, "git_parents": [null], "node": "4d761ee623551f669985bd595b35a9e92fc97af0", "parents": ["2346bba8106dfbf893edc78f24e9b22e13e72541"], "tags": []}, {"author": "Jan Horak \u003cjhorak@redhat.com\u003e", "branch": "default", "desc": "Bug 1580174 -  Don't use toplevel window as parent for the menus in popupnotification; r=stransky a=RyanVM\n\nUnder Wayland where there's a strict popup window hierarchy, using toplevel window\nfor the submenus in popupnotification cause the popupnotification to hide\nwhen opening them and this breaks user to Allow/Don't allow the action.\n\nWe have to use last opened popup window as a parent for these submenus.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45343", "files": ["widget/gtk/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "2c10339c29e45d8a539eb3e4e14f1bf86da01145", "parents": ["4d761ee623551f669985bd595b35a9e92fc97af0"], "tags": []}, {"author": "Alex Chronopoulos \u003cachronop@gmail.com\u003e", "branch": "default", "desc": "Bug 1580112 - Stop updating the database when the value has not changed. r=alwu a=RyanVM\n\nIn most of the cases, the value to be stored is the same as the existing value, which does not require an update to the database. Setting something in the database requires disk access. By using this we avoid accessing the disk in the majority of the cases.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45504", "files": ["dom/media/mediacapabilities/BenchmarkStorageParent.cpp"], "git_node": null, "git_parents": [null], "node": "5433da8d8132bf7743ae9db90889f2b95330441e", "parents": ["2c10339c29e45d8a539eb3e4e14f1bf86da01145"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1579823 - [Wayland] remove __PRETTY_FUNCTION__ from wayland logs as it produces too long function names, r=jhorak a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45173", "files": ["widget/gtk/WindowSurfaceWayland.cpp"], "git_node": null, "git_parents": [null], "node": "50da78761e577c6a45dc14a62d9316ee7bfd0118", "parents": ["5433da8d8132bf7743ae9db90889f2b95330441e"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1579849 - [Wayland] Optimize cached rendering to wl_buffer for widget.wayland_cache_mode=1, r=jhorak a=RyanVM\n\n- When widget.wayland_cache_mode=1 use direct rendering to wl_buffer only when there isn't any\n  cached rendering pending and we're updating one big piece of screen (video playback/scrolling etc..)\n\n- Disable frame callback commits between WindowSurfaceWayland::Lock and WindowSurfaceWayland::Commit\n  as the buffer can be updated by gecko compositor\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45184", "files": ["widget/gtk/WindowSurfaceWayland.cpp", "widget/gtk/WindowSurfaceWayland.h"], "git_node": null, "git_parents": [null], "node": "a358333fb896bada0a8ba91d1b02fcfddb750b76", "parents": ["50da78761e577c6a45dc14a62d9316ee7bfd0118"], "tags": []}], "date": 1568838814, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null], "user": "nerli@mozilla.com"}, "11986": {"changesets": [{"author": "Dylan Roeh \u003cdroeh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1557009 - Add some basic tests for ContentBlockingController. r=geckoview-reviewers,snorp a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44469", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/ContentBlockingControllerTest.kt"], "git_node": null, "git_parents": [null], "node": "05e4691a98d392b383ba112493229bb3710a0bde", "parents": ["a358333fb896bada0a8ba91d1b02fcfddb750b76"], "tags": []}], "date": 1568851803, "git_changesets": [null], "user": "droeh@mozilla.com"}, "11987": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nbn -\u003e 8c637c60bc09\nen-GB -\u003e e427b1049333\nes-AR -\u003e 2a658a5364ee\nit -\u003e ae673a2f0503\nkab -\u003e 48d158a90014\npt-BR -\u003e b82f8f8cc8e0\nrm -\u003e 5ff448eaf827\nsv-SE -\u003e afa80c8b5ea0\nzh-CN -\u003e bbedb9f6ef44", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "9c73c7cac285a81a96a5d1731506d1d1f15d3801", "parents": ["05e4691a98d392b383ba112493229bb3710a0bde"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nbn -\u003e 8c637c60bc09\nen-GB -\u003e e427b1049333\nes-AR -\u003e 2a658a5364ee\nit -\u003e ae673a2f0503\nkab -\u003e 48d158a90014\npt-BR -\u003e b82f8f8cc8e0\nrm -\u003e 5ff448eaf827\nsv-SE -\u003e afa80c8b5ea0\nzh-CN -\u003e bbedb9f6ef44", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "7fb8c338