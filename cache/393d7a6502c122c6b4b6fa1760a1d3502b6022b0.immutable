\u003e ab10bb853d3d\nsk -\u003e 5906225bd14d\nsl -\u003e 2fa1c3497475\nson -\u003e ab470cfdea5a\nsq -\u003e c50dd0f63331\nsr -\u003e 23ce221c7141\nsv-SE -\u003e fc3ef4f01d4f\nta -\u003e 1398dadea01e\nte -\u003e 516edff23ddf\nth -\u003e 246c435a7985\ntr -\u003e a79d74498aa9\nuk -\u003e 3c84e0f4a2ce\nur -\u003e be2c0df6d4df\nuz -\u003e 3c3af827fde0\nvi -\u003e 127f93bbd55c\nxh -\u003e 35cd0764517f\nzh-CN -\u003e 2ce69c110876\nzh-TW -\u003e c5c8afb8d5ff", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "6be15cc503c28ebeed18d486f69b3f2b5dffe250", "parents": ["6d4b16fb5794361ac25b28823305f4afd32bfd96"], "tags": []}], "date": 1568883645, "git_changesets": [null, null], "user": "ffxbld"}, "11990": {"changesets": [{"author": "Mihai Tabara \u003cmtabara@mozilla.com\u003e", "branch": "default", "desc": "Bug 1580476 - Switch to new GCP bouncer workers. r=rail a=release\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45834", "files": ["taskcluster/ci/bouncer-locations/kind.yml", "taskcluster/ci/release-bouncer-aliases/kind.yml", "taskcluster/ci/release-bouncer-sub-nazgul/kind.yml", "taskcluster/ci/release-bouncer-sub/kind.yml", "taskcluster/ci/release-partner-repack-bouncer-sub/kind.yml"], "git_node": null, "git_parents": [null], "node": "9e23d6196a1b9db381ab2ad6194657fe814f7b7b", "parents": ["6be15cc503c28ebeed18d486f69b3f2b5dffe250"], "tags": []}], "date": 1568883865, "git_changesets": [null], "user": "mtabara@mozilla.com"}, "11991": {"changesets": [{"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1581127 - Add IsShuttingDown checks to DOM Cache origin initialization; r=asuth a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45846", "files": ["dom/cache/QuotaClient.cpp", "dom/quota/ActorsParent.cpp"], "git_node": null, "git_parents": [null], "node": "64a32dce1d3ebb6d5e4ad6ca001b6206d66a6f15", "parents": ["9e23d6196a1b9db381ab2ad6194657fe814f7b7b"], "tags": []}, {"author": "Gabriele Svelto \u003cgsvelto@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575216 - Make low-memory detection use per-process stats to avoid janking the main thread r=dmajor a=RyanVM\n\nThis reverts the available memory tracker back to its old implementation that\nrelied on GlobalMemoryStatusEx() instead of the potentially expensive\nK32GetPerformanceInfo(). In spite of its name GlobalMemoryStatusEx() may return\nper-process values instead of global ones which might lead to underestimating\nthe actual memory pressure. Because of this limitation this change is a\nstop-gap while we replace this code with a non-polling implementation based on\nQueryMemoryResourceNotification().\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45338", "files": ["xpcom/base/AvailableMemoryTracker.cpp"], "git_node": null, "git_parents": [null], "node": "8818268cab5b48871f236fa3fdc4abce53a72f55", "parents": ["64a32dce1d3ebb6d5e4ad6ca001b6206d66a6f15"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1581625 - Move fingerprinting blocking out of the Standard mode of content blocking; r=tanvi a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46062", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "a4c96ce0ff04709a8ef75c7e6921cc3100eaf75c", "parents": ["8818268cab5b48871f236fa3fdc4abce53a72f55"], "tags": []}, {"author": "Brendan Dahl \u003cbrendan.dahl@gmail.com\u003e", "branch": "default", "desc": "Bug 1563295 - Only rebuild native menu when specific elements added. r=mstange a=RyanVM\n\nThe menuitem custom element inserts nodes when rendered. These nodes are\nnot related to the structure of the menu, but were causing nsMenuItemX\nto mark the menu as needing a rebuild. The rebuild would remove all items\nfrom the menu which caused the removal of the special menu items \"Start\nDictation\" and \"Emoji and Symbols\" that are automatically added by MacOS.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45420", "files": ["widget/cocoa/nsMenuItemX.mm"], "git_node": null, "git_parents": [null], "node": "dcaf39b427e14b1d1cbe9e6b49bbab4817b4979f", "parents": ["a4c96ce0ff04709a8ef75c7e6921cc3100eaf75c"], "tags": []}, {"author": "Miko Mynttinen \u003cmikokm@gmail.com\u003e", "branch": "default", "desc": "Bug 1559706 - Workaround for invalid layerization in Inspector r=gl a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45896", "files": ["devtools/client/themes/boxmodel.css"], "git_node": null, "git_parents": [null], "node": "c1ab57246ce06b4338835d057ae3141b0591b941", "parents": ["dcaf39b427e14b1d1cbe9e6b49bbab4817b4979f"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1577181 - Fix one off search button overflow layout in the urlbar. r=harry a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45826", "files": ["browser/components/search/content/search-one-offs.js", "browser/themes/shared/searchbar.inc.css", "browser/themes/shared/urlbar-autocomplete.inc.css"], "git_node": null, "git_parents": [null], "node": "6dd307dd68f9faf97e7355862031e168d40c42b4", "parents": ["c1ab57246ce06b4338835d057ae3141b0591b941"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1581377 - Let display:flex not override the hidden attribute on the one off search button container. r=harry a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46124", "files": ["browser/components/urlbar/tests/browser/browser_urlbarOneOffs.js", "browser/themes/shared/urlbar-autocomplete.inc.css"], "git_node": null, "git_parents": [null], "node": "5a0bc7ae79302146e2ecfd6a7f276a59128e1026", "parents": ["6dd307dd68f9faf97e7355862031e168d40c42b4"], "tags": []}, {"author": "Timothy Nikkel \u003ctnikkel@gmail.com\u003e", "branch": "default", "desc": "Bug 1580820. Update the inner window id as well as the context (document) pointer on an imgRequest if we validate it for that document/inner window id. r=aosmond a=RyanVM\n\nIf we just update the document pointer and not the inner window id then the request is unusable by any document since both the inner window id and the document pointer must match for it to be re-usable.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46121", "files": ["image/imgLoader.cpp", "image/imgLoader.h", "image/imgRequest.h"], "git_node": null, "git_parents": [null], "node": "67398bc7737c4fca6bab09147efdf9e9d7f710ef", "parents": ["5a0bc7ae79302146e2ecfd6a7f276a59128e1026"], "tags": []}, {"author": "Andrei Oprea \u003candrei.br92@gmail.com\u003e", "branch": "default", "desc": "Bug 1577148 - Open What's New Panel message links with the keyboard r=pdahiya a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46150", "files": ["browser/components/newtab/lib/ToolbarPanelHub.jsm"], "git_node": null, "git_parents": [null], "node": "2b80ad6a98036e7fabb024fdbb1cd9ebc5e28a43", "parents": ["67398bc7737c4fca6bab09147efdf9e9d7f710ef"], "tags": []}, {"author": "Tim Huang \u003ctihuang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1578052 - Add the focus outline of the TP switch in protections panel. r=nhnt11 a=RyanVM\n\nWe add the focus outline of the TP switch according to different\nplatforms.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45984", "files": ["browser/themes/linux/controlcenter/panel.css", "browser/themes/osx/controlcenter/panel.css", "browser/themes/windows/controlcenter/panel.css"], "git_node": null, "git_parents": [null], "node": "d15f21350cb733ac9a27aabbf34affa3fd44209a", "parents": ["2b80ad6a98036e7fabb024fdbb1cd9ebc5e28a43"], "tags": []}], "date": 1568885596, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "opoprus@mozilla.com"}, "11992": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nen-CA -\u003e cfbfe33e1d64\nhsb -\u003e 9dd9a0ce4f7b\nnn-NO -\u003e 82fce9ca8540\npl -\u003e 821457e3a522", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "60d4be7fad394bf866d8a62262e1f5be2fa38b5e", "parents": ["d15f21350cb733ac9a27aabbf34affa3fd44209a"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nen-CA -\u003e cfbfe33e1d64\nhsb -\u003e 9dd9a0ce4f7b\nnn-NO -\u003e 82fce9ca8540\npl -\u003e 821457e3a522", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "6696d5416444a52fad3a11105638ea6eabaff8d5", "parents": ["60d4be7fad394bf866d8a62262e1f5be2fa38b5e"], "tags": []}], "date": 1568887247, "git_changesets": [null, null], "user": "ffxbld"}, "11993": {"changesets": [{"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1578140: Use nsXULElement::Click for DoAction on XULLabelAccessible so it works for labels inside buttons. r=eeejay a=RyanVM\n\nFor labels inside buttons, The base implementation of DispatchClickEvent doesn't fire a command event on the button.\nTo fix this, override DispatchClickEvent to use nsXULElement::Click, which does fire a command event on the button.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44410", "files": ["accessible/tests/mochitest/actions.js", "accessible/tests/mochitest/actions/test_general.xul", "accessible/xul/XULElementAccessibles.cpp", "accessible/xul/XULElementAccessibles.h"], "git_node": null, "git_parents": [null], "node": "d86ca7707b35e5e3834bc70b7dd5dbcce45e1cde", "parents": ["6696d5416444a52fad3a11105638ea6eabaff8d5"], "tags": []}, {"author": "Jeremy Lempereur \u003cjeremy.lempereur@gmail.com\u003e", "branch": "default", "desc": "Bug 1562386 - Sort network attributes before hashing them to get a networkID r=mayhemer,michal,valentin a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D38418", "files": ["netwerk/system/mac/nsNetworkLinkService.mm", "netwerk/system/win32/nsNotifyAddrListener.cpp"], "git_node": null, "git_parents": [null], "node": "5a91270165e466780b5d548e75cf86ba2222770b", "parents": ["d86ca7707b35e5e3834bc70b7dd5dbcce45e1cde"], "tags": []}, {"author": "Erica Wright \u003cewright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1579487 - Change the Protections database API to return the correct date in the user's timezone. r=johannh a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45064", "files": ["browser/components/protections/content/protections.js", "toolkit/components/antitracking/TrackingDBService.jsm", "toolkit/components/antitracking/test/xpcshell/test_tracking_db_service.js"], "git_node": null, "git_parents": [null], "node": "beaf903278568f80dceace2119932ba10f615a86", "parents": ["5a91270165e466780b5d548e75cf86ba2222770b"], "tags": []}, {"author": "Erica Wright \u003cewright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1579947 - Edit font sizes and colors to match the mock. r=johannh a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45380", "files": ["browser/components/protections/content/protections.css"], "git_node": null, "git_parents": [null], "node": "9062431b57ca2d068141031bdb4628c85527eaee", "parents": ["beaf903278568f80dceace2119932ba10f615a86"], "tags": []}, {"author": "Erica Wright \u003cewright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1579944 - Align elements matching grids. r=johannh a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45451", "files": ["browser/components/protections/content/protections.css", "browser/components/protections/content/protections.html"], "git_node": null, "git_parents": [null], "node": "bc37281c97350764998d8477db94b39b727d59bc", "parents": ["9062431b57ca2d068141031bdb4628c85527eaee"], "tags": []}, {"author": "Erica Wright \u003cewright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1581544 - Use data from 1 week, not 8 days. r=johannh a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46046", "files": ["browser/components/protections/content/protections.js"], "git_node": null, "git_parents": [null], "node": "023ff6b1144f6c2dfde39a52f1c63a99c7b8fa1e", "parents": ["bc37281c97350764998d8477db94b39b727d59bc"], "tags": []}, {"author": "J.C. Jones \u003cjjones@mozilla.com\u003e", "branch": "default", "desc": "Bug 1573245 - Change AuthenticatorTransport to be string, not `enum` r=bzbarsky,keeler a=RyanVM\n\nUpstream: https://github.com/w3c/webauthn/issues/1268\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41620", "files": ["dom/webauthn/WebAuthnManager.cpp", "dom/webauthn/tests/test_webauthn_get_assertion.html", "dom/webauthn/tests/test_webauthn_make_credential.html", "dom/webidl/WebAuthentication.webidl"], "git_node": null, "git_parents": [null], "node": "17b847ad15633a9419e8b98254000c4f413575db", "parents": ["023ff6b1144f6c2dfde39a52f1c63a99c7b8fa1e"], "tags": []}, {"author": "Dana Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "bug 1578882 - wait on the loadable roots background task before handing out CertVerifier handles r=tjr a=RyanVM\n\nIf code acquires a handle on the certificate verifier before the loadable roots\nbackground task completes, that instance of the verifier may not know about any\nenterprise certificates loaded, and so early certificate verifications relying\non those certificates may fail. To prevent this, this patch ensures that the\nbackground task has completed before returning the handle. Note that there\nshould be no effect on performance since CertVerifier already ensures that the\nbackground task has completed internally before looking for potential issuer\ncertificates.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46224", "files": ["security/manager/ssl/nsNSSComponent.cpp"], "git_node": null, "git_parents": [null], "node": "6afdad3c5f0fed4fc111cb15712addf7392bc1f9", "parents": ["17b847ad15633a9419e8b98254000c4f413575db"], "tags": []}, {"author": "Edgar Chen \u003cechen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1579858 - Should release RefPtr before CollectData is clear; r=smaug a=RyanVM\n\nmAboutToBeNotifiedRejectedPromises will be clear in AfterProcessMicrotasks()\nand mPendingUnhandledRejections will be clear after NotifyUnhandledRejections\nrunnable is handled.\n\nHowever, worker could terminate in any time, we still need to clear those\nstructures manually before CollectData is clear.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46095", "files": ["xpcom/base/CycleCollectedJSContext.cpp"], "git_node": null, "git_parents": [null], "node": "fffca6c7380a0e0e412887d596349df5e9e19460", "parents": ["6afdad3c5f0fed4fc111cb15712addf7392bc1f9"], "tags": []}], "date": 1568889081, "git_changesets": [null, null, null, null, null, null, null, null, null], "user": "shindli@mozilla.com"}, "11994": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nhsb -\u003e 5e28bfbaed49\nit -\u003e 2e897a1e9ceb\npl -\u003e 9d86e2d0f193", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "6ebe07ad7766d44658e0eb757f80ef141a675ca8", "parents": ["fffca6c7380a0e0e412887d596349df5e9e19460"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nhsb -\u003e 5e28bfbaed4