.com\u003e", "branch": "default", "desc": "Bug 1558958 [wpt PR 17301] - Update wpt metadata, a=testonly\n\nwpt-pr: 17301\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/bluetooth/adapter/adapter-absent-getAvailability.https.window.js.ini", "testing/web-platform/meta/bluetooth/adapter/adapter-added-getAvailability.https.window.js.ini", "testing/web-platform/meta/bluetooth/adapter/adapter-powered-off-getAvailability.https.window.js.ini", "testing/web-platform/meta/bluetooth/adapter/adapter-powered-on-getAvailability.https.window.js.ini", "testing/web-platform/meta/bluetooth/adapter/adapter-powered-on-off-on-getAvailability.https.window.js.ini", "testing/web-platform/meta/bluetooth/adapter/adapter-removed-getAvailability.https.window.js.ini", "testing/web-platform/meta/bluetooth/adapter/cross-origin-iframe-getAvailability.sub.https.window.js.ini"], "git_node": null, "git_parents": [null], "node": "c30f8088872cc43817ce6b25f1ab1d529725fdf4", "parents": ["d1a30366320a2327da5d87ea9cc03901553c6f4d"], "tags": []}, {"author": "Nicol\u00e1s Pe\u00f1a Moreno \u003cnpm@chromium.org\u003e", "branch": "default", "desc": "Bug 1575301 [wpt PR 18569] - [LargestContentfulPaint] Add tests for invisible images and iframe, a=testonly\n\nAutomatic update from web-platform-tests\n[LargestContentfulPaint] Add tests for invisible images and iframe\n\nBug: 994414\nChange-Id: Ica33ea747b8985956ab791f9e55950f46016bda6\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1762334\nReviewed-by: Steve Kobes \u003cskobes@chromium.org\u003e\nCommit-Queue: Nicol\u00e1s Pe\u00f1a Moreno \u003cnpm@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#689002}\n\n--\n\nwpt-commits: 24dc5f097c1bbf98be038b534f3ba83c75c809e1\nwpt-pr: 18569\n", "files": ["testing/web-platform/tests/element-timing/resources/iframe-with-content.html", "testing/web-platform/tests/largest-contentful-paint/iframe-content-not-observed.html", "testing/web-platform/tests/largest-contentful-paint/invisible-images.html"], "git_node": null, "git_parents": [null], "node": "0d061585604052d655be17bac418ba092e4578f4", "parents": ["c30f8088872cc43817ce6b25f1ab1d529725fdf4"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575301 [wpt PR 18569] - Update wpt metadata, a=testonly\n\nwpt-pr: 18569\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/largest-contentful-paint/iframe-content-not-observed.html.ini", "testing/web-platform/meta/largest-contentful-paint/invisible-images.html.ini"], "git_node": null, "git_parents": [null], "node": "baa71b4865c1a2ea92c8f470b8676ff57d3ebc89", "parents": ["0d061585604052d655be17bac418ba092e4578f4"], "tags": []}, {"author": "Kevin Ellis \u003ckevers@chromium.org\u003e", "branch": "default", "desc": "Bug 1573500 [wpt PR 18399] - Code health refactoring of animation.cc., a=testonly\n\nAutomatic update from web-platform-tests\nCode health refactoring of animation.cc.\n\nThis patch aligns the implementation of web-animations with the spec.\nPreviously updates were performed via a PlayStateUpdateScope. This\nclass depended on an extra state (kPending) that is not to spec.\nSupport for microtasks is also introduced in this patch, which\naddresses most of the remaining timing issues with the finished state\nof an animation.\n\nBug: 960944\nChange-Id: I62aff2254d2b5265f869415e0f763e140b460c37\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1739386\nReviewed-by: Stephen McGruer \u003csmcgruer@chromium.org\u003e\nCommit-Queue: Kevin Ellis \u003ckevers@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#689018}\n\n--\n\nwpt-commits: 521a012922a378241b46eff13e96bb3c154cb01e\nwpt-pr: 18399\n", "files": ["testing/web-platform/tests/web-animations/timing-model/animations/pausing-an-animation.html"], "git_node": null, "git_parents": [null], "node": "299f19714e7caa234cc6ae4a2aa737c6ece7dc7e", "parents": ["baa71b4865c1a2ea92c8f470b8676ff57d3ebc89"], "tags": []}, {"author": "Ian Kilpatrick \u003cikilpatrick@chromium.org\u003e", "branch": "default", "desc": "Bug 1575353 [wpt PR 18570] - [css-layout-api] Re-add LayoutEdges., a=testonly\n\nAutomatic update from web-platform-tests\n[css-layout-api] Re-add LayoutEdges.\n\nThis patch was created by reverting:\nhttps://chromium-review.googlesource.com/c/chromium/src/+/1282724\n\nAnd converting the tests to use promises, and switching the API to NG.\n\nI run the patch against the mac-bots a few times to determine if I\ncould reproduced the flakiness which occurred initially to no avail.\n\nBug: 726125\nChange-Id: I5f6197699977c03d3efbd4ca0926815faabee19d\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1761372\nReviewed-by: Morten Stenshorne \u003cmstensho@chromium.org\u003e\nCommit-Queue: Ian Kilpatrick \u003cikilpatrick@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#689023}\n\n--\n\nwpt-commits: 443459a640bf144ec0ea6c7ab4b5e8bc6432f362\nwpt-pr: 18570\n", "files": ["testing/web-platform/tests/css/css-layout-api/edges/all-ref.html", "testing/web-platform/tests/css/css-layout-api/edges/all.https.html", "testing/web-platform/tests/css/css-layout-api/edges/border-htb-rtl.https.html", "testing/web-platform/tests/css/css-layout-api/edges/border-htb.https.html", "testing/web-platform/tests/css/css-layout-api/edges/border-vlr-rtl.https.html", "testing/web-platform/tests/css/css-layout-api/edges/border-vlr.https.html", "testing/web-platform/tests/css/css-layout-api/edges/border-vrl-rtl.https.html", "testing/web-platform/tests/css/css-layout-api/edges/border-vrl.https.html", "testing/web-platform/tests/css/css-layout-api/edges/padding-htb-rtl.https.html", "testing/web-platform/tests/css/css-layout-api/edges/padding-htb.https.html", "testing/web-platform/tests/css/css-layout-api/edges/padding-vlr-rtl.https.html", "testing/web-platform/tests/css/css-layout-api/edges/padding-vlr.https.html", "testing/web-platform/tests/css/css-layout-api/edges/padding-vrl-rtl.https.html", "testing/web-platform/tests/css/css-layout-api/edges/padding-vrl.https.html", "testing/web-platform/tests/css/css-layout-api/edges/scrollbar-ref.html", "testing/web-platform/tests/css/css-layout-api/edges/scrollbar.https.html", "testing/web-platform/tests/css/css-layout-api/edges/support/edges.js"], "git_node": null, "git_parents": [null], "node": "49e8bb08d5d951bb744bd29feb0c3bfd34888c0b", "parents": ["299f19714e7caa234cc6ae4a2aa737c6ece7dc7e"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575353 [wpt PR 18570] - Update wpt metadata, a=testonly\n\nwpt-pr: 18570\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/css/css-layout-api/edges/all.https.html.ini", "testing/web-platform/meta/css/css-layout-api/edges/border-htb-rtl.https.html.ini", "testing/web-platform/meta/css/css-layout-api/edges/border-htb.https.html.ini", "testing/web-platform/meta/css/css-layout-api/edges/border-vlr-rtl.https.html.ini", "testing/web-platform/meta/css/css-layout-api/edges/border-vlr.https.html.ini", "testing/web-platform/meta/css/css-layout-api/edges/border-vrl-rtl.https.html.ini", "testing/web-platform/meta/css/css-layout-api/edges/border-vrl.https.html.ini", "testing/web-platform/meta/css/css-layout-api/edges/padding-htb-rtl.https.html.ini", "testing/web-platform/meta/css/css-layout-api/edges/padding-htb.https.html.ini", "testing/web-platform/meta/css/css-layout-api/edges/padding-vlr-rtl.https.html.ini", "testing/web-platform/meta/css/css-layout-api/edges/padding-vlr.https.html.ini", "testing/web-platform/meta/css/css-layout-api/edges/padding-vrl-rtl.https.html.ini", "testing/web-platform/meta/css/css-layout-api/edges/padding-vrl.https.html.ini", "testing/web-platform/meta/css/css-layout-api/edges/scrollbar.https.html.ini"], "git_node": null, "git_parents": [null], "node": "5a85d75083fadbd836aaa013a4a93a863f753ef3", "parents": ["49e8bb08d5d951bb744bd29feb0c3bfd34888c0b"], "tags": []}, {"author": "Changwan Ryu \u003cchangwan@google.com\u003e", "branch": "default", "desc": "Bug 1573910 [wpt PR 17239] - WebView support, a=testonly\n\nAutomatic update from web-platform-tests\nAdd android_webview to products\n\ncrbug.com/992947\n\n--\n\nwpt-commits: 7ce48248652b528f3a80b38c68556720baa8f486\nwpt-pr: 17239\n", "files": ["testing/web-platform/tests/tools/wpt/browser.py", "testing/web-platform/tests/tools/wpt/run.py", "testing/web-platform/tests/tools/wptrunner/requirements_android_webview.txt", "testing/web-platform/tests/tools/wptrunner/wptrunner/browsers/__init__.py", "testing/web-platform/tests/tools/wptrunner/wptrunner/browsers/android_webview.py"], "git_node": null, "git_parents": [null], "node": "c8268335f83d44f9a4dcccc2314cffd7c33eefd1", "parents": ["5a85d75083fadbd836aaa013a4a93a863f753ef3"], "tags": []}, {"author": "Xiaocheng Hu \u003cxiaochengh@chromium.org\u003e", "branch": "default", "desc": "Bug 1575417 [wpt PR 18574] - Support percentage comparison resolution against negative reference values, a=testonly\n\nAutomatic update from web-platform-tests\nSupport percentage comparison resolution against negative reference values\n\nIt's a very edge case that a percentage may be resolved against a\nnegative value, which is allowed only in 'background-position' property.\n\nTo support this without massively changing existing code, this patch\nadds an indicator flag to |CSSMathFunctionValue|, so that when the flag\nis set, the resolution of calculated percentage values is delayed to when\na reference value is available. When the flag is not set, we still use\nthe existing code path where a calculated percentage value can be\nresolved immediately.\n\nTogether with this patch is a test suite on parsing and evaluation of\ncomparisons on percentages.\n\nBug: 825895, 978682\nChange-Id: I2a6aabd48313ccda82b50f6dc00fd62c4548bc84\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1762970\nCommit-Queue: Xiaocheng Hu \u003cxiaochengh@chromium.org\u003e\nReviewed-by: Rune Lillesveen \u003cfuthark@chromium.org\u003e\nReviewed-by: Emil A Eklund \u003ceae@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#689198}\n\n--\n\nwpt-commits: 8f929221b0664b735209dd1b44594dd21d643520\nwpt-pr: 18574\n", "files": ["testing/web-platform/tests/css/css-backgrounds/background-position-negative-percentage-comparison.html", "testing/web-platform/tests/css/css-backgrounds/reference/background-position-negative-percentage-comparison-ref.html", "testing/web-platform/tests/css/css-values/minmax-percentage-computed.html", "testing/web-platform/tests/css/css-values/minmax-percentage-invalid.html"], "git_node": null, "git_parents": [null], "node": "e5e59e33b55fdcdbf3eed414a6a70ee9b2cdae4a", "parents": ["c8268335f83d44f9a4dcccc2314cffd7c33eefd1"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575417 [wpt PR 18574] - Update wpt metadata, a=testonly\n\nwpt-pr: 18574\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/css/css-backgrounds/background-position-negative-percentage-comparison.html.ini", "testing/web-platform/meta/css/css-values/minmax-percentage-computed.html.ini"], "git_node": null, "git_parents": [null], "node": "82eed622a6a87ca1f9cc3a8c4e0b575141046dc8", "parents": ["e5e59e33b55fdcdbf3eed414a6a70ee9b2cdae4a"], "tags": []}, {"author": "David Grogan \u003cdgrogan@chromium.org\u003e", "branch": "default", "desc": "Bug 1574674 [wpt PR 18514] - [LayoutNG] Lay out flex items with ShrinkToFit in more cases, a=testonly\n\nAutomatic update from web-platform-tests\n[LayoutNG] Lay out flex items with ShrinkToFit in more cases\n\nA row flex box's cross size of {fit,min,max}-content isn't definite,\nwhich affects the inline size of orthogonal children.\n\nBug: 845235\nChange-Id: Id08a1cf6d23e9e295e87c52d426079bc7e886b74\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1758992\nReviewed-by: Christian Biesinger \u003ccbiesinger@chromium.org\u003e\nCommit-Queue: David Grogan \u003cdgrogan@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#689232}\n\n--\n\nwpt-commits: a1cec169e027d234248e36e74c29b1efae1b528c\nwpt-pr: 18514\n", "files": ["testing/web-platform/tests/css/css-flexbox/fit-content-item-002.html", "testing/web-platform/tests/css/css-flexbox/fit-content-item-003.html", "testing/web-platform/tests/css/css-flexbox/fit-content-item-004.html"], "git_node": null, "git_parents": [null], "node": "6fc8a85865f16548350106db4540573e56ac6ce3", "parents": ["82eed622a6a87ca1f9cc3a8c4e0b575141046dc8"], "tags": []}, {"author": "Ovidio Henriquez \u003codejesush@chromium.org\u003e", "branch": "default", "desc": "Bug 1574541 [wpt PR 18504] - bluetooth: descriptor tests to standalone window, a=testonly\n\nAutomatic update from web-platform-tests\nbluetooth: descriptor tests to standalone window\n\nThis change updates the descriptor tests in wpt/ to be standalone window\ntests. This change allows tests to be formatted with clang-format.\n\nBug: 994756\nChange-Id: Ifcedeadd35d0775793269572fec478eaa5dbe06d\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1757889\nReviewed-by: Matt Reynolds \u003cmattreynolds@chromium.org\u003e\nReviewed-by: Reilly Grant \u003creillyg@chromium.org\u003e\nCommit-Queue: Reilly Grant \u003creillyg@chromium.org\u003e\nAuto-Submit: Ovidio de Jes\u00fas Ruiz-Henr\u00edquez \u003codejesush@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#689260}\n\n--\n\nwpt-commits: e6dc25e5af4343c1220996a54ba24a735d3ce81c\nwpt-pr: 18504\n", "files": ["testing/web-platform/tests/bluetooth/descriptor/readValue/read-succeeds.https.html", "testing/web-platform/tests/bluetooth/descriptor/readValue/read-succeeds.https.window.js", "testing/web-platform/tests/bluetooth/descriptor/writeValue/buffer-is-detached.https.html", "testing/web-platform/tests/bluetooth/descriptor/writeValue/buffer-is-detached.https.window.js"], "git_node": null, "git_parents": [null], "node": "b29a7ed648b3de5cafc81d1d5834feb56567a6fe", "parents": ["6fc8a85865f16548350106db4540573e56ac6ce3"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1574541 [wpt PR 18504] - Update wpt metadata, a=testonly\n\nwpt-pr: 18504\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/bluetooth/descriptor/readValue/read-succeeds.https.html.ini", "testing/web-platform/meta/bluetooth/descriptor/readValue/read-succeeds.https.window.js.ini", "testing/web-platform/meta/bluetooth/descriptor/writeValue/buffer-is-detached.https.html.ini", "testing/web-platform/meta/bluetooth/descriptor/writeValue/buffer-is-detached.https.window.js.ini"], "git_node": null, "git_parents": [null], "node": "2df83a4161680457e587f6fec58105d52ad3b8f9", "parents": ["b29a7ed648b3de5cafc81d1d5834feb56567a6fe"], "tags": []}, {"author": "Hiroshige Hayashizaki \u003chiroshige@chromium.org\u003e", "branch": "default", "desc": "Bug 1575469 [wpt PR 18580] - [Import Maps] Mark some tests as slow, a=testonly\n\nAutomatic update from web-platform-tests\n[Import Maps] Mark some tests as slow\n\n- The tests are probably just slow.\n- fallback-disallowed.sub.tentative.html is no longer flakily failing.\n\nBug: 959372, 936279, 992615\nChange-Id: I0fd8c49514156f3bb60bfad3431affc38318384d\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1762260\nReviewed-by: Domenic Denicola \u003cdomenic@chromium.org\u003e\nCommit-Queue: Hiroshige Hayashizaki \u003chiroshige@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#689280}\n\n--\n\nwpt-commits: 75cb08020575a29ef1a4fa0d48976a3c132dd8c5\nwpt-pr: 18580\n", "files": ["testing/web-platform/tests/import-maps/data.sub.tentative.html", "testing/web-platform/tests/import-maps/fallback-disallowed.sub.tentative.html", "testing/web-platform/tests/import-maps/fallback.sub.tentative.html"], "git_node": null, "git_parents": [null], "node": "20a946f3154833b723408ab30237be31a4e0e792", "parents": ["2df83a4161680457e587f6fec58105d52ad3b8f9"], "tags": []}, {"author": "G\u00e9rard Talbot \u003cgithub@gtalbot.org\u003e", "branch": "default", "desc": "Bug 1575730 [wpt PR 18605] - Corrected text assert of abs-pos-non-replaced-vlr-213.xht test, a=testonly\n\nAutomatic update from web-platform-tests\nCorrected text assert of abs-pos-non-replaced-vlr-213.xht test (#18605)\n\n--\n\nwpt-commits: 738a91a4ef94f5163c0addc53e2f65d42a0e3cda\nwpt-pr: 18605\n", "files": ["testing/web-platform/tests/css/css-writing-modes/abs-pos-non-replaced-vlr-213.xht"], "git_node": null, "git_parents": [null], "node": "32763553675a5a030753952ba13fceb70a16d09a", "parents": ["20a946f3154833b723408ab30237be31a4e0e792"], "tags": []}, {"author": "David Grogan \u003cdgrogan@chromium.org\u003e", "branch": "default", "desc": "Bug 1575399 [wpt PR 18572] - [LayoutNG] Give flex items their stretched size earlier., a=testonly\n\nAutomatic update from web-platform-tests\n[LayoutNG] Give flex items their stretched size earlier.\n\nForce the cross size on stretchy items when they are laid out for\nflex base sizing or cross size determination.\n\nBug: 845235\nChange-Id: I49c6b9a9ef1d2e86aa02c47841075ed2726d5619\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1762816\nCommit-Queue: David Grogan \u003cdgrogan@chromium.org\u003e\nReviewed-by: Christian Biesinger \u003ccbiesinger@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#689303}\n\n--\n\nwpt-commits: 0702f3fe6d81479cb42dcc59c930599cd28ca5cc\nwpt-pr: 18572\n", "files": ["testing/web-platform/tests/css/css-flexbox/flexbox_align-items-stretch-3.html"], "git_node": null, "git_parents": [null], "node": "ab4ec8496abef46820008a1d9f838f6f8cc522b7", "parents": ["32763553675a5a030753952ba13fceb70a16d09a"], "tags": []}, {"author": "autofoolip \u003cauto@foolip.org\u003e", "branch": "default", "desc": "Bug 1575762 [wpt PR 18606] - Update interfaces/shape-detection-api.idl, a=testonly\n\nAutomatic update from web-platform-tests\nUpdate interfaces/shape-detection-api.idl (#18606)\n\nSource: https://github.com/tidoust/reffy-reports/blob/d705188/whatwg/idl/shape-detection-api.idl\nBuild: https://travis-ci.org/tidoust/reffy-reports/builds/575189906\n--\n\nwpt-commits: 2ac3724aeddf43352e94f08b512ac93d6f35eebc\nwpt-pr: 18606\n", "files": ["testing/web-platform/tests/interfaces/shape-detection-api.idl"], "git_node": null, "git_parents": [null], "node": "6bbe67151608e241b3310716ecd508360d680dc1", "parents": ["ab4ec8496abef46820008a1d9f838f6f8cc522b7"], "tags": []}, {"author": "autofoolip \u003cauto@foolip.org\u003e", "branch": "default", "desc": "Bug 1575764 [wpt PR 18607] - Update interfaces/web-nfc.idl, a=testonly\n\nAutomatic update from web-platform-tests\nUpdate interfaces/web-nfc.idl (#18607)\n\nSource: https://github.com/tidoust/reffy-reports/blob/d705188/whatwg/idl/web-nfc.idl\nBuild: https://travis-ci.org/tidoust/reffy-reports/builds/575189906\n--\n\nwpt-commits: c8c89cfcabc754e1affc4ff5d6b255ba7dfcfc74\nwpt-pr: 18607\n", "files": ["testing/web-platform/tests/interfaces/web-nfc.idl"], "git_node": null, "git_parents": [null], "node": "24691e3bf5810ebcd9d1a556b43f27edc5d24679", "parents": ["6bbe67151608e241b3310716ecd508360d680dc1"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575764 [wpt PR 18607] - Update wpt metadata, a=testonly\n\nwpt-pr: 18607\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/web-nfc/idlharness.https.window.js.ini"], "git_node": null, "git_parents": [null], "node": "c935962f6bb467e6a2622001b032d292aa777742", "parents": ["24691e3bf5810ebcd9d1a556b43f27edc5d24679"], "tags": []}, {"author": "Xiaocheng Hu \u003cxiaochengh@chromium.org\u003e", "branch": "default", "desc": "Bug 1575698 [wpt PR 18600] - Add parser and evaluation WPT for \u003cnumber\u003e and \u003cinteger\u003e involving min/max(), a=testonly\n\nAutomatic update from web-platform-tests\nAdd parser and evaluation WPT for \u003cnumber\u003e and \u003cinteger\u003e involving min/max()\n\nBug: 978682\nChange-Id: I03310f9116f66d3ec2248a357c209d704deb85cd\n\n--\n\nwpt-commits: d1d8d8b4fa654551cc683446674aa5b189786bdf\nwpt-pr: 18600\n", "files": ["testing/web-platform/tests/css/css-values/minmax-integer-computed.html", "testing/web-platform/tests/css/css-values/minmax-number-computed.html", "testing/web-platform/tests/css/css-values/minmax-number-invalid.html"], "git_node": null, "git_parents": [null], "node": "5d7f8450060d7e62f0975553315df283bee2d839", "parents": ["c935962f6bb467e6a2622001b032d292aa777742"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575698 [wpt PR 18600] - Update wpt metadata, a=testonly\n\nwpt-pr: 18600\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/css/css-values/minmax-integer-computed.html.ini", "testing/web-platform/meta/css/css-values/minmax-number-computed.html.ini"], "git_node": null, "git_parents": [null], "node": "2104112e4f94f728c053f7c320d5d9bab1c4bfbd", "parents": ["5d7f8450060d7e62f0975553315df283bee2d839"], "tags": []}, {"author": "Philip J\u00e4genstedt \u003cphilip@foolip.org\u003e", "branch": "default", "desc": "Bug 1575481 [wpt PR 18585] - Skip problematic tests in Safari using --exclude, a=testonly\n\nAutomatic update from web-platform-tests\nSkip problematic tests in Safari using --exclude (#18585)\n\nWorkaround for https://github.com/web-platform-tests/wpt/issues/16229.\n\n--\n\nwpt-commits: 2c25b504c582b31efdd33ae429de78efe9558331\nwpt-pr: 18585\n", "files": ["testing/web-platform/tests/.azure-pipelines.yml"], "git_node": null, "git_parents": [null], "node": "73225a9e209478b617cfc3024ed0523425e3efce", "parents": ["2104112e4f94f728c053f7c320d5d9bab1c4bfbd"], "tags": []}, {"author": "Emil A Eklund \u003ceae@chromium.org\u003e", "branch": "default", "desc": "Bug 1575841 [wpt PR 18612] - Revert \"[CSS] Treat viewport-relative units as computationally independent\", a=testonly\n\nAutomatic update from web-platform-tests\nRevert \"[CSS] Treat viewport-relative units as computationally independent\"\n\nThis is a speculative revert in order to either confirm or eliminate it\nas a source for a hard to track down persistent performance regression.\n\nThis reverts r679183 (commit 6b846d3689b9038c73d87ecbab61670e91c7e051).\n\nBug: 993476\nTbr: pdr@chromium.org\nChange-Id: I37566d32fb0853590e72299fdc0f281c712bf027\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1764195\nCommit-Queue: Emil A Eklund \u003ceae@chromium.org\u003e\nReviewed-by: Emil A Eklund \u003ceae@chromium.org\u003e\nReviewed-by: Philip Rogers \u003cpdr@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#689475}\n\n--\n\nwpt-commits: 7c8e32ead1a5cc9b402558fd43d0c555bd31965f\nwpt-pr: 18612\n", "files": ["testing/web-platform/tests/css/css-properties-values-api/register-property-syntax-parsing.html"], "git_node": null, "git_parents": [null], "node": "c6141012a736a409c71006910632fd8a477f3b73", "parents": ["73225a9e209478b617cfc3024ed0523425e3efce"], "tags": []}, {"author": "Christian Biesinger \u003ccbiesinger@chromium.org\u003e", "branch": "default", "desc": "Bug 1575407 [wpt PR 18573] - [css-flexbox] Only clear the override size if we're doing layout, a=testonly\n\nAutomatic update from web-platform-tests\n[css-flexbox] Only clear the override size if we're doing layout\n\nAnd make ChildUnstretchedLogical{Width,Height} handle the case where\nan override size is set (by clearing and re-setting).\n\nThe problem with clearing the override size, but not doing layout,\nis that we may later do a simplified layout which will then\nlay out as shrink-to-fit, which is undesired.\n\nBug: 992010\nChange-Id: I18d3ae66f62cbdc9cdcf76810dc0eff6be915af6\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1758940\nCommit-Queue: Christian Biesinger \u003ccbiesinger@chromium.org\u003e\nAuto-Submit: Christian Biesinger \u003ccbiesinger@chromium.org\u003e\nReviewed-by: David Grogan \u003cdgrogan@chromium.org\u003e\nReviewed-by: Morten Stenshorne \u003cmstensho@chromium.org\u003e\nReviewed-by: Emil A Eklund \u003ceae@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#689485}\n\n--\n\nwpt-commits: 768d6294ed324158d4269a833fda94ea7927efe3\nwpt-pr: 18573\n", "files": ["testing/web-platform/tests/css/css-flexbox/dynamic-change-simplified-layout.html"], "git_node": null, "git_parents": [null], "node": "ffeb51048e9b089ec1a2899bbf11dbcca798b201", "parents": ["c6141012a736a409c71006910632fd8a477f3b73"], "tags": []}, {"author": "Fr\u00e9d\u00e9ric Wang \u003cfwang@igalia.com\u003e", "branch": "default", "desc": "Bug 1575899 [wpt PR 18614] - MathML: Wait for Ahem fonts to be ready for displaystyle dynamic tests., a=testonly\n\nAutomatic update from web-platform-tests\nMathML: Wait for Ahem fonts to be ready for displaystyle dynamic tests. (#18614)\n\n--\n\nwpt-commits: 3ccf6da39967fe9e9c296c4b9342e3de8dcf4c98\nwpt-pr: 18614\n", "files": ["testing/web-platform/tests/mathml/relations/css-styling/displaystyle-013.html", "testing/web-platform/tests/mathml/relations/css-styling/displaystyle-014.html"], "git_node": null, "git_parents": [null], "node": "4d3a1568b0e24961e8c5adb46fc1e87ed1989e97", "parents": ["ffeb51048e9b089ec1a2899bbf11dbcca798b201"], "tags": []}, {"author": "Nick Burris \u003cnburris@chromium.org\u003e", "branch": "default", "desc": "Bug 1574282 [wpt PR 18469] - Create Web Platform Tests for Scroll to text, a=testonly\n\nAutomatic update from web-platform-tests\nCreate Web Platform Tests for Scroll to text\n\nAdd a web platform test that performs navigations to a test page with\nvarious targetText parameters and checks if the target page\nsuccessfully scrolled as expected. Using a BroadcastChannel is the only\nway to communicate whether the target page scrolled, since scroll to\ntext is specifically restricted from iframes or pages with an opener,\nso there's no other way for the test page to track the status of the\nchild target page.\n\nBug: 994299\nChange-Id: I69243e739c3a7469ac48647508e379f204ccfbf6\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1756707\nCommit-Queue: Nick Burris \u003cnburris@chromium.org\u003e\nReviewed-by: Robert Ma \u003crobertma@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#689453}\n\n--\n\nwpt-commits: 3c56e312080b972189b3dcfe57107b60527bb436\nwpt-pr: 18469\n", "files": ["testing/web-platform/tests/scroll-to-text-fragment/scroll-to-text-fragment-target.html", "testing/web-platform/tests/scroll-to-text-fragment/scroll-to-text-fragment.html"], "git_node": null, "git_parents": [null], "node": "33a19ec20cf62c07d8337f2772a79808a974290b", "parents": ["4d3a1568b0e24961e8c5adb46fc1e87ed1989e97"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1574282 [wpt PR 18469] - Update wpt metadata, a=testonly\n\nwpt-pr: 18469\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/scroll-to-text-fragment/scroll-to-text-fragment.html.ini"], "git_node": null, "git_parents": [null], "node": "c02557863b249066741f172df65a3a5db981fa2e", "parents": ["33a19ec20cf62c07d8337f2772a79808a974290b"], "tags": []}, {"author": "Dave Tapuska \u003cdtapuska@chromium.org\u003e", "branch": "default", "desc": "Bug 1570776 [wpt PR 17554] - Add ability for service worker to filter out frozen windows., a=testonly\n\nAutomatic update from web-platform-tests\nAdd ability for service worker to filter out frozen windows.\n\nAdd code to support handling of frozen clients. Frozen clients do not\nrun their event loop, so postMessage to them just causes problems. To\nallow service workers to continue working with frozen windows we expose\nincludeFrozen in the matchAll and the frozen attribute on the Client. If\na service worker calls focus on a client it will unfreeze the window when\nit is moved to have focus. This feature is currently marked as\nexperimental and an intent to ship will be sent.\n\nThis is specified in https://wicg.github.io/page-lifecycle/ and\nhttps://github.com/w3c/ServiceWorker/pull/1442\n\nBUG=957597\n\nChange-Id: I6abe1882e88c65dac99250db5bb7fa8d3a4b2b1d\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1677065\nCommit-Queue: Ken Buchanan \u003ckenrb@chromium.org\u003e\nReviewed-by: Ken Buchanan \u003ckenrb@chromium.org\u003e\nReviewed-by: Matt Falkenhagen \u003cfalken@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#689558}\n\n--\n\nwpt-commits: 3d052c54485970c1673500c1ba7d52182adf6f4f\nwpt-pr: 17554\n", "files": ["testing/web-platform/tests/service-workers/service-worker/clients-matchall-frozen.https.html", "testing/web-platform/tests/service-workers/service-worker/resources/clients-frame-freeze.html", "testing/web-platform/tests/service-workers/service-worker/resources/clients-matchall-worker.js"], "git_node": null, "git_parents": [null], "node": "d34dc9e00ee2c4ca00e2b78bdad1f7c51f68ba3e", "parents": ["c02557863b249066741f172df65a3a5db981fa2e"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1570776 [wpt PR 17554] - Update wpt metadata, a=testonly\n\nwpt-pr: 17554\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/service-workers/service-worker/clients-matchall-client-types.https.html.ini", "testing/web-platform/meta/service-workers/service-worker/clients-matchall-frozen.https.html.ini"], "git_node": null, "git_parents": [null], "node": "62a72299127dda255b6d6a420a6a2296319b5517", "parents": ["d34dc9e00ee2c4ca00e2b78bdad1f7c51f68ba3e"], "tags": []}, {"author": "Xiaocheng Hu \u003cxiaochengh@chromium.org\u003e", "branch": "default", "desc": "Bug 1575913 [wpt PR 18615] - Add parser and evaluation WPT for \u003clength\u003e involving min/max(), a=testonly\n\nAutomatic update from web-platform-tests\nAdd parser and evaluation WPT for \u003clength\u003e involving min/max()\n\nBug: 978682\nChange-Id: I428f84d516cf5ab4df8aa754f406008c034b6e24\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1764793\nReviewed-by: Emil A Eklund \u003ceae@chromium.org\u003e\nCommit-Queue: Xiaocheng Hu \u003cxiaochengh@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#689589}\n\n--\n\nwpt-commits: 52233cfa4b02c65739deabbaf038a81f28432cd6\nwpt-pr: 18615\n", "files": ["testing/web-platform/tests/css/css-values/minmax-length-computed.html", "testing/web-platform/tests/css/css-values/minmax-length-invalid.html"], "git_node": null, "git_parents": [null], "node": "972b8400031369dd346e45951c3ce6d8c5f7c333", "parents": ["62a72299127dda255b6d6a420a6a2296319b5517"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575913 [wpt PR 18615] - Update wpt metadata, a=testonly\n\nwpt-pr: 18615\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/css/css-values/minmax-length-computed.html.ini"], "git_node": null, "git_parents": [null], "node": "e9400421792967c9818bf26e9374628f2ff7d359", "parents": ["972b8400031369dd346e45951c3ce6d8c5f7c333"], "tags": []}, {"author": "Alex Cooper \u003calcooper@chromium.org\u003e", "branch": "default", "desc": "Bug 1574649 [wpt PR 18512] - [WebXR] Resolve required/optional features per the spec, a=testonly\n\nAutomatic update from web-platform-tests\n[WebXR] Resolve required/optional features per the spec\n\nThis adds support to resolve required/optional features against device\ncapabilities as well as sets up the plumbing for appropriately tailored\nconsent.\n\nA WPT test for lack of device support was also added, which required\nupdating the tests.\n\nBug: 991605\nChange-Id: Ibce6924492311544fd75ca36ed79aa855c943aad\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1757183\nAuto-Submit: Alexander Cooper \u003calcooper@chromium.org\u003e\nCommit-Queue: Daniel Cheng \u003cdcheng@chromium.org\u003e\nReviewed-by: Daniel Cheng \u003cdcheng@chromium.org\u003e\nReviewed-by: Jacob DeWitt \u003cjacde@chromium.org\u003e\nReviewed-by: Brandon Jones \u003cbajones@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#689605}\n\n--\n\nwpt-commits: 04c1d5adf9ab1e0b3b29a55599cf59727fcf9e93\nwpt-pr: 18512\n", "files": ["testing/web-platform/tests/resources/chromium/webxr-test.js", "testing/web-platform/tests/webxr/resources/webxr_test_constants.js", "testing/web-platform/tests/webxr/xrBoundedReferenceSpace_updates.https.html", "testing/web-platform/tests/webxr/xrReferenceSpace_originOffset.https.html", "testing/web-platform/tests/webxr/xrReferenceSpace_originOffsetBounded.https.html", "testing/web-platform/tests/webxr/xrSession_features_deviceSupport.https.html", "testing/web-platform/tests/webxr/xrSession_requestAnimationFrame_getViewerPose.https.html", "testing/web-platform/tests/webxr/xrSession_viewer_availability.https.html", "testing/web-platform/tests/webxr/xrView_match.https.html", "testing/web-platform/tests/webxr/xrView_oneframeupdate.https.html"], "git_node": null, "git_parents": [null], "node": "8496e1db47d0984be6e0a4aa2affeec402df030a", "parents": ["e9400421792967c9818bf26e9374628f2ff7d359"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1574649 [wpt PR 18512] - Update wpt metadata, a=testonly\n\nwpt-pr: 18512\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/webxr/xrSession_features_deviceSupport.https.html.ini", "testing/web-platform/meta/webxr/xrSession_viewer_availability.https.html.ini"], "git_node": null, "git_parents": [null], "node": "4152c82f4109b1b5df5c69cfb7162681d39395c9", "parents": ["8496e1db47d0984be6e0a4aa2affeec402df030a"], "tags": []}, {"author": "Domenic Denicola \u003cd@domenic.me\u003e", "branch": "default", "desc": "Bug 1575944 [wpt PR 18617] - Test \u003cframe\u003e.tabIndex, a=testonly\n\nAutomatic update from web-platform-tests\nTest \u003cframe\u003e.tabIndex\n\nFollows https://github.com/whatwg/html/pull/4859.\n\n--\n\nwpt-commits: