cc23a2fabb6", "parents": ["c7d7b0404bd515e4f0e26f61371df67c8eb5ecdc"], "tags": []}], "date": 1569437132, "git_changesets": [null, null], "user": "archaeopteryx@coole-files.de"}, "12048": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nnl -\u003e 0a2b5ecdfe36\nsl -\u003e b2433d3fecff", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "ef78b65ace6ea2890a2f8a13dd99016bdb2248ed", "parents": ["4c214d484fdc1384eb9022e5ea701cc23a2fabb6"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nnl -\u003e 0a2b5ecdfe36\nsl -\u003e 9ef06403585b", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "13a09bfb08af5287e25eee0807a957aa5291b618", "parents": ["ef78b65ace6ea2890a2f8a13dd99016bdb2248ed"], "tags": []}], "date": 1569452454, "git_changesets": [null, null], "user": "ffxbld"}, "12049": {"changesets": [{"author": "Matthew Noorenberghe \u003cmozilla@noorenberghe.ca\u003e", "branch": "default", "desc": "Bug 1423714 - Add an API to retrieve a password from Keychain by account and service. r=mstange a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45968", "files": ["browser/components/migration/components.conf", "browser/components/migration/moz.build", "browser/components/migration/nsIKeychainMigrationUtils.idl", "browser/components/migration/nsKeychainMigrationUtils.h", "browser/components/migration/nsKeychainMigrationUtils.mm", "widget/cocoa/nsCocoaUtils.h", "widget/cocoa/nsCocoaUtils.mm"], "git_node": null, "git_parents": [null], "node": "882e32d712a008d2baf12147816dc473289e5ea4", "parents": ["13a09bfb08af5287e25eee0807a957aa5291b618"], "tags": []}, {"author": "Matthew Noorenberghe \u003cmozilla@noorenberghe.ca\u003e", "branch": "default", "desc": "Bug 1423714 - Add a module to decrypt Chrome/Chromium Login Data from macOS. r=Gijs a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45969", "files": ["browser/components/migration/ChromeMacOSLoginCrypto.jsm", "browser/components/migration/moz.build"], "git_node": null, "git_parents": [null], "node": "6b26012e920beba837ccf21edc5785791fe3c148", "parents": ["882e32d712a008d2baf12147816dc473289e5ea4"], "tags": []}, {"author": "Matthew Noorenberghe \u003cmozilla@noorenberghe.ca\u003e", "branch": "default", "desc": "Bug 1423714 - Import logins from Chrome/Chromium on macOS. r=Gijs a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45155", "files": ["browser/components/aboutlogins/content/aboutLogins.html", "browser/components/aboutlogins/tests/browser/browser.ini", "browser/components/aboutlogins/tests/chrome/test_menu_button.html", "browser/components/migration/ChromeProfileMigrator.jsm", "browser/components/migration/tests/unit/Library/Application Support/Google/Chrome/Default/Login Data", "browser/components/migration/tests/unit/test_Chrome_passwords.js", "browser/components/migration/tests/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "90e626862af5a346f01f34ec65ef8c4d963c8f98", "parents": ["6b26012e920beba837ccf21edc5785791fe3c148"], "tags": []}, {"author": "Dana Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "bug 1571548 - support \"current user\" registry locations for enterprise certificates on Windows r=kjacobs,mhowell a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45720", "files": ["security/manager/ssl/EnterpriseRoots.cpp"], "git_node": null, "git_parents": [null], "node": "90e1fd734a20e8a9a2032d2393905e25cd3163b2", "parents": ["90e626862af5a346f01f34ec65ef8c4d963c8f98"], "tags": []}, {"author": "Nihanth Subramanya \u003cnhnt11@gmail.com\u003e", "branch": "default", "desc": "Bug 1575859 - Fix state label for cookie list items with exceptions. r=johannh a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44302", "files": ["browser/base/content/browser-siteProtections.js"], "git_node": null, "git_parents": [null], "node": "2b0f397d718c3276c8787c39201193fff2f9b4a7", "parents": ["90e1fd734a20e8a9a2032d2393905e25cd3163b2"], "tags": []}, {"author": "Bryce Seager van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576990 - Set durations on frames for the WMF decoder. r=dminor a=lizzard\n\nThis is a back out of changeset c52127007a01, i.e. reverts bug 1560440. That bug\nwas itself reverting a prior bug where we started setting the duration.\n\nThere are two scenarios involved, each with their own issues:\n- We don't set the duration when feeding the decoder (what we're doing prior to\n  this change). In this case the decoder will estimate durations for all\n  samples. This works in many cases, but leads to issues with files that have\n  non-uniform durations - as seen in bug 1576990 (this bug).\n- We do set the duration when feeding the decoder (what will happen after this\n  change). In this case the decoder will not estimate durations, except it still\n  seems to do so when fed 0 duration samples. Since our demuxing pipeline can\n  create 0 duration samples, this leads to issues with such files (as seen in\n  bug 1560440).\n\nThis patch fixes the former of the above, and the next patch in the chain will\naddress the latter.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46515", "files": ["dom/media/platforms/wmf/MFTDecoder.cpp", "dom/media/platforms/wmf/MFTDecoder.h", "dom/media/platforms/wmf/WMFAudioMFTManager.cpp", "dom/media/platforms/wmf/WMFVideoMFTManager.cpp"], "git_node": null, "git_parents": [null], "node": "01474942164b3aebdbada6350fd4d5c134526180", "parents": ["2b0f397d718c3276c8787c39201193fff2f9b4a7"], "tags": []}, {"author": "Bryce Seager van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576990 - Stop the WMF decoder estimating durations on 0 duration samples. r=dminor a=lizzard\n\nSet a trivial duration (1us) on 0 duration samples before feeding them to the\nWMF MFT decoder to prevent it from estimating the duration for such samples.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46516", "files": ["dom/media/platforms/wmf/MFTDecoder.cpp"], "git_node": null, "git_parents": [null], "node": "b7d9fad2146028e288f40557431805e2cd8874fd", "parents": ["01474942164b3aebdbada6350fd4d5c134526180"], "tags": []}, {"author": "Adam Gashlin \u003cagashlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1577317 - Add telemetry for \"fix update directory permissions\". r=rstrong a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46241", "files": ["toolkit/components/telemetry/Scalars.yaml", "toolkit/mozapps/update/UpdateService.jsm", "toolkit/mozapps/update/UpdateTelemetry.jsm"], "git_node": null, "git_parents": [null], "node": "42692bbe0a2525e65aba2e52597f44fad5713243", "parents": ["b7d9fad2146028e288f40557431805e2cd8874fd"], "tags": []}, {"author": "Scott \u003cscott.downe@gmail.com\u003e", "branch": "default", "desc": "Bug 1579480 - uplift newtab DS cards not removing idle callback r=nanj a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com//D46313", "files": ["browser/components/newtab/content-src/components/DiscoveryStreamComponents/DSCard/DSCard.jsx", "browser/components/newtab/data/content/activity-stream.bundle.js", "browser/components/newtab/test/unit/content-src/components/DiscoveryStreamComponents/DSCard.test.jsx"], "git_node": null, "git_parents": [null], "node": "870f8e24fea4e78bf5c2e6814d17cf23673b32f1", "parents": ["42692bbe0a2525e65aba2e52597f44fad5713243"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1580319 - Clear PopupNotifications UI state when no checkbox is present. r=prathiksha a=lizzard\n\nIn getUserMedia we didn't use to have prompts without a checkbox, thus this bug couldn't manifest.\nNow we do hide the checkbox for iframes, so this code path is triggered and doesn't properly\nreset the UI state between prompts.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45911", "files": ["browser/base/content/browser-addons.js", "browser/base/content/test/webrtc/browser_devices_get_user_media_screen.js", "browser/base/content/test/webrtc/head.js", "toolkit/modules/PopupNotifications.jsm"], "git_node": null, "git_parents": [null], "node": "b4c4862002c699584b75b0327b76be96c2f7a551", "parents": ["870f8e24fea4e78bf5c2e6814d17cf23673b32f1"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1582505 - OpenViewOnFocus should not open the view on the new tab page using a shortcut. r=adw a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46491", "files": ["browser/base/content/browser.js", "browser/components/urlbar/UrlbarInput.jsm", "browser/components/urlbar/tests/browser/browser_openViewOnFocus.js"], "git_node": null, "git_parents": [null], "node": "31d0b6ad87ec2998f0ec8f647c61a03fceb86fc9", "parents": ["b4c4862002c699584b75b0327b76be96c2f7a551"], "tags": []}, {"author": "Sam Foster \u003csfoster@mozilla.com\u003e", "branch": "default", "desc": "Bug 1582780 - Dont modify a empty-username login onGeneratedPasswordEditedOrFilled unless it is the auto-saved login. r=MattN a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46679", "files": ["toolkit/components/passwordmgr/LoginManagerParent.jsm", "toolkit/components/passwordmgr/test/browser/browser_generated_password_doorhangers.js"], "git_node": null, "git_parents": [null], "node": "d577eddf788820e8c6fbf527d6f9807ffe5acc38", "parents": ["31d0b6ad87ec2998f0ec8f647c61a03fceb86fc9"], "tags": []}, {"author": "Matthew Noorenbe