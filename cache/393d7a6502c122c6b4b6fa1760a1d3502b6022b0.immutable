ured-data/shared-array-buffers/window-failure.https.html.headers"], "git_node": null, "git_parents": [null], "node": "0aa129ddd17c56280259b733e63a3be2f9c1d128", "parents": ["9d5c92bbbf4b97c867de5eba0cb36d99399b4def"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1567279 [wpt PR 17909] - Update wpt metadata, a=testonly\n\nwpt-pr: 17909\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/html/infrastructure/safe-passing-of-structured-data/shared-array-buffers/window-failure.https.html.ini"], "git_node": null, "git_parents": [null], "node": "69eb020a79bc75ed5d2fbad40ecf0627c11ce151", "parents": ["0aa129ddd17c56280259b733e63a3be2f9c1d128"], "tags": []}, {"author": "Fr\u00e9d\u00e9ric Wang \u003cfwang@igalia.com\u003e", "branch": "default", "desc": "Bug 1575825 [wpt PR 18609] - MathML: Do not use new lines within \u003clink rel=\"help\"\u003e., a=testonly\n\nAutomatic update from web-platform-tests\nMathML: Do not use new lines withing \u003clink rel=\"help\"\u003e. (#18609)\n\nOtherwise\nhttps://github.com/mathml-refresh/mathml-core/blob/master/wpt/extract.sh\ncannot properly extract them.\n\nThis is also more consistent with the templates from\nhttps://web-platform-tests.org/writing-tests/reftest-tutorial.html#writing-the-test-file\n--\n\nwpt-commits: d3fba1a74cfc532b3b6736f5c7ed722acccd7207\nwpt-pr: 18609\n", "files": ["testing/web-platform/tests/mathml/relations/html5-tree/clipboard-event-handlers.tentative.html", "testing/web-platform/tests/mathml/relations/html5-tree/css-inline-style-interface.tentative.html", "testing/web-platform/tests/mathml/relations/html5-tree/html-or-foreign-element-interfaces.tentative.html", "testing/web-platform/tests/mathml/relations/html5-tree/math-global-event-handlers.tentative.html"], "git_node": null, "git_parents": [null], "node": "cc04ceb500105ed959a099d4adeb1040edf5d85d", "parents": ["69eb020a79bc75ed5d2fbad40ecf0627c11ce151"], "tags": []}, {"author": "Fr\u00e9d\u00e9ric Wang \u003cfwang@igalia.com\u003e", "branch": "default", "desc": "Bug 1576581 [wpt PR 18668] - Add tests for display: contents on MathML elements, a=testonly\n\nAutomatic update from web-platform-tests\nAdd tests for display: contents on MathML elements (#18668)\n\nhttps://github.com/mathml-refresh/mathml/issues/90\n--\n\nwpt-commits: 94a0b420301fc9d7da16097083ecdce927e22343\nwpt-pr: 18668\n", "files": ["testing/web-platform/tests/mathml/relations/css-styling/display-contents.html", "testing/web-platform/tests/mathml/relations/css-styling/not-participating-to-parent-layout.html"], "git_node": null, "git_parents": [null], "node": "518f1d58aca0f6172291259876cedb195550e53f", "parents": ["cc04ceb500105ed959a099d4adeb1040edf5d85d"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576581 [wpt PR 18668] - Update wpt metadata, a=testonly\n\nwpt-pr: 18668\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/mathml/relations/css-styling/not-participating-to-parent-layout.html.ini"], "git_node": null, "git_parents": [null], "node": "f1052bf49e9af0ec5a3c94707bc58cd7396eceea", "parents": ["518f1d58aca0f6172291259876cedb195550e53f"], "tags": []}, {"author": "Philip J\u00e4genstedt \u003cphilip@foolip.org\u003e", "branch": "default", "desc": "Bug 1576594 [wpt PR 18674] - Convert the Media Source idlharness.js test to use idl_test, a=testonly\n\nAutomatic update from web-platform-tests\nConvert the Media Source idlharness.js test to use idl_test (#18674)\n\nAlso rename it to .window.js since nothing is worker-exposed.\n--\n\nwpt-commits: bbaa31bd1cb350f8fab6da80c8159182e37e1b62\nwpt-pr: 18674\n", "files": ["testing/web-platform/tests/media-source/idlharness.any.js", "testing/web-platform/tests/media-source/idlharness.window.js"], "git_node": null, "git_parents": [null], "node": "d979bcd30c36f66ff6e59b5a3e52f52801660adb", "parents": ["f1052bf49e9af0ec5a3c94707bc58cd7396eceea"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576594 [wpt PR 18674] - Update wpt metadata, a=testonly\n\nwpt-pr: 18674\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/media-source/idlharness.any.js.ini", "testing/web-platform/meta/media-source/idlharness.window.js.ini"], "git_node": null, "git_parents": [null], "node": "28bcf3624fbb29e2c541db78ad21bf3880eccc41", "parents": ["d979bcd30c36f66ff6e59b5a3e52f52801660adb"], "tags": []}, {"author": "Philip J\u00e4genstedt \u003cphilip@foolip.org\u003e", "branch": "default", "desc": "Bug 1576089 [wpt PR 18631] - [Azure Pipelines] Trigger full runs on push instead of schedule, a=testonly\n\nAutomatic update from web-platform-tests\n[Azure Pipelines] Trigger full runs on push instead of schedule (#18631)\n\nWhen daily runs of Safari were set up, using the epochs/* branch push\nas a trigger didn't work, and we switched to a schedule:\nhttps://github.com/web-platform-tests/wpt/issues/14836\n\nHowever, this now seems to have been resolved on Azure Pipelines,\nno-op CI builds are being triggered for each branch push:\n - master: https://dev.azure.com/web-platform-tests/wpt/_build/results?buildId=28363\n - epochs/six_hourly: https://dev.azure.com/web-platform-tests/wpt/_build/results?buildId=28387\n - epochs/twelve_hourly: https://dev.azure.com/web-platform-tests/wpt/_build/results?buildId=28386\n - epochs/daily: https://dev.azure.com/web-platform-tests/wpt/_build/results?buildId=28385\n\nThis will make it easy to change the schedule for each configuration\nindividually, but keep all on six_hourly for now, as frequent runs are\nuseful for debugging reliability issues.\n--\n\nwpt-commits: d7cc037d05aadb3c064b2d43134a0d70829c0abb\nwpt-pr: 18631\n", "files": ["testing/web-platform/tests/.azure-pipelines.yml"], "git_node": null, "git_parents": [null], "node": "b912f5d04be40e4a4cc2ee4cde6191d3efddafc0", "parents": ["28bcf3624fbb29e2c541db78ad21bf3880eccc41"], "tags": []}, {"author": "Yutaka Hirano \u003cyhirano@chromium.org\u003e", "branch": "default", "desc": "Bug 1576582 [wpt PR 18670] - Fetch: data: URL HEAD request should result in empty response body, a=testonly\n\nAutomatic update from web-platform-tests\nFetch: data: URL HEAD request should result in empty response body\n\n--\n\nwpt-commits: 91b79fa82ec6fa6529a76f40726e07a6f3e09929\nwpt-pr: 18670\n", "files": ["testing/web-platform/tests/fetch/api/basic/scheme-data.any.js"], "git_node": null, "git_parents": [null], "node": "2fd02a2024462c80728beeef2f6cc783f763c932", "parents": ["b912f5d04be40e4a4cc2ee4cde6191d3efddafc0"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576582 [wpt PR 18670] - Update wpt metadata, a=testonly\n\nwpt-pr: 18670\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/fetch/api/basic/scheme-data.any.js.ini"], "git_node": null, "git_parents": [null], "node": "a911782d58c5bc5f98319b09e2204051984c5568", "parents": ["2fd02a2024462c80728beeef2f6cc783f763c932"], "tags": []}, {"author": "Philip J\u00e4genstedt \u003cphilip@foolip.org\u003e", "branch": "default", "desc": "Bug 1576094 [wpt PR 18632] - [Azure Pipelines] increase Safari parallel jobs from 4 to 5, a=testonly\n\nAutomatic update from web-platform-tests\n[Azure Pipelines] increase Safari parallel jobs from 4 to 5 (#18632)\n\nReasons:\n\n 1. The slowest STP job (job 1) now takes about 2h5m and is thus the\n    slowest link in getting new aligned runs on wpt.fyi.\n 2. Debugging issues is faster if runs are faster.\n 3. It's happened a few times that Azure Pipelines loses connection\n    with the agent. Less work in each job might make this less likely.\n--\n\nwpt-commits: 688a08c9ddd3551e07bd4c1bd6058998d2550c35\nwpt-pr: 18632\n", "files": ["testing/web-platform/tests/.azure-pipelines.yml"], "git_node": null, "git_parents": [null], "node": "517813958b0b39c8ab8e37625db19bcfdf18b1b7", "parents": ["a911782d58c5bc5f98319b09e2204051984c5568"], "tags": []}, {"author": "Stephen McGruer \u003csmcgruer@chromium.org\u003e", "branch": "default", "desc": "Bug 1576519 [wpt PR 18663] - Port a few color-related interpolation tests to WPT, a=testonly\n\nAutomatic update from web-platform-tests\nPort a few color-related interpolation tests to WPT\n\nBug: 900581\nChange-Id: I3a9a292495b86ddf32ebfd67a1531d5995e5879a\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1769314\nReviewed-by: Xida Chen \u003cxidachen@chromium.org\u003e\nCommit-Queue: Stephen McGruer \u003csmcgruer@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#690331}\n\n--\n\nwpt-commits: 227aa0eb0c0e8b413365935336fefa5fe70abe0e\nwpt-pr: 18663\n", "files": ["testing/web-platform/tests/css/css-color/animation/color-interpolation.html", "testing/web-platform/tests/css/css-ui/animation/caret-color-interpolation.html"], "git_node": null, "git_parents": [null], "node": "d2cc087b8ac4cb4837b9da660352fe9d0aef60b8", "parents": ["517813958b0b39c8ab8e37625db19bcfdf18b1b7"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576519 [wpt PR 18663] - Update wpt metadata, a=testonly\n\nwpt-pr: 18663\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/css/css-color/animation/color-interpolation.html.ini", "testing/web-platform/meta/css/css-ui/animation/caret-color-interpolation.html.ini"], "git_node": null, "git_parents": [null], "node": "595f275683778cca9a9f5b62319c99f8306fc15c", "parents": ["d2cc087b8ac4cb4837b9da660352fe9d0aef60b8"], "tags": []}, {"author": "Stephen McGruer \u003csmcgruer@chromium.org\u003e", "branch": "default", "desc": "Bug 1576517 [wpt PR 18662] - Port flex-*-interpolation.html tests to WPT, a=testonly\n\nAutomatic update from web-platform-tests\nPort flex-*-interpolation.html tests to WPT\n\nBug: 900581\nChange-Id: I9cd2582aea4792c6bc0fa68f9bbf20f17a74a90c\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1768551\nReviewed-by: Xida Chen \u003cxidachen@chromium.org\u003e\nCommit-Queue: Stephen McGruer \u003csmcgruer@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#690332}\n\n--\n\nwpt-commits: 42e0b913835a6d8d195cba39cfd540f0b8ebfa4b\nwpt-pr: 18662\n", "files": ["testing/web-platform/tests/css/css-flexbox/animation/flex-basis-interpolation.html", "testing/web-platform/tests/css/css-flexbox/animation/flex-grow-interpolation.html", "testing/web-platform/tests/css/css-flexbox/animation/flex-shrink-interpolation.html"], "git_node": null, "git_parents": [null], "node": "99bfc84f572e94e7de835046e5e848335aa13f13", "parents": ["595f275683778cca9a9f5b62319c99f8306fc15c"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576517 [wpt PR 18662] - Update wpt metadata, a=testonly\n\nwpt-pr: 18662\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/css/css-flexbox/animation/flex-basis-interpolation.html.ini", "testing/web-platform/meta/css/css-flexbox/animation/flex-grow-interpolation.html.ini", "testing/web-platform/meta/css/css-flexbox/animation/flex-shrink-interpolation.html.ini"], "git_node": null, "git_parents": [null], "node": "e9ae2ae34bf6bc42e21b6d65f7a64040a91b7cf3", "parents": ["99bfc84f572e94e7de835046e5e848335aa13f13"], "tags": []}, {"author": "Stephen McGruer \u003csmcgruer@chromium.org\u003e", "branch": "default", "desc": "Bug 1576520 [wpt PR 18664] - Port outline-*-interpolation.html to WPT, a=testonly\n\nAutomatic update from web-platform-tests\nPort outline-*-interpolation.html to WPT\n\nBug: 900581\nChange-Id: I40b7d6f983d37726b843e82ad5ba794cec9c1214\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1768666\nReviewed-by: Xida Chen \u003cxidachen@chromium.org\u003e\nCommit-Queue: Stephen McGruer \u003csmcgruer@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#690330}\n\n--\n\nwpt-commits: 552bd3bf8bc1beb528c6e9b6b730c3cbc3968345\nwpt-pr: 18664\n", "files": ["testing/web-platform/tests/css/css-ui/animation/outline-color-interpolation.html", "testing/web-platform/tests/css/css-ui/animation/outline-offset-interpolation.html", "testing/web-platform/tests/css/css-ui/animation/outline-width-interpolation.html"], "git_node": null, "git_parents": [null], "node": "2724049ee8a930629b76f8fd58766fa64ae01f94", "parents": ["e9ae2ae34bf6bc42e21b6d65f7a64040a91b7cf3"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576520 [wpt PR 18664] - Update wpt metadata, a=testonly\n\nwpt-pr: 18664\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/css/css-ui/animation/outline-color-interpolation.html.ini", "testing/web-platform/meta/css/css-ui/animation/outline-offset-interpolation.html.ini", "testing/web-platform/meta/css/css-ui/animation/outline-width-interpolation.html.ini"], "git_node": null, "git_parents": [null], "node": "8046d65970ac3a826ae9f37ca99ed293583fef22", "parents": ["2724049ee8a930629b76f8fd58766fa64ae01f94"], "tags": []}, {"author": "Aleks Totic \u003catotic@chromium.org\u003e", "branch": "default", "desc": "Bug 1576251 [wpt PR 18646] - [LayoutNG] Fix DCHECK abspos crash, a=testonly\n\nAutomatic update from web-platform-tests\n[LayoutNG] Fix DCHECK abspos crash\n\nDo not DCHECK if values are saturated.\n\nBug: 996085\nChange-Id: I1f9b299aef1f8bd5f18d6f4f05d50e33a7c1609d\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1769517\nCommit-Queue: Aleks Totic \u003catotic@chromium.org\u003e\nReviewed-by: Ian Kilpatrick \u003cikilpatrick@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#690402}\n\n--\n\nwpt-commits: 35f4c4c2a0baadbc5419a58750347076988c0e72\nwpt-pr: 18646\n", "files": ["testing/web-platform/tests/css/css-position/position-absolute-crash-chrome-012.html"], "git_node": null, "git_parents": [null], "node": "648a52f92d7168f62162a35405997f7dea61ebb1", "parents": ["8046d65970ac3a826ae9f37ca99ed293583fef22"], "tags": []}, {"author": "Hiroshige Hayashizaki \u003chiroshige@chromium.org\u003e", "branch": "default", "desc": "Bug 1568665 [wpt PR 18055] - [WPT/referrer-policy] Fix races around history.back(), a=testonly\n\nAutomatic update from web-platform-tests\n[WPT/referrer-policy] Fix races around history.back()\n\nBecause history.back() works asynchronously,\nthere are races between history.back() and subsequent\npromise_test()s.\nFor exmample:\n\n1. The first 4K-length-referrer subtest finishes and history.back() is called.\n2. The second subtest starts, and replaceState() is called.\n3. The change to `location` caused by hisotory.back() in Step 1\n   comes into effect.\n4. The second subtest finishes -- at this time, `location` is the\n   original Document URL\n   (not '.../AAAA....AAA' set by replaceState() in Step 2)\n   and thus history.back() has no effects.\n\nThis CL fixes the race by waiting for `popstate` events that should\nbe fired at the end of async tasks of history.back().\n\nThis CL reverts the changes to `referrer-policy-test-case.sub.js` in\nhttps://github.com/web-platform-tests/wpt/pull/18401\nhttps://github.com/web-platform-tests/wpt/commit/8b46cbf469fd282e56ea3ef883e8a8cb509d49d6\nand waits for popstate instead, because single asyncResolve() isn't sufficient\nto fix the race condition described above.\n\nBug: 906850\nChange-Id: I21e7b8dd6001a13230fd8dca4d1693ae956958ed\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1717268\nCommit-Queue: Hiroshige Hayashizaki \u003chiroshige@chromium.org\u003e\nReviewed-by: Mike West \u003cmkwst@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#690280}\n\n--\n\nwpt-commits: edd8fe11e357990cf3dafff83504c4f4a605028c\nwpt-pr: 18055\n", "files": ["testing/web-platform/tests/referrer-policy/generic/referrer-policy-test-case.sub.js"], "git_node": null, "git_parents": [null], "node": "0f7f604a2c761df9d21daba23b9a131790c28702", "parents": ["648a52f92d7168f62162a35405997f7dea61ebb1"], "tags": []}, {"author": "autofoolip \u003cauto@foolip.org\u003e", "branch": "default", "desc": "Bug 1575459 [wpt PR 18576] - Update interfaces/html.idl, a=testonly\n\nAutomatic update from web-platform-tests\nUpdate interfaces/html.idl (#18576)\n\nSource: https://github.com/tidoust/reffy-reports/blob/205b736/whatwg/idl/html.idl\nBuild: https://travis-ci.org/tidoust/reffy-reports/builds/576128771\n--\n\nwpt-commits: cf69fc8e607fb6c39f0b458cd5a93832994e2adf\nwpt-pr: 18576\n", "files": ["testing/web-platform/tests/interfaces/html.idl"], "git_node": null, "git_parents": [null], "node": "31f4b2680c2aaa84cf93e8ede3afedcc7f564ffa", "parents": ["0f7f604a2c761df9d21daba23b9a131790c28702"], "tags": []}, {"author": "Rohan Pavone \u003crohpavone@chromium.org\u003e", "branch": "default", "desc": "Bug 1573920 [wpt PR 18429] - [ChromeDriver] Creates new ChromeDriver SetPermission command, a=testonly\n\nAutomatic update from web-platform-tests\n[ChromeDriver] Creates new ChromeDriver SetPermission command\n\nAdds W3C WebDriver extension, SetPermission, to support simple\npermissions.\n\nDesign doc: go/chromedriver-permissions-ext\n\nof the spec, the tests do not test much, so new tests were added to\nrun_py_tests to enfore certain behaviors.\n\nTested: Passing W3C permissions tests. Due to the relaxed definition\nBug: chromedriver:2212\nChange-Id: Ie61cc4c0e18c714f93ac7ab918d0cec0e4210e1e\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1666438\nReviewed-by: Balazs Engedy \u003cengedy@chromium.org\u003e\nReviewed-by: Robert Ma \u003crobertma@chromium.org\u003e\nReviewed-by: Avi Drissman \u003cavi@chromium.org\u003e\nReviewed-by: Caleb Rouleau \u003ccrouleau@chromium.org\u003e\nReviewed-by: John Chen \u003cjohnchen@chromium.org\u003e\nCommit-Queue: Rohan Pavone \u003crohpavone@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#690496}\n\n--\n\nwpt-commits: f4a5e48093eeafe085fbae92253acd2c967ced4d\nwpt-pr: 18429\n", "files": ["testing/web-platform/tests/webdriver/tests/permissions/set.py"], "git_node": null, "git_parents": [null], "node": "ae05a3a6e4198d0fc78ddffd9f4603175757c9ec", "parents": ["31f4b2680c2aaa84cf93e8ede3afedcc7f564ffa"], "tags": []}, {"author": "Adam Rice \u003cricea@chromium.org\u003e", "branch": "default", "desc": "Bug 1576638 [wpt PR 18679] - Fix send-redirect-bogus-sync.htm when run locally, a=testonly\n\nAutomatic update from web-platform-tests\nFix send-redirect-bogus-sync.htm when run locally\n\nThe wpt xhr/send-redirect-bogus.sync.htm will timeout when run in a\nnetwork where a host named \"z\" exists but is not responding.\n\nChange the hostname used in the test to \"z.\" which reduces the risk that\nit will resolve.\n\nChange-Id: Ia368e6adaa850fa550788a9b26e422b3f32752b8\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1768505\nReviewed-by: Yutaka Hirano \u003cyhirano@chromium.org\u003e\nCommit-Queue: Adam Rice \u003cricea@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#690586}\n\n--\n\nwpt-commits: 481a2b6ee5ff1764ad031646e52044aae6ff311c\nwpt-pr: 18679\n", "files": ["testing/web-platform/tests/xhr/send-redirect-bogus-sync.htm"], "git_node": null, "git_parents": [null], "node": "4eb1555168d0c4ea18bb4f8fa9e7a758d8a28d82", "parents": ["ae05a3a6e4198d0fc78ddffd9f4603175757c9ec"], "tags": []}, {"author": "Stephen McGruer \u003csmcgruer@chromium.org\u003e", "branch": "default", "desc": "Bug 1576625 [wpt PR 18675] - Port a small collection of basic interpolation tests to WPT, a=testonly\n\nAutomatic update from web-platform-tests\nPort a small collection of basic interpolation tests to WPT\n\nThese are mostly unrelated properties, but are also simple test cases.\n\nBug: 900581\nChange-Id: I2353dbcb6ee733f9c0a9289b46eae4e00ade7c98\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1771576\nReviewed-by: Xida Chen \u003cxidachen@chromium.org\u003e\nCommit-Queue: Stephen McGruer \u003csmcgruer@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#690597}\n\n--\n\nwpt-commit