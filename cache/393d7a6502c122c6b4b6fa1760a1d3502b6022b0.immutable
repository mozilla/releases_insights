7df2f9b21f054d7e0fd56c98006c3af9", "parents": ["219e3b810852679fc915f460e02ec196a0a1bcbc"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576639 - Fix Print Preview's Custom Scale prompt title. r=flod,fluent-reviewers a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44670", "files": ["toolkit/components/printing/content/printPreviewToolbar.js", "toolkit/locales/en-US/toolkit/printing/printPreview.ftl"], "git_node": null, "git_parents": [null], "node": "3735e8cb4cad14ea19e9f005205bf93236e9bba5", "parents": ["33133c777df2f9b21f054d7e0fd56c98006c3af9"], "tags": []}], "date": 1567795655, "git_changesets": [null, null, null, null, null, null, null, null], "user": "shindli@mozilla.com"}, "11906": {"changesets": [{"author": "Honza Bambas \u003chonzab.moz@firemni.cz\u003e", "branch": "default", "desc": "Bug 1559088 - Fix test_redirect-caching_failure.js to again do what it has to, r=kershaw, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43796", "files": ["netwerk/test/unit/test_redirect-caching_failure.js", "netwerk/test/unit/test_redirect_failure.js", "netwerk/test/unit/xpcshell.ini", "netwerk/test/unit_ipc/test_redirect-caching_failure_wrap.js", "netwerk/test/unit_ipc/test_redirect_failure_wrap.js"], "git_node": null, "git_parents": [null], "node": "9399706f30aac2ac36c8a32311a1f30e418b88b0", "parents": ["3735e8cb4cad14ea19e9f005205bf93236e9bba5"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1519586 - Fix js error in browser_aboutdevtools_reuse_existing.js r=ladybenko, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44345", "files": ["devtools/startup/aboutdevtools/test/head.js"], "git_node": null, "git_parents": [null], "node": "98ff4e66fdd3d6471df4626efdc56df135428af6", "parents": ["9399706f30aac2ac36c8a32311a1f30e418b88b0"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1577795 - Fix browser_webconsole_reverse_search_initial_value.js intermittent. r=Honza, a=test-only\n\nThe failures were about pending requests to highlighters,\nbecause we were logging node elements. Since we don't\nreally need to do that, we simply change the command\nto not lod elements.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44367", "files": ["devtools/client/webconsole/test/browser/browser_webconsole_reverse_search_initial_value.js"], "git_node": null, "git_parents": [null], "node": "6be86c7f424d47e5cae251bc4e910f13ae0b70fe", "parents": ["98ff4e66fdd3d6471df4626efdc56df135428af6"], "tags": []}, {"author": "Erica Wright \u003cewright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1570537 - Fix intermittent by waiting for condition. r=johannh, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44176", "files": ["browser/components/protections/test/browser/browser_protections_monitor.js"], "git_node": null, "git_parents": [null], "node": "f3b9bc258035ce722c082c19f06e1ca0e08e918a", "parents": ["6be86c7f424d47e5cae251bc4e910f13ae0b70fe"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1273656 - Add wait before trying to click in browser_html_tooltip-02.js r=daisuke, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44356", "files": ["devtools/client/shared/test/browser_html_tooltip-02.js"], "git_node": null, "git_parents": [null], "node": "4f537bd2ad2653507be638221268dc1cc21381cd", "parents": ["f3b9bc258035ce722c082c19f06e1ca0e08e918a"], "tags": []}], "date": 1567798817, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "11907": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nfr -\u003e 09b32eb04699\nhu -\u003e ae52566585a5", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "c1b253c038ab963cf7de9446dac8481cf9577dd9", "parents": ["4f537bd2ad2653507be638221268dc1cc21381cd"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nbe -\u003e d2f78f07a34f\nfr -\u003e d279d147aa32\ngn -\u003e 0e3c2e837331\nhu -\u003e ae52566585a5\nia -\u003e bcc3c79c430c", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "c2a789be00bcd87138de9430b6d7cfc4b892216e", "parents": ["c1b253c038ab963cf7de9446dac8481cf9577dd9"], "tags": []}], "date": 1567814445, "git_changesets": [null, null], "user": "ffxbld"}, "11908": {"changesets": [{"author": "harry \u003chtwyford@mozilla.com\u003e", "branch": "default", "desc": "Bug 1577708 - Increase contrast on search settings button. r=dao a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44415", "files": ["browser/themes/shared/searchbar.inc.css"], "git_node": null, "git_parents": [null], "node": "585345b7a19fb3f9b3ebaba578852247f4f83d52", "parents": ["c2a789be00bcd87138de9430b6d7cfc4b892216e"], "tags": []}, {"author": "Kershaw Chang \u003ckershaw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576183 - Don't access worker promise if already shutdown r=baku a=lizzard\n\nThe reason of the assertion failure is that WorkerFetchResolver::Shutdown is already called, but we still call WorkerRun from WorkerFetchResponseEndRunnable::Cancel [1].\nThis patch adds a flag mIsShutdown to avoid doing WorkerRun if mIsShutdown is true.\n\n\n[1] https://searchfox.org/mozilla-central/rev/325c1a707819602feff736f129cb36055ba6d94f/dom/fetch/Fetch.cpp#733\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43777", "files": ["dom/fetch/Fetch.cpp"], "git_node": null, "git_parents": [null], "node": "7ac0d0a8e103c885bf59902b5399d6a9f91ba11e", "parents": ["585345b7a19fb3f9b3ebaba578852247f4f83d52"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1577872 - Bump MinGW version for updater fix r=froydnj a=lizzard\n\nThis picks up 0a1d495478d8ed1a94fc77b9dbb428b7e0372588 needed by\nTor for the updater.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44535", "files": ["taskcluster/ci/fetch/toolchains.yml"], "git_node": null, "git_parents": [null], "node": "0c8883322ae6a4b6634cd5ce76b262211acc31f5", "parents": ["7ac0d0a8e103c885bf59902b5399d6a9f91ba11e"], "tags": []}, {"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576605 - Don't fire extra MozTogglePictureInPicture when clicking toggle on videos with built-in controls. r=JSON_voorhees a=lizzard\n\nIn bug 1568320, we made it so that the PictureInPictureToggleChild attaches handlers to\nthe toggle, even on videos that have controls by default, so we don't need the\nvideocontrols UAWidget to call the method for firing the event anymore.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44270", "files": ["toolkit/content/widgets/videocontrols.js"], "git_node": null, "git_parents": [null], "node": "a1ec25f256c899946297d134eebdecb3ba5fff66", "parents": ["0c8883322ae6a4b6634cd5ce76b262211acc31f5"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1567440 - Don't use lower fill-opacity for the shield icon. r=timhuang a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44528", "files": ["browser/themes/shared/identity-block/identity-block.inc.css", "browser/themes/shared/identity-block/tracking-protection-animation-brighttext.svg", "browser/themes/shared/identity-block/tracking-protection-animation.svg"], "git_node": null, "git_parents": [null], "no