ces.mozilla.com/D44526", "files": ["layout/base/nsRefreshDriver.cpp"], "git_node": null, "git_parents": [null], "node": "7cbf56646abc48796c70db8e93823db3e4ede0df", "parents": ["1a8df1c35a0280137aed2ebc0e0207caba2ffb42"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1577558 - Add proper argument checking in AntiTrackingCommon::SaveFirstPartyStorageAccessGrantedForOriginOnParentProcess(); r=johannh a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44287", "files": ["toolkit/components/antitracking/AntiTrackingCommon.cpp"], "git_node": null, "git_parents": [null], "node": "67939ba141763bc71161fefdd401212f96b62b8b", "parents": ["7cbf56646abc48796c70db8e93823db3e4ede0df"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1577563 - Add proper argument checking in AntiTrackingCommon::CreateStoragePermissionKey(); r=johannh a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44286", "files": ["toolkit/components/antitracking/AntiTrackingCommon.cpp"], "git_node": null, "git_parents": [null], "node": "dfc9897032837feda9d708565c8a0904c4a9ce2f", "parents": ["67939ba141763bc71161fefdd401212f96b62b8b"], "tags": []}], "date": 1568008771, "git_changesets": [null, null, null, null], "user": "nbeleuzu@mozilla.com"}, "11913": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nbn -\u003e f49b7edf5d94\ncs -\u003e 3a844100b671\nda -\u003e 9e6800ec23bd\nde -\u003e 454403653c89\neo -\u003e d01d2fc50a18\nes-CL -\u003e 70c69d72a169\neu -\u003e 1f932419db5c\nfr -\u003e 91ae44453340\nfy-NL -\u003e 40dae758d93f\nhe -\u003e f7c9e49593d8\nnl -\u003e 6fbe1410ee7c\nrm -\u003e 38662bd46166", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "c2