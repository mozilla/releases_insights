, "git_parents": [null], "node": "4ab9abfb9b7343a63e59e785f79d0434f8ee58a5", "parents": ["a80f2fc253935a7e9bcf4d62cc146991fde58c6c"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\neo -\u003e c69be6989b22\net -\u003e c9b7ea29476e\nfi -\u003e f89847bb9569\nhr -\u003e e8f66e52869f\nia -\u003e d4f1225c825e\nis -\u003e cdadbbf568c7\nnb-NO -\u003e 2af5a46da5b2\nnn-NO -\u003e 6cadb20fb7d6\nro -\u003e 0fe2f57710ec\nsl -\u003e c0fb8dd03ffe", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "22309fb72120393427e41ab2354c68b49767bf7e", "parents": ["4ab9abfb9b7343a63e59e785f79d0434f8ee58a5"], "tags": []}], "date": 1569834044, "git_changesets": [null, null], "user": "ffxbld"}, "12071": {"changesets": [{"author": "Daosheng Mu \u003cdaoshengmu@gmail.com\u003e", "branch": "default", "desc": "Bug 1510622 - Initilize OpenVR controller haptic thread when the first time to do vibration. a=lizzard\n\nReviewers: kip\n\nReviewed By: kip\n\nBug #: 1510622\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46227", "files": ["gfx/vr/service/OpenVRSession.cpp"], "git_node": null, "git_parents": [null], "node": "ab1a2e4cbda57c895193994ce83d41df603eb69d", "parents": ["22309fb72120393427e41ab2354c68b49767bf7e"], "tags": []}, {"author": "Matt Howell \u003cmhowell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1578489 - New Windows installer icon. r=agashlin a=lizzard\n\nSummary:\nThis patch includes:\n* The new icon file itself\n* A modified Win32 SFX binary with the icon resource replaced and no other changes\n* A rebuilt ARM64 binary (because rebuilding it is just as easy as resource hacking it)\n* And I also took the opportunity to update the VC project to the 2019 toolchain\n  and removed the requirement for a particular Windows 10 SDK version.\n\nReviewers: agashlin\n\nReviewed By: agashlin\n\nBug #: 1578489\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46846", "files": ["other-licenses/7zstub/firefox/7zSD.ARM64.sfx", "other-licenses/7zstub/firefox/7zSD.Win32.sfx", "other-licenses/7zstub/firefox/SFXSetup.vcxproj", "other-licenses/7zstub/firefox/setup.ico"], "git_node": null, "git_parents": [null], "node": "47397a99bd0a0ed8360f60fbd6ebb969d7bc7703", "parents": ["ab1a2e4cbda57c895193994ce83d41df603eb69d"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1583170 - Dispatch nsNotifyAddrListener runnable after creating thread r=mayhemer a=lizzard\n\nSummary:\nBug 1576386 converted the thread into a threadpool, but when changing that it failed to dispatch the runnable to the thread/threadpool as before.\nAs a result nsNotifyAddrListener stopped listening for network change events on windows.\n\nReviewers: mayhemer, michal\n\nReviewed By: michal\n\nBug #: 1583170\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46932", "files": ["netwerk/system/win32/nsNotifyAddrListener.cpp"], "git_node": null, "git_parents": [null], "node": "8a079c3ff32f147fa864990e6fcf9b79efcf27c3", "parents": ["47397a99bd0a0ed8360f60fbd6ebb969d7bc7703"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1583837 - allow more significant increases in font size / zoom in reader mode, more quickly, r?jaws a=lizzard\n\nReviewers: jaws\n\nReviewed By: jaws\n\nBug #: 1583837\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47327", "files": ["toolkit/components/reader/AboutReader.jsm"], "git_node": null, "git_parents": [null], "node": "7894b0884d01d5e6e93ed85ec14bf0890dc195b0", "parents": ["8a079c3ff32f147fa864990e6fcf9b79efcf27c3"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1583985 - move breach alerts checkbox in markup to avoid its width enlarging the content box unnecessarily, r?MattN,jaws a=lizzard\n\nReviewers: MattN, jaws\n\nReviewed By: MattN\n\nBug #: 1583985\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47187", "files": ["browser/components/preferences/in-content/privacy.inc.xul"], "git_node": null, "git_parents": [null], "node": "a0d36046f60deb3f25336915332b0e83a509adcc", "parents": ["7894b0884d01d5e6e93ed85ec14bf0890dc195b0"], "tags": []}, {"author": "Matthew Noorenberghe \u003cmozilla@noorenberghe.ca\u003e", "branch": "default", "desc": "Bug 1584261 - Prolong the life of some migration telemetry histograms and update their metadata. r=Gijs a=lizzard\n\nReviewers: Gijs\n\nReviewed By: Gijs\n\nSubscribers: janerik\n\nBug #: 1584261\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47318", "files": ["toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "2e2d5a0f2a5f85f7bb7b83c8e70aca500048c135", "parents": ["a0d36046f60deb3f25336915332b0e83a509adcc"], "tags": []}], "date": 1569838630, "git_changesets": [null, null, null, null, null, null], "user": "dluca@mozilla.com"}, "12072": {"changesets": [{"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 47397a99bd0a (bug 1578489) for landing incomplete. a=backout", "files": ["other-licenses/7zstub/firefox/7zSD.ARM64.sfx", "other-licenses/7zstub/firefox/7zSD.Win32.sfx", "other-licenses/7zstub/firefox/SFXSetup.vcxproj", "other-licenses/7zstub/firefox/setup.ico"], "git_node": null, "git_parents": [null], "node": "2f8e434edfbe5910019bdb29e8a02352864e9d35", "parents": ["2e2d5a0f2a5f85f7bb7b83c8e70aca500048c135"], "tags": []}, {"author": "Matt Howell \u003cmhowell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1578489 - New Windows installer icon. r=agashlin a=lizzard\n\nThis patch includes:\n* The new icon file itself\n* A modified Win32 SFX binary with the icon resource replaced and no other changes\n* A rebuilt ARM64 binary (because rebuilding it is just as easy as resource hacking it)\n* And I also took the opportunity to update the VC project to the 2019 toolchain\n  and removed the requirement for a particular Windows 10 SDK version.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46846", "files": ["other-licenses/7zstub/firefox/7zSD.ARM64.sfx", "other-licenses/7zstub/firefox/7zSD.Win32.sfx", "other-licenses/7zstub/firefox/SFXSetup.vcxproj", "other-licenses/7zstub/firefox/setup.ico"], "git_node": null, "git_parents": [null], "node": "ac26f9b1e8ef8cd043d79109fd32975daa908a4d", "parents": ["2f8e434edfbe5910019bdb29e8a02352864e9d35"], "tags": []}], "date": 1569842759, "git_changesets": [null, null], "user": "archaeopteryx@coole-files.de"}, "12073": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\ncy -\u003e 119e50db25a8\nkab -\u003e a3f6db20fe25\nvi -\u003e 358c215308cf", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "65350df3c310dd429e1f57da91fecc4d09e35e8c", "parents": ["ac26f9b1e8ef8cd043d79109fd32975daa908a4d"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\ncy -\u003e 119e50db25a8\nkab -\u003e a3f6db20fe25\nvi -\u003e 358c215308cf", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "a8dc3f933b398c93d8cc01591933948cfd8513ca", "parents": ["65350df3c310dd429e1f57da91fecc4d09e35e8c"], "tags": []}], "date": 1569844846, "git_changesets": [null, null], "user": "ffxbld"}, "12074": {"changesets": [{"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1582857.  Fix security checks around this-unwrapping.  r=peterv,bholley a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46692", "files": ["dom/bindings/BindingUtils.cpp", "dom/bindings/BindingUtils.h", "dom/bindings/Codegen.py", "dom/bindings/Configuration.py", "dom/bindings/parser/WebIDL.py"], "git_node": null, "git_parents": [null], "node": "110ad98bd8c7f3bfbe5b22178ff10ca10123a110", "parents": ["a8dc3f933b398c93d8cc01591933948cfd8513ca"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1578933 - Run scroll anchoring adjustments when blocking script. r=dholbert a=RyanVM\n\nI wanted to fix the more general problem and script-block more of\nFlushPendingNotifications, but simple attempts to do that have resulted in\nterribly orange try runs with very bizarre failures, so in the \"perfect is the\nenemy of good\" spirit, fix the issue at hand (scroll anchoring adjustments not\ndealing with layout reentering beneath them) by running them while\nscript-blocked, which is the right thing to do anyway.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47256", "files": ["layout/base/PresShell.cpp", "testing/web-platform/meta/css/css-scroll-anchoring/anchoring-with-bounds-clamping-div.html.ini"], "git_node": null, "git_parents": [null], "node": "98b1971b0a2684e0cc076fe783c480760a9b4508", "parents": ["110ad98bd8c7f3bfbe5b22178ff10ca10123a110"], "tags": []}, {"author": "Matt Howell \u003cmhowell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1584613 - Fix detecting web filtering parental control state on Windows 10. r=aklotz a=RyanVM\n\nThe Windows parental controls API (e.g. IWindowsParentalControls) appears to\nhave been removed entirely from at least more recent builds of Windows 10. The\ninterfaces are still defined, but at runtime creating instances of them fails.\nThis patch enables us to tell if web filtering is enabled for the current user\non Windows 10 without going through that API by directly reading the relevant\nregistry value.\n\nAll methods of nsIParentalControlsService other than parentalControlsEnabled\nhave been left unimplemented because it isn't obvious how to implement them\nin this environment, since no replacement for the old API seems to have been\nprovided. For example, it appears that loggingEnabled could be implemented\nusing the same registry key, but the logging mechanism is unlikely to be\ncompatible with the old one, so reporting that it is enabled may be unsafe.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47508", "files": ["toolkit/components/parentalcontrols/nsParentalControlsServiceWin.cpp"], "git_node": null, "git_parents": [null], "node": "e8e31000eab25dc36710eb66dea7392646161cda", "parents": ["98b1971b0a2684e0cc076fe783c480760a9b4508"], "tags": ["DEVEDITION_70_0b11_BUILD1", "DEVEDITION_70_0b11_RELEASE", "FIREFOX_70_0b11_BUILD1", "FIREFOX_70_0b11_RELEASE"]}], "date": 1569850123, "git_changesets": [null, null, null], "user": "archaeopteryx@coole-files.de"}, "12075": {"changesets": [{"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1474041 - Wait for browser.windows.create instead of onCreated. r=rpl, a=test-only\n\nThe browser.windows.onCreated event is triggered before\nbrowser.windows.create returns. Waiting until browser.windows.create has\nresolved may resolve the memory leak from bug 1474041.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47106", "files": ["toolkit/components/extensions/test/browser/browser_ext_themes_ntp_colors_perwindow.js"], "git_node": null, "git_parents": [null], "node": "ae69a9019821ebb37067eb4c2091a86e17e7d26e", "parents": ["e8e31000eab25dc36710eb66dea7392646161cda"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1578102 - Increase max-run-time for windows 7 opt/shippable xpcshell; r=bc, a=test-only\n\nAvoid intermittent task timeouts.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47098", "files": ["taskcluster/ci/test/xpcshell.yml"], "git_node": null, "git_parents": [null], "node": "1d78c79e4f870b95bd2dcb87549a77ce6c53ea4d", "parents": ["ae69a9019821ebb37067eb4c2091a86e17e7d26e"], "tags": []}, {"author": "Bogdan Tara \u003cbtara@mozilla.com\u003e", "branch": "default", "desc": "Bug 1566843 - Disabling test_ext_proxy_socks.js on linux & windows debug r=gbrown, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46812", "files": ["toolkit/components/extensions/test/xpcshell/xpcshell-common.ini"], "git_node": null, "git_parents": [null], "node": "1136a9e1a53453b39f9197aa9864d6d4d9ab4094", "parents": ["1d78c79e4f870b95bd2dcb87549a77ce6c53ea4d"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1581206 - Reconvert browser_bug629172.js to mochitest. r=Ehsan, a=test-only\n\nCurrently, we can use chrome process's shortcut key with\n`EventUtils.synthesizeKey()` with enabling `\"test.events.async.enabled\"` pref.\nSo, we should reconvert it to a mochitest for making it more stable.\n\nOddly, when I try to run this test as test-verify on macOS, it permanently\nfails rendering resizer of `\u003ctextarea\u003e` elements immediately after creation.\nTherefore, this patch disables this test in test-verify on macOS.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46578", "files": ["editor/libeditor/tests/browser.ini", "editor/libeditor/tests/browser_bug629172.js", "editor/libeditor/tests/bug629172.html", "editor/libeditor/tests/mochitest.ini", "editor/libeditor/tests/test_bug629172.html"], "git_node": null, "git_parents": [null], "node": "1ca02c38c072472cfbb6409b84a6e9d12da50b70", "parents": ["1136a9e1a53453b39f9197aa9864d6d4d9ab4094"], "tags": []}, {"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP blocklist remote-settings tld-suffixes - a=repo-update r=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47623", "files": ["browser/app/blocklist.xml", "netwerk/dns/effective_tld_names.dat", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/blocklists/addons.json"], "git_node": null, "git_parents": [null], "node": "cb53769d4ecc7d0a3fbd447bcf7bf2e465b2496a", "parents": ["1ca02c38c072472cfbb6409b84a6e9d12da50b70"], "tags": []}], "date": 1569858649, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "12076": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging e8e31000eab25dc36710eb66dea7392646161cda with DEVEDITION_70_0b11_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "02dc02cd8217209d06980e7d3dced3db0360a520", "parents": ["cb53769d4ecc7d0a3fbd447bcf7bf2e465b2496a"], "tags": []}], "date": 1569863556, "git_changesets": [null], "user": "ffxbld"}, "12077": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging e8e31000eab25dc36710eb66dea7392646161cda with FIREFOX_70_0b11_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "68e56aad7b33db0338103ce67d6e5889f1600f42", "parents": ["02dc02cd8217209d06980e7d3dced3db0360a520"], "tags": []}], "date": 1569863881, "git_changesets": [null], "user": "ffxbld"}, "12078": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1574252 - Run Windows ASAN builds and tests on all branches. r=dmajor, a=npotb\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47636", "files": ["taskcluster/ci/build/windows.yml"], "git_node": null, "git_parents": [null], "node": "5e9ad72175fd70bf95c5abba04e0a0982d500f33",