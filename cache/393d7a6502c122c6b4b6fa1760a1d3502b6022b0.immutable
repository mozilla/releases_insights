4b4db2184595168b108c30b3", "parents": ["35bba585d13f15c90eb1c15b82accd37d9383847"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1580859 - Keyboard navigation in the login-list should cycle through only visible login-list-items. r=sfoster\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45894", "files": ["browser/components/aboutlogins/content/components/login-list.js", "browser/components/aboutlogins/tests/chrome/test_login_list.html"], "git_node": null, "git_parents": [null], "node": "bad933d2d8b39d4fce944e8751df299693cf4422", "parents": ["718f2ddc38e0f5214b4db2184595168b108c30b3"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1581014 - Select the login item on keyup instead of keydown to prevent the 'Edit' button, which gets focused on login selection, from getting an erroneous click event. r=MattN\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45898", "files": ["browser/components/aboutlogins/content/components/login-list.js"], "git_node": null, "git_parents": [null], "node": "4ab638589c800aa3915399fdeb4b48aa2017147d", "parents": ["bad933d2d8b39d4fce944e8751df299693cf4422"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1579852 - The login-item area should be blank when loading about:logins as well as loading about:logins with a prepopulated search filter with 0 results. r=MattN\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46287", "files": ["browser/components/aboutlogins/content/aboutLogins.css", "browser/components/aboutlogins/content/aboutLogins.js", "browser/components/aboutlogins/tests/browser/browser_openFiltered.js"], "git_node": null, "git_parents": [null], "node": "46dc4e12f63ee7524d5387d2f43c8ca849a17295", "parents": ["4ab638589c800aa3915399fdeb4b48aa2017147d"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u0