": null, "git_parents": [null], "node": "233ae8d44b8e56d0d1d9273e20b1fadbc2a35a17", "parents": ["4b5d122c045dd17e44a00dee9428e4fa9ddd2f15"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575220 - Show the close icon in the confirmation-dialog in high contrast mode. r?MattN\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47531", "files": ["browser/components/aboutlogins/content/aboutLogins.html", "browser/components/aboutlogins/content/components/confirmation-dialog.css", "browser/components/aboutlogins/content/components/confirmation-dialog.js"], "git_node": null, "git_parents": [null], "node": "0830139ba23d915273db8aea94efacd4d70c837f", "parents": ["233ae8d44b8e56d0d1d9273e20b1fadbc2a35a17"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1583428 - Remove the alt attribute for the favicon since it is not helpful and remove the alt attribute on the breached website icon so the title of 'Breached Website' is spoken. r?sfoster\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47811", "files": ["browser/components/aboutlogins/content/aboutLogins.html", "browser/components/aboutlogins/content/components/login-item.js", "browser/components/aboutlogins/content/components/login-list-item.js"], "git_node": null, "git_parents": [null], "node": "570504a161f475d6d9c5c9249c42a590304f7db2", "parents": ["0830139ba23d915273db8aea94efacd4d70c837f"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1583425 - Update the active descendant when rendering to make sure that it is a visible list-item. r?sfoster\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47827", "files": ["browser/components/aboutlogins/content/components/login-list.css", "browser/components/aboutlogins/content/components/login-list.js", "browser/components/aboutlogins/tests/browser/browser_openFiltered.js"], "git_node": null, "git_parents": [null], "node": "304bc94e13042c3f7b638e7bd5da147e0ae31864", "parents": ["570504a161f475d6d9c5c9249c42a590304f7db2"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1583426 - Clear the aria-activedescendant attribute if navigating through the list reaches an end of the list to trigger NVDA to speak the list's aria-label. Restore the aria-activedescendant attribute upon tabbing back to the listso the...\n\n...active descendant will correctly get announced. r?sfoster\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47972", "files": ["browser/components/aboutlogins/content/components/login-list.js"], "git_node": null, "git_parents": [null], "node": "5ff97d3d6f8b9352f8431dac497e06a0e445debf", "parents": ["304bc94e13042c3f7b638e7bd5da147e0ae31864"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1583796 - Re-sort and render the login list when breach notifications are updated without acting like a user-initiated sort. r=MattN a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47982", "files": ["browser/components/aboutlogins/content/components/login-list.js", "browser/components/aboutlogins/tests/browser/browser_aaa_eventTelemetry_run_first.js", "browser/components/aboutlogins/tests/browser/browser_breachAlertDismissals.js", "browser/components/aboutlogins/tests/browser/browser_breachAlertShowingForAddedLogin.js", "browser/components/aboutlogins/tests/browser/head.js", "toolkit/components/passwordmgr/test/LoginTestUtils.jsm"], "git_node": null, "git_parents": [null], "node": "90d8a6faebc4cff379ff91fb4356e30e7be362d8", "parents": ["5ff97d3d6f8b9352f8431dac497e06a0e445debf"], "tags": []}], "date": 1570211183, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "jwein@mozilla.com"}, "12107": {"changesets": [{"author": "Henri Sivonen \u003chsivonen@hsivonen.fi\u003e", "branch": "default", "desc": "Bug 1584216 - Adjust tokenization of U+0000. r=alchen a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47594", "files": ["parser/html/javasrc/Tokenizer.java", "parser/html/nsHtml5Tokenizer.cpp"], "git_node": null, "git_parents": [null], "node": "0b47d14dc42ff43dd27252fdf8831d4c7b22509f", "parents": ["90d8a6faebc4cff379ff91fb4356e30e7be362d8"], "tags": []}], "date": 1570216802, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "12108": {"changesets": [{"author": "Byron Campen [:bwc] \u003cdocfaraday@gmail.com\u003e", "branch": "default", "desc": "Bug 1581898: Move telephone-event to the back of the codec list, because webrtc.org crashes if we don't. r=mjf a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46830", "files": ["media/webrtc/signaling/src/peerconnection/TransceiverImpl.cpp"], "git_node": null, "git_parents": [null], "node": "6d321e762d12fe61f383e744cedfe7f19610b8c2", "parents": ["0b47d14dc42ff43dd27252fdf8831d4c7b22509f"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1583766 - Consider `IMEContentObserver` to send selection change notification when its sender sends a text change notification r=m_kato a=lizzard\n\nThe previous change is wrong because the sender shouldn't send selection change\nnotification if `IMEContentObserver` does not receive text change notifications\nnor selection change notifications.\n\nThis patch reverts the change in the if block of previous change and instead\nsets `IMEContentObserver::mNeedsToNotifyIMEOfSelectionChange` to `true` if\nthe sender sends a text change notification.  (Note that even if there is\nanother text change with a mutation event listener, we need to send selection\nchange notification later so that this must be the right approach.)\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47564", "files": ["dom/events/IMEContentObserver.cpp"], "git_node": null, "git_parents": [null], "node": "03a4de4097ad2d3c938f71c2d2c227d538fced61", "parents": ["6d321e762d12fe61f383e744cedfe7f19610b8c2"], "tags": []}], "date": 1570217622, "git_changesets": [null, null], "user": "ncsoregi@mozilla.com"}, "12109": {"changesets": [{"author": "Jan Horak \u003cjhorak@redhat.com\u003e", "branch": "default", "desc": "Bug 1582679 - Rewrite popup hiding on wayland; r=stransky a=lizzard\n\nUnder Wayland it is possible to add only one popup window\nto a parent window. If we try to attach another popup to the window,\nthe GTK refuses to do that. This can happen when the previous popup\nhas not yet been hidden while the new popup is showing (in some cases\nthe nsWindow::Show(false) for the previous popup is not called before\nnsWindow::Show(true) for the new one).\n\nWe deal with it by hiding wayland popups which are no longer in the\nXULPopupManager (PM) before showing a new one. We only do that for\nthe main menu popups or context (sub)menus. We cannot use PM to check\nfor the panel popup content like Folder dropdown in Edit Bookmark panel\nor WebRTC microphone/video source dropdown. In that case we simply use\nthe last shown popup as a transient for the new one or the toplevel window.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47610", "files": ["widget/gtk/nsWindow.cpp", "widget/gtk/nsWindow.h"], "git_node": null, "git_parents": [null], "node": "384a31a31869a3896e0956ab41b9e37fa480b065", "parents": ["03a4de4097ad2d3c938f71c2d2c227d538fced61"], "tags": []}], "date": 1570219142, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "12110": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nbe -\u003e 7106c388779b\ncak -\u003e 35815a76d153\ncs -\u003e cfaee0924ada\nda -\u003e a81bb04b19d1\nen-CA -\u003e d92