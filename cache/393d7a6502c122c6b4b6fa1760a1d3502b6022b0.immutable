lsprf.c:\n\tBug 1582343 - Use constant time memcmp in more places r=kjacobs,jcj\n\t[e2945c434286] \u003cNSS_3_46_BRANCH\u003e\n\n2019-08-30  J.C. Jones  \u003cjjones@mozilla.com\u003e\n\n\t* .hgtags:\n\tAdded tag NSS_3_46_RTM for changeset decbf7bd40fd\n\t[a75ea4cdacd9] \u003cNSS_3_46_BRANCH\u003e\n\n\t* lib/nss/nss.h, lib/softoken/softkver.h, lib/util/nssutil.h:\n\tSet version numbers to 3.46 final\n\t[decbf7bd40fd] [NSS_3_46_RTM]\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47998", "files": ["old-configure.in", "security/nss/TAG-INFO", "security/nss/coreconf/coreconf.dep", "security/nss/lib/nss/nss.h", "security/nss/lib/softoken/pkcs11c.c", "security/nss/lib/softoken/softkver.h", "security/nss/lib/softoken/tlsprf.c", "security/nss/lib/util/nssutil.h"], "git_node": null, "git_parents": [null], "node": "2d4b8973e8de95bb89e1138e154452bc5aa012ff", "parents": ["fd7e01f7e11f63c0f19afd62a1d5d48c4f492079"], "tags": []}, {"author": "Nihanth Subramanya \u003cnhnt11@gmail.com\u003e", "branch": "default", "desc": "Bug 1578459 - [Protections Panel] Reorder category items in popupshowing instead of shown. r=johannh a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44885", "files": ["browser/base/content/browser-siteProtections.js", "browser/components/controlcenter/content/protectionsPanel.inc.xul"], "git_node": null, "git_parents": [null], "node": "06ddf8fc87f7d6edae3eed1101cb82c1f8f47409", "parents": ["2d4b8973e8de95bb89e1138e154452bc5aa012ff"], "tags": []}], "date": 1570177167, "git_changesets": [null, null], "user": "archaeopteryx@coole-files.de"}, "12102": {"changesets": [{"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 06ddf8fc87f7 (bug 1578459) for failing browser-chrome's browser_trackingUI_trackers_subview.js. a=backout", "files": ["browser/base/content/browser-siteProtections.js", "browser/components/controlcenter/content/protectionsPanel.inc.xu