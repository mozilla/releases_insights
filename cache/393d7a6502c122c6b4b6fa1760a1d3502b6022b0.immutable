vateWindow.js"], "git_node": null, "git_parents": [null, null], "node": "0e52e746c47a89e8ff2e5fc08bfa79b164648033", "parents": ["4c09da80722fcf62db02f19dc67f3f1a6b88f84d", "c72fb6d63304f4b5df0dd05a3d2973b1fd4ee0da"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576358 - Delete fetch-sw.https.html for causing failures on Android. a=testonly", "files": ["testing/web-platform/meta/fetch/stale-while-revalidate/fetch-sw.https.html.ini"], "git_node": null, "git_parents": [null], "node": "3cdce027d04886041dc9fc92186390d6f89eb6e5", "parents": ["54ba46ed7f13d8a5c425a3a3d12c6173c791e523"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to mozilla-inbound.", "files": [], "git_node": null, "git_parents": [null, null], "node": "810d8a1a613e446e26973be58b855f735865403f", "parents": ["3cdce027d04886041dc9fc92186390d6f89eb6e5", "2b44d3e0c64c79c9376d3ce770da319cc1d72d01"], "tags": []}, {"author": "Stephen McGruer \u003csmcgruer@chromium.org\u003e", "branch": "default", "desc": "Bug 1575918 [wpt PR 18616] - Fix font-variation-settings interpolation test, a=testonly\n\nAutomatic update from web-platform-tests\nFix font-variation-settings interpolation test\n\nfont-variation-settings is a map, not an array, so the order is\nirrelevant when comparing the actual and expected values. Add the\nability to supply a custom comparison function to\ninterpolation-testcommon.js to support properties like this.\n\nThis also exposed one test which incorrectly asserted no interpolation\nwhen there should be interpolation.\n\nBug: 900581\nChange-Id: I6c336e010c9c3642b14c945b3d7ae828f94b3f99\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1764801\nCommit-Queue: Stephen McGruer \u003csmcgruer@chromium.org\u003e\nReviewed-by: Xida Chen \u003cxidachen@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#689924}\n\n--\n\nwpt-commits: 4ccb4d2607e3c1f460e742a9e3427e61394dec73\nwpt-pr: 18616\n", "files": ["testing/web-platform/tests/css/css-fonts/animations/font-variation-settings-interpolation.html", "testing/web-platform/tests/css/support/interpolation-testcommon.js"], "git_node": null, "git_parents": [null], "node": "0d9178e91ea1fe446d5b1d1c785482d55445543c", "parents": ["810d8a1a613e446e26973be58b855f735865403f"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575918 [wpt PR 18616] - Update wpt metadata, a=testonly\n\nwpt-pr: 18616\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/css/css-fonts/animations/font-variation-settings-interpolation.html.ini", "testing/web-platform/meta/css/filter-effects/animation/filter-interpolation-002.html.ini", "testing/web-platform/meta/css/motion/animation/offset-distance-interpolation.html.ini", "testing/web-platform/meta/css/motion/animation/offset-path-interpolation-005.html.ini", "testing/web-platform/meta/css/motion/animation/offset-rotate-interpolation.html.ini"], "git_node": null, "git_parents": [null], "node": "953372c50f372247d229737e28da88788a518f07", "parents": ["0d9178e91ea1fe446d5b1d1c785482d55445543c"], "tags": []}, {"author": "Nicol\u00e1s Pe\u00f1a Moreno \u003cnpm@chromium.org\u003e", "branch": "default", "desc": "Bug 1575260 [wpt PR 18566] - [ResourceTiming] Fix CORS preflight ResourceTiming information, a=testonly\n\nAutomatic update from web-platform-tests\n[ResourceTiming] Fix CORS preflight ResourceTiming information\n\nThe two tests that rely on\nhttp/tests/misc/resources/resource-timing-sizes-cors-preflight.js are\nincorrect because CORS preflights should not trigger new Resource Timing\nentries. This change reverts the changes made in 793f7c3 and fixes the\ntests.\n\nBug: 982924\nChange-Id: Ic656f9fc0cd6dadfa66d1176765696817bcec8f4\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1696525\nReviewed-by: Takashi Toyoshima \u003ctoyoshim@chromium.org\u003e\nReviewed-by: Yutaka Hirano \u003cyhirano@chromium.org\u003e\nReviewed-by: Kinuko Yasuda \u003ckinuko@chromium.org\u003e\nCommit-Queue: Nicol\u00e1s Pe\u00f1a Moreno \u003cnpm@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#689940}\n\n--\n\nwpt-commits: 14daf8c5b8b55d0c343218c0606bf4f49b513f20\nwpt-pr: 18566\n", "files": ["testing/web-platform/tests/resource-timing/cors-preflight.any.js", "testing/web-platform/tests/resource-timing/resources/preflight.py"], "git_node": null, "git_parents": [null], "node": "63c1975b2e0c2c6c54891b2c2e913b80f3b70be2", "parents": ["953372c50f372247d229737e28da88788a518f07"], "tags": []}, {"author": "Mike Pennisi \u003cmike@mikepennisi.com\u003e", "branch": "default", "desc": "Bug 1576017 [wpt PR 18623] - [wptserve] Support `.sub.` filename w/pipe param, a=testonly\n\nAutomatic update from web-platform-tests\n[wptserve] Support `.sub.` filename w/pipe param\n\nThe substitution feature may be enabled using a filename pattern\n(`.sub`) or a query string parameter (`pipe=sub`). Prior to this commit,\nthe former approach could not be used if any other \"pipe\" commands were\nincluded in the query string. Update wptserve to interpret the `.sub.`\nfilename pattern as though it were expressed as the first \"pipe\" command\nin the query string.\n\n--\n\nwpt-commits: ef77ba9ca4f582ac49e3aa7a1569134f149696b0\nwpt-pr: 18623\n", "files": ["testing/web-platform/tests/tools/wptserve/tests/functional/test_pipes.py", "testing/web-platform/tests/tools/wptserve/wptserve/handlers.py"], "git_node": null, "git_parents": [null], "node": "a73abcc509f778c81b482197de8a3a48a70f6fda", "parents": ["63c1975b2e0c2c6c54891b2c2e913b80f3b70be2"], "tags": []}, {"author": "Xiaocheng Hu \u003cxiaochengh@chromium.org\u003e", "branch": "default", "desc": "Bug 1575992 [wpt PR 18622] - Add parser and evaluation WPT \u003clength-percentage\u003e involving min/max(), a=testonly\n\nAutomatic update from web-platform-tests\nAdd parser and evaluation WPT \u003clength-percentage\u003e involving min/max()\n\nBug: 978682\nChange-Id: I5e377df4121a1ef1992a30fbeff822712b52b8ca\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1766843\nReviewed-by: Rune Lillesveen \u003cfuthark@chromium.org\u003e\nCommit-Queue: Xiaocheng Hu \u003cxiaochengh@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#690030}\n\n--\n\nwpt-commits: 86af37591b7df11a1b667874a0d818684c4dfeb6\nwpt-pr: 18622\n", "files": ["testing/web-platform/tests/css/css-values/minmax-length-percent-computed.html", "testing/web-platform/tests/css/css-values/minmax-length-percent-invalid.html"], "git_node": null, "git_parents": [null], "node": "8394d3fc54bcb83ba4426dad2e642343baeac0de", "parents": ["a73abcc509f778c81b482197de8a3a48a70f6fda"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575992 [wpt PR 18622] - Update wpt metadata, a=testonly\n\nwpt-pr: 18622\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/css/css-values/minmax-length-percent-computed.html.ini"], "git_node": null, "git_parents": [null], "node": "a61cb494a0bf642833f039cfbd37f9c84e8e8b13", "parents": ["8394d3fc54bcb83ba4426dad2e642343baeac0de"], "tags": []}, {"author": "Brandon Jones \u003cbajones@chromium.org\u003e", "branch": "default", "desc": "Bug 1576240 [wpt PR 18644] - Changed the WebXR required/optional features to take an array of 'any', a=testonly\n\nAutomatic update from web-platform-tests\nChanged the WebXR required/optional features to take an array of 'any'\n\nBug: 996949\nChange-Id: Ifd918931d1c4a8ad976655230efb1f5e70f53956\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1766601\nReviewed-by: Alexander Cooper \u003calcooper@chromium.org\u003e\nReviewed-by: Brian Sheedy \u003cbsheedy@chromium.org\u003e\nCommit-Queue: Brandon Jones \u003cbajones@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#690049}\n\n--\n\nwpt-commits: 449d483adbc38cb77e07da93bf871f6f9a5db8