o,bbouvier\n\nThis is part 1 of a series of revs that split up D41710 into smaller revs. This rev just adds a compile-time flag for wasm BigInt to I64 conversion but does not use it anywhere, as its uses are for toggling features in subsequent revs.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43177", "files": ["js/moz.configure"], "git_node": null, "git_parents": [null], "node": "d2072e34a3b169570acf05f7a6c26c25c93e68f4", "parents": ["f0e843f33a5ff8338d29db484ee2875d59d0f644"], "tags": []}, {"author": "Dale Harvey \u003cdale@arandomurl.com\u003e", "branch": "default", "desc": "Bug 1542268 - Use new engine selector behind a pref r=Standard8\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42879", "files": ["browser/components/search/extensions/engines.json", "toolkit/components/search/SearchEngineSelector.jsm", "toolkit/components/search/SearchService.jsm", "toolkit/components/search/SearchUtils.jsm", "toolkit/components/search/moz.build", "toolkit/components/search/tests/xpcshell/searchconfigs/head_searchconfig.js", "toolkit/components/search/tests/xpcshell/test_engine_selector.js"], "git_node": null, "git_parents": [null], "node": "16aa97b4ff64532bd443559663e80222abf70271", "parents": ["d2072e34a3b169570acf05f7a6c26c25c93e68f4"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Bug 1577362 - Disable browser_allowListSeparationInPrivateAndNormalWindows.js on fission. r=intermittent-reviewers,jmaher\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44095", "files": ["toolkit/components/antitracking/test/browser/browser.ini"], "git_node": null, "git_parents": [null], "node": "5882c5dd07f443554b2ec47fd78f5e6212e548b0", "parents": ["16aa97b4ff64532bd443559663e80222abf70271"], "tags": []}, {"author": "Alexander J. Vincent \u003cajvincent@gmail.com\u003e", "branch": "default", "desc": "Bug 1577372, restore copy command via context menu to pageInfo dialog. r=johannh,fluent-reviewers,flod\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44084", "files": ["browser/base/content/pageinfo/pageInfo.js", "browser/base/content/pageinfo/pageInfo.xul", "browser/locales/en-US/browser/pageInfo.ftl"], "git_node": null, "git_parents": [null], "node": "1dca0c6a9ad2cc92ccaf713983e975b28dec7eee", "parents": ["5882c5dd07f443554b2ec47fd78f5e6212e548b0"], "tags": []}, {"author": "Timothy Nikkel \u003ctnikkel@gmail.com\u003e", "branch": "default", "desc": "Bug 1577155. Make image/test/mochitest/test_bug415761.html copy both the test and reference icon so the OS doesn't include an extra badge indicating it is a sym link. r=Standard8\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44082", "files": ["image/test/mochitest/test_bug415761.html"], "git_node": null, "git_parents": [null], "node": "5e06c1d419b73bb5533b52b8126a55a25580afca", "parents": ["1dca0c6a9ad2cc92ccaf713983e975b28dec7eee"], "tags": []}, {"author": "Gurzau Raul \u003crgurzau@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 1dca0c6a9ad2 (bug 1577372) for eslint failure at pageInfo.js on a CLOSED TREE.", "files": ["browser/base/content/pageinfo/pageInfo.js", "browser/base/content/pageinfo/pageInfo.xul", "browser/locales/en-US/browser/pageInfo.ftl"], "git_node": null, "git_parents": [null], "node": "aa070cf72750b2bda6fac3591f100d98c75a5f22", "parents": ["5e06c1d419b73bb5533b52b8126a55a25580afca"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1577812 - correctly add the compiler's lib directory to LD_LIBRARY_PATH; r=sfink\n\nThe current code only adds the directory if `LD_LIBRARY_PATH` is not\nalready set.  We want to always add it so that host binaries--which will\nbe linked against whatever libraries the compiler in use provides--can\nrun correctly.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44172", "files": ["js/src/devtools/automation/autospider.py"], "git_node": null, "git_parents": [null], "node": "a54701dbcc65c71a9d8e55cc7cac09442aaeff8f", "parents": ["aa070cf72750b2bda6fac3591f100d98c75a5f22"], "tags": []}, {"author": "Jason Laster \u003cjlaster@mozilla.com\u003e", "branch": "default", "desc": "Bug 1577047 - Function calls without args should not be valid breakpoint positions. r=loganfsmyth\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43884", "files": ["devtools/server/tests/browser/browser_dbg_promises-fulfillment-stack.js", "devtools/server/tests/browser/browser_dbg_promises-rejection-stack.js", "devtools/server/tests/unit/test_source-02.js", "js/src/frontend/BytecodeEmitter.cpp", "js/src/jit-test/tests/arrow-functions/column-number.js", "js/src/jit-test/tests/basic/eval-introduction-principals.js", "js/src/jit-test/tests/basic/offThreadCompileScript-02.js", "js/src/jit-test/tests/binast/lazy/basic/offThreadCompileScript-02.binjs", "js/src/jit-test/tests/binast/nonlazy/basic/offThreadCompileScript-02.binjs", "js/src/jit-test/tests/debug/Debugger-setInstrumentation-01.js", "js/src/jit-test/tests/debug/Script-getPossibleBreakpoints.js", "js/src/jit-test/tests/parser/bug-1161312.js", "js/src/jit-test/tests/parser/columnNumber.js", "js/src/tests/non262/extensions/errorcolumnblame.js", "js/xpconnect/tests/chrome/test_nsScriptErrorWithStack.html"], "git_node": null, "git_parents": [null], "node": "96842051c994b95da275942a1c2c02494d6d2683", "parents": ["a54701dbcc65c71a9d8e55cc7cac09442aaeff8f"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Bug 1577768 - add toggle.svg to whitelist of referenced files for non-central repositories. r=mstriemer\n\nIt got added in bug 1533863 for the new about:config page (bug 1493439) which is currently on enabled in Nightly (bug 1532703).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44192", "files": ["browser/base/content/test/static/browser_all_files_referenced.js"], "git_node": null, "git_parents": [null], "node": "e22008fdeef19dc32e20092605f040f7a26f9770", "parents": ["96842051c994b95da275942a1c2c02494d6d2683"], "tags": []}, {"author": "Brian Hackett \u003cbhackett1024@gmail.com\u003e", "branch": "default", "desc": "Bug 1577666 - Add redirections for some printing functions, r=jlast.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44088", "files": ["toolkit/recordreplay/ProcessRedirectDarwin.cpp"], "git_node": null, "git_parents": [null], "node": "42a0301f905e88abbf4fe11d3701013c0aad44fa", "parents": ["e22008fdeef19dc32e20092605f040f7a26f9770"], "tags": []}, {"author": "Thomas Nguyen \u003ctnguyen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576347 - Correct referrerInfo when saving media and add a test of \"Go To Download Page\" button r=Gijs\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43749", "files": ["browser/actors/ContextMenuChild.jsm", "browser/base/content/nsContextMenu.js", "browser/components/downloads/DownloadsViewUI.jsm", "browser/components/downloads/test/browser/browser.ini", "browser/components/downloads/test/browser/browser_go_to_download_page.js", "toolkit/content/contentAreaUtils.js"], "git_node": null, "git_parents": [null], "node": "e147806b0a1c4943e5f5603e44b68fc8661ab2ee", "parents": ["42a0301f905e88abbf4fe11d3701013c0aad44fa"], "tags": []}, {"author": "Brad Werth \u003cbwerth@mozilla.com\u003e", "branch": "default", "desc": "Bug 1572840 Part 1: Add a zoom viewport action to RDM pane. r=gl\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41463", "files": ["devtools/client/responsive/actions/index.js", "devtools/client/responsive/actions/viewports.js", "devtools/client/responsive/reducers/viewports.js"], "git_node": null, "git_parents": [null], "node": "23feecbe07eb871cd41d849da963c7e734c40ce3", "parents": ["e147806b0a1c4943e5f5603e44b68fc8661ab2ee"], "tags": []}, {"author": "Brad Werth \u003cbwerth@mozilla.com\u003e", "branch": "default", "desc": "Bug 1572840 Part 2: Make the RDM viewport render scaled to the viewport.zoom property. r=gl\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41465", "files": ["devtools/client/responsive/components/ResizableViewport.js"], "git_node": null, "git_parents": [null], "node": "038722cc5bf49e63c2dc411788ca549bebac3eb7", "parents": ["23feecbe07eb871cd41d849da963c7e734c40ce3"], "tags": []}, {"author": "Brad Werth \u003cbwerth@mozilla.com\u003e", "branch": "default", "desc": "Bug 1572840 Part 3: Listen to fullzoom changes in the RDM pane and call the zoom viewport function. r=gl\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41467", "files": ["devtools/client/responsive/index.js", "devtools/client/responsive/manager.js"], "git_node": null, "git_parents": [null], "node": "8cd803e497e700233742053f9fd663ab1c5e95ee", "parents": ["038722cc5bf49e63c2dc411788ca549bebac3eb7"], "tags": []}, {"author": "Brad Werth \u003cbwerth@mozilla.com\u003e", "branch": "default", "desc": "Bug 1572840 Part 4: Change nsGlobalWindowOuter::GetRDMDeviceSize to divide out full zoom levels. r=Ehsan\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43716", "files": ["dom/base/nsGlobalWindowOuter.cpp", "dom/ipc/BrowserChild.h"], "git_node": null, "git_parents": [null], "node": "db42ac54835f8ea7a11738252efbdf6d0f17e447", "parents": ["8cd803e497e700233742053f9fd663ab1c5e95ee"], "tags": []}, {"author": "Brad Werth \u003cbwerth@mozilla.com\u003e", "branch": "default", "desc": "Bug 1572840 Part 5: Update test expectations. r=gl\n\nhttps://phabricator.services.mozilla.com/D42379\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43825", "files": ["devtools/client/responsive/test/browser/browser_window_sizing.js"], "git_node": null, "git_parents": [null], "node": "466e8f97c54f14584c6c23d8a8057255e5957abb", "parents": ["db42ac54835f8ea7a11738252efbdf6d0f17e447"], "tags": []}, {"author": "David Walsh \u003cdwalsh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1577677 - Update language for toggling inline preview r=jlast\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44098", "files": ["devtools/client/debugger/src/components/Editor/menus/editor.js", "devtools/client/locales/en-US/debugger.properties"], "git_node": null, "git_parents": [null], "node": "935f01089bf510d412935935e93a237843f14d77", "parents": ["466e8f97c54f14584c6c23d8a8057255e5957abb"], "tags": []}, {"author": "Daniel Holbert \u003cdholbert@cs.stanford.edu\u003e", "branch": "default", "desc": "Bug 1481951 late-breaking followup: Remove mistaken comment with a reference to this (closed) bug. r=TYLin\n\nDONTBUILD because this is a comment-only change.\n\nPer bug 1481951 comment 6, it seems our behavior was in fact correct even when\nthe comment was added, and this \"// XXX\" comment was just due to a\nmisunderstanding in what was going on in the testcase.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44229", "files": ["layout/generic/nsFrame.cpp"], "git_node": null, "git_parents": [null], "node": "8f159b8c631d3e2d05a81644ad435ca751a8aefe", "parents": ["935f01089bf510d412935935e93a237843f14d77"], "tags": []}, {"author": "Edwin Gao \u003cegao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1565332 - add new dockerfile for debian 10 (buster) test image and add necessary piping without switching the main CI pipeline from ubuntu 16.04 r=jmaher\n\nMajor changes:\n- add new directory under `taskcluster/docker` named `linux-test` that will supersede `desktop1604-test` when the appropriate time comes\n- add new job to support building this docker image in `kind.yml`\n- create a setup script similar to `ubuntu1604-test-system-setup.sh` tailored to debian 10\n- modify `test-linux.sh` to support switching based on detected distribution; this is important due to differences in how pulseaudio is handled\n\nMinor changes:\n- modify logic in the mochitest harness in order to support gstreamer0.1, 0.10 and 1.0 notations (varies slightly from ubuntu1604)\n\nGoal:\n- this patch will place all the necessary piping to enable debian 10 when needed\n- with the required debian 10 files and scripts recorded in tree, it is easier to have other developers quickly enable debian 10 to run tests on try\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42597", "files": ["taskcluster/ci/docker-image/kind.yml", "taskcluster/docker/debian10-test/Dockerfile", "taskcluster/docker/debian10-test/apport", "taskcluster/docker/debian10-test/dot-files/config/pip/pip.conf", "taskcluster/docker/debian10-test/dot-files/config/user-dirs.dirs", "taskcluster/docker/debian10-test/dot-files/config/user-dirs.locale", "taskcluster/docker/debian10-test/dot-files/pulse/client.conf", "taskcluster/docker/debian10-test/dot-files/pulse/default.pa", "taskcluster/docker/debian10-test/fonts.conf", "taskcluster/docker/debian10-test/motd", "taskcluster/docker/debian10-test/taskcluster-interactive-shell", "taskcluster/docker/recipes/debian-test-system-setup.sh", "taskcluster/scripts/tester/test-linux.sh", "testing/mochitest/mochitest_options.py", "testing/mochitest/runtests.py"], "git_node": null, "git_parents": [null], "node": "4d4271a0ccad1e5a561ca93bd4144767cf0503a4", "parents": ["8f159b8c631d3e2d05a81644ad435ca751a8aefe"], "tags": []}, {"author": "Olli Pettay \u003cOlli.Pettay@helsinki.fi\u003e", "branch": "default", "desc": "Bug 1574290, browser_html_options_ui.js should wait for the load event before expecting that the whole extension page has been loaded, r=mstriemer\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44143", "files": ["toolkit/mozapps/extensions/test/browser/browser_html_options_ui.js"], "git_node": null, "git_parents": [null], "node": "ac42ae777d5cdab6ddbe4b01411be39910c2a069", "parents": ["4d4271a0ccad1e5a561ca93bd4144767cf0503a4"], "tags": []}, {"author": "Andrew Halberstadt \u003cahalberstadt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576957 - [ci] Create 'attr' shortcut in target_tasks_ash, r=gbrown\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43806", "files": ["taskcluster/taskgraph/target_tasks.py"], "git_node": null, "git_parents": [null], "node": "734d2434e08bc19e3b904085e670b507daaf1759", "parents": ["ac42ae777d5cdab6ddbe4b01411be39910c2a069"], "tags": []}, {"author": "Andrew Halberstadt \u003cahalberstadt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576957 - [ci] Turn off QuantumRender tasks on Ash, r=gbrown\n\nDepends on D43806\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43807", "files": ["taskcluster/taskgraph/target_tasks.py"], "git_node": null, "git_parents": [null], "node": "de27cb9fb807d14598298c986b302f1e94c1facf", "parents": ["734d2434e08bc19e3b904085e670b507daaf1759"], "tags": []}, {"author": "Andrew Halberstadt \u003cahalberstadt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576957 - [ci] Turn off shippable builds and tests on Ash, r=gbrown\n\nDepends on D43807\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43808", "files": ["taskcluster/taskgraph/target_tasks.py"], "git_node": null, "git_parents": [null], "node": "e5b26c5fc4c0f6a7f56c2d536d1d81358926f1f4", "parents": ["de27cb9fb807d14598298c986b302f1e94c1facf"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Bug 1518210 - Wasm: Bounds checking support for x64. r=lth\n\nx86_64 can re-use MacroAssembler-x86-shared for its wasmBoundsCheck, and so it\ndoesn't require any new assembler code.\n\nIt does require a small baseline compiler change to ensure that TlsData is\nloaded if we are going to do a bounds check.\n\nI tested this commit with a x64 try run and manually disabling WASM_HUGE_MEMORY.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41863", "files": ["js/src/wasm/WasmBaselineCompile.cpp", "js/src/wasm/WasmTypes.cpp"], "git_node": null, "git_parents": [null], "node": "fcc67013b556f2d106996137060c8604c8a03804", "parents": ["e5b26c5fc4c0f6a7f56c2d536d1d81358926f1f4"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Bug 1518210 - Wasm: Bounds checking support for ARM64. r=lth\n\nThe only observed change needed to get bounds checking working on ARM64 was to\nimplement `wasmBoundsCheck` in MacroAssembler-arm64.\n\nARM64 doesn't support predicated instructions like ARM32, so to support spectre\nmitigations `wasmBoundsCheck` emits a 'csel' instruction. I'm not familiar with\nhow ARM performs speculative execution or how spidermonkey mitigates it, so this\nwas only a guess.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41864", "files": ["js/src/jit/MacroAssembler.h", "js/src/jit/arm64/MacroAssembler-arm64-inl.h", "js/src/jit/arm64/MacroAssembler-arm64.cpp"], "git_node": null, "git_parents": [null], "node": "1df22476f295b752a42881f77dc7f153583eb320", "parents": ["fcc67013b556f2d106996137060c8604c8a03804"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Bug 1518210 - Wasm: Remove unused wasm::DeserializeModule API. r=luke\n\nThis API is no longer used by IndexDB and can be removed.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41865", "files": ["js/src/jsapi.cpp", "js/src/jsapi.h", "js/src/wasm/WasmModule.cpp", "js/src/wasm/WasmModule.h"], "git_node": null, "git_parents": [null], "node": "1e7d2427f348f0a336ba474c55e2b315283c59b1", "parents": ["1df22476f295b752a42881f77dc7f153583eb320"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Bug 1518210 - Wasm: Add pref/flag boilerplate for making WASM_HUGE_MEMORY a runtime decision. r=lth\n\nThis commit is the boilerplate for making WASM_HUGE_MEMORY a runtime decision.\n\nBecause WasmModule's can be passed across threads with `postMessage`, we need\nto make this decision once per process. The support for this kind of flag seems\nad-hoc, so I stubbed in a global flag in WasmProcess.\n\nA new 'javascript.options.wasm_disable_huge_memory' pref and\n'--disable-wasm-huge-memory' JS shell flag are added. These have no effect if\nthe current platform doesn't support huge memory.\n\nTests and fuzzing flags are modified to also test with these new flags.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41866", "files": ["js/src/jit-test/tests/wasm/bench/directives.txt", "js/src/jit-test/tests/wasm/directives.txt", "js/src/jit-test/tests/wasm/gc/directives.txt", "js/src/jit-test/tests/wasm/regress/directives.txt", "js/src/jit-test/tests/wasm/spec/directives.txt", "js/src/jit-test/tests/wasm/timeout/directives.txt", "js/src/jsapi.cpp", "js/src/jsapi.h", "js/src/shell/fuzz-flags.txt", "js/src/shell/js.cpp", "js/src/vm/MutexIDs.h", "js/src/wasm/Makefile", "js/src/wasm/WasmProcess.cpp", "js/src/wasm/WasmProcess.h", "js/xpconnect/src/XPCJSContext.cpp"], "git_node": null, "git_parents": [null], "node": "255a6d989d91996737c90571c270af983a8134d9", "parents": ["1e7d2427f348f0a336ba474c55e2b315283c59b1"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Bug 1518210 - Wasm: Rename WASM_HUGE_MEMORY to WASM_SUPPORTS_HUGE_MEMORY. r=lth\n\nTo highlight that WASM_HUGE_MEMORY doesn't imply we are using huge memory, this\ncommit renames the #define.\n\nMost usages of WASM_HUGE_MEMORY are not updated, as they will be removed in\nlater commits.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41867", "files": ["js/src/js-config.mozbuild", "js/src/wasm/WasmTypes.cpp"], "git_node": null, "git_parents": [null], "node": "217c5f81229668bd561ad67f50888282f2134658", "parents": ["255a6d989d91996737c90571c270af983a8134d9"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Bug 1518210 - Wasm: Conditionally compile bounds checks based on wasm::IsHugeMemoryEnabled. r=lth\n\nThis commit allows us to conditionally compile bounds checks based on runtime\nsupport for huge memory.\n\nNew flags to CompileArgs and CompilerEnvironment are added for whether we are\nusing huge memory or not, and computed based on the global flag.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41868", "files": ["js/src/jit/CodeGenerator.cpp", "js/src/jit/Lowering.cpp", "js/src/jit/WasmBCE.cpp", "js/src/wasm/AsmJS.cpp", "js/src/wasm/WasmBaselineCompile.cpp", "js/src/wasm/WasmCode.cpp", "js/src/wasm/WasmCode.h", "js/src/wasm/WasmCompile.cpp", "js/src/wasm/WasmCompile.h", "js/src/wasm/WasmCraneliftCompile.cpp", "js/src/wasm/WasmGenerator.cpp", "js/src/wasm/WasmIonCompile.cpp", "js/src/wasm/WasmJS.cpp", "js/src/wasm/WasmValidate.cpp", "js/src/wasm/WasmValidate.h"], "git_node": null, "git_parents": [null], "node": "47e5adb5ad3137edae7d39b84f74d3d748e734ef", "parents": ["217c5f81229668bd561ad67f50888282f2134658"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Bug 1518210 - Wasm: Conditionally create huge memory's based on wasm::IsHugeMemoryEnabled. r=lth\n\nThis commit modifies WasmMemoryObject, ArrayBufferObject,\nSharedArrayBufferObject to support conditionally using huge memory based on the\nglobal flag.\n\nThe memory logic is fairly involved and entangled, making this change a bit\ntricky.\n\nThe following changes were made:\n\n* Stopped conditionally compiling huge memory constants and prefixed them with `Huge`\n* Stopped conditionally compiling `ExtendBufferMapping` and `wasmMovingGrowToSize`\n* Renamed `CreateBuffer` to `CreateSpecificWasmBuffer`\n\t* For clarity\n* Moved maxSize clamping into `CreateSpecificWasmBuffer`\n\t* Lets us keep one callsite to `wasm::IsHugeMemoryEnabled` during memory creation\n* Moved mappedSize computation out of `RawbufT::Allocate` to `CreateSpecificWasmBuffer`\n\t* Lets us keep one callsite to `wasm::IsHugeMemoryEnabled` during memory creation\n* Moved `boundsCheckLimit` computation from `ArrayBufferObjectMaybeShared` to `WasmMemoryObject`\n\t* Lets WasmMemoryObject be responsible for knowing whether it is 'huge' or not\n* Added method to determine if a `WasmMemoryObject` is huge or not\n\t* Lets use know whether we support `movingGrow` or have a `boundsCheckLimit`\n* Refactored `WasmMemoryObject::grow` to have one callsite to `wasmMovingGrowToSize`\n\t* For clarity\n* Added release assert in `Module::instantiateMemory`\n\t* Ensures we have a huge memory or bounds checks if needed\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41869", "files": ["js/src/vm/ArrayBufferObject.cpp", "js/src/vm/ArrayBufferObject.h", "js/src/vm/SharedArrayObject.cpp", "js/src/vm/SharedArrayObject.h", "js/src/wasm/WasmBaselineCompile.cpp", "js/src/wasm/WasmCraneliftCompile.cpp", "js/src/wasm/WasmInstance.cpp", "js/src/wasm/WasmIonCompile.cpp", "js/src/wasm/WasmJS.cpp", "js/src/wasm/WasmJS.h", "js/src/wasm/WasmModule.cpp", "js/src/wasm/WasmTypes.cpp", "js/src/wasm/WasmTypes.h"], "git_node": null, "git_parents": [null], "node": "5bd0f481e985190cf9bf6235d055d97a1378432b", "parents": ["47e5adb5ad3137edae7d39b84f74d3d748e734ef"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Bug 1518210 - Wasm: Make wasm::IsHugeMemoryEnabled() a component of the BuildID for correct invalidation of cached code. r=lth\n\nWe can't deserialize code that doesn't contain bounds checks if we have\ndynamically switched to not using huge memory. This commit uses BuildID to\ninvalidate cached code correctly.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41870", "files": ["js/src/wasm/WasmModule.cpp"], "git_node": null, "git_parents": [null], "node": "f493fd84da04b4e32de28dd4da7c2cb544f4353a", "parents": ["5bd0f481e985190cf9bf6235d055d97a1378432b"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Bug 1518210 - Wasm: Don't run --wasm-disable-huge-memory if the platform doesn't support huge memory. r=lth\n\nThis commit extends the jit-test runner to support\n'skip-variant-if: $FLAG, $COND', and uses this to not run\n'--wasm-disable-huge-memory' tests when the platform doesn't support huge\nmemory.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43670", "files": ["js/src/builtin/TestingFunctions.cpp", "js/src/jit-test/tests/wasm/bench/directives.txt", "js/src/jit-test/tests/wasm/directives.txt", "js/src/jit-test/tests/wasm/gc/directives.txt", "js/src/jit-test/tests/wasm/regress/directives.txt", "js/src/jit-test/tests/wasm/timeout/directives.txt", "js/src/tests/lib/jittests.py"], "git_node": null, "git_parents": [null], "node": "eee3b548e7cd4757d7611ec319aabcea8bf3c2df", "parents": ["f493fd84da04b4e32de28dd4da7c2cb544f4353a"], "tags": []}, {"author": "Brian Hackett \u003cbhackett1024@gmail.com\u003e", "branch": "default", "desc": "Bug 1576797 - Remove threadFront/target references from web replay tests, r=jlast.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43558", "files": ["devtools/client/debugger/test/mochitest/browser_dbg-scroll-run-to-completion.js", "devtools/client/debugger/test/mochitest/helpers.js", "devtools/client/webreplay/mochitest/browser_dbg_rr_breakpoints-01.js", "devtools/client/webreplay/mochitest/browser_dbg_rr_breakpoints-02.js", "devtools/client/webreplay/mochitest/browser_dbg_rr_breakpoints-03.js", "devtools/client/webreplay/mochitest/browser_dbg_rr_breakpoints-04.js", "devtools/client/webreplay/mochitest/browser_dbg_rr_breakpoints-05.js", "devtools/client/webreplay/mochitest/browser_dbg_rr_breakpoints-06.js", "devtools/client/webreplay/mochitest/browser_dbg_rr_breakpoints-07.js", "devtools/client/webreplay/mochitest/browser_dbg_rr_console_warp-01.js", "devtools/client/webreplay/mochitest/browser_dbg_rr_console_warp-02.js", "devtools/client/webreplay/mochitest/browser_dbg_rr_logpoint-01.js", "devtools/client/webreplay/mochitest/browser_dbg_rr_logpoint-02.js", "devtools/client/webreplay/mochitest/browser_dbg_rr_replay-01.js", "devtools/client/webreplay/mochitest/browser_dbg_rr_replay-02.js", "devtools/client/webreplay/mochitest/browser_dbg_rr_stepping-01.js", "devtools/client/webreplay/mochitest/browser_dbg_rr_stepping-02.js", "devtools/client/webreplay/mochitest/browser_dbg_rr_stepping-03.js", "devtools/client/webreplay/mochitest/browser_dbg_rr_stepping-04.js", "devtools/client/webreplay/mochitest/browser_rr_inspector-01.js", "devtools/client/webreplay/mochitest/browser_rr_inspector-02.js", "devtools/client/webreplay/mochitest/browser_rr_inspector-03.js", "devtools/client/webreplay/mochitest/head.js"], "git_node": null, "git_parents": [null], "node": "2708346920d8b5db198821c5a3eecc9e14cc6d73", "parents": ["eee3b548e7cd4757d7611ec319aabcea8bf3c2df"], "tags": []}, {"author": "Dylan Roeh \u003cdroeh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1572191 - Prevent nsPermissionManager from persisting certain permissions to disk under GeckoView. r=snorp,Ehsan\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43759", "files": ["extensions/permissions/nsPermissionManager.cpp", "mobile/android/components/geckoview/GeckoViewPermission.js"], "git_node": null, "git_parents": [null], "node": "a08f7d112fbf395f6b954499cf22b26a1e5d3ea8", "parents": ["2708346920d8b5db198821c5a3eecc9e14cc6d73"], "tags": []}, {"author": "Matthew Noorenberghe \u003cmozilla@noorenberghe.ca\u003e", "branch": "default", "desc": "Bug 1577710 - Disable browser_loginItemErrors.js in debug builds due to intermittent failures. r=ntim\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44276", "files": ["browser/components/aboutlogins/tests/browser/browser.ini"], "git_node": null, "git_parents": [null], "node": "100aaa02891611dc1efbede39a6e99f04ab03989", "parents": ["a08f7d112fbf395f6b954499cf22b26a1e5d3ea8"], "tags": []}, {"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 1577819, part 1 - Rename mozilla::dom::ProcType to mozilla::dom::WebIDLProcType. r=Ehsan\n\nThere is also a mozilla::ProcType, which makes things\nconfusing. dom::ProcType seems to be used only for passing values to\nJS via WebIDL, so I put WebIDL in the name.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44211", "files": ["dom/base/ChromeUtils.cpp", "dom/chrome-webidl/ChromeUtils.webidl"], "git_node": null, "git_parents": [null], "node": "01e8fd20bdc19218fc076daa79720c55ed3b7f08", "parents": ["100aaa02891611dc1efbede39a6e99f04ab03989"], "tags": []}, {"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 1577819, part 2 - WebIDLProcType should match ProcType. r=Ehsan\n\nProcType gets turned into WebIDLProcType, so I assume the intention is\nthat they are identical. I changed the definition of WebIDLProcType to\nmatch ProcType, and added a static assert to check that they have the\nsame number of cases.\n\nI also changed the coercion from a static_cast\u003c\u003e to an explicit switch\nstatement so that it will degrade more gracefully if, say, the enums\nget reordered, or one enum gets a case added and removed at the same\ntime.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44212", "files": ["dom/base/ChromeUtils.cpp", "dom/chrome-webidl/ChromeUtils.webidl", "widget/ProcInfo.h"], "git_node": null, "git_parents": [null], "node": "dd470e3dff60dc0e8e7f874cd95d3580503bb4e0", "parents": ["01e8fd20bdc19218fc076daa79720c55ed3b7f08"], "tags": []}, {"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 1577819, part 3 - Initialize process type in RequestProcInfo. r=Ehsan\n\nRight now, the type ends up being uninitialized if the type doesn't\nmatch, in the GeckoProcessType_Content case.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44213", "files": ["dom/base/ChromeUtils.cpp"], "git_node": null, "git_parents": [null], "node": "a9ac86bbe8d0bdec01fecf09827514a780142e57", "parents": ["dd470e3dff60dc0e8e7f874cd95d3580503bb4e0"], "tags": []}, {"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 1577819, part 4 - Add some basic validity checks for the type. r=Ehsan\n\nThe test for procinfo doesn't check if the process type is\nreasonable. With Fission, this test now asserts, so add a failure\nannotation. I'll fix it up for Fission in another bug.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44214", "files": ["widget/tests/browser/browser.ini", "widget/tests/browser/browser_test_procinfo.js"], "git_node": null, "git_parents": [null], "node": "98059acdf5be3f6b91a14e5700403432dd998ab8", "parents": ["a9ac86bbe8d0bdec01fecf09827514a780142e57"], "tags": []}, {"author": "Luke Crouch \u003clcrouch@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575597: Add pref UI for login breach alerts. r=fluent-reviewers,MattN,flod\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43831", "files": ["browser/components/BrowserGlue.jsm", "browser/components/aboutlogins/LoginBreaches.jsm", "browser/components/preferences/in-content/privacy.inc.xul", "browser/components/preferences/in-content/privacy.js", "browser/locales/en-US/browser/preferences/preferences.ftl", "toolkit/components/passwordmgr/storage-json.js", "toolkit/components/passwordmgr/test/unit/test_vulnerable_passwords.js"], "git_node": null, "git_parents": [null], "node": "bf6c6df8d211178292928a2194c560b22b168ba3", "parents": ["98059acdf5be3f6b91a14e5700403432dd998ab8"], "tags": []}, {"author": "Jason Laster \u003cjlaster@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575240 - inspect(x) should show x in the appropriate panel. r=nchevobbe\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42747", "files": ["devtools/client/framework/toolbox.js", "devtools/client/webconsole/test/browser/browser.ini", "devtools/client/webconsole/test/browser/browser_jsterm_inspect_panels.js", "devtools/client/webconsole/test/browser/test-simple-function.html", "devtools/client/webconsole/test/browser/test-simple-function.js", "devtools/client/webconsole/webconsole-wrapper.js"], "git_node": null, "git_parents": [null], "node": "204d32b36d7e2e2e06126b3b08015e4cca2134d8", "parents": ["bf6c6df8d211178292928a2194c560b22b168ba3"], "tags": []}, {"author": "Gurzau Raul \u003crgurzau@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 4d4271a0ccad (bug 1565332) for Android Mochitest failures on a CLOSED TREE.", "files": ["taskcluster/ci/docker-image/kind.yml", "taskcluster/docker/debian10-test/Dockerfile", "taskcluster/docker/debian10-test/apport", "taskcluster/docker/debian10-test/dot-files/config/pip/pip.conf", "taskcluster/docker/debian10-test/dot-files/config/user-dirs.dirs", "taskcluster/docker/debian10-test/dot-files/config/user-dirs.locale", "taskcluster/docker/debian10-test/dot-files/pulse/client.conf", "taskcluster/docker/debian10-test/dot-files/pulse/default.pa", "taskcluster/docker/debian10-test/fonts.conf", "taskcluster/docker/debian10-test/motd", "taskcluster/docker/debian10-test/taskcluster-interactive-shell", "taskcluster/docker/recipes/debian-test-system-setup.sh", "taskcluster/scripts/tester/test-linux.sh", "testing/mochitest/mochitest_options.py", "testing/mochitest/runtests.py"], "git_node": null, "git_parents": [null], "node": "f6714b862df3110ec4435d152ddbdbe6f3555527", "parents": ["204d32b36d7e2e2e06126b3b08015e4cca2134d8"], "tags": []}, {"author": "Brad Werth \u003cbwerth@mozilla.com\u003e", "branch": "default", "desc": "Bug 1563163 Part 1: Make Flex::Flex gracefully handle frames without FlexContainerInfo structures. r=mats\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44283", "files": ["dom/flex/Flex.cpp"], "git_node": null, "git_parents": [null], "node": "5119f09d6b99ac8b9f27ee676e8dc7acdfb02815", "parents": ["f6714b862df3110ec4435d152ddbdbe6f3555527"], "tags": []}, {"author": "Brad Werth \u003cbwerth@mozilla.com\u003e", "branch": "default", "desc": "Bug 1563163 Part 2: Downgrade an assert to a warning in nsFlexContainerFrame::GetFlexFrameWithComputedInfo. r=mats\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44284", "files": ["layout/generic/nsFlexContainerFrame.cpp", "layout/generic/nsFlexContainerFrame.h"], "git_node": null, "git_parents": [null], "node": "776f100fead626a135489e8a5373b237c1691c2f", "parents": ["5119f09d6b99ac8b9f27ee676e8dc7acdfb02815"], "tags": []}, {"author": "Robert Helmer \u003crhelmer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576507 - add new FirstStartup service and --first-startup post-install flag. r=mconley\n\nFirstStartup provides an optional mechanism to run synchronous services\nbefore the UI appears. This is intended to be called as a post-install\naction from an installer, such as the Windows Stub Installer, to allow\nfor downloading critical data and performance tuning before the first\nrun of a new Firefox install.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43364", "files": ["browser/components/BrowserContentHandler.jsm", "toolkit/modules/FirstStartup.jsm", "toolkit/modules/moz.build"], "git_node": null, "git_parents": [null], "node": "2d621070f778e4998b7efab944e4e9fb45e84862", "parents": ["776f100fead626a135489e8a5373b237c1691c2f"], "tags": []}, {"author": "Robert Helmer \u003crhelmer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576507 - skip ClientEnvironment entries unavailable on first run r=mythmon\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43570", "files": ["toolkit/components/utils/ClientEnvironment.jsm"], "git_node": null, "git_parents": [null], "node": "f16714d49101f2e80daeacbe4f38d74fa0a5cf7d", "parents": ["2d621070f778e4998b7efab944e4e9fb45e84862"], "tags": []}, {"author": "Robert Helmer \u003crhelmer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576507 - add Normandy to FirstStartup service. r=mythmon\n\nDepends on D43365\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43366", "files": ["toolkit/components/normandy/Normandy.jsm", "toolkit/components/telemetry/Scalars.yaml", "toolkit/modules/FirstStartup.jsm", "toolkit/modules/tests/xpcshell/test_firstStartup.js", "toolkit/modules/tests/xpcshell/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "2238ba5cec98f76011ba7b53a019124b7d048e70", "parents": ["f16714d49101f2e80daeacbe4f38d74fa0a5cf7d"], "tags": []}, {"author": "Robert Helmer \u003crhelmer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576507 - document FirstStartup module r=mythmon\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44035", "files": ["toolkit/modules/docs/FirstStartup.rst", "toolkit/modules/docs/index.rst"], "git_node": null, "git_parents": [null], "node": "efca0164a7621c926a4661314d2120c67754ed0d", "parents": ["2238ba5cec98f76011ba7b53a019124b7d048e70"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1577888 - Add whatsnew badge, optimistic cards and bug fixes to New Tab Page r=k88hudson\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44271", "files": ["browser/components/newtab/content-src/asrouter/templates/OnboardingMessage/OnboardingMessage.jsx", "browser/components/newtab/content-src/asrouter/templates/SimpleBelowSearchSnippet/_SimpleBelowSearchSnippet.scss", "browser/components/newtab/content-src/asrouter/templates/Trailhead/Trailhead.jsx", "browser/components/newtab/content-src/asrouter/templates/Trailhead/_Trailhead.scss", "browser/components/newtab/content-src/components/DiscoveryStreamBase/DiscoveryStreamBase.jsx", "browser/components/newtab/content-src/components/DiscoveryStreamBase/_DiscoveryStreamBase.scss", "browser/components/newtab/content-src/components/DiscoveryStreamComponents/CardGrid/CardGrid.jsx", "browser/components/newtab/content-src/components/DiscoveryStreamComponents/CardGrid/_CardGrid.scss", "browser/components/newtab/content-src/components/DiscoveryStreamComponents/DSCard/DSCard.jsx", "browser/components/newtab/content-src/components/DiscoveryStreamComponents/DSCard/_DSCard.scss", "browser/components/newtab/content-src/components/DiscoveryStreamComponents/DSImage/DSImage.jsx", "browser/components/newtab/content-src/components/DiscoveryStreamComponents/DSImage/_DSImage.scss", "browser/components/newtab/content-src/components/DiscoveryStreamComponents/DSTextPromo/DSTextPromo.jsx", "browser/components/newtab/content-src/components/DiscoveryStreamComponents/DSTextPromo/_DSTextPromo.scss", "browser/components/newtab/content-src/components/DiscoveryStreamImpressionStats/ImpressionStats.jsx", "browser/components/newtab/css/activity-stream-linux.css", "browser/components/newtab/css/activity-stream-mac.css", "browser/components/newtab/css/activity-stream-windows.css", "browser/components/newtab/data/content/activity-stream.bundle.js", "browser/components/newtab/lib/OnboardingMessageProvider.jsm", "browser/components/newtab/lib/PanelTestProvider.jsm", "browser/components/newtab/test/browser/browser.ini", "browser/components/newtab/test/browser/browser_asrouter_whatsnewpanel.js", "browser/components/newtab/test/unit/asrouter/PanelTestProvider.test.js", "browser/components/newtab/test/unit/content-src/components/DiscoveryStreamComponents/ImpressionStats.test.jsx", "browser/components/newtab/test/unit/lib/ToolbarBadgeHub.test.js"], "git_node": null, "git_parents": [null], "node": "9a0918622c83a226c6208ff7ea7a99df2d9a6bc2", "parents": ["efca0164a7621c926a4661314d2120c67754ed0d"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1574995 - Update Firefox workmark for the Private Browsing page r=k88hudson\n\nAdjust sizing to match https://github.com/mozilla/activity-stream/commit/ba740fb695efbe0c5b7817ffc2439293aff34b39\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44274", "files": ["browser/themes/shared/privatebrowsing/aboutPrivateBrowsing.css"], "git_node": null, "git_parents": [null], "node": "ee9ff899ce0c6dba4270b8259c1eb85497e9c910", "parents": ["9a0918622c83a226c6208ff7ea7a99df2d9a6bc2"], "tags": []}, {"author": "Nihanth Subramanya \u003cnhnt11@gmail.com\u003e", "branch": "default", "desc": "Bug 1577939 - [Protections Panel] Fix typo in selector that sets --height-offset. r=lina,Mardak\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44291", "files": ["browser/themes/shared/controlcenter/panel.inc.css"], "git_node": null, "git_parents": [null], "node": "becfb41d4f81b92d08532b7027e0be696d6e80cb", "parents": ["ee9ff899ce0c6dba4270b8259c1eb85497e9c910"], "tags": []}, {"author": "Andrei Oprea \u003candrei.br92@gmail.com\u003e", "branch": "default", "desc": "Bug 1571022 - Conditional rendering for CFR feature recommendations r=k88hudson\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43630", "files": ["browser/components/newtab/lib/ASRouter.jsm", "browser/components/newtab/lib/CFRMessageProvider.jsm", "browser/components/newtab/lib/CFRPageActions.jsm", "browser/components/newtab/test/browser/browser_asrouter_cfr.js", "browser/themes/shared/browser.inc.css"], "git_node": null, "git_parents": [null], "node": "d6aa2851ca9612c23409d5194fe2d912a9748958", "parents": ["becfb41d4f81b92d08532b7027e0be696d6e80cb"], "tags": []}, {"author": "Timothy Nikkel \u003ctnikkel@gmail.com\u003e", "branch": "default", "desc": "Bug 1567418. Try to diagnose crash in png decoder. r=aosmond\n\nCall WriteRow from a different line number if we have an interlacing buffer. I think the compiler shouldn't be able to optimize these into the same code, and so we should be able to distinguish them.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44061", "files": ["image/decoders/nsPNGDecoder.cpp"], "git_node": null, "git_parents": [null], "node": "c9487e92cf629f7ce92fe5074323fdfb46562a2b", "parents": ["d6aa2851ca9612c23409d5194fe2d912a9748958"], "tags": []}, {"author": "Eric Rahm \u003cerahm@mozilla.com\u003e", "branch": "default", "desc": "Bug 1577867 - Remove using namespace std from image/ r=tnikkel\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44250", "files": ["image/imgLoader.cpp"], "git_node": null, "git_parents": [null], "node": "98bdc3047120ee9d3700f4c13bc09b0db585c58f", "parents": ["c9487e92cf629f7ce92fe5074323fdfb46562a2b"], "tags": []}, {"author": "Eric Rahm \u003cerahm@mozilla.com\u003e", "branch": "default", "desc": "Bug 1577869 - Remove using namespace std from js/ r=jwalden\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44253", "files": ["js/src/ctypes/CTypes.cpp"], "git_node": null, "git_parents": [null], "node": "52721fabd4d12278444dccd78a90cbb2bbba3720", "parents": ["98bdc3047120ee9d3700f4c13bc09b0db585c58f"], "tags": []}, {"author": "Daniel Holbert \u003cdholbert@cs.stanford.edu\u003e", "branch": "default", "desc": "Bug 1577072: Use a slightly larger line-height in our \"bigger-than-one\" text-input line-height reftest, to accommodate bigger widgets on Debian. r=dbaron\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43787", "files": ["layout/reftests/forms/input/text/line-height-1.5.html", "layout/reftests/forms/input/text/line-height-1.8.html", "layout/reftests/forms/input/text/reftest.list"], "git_node": null, "git_parents": [null], "node": "7d029a9d6c0de272be77e49114555e493b480a05", "parents": ["52721fabd4d12278444dccd78a90cbb2bbba3720"], "tags": []}, {"author": "arthur.iakab \u003caiakab@mozilla.com\u003e", "branch": "default", "desc": "Backed out 4 changesets (bug 1576507) for causing xpcshell failures on test_firstStartup.js\n\nBacked out changeset efca0164a762 (bug 1576507)\nBacked out changeset 2238ba5cec98 (bug 1576507)\nBacked out changeset f16714d49101 (bug 1576507)\nBacked out changeset 2d621070f778 (bug 1576507)", "files": ["browser/components/BrowserContentHandler.jsm", "toolkit/components/normandy/Normandy.jsm", "toolkit/components/telemetry/Scalars.yaml", "toolkit/components/utils/ClientEnvironment.jsm", "toolkit/modules/FirstStartup.jsm", "toolkit/modules/docs/FirstStartup.rst", "toolkit/modules/docs/index.rst", "toolkit/modules/moz.build", "toolkit/modules/tests/xpcshell/test_firstStartup.js", "toolkit/modules/tests/xpcshell/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "2da8982d97aa34a90b0bd871dc32ac8aa65e40a7", "parents": ["7d029a9d6c0de272be77e49114555e493b480a05"], "tags": []}, {"author": "Jeff Walden \u003cjwalden@mit.edu\u003e", "branch": "default", "desc": "Bug 1577373 - Move ReadableStream{,Default}Reader details out of builtin/Stream.* to separate files.  r=arai\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43911", "files": ["js/src/builtin/Stream.cpp", "js/src/builtin/Stream.h", "js/src/builtin/streams/ReadableStreamDefaultReader.cpp", "js/src/builtin/streams/ReadableStreamReader.h", "js/src/moz.build", "js/src/vm/GlobalObject.cpp"], "git_node": null, "git_parents": [null], "node": "724755d6ff65b56b065aeff5f41ecadb3f15899a", "parents": ["2da8982d97aa34a90b0bd871dc32ac8aa65e40a7"], "tags": []}, {"author": "Jeff Walden \u003cjwalden@mit.edu\u003e", "branch": "default", "desc": "Bug 1577373 - Move ReadableStreamReader abstract operations out of Stream.cpp.  r=arai\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43912", "files": ["js/src/builtin/Stream.cpp", "js/src/builtin/Stream.h", "js/src/builtin/streams/ReadableStreamReader-inl.h", "js/src/builtin/streams/ReadableStreamReader.cpp", "js/src/builtin/streams/ReadableStreamReader.h", "js/src/moz.build"], "git_node": null, "git_parents": [null], "node": "a2c5184de22643f485fb8f6dfa586e1502044855", "parents": ["724755d6ff65b56b065aeff5f41ecadb3f15899a"], "tags": []}, {"author": "Jeff Walden \u003cjwalden@mit.edu\u003e", "branch": "default", "desc": "Bug 1577373 - Move public/friend stream API functions into a new file.  r=arai\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43913", "files": ["js/src/builtin/Stream.cpp", "js/src/builtin/Stream.h", "js/src/builtin/streams/StreamAPI.cpp", "js/src/moz.build"], "git_node": null, "git_parents": [null], "node": "2b9bdb19e36ab435879f22d01058e36d9085b7f2", "parents": ["a2c5184de22643f485fb8f6dfa586e1502044855"], "tags": []}, {"author": "Jeff Walden \u003cjwalden@mit.edu\u003e", "branch": "default", "desc": "Bug 1577373 - Move TeeState details into separate files.  r=arai\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43914", "files": ["js/src/builtin/Stream.cpp", "js/src/builtin/streams/TeeState.cpp", "js/src/builtin/streams/TeeState.h", "js/src/moz.build"], "git_node": null, "git_parents": [null], "node": "3f547590647a4d130177bb265470c09b02a15948", "parents": ["2b9bdb19e36ab435879f22d01058e36d9085b7f2"], "tags": []}, {"author": "Jeff Walden \u003cjwalden@mit.edu\u003e", "branch": "default", "desc": "Bug 1577373 - Move ReadableStream abstract operations to their own header.  r=arai\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43915", "files": ["js/src/builtin/Stream.cpp", "js/src/builtin/Stream.h", "js/src/builtin/streams/HandlerFunction-inl.h", "js/src/builtin/streams/ReadableStreamOperations.cpp", "js/src/builtin/streams/ReadableStreamOperations.h", "js/src/builtin/streams/StreamAPI.cpp", "js/src/moz.build"], "git_node": null, "git_parents": [null], "node": "d8ca7b07183c81c067b6680032f5bd4d7963f8ca", "parents": ["3f547590647a4d130177bb265470c09b02a15948"], "tags": []}, {"author": "Jeff Walden \u003cjwalden@mit.edu\u003e", "branch": "default", "desc": "Bug 1577373 - Split PullIntoDescriptor code into separate files.  r=arai\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43916", "files": ["js/src/builtin/Stream.cpp", "js/src/builtin/streams/PullIntoDescriptor.cpp", "js/src/builtin/streams/PullIntoDescriptor.h", "js/src/moz.build"], "git_node": null, "git_parents": [null], "node": "e6c27cc40626dcd4255c0dd096db338d533ea0d8", "parents": ["d8ca7b07183c81c067b6680032f5bd4d7963f8ca"], "tags": []}, {"author": "Jeff Walden \u003cjwalden@mit.edu\u003e", "branch": "default", "desc": "Bug 1577373 - Move ReadableStream standard library bits into separate files.  r=arai\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43917", "files": ["js/src/builtin/Stream.cpp", "js/src/builtin/Stream.h", "js/src/builtin/streams/ReadableStream.cpp", "js/src/builtin/streams/ReadableStream.h", "js/src/builtin/streams/ReadableStreamDefaultReader.cpp", "js/src/builtin/streams/ReadableStreamOperations.cpp", "js/src/builtin/streams/ReadableStreamReader-inl.h", "js/src/builtin/streams/ReadableStreamReader.cpp", "js/src/builtin/streams/StreamAPI.cpp", "js/src/builtin/streams/TeeState.cpp", "js/src/moz.build", "js/src/vm/GlobalObject.cpp"], "git_node": null, "git_parents": [null], "node": "035b232180066fa2dad1ffa9a1fe150fda463f65", "parents": ["e6c27cc40626dcd4255c0dd096db338d533ea0d8"], "tags": []}, {"author": "Jeff Walden \u003cjwalden@mit.edu\u003e", "branch": "default", "desc": "Bug 1577373 - Move IsMaybeWrapped to a header so it can be used in multiple files.  (It can't be *static* in those multiple files because of scumbag unified builds.)  r=arai\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43918", "files": ["js/src/builtin/Stream.cpp", "js/src/builtin/streams/MiscellaneousOperations.h"], "git_node": null, "git_parents": [null], "node": "b1148ccfa82f87a39998f1d77018193739cd3e99", "parents": ["035b232180066fa2dad1ffa9a1fe150fda463f65"], "tags": []}, {"author": "Jeff Walden \u003cjwalden@mit.edu\u003e", "branch": "default", "desc": "Bug 1577373 - Move ReadableStream stream/controller interactions to separate files.  r=arai\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43919", "files": ["js/src/builtin/Stream.cpp", "js/src/builtin/Stream.h", "js/src/builtin/streams/ReadableStream.cpp", "js/src/builtin/streams/ReadableStreamInternals.cpp", "js/src/builtin/streams/ReadableStreamInternals.h", "js/src/builtin/streams/ReadableStreamOperations.cpp", "js/src/builtin/streams/ReadableStreamReader.cpp", "js/src/builtin/streams/ReadableStreamReader.h", "js/src/builtin/streams/StreamAPI.cpp", "js/src/moz.build"], "git_node": null, "git_parents": [null], "node": "5aa0ce9364274e09987df67b6a563c25b05a5920", "parents": ["b1148ccfa82f87a39998f1d77018193739cd3e99"], "tags": []}, {"author": "Jeff Walden \u003cjwalden@mit.edu\u003e", "branch": "default", "desc": "Bug 1577373 - Move ReadableStreamDefaultController details into separate files.  r=arai\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43920", "files": ["js/src/builtin/Stream.cpp", "js/src/builtin/Stream.h", "js/src/builtin/streams/QueueWithSizes.cpp", "js/src/builtin/streams/ReadableStreamController.h", "js/src/builtin/streams/ReadableStreamDefaultController.cpp", "js/src/builtin/streams/ReadableStreamInternals.cpp", "js/src/builtin/streams/ReadableStreamReader.cpp", "js/src/builtin/streams/StreamAPI.cpp", "js/src/builtin/streams/TeeState.h", "js/src/moz.build", "js/src/vm/GlobalObject.cpp"], "git_node": null, "git_parents": [null], "node": "50eea29e2a96f6feb1ceb00ae9d8836892de9503", "parents": ["5aa0ce9364274e09987df67b6a563c25b05a5920"], "tags": []}, {"author": "Jeff Walden \u003cjwalden@mit.edu\u003e", "branch": "default", "desc": "Bug 1577373 - Move readable stream default controller operations into their own file.  r=arai\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43921", "files": ["js/src/builtin/Stream.cpp", "js/src/builtin/Stream.h", "js/src/builtin/streams/ReadableStream.cpp", "js/src/builtin/streams/ReadableStream.h", "js/src/builtin/streams/ReadableStreamDefaultController.cpp", "js/src/builtin/streams/ReadableStreamDefaultControllerOperations.cpp", "js/src/builtin/streams/ReadableStreamDefaultControllerOperations.h", "js/src/builtin/streams/ReadableStreamOperations.cpp", "js/src/builtin/streams/ReadableStreamOperations.h", "js/src/builtin/streams/ReadableStreamReader.cpp", "js/src/builtin/streams/StreamAPI.cpp", "js/src/moz.build"], "git_node": null, "git_parents": [null], "node": "d42177dc73dcaa7d7b3b3c34c94bb2cbe928f9a0", "parents": ["50eea29e2a96f6feb1ceb00ae9d8836892de9503"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1574745 - Use an explicit offset to deal with the fact that aClipRect in Compositor::DrawGeometry is relative to (0, 0) for the root render target, and not in the render target's device space. r=mattwoodrow\n\naClipRect is relative to\nclosestAncestorContainerLayerWithIntermediateSurface-\u003eGetVisibleRegion().GetBounds().TopLeft()\nor (0, 0) if there is no ancestor with an intermediate surface.\nIt gets computed by Layer::CalculateScissorRect.\nSo if there is an intermediate surface, that origin matches the render target\norigin. But if there is no intermediate surface, it does not always match: the\nroot render target's origin is not necessarily (0, 0).\n\nIn the past, BasicCompositor dealt with this by using the transform on the root\nrender target's mDrawTarget, which gets set in CreateRenderTargetAndClear\n(renamed to CreateRootRenderTarget in this patch). Render targets created in the\nregular CreateRenderTarget did not have a transform.\nThis allowed DrawGeometry to only conditionally apply an offset to aClipRect;\nthe offset was applied by calling PushClipRect before resetting the transform.\nNow all render targets have a translation by -offset on their DrawTarget, not\njust the root render target.\n\nI went with an explicit \"clip space origin\" field on the render target.\nOther alternatives would have been:\n - Having a bool IsRootRenderTarget() and using that to conditionally offset\n   aClipRect by the render target origin or not.\n - Changing Layer::CalculateScissorRect so that the clip space origin is always\n   (0, 0). I actually tried this first but ran into trouble with the MLGPU code.\n   We can do it later.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43866", "files": ["gfx/layers/basic/BasicCompositor.cpp", "gfx/layers/basic/BasicCompositor.h"], "git_node": null, "git_parents": [null], "node": "610cc17c583235db3e4a27f56c0cda2eae875d21", "parents": ["d42177dc73dcaa7d7b3b3c34c94bb2cbe928f9a0"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1574745 - Prepare BasicCompositor for layers that are not located at (0, 0). r=mattwoodrow\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43867", "files": ["gfx/layers/basic/BasicCompositor.cpp"], "git_node": null, "git_parents": [null], "node": "8a64ef16fc2e4d5ba18516280479cd69ad948c8c", "parents": ["610cc17c583235db3e4a27f56c0cda2eae875d21"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1574745 - Treat aClipRect in CompositorOGL::DrawGeometry correctly when drawing to a root render target that's not at (0, 0). r=mattwoodrow\n\nThis uses the same workaround as BasicCompositor.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43868", "files": ["gfx/layers/opengl/CompositingRenderTargetOGL.h", "gfx/layers/opengl/CompositorOGL.cpp"], "git_node": null, "git_parents": [null], "node": "de0fadd41dc3ef6620b9b82776b295f79012876e", "parents": ["8a64ef16fc2e4d5ba18516280479cd69ad948c8c"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1574745 - Prepare CompositorOGL for native layers that are not located at (0, 0). r=mattwoodrow\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42424", "files": ["gfx/layers/composite/TextureHost.h", "gfx/layers/opengl/CompositorOGL.cpp"], "git_node": null, "git_parents": [null], "node": "dd092bce314d6c0292d54b50ce540cfcf9e435bf", "parents": ["de0fadd41dc3ef6620b9b82776b295f79012876e"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1574745 - Respect render target clip during DrawGeometry culling and overdraw pixel counting. r=mattwoodrow\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43869", "files": ["gfx/layers/opengl/CompositorOGL.cpp"], "git_node": null, "git_parents": [null], "node": "f988e453af006431e31402f70dafd9bf5ef5e563", "parents": ["dd092bce314d6c0292d54b50ce540cfcf9e435bf"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1574745 - Make DrawGeometry culling work more reliably. r=mattwoodrow\n\nThe call to TransformAndClipBounds already clips destRect to renderBounds.\nHowever, if the resulting rect was empty, the Inflate call would make it\nnon-empty again. And now the decision whether we would cull would depend on the\nrect's position: Sometimes TransformAndClipBounds would place the empty rect at\na position along an edge of renderBounds, and then the inflated-from-nothingness\n2x2 rect would overlap renderBounds and we wouldn't cull.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43870", "files": ["gfx/layers/opengl/CompositorOGL.cpp"], "git_node": null, "git_parents": [null], "node": "cc84a0e9d5ddde198422f4f11ab6bf85f631d5f0", "parents": ["f988e453af006431e31402f70dafd9bf5ef5e563"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1574745 - Rename BeginFrame to BeginFrameForWindow. r=mattwoodrow\n\nIn the end we want to have BeginFrameForWindow, BeginFrameForTarget, and\nBeginFrameForNativeLayers, the latter with multiple Begin/EndRenderingToNativeLayer\npairs nested inside.\n\nThis is the first step.\n\nCompositorOGL and CompositorD3D11 keep their internal BeginFrame method but make\nit private.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43871", "files": ["gfx/layers/Compositor.h", "gfx/layers/basic/BasicCompositor.cpp", "gfx/layers/basic/BasicCompositor.h", "gfx/layers/composite/LayerManagerComposite.cpp", "gfx/layers/d3d11/CompositorD3D11.cpp", "gfx/layers/d3d11/CompositorD3D11.h", "gfx/layers/opengl/CompositorOGL.cpp", "gfx/layers/opengl/CompositorOGL.h"], "git_node": null, "git_parents": [null], "node": "6035e8ef4f82c1ab750f8fb0ca35c374c61ea9ed", "parents": ["cc84a0e9d5ddde198422f4f11ab6bf85f631d5f0"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1574745 - Add BeginFrameForTarget and replace Set/ClearTargetContext. r=mattwoodrow\n\nThis removes any *TargetContext methods from the Compositor interface and moves\n mTarget tracking into the compositor implementations.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43872", "files": ["gfx/layers/Compositor.h", "gfx/layers/basic/BasicCompositor.cpp", "gfx/layers/basic/BasicCompositor.h", "gfx/layers/composite/LayerManagerComposite.cpp", "gfx/layers/d3d11/CompositorD3D11.cpp", "gfx/layers/d3d11/CompositorD3D11.h", "gfx/layers/opengl/CompositorOGL.cpp", "gfx/layers/opengl/CompositorOGL.h"], "git_node": null, "git_parents": [null], "node": "1591247f9ce85e372ad6dcb36b952f1914667856", "parents": ["6035e8ef4f82c1ab750f8fb0ca35c374c61ea9ed"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1574745 - Add BeginFrameForNativeLayers() and Begin/EndRenderingToNativeLayer. r=mattwoodrow\n\nThis will let us render into multiple layers within one compositor frame.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43873", "files": ["gfx/layers/Compositor.h", "gfx/layers/basic/BasicCompositor.cpp", "gfx/layers/basic/BasicCompositor.h", "gfx/layers/composite/LayerManagerComposite.cpp", "gfx/layers/d3d11/CompositorD3D11.cpp", "gfx/layers/d3d11/CompositorD3D11.h", "gfx/layers/opengl/CompositorOGL.cpp", "gfx/layers/opengl/CompositorOGL.h"], "git_node": null, "git_parents": [null], "node": "4fcd04e8261e97537bd5a5c48e94385593421e40", "parents": ["1591247f9ce85e372ad6dcb36b952f1914667856"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1574745 - Calculate mShouldInvalidateWindow at the beginning of the frame. r=mattwoodrow\n\nThis is so that we can invalidate all layers when screenshot profiling has\nstarted, and not just the first layer.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43874", "files": ["gfx/layers/basic/BasicCompositor.cpp", "gfx/layers/basic/BasicCompositor.h"], "git_node": null, "git_parents": [null], "node": "ee0a3838c5c1d210b3c0b94da267b7d8a55bc5c6", "parents": ["4fcd04e8261e97537bd5a5c48e94385593421e40"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1574745 - Move ShouldRecordFrames() from BasicCompositor to Compositor because CompositorOGL will need it. r=mattwoodrow\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43875", "files": ["gfx/layers/Compositor.cpp", "gfx/layers/Compositor.h", "gfx/layers/basic/BasicCompositor.cpp", "gfx/layers/basic/BasicCompositor.h"], "git_node": null, "git_parents": [null], "node": "6d1b97aed6f0ed5b25eeb1246d38ebd964156e81", "parents": ["ee0a3838c5c1d210b3c0b94da267b7d8a55bc5c6"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1574745 - Change BlitFrameBufferToFrameBuffer to take rects instead of sizes. r=jgilbert\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43876", "files": ["gfx/gl/GLBlitHelper.cpp", "gfx/gl/GLBlitHelper.h", "gfx/gl/SharedSurface.cpp", "gfx/layers/opengl/CompositorOGL.cpp"], "git_node": null, "git_parents": [null], "node": "29be5f4832cabc9a1a94268138b47b1af988e1e4", "parents": ["6d1b97aed6f0ed5b25eeb1246d38ebd964156e81"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1574745 - Maintain a full window render target when rendering to native layers with CompositorOGL. r=mattwoodrow\n\nThis makes profiler screenshots and frame recording work again, when native\nlayers are used. The copying is a bit unfortunate. Maybe we can combine this\ncopy with the first downscaling step in the future. Or for frame recording,\nwhich doesn't use downscaling, we could readback the layers individually and\nreassemble them in CPU memory. But both of those solutions are more complex\nthan this.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43877", "files": ["gfx/layers/opengl/CompositorOGL.cpp", "gfx/layers/opengl/CompositorOGL.h"], "git_node": null, "git_parents": [null], "node": "ea690c643c8cba21a81cc2ee279e21ba03b2a8b1", "parents": ["29be5f4832cabc9a1a94268138b47b1af988e1e4"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1574745 - Reorder layer rendering invocations. r=mattwoodrow\n\nThis change groups the work that has to be done per compositing tile.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43878", "files": ["gfx/layers/composite/LayerManagerComposite.cpp"], "git_node": null, "git_parents": [null], "node": "1db2a705c75c28805a054c2023401860fad803df", "parents": ["ea690c643c8cba21a81cc2ee279e21ba03b2a8b1"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1574745 - Get everything ready for rendering into multiple native layers. r=mattwoodrow\n\nThis change breaks the draw-fps overlay when using native layers. I'll try to\nfix that in a new bug soon.\n\nThe do { } while(0) loop looks a bit odd, but it'll get replaced with a proper\nloop in bug 1574586.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43879", "files": ["gfx/layers/composite/LayerManagerComposite.cpp"], "git_node": null, "git_parents": [null], "node": "56928dc94586cba272761f8af49e67795baab0bf", "parents": ["1db2a705c75c28805a054c2023401860fad803df"], "tags": []}, {"author": "Nick Alexander \u003cnalexander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1577922 - Bump browsertime hash to c795660ef1e589dfb8bf01397782811934c90696. r=sefeng\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44288", "files": ["tools/browsertime/package.json"], "git_node": null, "git_parents": [null], "node": "da6f33b8403d6e2a56a836714d97bb29f6a9d8e3", "parents": ["56928dc94586cba272761f8af49e67795baab0bf"], "tags": []}, {"author": "Mihai Alexandru Michis \u003cmalexandru@mozilla.com\u003e", "branch": "default", "desc": "Bug 1574745 - Fix bustages on OS X Cross Compiled. a=bustage-fix CLOSED TREE", "files": ["gfx/layers/composite/LayerManagerComposite.cpp"], "git_node": null, "git_parents": [null], "node": "25005fcdb10689745308d4eab5d67f4dd2b034ab", "parents": ["da6f33b8403d6e2a56a836714d97bb29f6a9d8e3"], "tags": []}, {"author": "Daniel Holbert \u003cdholbert@cs.stanford.edu\u003e", "branch": "default", "desc": "Bug 1577053 part 1: Update generate-text-emphasis-* test creation scripts to add lang=\"ja\". r=jfkthame\n\nAlso, adjust the scripts to leave behind a note in each generated HTML file, to\ntell the reader that the file is auto-generated.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44257", "files": ["layout/reftests/w3c-css/submitted/text-decor-3/support/generate-text-emphasis-line-height-tests.py", "layout/reftests/w3c-css/submitted/text-decor-3/support/generate-text-emphasis-position-property-tests.py", "layout/reftests/w3c-css/submitted/text-decor-3/support/generate-text-emphasis-ruby-tests.py", "layout/reftests/w3c-css/submitted/text-decor-3/support/generate-text-emphasis-style-property-010-tests.sh", "layout/reftests/w3c-css/submitted/text-decor-3/support/generate-text-emphasis-style-property-tests.py"], "git_node": n