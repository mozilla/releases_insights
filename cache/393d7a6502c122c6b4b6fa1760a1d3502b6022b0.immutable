_addons.py", "taskcluster/taskgraph/transforms/release_generate_checksums_beetmover.py", "taskcluster/taskgraph/util/scriptworker.py"], "git_node": null, "git_parents": [null], "node": "e7f3f12d59e3b95b63bef535fa022ac9646afc9f", "parents": ["47ced6e49cfccfda6b0c369ddaf3eab0dba13ad3"], "tags": []}], "date": 1568245084, "git_changesets": [null], "user": "mtabara@mozilla.com"}, "11932": {"changesets": [{"author": "Narcis Beleuzu \u003cnbeleuzu@mozilla.com\u003e", "branch": "default", "desc": "Backed out 2 changesets (bug 1572878) for mda failures on test_convolverNodeOOM.html. a=backout\n\nBacked out changeset f0c0707cc365 (bug 1572878)\nBacked out changeset bebd155150c8 (bug 1572878)", "files": ["dom/media/webaudio/AudioNodeEngine.h", "dom/media/webaudio/AudioNodeStream.cpp", "dom/media/webaudio/AudioNodeStream.h", "dom/media/webaudio/ConvolverNode.cpp"], "git_node": null, "git_parents": [null], "node": "2228823d219f25bef2c69de9c58760a85f42a973", "parents": ["e7f3f12d59e3b95b63bef535fa022ac9646afc9f"], "tags": []}], "date": 1568248692, "git_changesets": [null], "user": "nbeleuzu@mozilla.com"}, "11933": {"changesets": [{"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1557153 - Workaround UITour default permissions overridden by UNKNOWN_ACTION r=MattN a=lizzard\n\nSpecially permit www.mozilla.org after ensuring other origin checks but failing ALLOW_ACTION.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45069", "files": ["browser/app/permissions", "browser/components/uitour/UITourChild.jsm"], "git_node": null, "git_parents": [null], "node": "3f4a21f5cb039da3bd696be87a50e1f0e4b76dde", "parents": ["2228823d219f25bef2c69de9c58760a85f42a973"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1579437 - Check for discarded BrowsingContext in more places, r=farre a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45088", "files": ["docshell/base/BrowsingContext.cpp", "docshell/base/BrowsingContext.h", "dom/media/mediacontrol/MediaControlUtils.h"], "git_node": null, "git_parents": [null], "node": "34a6de6322f55812aa923afd4edacdf2cf0c21b9", "parents": ["3f4a21f5cb039da3bd696be87a50e1f0e4b76dde"], "tags": []}, {"author": "Doug Thayer \u003cdothayer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575610 - Ensure we only show spinner after 400ms r=mconley a=lizzard\n\nI haven't been able to work out a reason why we should show the\nspinner before this.loadTimer is cleared. All this does is allow\nfor random reordering of events to sometimes show a spinner early.\nThis should ideally just make the spinner logic more rubust to\nevent ordering changes, without sacrificing visibility into tab\nswitch timings.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44878", "files": ["browser/modules/AsyncTabSwitcher.jsm"], "git_node": null, "git_parents": [null], "node": "18d2a997708a4f890f450835c666cfc6a9dbd194", "parents": ["34a6de6322f55812aa923afd4edacdf2cf0c21b9"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Bug 1578075 - Increase stack size of paint thread/workers on OSX Catalina or higher to workaround crash from recursion in CoreText. r=jrmuizel a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45370", "files": ["gfx/layers/PaintThread.cpp", "widget/cocoa/nsCocoaFeatures.h", "widget/cocoa/nsCocoaFeatures.mm"], "git_node": null, "git_parents": [null], "node": "ffefc518e569164c2c2e62258504bdc69d111bb3", "parents": ["18d2a997708a4f890f450835c666cfc6a9dbd194"], "tags": []}, {"author": "Lina Cambridge \u003clina@yakshaving.ninja\u003e", "branch": "default", "desc": "Bug 1577788 - Fix unique constraint errors when syncing bookmarks with tags. r=markh a=lizzard\n\nOur `INSTEAD OF INSERT` trigger for local tags reused existing tag\nfolders if they already existed, but not existing tag entries. This\ncaused us to insert duplicate tag entries for items whose tags\ndidn't change, which, in turn, threw unique constraint violations\nwhen we tried to insert rows for tag entries that already existed\ninto `itemsAdded`. This commit gives tag entries the same treatment as\ntag folders.\n\nThis commit also improves debug logging during application, so we\ncan pinpoint errors like this better in the future.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44769", "files": ["toolkit/components/places/SyncedBookmarksMirror.jsm", "toolkit/components/places/bookmark_sync/src/store.rs", "toolkit/components/places/tests/sync/head_sync.js", "toolkit/components/places/tests/sync/test_bookmark_value_changes.js"], "git_node": null, "git_parents": [null], "node": "0cb1c338561db822d21c0008276f42b801f797fe", "parents": ["ffefc518e569164c2c2e62258504bdc69d111bb3"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1568171.  Fix handling of load events if document.open() is called while async scripts are still loading for the original pageload.  r=smaug a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D44248", "files": ["dom/script/ScriptLoader.h", "testing/web-platform/tests/html/webappapis/dynamic-markup-insertion/closing-the-input-stream/document-close-with-pending-script.html"], "git_node": null, "git_parents": [null], "node": "bc11f09acf750c8a852d2b21cea2f8f421128531", "parents": ["0cb1c338561db822d21c0008276f42b801f797fe"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1579788 - Downgrade a few assertions in beta / release as to avoid crashing there. r=masayuki a=lizzard\n\nSummary:\nThis is the only short-term fix for now until we fix editor or find a\ntest-case...\n\nThis will keep asserting on Nightly, but the correctness issue it'd show in\nrelease (some pseudo-classes not matching) is better than crashing.\n\nReviewers: heycam, masayuki\n\nReviewed By: masayuki\n\nBug #: 1579788\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45575", "files": ["layout/base/RestyleManager.cpp"], "git_node": null, "git_parents": [null], "node": "e5bdd7763d2da5674bbc180bd9170b86a2ed6cc8", "parents": ["bc11f09acf750c8a852d2b21cea2f8f421128531"], "tags": []}], "date": 1568276895, "git_changesets": [null, null, null, null, null, null, null], "user": "ncsoregi@mozilla.com"}, "11934": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nan -\u003e d38f477c0190\nar -\u003e d3823c6ec096\nast -\u003e c191edb14c3b\naz -\u003e 718af5499981\nbe -\u003e 1d889f83b30f\nbg -\u003e 7ea6c6631cfe\nbn -\u003e 2d837280bf54\nbr -\u003e f82a80cca70e\nbs -\u003e 0482def4e85f\nca -\u003e 7ceecba3676b\ncak -\u003e ee18a42bc36e\ncs -\u003e 1802d2feb8aa\ncy -\u003e 9ed1b7d130a6\nda -\u003e 422fc5fcd34d\nde -\u003e dc513febb67e\ndsb -\u003e b7b65cf83fa5\nel -\u003e 13f5815c6577\nen-CA -\u003e ede4a95f799f\nen-GB -\u003e 1b10ef35df38\neo -\u003e 6075c7f70de8\nes-AR -\u003e c9fb678e5e41\nes-CL -\u003e 1be27907cf23\nes-ES -\u003e 95c0db40631b\nes-MX -\u003e a4b8a5cdde0f\net -\u003e 4fdc87b7fa72\neu -\u003e 3b1fad91785f\nfa -\u003e 9b6dac2f0646\nff -\u003e fb27bbb6cfeb\nfi -\u003e 28df5861dc99\nfr -\u003e 355e99a3bbd8\nfy-NL -\u003e 5ca4dea57171\nga-IE -\u003e bdff02b7f21c\ngd -\u003e 76f29d80f616\ngl -\u003e 08800587b3be\ngn -\u003e 610bab5b7e06\ngu-IN -\u003e c0b6d27e194a\nhe -\u003e ff01a7855eb2\nhi-IN -\u003e 7b96dff21885\nhr -\u003e bf403d80dd33\nhsb -\u003e d24c31710694\nhu -\u003e 424e26da8834\nhy-AM -\u003e 7ed65494bce8\nid -\u003e cc12d7436a1b\nis -\u003e 8b562d71b8e9\nit -\u003e 99080b829944\nja -\u003e e2d9a912ef0e\nka -\u003e 9e87929018df\nkab -\u003e 49d4e12c1c1a\nkk -\u003e c6babb49d4c7\nkn -\u003e a8e0d315c126\nko -\u003e 5dd109ccc1b4\nlij -\u003e 6747075ea3