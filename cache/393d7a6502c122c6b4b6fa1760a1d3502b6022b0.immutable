firefox-branding.js", "browser/branding/official/pref/firefox-branding.js", "browser/branding/unofficial/pref/firefox-branding.js", "mobile/android/app/geckoview-prefs.js", "mobile/android/app/mobile.js", "mobile/android/installer/mobile-l10n.js", "modules/libpref/greprefs.js", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "2bebda12a12a64915ad26887bdf94c503bc6103d", "parents": ["969bbf292e174b641fde2434fa86c84c04e00918"], "tags": []}, {"author": "Chris Manchester \u003ccmanchester@mozilla.com\u003e", "branch": "default", "desc": "Bug 1574314 - Provide a rust-dist-toolchain with Windows and macOS targets installed. r=firefox-build-system-reviewers,mshal\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42236", "files": ["taskcluster/ci/toolchain/dist-toolchains.yml", "taskcluster/ci/toolchain/rust.yml"], "git_node": null, "git_parents": [null], "node": "0206db34710d3f900c1062a3c49b867b24572efd", "parents": ["2bebda12a12a64915ad26887bdf94c503bc6103d"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1575760 - Generate .cargo/config as part of the build rather than as a configure subst file. r=firefox-build-system-reviewers,chmanchester\n\nWe'll require preprocessing that configure subst files don't allow in\nthe next change, so prepare for that.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43011", "files": ["config/recurse.mk", "moz.build", "python/mozbuild/mozbuild/backend/recursivemake.py"], "git_node": null, "git_parents": [null], "node": "9e0c871919f09f693a7f148bc23ac066c6446a2e", "parents": ["0206db34710d3f900c1062a3c49b867b24572efd"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1575760 - Make `mach vendor rust` create a .cargo/config and check it in the tree. r=nalexander\n\nMaybe back when .cargo/config.in was added, the directory indicated for\nvendored crates needed to be absolute. That is at least not the case\nwith the current supported versions of rust.\n\nThe current setup has a few caveats:\n- .cargo/config.in has shown to become stale (it currently contains\n  multiple unused entries)\n- non-gecko build tasks have to generate a .cargo/config on their own if\n  they want to use vendored crates\n- in turn, non-gecko build tasks that don't, may unknowingly get their\n  dependencies from crates.io (see the recent attempt at moving\n  geckodriver builds to a separate task).\n\nBy checking in a .cargo/config file, we can alleviate the last two, but\nthat comes at the price of `cargo update` not wanting to act when\n.cargo/config exists, because of the source replacement configuration.\n\nBut rust vendor gently generates a suitable configuration on its own, so\nwe can use that to generate a .cargo/config automatically. Which\naddresses the first caveat of the current setup. That leaves us with\n`cargo update` not working out of the box, but that just requires people\nrunning it to manually remove .cargo/config first. Which is arguably\nwhat rust wants you to do in the first place. It's kind of incidental\nthat we started with a .cargo/config.in rather than .cargo/config.\n\nNow, while a simple .cargo/config works, that's not enough for the case\nwhere the objdir doesn't live inside the source directory. In that case\ncargo looks for the configuration from the objdir, and fails to find it.\nSo we still need a .cargo/config.in, which we generate with a little\ntrick.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43012", "files": [".cargo/.gitignore", ".cargo/config", ".cargo/config.in", "js/src/make-source-package.sh", "js/src/wasm/cranelift/Cargo.toml", "python/mozbuild/mozbuild/vendor_rust.py", "taskcluster/scripts/builder/build-sm-mozjs-crate.sh", "taskcluster/scripts/builder/build-sm-rust-bindings.sh"], "git_node": null, "git_parents": [null], "node": "80fa83b977a0da53a967e32b152ddf09584ba433", "parents": ["9e0c871919f09f693a7f148bc23ac066c6446a2e"], "tags": []}, {"author": "Michal Novotny \u003cmichal.novotny@gmail.com\u003e", "branch": "default", "desc": "Bug 1567616 - network id based on default gateway is wrong when VPN overrides default gateway by more specific routes r=dragana\n\nThis patch implements NetlinkService which communicates with kernel via netlink socket. It keeps track of addresses, default routes, interfaces and neighbors and uses it to calculate network ID.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43175", "files": ["modules/libpref/init/StaticPrefList.yaml", "modules/libpref/init/all.js", "netwerk/base/nsIOService.cpp", "netwerk/base/nsIOService.h", "netwerk/build/components.conf", "netwerk/system/linux/moz.build", "netwerk/system/linux/nsNetworkLinkService.cpp", "netwerk/system/linux/nsNetworkLinkService.h", "netwerk/system/linux/nsNotifyAddrListener_Linux.cpp", "netwerk/system/linux/nsNotifyAddrListener_Linux.h", "netwerk/system/mac/nsNetworkLinkService.h", "netwerk/system/mac/nsNetworkLinkService.mm", "netwerk/system/moz.build", "netwerk/system/netlink/NetlinkService.cpp", "netwerk/system/netlink/NetlinkService.h", "netwerk/system/netlink/moz.build", "netwerk/system/win32/nsNotifyAddrListener.cpp", "netwerk/system/win32/nsNotifyAddrListener.h"], "git_node": null, "git_parents": [null], "node": "c8660505bc7e65f20c5959fb4e940df17a1c3d9e", "parents": ["80fa83b977a0da53a967e32b152ddf09584ba433"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1575804 - Don't decode the result from get_cmd_output. r=chmanchester\n\nAlso don't pass universal_newlines to check_cmd_output. That was added\nto make python 3 happier when check_cmd_output still returned bytes, to\nhint subprocess to return a unicode string, but now that\ncheck_cmd_output does the decoding, that's not needed anymore.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43205", "files": ["build/moz.configure/init.configure", "build/moz.configure/toolchain.configure"], "git_node": null, "git_parents": [null], "node": "56248ad240922ef2c7bca41eda522a0bf374be28", "parents": ["c8660505bc7e65f20c5959fb4e940df17a1c3d9e"], "tags": []}, {"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1574954 - Fix overlapping issues with login-footer. r=jaws\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43530", "files": ["browser/components/aboutlogins/content/aboutLogins.html", "browser/components/aboutlogins/content/components/login-footer.css", "browser/components/aboutlogins/content/components/login-item.css"], "git_node": null, "git_parents": [null], "node": "827537e16838585eb69dc4820e9026b2372293fb", "parents": ["56248ad240922ef2c7bca41eda522a0bf374be28"], "tags": []}, {"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1576029 - Updates to login-list CSS. r=jaws\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43539", "files": ["browser/components/aboutlogins/content/components/login-item.css", "browser/components/aboutlogins/content/components/login-list.css"], "git_node": null, "git_parents": [null], "node": "fbbf527bd3a80e1fc8e192047254b3792db6e08f", "parents": ["827537e16838585eb69dc4820e9026b2372293fb"], "tags": []}, {"author": "Mihai Alexandru Michis \u003cmalexandru@mozilla.com\u003e", "branch": "default", "desc": "Merge autoland to mozilla-central.  a=merge", "files": ["browser/actors/SubframeCrashChild.jsm", "browser/actors/SubframeCrashParent.jsm", "browser/components/extensions/test/browser/browser-common.ini", "browser/components/extensions/test/browser/browser-remote.ini", "browser/components/extensions/test/xpcshell/head_remote.js", "browser/components/extensions/test/xpcshell/xpcshell-common.ini", "browser/components/extensions/test/xpcshell/xpcshell-remote.ini", "devtools/client/application/src/components/manifest/ManifestItemIcon.js", "devtools/client/application/src/components/manifest/ManifestItemText.js", "devtools/client/application/src/components/manifest/ManifestView.css", "devtools/client/application/src/components/manifest/ManifestView.js", "devtools/client/application/src/components/manifest/ManifestViewEmpty.js", "devtools/client/application/test/components/manifest/__snapshots__/components_application_panel-ManifestView.test.js.snap", "devtools/client/application/test/components/manifest/__snapshots__/components_application_panel-ManifestViewEmpty.test.js.snap", "devtools/client/application/test/components/manifest/components_application_panel-ManifestView.test.js", "devtools/client/application/test/components/manifest/components_application_panel-ManifestViewEmpty.test.js"], "git_node": null, "git_parents": [null, null], "node": "5c7635de0cb65ac1ed72f8fa51fae47a2fd3e9ed", "parents": ["0cf9eded35d8150796eda1f892666d0a778bd488", "edcc94083dcf61f26153b6a3a08a837a2e519b41"], "tags": []}, {"author": "Mihai Alexandru Michis \u003cmalexandru@mozilla.com\u003e", "branch": "default", "desc": "Merge inbound to mozilla-central. a=merge", "files": ["browser/components/BrowserGlue.jsm", "browser/components/aboutlogins/tests/unit/test_getBreachesForLogins.js", "build/build-clang/r355141-arm64-cfg.patch", "docshell/base/BrowsingContext.cpp", "docshell/base/BrowsingContext.h", "docshell/base/nsDocShellLoadState.cpp", "dom/base/Location.cpp", "dom/base/Location.h", "dom/base/LocationBase.cpp", "dom/base/LocationBase.h", "dom/base/moz.build", "dom/tests/mochitest/bugs/test_bug684544.html", "dom/tests/mochitest/dom-level0/mochitest.ini", "dom/tests/mochitest/localstorage/mochitest.ini", "js/xpconnect/tests/mochitest/mochitest.ini"], "git_node": null, "git_parents": [null, null], "node": "2c268d869bc48dc4d5e8ff036cac82375ecf507a", "parents": ["5c7635de0cb65ac1ed72f8fa51fae47a2fd3e9ed", "6493cc875a3acf513c41f39bdeed31e68121a9ed"], "tags": []}, {"author": "Mihai Alexandru Michis \u003cmalexandru@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland.", "files": ["browser/components/aboutlogins/AboutLoginsParent.jsm", "browser/components/aboutlogins/content/components/login-item.css", "browser/components/aboutlogins/content/components/login-list.css", "browser/components/aboutlogins/tests/browser/browser.ini", "browser/components/aboutlogins/tests/unit/test_getBreachesForLogins.js", "build/build-clang/r355141-arm64-cfg.patch"], "git_node": null, "git_parents": [null, null], "node": "614c7ff5c423c779450d2c4f24e3cc18364deaa9", "parents": ["fbbf527bd3a80e1fc8e192047254b3792db6e08f", "2c268d869bc48dc4d5e8ff036cac82375ecf507a"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576553 - Partial ligatures need to be drawn if either GLYPH_FILL or GLYPH_STROKE is in effect. r=heycam\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43409", "files": ["gfx/thebes/gfxTextRun.cpp"], "git_node": null, "git_parents": [null], "node": "d653382c7997b177a085163e0a7ec37256b1b6a2", "parents": ["614c7ff5c423c779450d2c4f24e3cc18364deaa9"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576553 - Add reftest. r=heycam\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43411", "files": ["layout/reftests/bugs/1576553-1-ref.html", "layout/reftests/bugs/1576553-1.html", "layout/reftests/bugs/reftest.list"], "git_node": null, "git_parents": [null], "node": "bc36c4359eefdd8bf946de2a6c95e5f9a044cbee", "parents": ["d653382c7997b177a085163e0a7ec37256b1b6a2"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1576666 - Remove old warning allow which is no longer relevant. r=boris\n\n-moz-appearance uses cbindgen since a long time ago.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43472", "files": ["servo/components/style/properties/gecko.mako.rs"], "git_node": null, "git_parents": [null], "node": "baa507641ae2a35a2a13cd57d1d57dfc27142956", "parents": ["bc36c4359eefdd8bf946de2a6c95e5f9a044cbee"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1576666 - Use cbindgen for clip / -moz-image-region. r=boris\n\nThis also fixes some of the issues with -moz-image-region, where we just minted\nan auto out of the blue.\n\nDepends on D43472\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43474", "files": ["layout/generic/nsFrame.cpp", "layout/style/ServoBindings.toml", "layout/style/ServoStyleConstsInlines.h", "layout/style/nsStyleStruct.cpp", "layout/style/nsStyleStruct.h", "layout/style/test/test_transitions_per_property.html", "layout/svg/nsSVGUtils.cpp", "layout/xul/nsImageBoxFrame.cpp", "layout/xul/tree/nsTreeBodyFrame.cpp", "servo/components/style/properties/gecko.mako.rs", "servo/components/style/properties/longhands/list.mako.rs", "servo/components/style/values/computed/mod.rs", "servo/components/style/values/generics/mod.rs", "servo/components/style/values/specified/mod.rs", "servo/ports/geckolib/cbindgen.toml"], "git_node": null, "git_parents": [null], "node": "2e85fa357d6253a46ad1320780767fdbfc4f35bc", "parents": ["baa507641ae2a35a2a13cd57d1d57dfc27142956"], "tags": []}, {"author": "Chun-Min Chang \u003cchun.m.chang@gmail.com\u003e", "branch": "default", "desc": "Bug 1523920 - P1: Align the LOG policy in the nsSpeechTask. r=eeejay\n\nAll the LOG are placed in Dispatch*Impl except DispatchErrorImpl. Move\nthe LOG from DispatchError to DispatchErrorImpl to align the LOG policy\nin the nsSpeechTask.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35461", "files": ["dom/media/webspeech/synth/nsSpeechTask.cpp"], "git_node": null, "git_parents": [null], "node": "2e49430660ae20e1acecff858966effc4d851e24", "parents": ["2e85fa357d6253a46ad1320780767fdbfc4f35bc"], "tags": []}, {"author": "Chun-Min Chang \u003cchun.m.chang@gmail.com\u003e", "branch": "default", "desc": "Bug 1523920 - P2: Destroy AudioChannelAgent when error occurs. r=eeejay\n\nWhen error occurs, there is no need to use audio.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35462", "files": ["dom/media/webspeech/synth/nsSpeechTask.cpp"], "git_node": null, "git_parents": [null], "node": "18d8187317cdc1d33de3abcf2158be990dad83f4", "parents": ["2e49430660ae20e1acecff858966effc4d851e24"], "tags": []}, {"author": "Chun-Min Chang \u003cchun.m.chang@gmail.com\u003e", "branch": "default", "desc": "Bug 1523920 - P3: Enable the web-platform test to check the utterance is reusable. r=eeejay\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35463", "files": ["testing/web-platform/meta/speech-api/SpeechSynthesis-speak-twice.html.ini"], "git_node": null, "git_parents": [null], "node": "1d4911d7a26ca3a88065dc8d45e7a019825b2324", "parents": ["18d8187317cdc1d33de3abcf2158be990dad83f4"], "tags": []}, {"author": "Chun-Min Chang \u003cchun.m.chang@gmail.com\u003e", "branch": "default", "desc": "Bug 1523920 - P4: Move the state from SpeechSynthesisUtterance to nsSpeechTask. r=eeejay\n\nIt would be easier to reuse the utterance if it's stateless. The state\ncould still be tracked by moving from SpeechSynthesisUtterance to\nnsSpeechTask, which is the place to change the state in original\nimplementation. By removing state in utterance, we don't need to check\nthe state of utterance when it's pushed into the speech queue.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D35464", "files": ["dom/media/webspeech/synth/SpeechSynthesis.cpp", "dom/media/webspeech/synth/SpeechSynthesis.h", "dom/media/webspeech/synth/SpeechSynthesisUtterance.cpp", "dom/media/webspeech/synth/SpeechSynthesisUtterance.h", "dom/media/webspeech/synth/nsSpeechTask.cpp", "dom/media/webspeech/synth/nsSpeechTask.h"], "git_node": null, "git_parents": [null], "node": "c5c1ac80fd436e1c002b2ad25fb0a9529ebcdadd", "parents": ["1d4911d7a26ca3a88065dc8d45e7a019825b2324"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1576703 - Update cbindgen. r=boris\n\nThis cleans up the pattern of \"Use a private dtor so that the helper functions\ndo the right thing\" by enabling it everywhere using:\n\n  https://github.com/eqrion/cbindgen/pull/377\n\nIt also caught some uninitialized value issues.\n\nI think they're mostly harmless since we zero-initialize our structs:\n\nhttps://searchfox.org/mozilla-central/rev/325c1a707819602feff736f129cb36055ba6d94f/servo/components/style/properties/gecko.mako.rs#632\n\nAnd since we override the clip rect, which is the other bit of code that was\nfailing to build with this change.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43491", "files": ["build/moz.configure/bindgen.configure", "layout/style/FontFace.cpp", "layout/style/FontFaceSet.cpp", "layout/style/GeckoBindings.cpp", "layout/style/nsStyleStruct.cpp", "servo/components/style/values/computed/text.rs", "servo/components/style/values/generics/effects.rs", "servo/components/style/values/generics/grid.rs", "servo/components/style/values/generics/svg.rs", "servo/components/style/values/generics/transform.rs", "servo/components/style/values/generics/url.rs", "servo/components/style/values/specified/font.rs", "servo/components/style/values/specified/list.rs", "servo/components/style/values/specified/motion.rs", "servo/components/style/values/specified/position.rs", "servo/components/style/values/specified/text.rs", "servo/ports/geckolib/cbindgen.toml", "taskcluster/ci/fetch/toolchains.yml", "taskcluster/ci/toolchain/cbindgen.yml"], "git_node": null, "git_parents": [null], "node": "6c3f50c6f6662291139bc292fb9dd77aa64331ee", "parents": ["c5c1ac80fd436e1c002b2ad25fb0a9529ebcdadd"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1576666 - Try to fix Mac bustage on a CLOSED TREE.\n\nMANUAL PUSH: tree is red.\n", "files": ["widget/cocoa/nsMenuItemIconX.mm"], "git_node": null, "git_parents": [null], "node": "5389e4f8280dc79df253cd3dcc027dbb27783a3d", "parents": ["6c3f50c6f6662291139bc292fb9dd77aa64331ee"], "tags": []}, {"author": "Andreea Pavel \u003capavel@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 827537e16838 (bug 1574954) for bc failures at browser_dismissFooter.js on a CLOSED TREE", "files": ["browser/components/aboutlogins/content/aboutLogins.html", "browser/components/aboutlogins/content/components/login-footer.css", "browser/components/aboutlogins/content/components/login-item.css"], "git_node": null, "git_parents": [null], "node": "add190b0ebde47b9c942b3f5e0440d58869b9522", "parents": ["5389e4f8280dc79df253cd3dcc027dbb27783a3d"], "tags": []}, {"author": "Toshihito Kikuchi \u003ctkikuchi@mozilla.com\u003e", "branch": "default", "desc": "Bug 1570845 - Call CoAllowSetForegroundWindow before ShellExecute to launch an application in the foreground. r=aklotz\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43536", "files": ["widget/windows/ShellHeaderOnlyUtils.h"], "git_node": null, "git_parents": [null], "node": "e3a4af3c20e270df0102b785476b7125269573f5", "parents": ["add190b0ebde47b9c942b3f5e0440d58869b9522"], "tags": []}, {"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1574954 - Fix overlapping issues with login-footer. r=jaws\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43530", "files": ["browser/components/aboutlogins/content/aboutLogins.html", "browser/components/aboutlogins/content/components/login-footer.css", "browser/components/aboutlogins/content/components/login-item.css"], "git_node": null, "git_parents": [null], "node": "c44bd068d13f733ec6ad0e570d784e5949653155", "parents": ["e3a4af3c20e270df0102b785476b7125269573f5"], "tags": []}, {"author": "Andreea Pavel \u003capavel@mozilla.com\u003e", "branch": "default", "desc": "Bug 1572279 - disabled SharedWorker-exception-propagation.html on android r=intermittent-reviewers,egao\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43552", "files": ["testing/web-platform/meta/workers/SharedWorker-exception-propagation.html.ini"], "git_node": null, "git_parents": [null], "node": "c948133e30b62a8dd071ae6a91f002c372d9d570", "parents": ["c44bd068d13f733ec6ad0e570d784e5949653155"], "tags": []}, {"author": "kriswright \u003ckwright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1573992 - Convert browser.tabs.remote.desktopBehavior to static pref. r=njn\n\nConverts browser.tabs.remote.desktopBehavior to a static pref. Updates usages.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42390", "files": ["layout/forms/nsListControlFrame.cpp", "modules/libpref/init/StaticPrefList.yaml", "widget/PuppetWidget.cpp"], "git_node": null, "git_parents": [null], "node": "18aea5732dafafefd3003cd430b0ff1c18f29528", "parents": ["c948133e30b62a8dd071ae6a91f002c372d9d570"], "tags": []}, {"author": "kriswright \u003ckwright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1573992 - Convert two dom.keyboardevent.* prefs to staticprefs. r=njn\n\nConverts dom.keyboardevent.dispatch_during_composition and dom.keyboardevent.keypress.dispatch_non_printable_keys_only_system_group_in_content to static prefs. Removes the dispatch_during_composition entry from mobile.js, since it just redefines the same pref value.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42391", "files": ["mobile/android/app/mobile.js", "modules/libpref/init/StaticPrefList.yaml", "modules/libpref/init/all.js", "widget/TextEventDispatcher.cpp", "widget/TextEventDispatcher.h"], "git_node": null, "git_parents": [null], "node": "0c96b213ba8df283675d1170614fcb71cab0db2f", "parents": ["18aea5732dafafefd3003cd430b0ff1c18f29528"], "tags": []}, {"author": "kriswright \u003ckwright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1573992 - Convert 3 ui.key.* prefs to static prefs. r=njn\n\nConverts ui.key.generalAccessKey, ui.key.chromeAccess, and ui.key.contentAccess to static prefs. Updates usages.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42392", "files": ["accessible/generic/Accessible.cpp", "modules/libpref/init/StaticPrefList.yaml", "modules/libpref/init/all.js", "widget/TextEvents.h", "widget/WidgetEventImpl.cpp"], "git_node": null, "git_parents": [null], "node": "5b8559f79b9416edbe478440c7d996e829942dd3", "parents": ["0c96b213ba8df283675d1170614fcb71cab0db2f"], "tags": []}, {"author": "kriswright \u003ckwright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1573992 - Convert intl.ime.hack.on_any_apps.fire_key_events_for_composition  to static pref. r=njn\n\nConverts intl.ime.hack.on_any_apps.fire_key_events_for_composition to a static pref and updates its usages.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42393", "files": ["modules/libpref/init/StaticPrefList.yaml", "modules/libpref/init/all.js", "widget/android/GeckoEditableSupport.cpp", "widget/android/GeckoEditableSupport.h"], "git_node": null, "git_parents": [null], "node": "72a0e619b7c500d3bdd107dbeb2d4aa0485f2741", "parents": ["5b8559f79b9416edbe478440c7d996e829942dd3"], "tags": []}, {"author": "kriswright \u003ckwright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1573992 - Convert ui.scrolling.negate_wheel_scroll to static pref. r=njn\n\nConverts ui.scrolling.negate_wheel_scroll to a static pref and updates its usages. This one is only enabled on android, so I used the IS_ANDROID value to fill it.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42394", "files": ["mobile/android/app/mobile.js", "modules/libpref/init/StaticPrefList.yaml", "widget/android/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "17f6be679d8d067d0cfe8f26d9daabf317f1d2b3", "parents": ["72a0e619b7c500d3bdd107dbeb2d4aa0485f2741"], "tags": []}, {"author": "kriswright \u003ckwright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1573992 - Convert android.widget_paints_background to static pref. r=njn\n\nConverts android.widget_paints_background to a static pref. From my understanding, this pref only matters on android, and the overridden function in nsIWidget defaults to `false`. Based on that I replaced the entire WidgetPaintsBackground() function with a static pref.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42395", "files": ["modules/libpref/init/StaticPrefList.yaml", "modules/libpref/moz.build", "widget/android/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "d3dc8d935523a94d5870862aab5a83a7789d8400", "parents": ["17f6be679d8d067d0cfe8f26d9daabf317f1d2b3"], "tags": []}, {"author": "kriswright \u003ckwright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1573992 - Convert layout.css.devPixelsPerPx to static pref. r=njn\n\nConverts layout.css.devPixelsPerPx to a static pref. This one was one of the slightly odd ones; some values were expecting an atomic float, so instead of defining a regular type float it is defined in StaticPrefList.yaml as an AtomicFloat. I am assuming this was the intent of the pref value all along.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42396", "files": ["modules/libpref/init/StaticPrefList.yaml", "modules/libpref/init/all.js", "widget/Screen.cpp", "widget/gtk/nsLookAndFeel.cpp", "widget/gtk/nsNativeThemeGTK.cpp", "widget/nsBaseWidget.cpp", "widget/windows/TaskbarPreview.cpp", "widget/windows/nsNativeThemeWin.cpp", "widget/windows/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "0b5a8bc0d337dd503ae88fb58f6a5099f62e77ef", "parents": ["d3dc8d935523a94d5870862aab5a83a7789d8400"], "tags": []}, {"author": "Kristen Wright \u003ckwright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1573992 - Convert ui.context_menus.after_mouseup to static pref. r=njn\n\nConverts ui.context_menus.after_mouseup varcache pref to a static pref and removes its associated function.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43519", "files": ["modules/libpref/init/StaticPrefList.yaml", "modules/libpref/init/all.js", "widget/cocoa/nsChildView.mm", "widget/gtk/nsWindow.cpp", "widget/nsBaseWidget.cpp", "widget/nsBaseWidget.h"], "git_node": null, "git_parents": [null], "node": "330bdf13823dd7ff595b58c99173f297293251cc", "parents": ["0b5a8bc0d337dd503ae88fb58f6a5099f62e77ef"], "tags": []}, {"author": "Kristen Wright \u003ckwright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1573992 - Convert ui.use_native_colors to static pref. r=njn\n\nConverts ui.use_native_colors to a static pref and updates its usages.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43521", "files": ["modules/libpref/init/StaticPrefList.yaml", "modules/libpref/init/all.js", "widget/nsXPLookAndFeel.cpp", "widget/nsXPLookAndFeel.h"], "git_node": null, "git_parents": [null], "node": "c9489f3868a0ebf7ba3063e7b6c6346e28f05350", "parents": ["330bdf13823dd7ff595b58c99173f297293251cc"], "tags": []}, {"author": "Kristen Wright \u003ckwright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1573992 - Convert findbar.modalHighlight to static pref. r=njn\n\nConverts findbar.modalHighlight to a static pref and updates its usages.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43522", "files": ["modules/libpref/init/StaticPrefList.yaml", "modules/libpref/init/all.js", "modules/libpref/moz.build", "widget/nsXPLookAndFeel.cpp", "widget/nsXPLookAndFeel.h"], "git_node": null, "git_parents": [null], "node": "afcd59408f56e261fbf6cd81a619b76fb5d01f25", "parents": ["c9489f3868a0ebf7ba3063e7b6c6346e28f05350"], "tags": []}, {"author": "Kristen Wright \u003ckwright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1573992 - Convert dom.w3c_pointer_events.dispatch_by_pointer_messages to static pref. r=njn\n\nConverts dom.w3c_pointer_events.dispatch_by_pointer_messages to a static pref and removes its mirror variable.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43524", "files": ["modules/libpref/init/StaticPrefList.yaml", "modules/libpref/init/all.js", "widget/windows/WinPointerEvents.cpp", "widget/windows/WinPointerEvents.h"], "git_node": null, "git_parents": [null], "node": "5f00f7fcd77854dab538bb0606b573b3369957d8", "parents": ["afcd59408f56e261fbf6cd81a619b76fb5d01f25"], "tags": []}, {"author": "Andreea Pavel \u003capavel@mozilla.com\u003e", "branch": "default", "desc": "Backed out 2 changesets (bug 1576553) for failing reftest at 1576553-1.html on a CLOSED TREE\n\nBacked out changeset bc36c4359eef (bug 1576553)\nBacked out changeset d653382c7997 (bug 1576553)", "files": ["gfx/thebes/gfxTextRun.cpp", "layout/reftests/bugs/1576553-1-ref.html", "layout/reftests/bugs/1576553-1.html", "layout/reftests/bugs/reftest.list"], "git_node": null, "git_parents": [null], "node": "6097272103defa58d5710fd7f8170db3d756462f", "parents": ["5f00f7fcd77854dab538bb0606b573b3369957d8"], "tags": []}, {"author": "Mihai Alexandru Michis \u003cmalexandru@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset bd63dad85d34 (bug 1574023) for causing failures in browser_breachAlertDismissals.js", "files": ["browser/components/aboutlogins/tests/browser/browser.ini"], "git_node": null, "git_parents": [null], "node": "8abf2e05abaf82065731f9976f1a68fa57d4c9f0", "parents": ["6097272103defa58d5710fd7f8170db3d756462f"], "tags": []}, {"author": "Matthew Noorenberghe \u003cmozilla@noorenberghe.ca\u003e", "branch": "default", "desc": "Bug 1574023 - Skip browser_breachAlertDismissals.js in debug, ASAN, or verify.", "files": ["browser/components/aboutlogins/tests/browser/browser.ini"], "git_node": null, "git_parents": [null], "node": "7fa89d5cdb35de67da5cc94d15fbf0c184b32d8b", "parents": ["8abf2e05abaf82065731f9976f1a68fa57d4c9f0"], "tags": []}, {"author": "Mihai Alexandru Michis \u003cmalexandru@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset b2e87e49589e (bug 1569847) for causing failures in browser_breachAlertDismissals.js", "files": ["browser/components/BrowserGlue.jsm", "browser/components/about/AboutProtectionsHandler.jsm", "browser/components/aboutlogins/AboutLoginsParent.jsm", "browser/components/aboutlogins/LoginBreaches.jsm", "browser/components/aboutlogins/content/components/login-item.css", "browser/components/aboutlogins/content/components/login-list.css", "browser/components/aboutlogins/moz.build", "browser/components/aboutlogins/tests/browser/browser_breachAlertDismissals.js", "browser/components/aboutlogins/tests/unit/test_getBreachesForLogins.js", "browser/components/aboutlogins/tests/unit/test_getPotentialBreachesByLoginGUID.js", "browser/components/aboutlogins/tests/unit/xpcshell.ini", "toolkit/components/passwordmgr/LoginHelper.jsm", "toolkit/components/passwordmgr/LoginStore.jsm", "toolkit/components/passwordmgr/storage-json.js", "toolkit/components/passwordmgr/test/unit/test_vulnerable_passwords.js", "toolkit/components/passwordmgr/test/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "7e382148d47f8f09f5395c014bb621e8f55cc0a1", "parents": ["7fa89d5cdb35de67da5cc94d15fbf0c184b32d8b"], "tags": []}, {"author": "Adam Gashlin \u003cagashlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1572844 - Consistently check for MOZ_BITS_DOWNLOAD. r=bytesized\n\nBITS download can be disabled on Windows. This patch checks for the\nconfig/define MOZ_BITS_DOWNLOAD when including the C++ parts of the\nservice, exposing the service in JS, setting the pref, and including\nBITS-specific tests. For consistency and simplicity it also removes\nthe Windows checks; the configure system won't allow\nMOZ_BITS_DOWNLOAD if not on Windows.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43493", "files": ["browser/app/profile/firefox.js", "toolkit/components/bitsdownload/Bits.jsm", "toolkit/components/bitsdownload/components.conf", "toolkit/components/bitsdownload/moz.build", "toolkit/mozapps/update/tests/moz.build"], "git_node": null, "git_parents": [null], "node": "7ce6426b7653e89258f3bfd74903e9b97390399c", "parents": ["7e382148d47f8f09f5395c014bb621e8f55cc0a1"], "tags": []}, {"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 1576696 - Add a '0x' prefix to hex pointer values in logging nodes. r=Jamie\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43485", "files": ["accessible/base/Logging.cpp"], "git_node": null, "git_parents": [null], "node": "7395aa7395272714890d0510247743ca19fcbcc6", "parents": ["7ce6426b7653e89258f3bfd74903e9b97390399c"], "tags": []}, {"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 1576709 - Add crash test for bug 1572811. r=Jamie\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43499", "files": ["accessible/tests/crashtests/1572811.html", "accessible/tests/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "e48fd9a20d62c98ceb843010a7c08df4dd9d9650", "parents": ["7395aa7395272714890d0510247743ca19fcbcc6"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1573679: Add IsCurrentThread(Explicit|Implicit)MTA utility functions to mscom; r=Jamie\n\nThis patch provides us with utility functions that give us more specific\ninformation about the current thread's MTA if so desired.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41852", "files": ["ipc/mscom/Utils.cpp", "ipc/mscom/Utils.h"], "git_node": null, "git_parents": [null], "node": "623da84b651a53382a63b0465fa57f2125a5b5f8", "parents": ["e48fd9a20d62c98ceb843010a7c08df4dd9d9650"], "tags": []}, {"author": "Nick Thomas \u003cnthomas@mozilla.com\u003e", "branch": "default", "desc": "Bug 1572102 - deprioritize partner-repack tasks as they don't block QE, r=aki\n\nLower the priority of partner-repack jobs and downstreams to medium, so that tasks which do block QE work are not impeded.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43399", "files": ["taskcluster/ci/release-partner-repack-beetmover/kind.yml", "taskcluster/ci/release-partner-repack-repackage-signing/kind.yml", "taskcluster/taskgraph/transforms/beetmover_repackage_partner.py", "taskcluster/taskgraph/transforms/chunk_partners.py", "taskcluster/taskgraph/transforms/job/__init__.py", "taskcluster/taskgraph/transforms/partner_repack.py", "taskcluster/taskgraph/transforms/repackage_partner.py", "taskcluster/taskgraph/transforms/repackage_signing_partner.py", "taskcluster/taskgraph/transforms/signing.py", "taskcluster/taskgraph/transforms/task.py", "taskcluster/taskgraph/util/partners.py"], "git_node": null, "git_parents": [null], "node": "e8d7ad940a57aa47d0284cf2672376fddc8283db", "parents": ["623da84b651a53382a63b0465fa57f2125a5b5f8"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1575436 - Don't use absolute path for echo command. r=glandium\n\ncommon.gypi uses hard-coded absolute path for echo command, but this path\nis invalid on Windows.\n\nBut this lines are unused, so we should remove it.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42779", "files": ["build/gyp_includes/common.gypi"], "git_node": null, "git_parents": [null], "node": "6d0f23528aeabcafc9707d8d702c4d0a1a74738e", "parents": ["e8d7ad940a57aa47d0284cf2672376fddc8283db"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1576082 - Don't build jsapi-tests, gdb-tests and js tests when disabling js shell. r=sfink\n\nFor starters, js tests require the js shell, so recursing js/src/tests\nmake no sense.\n\nAs for the other, it feels like it's reasonably that if one didn't\nopt-in to build the js shell for Gecko builds, they are not interested\nin jsapi-tests and gdb-tests either.\n\nThe default for Spidermonkey standalone build being to build the shell,\nnothing changes for them.\n\nBuilding jsapi-tests and gdb-tests forces to build jsrust, which can be\na drag when building Firefox.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43537", "files": ["js/src/moz.build"], "git_node": null, "git_parents": [null], "node": "c1835ddb51e2c60b6286a12baf3e6c35e13217ed", "parents": ["6d0f23528aeabcafc9707d8d702c4d0a1a74738e"], "tags": []}, {"author": "Nihanth Subramanya \u003cnhnt11@gmail.com\u003e", "branch": "default", "desc": "Bug 1576685 - Update disabled TP toggle switch background color. r=timhuang\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43486", "files": ["browser/themes/shared/controlcenter/panel.inc.css"], "git_node": null, "git_parents": [null], "node": "de8a6bdc5d73dee65bc035410421a034c0688088", "parents": ["c1835ddb51e2c60b6286a12baf3e6c35e13217ed"], "tags": []}, {"author": "Nihanth Subramanya \u003cnhnt11@gmail.com\u003e", "branch": "default", "desc": "Bug 1575246 - Clear telemetry events before and after protections panel tests. r=johannh\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43392", "files": ["browser/base/content/test/siteProtections/browser_protections_UI.js"], "git_node": null, "git_parents": [null], "node": "d3025ffd55d1038d74ca9979a039d5669f6931ad", "parents": ["de8a6bdc5d73dee65bc035410421a034c0688088"], "tags": []}, {"author": "Nihanth Subramanya \u003cnhnt11@gmail.com\u003e", "branch": "default", "desc": "Bug 1574196 - Properly wrap long subview header text in identity and protections panels. r=johannh\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43335", "files": ["browser/components/customizableui/PanelMultiView.jsm", "browser/themes/shared/controlcenter/panel.inc.css"], "git_node": null, "git_parents": [null], "node": "29fa2438a42a6249aa9047ad51afec42015dc25b", "parents": ["d3025ffd55d1038d74ca9979a039d5669f6931ad"], "tags": []}, {"author": "lloan \u003clloanalas@outlook.com\u003e", "branch": "default", "desc": "Bug 1575930 - Add tool-tip in search results panel. r=Honza\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43149", "files": ["devtools/client/netmonitor/src/actions/search.js", "devtools/client/netmonitor/src/components/search/SearchPanel.js", "devtools/client/netmonitor/src/components/search/search-provider.js", "devtools/client/netmonitor/src/reducers/search.js", "devtools/client/shared/components/tree/LabelCell.js"], "git_node": null, "git_parents": [null], "node": "26fb0641910eb78d1edff264e11bd5930e778b01", "parents": ["29fa2438a42a6249aa9047ad51afec42015dc25b"], "tags": []}, {"author": "alwu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1572939 - part1 : allow user inputs on editable content to activate document. r=masayuki\n\nAs Chrome and Safari didn't block autoplay when haiving user input on editable content, it causes a compatible issue on Firefox because we only allow user inputs happening on non-editable content to activate document.\n\nIt seems that we don't really need to restrict that user inputs, which can activate document, should only occur on non-editable content.\nEven if they occur on non-editable content, it might still have a chance to annoy user, it's totally depending on websites' design.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43532", "files": ["dom/events/EventStateManager.cpp"], "git_node": null, "git_parents": [null], "node": "2ba2516d4a2c9d353a724b8c433701bf1b9df329", "parents": ["26fb0641910eb78d1edff264e11bd5930e778b01"], "tags": []}, {"author": "alwu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1572939 - part2 : remove editable content tests. r=masayuki\n\nAs we will allow user inputs on editable content to activate document, we should remove them from black list test.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43533", "files": ["dom/media/test/file_autoplay_policy_key_blacklist.html"], "git_node": null, "git_parents": [null], "node": "160da901fc3e63632497c1d42b3ebd7e84892224", "parents": ["2ba2516d4a2c9d353a724b8c433701bf1b9df329"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 324361 - Remove openApplication/openApplicationWithURI from the shell service as they aren't used. r=mossop\n\nKeeps a function for opening the Mac desktop preferences.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43269", "files": ["browser/components/shell/content/setDesktopBackground.js", "browser/components/shell/nsGNOMEShellService.cpp", "browser/components/shell/nsIMacShellService.idl", "browser/components/shell/nsIShellService.idl", "browser/components/shell/nsMacShellService.cpp", "browser/components/shell/nsWindowsShellService.cpp", "browser/components/uitour/test/browser_UITour_defaultBrowser.js"], "git_node": null, "git_parents": [null], "node": "f4da3ae7efa6a510348c1528afa6d77be99f021d", "parents": ["160da901fc3e63632497c1d42b3ebd7e84892224"], "tags": []}, {"author": "Paul Adenot \u003cpaul@paul.cx\u003e", "branch": "default", "desc": "Bug 1576168 - Update audio_thread_priority to 0.19.1. r=pehrsons\n\nThis changes the hard-limit of `RLIMIT_RTTIME` to be the maximum available\n(200ms on my system), and keep the soft limit to the same number.\n\nHaving different numbers allow catching SIGXCPU before getting SIGKILL.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43402", "files": ["media/audioipc/client/Cargo.toml", "media/audioipc/server/Cargo.toml", "toolkit/library/rust/shared/Cargo.toml"], "git_node": null, "git_parents": [null], "node": "6e85d1ee673aed2891cff7f532d6ce34f18b61ab", "parents": ["f4da3ae7efa6a510348c1528afa6d77be99f021d"], "tags": []}, {"author": "Paul Adenot \u003cpaul@paul.cx\u003e", "branch": "default", "desc": "Bug 1576168 - mach vendor rust. r=pehrsons\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43403", "files": ["Cargo.lock", "third_party/rust/audio_thread_priority/.cargo-checksum.json", "third_party/rust/audio_thread_priority/Cargo.toml", "third_party/rust/audio_thread_priority/src/lib.rs", "third_party/rust/audio_thread_priority/src/rt_linux.rs", "third_party/rust/audio_thread_priority/src/rt_mach.rs"], "git_node": null, "git_parents": [null], "node": "1f4a5ebd5c7ba0a0170e344096bf663072bf1acb", "parents": ["6e85d1ee673aed2891cff7f532d6ce34f18b61ab"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1573536 - Add crashtest. r=padenot\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42530", "files": ["dom/media/tests/crashtests/1573536.html", "dom/media/tests/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "b33102d31be2b86e8a546ca036354a1a32e4ecca", "parents": ["1f4a5ebd5c7ba0a0170e344096bf663072bf1acb"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1573536 - Allow gUM with audio:{mediaSource:audioCapture} and video:true simultaneously. r=padenot\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42531", "files": ["dom/media/MediaManager.cpp"], "git_node": null, "git_parents": [null], "node": "4b772d42c3ca2bc2c7ddb28293b44c16853cbb31", "parents": ["b33102d31be2b86e8a546ca036354a1a32e4ecca"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576553 - Partial ligatures need to be drawn if either GLYPH_FILL or GLYPH_STROKE is in effect. r=heycam\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43409", "files": ["gfx/thebes/gfxTextRun.cpp"], "git_node": null, "git_parents": [null], "node": "ae2021d2c744044813922bc5e42f6d05c5cab31a", "parents": ["4b772d42c3ca2bc2c7ddb28293b44c16853cbb31"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576553 - Add reftest. r=heycam\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43411", "files": ["layout/reftests/bugs/1576553-1-ref.html", "layout/reftests/bugs/1576553-1.html", "layout/reftests/bugs/reftest.list"], "git_node": null, "git_parents": [null], "node": "713c95e01d1e5a256225c935534a98d92b2f18b2", "parents": ["ae2021d2c744044813922bc5e42f6d05c5cab31a"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576653 - Add nightly-only option to toggle devtools.browsertoolbox.fission in Browser Toolbox r=yulia\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43473", "files": ["devtools/client/framework/toolbox-options.js"], "git_node": null, "git_parents": [null], "node": "e1b2ac748cea44945acb4c53cbcd174dc6c61dd7", "parents": ["713c95e01d1e5a256225c935534a98d92b2f18b2"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576653 - Use a custom toolbox window title for the omniscient browser toolbox r=nchevobbe,yulia\n\nDepends on D43473\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43478", "files": ["devtools/client/framework/toolbox.js"], "git_node": null, "git_parents": [null], "node": "c0535352f1201b8274a30fd7943d44e8a84ca9ed", "parents": ["e1b2ac748cea44945acb4c53cbcd174dc6c61dd7"], "tags": []}, {"author": "yulia \u003cystartsev@mozilla.com\u003e", "branch": "default", "desc": "Bug 1574156 - implement FrameDescriptor; r=ochameau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42305", "files": ["devtools/server/actors/descriptors/frame.js", "devtools/server/actors/descriptors/moz.build", "devtools/shared/fronts/descriptors/frame.js", "devtools/shared/fronts/descriptors/moz.build", "devtools/shared/specs/descriptors/frame.js", "devtools/shared/specs/descriptors/moz.build", "devtools/shared/specs/index.js"], "git_node": null, "git_parents": [null], "node": "5c69342869b413c4249304f8fd016603652fc809", "parents": ["c0535352f1201b8274a30fd7943d44e8a84ca9ed"], "tags": []}, {"author": "yulia \u003cystartsev@mozilla.com\u003e", "branch": "default", "desc": "Bug 1574159 - implement listRemoteFrames for browsingContextTarget and listRemoteTab for content process; r=ochameau\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42327", "files": ["devtools/server/actors/descriptors/frame.js", "devtools/server/actors/targets/browsing-context.js", "devtools/server/actors/targets/parent-process.js", "devtools/server/tests/browser/browser.ini", "devtools/server/tests/browser/browser_resource_list-remote-frames.js", "devtools/server/tests/browser/doc_iframe.html", "devtools/shared/fronts/descriptors/frame.js", "devtools/shared/specs/targets/browsing-context.js"], "git_node": null, "git_parents": [null], "node": "9a85c28fd033545e63ac5851f71c4d34a9436d28", "parents": ["5c69342869b413c4249304f8fd016603652fc809"], "tags": []}, {"author": "Tim Huang \u003ctihuang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576832 - Fix the info and check of the ETP state to use the right browser object for the test 'browser_protections_UI.js' r=nhnt11\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43586", "files": ["browser/base/content/test/siteProtections/browser_protections_UI.js"], "git_node": null, "git_parents": [null], "node": "2187d722dc389e70f1f0f93ac0195f31e3fab8c8", "parents": ["9a85c28fd033545e63ac5851f71c4d34a9436d28"], "tags": []}, {"author": "Aki Sasaki \u003casasaki@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576729 - disable ship-geckoview on release to stop failure email spam r=aryx p=aki\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43582", "files": [".cron.yml"], "git_node": null, "git_parents": [null], "node": "19f1235e5f70ace9207e64add8cdf65320e92e95", "parents": ["2187d722dc389e70f1f0f93ac0195f31e3fab8c8"], "tags": []}, {"author": "harry \u003chtwyford@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575360 - Add shadow effect to megabar when it's open. r=dao\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42714", "files": ["browser/themes/osx/browser.css", "browser/themes/shared/urlbar-searchbar.inc.css"], "git_node": null, "git_parents": [null], "node": "5b409f6201d591176a53873c7ec45239e0d2521d", "parents": ["19f1235e5f70ace9207e64add8cdf65320e92e95"], "tags": []}, {"author": "James Graham \u003cjames@hoppipolla.co.uk\u003e", "branch": "default", "desc": "Bug 1576833 - Handle tests with / in the path in metadata update, r=dheiberg\n\nFor tests with ids like foo/bar?baz/foobar we were incorrectly setting the manifest test_id\nto foobar rather than bar?baz/foobar. Fix this by determining the length of the path up to\nthe last / and trimming that off the front of the test id. This approach avoids\nreserializing the url.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43579", "files": ["testing/web-platform/tests/tools/wptrunner/wptrunner/manifestupdate.py"], "git_node": null, "git_parents": [null], "node": "493b216296d589e558ecf80eccded445be778bbe", "parents": ["5b409f6201d591176a53873c7ec45239e0d2521d"], "tags": []}, {"author": "Florens Verschelde \u003cflorens@fvsch.com\u003e", "branch": "default", "desc": "Bug 1575827 - Remove references to outdated DevToolsColors MDN page; r=pbro\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43227", "files": ["devtools/client/performance/modules/markers.js", "devtools/client/shared/theme.js", "devtools/docs/contributing/css.md"], "git_node": null, "git_parents": [null], "node": "358f649ea2691efba912d681b880c97d373fa5d5", "parents": ["493b216296d589e558ecf80eccded445be778bbe"], "tags": []}, {"author": "Stephen Horlander \u003cshorlander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575440 - Add context-fill and dark mode support for horizontal-lockup.svg r=dao\n\nAdd dark mode support for horizontal-lockup.svg for Developer and Nightly about:newinstall page\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42898", "files": ["browser/branding/aurora/content/horizontal-lockup.svg", "browser/branding/nightly/content/horizontal-lockup.svg"], "git_node": null, "git_parents": [null], "node": "02ce0be2e4fe6cd0cec4ed7279579dad4d2b5fd5", "parents": ["358f649ea2691efba912d681b880c97d373fa5d5"], "tags": []}, {"author": "Vlad Baicu \u003cvlad.baicu@softvision.ro\u003e", "branch": "default", "desc": "Bug 1576170 - Relocate the localization note above the strings for consistency. r=flod\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43468", "files": ["mobile/android/base/locales/en-US/android_strings.dtd"], "git_node": null, "git_parents": [null], "node": "9b36ad9d6c8ad3153f70e7601897a4e2258eb7d1", "parents": ["02ce0be2e4fe6cd0cec4ed7279579dad4d2b5fd5"], "tags": []}, {"author": "Andrew Halberstadt \u003cahalberstadt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1473498 - [mozbuild.mozconfig] Improve error message in MozconfigLoadException r=glandium\n\nWithout the output, this exception wasn't being very helpful.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42015", "files": ["python/mozbuild/mozbuild/base.py", "python/mozbuild/mozbuild/mozconfig.py", "python/mozbuild/mozbuild/test/test_mozconfig.py"], "git_node": null, "git_parents": [null], "node": "b51268c0040b67b03a3f02a45c437476fc1a810e", "parents": ["9b36ad9d6c8ad3153f70e7601897a4e2258eb7d1"], "tags": []}, {"author": "Andrew Halberstadt \u003cahalberstadt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1473498 - [mozbuild.base] Fix Python 3 incompatibilities in mozconfig error handling, r=glandium\n\nUse of 'BaseException.message` was deprecated in Python 2.6 (and removed in\nPython 3). We should rely on the exception's '__str__' instead.\n\nWe also need to ensure the mozconfig subprocess' output is text when formatting\nit into the message with Py3.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42843", "files": ["python/mozbuild/mozbuild/base.py"], "git_node": null, "git_parents": [null], "node": "983a86c020c9ac14397855a5415a751bb23d897c", "parents": ["b51268c0040b67b03a3f02a45c437476fc1a810e"], "tags": []}, {"author": "Andrew Halberstadt \u003cahalberstadt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1473498 - [configure] Fix ImportError in util.configure under Python 3, r=glandium\n\nThis import is actually unused as of bug 844509.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42869", "files": ["build/moz.configure/util.configure"], "git_node": null, "git_parents": [null], "node": "baf6c4adbf2b9917f118e562e733f962609ae8a0", "parents": ["983a86c020c9ac14397855a5415a751bb23d897c"], "tags": []}, {"author": "Andrew Halberstadt \u003cahalberstadt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1473498 - [mozbuild.util] Don't use 'patch_main' hack with Python 3.4+ r=firefox-build-system-reviewers,mshal\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42016", "files": ["python/mozbuild/mozbuild/util.py"], "git_node": null, "git_parents": [null], "node": "fa5e23975029455bd7fa2ec48960e3cad80ee2c1", "parents": ["baf6c4adbf2b9917f118e562e733f962609ae8a0"], "tags": []}, {"author": "Andrew Halberstadt \u003cahalberstadt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1473498 - [mach] Support running mach commands with python 3 r=glandium,mars\n\nCredit: mars for making the shell POSIX compliant\n\nThis embeds a blacklist of every mach command that needs to run with Python 2\ndirectly in the mach driver itself. Initially this is every mach command. We\nthen use a bit of shell to determine whether the command being run needs Python\n2 or 3.\n\nWhile this approach may seem a bit hacky, it has several benefits:\n\n1. No need to add complex machinery in mach's registration code.\n2. No need to spawn two separate Python interpreters in the event a different\n   Python from the original interpreter is needed.\n3. Perf impact is negligible.\n4. New commands are Python 3 by default.\n\nIt is also only a temporary hack. Once all commands are running with Python 3,\nwe can revert back to the original mach driver.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36103", "files": ["build/mach_bootstrap.py", "mach", "python/mach/mach/main.py", "python/mach/mach/registrar.py"], "git_node": null, "git_parents": [null], "node": "d5ef7a5e02a4d12e6349beb11a2cee666ea75b44", "parents": ["fa5e23975029455bd7fa2ec48960e3cad80ee2c1"], "tags": []}, {"author": "Andrew Halberstadt \u003cahalberstadt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1555762 - [mach] Get SearchProvider commands to run with Python 3 r=Callek\n\nThis includes the following commands:\n* dxr\n* google\n* mdn\n* search\n* searchfox\n\nDifferential Revision: https://phabricator.services.mozilla.com/D36843", "files": ["mach"], "git_node": null, "git_parents": [null], "node": "fa24b6a4ef6c4293581c8e6006df64f5886fba94", "parents": ["d5ef7a5e02a4d12e6349beb11a2cee666ea75b44"], "tags": []}, {"author": "Mirko Brodesser \u003cmbrodesser@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575839: part 1) Add `nsPlainTextSerializer::Settings::HasFlag`. r=hsivonen\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43415", "files": ["dom/base/nsPlainTextSerializer.cpp", "dom/base/nsPlainTextSerializer.h"], "git_node": null, "git_parents": [null], "node": "64b069575224c1905b59162effca4d61b684da9d", "parents": ["fa24b6a4ef6c4293581c8e6006df64f5886fba94"], "tags": []}, {"author": "Mirko Brodesser \u003cmbrodesser@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575839: part 2) Declare some methods `const` or `static`. r=hsivonen\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43416", "files": ["dom/base/nsPlainTextSerializer.cpp", "dom/base/nsPlainTextSerializer.h"], "git_node": null, "git_parents": [null], "node": "5a833f31ffb1e61c0a4047ea36a47c7a9dc8fca4", "parents": ["64b069575224c1905b59162effca4d61b684da9d"], "tags": []}, {"author": "Mirko Brodesser \u003cmbrodesser@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575839: part 3) Simplify assignment to `nsPlainTextSerializer::Write::atFirstColumn`. r=hsivonen\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43417", "files": ["dom/base/nsPlainTextSerializer.cpp"], "git_node": null, "git_parents": [null], "node": "ce15b71195316eb82954c24f62a319e54c0e4405", "parents": ["5a833f31ffb1e61c0a4047ea36a47c7a9dc8fca4"], "tags": []}, {"author": "Mirko Brodesser \u003cmbrodesser@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575839: part 4) Remove `nsPlainTextSerializer::Write::atFirstColumn`. r=hsivonen\n\nIts value was at all places where it's read equal to\n`outputLineBreak` which is now used instead.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43418", "files": ["dom/base/nsPlainTextSerializer.cpp"], "git_node": null, "git_parents": [null], "node": "13bf1f60ad2c582f9cec16faeb39743695059af5", "parents": ["ce15b71195316eb82954c24f62a319e54c0e4405"], "tags": []}, {"author": "Mirko Brodesser \u003cmbrodesser@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575839: part 5) Factor out `ReplaceVisiblyTrailingNbsps` from `nsPlainTextSerializer::Write`. r=hsivonen\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43419", "files": ["dom/base/nsPlainTextSerializer.cpp"], "git_node": null, "git_parents": [null], "node": "3511610e8ff95e124bb7d1e00b9884430abd3633", "parents": ["13bf1f60ad2c582f9cec16faeb39743695059af5"], "tags": []}, {"author": "Alphan Chen \u003calchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1482885 - Refactor nsHtml5TreeOperation's enum plus fields into mozilla::Variant r=hsivonen\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42809", "files": ["parser/html/nsHtml5Highlighter.cpp", "parser/html/nsHtml5TreeBuilderCppSupplement.h", "parser/html/nsHtml5TreeOperation.cpp", "parser/html/nsHtml5TreeOperation.h"], "git_node": null, "git_parents": [null], "node": "8efc09e271021ae20947900e5733c8e632ee830b", "parents": ["3511610e8ff95e124bb7d1e00b9884430abd3633"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1576268 - [Wayland] Use MOVE as a default Drag and Drop action to match X11 behavior, r=jhorak\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43578", "files": ["widget/gtk/nsClipboardWayland.cpp"], "git_node": null, "git_parents": [null], "node": "fe6f7a136d065df59f4037f22f662efe249f87ce", "parents": ["8efc09e271021ae20947900e5733c8e632ee830b"], "tags": []}, {"author": "Ted Campbell \u003ctcampbell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575077 - Cleanup handling of ScriptSource::setFilename/setIntroducerFilename r=jandem\n\nUse accessors instead of directly accessing fields so that we can later\ndo automatic deduplication. Add setters that can be passed owned strings\nwhen they are available.\n\nReplace the XDRState::codeCString mechanism entirely. First restrict\nstring lengths to JSString::MAX_LENGTH as a reasonable upper bound.\nIntroduce XDRState::codeCharsZ to generate owned strings while decoding.\nIn practice we would duplicate the string anyways and this better\nsupports unaligned and endian-safe char16_t strings as well.\n\nTogether we do the same number of copies as before.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43184", "files": ["js/src/vm/JSScript.cpp", "js/src/vm/JSScript.h", "js/src/vm/Xdr.cpp", "js/src/vm/Xdr.h"], "git_node": null, "git_parents": [null], "node": "ac703b3adadbcac00bb5fb7f37c47d7c3e8311c0", "parents": ["fe6f7a136d065df59f4037f22f662efe249f87ce"], "tags": []}, {"author": "Ted Campbell \u003ctcampbell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575077 - Cleanup ScriptSource::sourceMapURL/displayURL r=jandem\n\nAdd accessors to avoid direct access to fields so storage can be changed\nlater.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43185", "files": ["js/src/vm/JSScript.cpp", "js/src/vm/JSScript.h"], "git_node": null, "git_parents": [null], "node": "6a2ed5eebc87d114ed378b9cfb45f0f08aad2c3b", "parents": ["ac703b3adadbcac00bb5fb7f37c47d7c3e8311c0"], "tags": []}, {"author": "Ted Campbell \u003ctcampbell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575077 - Use SharedImmutableStringCache for SharedScript urls r=jandem\n\nPages that use 'new Function' heavily create a lot of ScriptSource\nobjects and waste memory duplicating filenames. This is particularly\nproblematic if the filename is a data-url. Use the existing runtime\nstrings cache as a straightforward way to share this. The source text\nalready is using this cache.\n\nFor the XDR case, we expect filenames to almost always be unique so we\ncan eagerly allocate the owned strings without worrying.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43186", "files": ["js/src/vm/JSScript.cpp", "js/src/vm/JSScript.h"], "git_node": null, "git_parents": [null], "node": "13b9c22b05c80f07d370d910c009bf742922db22", "parents": ["6a2ed5eebc87d114ed378b9cfb45f0f08aad2c3b"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1540117 - Part 1: Do not generate a console warning when we reject an attempt to retrieve a cookie for a host that has none stored; r=baku\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43270", "files": ["netwerk/cookie/nsCookieService.cpp"], "git_node": null, "git_parents": [null], "node": "c93e83feda5eaf32b2d21ef710967f99b98c9fba", "parents": ["13b9c22b05c80f07d370d910c009bf742922db22"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1540117 - Part 2: Add a pref to allow turning off the lazy reporting off anti-tracking warnings to the web console; r=baku\n\nThis pref will be used in tests only.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43271", "files": ["modules/libpref/init/StaticPrefList.yaml", "toolkit/components/antitracking/AntiTrackingCommon.cpp"], "git_node": null, "git_parents": [null], "node": "1dc867e1d4b2f00974234887678c0df736efceda", "parents": ["c93e83feda5eaf32b2d21ef710967f99b98c9fba"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1540117 - Part 3: Add unit tests for ensuring that the right set of console messages are captured during the anti-tracking test suite, and also add test coverage for BEHAVIOR_REJECT_FOREIGN; r=baku\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43272", "files": ["toolkit/components/antitracking/AntiTrackingCommon.cpp", "toolkit/components/antitracking/test/browser/antitracking_head.js", "toolkit/components/antitracking/test/browser/browser_blockingCookies.js", "toolkit/components/antitracking/test/browser/browser_blockingDOMCache.js", "toolkit/components/antitracking/test/browser/browser_blockingIndexedDb.js", "toolkit/components/antitracking/test/browser/browser_blockingIndexedDbInWorkers.js", "toolkit/components/antitracking/test/browser/browser_blockingLocalStorage.js", "toolkit/components/antitracking/test/browser/browser_blockingMessaging.js", "toolkit/components/antitracking/test/browser/browser_blockingServiceWorkersStorageAccessAPI.js", "toolkit/components/antitracking/test/browser/browser_blockingSessionStorage.js", "toolkit/components/antitracking/test/browser/browser_blockingSharedWorkers.js", "toolkit/components/antitracking/test/browser/browser_partitionedLocalStorage.js", "toolkit/components/antitracking/test/browser/browser_siteSpecificWorkArounds.js", "toolkit/components/antitracking/test/browser/browser_storageAccessPromiseRejectHandlerUserInteraction.js", "toolkit/components/antitracking/test/browser/browser_storageAccessSandboxed.js", "toolkit/components/antitracking/test/browser/imageCacheWorker.js"], "git_node": null, "git_parents": [null], "node": "1dcf5956a3f13c0a83a5585ff732c4be60894436", "parents": ["1dc867e1d4b2f00974234887678c0df736efceda"], "tags": []}, {"author": "Tim Huang \u003ctihuang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576871 - Clean up the allow list after the test 'testQuickSwitchTabAfterTogglingTPSwitch' in test browser_protections_UI.js r=nhnt11\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43594", "files": ["browser/base/content/test/siteProtections/browser_protections_UI.js"], "git_node": null, "git_parents": [null], "node": "20f391b8fafd1d8171f04c20a3aebdc4860a217b", "parents": ["1dcf5956a3f13c0a83a5585ff732c4be60894436"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576748 - make symbolstore.py complain loudly if expected output isn't found; r=nalexander\n\nThis change surfaces errors faster, and ensures that we don't silently\nend up with empty crashreporter symbols if `dump_syms` can't run for\nsome reason.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43520", "files": ["toolkit/crashreporter/tools/symbolstore.py"], "git_node": null, "git_parents": [null], "node": "f5c3925fab83971956e7a9da8c9364147ba371e6", "parents": ["20f391b8fafd1d8171f04c20a3aebdc4860a217b"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1573485 - put developer tools button back on the right/end of the toolbar in devedition, r=pbro,jaws\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43599", "files": ["browser/components/customizableui/CustomizableUI.jsm"], "git_node": null, "git_parents": [null], "node": "6473a165521bcfb94176525ed6b89a7dbe511c35", "parents": ["f5c3925fab83971956e7a9da8c9364147ba371e6"], "tags": []}, {"author": "Paul Zuehlcke \u003cpzuhlcke@mozilla.com\u003e", "branch": "default", "desc": "Bug 1573124 - Updated identity popup security view heading to include domain name. r=nhnt11\n\nDifferential Revision: https://phabricator.services.mozilla.com/D41546", "files": ["browser/base/content/browser-siteIdentity.js", "browser/components/controlcenter/content/identityPanel.inc.xul", "browser/locales/en-US/chrome/browser/browser.dtd", "browser/locales/en-US/chrome/browser/browser.properties"], "git_node": null, "git_parents": [null], "node": "b8c9f6b697f20e87c59e6cfad1d38232da90569c", "parents": ["6473a165521bcfb94176525ed6b89a7dbe511c35"], "tags": []}, {"author": "yulia \u003cystartsev@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575237 - allow access to all remote child targets' inspector fronts from the root target r=pbro,rcaliman\n\ninspector front; r=!ochameau,!pbro\"\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43432", "files": ["devtools/shared/fronts/inspector.js"], "git_node": null, "git_parents": [null], "node": "0109aabb60c568f1fd72b184d4794c505244be9a", "parents": ["b8c9f6b697f20e87c59e6cfad1d38232da90569c"], "tags": []}, {"author": "yulia \u003cystartsev@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575237 - Initial implementation of search for top level documents in the inspector; r=pbro\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42662", "files": ["devtools/client/inspector/inspector-search.js"], "git_node": null, "git_parents": [null], "node": "83a23e6e2b9f70817d6879ab60820591ac44ae33", "parents": ["0109aabb60c568f1fd72b184d4794c505244be9a"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1575190 - Properly unload test add-on after manager restart r=zombie\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42670", "files": ["toolkit/components/extensions/ExtensionXPCShellUtils.jsm", "toolkit/components/extensions/test/xpcshell/test_ext_test_wrapper.js", "toolkit/components/extensions/test/xpcshell/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "263a749246754088a6b6923f87bc3160c919b70f", "parents": ["83a23e6e2b9f70817d6879ab60820591ac44ae33"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1548508 - Ensure that primed event listeners are eventually unregistered r=mixedpuppy\n\nDepends on D42670\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42671", "files": ["toolkit/components/extensions/ExtensionCommon.jsm", "toolkit/components/extensions/parent/ext-backgroundPage.js", "toolkit/components/extensions/test/xpcshell/test_ext_persistent_events.js"], "git_node": null, "git_parents": [null], "node": "4a697b4bd644db1887aaf6a79697378b7b453ca6", "parents": ["263a749246754088a6b6923f87bc3160c919b70f"], "tags": []}, {"author": "goncharov \u003creal.trd@gmail.com\u003e", "branch": "default", "desc": "Bug 1097836 - Give users on Windows the choice between POSIX and Windows escaped \"Copy as cURL\" commands. r=Honza\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42699", "files": ["devtools/client/locales/en-US/netmonitor.properties", "devtools/client/netmonitor/src/widgets/RequestListContextMenu.js", "devtools/client/netmonitor/test/browser_net_copy_as_curl.js", "devtools/client/netmonitor/test/browser_net_curl-utils.js", "devtools/client/netmonitor/test/html_curl-utils.html", "devtools/client/shared/curl.js"], "git_node": null, "git_parents": [null], "node": "41b21e18ff5ae2e135dec99534dfe0fa091bf33d", "parents": ["4a697b4bd644db1887aaf6a79697378b7b453ca6"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1574036 - [Wayland] Fix flickering during window resize, r=jhorak\n\nRecently window resize on Wayland produces flickering/rendering artifacts because\nwindow background is randomly cleared due to actual window size changes.\nWe recently query widget size and do clear/fullscreen update when the size changes.\n\nTo avoid that, get widget size once at WindowSurfaceWayland::Lock() and use it\nuntil next WindowSurfaceWayland::Lock(). Also don't to switch wayland back buffers\nuntil there's really fullscreen update from compositor.\n\nThis patch:\n\n- Use mLockedScreenRect to store window size at WindowSurfaceWayland::Lock(). It's used\n  to detect widget resize, when it happens throw away all cached painting and wait for\n  full screen update.\n\n- Use mBufferScreenRect to store size of wayland back buffer and pass it\n  instead of actual widget size we used before this patch. This ensures all our\n  drawing matches the buffer size.\n\n- Rename aFullScreenUpdate to aCanSwitchBuffer at LockWaylandBuffer() to stress\n  actual meaning - we can/can't switch back buffers for partial drawing and we need to\n  wait until recent back buffer is released by compositor.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43263", "files": ["widget/gtk/WindowSurfaceWayland.cpp", "widget/gtk/WindowSurfaceWayland.h"], "git_node": null, "git_parents": [null], "node": "e351a8f6c71ed81628843795972db48e16118b17", "parents": ["41b21e18ff5ae2e135dec99534dfe0fa091bf33d"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1575692 - do not recreate the DB file via the directory service inside DatabaseLocker class off the mainthread, r=mak\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43225", "files": ["storage/test/gtest/storage_test_harness.h", "storage/test/gtest/test_unlock_notify.cpp"], "git_node": null, "git_parents": [null], "node": "0a32477c7afc8672b7ca965f7358a2936c3c06eb", "parents": ["e351a8f6c71ed81628843795972db48e16118b17"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1540982 - Upgrade to ESLint 6.2.2 and switch to ECMA version 11 (BigInt support, Dynamic imports). r=mossop\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43590", "files": ["js/src/builtin/TypedArray.js", "package-lock.json", "package.json", "tools/lint/eslint/eslint-plugin-mozilla/lib/configs/recommended.js", "tools/lint/eslint/eslint-plugin-mozilla/manifest.tt", "tools/lint/eslint/eslint-plugin-mozilla/package-lock.json", "tools/lint/eslint/eslint-plugin-mozilla/package.json", "tools/lint/eslint/manifest.tt"], "git_node": null, "git_parents": [null], "node": "639ee379247d4d2b20ee88cd6244b16ff5067d0f", "parents": ["0a32477c7afc8672b7ca965f7358a2936c3c06eb"], "tags": []}, {"author": "Christian Holler \u003ccholler@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576922 - Don't build JS fuzz-tests when JS shell is disabled. r=froydnj\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43615", "files": ["js/src/moz.build"], "git_node": null, "git_parents": [null], "node": "ac1b574350a7a224c04280cad6bde1ccbaf881b3", "parents": ["639ee379247d4d2b20ee88cd6244b16ff5067d0f"], "tags": []}, {"author": "Noemi Erli \u003cnerli@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset f5c3925fab83 (bug 1576748) for bustage in symbolstore.py", "files": ["toolkit/crashreporter/tools/symbolstore.py"], "git_node": null, "git_parents": [null], "node": "1630fa8aa729c0c3689d7f42905ddaf1b10682aa", "parents": ["ac1b574350a7a224c04280cad6bde1ccbaf881b3"], "tags": []}, {"author": "Noemi Erli \u003cnerli@mozilla.com\u003e", "branch": "default", "desc": "Backed out 3 changesets (bug 1540117) for failures in browser_storageAccessPrivateWindow.js\n\nBacked out changeset 1dcf5956a3f1 (bug 1540117)\nBacked out changeset 1dc867e1d4b2 (bug 1540117)\nBacked out changeset c93e83feda5e (bug 1540117)", "files": ["modules/libpref/init/StaticPrefList.yaml", "netwerk/cookie/nsCookieService.cpp", "toolkit/components/antitracking/AntiTrackingCommon.cpp", "toolkit/components/antitracking/test/browser/antitracking_head.js", "toolkit/components/antitracking/test/browser/browser_blockingCookies.js", "toolkit/components/antitracking/test/browser/browser_blockingDOMCache.js", "toolkit/components/antitracking/test/browser/browser_blockingIndexedDb.js", "toolkit/components/antitracking/test/browser/browser_blockingIndexedDbInWorkers.js", "toolkit/components/antitracking/test/browser/browser_blockingLocalStorage.js", "toolkit/components/antitracking/test/browser/browser_blockingMessaging.js", "toolkit/components/antitracking/test/browser/browser_blockingServiceWorkersStorageAccessAPI.js", "toolkit/components/antitracking/test/browser/browser_blockingSessionStorage.js", "toolkit/components/antitracking/test/browser/browser_blockingSharedWorkers.js", "toolkit/components/antitracking/test/browser/browser_partitionedLocalStorage.js", "toolkit/components/antitracking/test/browser/browser_siteSpecificWorkArounds.js", "toolkit/components/antitracking/test/browser/browser_storageAccessPromiseRejectHandlerUserInteraction.js", "toolkit/components/antitracking/test/browser/browser_storageAccessSandboxed.js", "toolkit/components/antitracking/test/browser/imageCacheWorker.js"], "git_node": null, "git_parents": [null], "node": "8c771ad2ef1ea634e2c15ea6b9e7ff84fb365d7e", "parents": ["1630fa8aa729c0c3689d7f42905ddaf1b10682aa"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1548734 - intermittent failure in rowser_view_resultTypes_display.js. r=dao\n\nThis is still failing in a similar way as before, try to change the target for now.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43617", "files": ["browser/components/urlbar/tests/browser/browser_view_resultTypes_display.js"], "git_node": null, "git_parents": [null], "node": "f8aee479958702d0fe93b9a0ee162a44bfe08c85", "parents": ["8c771ad2ef1ea634e2c15ea6b9e7ff84fb365d7e"], "tags": []}, {"author": "Kris Taeleman \u003cktaeleman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1565991 - Ensure calling createPattern with `new Image()` returns null. r=jrmuizel\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42038", "files": ["dom/canvas/CanvasRenderingContext2D.cpp", "testing/web-platform/meta/2dcontext/fill-and-stroke-styles/2d.pattern.image.incomplete.nosrc.html.ini", "testing/web-platform/tests/2dcontext/tools/tests2d.yaml"], "git_node": null, "git_parents": [null], "node": "f69e1e9da360ddb82c69ae7328710ab9dd339c96", "parents": ["f8aee479958702d0fe93b9a0ee162a44bfe08c85"], "tags": []}, {"author": "Sylvestre Ledru \u003csledru@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576502 - Fix some wording issues r=mhoye\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43363", "files": ["dom/tests/mochitest/ajax/mochikit/MochiKit/Logging.js", "js/src/vm/StringType.h", "layout/xul/nsMenuBarListener.cpp", "media/mtransport/test_nr_socket.cpp", "mobile/android/app/src/test/resources/feed_atom_planetmozilla.xml", "mobile/android/app/src/test/resources/feed_rss10_planetmozilla.xml", "mobile/android/app/src/test/resources/feed_rss20_planetmozilla.xml", "parser/htmlparser/nsScannerString.cpp", "security/manager/ssl/tests/mochitest/browser/browser_certViewer.js", "services/sync/modules-testing/fakeservices.js", "testing/mochitest/MochiKit/Logging.js", "toolkit/components/find/nsWebBrowserFind.cpp", "toolkit/components/passwordmgr/LoginManagerContent.jsm", "toolkit/recordreplay/ipc/ChildProcess.cpp"], "git_node": null, "git_parents": [null], "node": "4e2d578316675b7b876115c27b23d87ac1e95e35", "parents": ["f69e1e9da360ddb82c69ae7328710ab9dd339c96"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576758 - Correct a HostSharedLibrary's link command to correctly output a pdb r=glandium\n\n-Fd is the parameter accepted by clang. -PDB is the parameter accepted by lld-link. Additionally, to produce a pdb you apparently also need the -DEBUG flag\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43525", "files": ["config/rules.mk"], "git_node": null, "git_parents": [null], "node": "88935a44fe7ccbb0787cd0593e37345c8b03a392", "parents": ["4e2d578316675b7b876115c27b23d87ac1e95e35"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1572393 - Backout changeset 2a975bc4c88c because it wasn't useful to eliminate the test failures\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43626", "files": ["toolkit/components/antitracking/test/browser/browser.ini", "toolkit/components/antitracking/test/browser/browser_storageAccessPrivateWindow.js"], "git_node": null, "git_parents": [null], "node": "6cb67960abb5fb5822c2fdbcf2ec869100c7b253", "parents": ["88935a44fe7ccbb0787cd0593e37345c8b03a392"], "tags": []}, {"author": "M\u0101ris Fogels \u003cmars@mozilla.com\u003e", "branch": "default", "desc": "Bug 1210157 - Use unicode_literals in all mozboot modules r=firefox-build-system-reviewers,mshal\n\nAdd unicode_literals to all mozboot module __future__ statements to support\nrunning the modules under Python 3.  Remove comments about unicode_literals and\nPython 2.6 support as Python 2.6 is no longer supported in tree.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39359", "files": ["python/mozboot/mozboot/android.py", "python/mozboot/mozboot/archlinux.py", "python/mozboot/mozboot/bootstrap.py", "python/mozboot/mozboot/centosfedora.py", "python/mozboot/mozboot/debian.py", "python/mozboot/mozboot/freebsd.py", "python/mozboot/mozboot/gentoo.py", "python/mozboot/mozboot/linux_common.py", "python/mozboot/mozboot/mozillabuild.py", "python/mozboot/mozboot/openbsd.py", "python/mozboot/mozboot/rust.py", "python/mozboot/mozboot/test/test_write_config.py", "python/mozboot/mozboot/util.py", "python/mozboot/mozboot/windows.py", "python/mozboot/setup.py"], "git_node": null, "git_parents": [null], "node": "fd1ce26da3100194bb97ad192ae6247ba9628771", "parents": ["6cb67960abb5fb5822c2fdbcf2ec869100c7b253"], "tags": []}, {"author": "M\u0101ris Fogels \u003cmars@mozilla.com\u003e", "branch": "default", "desc": "Bug 1210157 - Add Python 3 support to mozboot.base and mozboot.bootstrap r=firefox-build-system-reviewers,mshal\n\nAdd support for both Python 3 and Python 2.7 to the mozboot.base and\nmozboot.bootstrap modules.  Remove legacy Python 2.6 code or mark it for later\nremoval.\n\nDepends on D39359\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39360", "files": ["python/mozboot/mozboot/base.py", "python/mozboot/mozboot/bootstrap.py", "python/mozboot/mozboot/test/python.ini", "python/mozboot/mozboot/test/test_write_config.py"], "git_node": null, "git_parents": [null], "node": "41bebeeebc277d0b23b6a55331ad97319be63d60", "parents": ["fd1ce26da3100194bb97ad192ae6247ba9628771"], "tags": []}, {"author": "M\u0101ris Fogels \u003cmars@mozilla.com\u003e", "branch": "default", "desc": "Bug 1210157 - Add Python 3 support to the mozboot Debian bootstrapper r=firefox-build-system-reviewers,mshal\n\nAdd support for Python 3 and Python 2.7 to the Debian-based linux distro\nbootstrap routines.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39361", "files": ["python/mozboot/mozboot/debian.py"], "git_node": null, "git_parents": [null], "node": "6a5f5594422fa3120fdc6f2ff5a8cbf072f94b42", "parents": ["41bebeeebc277d0b23b6a55331ad97319be63d60"], "tags": []}, {"author": "M\u0101ris Fogels \u003cmars@mozilla.com\u003e", "branch": "default", "desc": "Bug 1210157 - Add Python 3 support to mozboot Android toolchain bootstrap r=nalexander\n\nSupport installing the android development toolchain with Python 3 as well as\nPython 2.7.\n\nDepends on D39361\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39362", "files": ["python/mozboot/mozboot/android.py"], "git_node": null, "git_parents": [null], "node": "d79183b963e7c47d26150f31f0179888f3b51fd2", "parents": ["6a5f5594422fa3120fdc6f2ff5a8cbf072f94b42"], "tags": []}, {"author": "M\u0101ris Fogels \u003cmars@mozilla.com\u003e", "branch": "default", "desc": "Bug 1569046 - Add Python 3 support to mozboot.osx r=firefox-build-system-reviewers,mshal\n\nMake the mozboot.osx module work with Python 3 in addition to\nPython 2.7.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39560", "files": ["python/mozboot/mozboot/osx.py"], "git_node": null, "git_parents": [null], "node": "5ddb34b933f3229cd358d690dc13639445815755", "parents": ["d79183b963e7c47d26150f31f0179888f3b51fd2"], "tags": []}, {"author": "M\u0101ris Fogels \u003cmars@mozilla.com\u003e", "branch": "default", "desc": "Bug 1210157 - Add a --debug option to bootstrap.py r=nalexander\n\nAdd an option to run bootstrap.py with '--debug'. This will print full\ntracebacks if the bootstrap process encounters an uncaught exception. It should\nbe useful for developers who are working on the bootstrap code as well as users\nwhen writing bug reports.\n\nDepends on D39362\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39363", "files": ["python/mozboot/bin/bootstrap.py"], "git_node": null, "git_parents": [null], "node": "7c2b0c902854d5e60b4b0013f17e2f5ce195aa4a", "parents": ["5ddb34b933f3229cd358d690dc13639445815755"], "tags": []}, {"author": "M\u0101ris Fogels \u003cmars@mozilla.com\u003e", "branch": "default", "desc": "Bug 1210157 - Make bootstrap.py work with Python 3.5+ and Python 2.7 r=firefox-build-system-reviewers,mshal\n\nMake bootstrap.py compatible with both Python 3.5+ and Python 2.7. Remove\nPython 2.6 support as Python 2.6 is no longer supported in the Firefox source\ntree.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39364", "files": ["python/mozboot/bin/bootstrap.py"], "git_node": null, "git_parents": [null], "node": "f0f92aecee180a0377721ee8558579769c1ccc45", "parents": ["7c2b0c902854d5e60b4b0013f17e2f5ce195aa4a"], "tags": []}, {"author": "M\u0101ris Fogels \u003cmars@mozilla.com\u003e", "branch": "default", "desc": "Bug 1210157 - Fix Python 3 issues in mozboot.gentoo and mozboot.archlinux r=firefox-build-system-reviewers,mshal\n\nFix some library calls and syntax that are required to support Python 3.\n\nDepends on D39364\n\nDifferential Revision: https://phabricator.services.mozilla.com/D39365", "files": ["python/mozboot/mozboot/archlinux.py", "python/mozboot/mozboot/gentoo.py"], "git_node": null, "git_parents": [null], "node": "d00d447a0c29aa932ab110abd0449f4463ef829a", "parents": ["f0f92aecee180a0377721ee8558579769c1ccc45"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1559592 - [marionette] Change test_capture_full_area to capture an opened dialog. r=webdriver-reviewers,automatedtester\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42372", "files": ["testing/marionette/harness/marionette_harness/tests/unit/test_screenshot.py"], "git_node": null, "git_parents": [null], "node": "dc7d1cfdaf586d43902b3590c7bab87384dc0740", "parents": ["d00d447a0c29aa932ab110abd0449f4463ef829a"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1559592 - [marionette] Remove unit tests for screenshot flags. r=webdriver-reviewers,ato\n\nOn Android there is no focus ring drawn, and in general it depends\non the visibility of the caret, which constantly blinks. As such\nintermittent and perma failures can always occur. Best is to just\nremove this flaky test.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42493", "files": ["testing/marionette/harness/marionette_harness/tests/unit/test_screenshot.py"], "git_node": null, "git_parents": [null], "node": "2ce935953dd0fb3babd970de88a110219eecba69", "parents": ["dc7d1cfdaf586d43902b3590c7bab87384dc0740"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1559592 - [marionette] Take screenshots for content in parent process. r=webdriver-reviewers,ato,automatedtester\n\nThis moves all the screenshot related code from the framescript to\nthe parent process, so that canvas.js is no longer called from\nwithin a content process.\n\nThe remaining code in the framescript is only needed to compute\nthe dimensions of the screenshot, and from all the to highlight\nelements.\n\nThis move is necessary to allow switching to the new drawSnapshot\nAPI which only works from within the parent process.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D40209", "files": ["testing/marionette/capture.js", "testing/marionette/driver.js", "testing/marionette/listener.js"], "git_node": null, "git_parents": [null], "node": "5fee1e8e06c6cab1755f15e0fcf6ffb0cb186ba9", "parents": ["2ce935953dd0fb3babd970de88a110219eecba69"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1559592 - [marionette] Make use of the new Fission compatible screen capture API. r=webdriver-reviewers,ato,automatedtester\n\nTo allow Marionette to capture the content of OOP iframes, the\nnew Fission compatible screenshot API has to be used.\n\nFor callers requesting a read-back of the pixel data as\ncurrently in the compositor/window, the 'drawWindow()'\nmethod still has to be called.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D40654", "files": ["testing/marionette/capture.js", "testing/marionette/driver.js", "testing/marionette/listener.js", "testing/marionette/reftest.js"], "git_node": null, "git_parents": [null], "node": "c4ce2527e763199e2c43ef24b1f4043aeefd21e0", "parents": ["5fee1e8e06c6cab1755f15e0fcf6ffb0cb186ba9"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1559592 - [wdspec] Add same and cross origin iframe tests for \"Take (Element) Screenshot\". r=webdriver-reviewers,automatedtester,ato\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42132", "files": ["testing/web-platform/mozilla/tests/webdriver/take_full_screenshot/__init__.py", "testing/web-platform/mozilla/tests/webdriver/take_full_screenshot/iframe.py", "testing/web-platform/tests/webdriver/tests/take_element_screenshot/__init__.py", "testing/web-platform/tests/webdriver/tests/take_element_screenshot/iframe.py", "testing/web-platform/tests/webdriver/tests/take_element_screenshot/screenshot.py", "testing/web-platform/tests/webdriver/tests/take_screenshot/__init__.py", "testing/web-platform/tests/webdriver/tests/take_screenshot/iframe.py", "testing/web-platform/tests/webdriver/tests/take_screenshot/screenshot.py"], "git_node": null, "git_parents": [null], "node": "e1415988eb6f0c808f5beea4209b2c1a8cfd16c6", "parents": ["c4ce2527e763199e2c43ef24b1f4043aeefd21e0"], "tags": []}, {"author": "myeongjun \u003cmyeongjun.ko@gmail.com\u003e", "branch": "default", "desc": "Bug 1392591 - browser.notifications.onClicked callback get erroneous second parameter r=robwu\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43592", "files": ["toolkit/components/extensions/parent/ext-notifications.js"], "git_node": null, "git_parents": [null], "node": "f97cc8c93227d39b4443332f55e3079c40278099", "parents": ["e1415988eb6f0c808f5beea4209b2c1a8cfd16c6"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1540117 - Part 1: Do not generate a console warning when we reject an attempt to retrieve a cookie for a host that has none stored; r=baku\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43270", "files": ["netwerk/cookie/nsCookieService.cpp"], "git_node": null, "git_parents": [null], "node": "11837979956b360341c19e3859b473bc02b46069", "parents": ["f97cc8c93227d39b4443332f55e3079c40278099"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1540117 - Part 2: Add a pref to allow turning off the lazy reporting off anti-tracking warnings to the web console; r=baku\n\nThis pref will be used in tests only.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43271", "files": ["modules/libpref/init/StaticPrefList.yaml", "toolkit/components/antitracking/AntiTrackingCommon.cpp"], "git_node": null, "git_parents": [null], "node": "fcc060bc96777430b9046cd9c6c490171d091483", "parents": ["11837979956b360341c19e3859b473bc02b46069"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1540117 - Part 3: Add unit tests for ensuring that the right set of console messages are captured during the anti-tracking test suite, and also add test coverage for BEHAVIOR_REJECT_FOREIGN; r=baku\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43272", "files": ["toolkit/components/antitracking/AntiTrackingCommon.cpp", "toolkit/components/antitracking/test/browser/antitracking_head.js", "toolkit/components/antitracking/test/browser/browser_blockingCookies.js", "toolkit/components/antitracking/test/browser/browser_blockingDOMCache.js", "toolkit/components/antitracking/test/browser/browser_blockingIndexedDb.js", "toolkit/components/antitracking/test/browser/browser_blockingIndexedDbInWorkers.js", "toolkit/components/antitracking/test/browser/browser_blockingLocalStorage.js", "toolkit/components/antitracking/test/browser/browser_blockingMessaging.js", "toolkit/components/antitracking/test/browser/browser_blockingServiceWorkersStorageAccessAPI.js", "toolkit/components/antitracking/test/browser/browser_blockingSessionStorage.js", "toolkit/components/antitracking/test/browser/browser_blockingSharedWorkers.js", "toolkit/components/antitracking/test/browser/browser_partitionedLocalStorage.js", "toolkit/components/antitracking/test/browser/browser_siteSpecificWorkArounds.js", "toolkit/components/antitracking/test/browser/browser_storageAccessPromiseRejectHandlerUserInteraction.js", "toolkit/components/antitracking/test/browser/browser_storageAccessSandboxed.js", "toolkit/components/antitracking/test/browser/imageCacheWorker.js"], "git_node": null, "git_parents": [null], "node": "1f918cd124a8ea37967bb35e0734795b1ef2c6c8", "parents": ["fcc060bc96777430b9046cd9c6c490171d091483"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576369 - Increase the timeout on browser_blockingCookies.js even more\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43635", "files": ["toolkit/components/antitracking/test/browser/browser_blockingCookies.js"], "git_node": null, "git_parents": [null], "node": "e0afd35bd8cdf253916ba482a214ffdf50bdaf8d", "parents": ["1f918cd124a8ea37967bb35e0734795b1ef2c6c8"], "tags": []}, {"author": "Noemi Erli \u003cnerli@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset f69e1e9da360 (bug 1565991) for failing in test_createPattern_broken.html", "files": ["dom/canvas/CanvasRenderingContext2D.cpp", "testing/web-platform/meta/2dcontext/fill-and-stroke-styles/2d.pattern.image.incomplete.nosrc.html.ini", "testing/web-platform/tests/2dcontext/tools/tests2d.yaml"], "git_node": null, "git_parents": [null], "node": "812f0c821d05280423ec5ceef539f89d2ccac912", "parents": ["e0afd35bd8cdf253916ba482a214ffdf50bdaf8d"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Bug 1576906 - Turn on layout.css.line-height.normal-as-resolved-value.enabled in line-height-computed.html. r=emilio\n\nBy default, it is only enabled in Nightly and Early Beta and causes the test to fail on Late Beta.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43624", "files": ["testing/web-platform/meta/css/css-inline/parsing/line-height-computed.html.ini"], "git_node": null, "git_parents": [null], "node": "22443bed54851de378c4c998fe517248ecbe3ff2", "parents": ["812f0c821d05280423ec5ceef539f89d2ccac912"], "tags": []}, {"author": "Stefan Zager \u003cszager@chromium.org\u003e", "branch": "default", "desc": "Bug 1574064 [wpt PR 18443] - [IntersectionObserver] Use inclusive intersect with remote frame parent, a=testonly\n\nAutomatic update from web-platform-tests\n[IntersectionObserver] Use inclusive intersect with remote frame parent\n\nThe rest of the MapToVisualRectInAncestorSpace code will do inclusive\nintersections when the kEdgeInclusive flag is set, as required by\nIntersectionObserver to correctly handle zero-area targets.\n\nThis patch adds coverage for this situation to the existing WPT for\ncross-origin IntersectionObserver. Since the bug only affects\nIntersectionObserver running inside an OOPIF, this also updates the\ntest to force the iframe into a different domain, rather than just\nusing the sandbox attribute (which is not sufficient to trigger OOPIF).\n\nBUG=978759\n\nChange-Id: I7dbe52d2f3e39e029fed3dda5be31190c593a1e2\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1754595\nReviewed-by: Ken Buchanan \u003ckenrb@chromium.org\u003e\nCommit-Queue: Stefan Zager \u003cszager@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#687361}\n\n--\n\nwpt-commits: 504feb2f721bab75aa597a8082e06700874b84d6\nwpt-pr: 18443\n", "files": ["testing/web-platform/tests/intersection-observer/cross-origin-iframe.html", "testing/web-platform/tests/intersection-observer/cross-origin-iframe.sub.html", "testing/web-platform/tests/intersection-observer/resources/cross-origin-subframe.html", "testing/web-platform/tests/intersection-observer/resources/intersection-observer-test-utils.js"], "git_node": null, "git_parents": [null], "node": "8b1cf775aa78f42e495722c411b2057fd92f8c8b", "parents": ["2c268d869bc48dc4d5e8ff036cac82375ecf507a"], "tags": []}, {"author": "Mike Pennisi \u003cmike@mikepennisi.com\u003e", "branch": "default", "desc": "Bug 1574533 [wpt PR 18341] - [ci] Correct file management in tests, a=testonly\n\nAutomatic update from web-platform-tests\n[ci] Correct file management in tests\n\nThe `mkstemp` function creates a file and opens that file [1], so these\ntests erroneously attempted to delete an open file. This mistake was not\nidentified during development or automated testing because it only leads\nto a runtime exception in Windows environments [2].\n\nRefactor the helper function to close the file immediately after writing\nto it.\n\n[1] \u003e `mkstemp()` returns a tuple containing an OS-level handle to an\n    \u003e open file (as would be returned by `os.open()`) and the absolute\n    \u003e pathname of that file, in that order.\n\n    https://docs.python.org/2/library/tempfile.html#tempfile.mkstemp\n\n[2] \u003e On Windows, attempting to remove a file that is in use causes an\n    \u003e exception to be raised; on Unix, the directory entry is removed\n    \u003e but the storage allocated to the file is not made available until\n    \u003e the original file is no longer in use.\n\n    https://docs.python.org/2/library/os.html#os.remove\n\n--\n\nwpt-commits: 7f35d6cf8b99b613d14786ce990a815c805a1d74\nwpt-pr: 18341\n", "files": ["testing/web-platform/tests/tools/ci/tests/test_update_pr_preview.py"], "git_node": null, "git_parents": [null], "node": "d8ec210f26bdce38b5b4aaed5be98a9bd4226ada", "parents": ["8b1cf775aa78f42e495722c411b2057fd92f8c8b"], "tags": []}, {"author": "Adam Raine \u003casraine@google.com\u003e", "branch": "default", "desc": "Bug 1568324 [wpt PR 18013] - Composite color values on the worklet thread, a=testonly\n\nAutomatic update from web-platform-tests\nComposite color values on the worklet thread\n\nFollow up to:\nhttps://chromium-review.googlesource.com/c/chromium/src/+/1614120\n(Allows number values to be composited on the worklet thread)\n--and--\nhttps://chromium-review.googlesource.com/c/chromium/src/+/1698667\n(Allows creation of keyframe model for color values on compositor)\n\nThis CL adds similar functionality as that used for number types to update\ncolor values on the compositor.  New classes CrossThreadColorValue and\nCSSUnsupportedColorValue were created for CSSPaintValue::GetImage to identify\ncolor valued custom properties as compositable.\n\nBug: 883721\nChange-Id: Ib8c26e5c6c6077b21288de3156fa35cc6e02435d\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1713747\nCommit-Queue: Adam Raine \u003casraine@google.com\u003e\nReviewed-by: Rune Lillesveen \u003cfuthark@chromium.org\u003e\nReviewed-by: Stephen McGruer \u003csmcgruer@chromium.org\u003e\nReviewed-by: Xida Chen \u003cxidachen@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#687702}\n\n--\n\nwpt-commits: 7c42039e0623abaae97105214e9968c92272f15d\nwpt-pr: 18013\n", "files": ["testing/web-platform/tests/css/css-paint-api/color-custom-property-animation-ref.html", "testing/web-platform/tests/css/css-paint-api/color-custom-property-animation.https.html"], "git_node": null, "git_parents": [null], "node": "6e1dcbe925421c39cb7981354f13d7219506ffdd", "parents": ["d8ec210f26bdce38b5b4aaed5be98a9bd4226ada"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1568324 [wpt PR 18013] - Update wpt metadata, a=testonly\n\nwpt-pr: 18013\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/css/css-paint-api/color-custom-property-animation.https.html.ini"], "git_node": null, "git_parents": [null], "node": "b4ec189f388b153b357f95f34aa42bfba53db8cf", "parents": ["6e1dcbe925421c39cb7981354f13d7219506ffdd"], "tags": []}, {"author": "Jacob DeWitt \u003cjacde@chromium.org\u003e", "branch": "default", "desc": "Bug 1573699 [wpt PR 18410] - WPT tests for WebXR SameObject attributes, a=testonly\n\nAutomatic update from web-platform-tests\nWPT tests for WebXR SameObject attributes\n\nAdding [SaveSameObject] and a reference to the attribute in\nv8_private_property.h is required for the [SameObject] FrozenArray\nattributes to have the expected behavior.\n\nAttributes now covered by tests:\nNavigator.xr\nXRSession.{renderState,inputSources}\nXRView.{projectionMatrix,transform}\nXRRigidTransform.{position,orientation,inverse}\nXRPose.transform\nXRViewerPose.views\nXRInputSource.{targetRaySpace,gripSpace,profiles}\nXRWebGLLayer.framebuffer\nXRSessionEvent.session\nXRInputSourceEvent.{frame,inputSource}\nXRInputSourcesChangeEvent.{session,added,removed}\nXRReferenceSpaceEvent.{referenceSpace,transform}\n\nBug: 960958\nChange-Id: I8582909c3e87ec0bfe05e443416708a54f606bd4\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1752934\nReviewed-by: Alexander Cooper \u003calcooper@chromium.org\u003e\nReviewed-by: Brandon Jones \u003cbajones@chromium.org\u003e\nReviewed-by: Jeremy Roman \u003cjbroman@chromium.org\u003e\nCommit-Queue: Jacob DeWitt \u003cjacde@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#687756}\n\n--\n\nwpt-commits: b5a32d255d399ca91c55d37a0cd204a65c5c8866\nwpt-pr: 18410\n", "files": ["testing/web-platform/tests/webxr/events_input_sources_change.https.html", "testing/web-platform/tests/webxr/events_referenceSpace_reset.https.html", "testing/web-platform/tests/webxr/events_session_select.https.html", "testing/web-platform/tests/webxr/navigator_xr_sameObject.https.html", "testing/web-platform/tests/webxr/xrFrame_session_sameObject.https.html", "testing/web-platform/tests/webxr/xrInputSource_sameObject.https.html", "testing/web-platform/tests/webxr/xrPose_transform_sameObject.https.html", "testing/web-platform/tests/webxr/xrRigidTransform_sameObject.https.html", "testing/web-platform/tests/webxr/xrSession_end.https.html", "testing/web-platform/tests/webxr/xrSession_sameObject.https.html", "testing/web-platform/tests/webxr/xrView_sameObject.https.html", "testing/web-platform/tests/webxr/xrViewerPose_views_sameObject.https.html", "testing/web-platform/tests/webxr/xrWebGLLayer_framebuffer_sameObject.https.html"], "git_node": null, "git_parents": [null], "node": "ea81c84418b592dd49ff767a2d7a33f267366d31", "parents": ["b4ec189f388b153b357f95f34aa42bfba53db8cf"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1573699 [wpt PR 18410] - Update wpt metadata, a=testonly\n\nwpt-pr: 18410\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/webxr/navigator_xr_sameObject.https.html.ini", "testing/web-platform/meta/webxr/xrFrame_session_sameObject.https.html.ini", "testing/web-platform/meta/webxr/xrInputSource_sameObject.https.html.ini", "testing/web-platform/meta/webxr/xrPose_transform_sameObject.https.html.ini", "testing/web-platform/meta/webxr/xrRigidTransform_sameObject.https.html.ini", "testing/web-platform/meta/webxr/xrSession_sameObject.https.html.ini", "testing/web-platform/meta/webxr/xrView_sameObject.https.html.ini", "testing/web-platform/meta/webxr/xrViewerPose_views_sameObject.https.html.ini", "testing/web-platform/meta/webxr/xrWebGLLayer_framebuffer_sameObject.https.html.ini"], "git_node": null, "git_parents": [null], "node": "9d418c852407b6345c7e498cd3aad3b7ffe2bb52", "parents": ["ea81c84418b592dd49ff767a2d7a33f267366d31"], "tags": []}, {"author": "Xida Chen \u003cxidachen@chromium.org\u003e", "branch": "default", "desc": "Bug 1573608 [wpt PR 18402] - Rewrite interpolation-testcommon.js, a=testonly\n\nAutomatic update from web-platform-tests\nRewrite interpolation-testcommon.js\n\nRight now the wpt/css/support/interpolation-testcommon.js is very\nspecific to interpolations using CSS animations. As a result, it is\nused by a few tests only.\n\nThis CL rewrites the file. To be more specific, most of the code comes\nfrom web_tests/animations/interpolation/resources/interpolation-test.js,\nwhich runs the tests with several interpolation methods:\n  1. cssAnimationsInterpolation\n  2. cssTransitionsInterpolation\n  3. cssTransitionAllInterpolation\n  4. webAnimationsInterpolation\nWith this general test file, a lot of existing interpolation test can\nuse this. Furthermore, the intention is to move non-wpt interpolation\nand composition tests to wpt using this file.\n\nBug: 900581\nChange-Id: I1058c556932d28709bacdb08a4591c958aead937\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1752103\nCommit-Queue: Xida Chen \u003cxidachen@chromium.org\u003e\nReviewed-by: Stephen McGruer \u003csmcgruer@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#687264}\n\n--\n\nwpt-commits: 92d4abd3c9f5ba2970467b540da200739af27a1f\nwpt-pr: 18402\n", "files": ["testing/web-platform/tests/css/css-transforms/animation/list-interpolation.html", "testing/web-platform/tests/css/css-transforms/animation/matrix-interpolation.html", "testing/web-platform/tests/css/css-transforms/animation/resources/interpolation-testcommon.js", "testing/web-platform/tests/css/css-transforms/animation/rotate-interpolation.html", "testing/web-platform/tests/css/css-transforms/animation/scale-interpolation.html", "testing/web-platform/tests/css/css-transforms/animation/translate-interpolation.html", "testing/web-platform/tests/css/support/interpolation-testcommon.js"], "git_node": null, "git_parents": [null], "node": "c4c7149ef15c3432caf0299adcd1e2c100bb12cb", "parents": ["9d418c852407b6345c7e498cd3aad3b7ffe2bb52"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1573608 [wpt PR 18402] - Update wpt metadata, a=testonly\n\nwpt-pr: 18402\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/css/css-grid/animation/__dir__.ini", "testing/web-platform/meta/css/css-grid/animation/grid-template-columns-interpolation.html.ini", "testing/web-platform/meta/css/css-grid/animation/grid-template-rows-interpolation.html.ini", "testing/web-platform/meta/css/css-transforms/animation/list-interpolation.html.ini", "testing/web-platform/meta/css/css-transforms/animation/matrix-interpolation.html.ini", "testing/web-platform/meta/css/css-transforms/animation/rotate-interpolation.html.ini", "testing/web-platform/meta/css/css-transforms/animation/scale-interpolation.html.ini", "testing/web-platform/