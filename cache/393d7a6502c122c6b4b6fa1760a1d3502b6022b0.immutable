ttps.html.ini", "testing/web-platform/meta/bluetooth/service/getCharacteristics/gen-service-is-removed-with-uuid.https.window.js.ini", "testing/web-platform/meta/bluetooth/service/getCharacteristics/gen-service-is-removed.https.html.ini", "testing/web-platform/meta/bluetooth/service/getCharacteristics/gen-service-is-removed.https.window.js.ini"], "git_node": null, "git_parents": [null], "node": "0c9e01c0a88dec1280303fcd88a4fca883ceb9e0", "parents": ["44ed57bf9874c18e138ebb8c6446916f6d0b82aa"], "tags": []}, {"author": "Leon Han \u003cleon.han@intel.com\u003e", "branch": "default", "desc": "Bug 1575128 [wpt PR 18556] - [webnfc] Make the retval of NDEFRecord#{toText,toArrayBuffer,toJSON}() nullable, a=testonly\n\nAutomatic update from web-platform-tests\n[webnfc] Make the retval of NDEFRecord#{toText,toArrayBuffer,toJSON}() nullable\n\nPreviously, for invalid cases, toText() returns an empty string,\ntoJSON() returns undefined, which does not match the spec.\n\nThe spec was changed at:\nhttps://github.com/w3c/web-nfc/pull/298\n\nBUG=520391\n\nChange-Id: Ia63e675c5b0032cee13802d1e5d706c35089a056\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1761586\nReviewed-by: Rijubrata Bhaumik \u003crijubrata.bhaumik@intel.com\u003e\nReviewed-by: Reilly Grant \u003creillyg@chromium.org\u003e\nCommit-Queue: Leon Han \u003cleon.han@intel.com\u003e\nCr-Commit-Position: refs/heads/master@{#688840}\n\n--\n\nwpt-commits: 92f88af2986da56259c26c16ec473e6961c80ad3\nwpt-pr: 18556\n", "files": ["testing/web-platform/tests/web-nfc/NDEFMessage_constructor.https.html", "testing/web-platform/tests/web-nfc/NDEFRecord_constructor.https.html", "testing/web-platform/tests/web-nfc/resources/nfc-helpers.js"], "git_node": null, "git_parents": [null], "node": "7ec08fc314cd8d8de4ff92d3cb3333d56e48e403", "parents": ["0c9e01c0a88dec1280303fcd88a4fca883ceb9e0"], "tags": []}, {"author": "Yutaka Hirano \u003cyhirano@chromium.org\u003e", "branch": "default", "desc": "Bug 1575152 [wpt PR 18559] - Add cross-origin-embedder-policy tests with service workers, a=testonly\n\nAutomatic update from web-platform-tests\nAdd cross-origin-embedder-policy tests with service workers (#18559)\n\n--\n\nwpt-commits: 036e8eee89e1162bd73fd7e4f4e94bcba5c4bbbe\nwpt-pr: 18559\n", "files": ["testing/web-platform/tests/html/cross-origin-embedder-policy/none-sw-from-none.https.html", "testing/web-platform/tests/html/cross-origin-embedder-policy/none-sw-from-require-corp.https.html", "testing/web-platform/tests/html/cross-origin-embedder-policy/none-sw-from-require-corp.https.html.headers", "testing/web-platform/tests/html/cross-origin-embedder-policy/require-corp-sw-from-none.https.html", "testing/web-platform/tests/html/cross-origin-embedder-policy/require-corp-sw-from-require-corp.https.html", "testing/web-platform/tests/html/cross-origin-embedder-policy/require-corp-sw-from-require-corp.https.html.headers", "testing/web-platform/tests/html/cross-origin-embedder-policy/resources/nothing.txt", "testing/web-platform/tests/html/cross-origin-embedder-policy/resources/sw.js"], "git_node": null, "git_parents": [null], "node": "472522e4b01dcd4c939637c871b31d89cb16f8d9", "parents": ["7ec08fc314cd8d8de4ff92d3cb3333d56e48e403"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1575152 [wpt PR 18559] - Update wpt metadata, a=testonly\n\nwpt-pr: 18559\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/html/cross-origin-embedder-policy/none-sw-from-none.https.html.ini", "testing/web-platform/meta/html/cross-origin-embedder-policy/none-sw-from-require-corp.https.html.ini", "testing/web-platform/meta/html/cross-origin-embedder-policy/require-corp-sw-from-none.https.html.ini", "testing/web-platform/meta/html/cross-origin-embedder-policy/require-corp-sw-from-require-corp.https.html.ini"], "git_node": null, "git_parents": [null], "node": "d6d7926c1d0b44999a2cdb9e198dd3d305f13bde", "parents": ["472522e4b01dcd4c939637c871b31d89cb16f8d9"], "tags": []}, {"author": "Sam Sebree \u003csasebree@microsoft.com\u003e", "branch": "default", "desc": "Bug 1574365 [wpt PR 18477] - [SyntheticModules] Allows for Fetching and Loading of JSON/Synthetic Modules, a=testonly\n\nAutomatic update from web-platform-tests\n[SyntheticModules] Allows for Fetching and Loading of JSON/Synthetic Modules\n\nThis is the final change required for JSON Modules to be utilized by developers.\nFollowing the acceptance of this change, if you run chromium with the JSONModules runtime flag, the following is now valid syntax:\n\n\u003cscript type=\"module\"\u003e\n    import data from \"./example.json\";\n\u003c/script\u003e\n\nThis change introduces several things:\n\n-It introduces the ability for ModuleScriptLoader to load JSON Modules\n-It introduces the ability for ModuleScriptFetcher to retrieve JSON resources\n-It introduces a new field to ModuleScriptCreationParams: response_mime_type_\n-It introduces the JSONModules runtime flag to chromium\n\nThis change corresponds with the following V8 change:\nhttps://chromium-review.googlesource.com/c/v8/v8/+/1761583\n\nBug: 967018\nChange-Id: Ibcdb61659fb07047ffeead2ff4a55c450c183e43\nReviewed-on: https://chromium-review.googlesource.com/c/chromium/src/+/1731108\nReviewed-by: Hiroshige Hayashizaki \u003chiroshige@chromium.org\u003e\nReviewed-by: Hiroki Nakagawa \u003cnhiroki@chromium.org\u003e\nCommit-Queue: Sam Sebree \u003csasebree@microsoft.com\u003e\nCr-Commit-Position: refs/heads/master@{#688905}\n\n--\n\nwpt-commits: a8a1303f3dadc7392a426ca6525e23b6114bb066\nwpt-pr: 18477\n", "files": ["testing/web-platform/tests/html/semantics/scripting-1/the-script-element/json-module/non-object.any.js"], "git_node": null, "git_parents": [null], "node": "bff8292409ef3d02dff5515ced4ae1bb976fc58d", "parents": ["d6d7926c1d0b44999a2cdb9e198dd3d305f13bde"], "tags": []}, {"author": "Philip J\u00e4genstedt \u003cphilip@foolip.org\u003e", "branch": "default", "desc": "Bug 1574126 [wpt PR 18454] - [Azure Pipelines] drop old workaround for `safaridriver --version`, a=testonly\n\nAutomatic update from web-platform-tests\n[Azure Pipelines] drop old workaround for `safaridriver --version` (#18454)\n\nThe `--version` argument is supported starting in Safari 12.1:\nhttps://github.com/web-platform-tests/results-collection/issues/617\n--\n\nwpt-commits: a2d1acf3d4e8fe76eba70ee9b5f69dba2189819f\nwpt-pr: 18454\n", "files": ["testing/web-platform/tests/.azure-pipelines.yml"], "git_node": null, "git_parents": [null], "node": "5bdb6f1e8f37dfdc0ca96fdb8ae79ea0a36f2483", "parents": ["bff8292409ef3d02dff5515ced4ae1bb976fc58d"], "tags": []}, {"author": "Anne van Kesteren \u003cannevk@annevk.nl\u003e", "branch": "default", "desc": "Bug 1574918 [wpt PR 18543] - HTML: COEP and ImageBitmap, a=testonly\n\nAutomatic update from web-platform-tests\nHTML: COEP and ImageBitmap\n\nHelps with https://github.com/whatwg/html/pull/4734 and #18354.\n--\n\nwpt-commits: 53c7a93cc4ba3a5fa1fe3f3358eeb9ad2ad2f0e9\nwpt-pr: 18543\n", "files": ["testing/web-platform/tests/2dcontext/imagebitmap/no-coop-coep.https.window.js", "testing/web-platform/tests/2dcontext/imagebitmap/resources/coop-coep-popup.html", "testing/web-platform/tests/2dcontext/imagebitmap/resources/coop-coep-popup.html.headers", "testing/web-platform/tests/2dcontext/imagebitmap/resources/coop-coep-worker.js", "testing/web-platform/tests/2dcontext/imagebitmap/resources/coop-coep-worker.js.headers"], "git_node": null, "git_parents": [null], "node": "c54a17c0f130def375ddf9dffae7b4ebd52d9da0", "parents": ["5bdb6f1e8f37dfdc0ca96fdb8ae79ea0a36f2483"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1574918 [wpt PR 18543] - Update wpt metadata, a=testonly\n\nwpt-pr: 18543\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/2dcontext/imagebitmap/no-coop-coep.https.window.js.ini"], "git_node": null, "git_parents": [null], "node": "3c03927d9723b34564efb39bd8896254c23