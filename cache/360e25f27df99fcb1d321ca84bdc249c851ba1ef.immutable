pp", "gfx/webrender_bindings/RenderCompositorANGLE.cpp", "gfx/webrender_bindings/RenderThread.cpp", "gfx/webrender_bindings/RenderThread.h"], "git_node": null, "git_parents": [null], "node": "e962019750e9396af45cb45b7b38fbf046d8c221", "parents": ["dfff9e92ca9710b2e56e0a38f86362b7a8903049"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1467842 - Don't take the exclusive access lock during GC r=sfink", "files": ["js/src/gc/GC.cpp", "js/src/gc/GCInternals.h", "js/src/gc/GCMarker.h", "js/src/gc/GCRuntime.h", "js/src/gc/Marking.cpp", "js/src/gc/PublicIterators.cpp", "js/src/gc/RootMarking.cpp", "js/src/gc/Verifier.cpp", "js/src/gc/Zone.cpp", "js/src/gc/Zone.h", "js/src/jit/Ion.cpp", "js/src/jit/JitRealm.h", "js/src/jsfriendapi.cpp", "js/src/threading/ProtectedData.cpp", "js/src/vm/HelperThreads.cpp", "js/src/vm/HelperThreads.h", "js/src/vm/JSAtom.cpp", "js/src/vm/JSAtom.h", "js/src/vm/JSContext.h", "js/src/vm/Runtime.cpp", "js/src/vm/Runtime.h", "js/src/vm/SymbolType.cpp", "js/src/vm/SymbolType.h"], "git_node": null, "git_parents": [null], "node": "84b05310b2c7a6b0c585add58fdb27e635e70963", "parents": ["e962019750e9396af45cb45b7b38fbf046d8c221"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1467842 - Refactor heap state RAII classes r=sfink", "files": ["js/src/gc/GC.cpp", "js/src/gc/GCInternals.h", "js/src/gc/GCRuntime.h", "js/src/gc/Nursery.cpp", "js/src/gc/RootMarking.cpp", "js/src/gc/Verifier.cpp", "js/src/jsfriendapi.cpp", "js/src/vm/BytecodeUtil.cpp", "js/src/vm/Runtime.h"], "git_node": null, "git_parents": [null], "node": "4f50305f72aba391db457322d078d4908221e20e", "parents": ["84b05310b2c7a6b0c585add58fdb27e635e70963"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1468665: Don't call the before change closure with the locked declaration block. r=xidorn\n\nTest Plan: No behavior change.\n\nReviewers: xidorn\n\nBug #: 1468665\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1681\n\nMozReview-Commit-ID: JI18xI6aHCh\n", "files": ["layout/style/ServoBindingList.h", "layout/style/ServoBindingTypes.h", "layout/style/ServoBindings.toml", "servo/components/style/properties/declaration_block.rs", "servo/ports/geckolib/glue.rs"], "git_node": null, "git_parents": [null], "node": "95b1c86a8b55c8ef5b3c955a3ab592e3c658f3fa", "parents": ["4f50305f72aba391db457322d078d4908221e20e"], "tags": []}, {"author": "tiago \u003ctiago.paez11@gmail.com\u003e", "branch": "default", "desc": "Bug 948882 - Move inline scripts and styles into separate file for toolkit/crashreporter/content/crashes.xhtml (about:crashes). r=freddyb,gijs\n\nMozReview-Commit-ID: AdM1JIOaRIx", "files": ["toolkit/crashreporter/content/crashes.css", "toolkit/crashreporter/content/crashes.js", "toolkit/crashreporter/content/crashes.xhtml", "toolkit/crashreporter/jar.mn"], "git_node": null, "git_parents": [null], "node": "75df8c6facf7eda425d18b8053dc4c2eb9ed3ec7", "parents": ["95b1c86a8b55c8ef5b3c955a3ab592e3c658f3fa"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1465360 - add asm.js-apps shell benchmark to jsshell-bench. r=ahal", "files": ["taskcluster/ci/source-test/jsshell.yml", "testing/jsshell/benchmark.py", "third_party/webkit/PerformanceTests/asmjs-apps/README_MOZILLA", "third_party/webkit/PerformanceTests/asmjs-apps/VERSION", "third_party/webkit/PerformanceTests/asmjs-apps/box2d.js", "third_party/webkit/PerformanceTests/asmjs-apps/bullet.js", "third_party/webkit/PerformanceTests/asmjs-apps/harness.py", "third_party/webkit/PerformanceTests/asmjs-apps/harness.sh", "third_party/webkit/PerformanceTests/asmjs-apps/lua_binarytrees.js", "third_party/webkit/PerformanceTests/asmjs-apps/run.js", "third_party/webkit/PerformanceTests/asmjs-apps/zlib.js"], "git_node": null, "git_parents": [null], "node": "010e2e111043912594c52f7c268f746818e0f99f", "parents": ["75df8c6facf7eda425d18b8053dc4c2eb9ed3ec7"], "tags": []}, {"author": "Nicolas Silva \u003cnsilva@mozilla.com\u003e", "branch": "default", "desc": "Bug 1464039 - Only reject qcms transform with invalid grid size if the transform function uses the grid size. r=Bas", "files": ["gfx/qcms/chain.c", "gfx/thebes/gfxPlatform.cpp"], "git_node": null, "git_parents": [null], "node": "8dde5c1d895e4c063d5bda39029c9a01a178ebba", "parents": ["010e2e111043912594c52f7c268f746818e0f99f"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1467381 - check Accessible::AccessKey and Accessible::KeyboardShortcut when filling up keyboardShortcut for accessible actor. r=pbro\n\nMozReview-Commit-ID: IkqfyL5cGGh\n", "files": ["devtools/server/actors/accessibility.js", "devtools/server/tests/browser/browser_accessibility_node.js", "devtools/server/tests/browser/browser_accessibility_node_events.js", "devtools/server/tests/browser/doc_accessibility.html"], "git_node": null, "git_parents": [null], "node": "45a968a577b741e70c5122e3ee118352a754425f", "parents": ["8dde5c1d895e4c063d5bda39029c9a01a178ebba"], "tags": []}, {"author": "Richard Pospesel \u003crichard@torproject.org\u003e", "branch": "default", "desc": "Bug 859782 - Firefox cannot start without /proc (chroot). r=sfink,evilpie,jld\n\nFirefox uses the current stack frame address and the stack size\nas a sort of heuristic for various things in the javascript\nengine.  The js::GetNativeStackBaseImpl() function is used to\nget the base stack address (ie the address from which the stack\ngrows, so this can be either the first or last memory address of\nthe stack memory space depending on the CPU architecture).\n\nOn Linux, this function is implemented using the pthreads APIs.\nFor non-main threads, the queried thread info is stored in\nmemory.  The main thread does not have this information on hand,\nso it gets the stack memory range via the /proc/self/maps file\n( see glibc's pthread_get_attr_np.c ).\n\nFortunately (per discussions with the firefox devs in #jsapi)\nthe base address only needs to be approximation.  In reality,\nenvironment variables, args, and other things are stored in space\nbetween the end/beginning of the mapped stack memory and the 'top'\nof the stack space used by stack frames.\n\nWe can get the top of this usable stack from __libc_stack_end,\nwhich is a void* set by glibc during program initialization.\nNon-main threads still get their stack-base through the usual\npthreads APIs.", "files": ["js/src/util/NativeStack.cpp"], "git_node": null, "git_parents": [null], "node": "e8d4a24e47a943db327206a4680fb75c156f9086", "parents": ["45a968a577b741e70c5122e3ee118352a754425f"], "tags": []}, {"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 1465649 - Update 3-pane mode's sidebar buttons. r=pbro", "files": ["devtools/client/jar.mn", "devtools/client/themes/images/close-3-pane.svg", "devtools/client/themes/images/open-3-pane.svg", "devtools/client/themes/inspector.css"], "git_node": null, "git_parents": [null], "node": "72bd48d00704bf1c1d30cc945898b57d73081511", "parents": ["e8d4a24e47a943db327206a4680fb75c156f9086"], "tags": []}, {"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 1468495 - Reset the inspector widths for the first run of 3 pane inspector. r=pbro", "files": ["devtools/client/inspector/inspector.js", "devtools/client/preferences/devtools-client.js"], "git_node": null, "git_parents": [null], "node": "130fd3919bd9ebf17c2c1c244aaeec5da183564c", "parents": ["72bd48d00704bf1c1d30cc945898b57d73081511"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1467643 - remove 'help' accessibility property from accessibility inspector. r=pbro\n\nMozReview-Commit-ID: LtmD38VC8sN\n", "files": ["devtools/client/accessibility/constants.js", "devtools/client/accessibility/test/browser/browser.ini", "devtools/client/accessibility/test/browser/browser_accessibility_mutations.js", "devtools/client/accessibility/test/browser/browser_accessibility_sidebar.js", "devtools/client/accessibility/test/browser/browser_accessibility_tree_nagivation.js", "devtools/server/actors/accessibility.js", "devtools/server/tests/browser/browser_accessibility_node.js", "devtools/server/tests/browser/browser_accessibility_node_events.js", "devtools/shared/fronts/accessibility.js", "devtools/shared/specs/accessibility.js"], "git_node": null, "git_parents": [null], "node": "5d7ff9efd67fb15ec6ce70e8e49f37fd57061a87", "parents": ["130fd3919bd9ebf17c2c1c244aaeec5da183564c"], "tags": []}, {"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 1468768 - Part 1: Move UserProperties into its own file. r=pbro", "files": ["devtools/client/inspector/rules/models/element-style.js", "devtools/client/inspector/rules/models/moz.build", "devtools/client/inspector/rules/models/user-properties.js"], "git_node": null, "git_parents": [null], "node": "d8e055e56c9bfacd362b7f0c78358f010f5307ed", "parents": ["5d7ff9efd67fb15ec6ce70e8e49f37fd57061a87"], "tags": []}, {"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 1468768 - Part 2: Format the code in ElementStyle. r=pbro", "files": ["devtools/client/inspector/rules/models/element-style.js"], "git_node": null, "git_parents": [null], "node": "c86e60a88b37921d2a98d57dab7d5ea281e39351", "parents": ["d8e055e56c9bfacd362b7f0c78358f010f5307ed"], "tags": []}, {"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 1468768 - Part 3: Clean up the code in ElementStyle. r=pbro", "files": ["devtools/client/inspector/rules/models/element-style.js"], "git_node": null, "git_parents": [null], "node": "2d5727bbe035f34e4044878e2870520291286156", "parents": ["c86e60a88b37921d2a98d57dab7d5ea281e39351"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-inbound to mozilla-central. a=merge", "files": ["js/src/gc/GC.cpp", "js/src/gc/GCRuntime.h", "js/src/jsfriendapi.cpp", "js/src/vm/Runtime.cpp", "js/src/vm/Runtime.h"], "git_node": null, "git_parents": [null, null], "node": "e429320fcdd2d5236bb4713e6c435456146e42b9", "parents": ["33c34fbb0b0d7e890c1985c3ba896dd1a238dd1d", "2d5727bbe035f34e4044878e2870520291286156"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland", "files": ["devtools/client/inspector/rules/models/user-properties.js"], "git_node": null, "git_parents": [null, null], "node": "b994e5f56361c407feabf5f336bc34fbb8bface2", "parents": ["bad278043bc9ae7b0570bbec9c59d2578401becf", "e429320fcdd2d5236bb4713e6c435456146e42b9"], "tags": []}, {"author": "Mike Shal \u003cmshal@mozilla.com\u003e", "branch": "default", "desc": "Bug 1469712 - Don't update mtime for backend file during --dry-run; r=gps\n\nWhen we do a './mach build-backend --dry-run', no files in the objdir\nshould be written or touched. Updating the mtime of the backend file\nduring dry-run causes a future './mach build' to think that the backend\nis up-to-date when it is not, which causes an incorrect build.\n\nMozReview-Commit-ID: 2NA0rcSGrvL", "files": ["python/mozbuild/mozbuild/backend/base.py"], "git_node": null, "git_parents": [null], "node": "4f001c506ff8ba7ec562a0576107496c9eeaddeb", "parents": ["b994e5f56361c407feabf5f336bc34fbb8bface2"], "tags": []}, {"author": "prathiksha \u003cprathikshaprasadsuman@gmail.com\u003e", "branch": "default", "desc": "Bug 1462461 - Show the back button in the basic card page during on-boarding. r=MattN\n\nMozReview-Commit-ID: 7Vxgp2vkKKN", "files": ["browser/components/payments/res/containers/basic-card-form.js", "browser/components/payments/test/browser/browser_payments_onboarding_wizard.js"], "git_node": null, "git_parents": [null], "node": "d76b9bf7d97cb19153b6cd8d7acfeb401ffe7a89", "parents": ["4f001c506ff8ba7ec562a0576107496c9eeaddeb"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset bad278043bc9 (bug 1467549) for build bustage on asan builds. CLOSED TREE", "files": ["toolkit/components/backgroundhangmonitor/moz.build"], "git_node": null, "git_parents": [null], "node": "508f1ee4b3326e52b2b03fd63fc594ef3c92b23a", "parents": ["d76b9bf7d97cb19153b6cd8d7acfeb401ffe7a89"], "tags": []}, {"author": "Harry Twyford \u003chtwyford@mozilla.com\u003e", "branch": "default", "desc": "Bug 1460097 - Autocompleted URLs are trimmed. r=mak\n\nMozReview-Commit-ID: 6y26a9Nhm3b", "files": ["browser/base/content/test/urlbar/browser_pasteAndGo.js", "browser/base/content/urlbarBindings.xml", "toolkit/components/places/UnifiedComplete.js", "toolkit/components/places/tests/unifiedcomplete/test_visit_url.js"], "git_node": null, "git_parents": [null], "node": "9d105e4b00bee0ba8f9328fa0c4eef005163eb63", "parents": ["508f1ee4b3326e52b2b03fd63fc594ef3c92b23a"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1466910 - 1. Forward more InputContext members through e10s; r=masayuki\n\nSome InputContext members are not forwarded through\nPBrowser::SetInputContext.\n\nMozReview-Commit-ID: C1bGYq4w8zT", "files": ["dom/ipc/PBrowser.ipdl", "dom/ipc/TabParent.cpp", "dom/ipc/TabParent.h", "widget/PuppetWidget.cpp", "widget/nsGUIEventIPC.h"], "git_node": null, "git_parents": [null], "node": "13fe429f97b1771a0d66b5d31bf147244293737b", "parents": ["9d105e4b00bee0ba8f9328fa0c4eef005163eb63"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1466910 - 2. Allow @AssertCalled(count = 0) in waitUntilCalled; r=jchen\n\nAllow some methods to be annotated with @AssertCalled(count = 0) for the\nobject passed to waitUntilCalled.\n\nMozReview-Commit-ID: 1pqpQV3OyKS", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/GeckoSessionTestRuleTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/rule/GeckoSessionTestRule.java"], "git_node": null, "git_parents": [null], "node": "8ba06e49a4bac382725c28fb7684dcaa8fdfc2a7", "parents": ["13fe429f97b1771a0d66b5d31bf147244293737b"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1466910 - 3. Add TextInputDelegateTest; r=esawin\n\nAdd a test for TextInputDelegate to ensure restartInput / showSoftInput\n/ hideSoftInput are called.\n\nMozReview-Commit-ID: K7CPgL7STGm", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/TextInputDelegateTest.kt"], "git_node": null, "git_parents": [null], "node": "2fa2e8bb83b61e6a6a777c4c65fbb02e2d4d20d6", "parents": ["8ba06e49a4bac382725c28fb7684dcaa8fdfc2a7"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1466910 - 4. Don't notify of blur unnecessarily; r=esawin\n\nRight now we always notify Java of input blur. However, when input is\nrapidly blurred and then focused again, we don't want to generate the\nunnecessary blur notification, in order to avoid unwanted effects such\nas the keyboard flashing.\n\nMozReview-Commit-ID: AL6aLAHqNpD", "files": ["widget/android/GeckoEditableSupport.cpp", "widget/android/GeckoEditableSupport.h"], "git_node": null, "git_parents": [null], "node": "ead6b1470d36ad284f4e750fef186556116ad54c", "parents": ["2fa2e8bb83b61e6a6a777c4c65fbb02e2d4d20d6"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1466910 - 5. Correctly handle focus/blur ordering issues; r=esawin\n\n* Move restartInput(blur) call from notifyIMEContext to notifyIME, so we\ndon't make the call unnecessarily.\n\n* Correctly handle when notifyIMEContext(enabled) is called _after_\nnotifyIME(focus), by having notifyIMEContext call restartInput(focus) if\nnecessary.\n\nMozReview-Commit-ID: 4jJlmhOws8", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoEditable.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/SessionTextInput.java"], "git_node": null, "git_parents": [null], "node": "6d64d1e37db5078cd6fb90af3cbd482b11a794f6", "parents": ["ead6b1470d36ad284f4e750fef186556116ad54c"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1466910 - 6. Fix logging code; r=jchen\n\nMozReview-Commit-ID: KciGTPzrkkG", "files": ["widget/android/GeckoEditableSupport.cpp"], "git_node": null, "git_parents": [null], "node": "38bdc7128df6f44334a9776704fc90b7b150c64e", "parents": ["6d64d1e37db5078cd6fb90af3cbd482b11a794f6"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1466910 - 7. Don't coalesce notifyIMEContext calls; r=esawin\n\nRight now we coalesce notifyIMEContext calls but only for legacy\nreasons. With the current code we don't want to coalesce calls, in order\nto be properly notified of blurring and focusing.\n\nMozReview-Commit-ID: 6N2jhyyBKui", "files": ["widget/android/GeckoEditableSupport.cpp", "widget/android/GeckoEditableSupport.h"], "git_node": null, "git_parents": [null], "node": "32673fc26bafde64ae44439ec13b566a9e9db234", "parents": ["38bdc7128df6f44334a9776704fc90b7b150c64e"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1466910 - 8. Use \"content-document-global-created\" to attach GeckoEditableSupport; r=esawin\n\nRight now we use the \"tab-child-created\" notification to attach\nGeckoEditableSupport to a PuppetWidget in the child process. However,\n\"tab-child-created\" is not fired for all instances of PuppetWidget\ncreation, and attaching GeckoEditableSupport at this stage can also\ncause race conditions.\n\nThis patch makes us listen to \"content-document-global-created\" instead,\nbut attach GeckoEditableSupport to the PuppetWidget the same way.\n\nMozReview-Commit-ID: 8IAtzuvlK4K", "files": ["widget/android/nsAppShell.cpp"], "git_node": null, "git_parents": [null], "node": "bc1d1bee80846966bbf97a10f6fdb17f22278c97", "parents": ["32673fc26bafde64ae44439ec13b566a9e9db234"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1464351 - Look for initial about:blank load for cached session; r=esawin\n\nWe can get multiple initial loads for the cached session, so we must\nspecifically look for an about:blank load to wait on.\n\nMozReview-Commit-ID: 6RxEmiSF2ti", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/rule/GeckoSessionTestRule.java"], "git_node": null, "git_parents": [null], "node": "359b40c7c26875d3bd47445e1dcf3132fbda99bd", "parents": ["bc1d1bee80846966bbf97a10f6fdb17f22278c97"], "tags": []}, {"author": "Micah Tigley \u003cmtigley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1450930 - The Page Down/Up keys doesn't work after pressing Home/End keys. r=Honza,yzen", "files": ["devtools/client/shared/components/tree/TreeView.js"], "git_node": null, "git_parents": [null], "node": "40b467f3830618e185c0e6d6f857b07f345b62ef", "parents": ["359b40c7c26875d3bd47445e1dcf3132fbda99bd"], "tags": []}, {"author": "Myk Melez \u003cmyk@mykzilla.org\u003e", "branch": "default", "desc": "Bug 1467307 - whitelist BSD-2-Clause license for Rust crates, r=gps\n\nMozReview-Commit-ID: HVOlQlfley1", "files": ["python/mozbuild/mozbuild/vendor_rust.py"], "git_node": null, "git_parents": [null], "node": "b295397ebb08320fbe518f0e28dddd48061c53e0", "parents": ["40b467f3830618e185c0e6d6f857b07f345b62ef"], "tags": []}, {"author": "J. Ryan Stinnett \u003cjryans@gmail.com\u003e", "branch": "default", "desc": "Bug 1466534 - Centralize DevTools link handling. r=jdescottes\n\nThis adds a `openContentLink` helper meant for any link controlled by web\ncontent.  If there is an associated toolbox open, the toolbox's tab is used to\nsupply a triggering principal for the link.\n\nMozReview-Commit-ID: 45l5yAPGpZr", "files": ["devtools/client/accessibility/components/Accessible.js", "devtools/client/accessibility/test/mochitest/test_accessible_openLink.html", "devtools/client/application/src/components/WorkerListEmpty.js", "devtools/client/debugger/content/views/sources-view.js", "devtools/client/debugger/new/panel.js", "devtools/client/dom/dom-panel.js", "devtools/client/framework/components/ToolboxToolbar.js", "devtools/client/framework/target.js", "devtools/client/inspector/computed/computed.js", "devtools/client/inspector/inspector.js", "devtools/client/inspector/rules/views/text-property-editor.js", "devtools/client/inspector/shared/three-pane-onboarding-tooltip.js", "devtools/client/menus.js", "devtools/client/netmonitor/src/utils/open-request-in-tab.js", "devtools/client/performance-new/components/Description.js", "devtools/client/scratchpad/scratchpad.js", "devtools/client/shared/components/MdnLink.js", "devtools/client/shared/link.js", "devtools/client/shared/test/browser_link.js", "devtools/client/styleeditor/StyleEditorUI.jsm", "devtools/client/styleeditor/test/browser_styleeditor_opentab.js", "devtools/client/webconsole/hudservice.js", "devtools/client/webconsole/test/mochitest/browser_webconsole_allow_mixedcontent_securityerrors.js", "devtools/client/webconsole/test/mochitest/browser_webconsole_network_messages_status_code.js", "devtools/client/webconsole/test/mochitest/head.js", "devtools/client/webconsole/utils/context-menu.js", "devtools/client/webide/content/webide.js", "devtools/shared/gcli/commands/screenshot.js"], "git_node": null, "git_parents": [null], "node": "fc6c078e39d968c819341ffcbcfaa54f2d9a8d16", "parents": ["b295397ebb08320fbe518f0e28dddd48061c53e0"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset d76b9bf7d97c (bug 1462461) for 