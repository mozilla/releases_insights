ctivity-stream-strings.js", "browser/extensions/activity-stream/prerendered/locales/sr/activity-stream-strings.js", "browser/extensions/activity-stream/prerendered/locales/sv-SE/activity-stream-strings.js", "browser/extensions/activity-stream/prerendered/locales/ta/activity-stream-strings.js", "browser/extensions/activity-stream/prerendered/locales/te/activity-stream-strings.js", "browser/extensions/activity-stream/prerendered/locales/tl/activity-stream-strings.js", "browser/extensions/activity-stream/prerendered/locales/tr/activity-stream-strings.js", "browser/extensions/activity-stream/prerendered/locales/uk/activity-stream-strings.js", "browser/extensions/activity-stream/prerendered/locales/ur/activity-stream-strings.js", "browser/extensions/activity-stream/prerendered/locales/vi/activity-stream-strings.js", "browser/extensions/activity-stream/prerendered/locales/zh-CN/activity-stream-strings.js", "browser/extensions/activity-stream/prerendered/locales/zh-TW/activity-stream-strings.js"], "git_node": null, "git_parents": [null], "node": "4a9fed27bebf2159ab68ee312164f3862a69a4af", "parents": ["1a80ac4f1ab7464dc0d2eeeeaba11ba37bf0aca0"], "tags": []}, {"author": "Timothy Guan-tin Chien \u003ctimdream@gmail.com\u003e", "branch": "default", "desc": "Bug 1474574 - Ensure \u003cvideo\u003e is the only focusable element in TopLevelVideoDocument. r=Gijs, a=lizzard\n\nInstead of re-dispatch an untrusted event, simply make sure the keyboard event is handled\nby the video controls.\n\nMozReview-Commit-ID: 9Kj7E3UP77w", "files": ["layout/style/TopLevelVideoDocument.css", "toolkit/content/TopLevelVideoDocument.js"], "git_node": null, "git_parents": [null], "node": "e6f2a719979c62b226b0ef54818f5c6280a49f1c", "parents": ["4a9fed27bebf2159ab68ee312164f3862a69a4af"], "tags": []}, {"author": "Eugen Sawin \u003cesawin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1476689 - [1.1] Use GeckoResult in runtime telemetry API. r=droeh, r=jchen, a=lizzard", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/geckoview/RuntimeTelemetry.java"], "git_node": null, "git_parents": [null], "node": "d2a0c97079f6cbad4c09f7026260098a54b33062", "parents": ["e6f2a719979c62b226b0ef54818f5c6280a49f1c"], "tags": []}, {"author": "Eugen Sawin \u003cesawin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1476689 - [2.2] Add basic runtime telemetry test. r=jchen, a=lizzard", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/NavigationDelegateTest.kt"], "git_node": null, "git_parents": [null], "node": "d7b23492ad24997e502fd0016cd51e37293db002", "parents": ["d2a0c97079f6cbad4c09f7026260098a54b33062"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1477199 - Show keyboard highlights in all tabs menu after bad rebase. r=dao, a=lizzard\n\nMozReview-Commit-ID: OySLmFFw2j", "files": ["browser/themes/shared/tabs.inc.css"], "git_node": null, "git_parents": [null], "node": "32b73599ce1516d3f808b1082a59cab3b962458d", "parents": ["d7b23492ad24997e502fd0016cd51e37293db002"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1468645 - Set active menu bar item color to -moz-menuhovertext instead of -moz-menubarhovertext since we've not using -moz-appearance:menuitem anymore. r=Felipe, a=lizzard\n\nMozReview-Commit-ID: EaVa7MJVXD3", "files": ["browser/themes/windows/browser.css"], "git_node": null, "git_parents": [null], "node": "34af42d33444e30c9f616e159cae7d2cd71eeffa", "parents": ["32b73599ce1516d3f808b1082a59cab3b962458d"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1461307 - Overwrite selection colors of widget which may be referred by IME via IM context with selection colors of GtkTextView. r=karlt, a=lizzard\n\nIME (e.g., fcitx) may refer selection colors of widget under window which\nis associated with IM context to support any colored widget.  So, IME\nexpects good selection colors which have sufficient contrast between\nforeground and background, and also selection background color and\nwidget background color like GtkTextView.  However, some desktop themes\nset our widget to different selection colors from GtkTextView which may\nbe unreadable.\n\nnsTextFrame (which paints composition string) expects that composition\nstring colors coming from IME are sufficiently readable and background\ncolor of composition string and background color of our editor's default\nstyle (coming from LookAndFeel) have sufficient contrast because\nnsTextFrame assmes that composition string colors coming from IME are\ndecided for the default style.\n\nTherefore, this patch creates SelectionStyleProvider which overwrites\nselection style of our widget with selection style of GtkTextView so\nthat IME can refer selection colors of GtkTextView via our widget.\n\nMozReview-Commit-ID: 5vdcSgoEYv0", "files": ["widget/gtk/IMContextWrapper.cpp", "widget/gtk/IMContextWrapper.h", "widget/gtk/mozgtk/mozgtk.c", "widget/gtk/nsWidgetFactory.cpp", "widget/gtk/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "8e02ffa9353b7c2ce3bb43bf97f2cf269b3fbe5c", "parents": ["34af42d33444e30c9f616e159cae7d2cd71eeffa"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1476991 - Move selected tab indicator to right side in RTL. r=dao, a=lizzard\n\nMozReview-Commit-ID: 33EfbEXeCQg", "files": ["browser/themes/shared/tabs.inc.css"], "git_node": null, "git_parents": [null], "node": "33c02e487f58709e85e1ef53824cd145fd043a40", "parents": ["8e02ffa9353b7c2ce3bb43bf97f2cf269b3fbe5c"], "tags": []}], "date": 1533692491, "git_changesets": [null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9619": {"changesets": [{"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1476239 - Make MarkStack code more robust and add assertions. r=sfink, a=lizzard", "files": ["js/src/gc/GCMarker.h", "js/src/gc/Marking.cpp", "js/src/jsutil.h"], "git_node": null, "git_parents": [null], "node": "bc83bb0212b344803ac00c416052b2520709f7f9", "parents": ["33c02e487f58709e85e1ef53824cd145fd043a40"], "tags": []}, {"author": "Nicolas Silva \u003cnsilva@mozilla.com\u003e", "branch": "default", "desc": "Bug 1474722 - Prevent large rect integer overflows without forbidding large nine-patches. r=Bas, a=lizzard", "files": ["gfx/2d/Rect.h", "gfx/thebes/gfxBlur.cpp"], "git_node": null, "git_parents": [null], "node": "218d36910b9231648062034b52f49e1e4af43388", "parents": ["bc83bb0212b344803ac00c416052b2520709f7f9"], "tags": []}, {"author": "Nicolas Silva \u003cnsilva@mozilla.com\u003e", "branch": "default", "desc": "Bug 1474722 - Add a reftest. r=Bas, a=lizzard", "files": ["gfx/tests/reftest/1474722-ref.html", "gfx/tests/reftest/1474722.html", "gfx/tests/reftest/reftest.list"], "git_node": null, "git_parents": [null], "node": "bbf140a25c62f36eb0bca2c13a65bd9ce21a0110", "parents": ["218d36910b9231648062034b52f49e1e4af43388"], "tags": []}, {"author": "Chris H-C \u003cchutten@mozilla.com\u003e", "branch": "default", "desc": "Bug 1479026 - Adjust mobile-metrics structure to match schema. r=janerik, a=lizzard\n\nMozReview-Commit-ID: BvPO0IDcoSl", "files": ["toolkit/components/telemetry/geckoview/GeckoViewTelemetryController.jsm"], "git_node": null, "git_parents": [null], "node": "2f58ed9bd8c13cb99937dd951c80990e2d6d0e01", "parents": ["bbf140a25c62f36eb0bca2c13a65bd9ce21a0110"], "tags": []}, {"author": "Eugen Sawin \u003cesawin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1479026 - Adjust GeckoView telemetry API tests to match corrected schema. r=janerik, r=jchen, a=lizzard", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/NavigationDelegateTest.kt"], "git_node": null, "git_parents": [null], "node": "d3a8b368ded7b6da0eb597c18d41bef86c23ee1a", "parents": ["2f58ed9bd8c13cb99937dd951c80990e2d6d0e01"], "tags": []}], "date": 1533693478, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9620": {"changesets": [{"author": "Csoregi Natalia \u003cncsoregi@mozilla.com\u003e", "branch": "default", "desc": "Backed out 2 changesets (bug 1479026) for NavigationDelegateTest failures. a=backout\n\nBacked out changeset d3a8b368ded7 (bug 1479026)\nBacked out changeset 2f58ed9bd8c1 (bug 1479026)", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/NavigationDelegateTest.kt", "toolkit/components/telemetry/geckoview/GeckoViewTelemetryController.jsm"], "git_node": null, "git_parents": [null], "node": "2d3a55472637ec5252d9be828991709f07ac4664", "parents": ["d3a8b368ded7b6da0eb597c18d41bef86c23ee1a"], "tags": []}, {"author": "Csoregi Natalia \u003cncsoregi@mozilla.com\u003e", "branch": "default", "desc": "Backed out 2 changesets (bug 1474722) for reftest failures on gfx/tests/reftest/1461313.html. a=backout\n\nBacked out changeset bbf140a25c62 (bug 1474722)\nBacked out changeset 218d36910b92 (bug 1474722)", "files": ["gfx/2d/Rect.h", "gfx/tests/reftest/1474722-ref.html", "gfx/tests/reftest/1474722.html", "gfx/tests/reftest/reftest.list", "gfx/thebes/gfxBlur.cpp"], "git_node": null, "git_parents": [null], "node": "b9a609c0b055c4ef687164d15b5a5b2f1b6dc59c", "parents": ["2d3a55472637ec5252d9be828991709f07ac4664"], "tags": []}], "date": 1533714590, "git_changesets": [null, null], "user": "ncsoregi@mozilla.com"}, "9621": {"changesets": [{"author": "Nicolas Silva \u003cnsilva@mozilla.com\u003e", "branch": "default", "desc": "Bug 1474722 - Prevent large rect integer overflows without forbidding large nine-patches. r=Bas, a=lizzard", "files": ["gfx/2d/Rect.h", "gfx/thebes/gfxBlur.cpp"], "git_node": null, "git_parents": [null], "node": "c5ba7c0202f22f88b59855bc8a805f821e81fc78", "parents": ["b9a609c0b055c4ef687164d15b5a5b2f1b6dc59c"], "tags": []}, {"author": "Nicolas Silva \u003cnsilva@mozilla.com\u003e", "branch": "default", "desc": "Bug 1474722 - Add a reftest. r=Bas, a=lizzard", "files": ["gfx/tests/reftest/1474722-ref.html", "gfx/tests/reftest/1474722.html", "gfx/tests/reftest/reftest.list"], "git_node": null, "git_parents": [null], "node": "c4abffd0c2c0479cf9cabd42e14b923aa0f99b3b", "parents": ["c5ba7c0202f22f88b59855bc8a805f821e81fc78"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1469875 - Make nsPluginInstanceOwner::RequestCommitOrCancel() call IMEStateManager::NotifyIME() rather than calling nsIWidget::NotifyIME(). r=m_kato, a=jcristau\n\nAny content code except TextComposition shouldn't call nsIWidget::NotifyIM()\nsince IMEStateManager and TextComposition manage state of the composition.\nTherefore, we need to make nsPluginInstanceOwner::RequestCommitOrCancel()\ncall IMEStateManager::NotifyIME() instead.\n\nAdditionally, this method should ignore the request if composition has\nalready been gone.  This patch makes check whether there is a TextComposition\ninstance for the widget and the composition is handled in the plugin owner\nelement.\n\nMozReview-Commit-ID: 5cx5X2hGfek", "files": ["dom/plugins/base/nsPluginInstanceOwner.cpp"], "git_node": null, "git_parents": [null], "node": "242c40439f4dfe64c70bd9a4e5551490506377aa", "parents": ["c4abffd0c2c0479cf9cabd42e14b923aa0f99b3b"], "tags": []}, {"author": "David Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "Bug 1475775 - Clean up old NSS DB file after upgrade if necessary. r=franziskus, r=mattn, a=jcristau\n\nReviewers: franziskus, mattn\n\nBug #: 1475775\n\nDifferential Revision: https://phabricator.services.mozilla.com/D2202", "files": ["security/manager/ssl/nsNSSComponent.cpp", "security/manager/ssl/tests/unit/test_sdr_upgraded_with_password.js", "security/manager/ssl/tests/unit/test_sdr_upgraded_with_password/cert8.db", "security/manager/ssl/tests/unit/test_sdr_upgraded_with_password/cert9.db", "security/manager/ssl/tests/unit/test_sdr_upgraded_with_password/key3.db", "security/manager/ssl/tests/unit/test_sdr_upgraded_with_password/key4.db", "security/manager/ssl/tests/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "1e05e8939a189df7b3d8309ad7936079ec012057", "parents": ["242c40439f4dfe64c70bd9a4e5551490506377aa"], "tags": []}], "date": 1533730293, "git_changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "9622": {"changesets": [{"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1476317 - Fix identity popup display for pages with exceptions that have blocked content. r=nhnt11, a=jcristau\n\nThe identity popup will now show that there's an exception on the site instead of being confused.\n\nWe previously didn't handle this state because I assumed it wouldn't be possible to enter.\nTurns out if you open the same (tracking) site in two tabs and then add an exception in one tab,\nthe other tab will be in this state until reload.\n\nMozReview-Commit-ID: GVVdNpsAm6h", "files": ["browser/base/content/browser-trackingprotection.js", "browser/base/content/test/trackingUI/browser_trackingUI_state.js", "browser/themes/shared/controlcenter/panel.inc.css", "browser/themes/shared/identity-block/identity-block.inc.css"], "git_node": null, "git_parents": [null], "node": "68612f2591b72284db0024a56b82696d2d65ef30", "parents": ["1e05e8939a189df7b3d8309ad7936079ec012057"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "Bug 1476872 - Inform the microtask arch that we're shutting down. r=asuth, a=jcristau\n\nThis should hopefully prevent races where we run promise handlers during\nworker shutdown, when we're canceling regular events anyway.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D2376", "files": ["dom/workers/WorkerScope.cpp"], "git_node": null, "git_parents": [null], "node": "603f5f026cf4f983f618406b291acf26dae743da", "parents": ["68612f2591b72284db0024a56b82696d2d65ef30"], "tags": []}, {"author": "Brad Werth \u003cbwerth@mozilla.com\u003e", "branch": "default", "desc": "Bug 1479627 - Set overflow:hidden for webconsole message-body style, to avoid a slow path in restyling. r=nchevobbe, a=jcristau\n\nMozReview-Commit-ID: ImKq594IB7P", "files": ["devtools/client/themes/webconsole.css"], "git_node": null, "git_parents": [null], "node": "708dd36ae354550076f56695764af5264c6938e8", "parents": ["603f5f026cf4f983f618406b291acf26dae743da"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1478604 - Fix RepaintSelectionRunner so that it does something for non-presShell impls. r=masayuki, a=jcristau\n\nThe regressing bug made RepaintSelectionRunner do nothing for any\nnsISelectionListener that wasn't a PresShell.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D2846", "files": ["editor/libeditor/EditorBase.cpp", "layout/base/PresShell.cpp", "layout/reftests/selection/1478604-ref.html", "layout/reftests/selection/1478604.html", "layout/reftests/selection/reftest.list"], "git_node": null, "git_parents": [null], "node": "7addc88e15b1e4abedddbbd2fd4fde9de5d4c637", "parents": ["708dd36ae354550076f56695764af5264c6938e8"], "tags": []}], "date": 1533746881, "git_changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "9623": {"changesets": [{"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1467695 - Wait for async disable operations to finish when calling addonChanged listeners. r=aswan, a=lizzard\n\nMozReview-Commit-ID: 1vsevE8IgYU", "files": ["browser/base/content/test/general/browser_compacttheme.js", "browser/components/customizableui/test/browser_1007336_lwthemes_in_customize_mode.js", "toolkit/mozapps/extensions/AddonManager.jsm", "toolkit/mozapps/extensions/internal/XPIDatabase.jsm", "toolkit/mozapps/extensions/test/browser/browser_list.js", "toolkit/mozapps/extensions/test/xpcshell/test_LightweightThemeManager.js", "toolkit/mozapps/extensions/test/xpcshell/test_shutdown.js", "toolkit/mozapps/extensions/test/xpcshell/test_webextension_theme.js"], "git_node": null, "git_parents": [null], "node": "0fc394c4200944c32d4ee096010c16258d4399f8", "parents": ["7addc88e15b1e4abedddbbd2fd4fde9de5d4c637"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1462299 - input[date] unusable on Android 4.x. r=jchen, a=lizzard\n\nThe issue stemmed from platform's DatePicker.\nTo make amends and fix both this bug and Bug 1460585 I went with\nhiding the calendar and showing only the spinners for Api \u003c21.\n\nMozReview-Commit-ID: CS9pFdlMSTd", "files": ["mobile/android/base/java/org/mozilla/gecko/prompts/PromptInput.java"], "git_node": null, "git_parents": [null], "node": "7480f990a1045fa8a9975d02debbb2df8339d943", "parents": ["0fc394c4200944c32d4ee096010c16258d4399f8"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1460074 - Still cannot switch between years in date picker. r=jchen, a=lizzard\n\nThe problem stemmed from having the DatePicker inside a ScrollView which\nwas receiving the swipe events.\nTo avoid this I've created the new FocusableDatePicker which has the ability\nto prevent it's parent from receiving touch events.\n\nMozReview-Commit-ID: 6VntjE5A0ec", "files": ["mobile/android/base/java/org/mozilla/gecko/prompts/PromptInput.java", "mobile/android/base/java/org/mozilla/gecko/widget/FocusableDatePicker.java"], "git_node": null, "git_parents": [null], "node": "6eea74660c1c42b43bb4ee8fd20204c043455eea", "parents": ["7480f990a1045fa8a9975d02debbb2df8339d943"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1474925 - TimePicker swipe not possible in landscape. r=jchen, a=lizzard\n\nMozReview-Commit-ID: DVp6d40OLE3", "files": ["mobile/android/base/java/org/mozilla/gecko/prompts/PromptInput.java", "mobile/android/base/java/org/mozilla/gecko/widget/FocusableTimePicker.java"], "git_node": null, "git_parents": [null], "node": "f3146c971a5fec66acb4313b6ea0afab37fcc75d", "parents": ["6eea74660c1c42b43bb4ee8fd20204c043455eea"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1477234 - WeekPicker starts with incorrect values. r=jchen, a=lizzard\n\nMozReview-Commit-ID: AKXF2e7ktpN", "files": ["mobile/android/base/java/org/mozilla/gecko/widget/DateTimePicker.java"], "git_node": null, "git_parents": [null], "node": "c24f8bc9d8f5de4ceafef698af1d2a627960bcab", "parents": ["f3146c971a5fec66acb4313b6ea0afab37fcc75d"], "tags": []}, {"author": "Byron Campen [:bwc] \u003cdocfaraday@gmail.com\u003e", "branch": "default", "desc": "Bug 1472321 - Make sure sink identity is set on recvonly/inactive transceivers. r=drno, r=mjf, a=lizzard\n\nMozReview-Commit-ID: jZHsDKN5o6", "files": ["media/webrtc/signaling/src/mediapipeline/MediaPipeline.cpp", "media/webrtc/signaling/src/peerconnection/TransceiverImpl.cpp"], "git_node": null, "git_parents": [null], "node": "b9bf6fef15c756bdd44efc0f6d7f3c99cc591c11", "parents": ["c24f8bc9d8f5de4ceafef698af1d2a627960bcab"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1410218 - Fix NPE when cast fails. r=jchen, a=lizzard\n\nThis happened whenever starting to cast a video and loading the media failed.\nMediaStatus in this case would be null and querying it would throw a\nNullPointerException.\nAvoiding this query when the MediaStatus is null lets the normal execution flow\ncontinue and if loading media failed casting will fail gracefully.\n\nMozReview-Commit-ID: 8ZOqr1FO1Dt", "files": ["mobile/android/base/java/org/mozilla/gecko/ChromeCastPlayer.java"], "git_node": null, "git_parents": [null], "node": "bc58af8e34e6241b613f6f6367eed16ad8113124", "parents": ["b9bf6fef15c756bdd44efc0f6d7f3c99cc591c11"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1475875 - Use ScreenManager on Android. r=esawin, r=jchen, a=lizzard\n\nThis ensures we have screen information with e10s.\n\nMozReview-Commit-ID: 1zghxZuLqr3", "files": ["widget/android/AndroidBridge.cpp", "widget/android/AndroidBridge.h", "widget/android/ScreenHelperAndroid.cpp", "widget/android/ScreenHelperAndroid.h", "widget/android/moz.build", "widget/android/nsAppShell.cpp", "widget/android/nsScreenManagerAndroid.cpp", "widget/android/nsScreenManagerAndroid.h", "widget/android/nsWidgetFactory.cpp", "widget/android/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "7b9c3989046bc01299dab53dd4bea2aff6c17ef1", "parents": ["bc58af8e34e6241b613f6f6367eed16ad8113124"], "tags": []}], "date": 1533759318, "git_changesets": [null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9624": {"changesets": [{"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1412517 - Time picker layout broken when opened in landscape mode. r=jchen, a=lizzard\n\nMozReview-Commit-ID: HKidrZXrgqK", "files": ["mobile/android/base/java/org/mozilla/gecko/prompts/Prompt.java"], "git_node": null, "git_parents": [null], "node": "9ad2ab8a19ab26bc32ce9afe26fca6e4e0c8d86d", "parents": ["7b9c3989046bc01299dab53dd4bea2aff6c17ef1"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1475251 - HTTP auth dialog looks wrong. r=jchen, a=lizzard\n\nSpecialized the code added in Bug 1412517 so that it will apply only for\ndate/time inputs. The rest will have the previous behaviour.\n\nMozReview-Commit-ID: JCAruK4x3r1", "files": ["mobile/android/base/java/org/mozilla/gecko/prompts/Prompt.java", "mobile/android/base/java/org/mozilla/gecko/prompts/PromptInput.java"], "git_node": null, "git_parents": [null], "node": "ea5b02a5d0ef3d58eb457c4606395beeb3e69b53", "parents": ["9ad2ab8a19ab26bc32ce9afe26fca6e4e0c8d86d"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1474888 - Fix Prompt.java's AlertDialog. r=jchen, a=lizzard\n\nPromptService will be informed when the screen is rotated and in turn it will\nask every Prompt shown to reset it's current layout.\nFor this, every Prompt will\n- save it's current input value in PromptInput's mValue or similar field\nalready used for storing the default PromptInput value.\n- create a new widget to be used in the new AlertDialog, with a new appropriate\nlayout for portrait / landscape. This is when the mValue field will be used\nto initialize the new widget with the previous input.\n\nMozReview-Commit-ID: L6eHyGNDt3d", "files": ["mobile/android/base/java/org/mozilla/gecko/GeckoApp.java", "mobile/android/base/java/org/mozilla/gecko/customtabs/CustomTabsActivity.java", "mobile/android/base/java/org/mozilla/gecko/prompts/ColorPickerInput.java", "mobile/android/base/java/org/mozilla/gecko/prompts/IconGridInput.java", "mobile/android/base/java/org/mozilla/gecko/prompts/Prompt.java", "mobile/android/base/java/org/mozilla/gecko/prompts/PromptInput.java", "mobile/android/base/java/org/mozilla/gecko/prompts/PromptService.java", "mobile/android/base/java/org/mozilla/gecko/prompts/TabInput.java", "mobile/android/base/java/org/mozilla/gecko/webapps/WebAppActivity.java"], "git_node": null, "git_parents": [null], "node": "ebf6855161a1b332effbf43e70a7c4b2560579b8", "parents": ["ea5b02a5d0ef3d58eb457c4606395beeb3e69b53"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1412518 - Photon themed TimePicker. r=jchen, a=lizzard\n\nOn Api \u003e=21 the Material TimePicker will have applied a Photon style.\nBelow Api 21 TimePicker will still be using spinners.\n\nMozReview-Commit-ID: 2jZLPGCx4rI", "files": ["mobile/android/app/src/main/res/color/time_picker_header_text_selector.xml", "mobile/android/app/src/main/res/color/time_picker_inner_radial_selector.xml", "mobile/android/app/src/main/res/color/time_picker_radial_selector.xml", "mobile/android/app/src/main/res/values/themes.xml", "mobile/android/app/src/photon/res/values/colors.xml", "mobile/android/app/src/photon/res/values/styles.xml"], "git_node": null, "git_parents": [null], "node": "368a3770259c927708c8f8a7ec4898d2484af368", "parents": ["ebf6855161a1b332effbf43e70a7c4b2560579b8"], "tags": []}, {"author": "Petru Lingurar \u003cpetru.lingurar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1412518 - Photon themed DatePicker. r=jchen, a=lizzard\n\nOn Api \u003e=21 the Material DatePicker will have applied a Photon style.\nBelow Api 21 DatePicker will still be using spinners.\n\nMozReview-Commit-ID: LuWP6C1o4Ej", "files": ["mobile/android/app/src/main/res/color/calendar_view_text_selector.xml", "mobile/android/app/src/main/res/values/themes.xml", "mobile/android/app/src/photon/res/values/styles.xml"], "git_node": null, "git_parents": [null], "node": "16145096886544434502bb35544226d76ccdee1f", "parents": ["368a3770259c927708c8f8a7ec4898d2484af368"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1478484 - Avoid focusing the video element if we get focus events for the controls. r=jaws, a=lizzard\n\nMozReview-Commit-ID: 1FEu4Ly701o", "files": ["toolkit/content/TopLevelVideoDocument.js"], "git_node": null, "git_parents": [null], "node": "87a0f14ada202aaf2a805fdbdc212a8144ce0e13", "parents": ["16145096886544434502bb35544226d76ccdee1f"], "tags": []}], "date": 1533763204, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9625": {"changesets": [{"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1464938: Stop needlessly waiting for responses to startup messages. r=aswan a=pascalc\n\nMozReview