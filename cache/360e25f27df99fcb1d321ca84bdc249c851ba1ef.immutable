g 1467627 - Calculate origin frecency as the sum of all URL frecencies instead of the max. r=mak a=lizzard\n\nMozReview-Commit-ID: KZi9C7olvsj", "files": ["browser/base/content/test/urlbar/browser_urlbarAutoFillTrimURLs.js", "toolkit/components/places/Bookmarks.jsm", "toolkit/components/places/Database.cpp", "toolkit/components/places/Database.h", "toolkit/components/places/History.cpp", "toolkit/components/places/History.jsm", "toolkit/components/places/PlacesDBUtils.jsm", "toolkit/components/places/SyncedBookmarksMirror.jsm", "toolkit/components/places/UnifiedComplete.js", "toolkit/components/places/nsINavHistoryService.idl", "toolkit/components/places/nsNavHistory.cpp", "toolkit/components/places/nsNavHistory.h", "toolkit/components/places/nsPlacesTables.h", "toolkit/components/places/nsPlacesTriggers.h", "toolkit/components/places/tests/maintenance/test_preventive_maintenance.js", "toolkit/components/places/tests/migration/head_migration.js", "toolkit/components/places/tests/migration/test_current_from_v47.js", "toolkit/components/places/tests/unit/test_frecency_stats.js", "toolkit/components/places/tests/unit/test_origins.js", "toolkit/components/places/tests/unit/test_origins_parsing.js", "toolkit/components/places/tests/unit/test_sql_function_origin.js", "toolkit/components/places/tests/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "0deb6e00faa3e55cb1af1a8fddf3f3448eeb6227", "parents": ["7a488bdb5f3cf17217c6be505396b4120a68641a"], "tags": []}, {"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1469651 - For autofill, collapse all prefixes per host. r=mak a=lizzard\n\nMozReview-Commit-ID: Dy7IoOV8n8f", "files": ["toolkit/components/places/UnifiedComplete.js", "toolkit/components/places/tests/unifiedcomplete/test_autofill_origins.js"], "git_node": null, "git_parents": [null], "node": "be5e626019bed2a730dafd98bedd80bea045f616", "parents": ["0deb6e00faa3e55cb1af1a8fddf3f3448eeb6227"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 947838 - Don't reload distro prefs, just load at the same time as customizations. r=florian a=lizzard\n\nMozReview-Commit-ID: DPaE92V2xKg", "files": ["browser/components/distribution.js", "browser/components/nsBrowserGlue.js"], "git_node": null, "git_parents": [null], "node": "95d66abccf63483bcd778947778959e0cef6da95", "parents": ["be5e626019bed2a730dafd98bedd80bea045f616"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1468048 - Factor out loopUntilIdle() from GeckoSessionTestRule into UiThreadUtils r=jchen a=lizzard\n\nThis allows us to write other tests that need similar loop integration\nwithout having to use GeckoSessionTestRule.\n\nMozReview-Commit-ID: LfVSGhvyMoP", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/GeckoSessionTestRuleTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/rule/GeckoSessionTestRule.java", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/util/UiThreadUtils.java"], "git_node": null, "git_parents": [null], "node": "61a607f98731ece6c4ea3c24586a2c8bfc77a4d1", "parents": ["95d66abccf63483bcd778947778959e0cef6da95"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1468048 - Introduce GeckoResult r=droeh,jchen a=lizzard\n\nThis is a Promise-like system used to return asynchronous results.\n\nMozReview-Commit-ID: 3ZBP4S7d25A", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/GeckoResultTest.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoResult.java"], "git_node": null, "git_parents": [null], "node": "3cb6c770f9939b36c8904f114c5db42a5ee3d910", "parents": ["61a607f98731ece6c4ea3c24586a2c8bfc77a4d1"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1468048 - Add GeckoSessionTestRule.waitForResult() r=esawin,jchen a=lizzard\n\nMozReview-Commit-ID: HEcBXmwOaD7", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/GeckoSessionTestRuleTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/rule/GeckoSessionTestRule.java"], "git_node": null, "git_parents": [null], "node": "8d742d7212bbb9e4b037734962b85c2c7b762f7c", "parents": ["3cb6c770f9939b36c8904f114c5db42a5ee3d910"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1468048 - Make GeckoSession.saveState() return a GeckoResult r=droeh,esawin a=lizzard\n\nMozReview-Commit-ID: Ck6EZcaUeV2", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSession.java"], "git_node": null, "git_parents": [null], "node": "867449d771f06b4b49fdfe21fae948874d656efa", "parents": ["8d742d7212bbb9e4b037734962b85c2c7b762f7c"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1468048 - Add tests for GeckoSession.saveState() and restoreState() r=droeh,jchen a=lizzard\n\nMozReview-Commit-ID: 7oIHXAQvGcq", "files": ["mobile/android/geckoview/src/androidTest/assets/www/saveState.html", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/BaseSessionTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/ContentDelegateTest.kt"], "git_node": null, "git_parents": [null], "node": "2c0ec484c4eca7721900a7a0a5d8779f1d2bd46f", "parents": ["867449d771f06b4b49fdfe21fae948874d656efa"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1473713 - Fix GeckoSession.saveState() when accessibility is used r=droeh a=lizzard\n\nMozReview-Commit-ID: GG16D99S2Id", "files": ["mobile/android/chrome/geckoview/GeckoViewContent.js"], "git_node": null, "git_parents": [null], "node": "0861f4656f09d9a44a95b8d7e9f431c4c2b3d63c", "parents": ["2c0ec484c4eca7721900a7a0a5d8779f1d2bd46f"], "tags": []}, {"author": "David Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "bug 1471932 - avoid deadlock when loading 3rd party roots r=franziskus a=lizzard\n\nChangeCertTrustWithPossibleAuthentication should never be called while holding\nnsNSSComponent::mMutex, because doing so can result in showing the master\npassword dialog, which spins the event loop, which can cause other code to run\nthat may attempt to acquire the same lock (e.g. speculative connect checking\nnsNSSComponent to see if the user has smart cards or client certificates).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D2011", "files": ["security/manager/ssl/nsNSSComponent.cpp"], "git_node": null, "git_parents": [null], "node": "99a0a46fbae75d8d4acfaf3fcd3f327904e23898", "parents": ["0861f4656f09d9a44a95b8d7e9f431c4c2b3d63c"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1473685 - When a user \"disables protection\" on a site, and no trackers are detected, indicate that TP is turned off instead of on. r=nhnt11 a=lizzard\n\nMozReview-Commit-ID: 9JjCK1GYMbC", "files": ["browser/base/content/test/trackingUI/browser_trackingUI_state.js", "browser/themes/shared/controlcenter/panel.inc.css"], "git_node": null, "git_parents": [null], "node": "9069ef47ae90d684e798dab701a79a26d3515912", "parents": ["99a0a46fbae75d8d4acfaf3fcd3f327904e23898"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1474402 - Disable TryUpdateTransformOnly when we have RDL enabled since it can cause sorting issues. r=miko a=lizzard\n\nMozReview-Commit-ID: GguBTl2zZXO", "files": ["layout/generic/nsFrame.cpp"], "git_node": null, "git_parents": [null], "node": "8c9f4cc4061bd70add1b5a9619f7eac0535c73bd", "parents": ["9069ef47ae90d684e798dab701a79a26d3515912"], "tags": []}], "date": 1531516436, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "9475": {"changesets": [{"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1463484 - 1. Add SessionFinder; r=droeh,esawin,snorp a=lizzard\n\nAdd a SessionFinder API for find-in-page functionality.\n\nMozReview-Commit-ID: KB7dOPUC6s2", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSession.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/SessionFinder.java", "mobile/android/modules/geckoview/GeckoViewContent.jsm"], "git_node": null, "git_parents": [null], "node": "a3fcc54f9143366ea20f513b29d5fb4b018241d0", "parents": ["8c9f4cc4061bd70add1b5a9619f7eac0535c73bd"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1463484 - 2. Add test for find-in-page; r=esawin,snorp a=lizzard\n\nAdd some test cases for find-in-page and the different flags.\n\nMozReview-Commit-ID: BzN0OTSUy7z", "files": ["mobile/android/geckoview/src/androidTest/assets/www/loremIpsum.html", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/BaseSessionTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/FinderTest.kt"], "git_node": null, "git_parents": [null], "node": "1654819afa70a2196808dcc478190a40fbd9fdf1", "parents": ["a3fcc54f9143366ea20f513b29d5fb4b018241d0"], "tags": []}, {"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 1473998 - Use EditText entry in accessible's classNames and use the hint for the label. r=yzen r=jchen a=lizzard", "files": ["accessible/jsat/Constants.jsm", "accessible/jsat/Presentation.jsm", "accessible/tests/mochitest/jsat/test_text_editable_navigation.html", "accessible/tests/mochitest/jsat/test_text_editing.html", "accessible/tests/mochitest/jsat/test_text_navigation_focus.html", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/AccessibilityTest.kt", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/SessionAccessibility.java"], "git_node": null, "git_parents": [null], "node": "36921dd17b6b146cb2dcf57f5b76a4047f38d971", "parents": ["1654819afa70a2196808dcc478190a40fbd9fdf1"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1473974 - Fix opening all tabs panel with cycle recent tabs r=dao a=lizzard\n\nMozReview-Commit-ID: EGYJo8AAF2K", "files": ["browser/base/content/browser-allTabsMenu.js", "browser/base/content/browser-ctrlTab.js", "browser/base/content/browser-sets.inc"], "git_node": null, "git_parents": [null], "node": "f31b2ce16942de1e0ffe60fedfc679c0f2c66d41", "parents": ["36921dd17b6b146cb2dcf57f5b76a4047f38d971"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1474814: Invalidate the AccessibleHandler cache on focus events. r=MarcoZ a=lizzard\n\nWe don't fire a state change for the focused state, since that would be redundant given that we fire a focus event.\nHowever, that also means the handler cache previously didn't get invalidated when there was a focus change without any other update.\nThat resulted in stale focused states, which could mean an object was exposed as focused when it wasn't.\nInvalidating the cache for focus events ensures the focused state is always up to date.\n\nMozReview-Commit-ID: DZTJMbiTwgt", "files": ["accessible/windows/msaa/AccessibleWrap.cpp"], "git_node": null, "git_parents": [null], "node": "825a33b82f472d439196ecfae5dd34fc6566a6f7", "parents": ["f31b2ce16942de1e0ffe60fedfc679c0f2c66d41"], "tags": []}, {"author": "Dragana Damjanovic \u003cdd.mozilla@gmail.com\u003e", "branch": "default", "desc": "Bug 1467102 - Fix the ftp diversion. r=bagder a=lizzard", "files": ["netwerk/protocol/ftp/nsFTPChannel.h"], "git_node": null, "git_parents": [null], "node": "f98d084dff6ce1383517d4834f00982384862002", "parents": ["825a33b82f472d439196ecfae5dd34fc6566a6f7"], "tags": []}, {"author": "Shane Caraveo \u003cscaraveo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1474626 - fix timestamp test and values, r=rpl a=lizzard\n\nThe test was incorrect and the timestamp should be milliseconds, not microseconds.\n\nMozReview-Commit-ID: 2d79r6PHH4Z", "files": ["toolkit/components/extensions/test/mochitest/test_ext_webrequest_hsts.html", "toolkit/modules/addons/SecurityInfo.jsm"], "git_node": null, "git_parents": [null], "node": "54ec00f46350250ebef7caa4d27b4c02bbb30443", "parents": ["f98d084dff6ce1383517d4834f00982384862002"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1474450 - 1. Add some tests for more GeckoResult behavior; r=snorp a=lizzard\n\nAdd some tests for handling of uncaught exceptions, and tests for value\nand exception propagation.\n\nMozReview-Commit-ID: 4sEakRr1lLo", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/GeckoResultTest.java"], "git_node": null, "git_parents": [null], "node": "6055650e6d31f7535a75ca65950a928fe68e86bf", "parents": ["54ec00f46350250ebef7caa4d27b4c02bbb30443"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1474450 - 2. Rethrow uncaught and unhandled exceptions in GeckoResult; r=snorp a=lizzard\n\nIf at the end of a chain, we have an uncaught and unhandled exception,\nrethrow the exception to make it more visible.\n\nAlso, when a GeckoResult is completed with a value/exception, propagate\nthe value/exception properly down the chain.\n\nMozReview-Commit-ID: F4tnST1nKe5", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoResult.java"], "git_node": null, "git_parents": [null], "node": "94e6d8bb45e5ebb3ea6ff8055436e4a302784737", "parents": ["6055650e6d31f7535a75ca65950a928fe68e86bf"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1474450 - 3. Fix javadoc; r=jchen a=lizzard\n\n1) Add some missing javadoc and fix existing javadoc warnings.\n\n2) Expand the GeckoResult javadoc with some examples.\n\n3) Make @IntDef/@StringDef interfaces package-private, so they don't\n   show up in javadoc as empty stubs.\n\nMozReview-Commit-ID: JzvlLzTMgAQ", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoResult.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoRuntime.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoRuntimeSettings.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSession.java"], "git_node": null, "git_parents": [null], "node": "7f495a6969c57d696fc22d95a909199994aa133b", "parents": ["94e6d8bb45e5ebb3ea6ff8055436e4a302784737"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1474891 - Reset tracking protection state when visiting about: pages. r=ewright a=lizzard\n\nMozReview-Commit-ID: CsXj95KDVaD", "files": ["browser/base/content/browser-trackingprotection.js"], "git_node": null, "git_parents": [null], "node": "fb31b6425bf7e512822de69455072c20466ac5b9", "parents": ["7f495a6969c57d696fc22d95a909199994aa133b"], "tags": []}, {"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1473041 - save and restore PermitSubpixelAA state for basic layer paint callback. r=mstange a=lizzard", "files": ["gfx/layers/basic/BasicPaintedLayer.cpp"], "git_node": null, "git_parents": [null], "node": "0f8a467c6c83f3e71e841f49dff92573d3e01fc6", "parents": ["fb31b6425bf7e512822de69455072c20466ac5b9"], "tags": []}, {"author": "Nicolas B. Pierron \u003cnicolas.b.pierron@gmail.com\u003e", "branch": "default", "desc": "Bug 1474904 - Enable memory protection exception handler on dev-edition builds. r=ehoogeveen a=lizzard", "files": ["js/src/ds/MemoryProtectionExceptionHandler.cpp"], "git_node":