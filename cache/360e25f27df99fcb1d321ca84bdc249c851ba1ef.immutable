: ["toolkit/components/search/nsSearchService.js", "toolkit/components/search/tests/xpcshell/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "06bf0684c8eb89a31e5db98bfb15887e77fb7cef", "parents": ["bf975c9634a5713c5eb205af9d99da001dafde9e"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1469889 - Allow blacklisting search engines based on URL. r=florian, a=lizzard", "files": ["toolkit/components/search/nsSearchService.js", "toolkit/components/search/tests/xpcshell/data/search_blacklist.json", "toolkit/components/search/tests/xpcshell/test_blacklist.js", "toolkit/components/search/tests/xpcshell/test_json_cache_blacklist.js", "toolkit/components/search/tests/xpcshell/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "80db10d6e9c64be3344766371c566bc2fce10c14", "parents": ["06bf0684c8eb89a31e5db98bfb15887e77fb7cef"], "tags": []}], "date": 1531760551, "git_changesets": [null, null], "user": "archaeopteryx@coole-files.de"}, "9488": {"changesets": [{"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 80db10d6e9c6 (bug 1469889) for eslint failure due to missing uplift of bug 1463162. a=backout", "files": ["toolkit/components/search/nsSearchService.js", "toolkit/components/search/tests/xpcshell/data/search_blacklist.json", "toolkit/components/search/tests/xpcshell/test_blacklist.js", "toolkit/components/search/tests/xpcshell/test_json_cache_blacklist.js", "toolkit/components/search/tests/xpcshell/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "42da3e228e5b0972266fdeca15b69b816209f65f", "parents": ["80db10d6e9c64be3344766371c566bc2fce10c14"], "tags": []}], "date": 1531761743, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "9489": {"changesets": [{"author": "Daniel Holbert \u003cdholbert@cs.stanford.edu\u003e", "branch": "default", "desc": "Bug 1462983: Check for redundant \"loaded\" messages from opened window, in test_bug607529.html. r=bz a=testonly\n\nSuch messages happen intermittently on Android, presumably from bfcache being\npurged due to memory pressure (which would then cause the back() operation\nbehave like a fresh load).  So on Android, we'll now treat these redundant\nmessages as a \"todo()\" failure, to indicate that something went wrong but avoid\nturning the testsuite orange.\n\nMozReview-Commit-ID: GkaxB06vL7q", "files": ["layout/base/tests/test_bug607529.html"], "git_node": null, "git_parents": [null], "node": "b286967e493909fec69b93f0521a221a2a18d11b", "parents": ["42da3e228e5b0972266fdeca15b69b816209f65f"], "tags": []}], "date": 1531762290, "git_changesets": [null], "user": "dholbert@mozilla.com"}, "9490": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nia -\u003e 697de004a277\nml -\u003e 4537fd842740\npa-IN -\u003e d364ea9b9c07", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "ecfe37b248f09af40d83fe8a45cfe729ab77dcc7", "parents": ["b286967e493909fec69b93f0521a221a2a18d11b"], "tags": []}], "date": 1531763308, "git_changesets": [null], "user": "ffxbld"}, "9491": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nel -\u003e c001b588f29b\nte -\u003e 91718373a56f\nuk -\u003e 8b1742337ff7", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "e16b99d677c361dd26d2897c8ea0fdd8fc41816d", "parents": ["ecfe37b248f09af40d83fe8a45cfe729ab77dcc7"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nel -\u003e af1a