rents": [null], "node": "a2e970897bb27b5fe17891526b233907653e53e0", "parents": ["567df8598cdb89ab9869c5d664db131499adf5b5"], "tags": []}, {"author": "Ciure Andrei \u003caciure@mozilla.com\u003e", "branch": "default", "desc": "Backed out 1 changesets (bug 1470552) for build bustages mozbuild/test/backend/test_build.py CLOSED TREE\n\nBacked out changeset 567df8598cdb (bug 1470552)", "files": ["Makefile.in"], "git_node": null, "git_parents": [null], "node": "bf56c04574dd2e91f2bdcfc3c901bf2ebbae904f", "parents": ["a2e970897bb27b5fe17891526b233907653e53e0"], "tags": []}, {"author": "Andreea Pavel \u003capavel@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland. a=merge on a CLOSED TREE", "files": ["browser/components/nsBrowserGlue.js", "mobile/android/geckoview/src/androidTest/assets/www/selectionAction.html"], "git_node": null, "git_parents": [null, null], "node": "14b748d68b531af5fdbc12f89cc1d1b70c41e994", "parents": ["bf56c04574dd2e91f2bdcfc3c901bf2ebbae904f", "16a0430796894ad4b9cb86bde55f07cf57453b56"], "tags": []}, {"author": "Sylvestre Ledru \u003csledru@mozilla.com\u003e", "branch": "default", "desc": "Bug 1466661 - Do not build breakpad md5.cc on Linux r=ted\n\nMozReview-Commit-ID: 5mF8BVX67iW", "files": ["toolkit/crashreporter/google-breakpad/src/common/moz.build"], "git_node": null, "git_parents": [null], "node": "6aec9dc32d1c194f22d98bc51e886678ff0ba200", "parents": ["14b748d68b531af5fdbc12f89cc1d1b70c41e994"], "tags": []}, {"author": "Chris Manchester \u003ccmanchester@mozilla.com\u003e", "branch": "default", "desc": "Bug 1470552 - Update Makefile.in to refer to stub file target for buildid.h and source-repo.h generated in backend.mk r=froydnj\n\nMozReview-Commit-ID: CxLkQjX8veW", "files": ["Makefile.in"], "git_node": null, "git_parents": [null], "node": "1dbc843c1429a374579251d6c843e11bd211ec28", "parents": ["6aec9dc32d1c194f22d98bc51e886678ff0ba200"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1448513 - Only do the panThreshold check if the threshold is \u003e 0. r=botond\n\nThis optimization also sneakily avoids the call to UpdateWithTouchAtDevicePoint\nwhich is what updates the Axis::mPos variable to the new touch point. Without\nthat update, mPos remains at the touchstart point, which ensures that the full\npixel delta from all the touchmove events gets turned into scrolling. Without\nthis, the first touchmove event always gets consumed in the process of overcoming\nthe pan threshold, which lead to flaky test behaviour.\n\nMozReview-Commit-ID: Io0zqgh8MZR", "files": ["gfx/layers/apz/src/AsyncPanZoomController.cpp", "gfx/layers/apz/test/mochitest/apz_test_native_event_utils.js", "gfx/layers/apz/test/mochitest/helper_basic_pan.html", "gfx/layers/apz/test/mochitest/helper_bug1280013.html", "gfx/layers/apz/test/mochitest/helper_div_pan.html", "gfx/layers/apz/test/mochitest/helper_iframe_pan.html", "gfx/layers/apz/test/mochitest/helper_touch_action.html", "gfx/layers/apz/test/mochitest/helper_touch_action_complex.html"], "git_node": null, "git_parents": [null], "node": "580bc3d27e23d3e97b96a259896caf212599c986", "parents": ["1dbc843c1429a374579251d6c843e11bd211ec28"], "tags": []}, {"author": "Sahith Nallapareddy \u003csahith.reddy@gmail.com\u003e", "branch": "default", "desc": "Bug 1455965 - Removed obsolete strings r=Gijs\n\nMozReview-Commit-ID: DOo8F7kpHYG", "files": ["browser/locales/en-US/chrome/browser/browser.dtd"], "git_node": null, "git_parents": [null], "node": "dee91f9d3b3a6bc994b7f999c2e8afae226d3f3b", "parents": ["580bc3d27e23d3e97b96a259896caf212599c986"], "tags": []}, {"author": "rforbes \u003crforbes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1470079 - Add fuzzing coverage build to taskcluster r=marco\n\nMozReview-Commit-ID: 7FwYAjzHJJw", "files": ["browser/config/mozconfigs/linux64/nightly-fuzzing-cov", "taskcluster/ci/build/linux.yml", "testing/mozharness/configs/builds/releng_sub_linux_configs/64