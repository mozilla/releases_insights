owser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "152692897bcd0a76df041fb0310c668b972898b5", "parents": ["b89aa2f43340452a155a204a0590da58ba9bb246"], "tags": []}], "date": 1533196833, "git_changesets": [null, null], "user": "ffxbld"}, "9569": {"changesets": [{"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1470731 - Don't try to unbind child process service if we aren't bound r=droeh a=ritu\n\nMozReview-Commit-ID: GYy1utiAa5v", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/process/GeckoProcessManager.java"], "git_node": null, "git_parents": [null], "node": "ff703785d55de47da9cead14e50fdeb4b1abbb9b", "parents": ["152692897bcd0a76df041fb0310c668b972898b5"], "tags": []}, {"author": "Haik Aftandilian \u003chaftandilian@mozilla.com\u003e", "branch": "default", "desc": "Bug 1475707 - [Mac] Flash sandbox on Nightly/Beta causes OS X 10.9 file upload dialog Flash plugin crash r=Alex_Gaynor a=ritu\n\nAdd the com.apple.xpcd service to the Flash plugin sandbox for OS X 10.9 systems to avoid crashes when opening file dialogs.\n\nMozReview-Commit-ID: A40Mov98Ddy", "files": ["security/sandbox/mac/SandboxPolicies.h"], "git_node": null, "git_parents": [null], "node": "a44407cbf3dbea222ed83f1d1be140f44172724b", "parents": ["ff703785d55de47da9cead14e50fdeb4b1abbb9b"], "tags": []}, {"author": "Haik Aftandilian \u003chaftandilian@mozilla.com\u003e", "branch": "default", "desc": "Bug 1471977 - Mac Flash sandbox causing World Cup playback issues on foxsports.com r=Alex_Gaynor a=ritu\n\nPass the user cache dir as a parameter to the Flash sandbox profile.\nAdd services and paths to the Flash sandbox profile needed for TLS\nand encrypted video playback.\n\nMozReview-Commit-ID: 1szVXVVATFy", "files": ["security/sandbox/mac/Sandbox.mm", "security/sandbox/mac/SandboxPolicies.h"], "git_node": null, "git_parents": [null], "node": "b6476b444aab3135d20f3e704f82d97842297adc", "parents": ["a44407cbf3dbea222ed83f1d1be140f44172724b"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1470947 - Part 1: Remove visible tab indicator from all tabs menu r=dao a=ritu\n\nMozReview-Commit-ID: CliduvaGqUb", "files": ["browser/base/content/browser-allTabsMenu.js", "browser/modules/TabsList.jsm", "browser/themes/shared/tabs.inc.css"], "git_node": null, "git_parents": [null], "node": "73061be36d6f4a10832d11b4e09b0af9b6493c2d", "parents": ["b6476b444aab3135d20f3e704f82d97842297adc"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1470947 - Part 2: Call _tabAttrModified on busy and progress changes r=dao a=ritu\n\nThis fixes the tab throbbers not showing sometimes and not showing\nthe progress state in the all tabs menu.\n\nMozReview-Commit-ID: FintGto9e9g", "files": ["browser/base/content/tabbrowser.js", "browser/modules/TabsList.jsm"], "git_node": null, "git_parents": [null], "node": "cc5cd2afe96f62a89a72cbf52245f1144e8363f3", "parents": ["73061be36d6f4a10832d11b4e09b0af9b6493c2d"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1470947 - Part 3: Ensure tab throbbers are always hidden with browser.tabs.hideThrobber r=mconley a=ritu\n\nThe tab throbbers were being shown in the new all tabs menu. If this pref\nis set then we never want them to be visible, so using !important to fix\nthis and future issues.\n\nMozReview-Commit-ID: DHRrCAKEwnA", "files": ["browser/base/content/browser.css"], "git_node": null, "git_parents": [null], "node": "a8ea40cfeaf2504066ad7a0aa553d9510b438de4", "parents": ["cc5cd2afe96f62a89a72cbf52245f1144e8363f3"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1470947 - Part 4: Fix the selected tab colour in all tabs menu r=dao a=ritu\n\nMozReview-Commit-ID: snNPRH0JpV", "files": ["browser/themes/shared/tabs.inc.css"], "git_node": null, "git_parents": [null], "node": "4d020a78c00fdaabaa3ebb65c34dfe5bb6864745", "parents": ["a8ea40cfeaf2504066ad7a0aa553d9510b438de4"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1470947 - Part 5: Remove block padding from scrollbars in all tabs menu r=dao a=ritu\n\nMozReview-Commit-ID: 32Uc6h4PSUu", "files": ["browser/base/content/browser-allTabsMenu.inc.xul", "browser/base/content/browser-allTabsMenu.js", "browser/themes/shared/tabs.inc.css"], "git_node": null, "git_parents": [null], "node": "c583095f5b08fdaaf8fde3b101c5bc306c3316e6", "parents": ["4d020a78c00fdaabaa3ebb65c34dfe5bb6864745"], "tags": []}, {"author": "Haik Aftandilian \u003chaftandilian@mozilla.com\u003e", "branch": "default", "desc": "Bug 1475722 - Mac Flash sandbox causes empty file upload dialogs on OS X 10.9, 10.10 r=Alex_Gaynor a=ritu\n\nOn 10.9 and 10.10, grant global read access to the Flash sandbox.\n\nChange Flash sandbox levels by adding a new level 1 that includes\nglobal read access which will be the default on 10.9/10.10.\nLevel 2 is the new default for 10.11 and above with file read\naccess enabled by file dialog activity.\n\nMozReview-Commit-ID: LvXhd6Vf7mo", "files": ["browser/app/profile/firefox.js", "dom/plugins/base/nsPluginTags.cpp", "security/sandbox/common/SandboxSettings.cpp", "security/sandbox/mac/SandboxPolicies.h"], "git_node": null, "git_parents": [null], "node": "3edfcf8b06b7c77e225e19b746edf403b74abff8", "parents": ["c583095f5b08fdaaf8fde3b101c5bc306c3316e6"], "tags": []}, {"author": "Haik Aftandilian \u003chaftandilian@mozilla.com\u003e", "branch": "default", "desc": "Bug 1474375 - [Mac] Let Sandboxing for the Flash NPAPI plugin process ride the trains r=Alex_Gaynor a=ritu\n\nMozReview-Commit-ID: Jlvjulbvo7S", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "44ca37781c49660b9a815b1263bb6ca7d65e8a4c", "parents": ["3edfcf8b06b7c77e225e19b746edf403b74abff8"], "tags": []}, {"author": "Brad Werth \u003cbwerth@mozilla.com\u003e", "branch": "default", "desc": "Bug 1471894 Part 1: Ensure that absolute positioned blocks with auto margins update their UsedMargin property. r=dholbert a=ritu\n\nMozReview-Commit-ID: EFIQVvazkTg", "files": ["layout/generic/ReflowInput.cpp"], "git_node": null, "git_parents": [null], "node": "a870235212e9aaeb67ded818f656567544b5355b", "parents": ["44ca37781c49660b9a815b1263bb6ca7d65e8a4c"], "tags": []}, {"author": "Brad Werth \u003cbwerth@mozilla.com\u003e", "branch": "default", "desc": "Bug 1471894 Part 2: Add a web-platform-test to check computed margin values on auto margin blocks. r=dholbert a=ritu\n\nMozReview-Commit-ID: KbSZzhoX5mu", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/css/cssom/computed-style-005.html"], "git_node": null, "git_parents": [null], "node": "cbdb0aea5c60d712ca220deed2179e101ffedf6c", "parents": ["a870235212e9aaeb67ded818f656567544b5355b"], "tags": []}, {"author": "Brad Werth \u003cbwerth@mozilla.com\u003e", "branch": "default", "desc": "Bug 1471894 Part 3: Update expectation to pass for parts of a WPT test. r=dholbert a=ritu\n\nMozReview-Commit-ID: K6nU6C76gZg", "files": ["testing/web-platform/meta/html/rendering/non-replaced-elements/flow-content-0/dialog.html.ini"], "git_node": null, "git_parents": [null], "node": "9ab230cdc61409a376cc19a4232e5eba0f4fab67", "parents": ["cbdb0aea5c60d712ca220deed2179e101ffedf6c"], "tags": []}, {"author": "Razvan Caliman \u003crcaliman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1478051 - Skip using stylesheet from Netmonitor if its content size is zero. r=jdescottes a=ritu\n\nMozReview-Commit-ID: 6A1YbwDmBVj", "files": ["devtools/server/actors/stylesheets.js"], "git_node": null, "git_parents": [null], "node": "2107f137f325fcaeaf6689b445f745aa2b55141f", "parents": ["9ab230cdc61409a376cc19a4232e5eba0f4fab67"], "tags": []}, {"author": "yulia \u003cystartsev@mozilla.com\u003e", "bra