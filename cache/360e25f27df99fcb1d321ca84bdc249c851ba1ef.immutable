], "git_node": null, "git_parents": [null], "node": "4df089dd0c1aedf2f2093bff842fd687eabb521f", "parents": ["9e752b54a20f425449e1f00bf3adefa903f8051a"], "tags": []}], "date": 1534408534, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "9674": {"changesets": [{"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset a1f21507bec3 (bug 1451172) for conflicts with bug 1482029. a=backout", "files": ["dom/bindings/BindingUtils.h"], "git_node": null, "git_parents": [null], "node": "50cee4072a3797487fe884ca88b3eab8b406bd29", "parents": ["4df089dd0c1aedf2f2093bff842fd687eabb521f"], "tags": []}], "date": 1534410996, "git_changesets": [null], "user": "dluca@mozilla.com"}, "9675": {"changesets": [{"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1446274 - Fix browserAction popup resize test intermittency due to initial popup height being detected while still resizing. r=mixedpuppy, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3349", "files": ["browser/components/extensions/test/browser/browser_ext_browserAction_popup_resize.js"], "git_node": null, "git_parents": [null], "node": "4ec21bd0926f44934a4b72e7c38fedf341ba6064", "parents": ["50cee4072a3797487fe884ca88b3eab8b406bd29"], "tags": []}, {"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP blocklist remote-settings - a=repo-update r=mtabara\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3494", "files": ["browser/app/blocklist.xml", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/blocklists/addons.json"], "git_node": null, "git_parents": [null], "node": "3e1db8822939a99cefa3c5d29b913081881cb82c", "parents": ["4ec21bd0926f44934a4b72e7c38fedf341ba6064"], "tags": []}], "date": 1534428497, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "9676": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1482694 - Don't clear the insertion point from ClearInsertedChildren if we're not the insertion point the node is assigned to. r=smaug, a=RyanVM\n\nWhat's going on is that nested XBL insertion points are completely unsound, and\nwe leave all sorts of kids in mInsertedChildren when bindings dynamically\nchange.\n\nSo if bindings change in a particular way so that the innermost insertion point\nis cleared, but the outermost bindings aren't, like this, we end up with an\ninconsistent flattened tree.\n\nThis prevents the inconsistent flattened tree in this case, though what ought\nto happen in the SetXBLInsertionPoint(nullptr) case is setting the insertion\npoint to the outer insertion point.\n\nBut we don't keep track of all our insertion points, and I don't think it's\nworth to fix that given XBL is going away unless it gives us more problems. See\nalso bug 1425362 & co.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3163", "files": ["dom/xbl/XBLChildrenElement.h"], "git_node": null, "git_parents": [null], "node": "8b634e6d6b4c580db6cb4c8353d67e3cf826bbb8", "parents": ["3e1db8822939a99cefa3c5d29b913081881cb82c"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1482797 - Don't use MADV_FREE on Linux until we support it properly. r=njn, a=RyanVM", "files": ["memory/build/mozjemalloc.cpp"], "git_node": null, "git_parents": [null], "node": "8ad88c2fad5cb9d2c984add1ef3d6902c02c204e", "parents": ["8b634e6d6b4c580db6cb4c8353d67e3cf826bbb8"], "tags": []}], "date": 1534432007, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "9677": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset 4ec21bd0926f (bug 1446274) for browser_ext_browserAction_popup_resize.js failures.", "files": ["browser/components/extensions/test/browser/browser_ext_browserAction_popup_resize.js"], "git_node": null, "git_parents": [null], "node": "5d1304c8f20a6602a93176ec772075df7ac38d32", "parents": ["8ad88c2fad5cb9d2c984add1ef3d6902c02c204e"], "tags": ["DEVEDITION_62_0b18_BUILD1", "DEVEDITION_62_0b18_RELEASE", "FIREFOX_62_0b18_BUILD1", "FIREFOX_62_0b18_RELEASE"]}], "date": 1534432670, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "9678": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 5d1304c8f20a6602a93176ec772075df7ac38d32 with DEVEDITION_62_0b18_BUILD1 a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "47b9b4078b7c37f1e193274c4059b6adaf702e24", "parents": ["5d1304c8f20a6602a93176ec772075df7ac38d32"], "tags": []}], "date": 1534443177, "git_changesets": [null], "user": "ffxbld"}, "9679": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 5d1304c8f20a6602a93176ec772075df7ac38d32 with FIREFOX_62_0b18_BUILD1 a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "d16e514eb7ed03e571c24af651b01628a11596ab", "parents": ["47b9b4078b7c37f1e193274c4059b6adaf702e24"], "tags": []}], "date": 1534443358, "git_changesets": [null], "user": "ffxbld"}, "9680": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 5d1304c8f20a6602a93176ec772075df7ac38d32 with FIREFOX_62_0b18_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "a199e082f24777d9d2d9f47ffe35a2b28dc51863", "parents": ["d16e514eb7ed03e571c24af651b01628a11596ab"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "Automatic vers