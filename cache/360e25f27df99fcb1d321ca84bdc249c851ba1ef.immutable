 "node": "4e9c6de435ef57e9cab0cb97873b46477ff69538", "parents": ["4eb0833bb0b4c1d5a97b9f4dfd89c40d74f562f4"], "tags": []}, {"author": "Mats Palmgren \u003cmats@mozilla.com\u003e", "branch": "default", "desc": "Bug 1470260 part 2 - Make RefreshDriverTimer ref-counted and hold a strong ref on it on the stack when nsRefreshDriver::Tick can be reached.  r=emilio a=lizzard", "files": ["layout/base/nsRefreshDriver.cpp"], "git_node": null, "git_parents": [null], "node": "ea5d50cccb4b7979734751bb51a161f4f33cb084", "parents": ["4e9c6de435ef57e9cab0cb97873b46477ff69538"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1469873 Make ClientSource::Control() fail if storage access is not available and make claim() respect the result. r=mrbkap a=lizzard", "files": ["dom/clients/manager/ClientManagerService.cpp", "dom/clients/manager/ClientSource.cpp", "dom/clients/manager/ClientSource.h", "dom/clients/manager/ClientSourceOpParent.cpp", "dom/clients/manager/ClientSourceOpParent.h", "dom/clients/manager/ClientSourceParent.cpp", "dom/clients/manager/ClientSourceParent.h", "dom/serviceworkers/ServiceWorkerManager.cpp"], "git_node": null, "git_parents": [null], "node": "cb10387ab1cff10b532ced4ad1ef965df964c427", "parents": ["ea5d50cccb4b7979734751bb51a161f4f33cb084"], "tags": []}], "date": 1530549936, "git_changesets": [null, null, null], "user": "archaeopteryx@coole-files.de"}, "9424": {"changesets": [{"author": "Lisa Guo \u003clguo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1443873 - update beetmover in-tree payload to include buildhub. r=mtabara a=release", "files": ["taskcluster/taskgraph/transforms/beetmover.py", "taskcluster/taskgraph/transforms/beetmover_repackage.py"], "git_node": null, "git_parents": [null], "node": "801112336847960bbb9a018695cf09ea437dc137", "parents": ["cb10387ab1cff10b532ced4ad1ef965df964c427"], "tags": ["DEVEDITION_62_0b5_BUILD1", "DEVEDITION_62_0b5_RELEASE", "FENNEC_62_0b5_BUILD1", "FENNEC_62_0b5_RELEASE", "FIREFOX_62_0b5_BUILD1", "FIREFOX_62_0b5_RELEASE"]}], "date": 1530550145, "git_changesets": [null], "user": "mtabara@mozilla.com"}, "9425": {"changesets": [{"author": "\"Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e\"", "branch": "default", "desc": "No bug - Tagging 801112336847960bbb9a018695cf09ea437dc137 with FENNEC_62_0b5_BUILD1 a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "a1fed36e3abd0b666c05c579bedda65e9d9a481d", "parents": ["801112336847960bbb9a018695cf09ea437dc137"], "tags": []}], "date": 1530561165, "git_changesets": [null], "user": "ffxbld"}, "9426": {"changesets": [{"author": "\"Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e\"", "branch": "default", "desc": "No bug - Tagging 801112336847960bbb9a018695cf09ea437dc137 with DEVEDITION_62_0b5_BUILD1 a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "b66167d76d509eef31fe991f899bca870912c8a2", "parents": ["a1fed36e3abd0b666c05c579bedda65e9d9a481d"], "tags": []}], "date": 1530561395, "git_changesets": [null], "user": "ffxbld"}, "9427": {"changesets": [{"author": "\"Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e\"", "branch": "default", "desc": "No bug - Tagging 801112336847960bbb9a018695cf09ea437dc137 with FIREFOX_62_0b5_BUILD1 a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "c12b6a853caa91d8cd1f89c63c4e94d613e52429", "parents": ["b66167d76d509eef31fe991f899bca870912c8a2"], "tags": []}], "date": 1530561569, "git_changesets": [null], "user": "ffxbld"}, "9428": {"changesets": [{"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418806 - Introduce a constant variable to represents the number of all animatable longhands. r=xidorn a=lizzard\n\nWe will use this number to cap the pre-allocation AnimationValueMap in the next\npatch.\n\nMozReview-Commit-ID: Iqq9plbD8Vl", "files": ["servo/components/style/properties/properties.mako.rs"], "git_node": null, "git_parents": [null], "node": "131e7cdf1d22e92aded33ff7af7b42ddf7578c15", "parents": ["c12b6a853caa91d8cd1f89c63c4e94d613e52429"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418806 - Try to allocate possible size for AnimationValueMap before composing. r=birtles a=lizzard\n\nThe EffectSet count does not exactly represent the count what we really need\nfor AnimationValueMap, but in most cases it matches.  For example;\n\n1) The element has two different keyframes animations\n\n @keyframes anim1 {\n   to { opacity: 0; }\n }\n @keyframes anim2 {\n   to { transform: rotate(360deg); }\n }\n\n In this case the number matches.\n\n2) The element has two animations but both keyframes have the same CSS property\n\n @keyframes anim1 {\n   to { opacity: 0; }\n }\n @keyframes anim2 {\n   to { opacity: 0.1; }\n }\n\n In this case the number doesn't match, moreover it results more memory than we\n ever needed, but this case is presumably less common.\n\n3) The element has an animation having keyframes for two different CSS\n   properties.\n\n @keyframes anim {\n   from { opacity: 0; transform: rotate(360deg); }\n }\n\n In this kind of cases, the number doesn't match.  But even so, this patch\n reduces the opportunities that the AnimationValueMap tries to allocate a new\n memory (i.e. less opportunities on expanding the map).\n\nNote that when the hash map is expanded, we do allocate a new RawTable with the\nnew size then replace the old one with the new one [1], so I believe this\nchange will reduce the crash rate to some extent.\n\n[1] https://hg.mozilla.org/mozilla-central/file/15c95df467be/servo/components/hashglobe/src/hash_map.rs#l734\n\nMozReview-Commit-ID: 6tcF9aqXh7a", "files": ["layout/style/ServoBindings.cpp", "layout/style/ServoBindings.h", "servo/components/style/gecko/wrapper.rs"], "git_node": null, "git_parents": [null], "node": "b94f852925e66dae47c32432e4786290c05c7c7d", "parents": ["131e7cdf1d22e92aded33ff7af7b42ddf7578c15"], "tags": []}, {"author": "Eric Rahm \u003cerahm@mozilla.com\u003e", "branch": "default", "desc": "Bug 1472018 - Limit the lock scope in WebCryptoThreadPool::Shutdown. r=bz a=RyanVM\n\nIn bug 1364624 we switched over to SRWLock on Windows for our internal\nimplementation of mozilla::Mutex. This doesn't allow for re-entrancy. The\nWebCryptoThreadPool shutdown code has potential for re-entrancy due to the\nspinning of the main thread event loop while shutting down the worker threads.\n\nBy limiting the scope of the lock protecting mPool during shutdown we can avoid\nthe re-entrancy. Addtionally we track the shutdown status to avoid dispatching\nevents once shutdown has started.", "files": ["dom/crypto/WebCryptoThreadPool.cpp", "dom/crypto/WebCryptoThreadPool.h"], "git_node": null, "git_parents": [null], "node": "fb489313aa898d1cbe956df008c9b76d24425952", "parents": ["b94f852925e66dae47c32432e4786290c05c7c7d"], "tags": []}, {"author": "Stephen A Pohl \u003cspohl.mozilla.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1466335: Automatically switch to the appropriate Firefox theme based on the macOS dark mode system preference. r=dao,mstange a=lizzard", "files": ["browser/base/content/browser-compacttheme.js", "layout/style/nsMediaFeatures.cpp", "toolkit/modules/LightweightThemeConsumer.jsm", "toolkit/mozapps/extensions/LightweightThemeManager.jsm", "widget/LookAndFeel.h", "widget/cocoa/nsChildView.mm", "widget/cocoa/nsLookAndFeel.h", "widget/cocoa/nsLookAndFeel.mm", "widget/cocoa/nsNativeThemeCocoa.mm", "widget/nsXPLookAndFeel.cpp", "xpcom/ds/nsGkAtomList.h"], "git_node": null, "git_parents": [null], "node": "287d12a9f2eab91769b92220df6fdf33768e015c", "parents": ["fb489313aa898d1cbe956df008c9b76d24425952"], "tags": []}, {"author": "Stephen A Pohl \u003cspohl.mozilla.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1471950: Restrict to 10.14 andd above the automatic enabling of the dark theme when the system appearance changes to dark mode. r=haik a=lizzard", "files": ["widget/cocoa/nsCocoaFeatures.h", "widget/cocoa/nsCocoaFeatures.mm", "widget/cocoa/nsLookAndFeel.mm"], "git_node": null, "git_parents": [null], "node": "90df1b0f7e85412415791f2f6f337822178c622b", "parents": ["287d12a9f2eab91769b92220df6fdf33768e015c"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1470336 - The FxA signin form on about:welcome discards metrics query params. r=ursula a=lizzard\n\nMozReview-Commit-ID: KxmyyEYwRzv", "files": ["browser/extensions/activity-stream/content-src/components/StartupOverlay/StartupOverlay.jsx", "browser/extensions/activity-stream/data/content/activity-stream.bundle.js", "browser/extensions/activity-stream/data/content/activity-stream.bundle.js.map", "browser/extensions/activity-stream/install.rdf.in"], "git_node": null, "git_parents": [null], "node": "7d3146d065feeba6ee6dc06b674c2763f42e28c0", "parents": ["90df1b0f7e85412415791f2f6f337822178c622b"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1469823 - A new Top Sites tile does not appear after deleting a tile. r=Mardak a=lizzard\n\nMozReview-Commit-ID: C7SgdnHyv6S", "files": ["browser/extensions/activity-stream/install.rdf.in", "browser/extensions/activity-stream/lib/TopSitesFeed.jsm", "browser/extensions/activity-stream/test/unit/lib/TopSitesFeed.test.js"], "git_node": null, "git_parents": [null], "node": "42ed67641f893224d00195f90304f152f119a3d9", "parents": ["7d3146d065feeba6ee6dc06b674c2763f42e28c0"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1468077 - Stop disabling cmd_close and cmd_closeWindow in the bookmark panel since it seems to be half-broken and is inconsistent with other panels. r=mak a=lizzard\n\nMozReview-Commit-ID: AkKaq5Kon77", "files": ["browser/base/content/browser-places.js"], "git_node": null, "git_parents": [null], "node": "b55af4da7030e83fd7d3ead356f3279ee774b9ea", "parents": ["42ed67641f893224d00195f90304f152f119a3d9"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1468060 - Fix disabled styling for toolbaritem-combined-buttons in appMenu-popup. r=jaws a=lizzard\n\nMozReview-Commit-ID: 2GfHwaiQL73", "files": ["browser/themes/shared/customizableui/panelUI.inc.css"], "git_node": null, "git_parents": [null], "node": "8f24de7f709f874ea4d39641c30f67a0a7bcbecb", "parents": ["b55af4da7030e83fd7d3ead356f3279ee774b9ea"], "tags": []}], "date": 1530630667, "git_changesets": [null, null, null, null, null, null, null, null, null], "user": "aiakab@mozilla.com"}, "9429": {"changesets": [{"author": "\"Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e\"", "branch": "default", "desc": "No bug - Tagging 801112336847960bbb9a018695cf09ea437dc137 with FIREFOX_62_0b5_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "d14c476f0834c65c4e1ba82b46b997d7d019144a", "parents": ["8f24de7f709f874ea4d39641c30f67a0a7bcbecb"], "tags": []}, {"author": "\"Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e\"", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "d6d27e2044997414538b6b75086571695233ae7c", "parents": ["d14c476f0834c65c4e1ba82b46b997d7d019144a"], "tags": []}], "date": 1530633879, "git_changesets": [null, null], "user": "ffxbld"}, "9430": {"changesets": [{"author": "\"Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e\"", "branch": "default", "desc": "No bug - Tagging 801112336847960bbb9a018695cf09ea437dc137 with DEVEDITION_62_0b5_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "29b871d37ec6d7242f6beee32c60feb57cccb7db", "parents": ["d6d27e2044997414538b6b75086571695233ae7c"], "tags": []}], "date": 1530634204, "git_changesets": [null], "user": "ffxbld"}, "9431": {"changesets": [{"author": "\"Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e\"", "branch": "default", "desc": "No bug - Tagging 801112336847960bbb9a018695cf09ea437dc137 with FENNEC_62_0b5_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "ae03c256c0920df971f2d26fefd515838dd5c0af", "parents": ["29b871d37ec6d7242f6beee32c60feb57cccb7db"], "tags": []}], "date": 1530634882, "git_changesets": [null], "user": "ffxbld"}, "9432": {"changesets": [{"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1466846 - Enabling addon should set homepage override. r=kmag, a=RyanVM\n\nMozReview-Commit-ID: G9cfRuQjyGb", "files": ["browser/components/extensions/parent/ext-chrome-settings-overrides.js"], "git_node": null, "git_parents": [null], "node": "187686c0fc83b263b03659edbc1b5051d7df1936", "parents": ["ae03c256c0920df971f2d26fefd515838dd5c0af"], "tags": []}, {"author": "Kyle Machulis \u003ckyle@nonpolynomial.com\u003e", "branch": "default", "desc": "Bug 1469879 - Add check for closed socket on Multicast IPC parent funcs. r=baku, a=lizzard\n\nMozReview-Commit-ID: CaNYPtgFz87", "files": ["dom/network/UDPSocketParent.cpp"], "git_node": null, "git_parents": [null], "node": "a1992e3234f46097648c27175d2ac8b540f561df", "parents": ["187686c0fc83b263b03659edbc1b5051d7df1936"], "tags": []}, {"author": "Lina Cambridge \u003clina@yakshaving.ninja\u003e", "branch": "default", "desc": "Bug 1472835 - Exclude the root from the `parentsWithGaps` check in the bookmarks mirror. r=markh, a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1918", "files": ["toolkit/components/places/SyncedBookmarksMirror.jsm", "toolkit/components/places/tests/sync/test_bookmark_corruption.js"], "git_node": null, "git_parents": [null], "node": "6ce7f5a3eaf3e8935f8d6b9c60b3a3fd8558828b", "parents": ["a1992e3234f46097648c27175d2ac8b540f561df"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1472137 - Prevent mutex reentry in mscom::Interceptor::Create if GetInitialInterceptorForIID fails. r=aklotz, a=RyanVM\n\nIf GetInitialInterceptorForIID fails, the live set lock is not released in most cases, but the newly created Interceptor will be destroyed.\nThe Interceptor's destructor tries to acquire the live set lock again, but that causes a deadlock, since reentry is no longer allowed for a mutex after bug 1364624.\nGetInitialInterceptorForIID now ensures the live set lock is always released  on failure, thus preventing the deadlock.\n\nMozReview-Commit-ID: z0Q7JLnJXQ", "files": ["accessible/ipc/win/HandlerProvider.cpp", "ipc/mscom/Interceptor.cpp", "ipc/mscom/Utils.h"], "git_node": null, "git_parents": [null], "node": "505d8765ce63f12bbeca8e7be96e52033a137687", "parents": ["6ce7f5a3eaf3e8935f8d6b9c60b3a3fd8558828b"], "tags": []}], "date": 1530663697, "git_changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "9433": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\naz -\u003e 89c0c979bcd8\nbg -\u003e 8c2bedf7c4a6\ncy -\u003e bac55ec13dc2\nes-CL -\u003e 454984340faa\nes-MX -\u003e 19c2c80278f1\nka -\u003e 13ed338989ee\nkab -\u003e b54eef9460a6\nms -\u003e 12b185e9a456\nte -\u003e 9c9f3d45dc97\nuk -\u003e 7e9fb9e150cf\nur -\u003e 8748ba9b7c23", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "1e5070713a74afa001c8316f4d2a86a847f0945d", "parents": ["505d8765ce63f12bbeca8e7be96e52033a137687"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\naz -\u003e 89c0c979bcd8\nbg -\u003e f4a1ac5335d8\nbr -\u003e 6adea6129193\nbs -\u003e ac739d6dac29\ncs -\u003e 4850292f0bbd\ncy -\u003e bac55ec13dc2\nes-AR -\u003e ac96e9983c5a\nes-CL -\u003e 454984340faa\nes-ES -\u003e c12ae37263f4\nes-MX -\u003e 19c2c80278f1\nhe -\u003e 685be298f1e4\nhi-IN -\u003e 46166eb7458f\nis -\u003e c28b679bde09\nit -\u003e 640ada79194a\nka -\u003e 97d33c691557\nkab -\u003e b54eef9460a6\nkm -\u003e 62d667170902\nms -\u003e 12b185e9a456\npl -\u003e c4977e7c5c26\nsr -\u003e aeecaf9231ea\nta -\u003e d1267956537a\nte -\u003e 45421d80dd98\nuk -\u003e 7e9fb9e150cf\nur -\u003e a265f7e3e850\nvi -\u003e d17c1750348d", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "eb97b84f4bfe07c09a50c3791c3ebfba3b6c5898", "parents": ["1e5070713a74afa001c8316f4d2a86a847f0945d"], "tags": []}], "date": 1530665233, "git_changesets": [null, null], "user": "ffxbld"}, "9434": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nit -\u003e f61eeea32db5\nms -\u003e 541f9a6c3c1b", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "4abc05a9b1c87915f0f6891939baa274bbc6555a", "parents": ["eb97b84f4bfe07c09a50c3791c3ebfba3b6c5898"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nfr -\u003e db02b3395a0e\nit -\u003e f61eeea32db5\nms -\u003e 541f9a6c3c1b\nte -\u003e 947e68faf80c", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "01d488872338e4b562af1011bc8a1aa7b9aa6af9", "parents": ["4abc05a9b1c87915f0f6891939baa274bbc6555a"], "tags": []}], "date": 1530696150, "git_changesets": [null,