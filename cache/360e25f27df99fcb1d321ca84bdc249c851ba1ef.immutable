null], "node": "f0c51d4ad04b0f66e85f6ffe1a6d20bd2c6694f2", "parents": ["ae4c7cec37a4405685048480105f5df532ab8369"], "tags": []}, {"author": "Kirk Steuber \u003cksteuber@mozilla.com\u003e", "branch": "default", "desc": "Bug 1460082 - Allow DisableAppUpdate and DisableSystemAddonUpdate policies outside of the ESR. r=Felipe, a=lizzard\n\nChanging enterprise_only to machine_only will allow these policies outside of the ESR, but not in HKEY_CURRENT_USER.\n\nMozReview-Commit-ID: UAT6CPFOWO", "files": ["browser/components/enterprisepolicies/schemas/policies-schema.json"], "git_node": null, "git_parents": [null], "node": "e28ce913332af9fdf5d3efb11f0588e4d5476230", "parents": ["f0c51d4ad04b0f66e85f6ffe1a6d20bd2c6694f2"], "tags": []}], "date": 1530539385, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9420": {"changesets": [{"author": "Andreas Farre \u003cfarre@mozilla.com\u003e", "branch": "default", "desc": "Bug 1468843 - Change telemetry to only record docgroup count for http(s). r=nika, data-review=chutten, a=lizzard\n\nRename TOTAL_DOCGROUPS_PER_TABGROUP to\nTOTAL_HTTP_DOCGROUPS_PER_TABGROUP, that collects telemetry for all\ndocgroups per tabgroup, but only for uris with http:// or https://\nschemes.\n\nRename ACTIVE_DOCGROUPS_PER_TABGROUP to\nACTIVE_HTTP_DOCGROUPS_PER_TABGROUP, that collects telemetry for active\ndocgroups per tabgroup, but only for uris with http:// or https://\nschemes.", "files": ["dom/base/nsDocument.cpp", "toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "69bd2a456d6b6a54dd1ccb797570deaad5f42fe7", "parents": ["e28ce913332af9fdf5d3efb11f0588e4d5476230"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1471415 - Fix logic in nsXULPopupManager::ShouldConsumeOnMouseWheelEvent. r=smaug, a=RyanVM\n\nIt was accidentally toggled in bug 1423990.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1863", "files": ["layout/xul/nsXULPopupManager.cpp"], "git_node": null, "git_parents": [null], "node": "7765ed93426ca9003ddbc38491bf9f082932789a", "parents": ["69bd2a456d6b6a54dd1ccb797570deaad5f42fe7"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1465458 - Fix launching downloads without a file extension on Windows. r=mak, a=lizzard\n\nMozReview-Commit-ID: 6VYjHM46gZx", "files": ["toolkit/components/downloads/DownloadIntegration.jsm"], "git_node": null, "git_parents": [null], "node": "cd20a5a8658bb5bb119ba77dfe3db38b5c1820e6", "parents": ["7765ed93426ca9003ddbc38491bf9f082932789a"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1471095 - Don't do extra work we don't need to in ReparentWrappersInSubtree. r=smaug, a=RyanVM", "files": ["dom/base/nsINode.cpp", "layout/base/nsCSSFrameConstructor.cpp"], "git_node": null, "git_parents": [null], "node": "30c32c21df574fa81317837ded730aa03d296712", "parents": ["cd20a5a8658bb5bb119ba77dfe3db38b5c1820e6"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1471375 - Reports about missing activity stream content on new tab page and about:preferences#home panel. r=k88hudson, a=RyanVM", "files": ["browser/extensions/activity-stream/install.rdf.in", "browser/extensions/activity-stream/lib/Store.jsm", "browser/extensions/activity-stream/test/unit/lib/Store.test.js"], "git_node": null, "git_parents": [null], "node": "6f9103e33409b8465cad9fa46c05defb130c0ece", "parents": ["30c32c21df574fa81317837ded730aa03d296712"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1472127 - Update to Firefox 61.0 may wrongly remove incorrectly parented roots. r=standard8, a=lizzard\n\nMozReview-Commit-ID: 6ZRBERi0PaW", "files": ["toolkit/components/places/Database.cpp", "toolkit/components/places/tests/migration/test_