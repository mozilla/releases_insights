ette/client/marionette_driver/geckoinstance.py"], "git_node": null, "git_parents": [null], "node": "e407c763b97d170e714b88cadad64d051181021d", "parents": ["5ce33c943102e616099282a90984996886f537e1"], "tags": []}, {"author": "Dave Hunt \u003cdhunt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1470122 - Bump mozinstall to 1.16.0; r=whimboo\n\nMozReview-Commit-ID: LtxU2upM8Oo", "files": ["testing/mozbase/mozinstall/setup.py", "testing/tps/setup.py"], "git_node": null, "git_parents": [null], "node": "99a313afa9b336b696d992dded8227ebbdb6074d", "parents": ["e407c763b97d170e714b88cadad64d051181021d"], "tags": []}, {"author": "Francesco Lodolo (:flod) \u003cflod@lodolo.net\u003e", "branch": "default", "desc": "Bug 1470138 - Add localization comment to RunningClearSiteDataValue and fix message r=baku\n\nMozReview-Commit-ID: 5c8wwjqG9Pj", "files": ["dom/locales/en-US/chrome/security/security.properties"], "git_node": null, "git_parents": [null], "node": "010be7898590efe6107f8ab5e5723217c584c737", "parents": ["99a313afa9b336b696d992dded8227ebbdb6074d"], "tags": []}, {"author": "Daniel Stenberg \u003cdaniel@haxx.se\u003e", "branch": "default", "desc": "bug 1470093 - fix telemetry::DNS_TRR_LOOKUP_TIME r=mcmanus\n\nMozReview-Commit-ID: 80jrEQ4kLM6", "files": ["netwerk/dns/nsHostResolver.cpp"], "git_node": null, "git_parents": [null], "node": "f9c5cbd49b985bb3e4f6eb937ee5fba6ed9dc679", "parents": ["010be7898590efe6107f8ab5e5723217c584c737"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1441743 - [Wayland] Don't draw directly to frame buffer for partial window updates, r=jhorak\n\nWhen only a part of window is updated we need to clip that drawing.\nWe use image surface for that as WindowSurfaceX11Image does.\n\nMozReview-Commit-ID: 13znE1ZszB8", "files": ["widget/gtk/WindowSurfaceWayland.cpp", "widget/gtk/WindowSurfaceWayland.h"], "git_node": null, "git_parents": [null], "node": "6ac15a2e69147a7d09209fdec9a2009