d\n\nMozReview-Commit-ID: GI6rL2Kv0D5", "files": ["browser/branding/aurora/background.png", "browser/branding/official/background.png"], "git_node": null, "git_parents": [null], "node": "a0d7247da1b7951c08867b5d5e8b8924dd0abc04", "parents": ["f5fd704dd43c3ee346efe848947d181b96a00a3b"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1465337 - Adjust tracking protection toggle and other right-hand-side buttons in the main menu to align their separators. r=dao a=lizzard\n\nMozReview-Commit-ID: 6u5AaSCMhr", "files": ["browser/themes/shared/customizableui/panelUI.inc.css"], "git_node": null, "git_parents": [null], "node": "93c4df61e1d1bbffb8b37d9f0c8bed1141fd1a8f", "parents": ["a0d7247da1b7951c08867b5d5e8b8924dd0abc04"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1469354: Use the first continuation to get the layout parent style. r=mats a=lizzard\n\nContinuations do not have placeholders. There's a bunch of code that already\ndeals with that in other places in the tree.\n\nMozReview-Commit-ID: Htizql7692e", "files": ["layout/base/RestyleManager.cpp", "layout/base/crashtests/1469354.html", "layout/base/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "73e476e6f9d2eaed08c5270aa987adc6785a927b", "parents": ["93c4df61e1d1bbffb8b37d9f0c8bed1141fd1a8f"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1469959 - Don't use relatedTarget to check if the ObjectInspector was focused by tabbing; r=bgrins a=lizzard\n\nBasically this rolls back the changes made to the reps bundle\nin Bug 1463415. This change will be backported in Github later\nso the fix can ride the train.\nA test is added to make sure we don't regress again.\n\nMozReview-Commit-ID: Csak2pPyTOR", "files": ["devtools/client/shared/components/reps/reps.js", "devtools/client/webconsole/test/mochitest/browser.ini", "devtools/client/webconsole/test/mochitest/browser_webconsole_object_inspector_scroll.js"], "git_node": null, "git_parents": [null], "node": "4b518c97f12c97eaae20d747e17530ce7dd80b7b", "parents": ["73e476e6f9d2eaed08c5270aa987adc6785a927b"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1470393 - Implement workaround for squashed favicon in the bookmarking panel. r=mak a=lizzard\n\nMozReview-Commit-ID: IjbeUoTgxWO", "files": ["browser/base/content/browser.xul", "browser/themes/shared/places/editBookmarkPanel.inc.css"], "git_node": null, "git_parents": [null], "node": "f514597a84c4f5be08c5ed5fe4a5e0371916897d", "parents": ["4b518c97f12c97eaae20d747e17530ce7dd80b7b"], "tags": []}, {"author": "J. Ryan Stinnett \u003cjryans@gmail.com\u003e", "branch": "default", "desc": "Bug 1470497 - Fix navigation after opening container in RDM. r=gl a=lizzard\n\nThis fixes the case of navigating a container tab from about:newtab to a remote\nsite.  This case triggers the process flip machinery where parent process is\ntold to manage the load.  We needed to allow certain session store messages for\nthis to complete successfully.", "files": ["devtools/client/responsive.html/browser/swap.js", "devtools/client/responsive.html/browser/tunnel.js", "devtools/client/responsive.html/test/browser/browser.ini", "devtools/client/responsive.html/test/browser/browser_container_tab.js", "devtools/client/responsive.html/test/browser/browser_contextual_identity.js", "devtools/client/responsive.html/test/browser/browser_preloaded_newtab.js", "devtools/client/responsive.html/test/browser/head.js", "devtools/client/shared/test/shared-head.js"], "git_node": null, "git_parents": [null], "node": "ed377d7086570469fba9e99b47f367c947e86f70", "parents": ["f514597a84c4f5be08c5ed5fe4a5e0371916897d"], "tags": []}, {"author": "Jan Beich \u003cjbeich@FreeBSD.org\u003e", "branch": "default", "desc": "Bug 1470938 - Unbreak build without 