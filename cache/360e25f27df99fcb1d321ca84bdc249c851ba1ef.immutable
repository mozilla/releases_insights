ll], "node": "25ffc90ec5745160a1b315f72df460a8e08a6b17", "parents": ["4137abca621df5ccf7835912d812ca6ef347698b"], "tags": []}, {"author": "Brendan Dahl \u003cbrendan.dahl@gmail.com\u003e", "branch": "default", "desc": "Bug 1475262 - Only ignore XUL persist on top level windows. r=smaug a=lizzard\n\nFixes the incorrect assumption that all XUL \u003cwindow\u003e elements are top level\nwindows and will have their attribute persistence handled by the\nnsXULWindow. An example of where this assumption fails is the password\nmanager which opens a \u003cwindow\u003e within a sub dialog that has no nsXULWindow.\n\nMozReview-Commit-ID: 1f59QPIz42s", "files": ["dom/xul/XULDocument.cpp"], "git_node": null, "git_parents": [null], "node": "558c190298cd65b630f769fd9e0fa7466ee93fec", "parents": ["25ffc90ec5745160a1b315f72df460a8e08a6b17"], "tags": []}], "date": 1532525113, "git_changesets": [null, null, null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "9536": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nnb-NO -\u003e f0800b5e483f\nnl -\u003e 4cbc1a1360ee\noc -\u003e c197615ca682\npl -\u003e f00faca9bcea\npt-BR -\u003e 30a829556ad6\nth -\u003e d48ae7fc726e\nzh-CN -\u003e 5b37051d97d8", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "9b58a99972ba027435b321b835f676123b2a57a0", "parents": ["558c190298cd65b630f769fd9e0fa7466ee93fec"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nnb-NO -\u003e 3a977f1abb57\nnl -\u003e b68748984f1a\npl -\u003e f00faca9bcea\npt-BR -\u003e 3dc67ba26aba\nsv-SE -\u003e ffae28b382e0\nte -\u003e d9ed9bb141eb\nth -\u003e bcd0e3f50a86\nur -\u003e 86be0e41dcab\nzh-CN -\u003e 5b37051d97d8", "fi