trunk/webrtc/modules/desktop_capture/screen_capturer_mac.mm"], "git_node": null, "git_parents": [null], "node": "a7bd9bd361a3da29ab46cc4bbedc34270d23fd5a", "parents": ["89b72c9c5db5dc38c0dd6547eac9b1b1a777c53f"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1409018 - Defer RegisterRefreshAndMoveHandlers call; r=pehrsons\n\nThis defers the call to register the refresh and move handlers to the\nCaptureFrame() call so that they will be registered on the ScreenCapture\nthread.\n\nThis also calls CFRunLoopInMode to process any pending sources in the\nrun loop corresponding to the ScreenCapture thread so that the\nrefresh and move notifications are received.\n\nMozReview-Commit-ID: G4aEchnGuUz", "files": ["media/webrtc/trunk/webrtc/modules/desktop_capture/screen_capturer_mac.mm"], "git_node": null, "git_parents": [null], "node": "1a8d462805f02ed0314c6da98e37000ccdd04592", "parents": ["a7bd9bd361a3da29ab46cc4bbedc34270d23fd5a"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1409018 - Re-enable test_getUserMedia_basicScreenshare; r=pehrsons\n\nMozReview-Commit-ID: J5yvuOFoMmv", "files": ["dom/media/tests/mochitest/mochitest.ini"], "git_node": null, "git_parents": [null], "node": "0708df4d3b7a8c38dd32f52d3199e5a27a0758f2", "parents": ["1a8d462805f02ed0314c6da98e37000ccdd04592"], "tags": []}, {"author": "Brindusan Cristian \u003ccbrindusan@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 1c40cef0e222 (bug 1469318) for mochitest failures on test_ext_all_apis.html CLOSED TREE", "files": ["toolkit/components/extensions/schemas/theme.json", "toolkit/components/extensions/test/browser/browser_ext_themes_getCurrent_differentExt.js", "toolkit/components/extensions/test/browser/browser_ext_themes_static_onUpdated.js"], "git_node": null, "git_parents": [null], "node": "c2ced94f52aade1532494cfdd31d6fdacd3f1edf", "parents": ["0708df4d3b7a8c38dd32f52d3199