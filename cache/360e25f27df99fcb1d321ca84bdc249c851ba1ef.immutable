pers.h"], "git_node": null, "git_parents": [null], "node": "50dbda5a6c9be4d5935fe0a9d4bf40ea7e5c129f", "parents": ["75b79018fff9e0bf1eaeebec13290aed2a19ee90"], "tags": []}, {"author": "Mathieu Leplatre \u003cmathieu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1476934 - Disable the dump for the tippytop collection r=nanj a=lizzard\n\nMozReview-Commit-ID: FC1FMmTHRuO", "files": ["browser/installer/allowed-dupes.mn", "services/settings/dumps/main/example.json", "services/settings/dumps/main/moz.build", "services/settings/dumps/main/tippytop.json", "services/settings/test/unit/test_remote_settings_poll.js"], "git_node": null, "git_parents": [null], "node": "9913c644c5c01069ccabd0d678954915502c2cff", "parents": ["50dbda5a6c9be4d5935fe0a9d4bf40ea7e5c129f"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1468968 - Restrict the concept of root icons and remove orphans, to avoid possible privacy leaks. r=Standard8,mikedeboer a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D2122", "files": ["toolkit/components/places/History.jsm", "toolkit/components/places/PlacesDBUtils.jsm", "toolkit/components/places/nsFaviconService.cpp", "toolkit/components/places/tests/favicons/test_root_icons.js", "toolkit/components/places/tests/history/test_remove.js", "toolkit/components/places/tests/maintenance/test_preventive_maintenance.js"], "git_node": null, "git_parents": [null], "node": "5f615d0ac261e5d59de51e09bb863aee5c86c6dd", "parents": ["9913c644c5c01069ccabd0d678954915502c2cff"], "tags": []}, {"author": "Shane Caraveo \u003cscaraveo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1461695 change tabs.onUpdated filter name to isArticle, r=aswan a=lizzard\n\nMozReview-Commit-ID: Ha0nJPMTYkJ", "files": ["browser/components/extensions/parent/ext-tabs.js", "browser/components/extensions/schemas/tabs.json", "browser/components/extensions/test/browser/browser_ext_tabs_onUpdated_filter.js"], "git_node": null, "git_parents": [null], "node": "336b10b00c1c9d92993365e3743ff0f192957edf", "parents": ["5f615d0ac261e5d59de51e09bb863aee5c86c6dd"], "tags": []}], "date": 1532690536, "git_changesets": [null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "9546": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 23bc64507f53b0cba44c72f72539716adcf02d68 with FIREFOX_62_0b12_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "a676f0c9a9d5b39244f2ea8ea14d9d7d64a982c6", "parents": ["336b10b00c1c9d92993365e3743ff0f192957edf"], "tags": []}], "date": 1532702965, "git_changesets": [null], "user": "Callek@gmail.com"}, "9547": {"changesets": [{"author": "dvarga \u003cdvarga@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset db7a4be05d8f (bug 1470394) for failing browser-chrome browser/base/content/test/general/browser_bookmark_popup.js on windows debug a=backout", "files": ["browser/base/content/browser.xul", "browser/themes/linux/places/editBookmark.css", "browser/themes/osx/places/editBookmark.css", "browser/themes/shared/places/editBookmarkPanel.inc.css", "browser/themes/windows/places/editBookmark.css"], "git_node": null, "git_parents": [null], "node": "d96403683b5b001d08e88efab5a02dc044ce7eef", "parents": ["a676f0c9a9d5b39244f2ea8ea14d9d7d64a982c6"], "tags": []}], "date": 1532716772, "git_changesets": [null], "user": "dvarga@mozilla.com"}, "9548": {"changesets": [{"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1414776 - [fxui] Change testcases from mozqa.com to badssl.com and mixed-content-tests-mozilla.org. r=ato a=ato\n\nMozReview-Commit-ID: DadY39FdZQT", "files": ["testing/firefox-ui/tests/functional/security/test_dv_certificate.py", "testing/firefox-ui/tests/functional/security/test_ev_certificate.py", "testing/firefox-ui/tests/functional/