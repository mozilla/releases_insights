ositorWidget.h"], "git_node": null, "git_parents": [null], "node": "0ef199e4d83dad031c14f97d9524a30f0b0cf97e", "parents": ["9d9f90b47174476dca400ab03cf88512c41cce68"], "tags": []}, {"author": "Csoregi Natalia \u003cncsoregi@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to inbound.  a=merge CLOSED TREE", "files": ["browser/themes/shared/identity-block/tracking-protection-16.svg", "mobile/android/services/README.txt", "mobile/android/services/src/main/java/org/mozilla/gecko/sync/README.txt", "mobile/android/thirdparty/ch/boye/httpclientandroidlib/README.txt", "third_party/rust/quote/src/tokens.rs", "third_party/rust/syn/src/ident.rs", "toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null, null], "node": "2a08d68ca8f3bde85b102fd4958182b99bf0886c", "parents": ["0ef199e4d83dad031c14f97d9524a30f0b0cf97e", "27e90ec610a4c8f6b2a73d79cb1a4df38e822e6a"], "tags": []}, {"author": "Justin Wood \u003cCallek@gmail.com\u003e", "branch": "default", "desc": "Bug 1301782 - Be explicit about what tags to create. r=aki\n\nfor Tag RC releases\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1757", "files": ["taskcluster/ci/release-version-bump/kind.yml", "taskcluster/taskgraph/transforms/task.py"], "git_node": null, "git_parents": [null], "node": "eb64af8f8cec26d454e86dca7a3242180bdad348", "parents": ["2a08d68ca8f3bde85b102fd4958182b99bf0886c"], "tags": []}, {"author": "Justin Wood \u003cCallek@gmail.com\u003e", "branch": "default", "desc": "Bug 1301782 - Perform buildN tagging at promote phase. r=aki\n\nfor Tag RC releases\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1758", "files": ["taskcluster/ci/release-early-tagging/kind.yml", "taskcluster/ci/release-version-bump/kind.yml", "taskcluster/docs/kinds.rst"], "git_node": null, "git_parents": [null], "node": "5abb841c6ec2cc629f33a0d519fb879d70e51d7d", "parents": ["eb64af8f8cec26d454e86dca7a3242180bdad348"], "tags": []}, {"author": "Bogdan Tara \u003cbtara@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 0ef199e4d83d (bug 1467363) for failures on BlockingResourceBase.cpp CLOSED TREE", "files": ["widget/windows/WinCompositorWidget.cpp", "widget/windows/WinCompositorWidget.h"], "git_node": null, "git_parents": [null], "node": "6c29e4fc89c79a9a710eaa349f138cc84115ffd8", "parents": ["5abb841c6ec2cc629f33a0d519fb879d70e51d7d"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1447951 - Store nsDynamicAtom's chars after the end of the object. r=froydnj\n\nThis reduces memory usage because we only need one allocation instead of two\nfor the dynamic atom and its chars, and because we don't need to store a\nrefcount and a size. It precludes sharing of chars between dynamic atoms, but\nwe weren't benefiting much from that anyway.\n\nThis reduces per-process memory usage by up to several hundred KiB on my\nLinux64 box.\n\nOne consequence of this change is that we need to allocate + copy in\nDOMString::SetKnownLiveAtom(), which could make some things slower.", "files": ["dom/bindings/DOMString.h", "parser/html/nsHtml5AtomTable.cpp", "parser/html/nsHtml5String.h", "servo/components/style/gecko_string_cache/mod.rs", "toolkit/components/aboutmemory/tests/test_memoryReporters.xul", "xpcom/base/nsMemoryReporterManager.cpp", "xpcom/ds/nsAtom.h", "xpcom/ds/nsAtomTable.cpp", "xpcom/ds/nsAtomTable.h", "xpcom/tests/gtest/TestAtoms.cpp"], "git_node": null, "git_parents": [null], "node": "b67973aeb2af232a387f926e0103a140c98f8865", "parents": ["6c29e4fc89c79a9a710eaa349f138cc84115ffd8"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1470145: Better debugging for stylesheets and URLs. r=xidorn\n\nMozReview-Commit-ID: FIcz2K1ZYX0\n", "files": ["layout/style/ServoBindings.cpp", "layout/style/ServoBindings.h", "servo/components/style/error_reporting.rs", "servo/components/style/gecko/data.rs", "servo/components/style/gecko/url.rs", "servo/components/style/gecko_bindings/sugar/refptr.rs", "servo/components/style/stylesheets/mod.rs", "servo/components/style/stylesheets/stylesheet.rs", "servo/ports/geckolib/glue.rs", "servo/ports/geckolib/stylesheet_loader.rs"], "git_node": null, "git_parents": [null], "node": "a1eb2582c7d29e2d6182e7eadaec56a91d6fe4ff", "parents": ["b67973aeb2af232a387f926e0103a140c98f8865"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1470145: Better debugging for media-query related code and ua-cache. r=xidorn\n\nMozReview-Commit-ID: 3XHAxK2BOTS\n", "files": ["servo/components/style/gecko/media_queries.rs", "servo/components/style/media_queries/media_list.rs", "servo/components/style/stylist.rs", "servo/components/style_derive/to_css.rs"], "git_node": null, "git_parents": [null], "node": "1440edb27dc4460e268387c57459506dbcbfe256", "parents": ["a1eb2582c7d29e2d6182e7eadaec56a91d6fe4ff"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1470087: Tests for getComputedStyle on display: none subtrees. r=heycam\n\nMozReview-Commit-ID: B7UNVcTW0WG\n", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/meta/css/cssom/getComputedStyle-display-none-001.html.ini", "testing/web-platform/tests/css/cssom/getComputedStyle-display-none-001.html", "testing/web-platform/tests/css/cssom/getComputedStyle-display-none-002.html"], "git_node": null, "git_parents": [null], "node": "393be8743349aa97b9c3413cdc164f2d976cf34d", "parents": ["1440edb27dc4460e268387c57459506dbcbfe256"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1468133: Remove the optimization to lazily load non-SVG styles since it's not relevant anymore. r=heycam\n\nThis was a memory-saving optimization introduced as part of dependencies for bug\n686875, but a more general system landed in bug 77999 for Gecko and\nhttps://github.com/servo/servo/pull/18509 for Servo.\n\nSo now it's probably even a bit of a pessimization (though probably not huge),\nand given this causes bugs like bug 1462742, bug 1157592, and bug 1468145, and\nfishiness like the one pointed out in this bug, we may as well remove it.\n\nThe performance impact of having to lookup through more rules should be minimal\ngiven the bloom filter and the rule hash optimizations.\n\nThis makes me wonder whether we could remove the whole concept of on-demand UA\nsheets, since they've caused pain, for example, when the frontend people try\nloading \u003csvg\u003es from NAC (since that triggers sheet loading from frame\nconstruction, which is not good). I'm not concerned about loading mathml.css and\nsvg.css everywhere, though xul.css may not be as doable since it adds a bunch of\nattribute-dependent selectors. Though on the other hand I asserted in the\nxul.css code and we don't load it in content with \u003cvideo\u003e / \u003cinput\ntype=\"date/time/etc\"\u003e and such, afaict, so maybe now that legacy addons are gone\nwe can remove that sheet from content processes altogether.\n\nMozReview-Commit-ID: 9JCWNZj6BkT\n", "files": ["dom/base/nsDocument.cpp", "dom/base/nsIDocument.h", "dom/svg/SVGDocument.cpp", "dom/svg/SVGDocument.h", "dom/svg/SVGForeignObjectElement.cpp", "dom/svg/SVGForeignObjectElement.h", "dom/svg/SVGSVGElement.cpp", "dom/xul/nsXULElement.cpp", "layout/base/nsDocumentViewer.cpp", "layout/printing/nsPrintJob.cpp", "layout/svg/svg.css"], "git_node": null, "git_parents": [null], "node": "4c8f6b544de1a3918199086d1bd4474855581bb5", "parents": ["393be8743349aa97b9c3413cdc164f2d976cf34d"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1470150: noscript rules should not apply to non-HTML elements. r=heycam\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1749\n\nMozReview-Commit-ID: JhNFlHbtDw6\n", "files": ["layout/style/res/noscript.css", "testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/html/scripting/the-noscript-element/non-html-noscript.html"], "git_node": null, "git_parents": [null], "node": "e27f16329c725d807150863588ed572b2990c60c", "parents": ["4c8f6b544de1a3918199086d1bd4474855581bb5"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1410578: Make \u003clink rel=\"stylesheet\"\u003e work in shadow trees. r=heycam\n\nSummary: Somewhat straight-forward, mostly removing special-casing.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1761\n\nMozReview-Commit-ID: 6f8duD4pGrl\n", "files": ["dom/base/nsStyleLinkElement.cpp", "dom/html/HTMLLinkElement.cpp", "dom/tests/mochitest/webcomponents/test_shadowroot_inert_element.html", "layout/style/Loader.cpp", "testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/css/css-scoping/shadow-link-rel-stylesheet-no-style-leak.html", "testing/web-platform/tests/css/css-scoping/shadow-link-rel-stylesheet.html"], "git_node": null, "git_parents": [null], "node": "d7b2d2d11109e2cd17e2f68960260631560d03f3", "parents": ["e27f16329c725d807150863588ed572b2990c60c"], "tags": []}, {"author": "Barry Chen \u003cbchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1465581 - Export Screenshots 33.0.0 to Firefox (translations only); r=flod,ianbicking\n\nMozReview-Commit-ID: 2CXjtCJ6xvm", "files": ["browser/extensions/screenshots/moz.build", "browser/extensions/screenshots/webextension/_locales/crh/messages.json", "browser/extensions/screenshots/webextension/_locales/gn/messages.json", "browser/extensions/screenshots/webextension/_locales/ia/messages.json", "browser/extensions/screenshots/webextension/_locales/ka/messages.json", "browser/extensions/screenshots/webextension/_locales/ko/messages.json", "browser/extensions/screenshots/webextension/_locales/lo/messages.json", "browser/extensions/screenshots/webextension/_locales/mai/messages.json", "browser/extensions/screenshots/webextension/_locales/ro/messages.json"], "git_node": null, "git_parents": [null], "node": "5d075fe8282751cc0be0a879af3f4a0be72d157b", "parents": ["35dd3b1bd10be61a53952723c726534c8c3e599b"], "tags": []}, {"author": "Barry Chen \u003cbchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1465581 - Export Screenshots 33.0.0 to Firefox (upgrade Raven to 3.25.2); r=ianbicking,_6a68\n\nMozReview-Commit-ID: 67A865KrF3z", "files": ["browser/extensions/screenshots/webextension/build/raven.js"], "git_node": null, "git_parents": [null], "node": "3dda0c68e6bd7755f3dd31c5c2042aca751af3ba", "parents": ["5d075fe8282751cc0be0a879af3f4a0be72d157b"], "tags": []}, {"author": "Barry Chen \u003cbchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1465581 - Export Screenshots 33.0.0 to Firefox (code excluding translations and Raven update); r=ianbicking,_6a68\n\nMozReview-Commit-ID: FrvoD9G74mJ", "files": ["browser/extensions/screenshots/bootstrap.js", "browser/extensions/screenshots/install.rdf", "browser/extensions/screenshots/moz.build", "browser/extensions/screenshots/webextension/assertIsBlankDocument.js", "browser/extensions/screenshots/webextension/assertIsTrusted.js", "browser/extensions/screenshots/webextension/background/analytics.js", "browser/extensions/screenshots/webextension/background/main.js", "browser/extensions/screenshots/webextension/background/selectorLoader.js", "browser/extensions/screenshots/webextension/background/takeshot.js", "browser/extensions/screenshots/webextension/build/inlineSelectionCss.js", "browser/extensions/screenshots/webextension/build/selection.js", "browser/extensions/screenshots/webextension/build/thumbnailGenerator.js", "browser/extensions/screenshots/webextension/icons/copied-notification.svg", "browser/extensions/screenshots/webextension/icons/copy.png", "browser/extensions/screenshots/webextension/log.js", "browser/extensions/screenshots/webextension/manifest.json", "browser/extensions/screenshots/webextension/randomString.js", "browser/extensions/screenshots/webextension/selector/callBackground.js", "browser/extensions/screenshots/webextension/selector/shooter.js", "browser/extensions/screenshots/webextension/selector/ui.js", "browser/extensions/screenshots/webextension/selector/uicontrol.js"], "git_node": null, "git_parents": [null], "node": "3f8b00d17eea04f7849a42b855618b83c3409402", "parents": ["3dda0c68e6bd7755f3dd31c5c2042aca751af3ba"], "tags": []}, {"author": "Dustin J. Mitchell \u003cdustin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1468627 - add docs pointing to ci-admin and ci-configuration; r=tomprince\n\nThis is just enough to make these repos discoverable and suggest their usage.\nAnything more would duplicate documentation in those repositories.\n\nMozReview-Commit-ID: 1WNEsoQBB9U", "files": ["taskcluster/docs/actions.rst", "taskcluster/docs/index.rst", "taskcluster/docs/taskcluster-config.rst"], "git_node": null, "git_parents": [null], "node": "927bbe6abacff9b55d54c9c52d6a656f0a46112b", "parents": ["3f8b00d17eea04f7849a42b855618b83c3409402"], "tags": []}, {"author": "Alex Gaynor \u003cagaynor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1470181 - handle deserialization failure gracefully in JS IPC; r=evilpie\n\nThis primarily effects the efficiency of fuzzing.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1751", "files": ["js/ipc/WrapperOwner.cpp"], "git_node": null, "git_parents": [null], "node": "91899c39ed9ed09aebc5883c30ed79a194c38d9a", "parents": ["927bbe6abacff9b55d54c9c52d6a656f0a46112b"], "tags": []}, {"author": "Brian Grinstead \u003cbgrinstead@mozilla.com\u003e", "branch": "default", "desc": "Bug 1466833 - Upgrade the \u003cxul:deck\u003e inside of search-one-offs at the beginning of the XBL constructor;r=timdream\n\nRight now, a XBL \u003cconstructor\u003e runs before Custom Elements inside of its\n\u003ccontent\u003e get upgraded. This leads to unexpected behavior where deck.selectedIndex = N\ncauses selectedIndex to get set as an expando property on the DOM node rather\nthan running the setter defined by the Custom Element.\n\nOnce the Custom Element does finally get upgraded, the selectedIndex getter and\nsetter don't get attached since there's an expando property with the same name.\n\nThis isn't a case we want to have to support from calling code. So this patch fixes\nthis one case by manually upgrading the element inside the constructor before\nanything accesses the node. In Bug 1470242 we are planning to make this happen\nbehind the scenes so we don't need to do this for every CE inside of \u003ccontent\u003e.\n\nMozReview-Commit-ID: LbXKKVeBYyQ", "files": ["browser/components/search/content/search.xml"], "git_node": null, "git_parents": [null], "node": "c1561409e431468169a6f22acaece537fe3de934", "parents": ["91899c39ed9ed09aebc5883c30ed79a194c38d9a"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1470020 - Part 1 - Don't show the \"Enable Protection\" button when it links to the TP preferences. r=florian\n\nUX found this confusing and unnecessary, after all.\n\nMozReview-Commit-ID: DSBu8Xyo3YO", "files": ["browser/base/content/browser-trackingprotection.js", "browser/base/content/test/trackingUI/browser_trackingUI_open_preferences.js", "browser/base/content/test/trackingUI/browser_trackingUI_reload_hint.js", "browser/base/content/test/trackingUI/browser_trackingUI_state.js", "browser/themes/shared/controlcenter/panel.inc.css"], "git_node": null, "git_parents": [null], "node": "b7af8264a3368382eedcd25bb691a5ccb16d8f96", "parents": ["c1561409e431468169a6f22acaece537fe3de934"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1470020 - Part 2 - Add specific states for when the user has added a TP exception to the TP section of the identity popup. r=florian\n\nWe used to give this all the same \"tracking-loaded\" state, but now we want to differentiate between:\n\n- Tracking loaded because TP is off\n- Tracking loaded because of an exception\n- Tracking not loaded but the site has an exception, which we want to allow the user to remove (if TP is on)\n\nMozReview-Commit-ID: E9j0Roq1bsH", "files": ["browser/base/content/browser-trackingprotection.js", "browser/base/content/test/general/browser_trackingUI_5.js", "browser/base/content/test/trackingUI/browser_trackingUI_state.js", "browser/components/controlcenter/content/panel.inc.xul", "browser/locales/en-US/chrome/browser/browser.dtd", "browser/themes/shared/controlcenter/panel.inc.css"], "git_node": null, "git_parents": [null], "node": "74475cd5a23339178bc475eeac89b13101fe8397", "parents": ["b7af8264a3368382eedcd25bb691a5ccb16d8f96"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1470020 - Part 3 - Updates to TP copy in the identity popup. r=florian\n\nMozReview-Commit-ID: 9LPReDTgjxJ", "files": ["browser/components/controlcenter/content/panel.inc.xul", "browser/locales/en-US/chrome/browser/browser.dtd"], "git_node": null, "git_parents": [null], "node": "00c94772a661b82c8fae8b520211cd47e8cd6251", "parents": ["74475cd5a23339178bc475eeac89b13101fe8397"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1470020 - Part 4 - Don't handle Tracking Protection UI on file: and about: URIs. r=florian\n\n... because these URIs are incompatible with TP.\n\nWe now show it on moz-extension: instead, which was forgotten previously.\n\nThis should probably have been in its own separate bug, but the changes in bug 1470020\nsurfaced this issue by throwing a lot of console errors when the baseURI was accessed,\nso I didn't want to defer the fix.\n\nMozReview-Commit-ID: 8KNV0oabv7Y", "files": ["browser/base/content/browser-trackingprotection.js", "browser/components/controlcenter/content/panel.inc.xul"], "git_node": null, "git_parents": [null], "node": "6e0fc38940b484f165c4e76551d1bc91ded92ab7", "parents": ["00c94772a661b82c8fae8b520211cd47e8cd6251"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1468671 - Enable identity popup headlines to span multiple lines. r=Paolo\n\nMozReview-Commit-ID: 8Y3Pql7n2U5", "files": ["browser/components/controlcenter/content/panel.inc.xul", "browser/themes/shared/controlcenter/panel.inc.css"], "git_node": null, "git_parents": [null], "node": "6fd500bb5dd80e0695920b6ecf343eab05ec46fc", "parents": ["6e0fc38940b484f165c4e76551d1bc91ded92ab7"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1470055 - Lift libstdc++ requirement relaxation when building clang-plugin. r=froydnj", "files": ["build/clang-plugin/Makefile.in"], "git_node": null, "git_parents": [null], "node": "db11d8b0ea4651c00eed270420fda3b282c13ca7", "parents": ["6fd500bb5dd80e0695920b6ecf343eab05ec46fc"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1466853 - Port stylebench and motionmark benchmarks test from talos to raptor. r=rwood\n\nCurrently stylebench and motionmark run on talos, these are ideal benchmarks to run on raptor\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1752", "files": ["taskcluster/ci/test/raptor.yml", "taskcluster/ci/test/test-sets.yml", "testing/mozharness/mozharness/mozilla/testing/raptor.py", "testing/raptor/raptor/benchmark.py", "testing/raptor/raptor/manifest.py", "testing/raptor/raptor/output.py", "testing/raptor/raptor/raptor.ini", "testing/raptor/raptor/raptor.py", "testing/raptor/raptor/tests/raptor-motionmark-animometer.ini", "testing/raptor/raptor/tests/raptor-motionmark-htmlsuite.ini", "testing/raptor/raptor/tests/raptor-stylebench.ini", "testing/raptor/webext/raptor/manifest.json", "thi