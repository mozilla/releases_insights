/src/ds/LifoAlloc.cpp"], "git_node": null, "git_parents": [null], "node": "bf0bb0c068781fe2aeef71dea5162bb4da6a9833", "parents": ["1a3e6da8c4dfed54c83d5f7b5a6176aa5d09e6ce"], "tags": []}], "date": 1531355700, "git_changesets": [null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9463": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset e662278dd698 (bug 1469889) for ESLint failures in test_json_cache_blacklist.js.", "files": ["toolkit/components/search/nsSearchService.js", "toolkit/components/search/tests/xpcshell/data/search_blacklist.json", "toolkit/components/search/tests/xpcshell/test_blacklist.js", "toolkit/components/search/tests/xpcshell/test_json_cache_blacklist.js", "toolkit/components/search/tests/xpcshell/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "36d63961e4f89660ec4268de764873fce274ab91", "parents": ["bf0bb0c068781fe2aeef71dea5162bb4da6a9833"], "tags": []}], "date": 1531356516, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "9464": {"changesets": [{"author": "Mihai Tabara \u003cmtabara@mozilla.com\u003e", "branch": "default", "desc": "Bug 1462064 - prevent release-bouncer-check test against sha1 installers. r=rail a=release", "files": ["testing/mozharness/configs/releases/bouncer_firefox_esr.py"], "git_node": null, "git_parents": [null], "node": "3d5cd8fb1b22d1d7dfc3469d3c91baf37fca84e7", "parents": ["36d63961e4f89660ec4268de764873fce274ab91"], "tags": []}], "date": 1531356874, "git_changesets": [null], "user": "mtabara@mozilla.com"}, "9465": {"changesets": [{"author": "ozoder \u003cozoder@redhat.com\u003e", "branch": "default", "desc": "Bug 1472611 - Don't link DBus 1.5.12 symbol dbus_validate_bus_name(). r=stransky, a=lizzard\n\nMozReview-Commit-ID: 6scVh8DOex2", "files": ["toolkit/components/remote/nsDBusRemoteService.cpp", "widget/xremoteclient/DBusRemoteClient.cpp"], "git_node": null, "git_parents": [null], "node": "9b330d91059107e972908036c1580ce98a477eb5", "parents": ["3d5cd8fb1b22d1d7dfc3469d3c91baf37fca84e7"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1474265 - Add missing semicolon at DBusRemoteClient.cpp. r=jhorak, a=lizzard\n\nMozReview-Commit-ID: HIz4gZOzfOE", "files": ["widget/xremoteclient/DBusRemoteClient.cpp"], "git_node": null, "git_parents": [null], "node": "f27de60fff477d7b61b5509fc2c9c9c098f5b953", "parents": ["9b330d91059107e972908036c1580ce98a477eb5"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1474007 - Null check to prevent crash when ipc::mscom::GetInitialInterceptorForIID fails after PublishTarget. r=aklotz, a=lizzard\n\nPublishTarget calls Unlock on our LiveSetAutolock.\nIt's possible for GetInitialInterceptorForIID to fail after this point.\nThis will cause the failure cleanup code to run, which tries to call Unlock again.\nHowever, the previous call to Unlock set mLiveSet to null, and Unlock previously didn't handle this case.\nNow, unlock is a no-op (in release builds) if it's already been called.\n\nMozReview-Commit-ID: 15ffXR6nKqc", "files": ["ipc/mscom/Interceptor.cpp"], "git_node": null, "git_parents": [null], "node": "a498f0d3e43c4536c404b3401679f88f8aee0ab9", "parents": ["f27de60fff477d7b61b5509fc2c9c9c098f5b953"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1469152 - Fix playback on older macOS systems and some 3rd party audio cards. r=kinetik, a=lizzard\n\nWe were using an audio API not available prior 10.12. Also add a workaround for 3rd party audio cards with unusually high channels count.\n\nThis cherry-pick cubeb commits 59f5cb4ba01f21c4ad87e9404d1e470408e18505 and dbd61924736fbe1a1caf1cbd544f7d197f1836f7\n\nDifferential Revision: https://phabricator.services.mozilla.com/D2041", "files": ["media/libcubeb/0001-Correctly-retrieve-the-output-layout-on-macOS-10.12.patch", "media/libcubeb/0002-Always-upmix-mono-to-the-first-two-channels-if-enoug.patch", "media/libcubeb/src/cubeb_audiounit.cpp", "media/libcubeb/src/cubeb_mixer.cpp", "media/libcubeb/update.sh"], "git_node": null, "git_parents": [null], "node": "7cb0a07dc9f06a001ca81ba6d3dfa938f0e376b4", "parents": ["a498f0d3e43c4536c404b3401679f88f8aee0ab9"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1462906 - Make HTTP throttling v2 algorithm Nightly-only due to video streaming regressions. r=mayhemer, a=lizzard", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "9ff4fe6505c29c371d45766e432f2f89f9e75222", "parents": ["7cb0a07dc9f06a001ca81ba6d3dfa938f0e376b4"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1472749 - Fix reader mode on nytimes website (sync from github 7d03bec52d0a0c4b22d044e06af84abb15a9f02b). r=jaws, a=lizzard", "files": ["toolkit/components/reader/Readability.js"], "git_node": null, "git_parents": [null], "node": "dc27393652a6cd2eeaccd1f7d9699a5669ef6822", "parents": ["9ff4fe6505c29c371d45766e432f2f89f9e75222"], "tags": []}], "date": 1531357938, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9466": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nsl -\u003e 7dd7bff2b82f\nsr -\u003e f31a74d15318\nsv-SE -\u003e b91ece9785d7", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "a29518a702dbb993627345989f2032b7f6216bf6", "parents": ["dc27393652a6cd2eeaccd1f7d9699a5669ef6822"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=