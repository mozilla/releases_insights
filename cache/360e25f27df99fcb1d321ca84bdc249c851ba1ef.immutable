, "node": "cd3ecb04a7bc9ace666dc34bd855c60824e0ed4c", "parents": ["6870eb4e9daada2e2bd615868553d64226c8d416"], "tags": []}, {"author": "Jan-Erik Rediger \u003cjrediger@mozilla.com\u003e", "branch": "default", "desc": "Bug 1466490 - Set Telemetry preference on startup. r=Dexter\n\nMozReview-Commit-ID: 1ac74K1Leoy", "files": ["toolkit/components/telemetry/tests/unit/head_GeckoView.js"], "git_node": null, "git_parents": [null], "node": "d282d6a159659f4e45fb91d3c164f90dcf0a5f46", "parents": ["cd3ecb04a7bc9ace666dc34bd855c60824e0ed4c"], "tags": []}, {"author": "Jan-Erik Rediger \u003cjrediger@mozilla.com\u003e", "branch": "default", "desc": "Bug 1466490 - Add multi-process xpcshell test for scalar semantics. r=Dexter\n\nThis follows the documentation example:\n\n* Scalar deserialization is started\n* \u201ctest\u201d scalar is incremented by \u201c10\u201d by the application -\u003e The operation [test, add, 10] is recorded into the list.\n* The state of the \u201ctest\u201d scalar is loaded off the persistence file, and the value \u201c14\u201d is set.\n* Deserialization is finished and the pending operations are applied.\n* The \u201ctest\u201d scalar is incremented by \u201c10\u201d, the value is now \u201c24\u201d\n\nIt does that in both the parent and the content process.\n\nMozReview-Commit-ID: CnzDcJ5o7jJ", "files": ["toolkit/components/telemetry/Scalars.yaml", "toolkit/components/telemetry/TelemetryScalar.h", "toolkit/components/telemetry/geckoview/TelemetryGeckoViewTesting.cpp", "toolkit/components/telemetry/geckoview/nsITelemetryGeckoViewTesting.idl", "toolkit/components/telemetry/tests/unit/head_GeckoView.js", "toolkit/components/telemetry/tests/unit/test_GeckoView_ScalarSemantics.js", "toolkit/components/telemetry/tests/unit/test_GeckoView_content_scalars.js", "toolkit/components/telemetry/tests/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "eb0d3d9a16c67acb93a23c87113d6f445ded8710", "parents": ["d282d6a159659f4e45fb91d3c164f90dcf0a5f46"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1463708 - only reset previews when leaving the panel, r=johannh\n\nMozReview-Commit-ID: 1KVseuWlEPU", "files": ["browser/components/customizableui/CustomizeMode.jsm"], "git_node": null, "git_parents": [null], "node": "b70d2c476c339ca54c0578d218d86efe37daed0f", "parents": ["eb0d3d9a16c67acb93a23c87113d6f445ded8710"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1448792 - [wdclient] Fix Element.clear() for unknown \"url\" property. r=ato\n\nMozReview-Commit-ID: 8lvsj6vWYrw", "files": ["testing/web-platform/tests/tools/webdriver/webdriver/client.py"], "git_node": null, "git_parents": [null], "node": "083b06a7b31e907c01979980ecdf23e92914772b", "parents": ["b70d2c476c339ca54c0578d218d86efe37daed0f"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1448792 - [wdspec] Add basic tests and user prompt tests for Element Send Keys. r=ato\n\nMozReview-Commit-ID: KzfN4OLM1YC", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/meta/webdriver/tests/element_send_keys/user_prompts.py.ini", "testing/web-platform/tests/webdriver/tests/element_send_keys/form_controls.py", "testing/web-platform/tests/webdriver/tests/element_send_keys/send_keys.py", "testing/web-platform/tests/webdriver/tests/element_send_keys/user_prompts.py"], "git_node": null, "git_parents": [null], "node": "604eed55c12a21fd4d14c0b005fcd7803611c683", "parents": ["083b06a7b31e907c01979980ecdf23e92914772b"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1448792 - [wdspec] Create global fixture and assert methods for event checks. r=ato\n\nA lot of commands will have to check for fired events on the\nelement under test. Having this global fixture and assert method\ndoesn't require a redefinition of the required code.\n\nMozReview-Commit-ID: K4jaaU4uHtP", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/webdriver/tests/conftest.py", "testing/web-platform/tests/webdriver/tests/element_clear/clear.py", "testing/web-platform/tests/webdriver/tests/element_send_keys/form_controls.py", "testing/web-platform/tests/webdriver/tests/support/asserts.py", "testing/web-platform/tests/webdriver/tests/support/fixtures.py"], "git_node": null, "git_parents": [null], "node": "793b358c6ae01cc330cdf1f4bbfbc8044c1a5072", "parents": ["604eed55c12a21fd4d14c0b005fcd7803611c683"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1448792 - [marionette][wdspec] Make Element Send Keys wdspec conforming for file uploads. r=ato\n\nThis patch fixes remaining bugs in Marionette for uploading\nfiles via \"element_send_keys\", and also adds support for\nmultiple file uploads.\n\nIt also adds Wdspec tests to proof the latest changes to\nthe WebDriver specification.\n\nMozReview-Commit-ID: 2OKGNxMvyMr", "files": ["testing/marionette/interaction.js", "testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/webdriver/tests/element_send_keys/conftest.py", "testing/web-platform/tests/webdriver/tests/element_send_keys/file_upload.py", "testing/web-platform/tests/webdriver/tests/support/asserts.py"], "git_node": null, "git_parents": [null], "node": "bd820cb9ca2dcf0e8067409d5e08d2da8fd0f9e0", "parents": ["793b358c6ae01cc330cdf1f4bbfbc8044c1a5072"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1448792 - [marionette][wdspec] Make Element Send Keys fire change event for \u003cinput type=file\u003e. r=ato\n\nAdds a wdspec test to ensure the latest WebDriver specification\nchanges for https://github.com/w3c/webdriver/pull/1262.\n\nMozReview-Commit-ID: CQqq8VjBobU", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/webdriver/tests/element_send_keys/events.py", "testing/web-platform/tests/webdriver/tests/element_send_keys/form_controls.py"], "git_node": null, "git_parents": [null], "node": "c26eb7edb08f6c7540a6f39d3dde16631a7a28a4", "parents": ["bd820cb9ca2dcf0e8067409d5e08d2da8fd0f9e0"], "tags": []}, {"author": "Francesco Lodolo (:flod) \u003cflod@lodolo.net\u003e", "branch": "default", "desc": "Bug 1467183 - Add documentation for Fluent migrations, r=gandalf,Pike,stas\n\nMozReview-Commit-ID: 8eaH4SaXfAu", "files": ["intl/l10n/docs/fluent_migrations.rst", "intl/l10n/docs/fluent_tutorial.rst", "intl/l10n/docs/index.rst"], "git_node": null, "git_parents": [null], "node": "97a8832286af822cdaedee500878fbf6f2976406", "parents": ["c26eb7edb08f6c7540a6f39d3dde16631a7a28a4"], "tags": []}, {"author": "Jan-Erik Rediger \u003cjrediger@mozilla.com\u003e", "branch": "default", "desc": "Bug 1466857 - Avoid sending an update ping if Telemetry is disabled. r=chutten\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1596", "files": ["toolkit/components/telemetry/UpdatePing.jsm", "toolkit/components/telemetry/tests/browser/browser_UpdatePingSuccess.js"], "git_node": null, "git_parents": [null], "node": "0d0e171c6919048c4908114fe6e3922fc9ccfbcb", "parents": ["97a8832286af822cdaedee500878fbf6f2976406"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Bug 1466139 - set animation panel ID depending on devtools.new-animationinspector.enabled. r=yulia\n\nMozReview-Commit-ID: H093tRApoPq", "files": ["devtools/client/shared/test/browser_telemetry_sidebar.js"], "git_node": null, "git_parents": [null], "node": "1c5bd07226cae0c640d95463b94e60c66db1f5a7", "parents": ["0d0e171c6919048c4908114fe6e3922fc9ccfbcb"], "tags": []}, {"author": "Nico Grunbaum \u003cna-g@nostrum.com\u003e", "branch": "default", "desc": "Bug 1456101 - ensure X11 DesktopCapture module is created on main thread r=dminor\n\nMozReview-Commit-ID: 8lP03135ttK", "files": ["dom/media/systemservices/VideoEngine.cpp", "media/webrtc/trunk/webrtc/video_engine/desktop_capture_impl.cc"], "git_node": null, "git_parents": [null], "node": "fb01c7ab313cced66ce02fdeb33c0a1deb993990", "parents": ["1c5bd07226cae0c640d95463b94e60c66db1f5a7"], "tags": []}, {"author": "J. Ryan Stinnett \u003cjryans@gmail.com\u003e", "branch": "default", "desc": "Bug 1469602 - Clean up custom host messages. r=ochameau\n\nSlightly simplify custom host messaging by removing the redundant stringify /\nparse.  This makes it simpler to ignore messages you might overhear.\n\nMozReview-Commit-ID: JZHAzZAVeHZ", "files": ["devtools/client/debugger/test/mochitest/head.js", "devtools/client/framework/test/browser_toolbox_custom_host.js", "devtools/client/framework/toolbox-host-manager.js", "devtools/client/framework/toolbox-hosts.js", "devtools/client/framework/toolbox-process-window.js"], "git_node": null, "git_parents": [null], "node": "c3ad68679ef115f04af7386562280ce03fad3f2b", "parents": ["fb01c7ab313cced66ce02fdeb33c0a1deb993990"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1467137 - Turn on crashtests on macosx64-qr. r=jmaher\n\nMozReview-Commit-ID: H0J812eMROl", "files": ["taskcluster/ci/test/reftest.yml", "taskcluster/ci/test/test-sets.yml"], "git_node": null, "git_parents": [null], "node": "8fce7baafd042fa3e5d5974633607ca582b12c86", "parents": ["c3ad68679ef115f04af7386562280ce03fad3f2b"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1469793 - Intermittent jsbench with file already existing. r=ahal\n\nensure we overwrite existing files if they exist while unzipping artifact\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1728", "files": ["taskcluster/ci/source-test/jsshell.yml"], "git_node": null, "git_parents": [null], "node": "c4ddc413f671773e67b798d1142064482c2ad7b6", "parents": ["8fce7baafd042fa3e5d5974633607ca582b12c86"], "tags": []}, {"author": "Alexandre Poirot \u003cpoirot.alex@gmail.com\u003e", "branch": "default", "desc": "Bug 1469824 - Remove AppCacheUtils.jsm. r=jryans\n\nMozReview-Commit-ID: 7ZtVj55k11U", "files": ["devtools/.eslintrc.js", "devtools/client/locales/en-US/appcacheutils.properties", "devtools/client/shared/AppCacheUtils.jsm", "devtools/client/shared/moz.build"], "git_node": null, "git_parents": [null], "node": "219e110548a9ea5ddeb5da94cac666b599c0a416", "parents": ["c4ddc413f671773e67b798d1142064482c2ad7b6"], "tags": []}, {"author": "Alexandre Poirot \u003cpoirot.alex@gmail.com\u003e", "branch": "default", "desc": "Bug 1388054 - Stop using Promise.jsm from devtools/shared/defer. r=jryans\n\nMozReview-Commit-ID: DHEYqnPjMuG", "files": ["devtools/shared/defer.js"], "git_node": null, "git_parents": [null], "node": "0605328631fda3d73bf749db3b3f2d3cc652a1ae", "parents": ["219e110548a9ea5ddeb5da94cac666b599c0a416"], "tags": []}, {"author": "Francois Marier \u003cfrancois@mozilla.com\u003e", "branch": "default", "desc": "Bug 1469427 - Add AppleScript-related extensions to download protection. r=gcp\n\nMozReview-Commit-ID: Dc0gyfnmki8", "files": ["toolkit/components/reputationservice/ApplicationReputation.cpp"], "git_node": null, "git_parents": [null], "node": "d9da944ee84eb2b475f4412d7bddb9163b8f75a3", "parents": ["0605328631fda3d73bf749db3b3f2d3cc652a1ae"], "tags": []}, {"author": "Francois Marier \u003cfrancois@mozilla.com\u003e", "branch": "default", "desc": "Bug 1469427 - Add settings shortcuts to download protection. r=gcp\n\nFiles with this extension are used to create shortcuts to Windows setting\npages. This apparently allows invoking any binary file with any parameters.\n\nMozReview-Commit-ID: 6WOEaVG7Lq5", "files": ["toolkit/components/reputationservice/ApplicationReputation.cpp"], "git_node": null, "git_parents": [null], "node": "1e68fab00d8144ac57048540dbfdb3ecd99ca138", "parents": ["d9da944ee84eb2b475f4412d7bddb9163b8f75a3"], "tags": []}, {"author": "Francois Marier \u003cfrancois@mozilla.com\u003e", "branch": "default", "desc": "Bug 1467581 - Remove the use of default captures in closures. r=gcp\n\nExplicitly specify the arguments to copy to avoid making a copy of\na dangling `this` pointer.\n\nConvert nsUrlClassifierDBService::mClassifier to a RefPtr since\nthe update closure might need to continue to access its members\nafter it's been released by the main thread.\n\nMozReview-Commit-ID: CPio3n9MmsK", "files": ["toolkit/components/url-classifier/Classifier.cpp", "toolkit/components/url-classifier/Classifier.h", "toolkit/components/url-classifier/nsUrlClassifierDBService.cpp", "toolkit/components/url-classifier/nsUrlClassifierDBService.h", "toolkit/components/url-classifier/tests/gtest/Common.cpp", "toolkit/components/url-classifier/tests/gtest/TestClassifier.cpp", "toolkit/components/url-classifier/tests/gtest/TestUrlClassifierTableUpdateV4.cpp"], "git_node": null, "git_parents": [null], "node": "145132e9d947260102a85b66f44ba67ef6c939f5", "parents": ["1e68fab00d8144ac57048540dbfdb3ecd99ca138"], "tags": []}, {"author": "Francois Marier \u003cfrancois@mozilla.com\u003e", "branch": "default", "desc": "Bug 1467581 - Do less work in Reset() if Close() has been called. r=gcp\n\nIf Reset() is interleaved with a shutdown, there's no point in\nfinishing up and we may as well bail early.\n\nMozReview-Commit-ID: Lhm6NfAEgSj", "files": ["toolkit/components/url-classifier/Classifier.cpp", "toolkit/components/url-classifier/Classifier.h"], "git_node": null, "git_parents": [null], "node": "5beee22d04c95f8686e2e8218fc9ebe77f87357b", "parents": ["145132e9d947260102a85b66f44ba67ef6c939f5"], "tags": []}, {"author": "Francois Marier \u003cfrancois@mozilla.com\u003e", "branch": "default", "desc": "Bug 1467581 - Replace all nsAutoPtrs with UniquePtrs in Safe Browsing code. r=gcp\n\nThis should not change anything since we were using nsAutoPtrs properly,\nbut we may as well clean this up given the recent move to smart pointers\nfor everything.\n\nMozReview-Commit-ID: FWS54SYNiBm", "files": ["toolkit/components/url-classifier/nsUrlClassifierDBService.cpp", "toolkit/components/url-classifier/nsUrlClassifierDBService.h", "toolkit/components/url-classifier/nsUrlClassifierUtils.h"], "git_node": null, "git_parents": [null], "node": "1489fb7b99b48df5b67ab1bf3280a6c89becca44", "parents": ["5beee22d04c95f8686e2e8218fc9ebe77f87357b"], "tags": []}, {"author": "Kyle Machulis \u003ckyle@nonpolynomial.com\u003e", "branch": "default", "desc": "Bug 1469430 - Remove unused nsDocShell::LoadStream; r=Nika\n\nMozReview-Commit-ID: BbTMuZXKzsJ", "files": ["docshell/base/nsDocShell.cpp", "docshell/base/nsIDocShell.idl"], "git_node": null, "git_parents": [null], "node": "fedceb7bd90c588dbf028d6a4570e67d4f3667a9", "parents": ["1489fb7b99b48df5b67ab1bf3280a6c89becca44"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Bug 1469872 - update bugzilla products and components in moz.build files: devtools. r=nalexander\n\nMozReview-Commit-ID: 6bs0jkTP6rP", "files": ["browser/tools/mozscreenshots/moz.build", "devtools/client/aboutdebugging/moz.build", "devtools/client/accessibility/moz.build", "devtools/client/canvasdebugger/moz.build", "devtools/client/debugger/moz.build", "devtools/client/dom/moz.build", "devtools/client/framework/moz.build", "devtools/client/inspector/animation-old/moz.build", "devtools/client/inspector/moz.build", "devtools/client/jsonview/moz.build", "devtools/client/memory/moz.build", "devtools/client/moz.build", "devtools/client/netmonitor/moz.build", "devtools/client/performance-new/moz.build", "devtools/client/performance/moz.build", "devtools/client/responsive.html/moz.build", "devtools/client/scratchpad/moz.build", "devtools/client/shadereditor/moz.build", "devtools/client/shared/moz.build", "devtools/client/sourceeditor/moz.build", "devtools/client/storage/moz.build", "devtools/client/styleeditor/moz.build", "devtools/client/webaudioeditor/moz.build", "devtools/client/webconsole/moz.build", "devtools/client/webide/moz.build", "devtools/moz.build", "devtools/server/actors/inspector/moz.build", "devtools/server/actors/moz.build", "devtools/server/moz.build", "devtools/server/performance/moz.build", "devtools/shared/heapsnapshot/moz.build", "devtools/shared/moz.build", "devtools/shared/test-helpers/moz.build", "docshell/base/timeline/moz.build", "docshell/test/moz.build", "dom/chrome-webidl/moz.build", "dom/tests/moz.build", "dom/webidl/moz.build", "python/moz.build", "testing/web-platform/moz.build", "toolkit/modules/moz.build"], "git_node": null, "git_parents": [null], "node": "f9c7b74f40f23d53579508dc45a10585f5514de2", "parents": ["fedceb7bd90c588dbf028d6a4570e67d4f3667a9"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Bug 1469872 - update bugzilla products and components in moz.build files: webextensions. r=nalexander\n\nMozReview-Commit-ID: JtvcjQKclJf", "files": ["browser/base/content/moz.build", "browser/components/extensions/moz.build", "browser/modules/moz.build", "dom/chrome-webidl/moz.build", "dom/webidl/moz.build", "mobile/android/components/moz.build", "toolkit/components/extensions/moz.build", "toolkit/components/extensions/webrequest/moz.build", "toolkit/modules/moz.build"], "git_node": null, "git_parents": [null], "node": "7eab423d6991f0b239071a32e11d3c0ea8d9c7c7", "parents": ["f9c7b74f40f23d53579508dc45a10585f5514de2"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1448330 - Make nsIURI.clone a private method r=mayhemer\n\nMozReview-Commit-ID: 1efpeaEPaXP", "files": ["browser/base/content/browser-safebrowsing.js", "browser/modules/BlockedSiteContent.jsm", "caps/NullPrincipalURI.cpp", "caps/NullPrincipalURI.h", "docshell/base/nsDocShell.cpp", "dom/base/Link.cpp", "dom/base/Link.h", "dom/base/Location.cpp", "dom/html/HTMLFormElement.cpp", "dom/jsurl/nsJSProtocolHandler.cpp", "dom/webbrowserpersist/nsWebBrowserPersist.cpp", "dom/xbl/nsXBLPrototypeBinding.cpp", "image/decoders/icon/nsIconURI.cpp", "image/decoders/icon/nsIconURI.h", "layout/generic/nsImageFrame.cpp", "layout/style/nsCSSValue.cpp", "modules/libjar/nsJARChannel.cpp", "modules/libjar/nsJARURI.cpp", "modules/libjar/nsJARURI.h", "netwerk/base/nsIURI.idl", "netwerk/base/nsSimpleNestedURI.cpp", "netwerk/base/nsSimpleURI.cpp", "netwerk/base/nsSimpleURI.h", "netwerk/base/nsStandardURL.cpp", "netwerk/base/nsStandardURL.h", "netwerk/protocol/about/nsAboutProtocolHandler.cpp", "netwerk/protocol/res/SubstitutingProtocolHandler.h", "netwerk/test/unit/test_URIs.js", "netwerk/test/unit/test_URIs2.js", "netwerk/test/unit/test_bug396389.js", "toolkit/components/places/nsFaviconService.cpp", "toolkit/modules/RemoteWebProgress.jsm", "uriloader/prefetch/OfflineCacheUpdateParent.cpp"], "git_node": null, "git_parents": [null], "node": "110e4b10e2eaca929de9ec715da66fe26d52445f", "parents": ["7eab423d6991f0b239071a32e11d3c0ea8d9c7c7"], "tags": []}, {"author": "Noemi Erli \u003cnerli@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 0605328631fd (bug 1388054) for failing in devtools/client/shadereditor/test/browser_se_aaa_run_first_leaktest.js on a CLOSED TREE", "files": ["devtools/shared/defer.js"], "git_node": null, "git_parents": [null], "node": "30ef0ff424054f15fb9dee7203cd73eac30f9c9e", "parents": ["110e4b10e2eaca929de9ec715da66fe26d52445f"], "tags": []}, {"author": "Matt Woodrow \u003cmwoodrow@mozilla.com\u003e", "branch": "default", "desc": "Bug 1461267 - Add some more assertions to verify the length of the DAG. r=mstange\n\nMozReview-Commit-ID: DFy6Kb2KSwf", "files": ["layout/painting/RetainedDisplayListBuilder.cpp"], "git_node": null, "git_parents": [null], "node": "9e0e314fe39a2d8bdc1ed48068163c4c51c81db2", "parents": ["30ef0ff424054f15fb9dee7203cd73eac30f9c9e"], "tags": []}, {"author": "layely \u003cablayelyfondou@gmail.com\u003e", "branch": "default", "desc": "Bug 1458039 - Implement ability to mute/unmute a selection of tabs. r=jaws\n\nMozReview-Commit-ID: 7aw08gxOOtk", "files": ["browser/base/content/browser.js", "browser/base/content/browser.xul", "browser/base/content/tabbrowser.js", "browser/base/content/tabbrowser.xml", "browser/base/content/test/tabs/browser.ini", "browser/base/content/test/tabs/browser_multiselect_tabs_close.js", "browser/base/content/test/tabs/browser_multiselect_tabs_mute_unmute.js", "browser/locales/en-US/chrome/browser/browser.properties"], "git_node": null, "git_parents": [null], "node": "ff8e661f8b074c558b70493034beed22e6213b93", "parents": ["9e0e314fe39a2d8bdc1ed48068163c4c51c81db2"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1469683 - 1. Fix crash tests; r=esawin\n\nSpecify individual sessions in crash tests (i.e.\n\"mainSession.waitUntilCalled\" instead of \"sessionRule.waitUntilCalled\"),\nso that the tests assert behavior on the correct session, and not\ninadvertently on the cached session.\n\nAlso, under x86 debug builds, Gecko installs an \"ah_crap_handler\" for\nSIGSEGV that waits for a long time, which causes our crash tests to time\nout. Therefore, ignore crash tests under x86 debug.\n\nMozReview-Commit-ID: DdtmRBLmPGp", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/ContentDelegateTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/GeckoSessionTestRuleTest.kt"], "git_node": null, "git_parents": [null], "node": "2806729c61eaac199ad4670788c4008079a99f34", "parents": ["ff8e661f8b074c558b70493034beed22e6213b93"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1469683 - 2. Make child crashes throw special exception; r=esawin\n\nMake child crashes throw ChildCrashException instead of the generic\nRuntimeException, which can mean a variety of errors such as timeout.\n\nMozReview-Commit-ID: H0E6gipkTxg", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/GeckoSessionTestRuleTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/rule/GeckoSessionTestRule.java"], "git_node": null, "git_parents": [null], "node": "13ff68c7707d414ea98096933b322025a75ad871", "parents": ["2806729c61eaac199ad4670788c4008079a99f34"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1469683 - 3. Make sure cached session is closed after crash; r=esawin\n\nIf @IgnoreCrash is specified, assume there has been a crash and\ntherefore wait for the cached session to close at the end of the test,\nso that the closing operation doesn't carry over to the next test.\n\nMozReview-Commit-ID: KrMfHgIiELQ", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/rule/GeckoSessionTestRule.java"], "git_node": null, "git_parents": [null], "node": "c9487350a119359a14bce87083e34930ba6258df", "parents": ["13ff68c7707d414ea98096933b322025a75ad871"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1469676 - Reduce max-run-time for various build tasks; r=glandium\n\nThe max-run-time for tasks appears to have been mostly cargo\nculted. In particular, a value of 36000 (10 hours) is quite absurd:\nno single task takes that long to execute.\n\nThis commit reduces the max-run-time of several tasks to\nmore reasonable values. The goal here is to prevent\nexcessively long-running tasks. There is definitely room to\nfurther tweak values to further mitigate long-running tasks. But\nlet's bite off the biggest chunk first, since that doesn't\nrequire much mental effort.\n\nThere is a possibility I overshot on some of these tasks. If we\nget timeouts, we can always increase the timeout again.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1716", "files": ["taskcluster/ci/artifact-build/kind.yml", "taskcluster/ci/build/android-stuff.yml", "taskcluster/ci/build/linux.yml", "taskcluster/ci/build/macosx.yml", "taskcluster/ci/toolchain/linux.yml", "taskcluster/ci/toolchain/macosx.yml", "taskcluster/ci/toolchain/windows.yml"], "git_node": null, "git_parents": [null], "node": "5cc046f4654100da7d01a0e44aa069331860f784", "parents": ["c9487350a119359a14bce87083e34930ba6258df"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1469766 - Update OOM hook on rustc 1.28 after rust PR 51543. r=froydnj", "files": ["taskcluster/ci/toolchain/linux.yml", "toolkit/library/rust/shared/lib.rs"], "git_node": null, "git_parents": [null], "node": "11018f20ca8dbeef5e71a4a67882d9b51ee90c03", "parents": ["5cc046f4654100da7d01a0e44aa069331860f784"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1466379 - fall back to currentURI in case images are blocked, r=bz,dao\n\nMozReview-Commit-ID: FW2f18pF4t5", "files": ["browser/modules/ContextMenu.jsm", "dom/browser-element/BrowserElementChildPreload.js", "mobile/android/chrome/content/browser.js"], "git_node": null, "git_parents": [null], "node": "7b5b59d44cead15900cdc4e79c7657cc11be5349", "parents": ["11018f20ca8dbeef5e71a4a67882d9b51ee90c03"], "tags": []}, {"author": "Nils Ohlmeier [:drno] \u003cdrno@ohlmeier.org\u003e", "branch": "default", "desc": "Bug 1465253: use postfix as prefix when logging and log in clear. r=bwc\n\nMozReview-Commit-ID: 4bfVQZyM9qy", "files": ["media/webrtc/signaling/src/mediapipeline/MediaPipeline.cpp", "media/webrtc/signaling/src/mediapipeline/RtpLogger.cpp", "media/webrtc/signaling/src/mediapipeline/RtpLogger.h"], "git_node": null, "git_parents": [null], "node": "3c53e83acb19a4e319758b1c8f19f2107732c1df", "parents": ["7b5b59d44cead15900cdc4e79c7657cc11be5349"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1469257 - [H264] Only check for SPS changes on keyframe r=bryce\n\nSome invalid streams contain SPS changes and those appear to only occur on non-keyframe, this cause all frames to be dropped until the next keyframe is found. This result in apparent freezes.\n\nWhile it is theoretically possible to have SPS changes inband on non-keyframe those should be very rare (I've never seen one). The content would have been invalid anyway in an non-fragmented mp4.\n\nSo we now only check for a SPS change on keyframe. This would cause no affect on either windows, android or ffmpeg as those decoders handle format change fine. The mac decoder could however show garbled frames temporarily.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1733", "files": ["dom/media/platforms/wrappers/H264Converter.cpp"], "git_node": null, "git_parents": [null], "node": "ddde6ad6d9e6c4069632e195613bcd53a39883e4", "parents": ["3c53e83acb19a4e319758b1c8f19f2107732c1df"], "tags": []}, {"author": "Daniel Stenberg \u003cdaniel@haxx.se\u003e", "branch": "default", "desc": "bug 1463356 do not count \"not started\" TRR resolves as failures r=mcmanus\n\n... when comparing against the native resolver. DNS_TRR_COMPARE is meant\nto compare how the actually performed name resolves fare against each\nother.\n\nMozReview-Commit-ID: 98NoUGPpHr6", "files": ["netwerk/dns/TRR.cpp", "netwerk/dns/TRR.h", "netwerk/dns/nsHostResolver.cpp", "netwerk/dns/nsHostResolver.h"], "git_node": null, "git_parents": [null], "node": "08b8d3da8635e10564150b04742b787d74d372e6", "parents": ["ddde6ad6d9e6c4069632e195613bcd53a39883e4"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1469095 - Fix always-optimized jobs after bug 1465181. r=dustin", "files": ["taskcluster/taskgraph/transforms/job/__init__.py"], "git_node": null, "git_parents": [null], "node": "88a05771dd2bfbd22e31a543c7403414886e1523", "parents": ["08b8d3da8635e10564150b04742b787d74d372e6"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1463917 part 1 - Add scrollcorner to -moz-appearance so that widget can render it. r=heycam\n\nMozReview-Commit-ID: 1Za22ifONfG", "files": ["devtools/shared/css/generated/properties-db.js", "gfx/src/nsThemeConstants.h", "layout/style/nsCSSKeywordList.h", "layout/style/nsCSSProps.cpp", "servo/components/style/properties/longhand/box.mako.rs", "toolkit/themes/osx/global/nativescrollbars.css", "toolkit/themes/windows/global/xulscrollbars.css"], "git_node": null, "git_parents": [null], "node": "d1321b14461680936a84f7a283e55cb4085b0d61", "parents": ["88a05771dd2bfbd22e31a543c7403414886e1523"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1463917 part 2 - Have windows widget render scrollcorner. r=jimm\n\nMozReview-Commit-ID: K4Cu1mL6xvH", "files": ["widget/tests/test_scrollbar_colors.html", "widget/windows/nsNativeThemeWin.cpp"], "git_node": null, "git_parents": [null], "node": "d69617c50c04497f084bd5a39ee698dff4cb4282", "parents": ["d1321b14461680936a84f7a283e55cb4085b0d61"], "tags": []}, {"author": "Daniel Stenberg \u003cdaniel@haxx.se\u003e", "branch": "default", "desc": "bug 1470005 - change default TRR blacklist duration to 60 seconds r=mcmanus\n\nMozReview-Commit-ID: FGQCmhlBBG8", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "e09fbaee1456a373382d2d5bf6ab7321e26e3710", "parents": ["d69617c50c04497f084bd5a39ee698dff4cb4282"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "Bug 1469433 - Match the spec's error reporting more closely. r=smaug\n\nMozReview-Commit-ID: LI13cA0okeu", "files": ["dom/payments/PaymentRequest.cpp", "testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/payment-request/payment-request-canmakepayment-method-manual.https.html"], "git_node": null, "git_parents": [null], "node": "83f67349e19f28eda78ff62c949960c0605debe2", "parents": ["e09fbaee1456a373382d2d5bf6ab7321e26e3710"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "Bug 1469433 - Handle shutdown more gracefully. r=smaug\n\nIf we end up shutting down the content process while there's a request active\nwe'll end up \"leaking\" the request and asserting. This makes sure that we\nlet go of the PaymentRequest in that edge case. I can cause this by forceably\nclosing the payment request window on Linux without hitting OK or cancel.\n\nMozReview-Commit-ID: 6XDYIcqNkC6", "files": ["dom/payments/PaymentRequest.cpp", "dom/payments/PaymentRequestManager.cpp", "dom/payments/PaymentRequestManager.h", "dom/payments/ipc/PaymentRequestChild.cpp", "dom/payments/ipc/PaymentRequestChild.h"], "git_node": null, "git_parents": [null], "node": "ef0c3f86216fcf0024e2e33c73881daa54e96bc0", "parents": ["83f67349e19f28eda78ff62c949960c0605debe2"], "tags": []}, {"author": "Blake Kaplan \u003cmrbkap@gmail.com\u003e", "branch": "default", "desc": "Bug 1469433 - Remove an unused function. r=smaug\n\nThis was just sitting around.\n\nMozReview-Commit-ID: 282neafD23x", "files": ["dom/payments/ipc/PaymentRequestChild.cpp", "dom/payments/ipc/PaymentRequestChild.h"], "git_node": null, "git_parents": [null], "node": "5e99f060685d12e406f8b18108e84fb012275e2e", "parents": ["ef0c3f86216fcf0024e2e33c73881daa54e96bc0"], "tags": []}, {"author": "prathiksha \u003cprathikshaprasadsuman@gmail.com\u003e", "branch": "default", "desc": "Bug 1462461 - Show the back button in the basic card page during on-boarding.r=MattN\n\nMozReview-Commit-ID: 1a8YtdbtV2M", "files": ["browser/components/payments/res/containers/basic-card-form.js", "browser/components/payments/test/browser/browser_payments_onboarding_wizard.js"], "git_node": null, "git_parents": [null], "node": "d5ec52381e06546b575ae94901d607401f40c3de", "parents": ["5e99f060685d12e406f8b18108e84fb012275e2e"], "tags": []}, {"author": "Kearwood \"Kip\" Gilbert \u003ckgilbert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1469972 - Remove VRPose::mFrameId and its accessor as it is unused r=rbarker\n\nMozReview-Commit-ID: 8t2a7gQacDl", "files": ["dom/vr/VRDisplay.cpp", "dom/vr/VRDisplay.h"], "git_node": null, "git_parents": [null], "node": "1c119911fc842731dbbf4c207ec84e3b3a09f59e", "parents": ["d5ec52381e06546b575ae94901d607401f40c3de"], "tags": []}, {"author": "Brian Stack \u003cbstack@mozilla.com\u003e", "branch": "default", "desc": "Bug 1465117 - Take two at updating backfill task. Use modifier this time. r=dustin,jmaher\n\nMozReview-Commit-ID: CAs0WRb839r", "files": ["taskcluster/mach_commands.py", "taskcluster/taskgraph/actions/backfill.py", "taskcluster/taskgraph/actions/util.py", "taskcluster/taskgraph/task.py"], "git_node": null, "git_parents": [null], "node": "2731368a39e57a7fda79ebe8b33a9251a327fe5d", "parents": ["1c119911fc842731dbbf4c207ec84e3b3a09f59e"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1423017 followup - Make the telemetry opt-out on release channel.", "files": ["toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "e7d6ae2adfe21485357b3254e05157f58766420d", "parents": ["b6f1b6284f474a08953cd3b58709c14c5cd5e684"], "tags": []}, {"author": "Andi-Bogdan Postelnicu \u003cbpostelnicu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1453795 - XPCOM - Initialize member fields in classes/ structures. r=froydnj", "files": ["xpcom/base/nsGZFileWriter.cpp", "xpcom/base/nsTraceRefcnt.cpp", "xpcom/ds/nsCheapSets.h", "xpcom/ds/nsExpirationTracker.h", "xpcom/ds/nsPersistentProperties.cpp", "xpcom/ds/nsTArray.h", "xpcom/ds/nsVariant.h", "xpcom/io/nsInputStreamTee.cpp", "xpcom/io/nsLocalFileUnix.cpp", "xpcom/io/nsStorageStream.cpp", "xpcom/io/nsStringStream.cpp", "xpcom/tests/TestHarness.h", "xpcom/threads/CPUUsageWatcher.h", "xpcom/threads/Scheduler.cpp", "xpcom/threads/nsTimerImpl.cpp"], "git_node": null, "git_parents": [null], "node": "00ae61d464066c27a4485e5f0dae02a7b78243ac", "parents": ["e7d6ae2adfe21485357b3254e05157f58766420d"], "tags": []}, {"author": "Andi-Bogdan Postelnicu \u003cbpostelnicu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1453795 - Widget/Cocoa - Initialize member fields in classes/ structures. r=mstange", "files": ["widget/cocoa/TextInputHandler.mm", "widget/cocoa/nsCocoaWindow.mm", "widget/cocoa/nsLookAndFeel.mm", "widget/cocoa/nsMacDockSupport.mm"], "git_node": null, "git_parents": [null], "node": "85493d8b9dae872d8b594f145fc289fb49ab0a4e", "parents": ["00ae61d464066c27a4485e5f0dae02a7b78243ac"], "tags": []}, {"author": "Lars T Hansen \u003clhansen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1461948 - Factor the TypedObject struct type constructor. r=till\n\nFor Wasm support we'll want to bypass the bits that interpret the\nobject coming from JS, and instead just pass in parallel arrays of IDs\nand type descriptors, and other parameters.\n\nThis also allows us to request an opaque type, even if none of the\nfield types are opaque.", "files": ["js/src/builtin/TypedObject.cpp", "js/src/builtin/TypedObject.h"], "git_node": null, "git_parents": [null], "node": "e6cd4f48162d22ef3608391bbf16e7509e39de11", "parents": ["85493d8b9dae872d8b594f145fc289fb49ab0a4e"], "tags": []}, {"author": "Lars T Hansen \u003clhansen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1461948 - Generalize and abstract TypedObject field layout algorithm. r=till\n\nThe algorithm is used by code that builds the TypeDesc, but also\nneeded earlier by the Wasm parser to build the compilation\nenvironment.  So abstract the algorithm and expose it.", "files": ["js/src/builtin/TypedObject.cpp", "js/src/builtin/TypedObject.h"], "git_node": null, "git_parents": [null], "node": "c8434494445c6b5403c292226498a78b3d428331", "parents": ["e6cd4f48162d22ef3608391bbf16e7509e39de11"], "tags": []}, {"author": "Lars T Hansen \u003clhansen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1461948 - Uncouple ReferenceType from TypedObject's ReferenceTypeDescr. r=till\n\nThe coupling created some problems for a later patch where I need to\nreference ReferenceTypeDescr::Type in GlobalObject.h, but can't,\nbecause this creates a circular include path.  As for SIMD and Scalar,\nthere's no reason to embed the type all the way inside the TypedObject\nmachinery, we can just have it as its own thing.", "files": ["js/src/builtin/TypedObject.cpp", "js/src/builtin/TypedObject.h", "js/src/jit/BaselineCacheIRCompiler.cpp", "js/src/jit/BaselineIC.cpp", "js/src/jit/CacheIR.cpp", "js/src/jit/CacheIR.h", "js/src/jit/CacheIRCompiler.cpp", "js/src/jit/CacheIRCompiler.h", "js/src/jit/IonBuilder.cpp", "js/src/jit/IonBuilder.h", "js/src/jit/IonCacheIRCompiler.cpp", "js/src/jit/SharedIC.h", "js/src/jit/TypedObjectPrediction.cpp", "js/src/jit/TypedObjectPrediction.h"], "git_node": null, "git_parents": [null], "node": "1d069afa41fa40ba8c5835dbd83f1218c46b83e7", "parents": ["c8434494445c6b5403c292226498a78b3d428331"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1435319, r=valentin", "files": ["docshell/base/nsDefaultURIFixup.cpp"], "git_node": null, "git_parents": [null], "node": "b58c103b639f29520c952137cd607148e2b01675", "parents": ["1d069afa41fa40ba8c5835dbd83f1218c46b83e7"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1435319 - tests, r=valentin", "files": ["docshell/test/unit/test_nsDefaultURIFixup_info.js"], "git_node": null, "git_parents": [null], "node": "34fc2ff698c3796600e79073daa6011f24aecc06", "parents": ["b58c103b639f29520c952137cd607148e2b01675"], "tags": []}, {"author": "Gabriele Svelto \u003cgsvelto@mozilla.com\u003e", "branch": "default", "desc": "Bug 1309172 - Updated breakpad to version 69c2c51dd89965d234eec16e3a9353634831916b; r=ted.mielczarek\n\nThis includes both the vanilla sources we haven't forked and the client\nsources that we have. Client patches were applied manually up to version\n69c2c51dd89965d234eec16e3a9353634831916b. The following changes were not\nincluded as they break merging segments corresponding to libxul.so in the\nmodule list:\n\n8915f7be39448d9257b6da3ad0233944d1d9a92a\n17ad0c18b179c135fc5a3d2bba199c3fa4276035\n94b6309aecaddfcf11672f6cfad9575d68ad3b40\n\nWith these changes applied two entries for libxul.so are generated, the second\none is bogus and prevents symbolication from working correctly.\n\nThe build system and some of the tools relying on breakpad were also updated\nto work with the new version.", "files": ["toolkit/crashreporter/breakpad-client/linux/crash_generation/crash_generation_server.cc", "toolkit/crashreporter/breakpad-client/linux/dump_writer_common/mapping_info.h", "toolkit/crashreporter/breakpad-client/linux/dump_writer_common/ucontext_reader.cc", "toolkit/crashreporter/breakpad-client/linux/dump_writer_common/ucontext_reader.h", "toolkit/crashreporter/breakpad-client/linux/handler/exception_handler.cc", "toolkit/crashreporter/breakpad-client/linux/handler/exception_handler.h", "toolkit/crashreporter/breakpad-client/linux/handler/exception_handler_unittest.cc", "toolkit/crashreporter/breakpad-client/linux/handler/minidump_descriptor.cc", "toolkit/crashreporter/breakpad-client/linux/handler/minidump_descriptor.h", "toolkit/crashreporter/breakpad-client/linux/microdump_writer/microdump_writer.cc", "toolkit/crashreporter/breakpad-client/linux/microdump_writer/microdump_writer.h", "toolkit/crashreporter/breakpad-client/linux/microdump_writer/microdump_writer_unittest.cc", "toolkit/crashreporter/breakpad-client/linux/minidump_writer/linux_core_dumper.cc", "toolkit/crashreporter/breakpad-client/linux/minidump_writer/linux_core_dumper_unittest.cc", "toolkit/crashreporter/breakpad-client/linux/minidump_writer/linux_dumper.cc", "toolkit/crashreporter/breakpad-client/linux/minidump_writer/linux_dumper.h", "toolkit/crashrepor