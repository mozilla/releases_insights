-IN -\u003e 1f43824151bf\nbr -\u003e fdfecb896486\ncak -\u003e 7d889a660499\ncs -\u003e e68e181cde91\nde -\u003e d799dc3a81e3\ndsb -\u003e 39e83980b6d6\nel -\u003e 9c704668d5b9\neo -\u003e 17d139e55656\nes-ES -\u003e ea2ec066d6ce\nes-MX -\u003e 81cb519ff183\nia -\u003e 5290a770e011\nka -\u003e 0b9ec7ff2666\nlij -\u003e 7c95ff773b1e", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "61b3a12b7f3c4adefe953c736518a3f8b3cd6303", "parents": ["a44cadf6f3ed7cd0a9dc57ca65a038c1b6638599"], "tags": []}], "date": 1532523629, "git_changesets": [null, null], "user": "ffxbld"}, "9535": {"changesets": [{"author": "Stephen A Pohl \u003cspohl.mozilla.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1290972: Remove linker flags for macOS that are no longer necessary and cause crashes such as bug 1471366 due to an inability to handle native exceptions when these flags are used. r=froydnj a=lizzard", "files": ["toolkit/library/moz.build"], "git_node": null, "git_parents": [null], "node": "d5018fab965071e686243ccc2cf73876d576407f", "parents": ["61b3a12b7f3c4adefe953c736518a3f8b3cd6303"], "tags": []}, {"author": "Michal Novotny \u003cmichal.novotny@gmail.com\u003e", "branch": "default", "desc": "Bug 1466577 - Race condition in WebSocketChannel::StopSession. r=hurley a=dveditz\n\nThis patch prevents calling WebSocketChannel::StopSession at the same time on main thread from WebSocketChannel::Close and on socket thread from WebSocketChannel::AbortSession.", "files": ["netwerk/protocol/websocket/WebSocketChannel.cpp", "netwerk/protocol/websocket/WebSocketChannel.h"], "git_node": null, "git_parents": [null], "node": "996ae2e4deaac50729b1c773b468b073a764f6ba", "parents": ["d5018fab965071e686243ccc2cf73876d576407f"], "tags": []}, {"author": "Patrick McManus \u003cmcmanus@ducksong.com\u003e", "branch": "default", "desc": "Bug 1475420 - mark the TRR connection as DISABLE_TRR to avoid TXT deadlock r=valentin a=lizzard\n\nMozReview-Commit-ID: 3xF3Hb5rpyh", "files": ["netwerk/protocol/http/nsHttp.h", "netwerk/protocol/http/nsHttpChannel.cpp", "netwerk/protocol/http/nsHttpConnectionMgr.cpp"], "git_node": null, "git_parents": [null], "node": "5bf0dbc446bb24f9fbb1f887933cf3ad9276888b", "parents": ["996ae2e4deaac50729b1c773b468b073a764f6ba"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1475662 - Ensure GeckoSession.saveState() always completes r=droeh a=lizzard\n\nMozReview-Commit-ID: CLcdjOkGI9b", "files": ["mobile/android/chrome/geckoview/GeckoViewContent.js", "mobile/android/modules/geckoview/GeckoViewContent.jsm"], "git_node": null, "git_parents": [null], "node": "05684a3069ff6395582dca3cc94e3b6f64cdc8c4", "parents": ["5bf0dbc446bb24f9fbb1f887933cf3ad9276888b"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1474454 - Use GeckoResult in GeckoSession.NavigationDelegate.onLoadRequest() r=jchen,droeh a=lizzard\n\nMozReview-Commit-ID: CmdjYhqpZcZ", "files": ["mobile/android/base/java/org/mozilla/gecko/customtabs/CustomTabsActivity.java", "mobile/android/base/java/org/mozilla/gecko/webapps/WebAppActivity.java", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/ContentDelegateTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/NavigationDelegateTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/ProgressDelegateTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/TestRunnerActivity.java", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/util/Callbacks.kt", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSession.java", "mobile/android/geckoview_example/src/main/java/org/mozilla/geckoview_example/GeckoViewActivity.java"], "git_node": null, "git_parents": [null], "node": "f7122adfbe8b0d734155c3a44c4bfea72a21a9bf", "parents": ["05684a3069f