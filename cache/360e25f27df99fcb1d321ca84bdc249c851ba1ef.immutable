-\u003e 89035799b2ed\nrm -\u003e 9e94e886f054\nsk -\u003e 7aff22dce574\nth -\u003e f4cb77b17534", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "756867bd174ca9282bd7256e27af7bce4b2a1554", "parents": ["4c8db9fde36c010f26839a08c1c591d910145f1c"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\naz -\u003e 33de4b67ed88\ncak -\u003e 37b62844a232\ndsb -\u003e ef471746da8d\nen-CA -\u003e e19d7d2ca383\nfi -\u003e 8a2efa80ec98\nia -\u003e 5bca036b1029\nid -\u003e 6e47c0c71fb1\nka -\u003e 45209cd4cb79\nkab -\u003e b7673e6dce70\nkk -\u003e cf7a7ba7d11e\nms -\u003e 72ed8be7ed8e\nnl -\u003e 89035799b2ed\nnn-NO -\u003e 5b347c8edc77\npl -\u003e 1662312cfcdf\nrm -\u003e 9e94e886f054\nsk -\u003e 3adf0ca5608f\nth -\u003e 2e58816bd913\ntr -\u003e 256e6d344380", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "fff628e1f57066c42cecfbe521104eece858551c", "parents": ["756867bd174ca9282bd7256e27af7bce4b2a1554"], "tags": []}], "date": 1532273088, "git_changesets": [null, null], "user": "ffxbld"}, "9516": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\ntr -\u003e 256e6d344380\nzh-CN -\u003e 7f3a4de66c24", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "e532b621926a75cf21736c410695cf2cf76567c1", "parents": ["fff628e1f57066c42cecfbe521104eece858551c"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nzh-CN -\u003e f1d96b15e767", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "a59b0ee25b6ebca42259baf20b95b9a57d80a3fc", "parents": ["e532b621926a75cf21736c410695cf2cf76567c1"], "tags": []}], "date": 1532276595, "git_changesets": [null, null], "user": "ffxbld"}, "9517": {"changesets": [{"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1462257 - TextComposition should dispatch eCompositionChange event when eCompositionCommit is being fired immediately after eCompositionStart r=m_kato a=lizzard\n\nTextEditor modifies composition string or selected string when first\neCompositionChange event is received.  However, TextComposition dispatches\neCompositionChange event (\"text\" event of DOM) only when composition string\nbecomes non-empty if current composition string is empty.  So, when IME\ndispatches only eCompositionStart and eCompositionCommit events for removing\nselected text, TextEditor does nothing.  This hacky behavior is used by\nMS Pinyin on Windows 10 at least.\n\nFor supporting this behavior, we need to make TextComposition dispatch\neCompositionChange event when eCompositionChange(AsIs) event is fired\neven before dispatching eCompositionChange event.\n\nAlthough from point of view of web apps, the hacky composition should be\nmerged into the previous composition if it's possible but it's out of scope\nof this bug.\n\nMozReview-Commit-ID: 7QfeBJamGTU", "files": ["dom/events/TextComposition.cpp", "dom/events/TextComposition.h", "editor/libeditor/tests/test_bug1230473.html", "widget/tests/window_composition_text_querycontent.xul"], "git_node": null, "git_parents": [null], "node": "3743c968feeb2a137fb950df3d9b762be0641b10", "parents": ["a59b0ee25b6ebca42259baf20b95b9a57d80a3fc"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1443902 - Reinitilize selection after destroying nsIEditingSession. r=masayuki a=lizzard\n\nWhen setting contenteditable to false, editing session destroys HTMLEditor.\nDestroying HTMLEditor means that selection visibility is reset by\nFinalizeSelection.\n\nSo after calling TearDownEditorOnWindow on nsHTMLDocument, we should initialize\nselection visibility if current focus is text control that has editor.\n\nMozReview-Commit-ID: 4V8kZtOtKO3", "files": ["dom/html/nsHTMLDocument.cpp", "editor/libeditor/EditorBase.cpp", "editor/libeditor/EditorBase.h", "editor/reftests/1443902-1-ref.html", "editor/reftests/1443902-1.html", "editor/reftests/1443902-2-ref.html", "editor/reftests/1443902-2.html", "editor/reftests/1443902-3-ref.html", "editor/reftests/1443902-3.html", "editor/reftests/1443902-4-ref.html", "editor/reftests/1443902-4.html", "editor/reftests/reftest.list"], "git_node": null, "git_parents": [null], "node": "f9542916a0bb4d55873991ef42ad2ae1fe5feef3", "parents": ["3743c968feeb2a137fb950df3d9b762be0641b10"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1443902 - Part 2. Update spellcheck status on focused element after turning off contenteditable. r=masayuki a=lizzard\n\nSpellchecker of \u003cinput\u003e element is off by default, however, if it's in a\ncontenteditable element, spellchecker is on by default.\n\nWhen turning off contenteditable, we have to update spellcheck status if\nfocused editor is in this contenteditable.\n\nMozReview-Commit-ID: 6Y9mUWTIWRn", "files": ["editor/libeditor/EditorBase.cpp"], "git_node": null, "git_parents": [null], "node": "013481de4c5f20107b837e204e7cbd08ab6369e5", "parents": ["f9542916a0bb4d55873991ef42ad2ae1fe5feef3"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1475501 - Clean up addTab call in undoCloseTab. r=mikedeboer a=lizzard\n\nMozReview-Commit-ID: HT8C5cTzdvg", "files": ["browser/components/sessionstore/SessionStore.jsm"], "git_node": null, "git_parents": [null], "node": "50ec48d931ba5f0977d2868ccd5334e2ae39ac80", "parents": ["013481de4c5f20107b837e204e7cbd08ab6369e5"], "tags": []}, {"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1474755 - Change autofill threshold calculation to multiply the standard deviation by a constant, which is stored in prefs. r=mak a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D2233", "files": ["toolkit/components/places/UnifiedComplete.js", "toolkit/components/places/tests/unifiedcomplete/test_autofill_origins.js"], "git_node": null, "git_parents": [null], "node": "39327053019c217d0419cf5b7a2b1af15abb5115", "parents": ["50ec48d931ba5f0977d2868ccd5334e2ae39ac80"], "tags": []}, {"author": "Nicolas B. Pierron \u003cnicolas.b.pierron@gmail.com\u003e", "branch": "default", "desc": "Bug 1473289 - Work around page table fragmentation caused by mprotect / VirtualProtect using LifoAlloc r=tcampbell a=lizzard", "files": ["js/src/ds/LifoAlloc.cpp", "js/src/jit-test/tests/basic/consume-interpreter-stack-bug1473289.js", "js/src/jit-test/tests/basic/expr-decompiler-bug1475953.js"], "git_node": null, "git_parents": [null], "node": "8d716257450c6db490190d7acf232fd9df4da88d", "parents": ["39327053019c217d0419cf5b7a2b1af15abb5115"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1474360 - Don't immediately hide selection toolbar after showing it; r=esawin a=lizzard\n\nTo conform to Android behavior, we intentionally suppress the selection\ntoolbar when an input is first focused. However, that code has a bug\nwhere right after we show the selection toolbar, we still think the\ntoolbar should be suppressed, and therefore end up hiding the toolbar\nimmediately. The patch fixes that bug and introduces an ACTION_HIDE\naction, which is necessary to re-hide the toolbar when the user\ndismisses it manually.\n\nMozReview-Commit-ID: DbLd2MCxSyL", "files": ["mobile/android/chrome/geckoview/GeckoViewSelectionActionContent.js", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/SelectionActionDelegateTest.kt", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/BasicSelectionActionDelegate.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSession.java"], "git_node": null, "git_parents": [null], "node": "22ec5db4a28dbe691c1a211b1468225956f1ac94", "parents": ["8d716257450c6db490190d7acf232fd9df4da88d"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1471705 - Fix findbar status text color for lightweight themes. r=ntim a=lizzard\n\nMozReview-Commit-ID: 7mta63GhgrW", "files": ["toolkit/themes/osx/global/findBar.css", "toolkit/themes/shared/findBar.inc.css"], "git_node": null, "git_parents": [null], "node": "38fbd70b8bb672e0fb1d723661d594140822bb62", "parents": ["22ec5db4a28dbe691c1a211b1468225956f1ac94"], "tags": []}, {"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1476674 - Fix crash in nsNavHistory::RecalculateOriginFrecencyStats r=mak a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D2232", "files": ["toolkit/components/places/Database.cpp", "toolkit/components/places/nsNavHistory.cpp"], "git_node": null, "git_parents": [null], "node": "b2360af9510ebfd8812095d0a7298158e8d94c0a", "parents": ["38fbd70b8bb672e0fb1d723661d594140822bb62"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1470786 - 1. Support async text changes from replacing text; r=esawin a=lizzard\n\nCurrently, we expect editing operations in\nGeckoEditableSupport::OnImeReplaceText to cause synchronous text change\nnotifications. However, under e10s, text change notifications can be\nasynchornous. The new code keeps track of active OnImeReplaceText calls,\nand look for async text changes before replying to the calls.\n\nMozReview-Commit-ID: INM3JLmQebK", "files": ["mobile/android/tests/browser/robocop/src/org/mozilla/gecko/tests/testInputConnection.java", "widget/android/GeckoEditableSupport.cpp", "widget/android/GeckoEditableSupport.h"], "git_node": null, "git_parents": [null], "node": "7e6f51f7fca4a34f69d91260fcbe2c6b7eb8da40", "parents": ["b2360af9510ebfd8812095d0a7298158e8d94c0a"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1470786 - 2. Fix a text sync issue; r=esawin a=lizzard\n\nFix an issue in GeckoEditable where spans can be mistakenly deleted when\ndeleting text. The new code re-copies all spans to make sure similar\nissues don't happen in the future.\n\nMozReview-Commit-ID: G1fWsJkeTka", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoEditable.java"], "git_node": null, "git_parents": [null], "node": "ddfa017fb3b0b12a714cdd35886ad50ef890c5f4", "parents": ["7e6f51f7fca4a34f69d91260fcbe2c6b7eb8da40"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1459404 - Ensure that ChildAPIManager can be garbage-collected. r=mixedpuppy a=lizzard\n\nMozReview-Commit-ID: IEGq1mo4WWq", "files": ["toolkit/components/extensions/ExtensionChild.jsm", "toolkit/components/extensions/test/xpcshell/test_ext_contexts_gc.js", "toolkit/components/extensions/test/xpcshell/xpcshell-content.ini"], "git_node": null, "git_parents": [null], "node": "52dd0b769e22eb79c05bcf45462cf2564c654d32", "parents": ["ddfa017fb3b0b12a714cdd35886ad50ef890c5f4"], "tags": []}], "date": 1532292617, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "apavel@mozilla.com"}, "9518": {"changesets": [{"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1412081 - Add ability to blacklist file paths on Unix platforms r=mayhemer a=lizzard", "files": ["xpcom/io/FilePreferences.cpp", "xpcom/io/FilePreferences.h", "xpcom/io/nsLocalFileUnix.cpp", "xpcom/tests/gtest/TestFilePreferencesUnix.cpp", "xpcom/tests/gtest/moz.build"], "git_node": null, "git_parents": [null], "node": "5b0