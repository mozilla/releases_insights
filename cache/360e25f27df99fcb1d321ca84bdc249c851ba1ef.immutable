arded.js", "browser/components/sessionstore/SessionStore.jsm"], "git_node": null, "git_parents": [null], "node": "645e1b5b6470312fccafb126a1678b939f0d2b7f", "parents": ["7d56af790745509ecb3636a8c7fa8a6c0f7eebf6"], "tags": []}, {"author": "Rob Hoelz \u003crob@hoelz.ro\u003e", "branch": "default", "desc": "Bug 1468104 - Existence of tag on a bookmark prevents deletion of associated keyword. r=mak\n\nMozReview-Commit-ID: B0w1dZhVBWw", "files": ["toolkit/components/places/PlacesUtils.jsm", "toolkit/components/places/tests/unit/test_keywords.js"], "git_node": null, "git_parents": [null], "node": "e717472a6ac6ad0138932027312df3ab9e50afef", "parents": ["645e1b5b6470312fccafb126a1678b939f0d2b7f"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1469583 - add 'verify' as an option for web-platform-tests manifests. r=gbrown\n\nwhen running test-verify there are known failures and we need the ability to mark tests as disabled when run in test-verify mode\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1702", "files": ["testing/web-platform/tests/tools/wptrunner/wptrunner/browsers/firefox.py"], "git_node": null, "git_parents": [null], "node": "3f6f6020896579a4a2f8201638741ebd10d263b0", "parents": ["e717472a6ac6ad0138932027312df3ab9e50afef"], "tags": []}, {"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1469404 - Remove gradient from findbar button styling. r=jaws\n\nMozReview-Commit-ID: 9bU2fj8bgIh", "files": ["toolkit/themes/shared/findBar.inc.css"], "git_node": null, "git_parents": [null], "node": "135bf31e39c7fc349e0c6ef1b9181aa386c32eda", "parents": ["3f6f6020896579a4a2f8201638741ebd10d263b0"], "tags": []}, {"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1467423 - Make findbar textbox focused state follow theme properties. r=jaws\n\nMozReview-Commit-ID: GfkUVIdmWjw", "files": ["browser/modules/ThemeVariableMap.jsm", "toolkit/modules/LightweightThemeConsumer.jsm", "toolkit/themes/osx/global/findBar.css", "toolkit/themes/shared/findBar.inc.css"], "git_node": null, "git_parents": [null], "node": "855360a8022769672528a24501c1902235d76021", "parents": ["135bf31e39c7fc349e0c6ef1b9181aa386c32eda"], "tags": []}, {"author": "Justin Wood \u003cCallek@gmail.com\u003e", "branch": "default", "desc": "Bug 1469595 - Android single locale (not nightly) broken on beta. r=rail\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1703", "files": ["testing/mozharness/scripts/mobile_l10n.py"], "git_node": null, "git_parents": [null], "node": "81864d0dfb82a4d1812607225114797c1d1df052", "parents": ["855360a8022769672528a24501c1902235d76021"], "tags": []}, {"author": "Chris Manchester \u003ccmanchester@mozilla.com\u003e", "branch": "default", "desc": "Bug 1469067 - Build host programs in their final locations rather than copying them to dist/host/bin. r=mshal\n\nMozReview-Commit-ID: BrSou1ee2qV", "files": ["config/makefiles/target_binaries.mk", "config/rules.mk", "python/mozbuild/mozbuild/backend/recursivemake.py", "python/mozbuild/mozbuild/backend/tup.py", "python/mozbuild/mozbuild/frontend/data.py", "python/mozbuild/mozbuild/test/frontend/data/host-program-paths/final-target/moz.build", "python/mozbuild/mozbuild/test/frontend/data/host-program-paths/installed/moz.build", "python/mozbuild/mozbuild/test/frontend/data/host-program-paths/moz.build", "python/mozbuild/mozbuild/test/frontend/data/host-program-paths/not-installed/moz.build", "python/mozbuild/mozbuild/test/frontend/test_emitter.py"], "git_node": null, "git_parents": [null], "node": "33c34fbb0b0d7e890c1985c3ba896dd1a238dd1d", "parents": ["81864d0dfb82a4d1812607225114797c1d1df052"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1468864 - Set the fill and stroke for warning.svg in a few places that inherit fill and stroke colors on from toolbarbuttons. r=ntim\n\nMozReview-Commit-ID: 2GWxmNVTsFc", "files": ["browser/themes/shared/customizableui/panelUI.inc.css"], "git_node": null, "git_parents": [null], "node": "f33185af8502d5d9ab66f258fd7b59bf397bbba5", "parents": ["33c34fbb0b0d7e890c1985c3ba896dd1a238dd1d"], "tags": []}, {"author": "Tarek Ziad\u00e9 \u003ctarek@mozilla.com\u003e", "branch": "default", "desc": "Bug 1464571 - fixes DOM Worker performance counters - r=baku,froydnj\n\nNow uses StaticPrefs instead of DOMPrefs, and how we count dispatches for Workers.\n\nMozReview-Commit-ID: DTumwcI5bG", "files": ["dom/base/DOMPrefsInternal.h", "dom/base/DocGroup.cpp", "dom/ipc/ContentChild.cpp", "dom/ipc/ContentParent.cpp", "dom/tests/browser/browser_test_performance_metrics.js", "dom/tests/browser/ping_worker.html", "dom/workers/WorkerPrivate.cpp", "dom/workers/WorkerThread.cpp", "dom/workers/WorkerThread.h", "modules/libpref/init/StaticPrefList.h", "xpcom/tests/gtest/TestThreadMetrics.cpp", "xpcom/threads/nsThread.cpp", "xpcom/threads/nsThread.h"], "git_node": null, "git_parents": [null], "node": "252ca15e9688d1f32dc967f2139bc369f169be6b", "parents": ["f33185af8502d5d9ab66f258fd7b59bf397bbba5"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1469687 - Handle EXIT_PURGE_CACHES in all run-task tasks; r=tomprince\n\nAny run-task task could exit with EXIT_PURGE_CACHES and expect the\ntask to be retried. Before this commit, we only registered this exit\ncode for tasks \"using: run-task.\" That excluded mozharness and\na handful of other \"using\" flavors.\n\nWith this commit, we register the exit codes for all run-task tasks\nby sniffing for the presence of run-task in the low-level code that\nemits the task definition. This should prevent run-tasks tasks\nfrom falling through the cracks and not having their exit codes\nresult in meaningful behavior.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1715", "files": ["taskcluster/taskgraph/transforms/job/run_task.py", "taskcluster/taskgraph/transforms/task.py"], "git_node": null, "git_parents": [null], "node": "9fbd5150cf6921f5542d7233ac197775d07f6ac8", "parents": ["252ca15e9688d1f32dc967f2139bc369f169be6b"], "tags": []}, {"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 1467549 - Disable the BackgroundHangReporter in ASan builds. r=Nika\n\nThis is causing LSan leaks which don't have an easy fix, and we're\nalready not running it in debug builds, so it can't hurt too much.\n\nMozReview-Commit-ID: I8nDnWIz9qr", "files": ["toolkit/components/backgroundhangmonitor/moz.build"], "git_node": null, "git_parents": [null], "node": "bad278043bc9ae7b0570bbec9c59d2578401becf", "parents": ["9fbd5150cf6921f5542d7233ac197775d07f6ac8"], "tags": []}, {"author": "Tokio Kajitsuka \u003ckajitsuka-tokio@g.ecc.u-tokyo.ac.jp\u003e", "branch": "default", "desc": "Bug 1469379 - let is missing from accessible/tests/mochitest/aom/test_general.html. r=surkov", "files": ["accessible/tests/mochitest/aom/test_general.html"], "git_node": null, "git_parents": [null], "node": "ca59f5dfd548d64d7b8c480f358bfcc80433bdc6", "parents": ["81bb56f69788224c30d62dc42e60004ecb5fc860"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Bug 1464898 - Disable /service-workers/service-worker/fetch-canvas-tainting-video-cache.https.html on Linux and Win7 for frequent failures. r=jmaher", "files": ["testing/web-platform/meta/service-workers/service-worker/fetch-canvas-tainting-video-cache.https.html.ini"], "git_node": null, "git_parents": [null], "node": "14cd7faaba45e0079bf5f7613969de9cf2bd5809", "parents": ["ca59f5dfd548d64d7b8c480f358bfcc80433bdc6"], "tags": []}, {"author": "Andi-Bogdan Postelnicu \u003cbpostelnicu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1453795 - PSM-Security - Initialize member fields in classes/ structures. r=keeler", "files": ["security/certverifier/CertVerifier.h", "security/manager/ssl/PublicKeyPinningService.cpp", "security/manager/ssl/SSLServerCertVerification.cpp", "security/pkix/lib/pkixbuild.cpp", "security/pkix/lib/pkixcheck.cpp", "security/pkix/lib/pkixder.h", "security/pkix/lib/pkixutil.h", "security/pkix/lib/pkixverify.cpp"], "git_node": null, "git_parents": [null], "node": "01b407d8a5afabe4fd3da80e3f586c26dc9bc901", "parents": ["14cd7faaba45e0079bf5f7613969de9cf2bd5809"], "tags": []}, {"author": "Andi-Bogdan Postelnicu \u003cbpostelnicu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1453795 - MFTB - Initialize member fields in classes/ structures. r=waldo", "files": ["mfbt/tests/TestPair.cpp"], "git_node": null, "git_parents": [null], "node": "e149fb41c712fb6e5236ca192d326451a41b0a82", "parents": ["01b407d8a5afabe4fd3da80e3f586c26dc9bc901"], "tags": []}, {"author": "Narcis Beleuzu \u003cnbeleuzu@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 01b407d8a5af (bug 1453795) for build bustages on CertVerifier.h . CLOSED TREE", "files": ["security/certverifier/CertVerifier.h", "security/manager/ssl/PublicKeyPinningService.cpp", "security/manager/ssl/SSLServerCertVerification.cpp", "security/pkix/lib/pkixbuild.cpp", "security/pkix/lib/pkixcheck.cpp", "security/pkix/lib/pkixder.h", "security/pkix/lib/pkixutil.h", "security/pkix/lib/pkixverify.cpp"], "git_node": null, "git_parents": [null], "node": "224fbf6776658105ad0ae21e8571ac7e50079431", "parents": ["e149fb41c712fb6e5236ca192d326451a41b0a82"], "tags": []}, {"author": "Olli Pettay \u003cOlli.Pettay@helsinki.fi\u003e", "branch": "default", "desc": "Bug 1469329, ensure mRetargetedTouchTargets has touch objects before using it, r=masayuki", "files": ["dom/events/EventDispatcher.cpp"], "git_node": null, "git_parents": [null], "node": "4cde573c283a56269a37bcb60066c863ba04ddd9", "parents": ["224fbf6776658105ad0ae21e8571ac7e50079431"], "tags": []}, {"author": "catalin.badea392@gmail.com", "branch": "default", "desc": "Bug 1469385 - Remove InsertChildAt_Deprecated and RemoveChildAt_Deprecated, r=bz,smaug", "files": ["dom/base/Attr.cpp", "dom/base/Attr.h", "dom/base/CharacterData.cpp", "dom/base/CharacterData.h", "dom/base/FragmentOrElement.cpp", "dom/base/FragmentOrElement.h", "dom/base/nsDocument.cpp", "dom/base/nsIDocument.h", "dom/base/nsINode.cpp", "dom/base/nsINode.h", "dom/html/HTMLFieldSetElement.cpp", "dom/html/HTMLFieldSetElement.h", "dom/html/HTMLOptGroupElement.cpp", "dom/html/HTMLOptGroupElement.h", "dom/html/HTMLPictureElement.cpp", "dom/html/HTMLPictureElement.h", "dom/html/HTMLSelectElement.cpp", "dom/html/HTMLSelectElement.h", "dom/svg/SVGDocument.cpp", "dom/svg/SVGDocument.h", "dom/svg/SVGSwitchElement.cpp", "dom/svg/SVGSwitchElement.h", "dom/xul/nsXULElement.cpp", "dom/xul/nsXULElement.h"], "git_node": null, "git_parents": [null], "node": "3395984ed40ce4a53e1621fcbeda606ea2c5cb62", "parents": ["4cde573c283a56269a37bcb60066c863ba04ddd9"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1467722: Don't return null for getComputedStyle when there's no pres shell. r=heycam\n\nWe need to deal with this case regardless from getPropertyValue, and this causes\npain and webcompat issues.\n\nMozReview-Commit-ID: Gbpzq0N4O2T\n", "files": ["dom/base/AnonymousContent.cpp", "dom/base/nsGlobalWindowOuter.cpp", "editor/libeditor/CSSEditUtils.cpp", "layout/style/nsComputedDOMStyle.cpp", "layout/style/nsComputedDOMStyle.h"], "git_node": null, "git_parents": [null], "node": "cb86f60d263987d7836f0694acc12106fee5d837", "parents": ["3395984ed40ce4a53e1621fcbeda606ea2c5cb62"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1467722: Make nsComputedDOMStyle store an actual Element. r=heycam\n\nMozReview-Commit-ID: FdfXvPARilD\n", "files": ["layout/style/nsComputedDOMStyle.cpp", "layout/style/nsComputedDOMStyle.h"], "git_node": null, "git_parents": [null], "node": "7a18800b893dee5ba5d051de33f7a10daa8fb9c2", "parents": ["cb86f60d263987d7836f0694acc12106fee5d837"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1467722: Do not throw when we don't have a style, but just return an empty style. r=heycam\n\nWe return '0' for the length, and \"\" for every declaration. This matches other\nbrowsers and the spec in the \"no style\" behavior.\n\nOf course we don't claim not to have a style for every case the spec says, but\nthat will come later, given that's a much more risky change.\n\nThis doesn't make any case where we returned something useful return something\nless useful, but stops null from getting returned, and returns the empty string\nwhich matches other browsers when they cannot return a style.\n\nMozReview-Commit-ID: 7Sc7HL5CgZU\n", "files": ["layout/style/nsComputedDOMStyle.cpp", "testing/web-platform/tests/css/cssom/getComputedStyle-detached-subtree.html"], "git_node": null, "git_parents": [null], "node": "c2b039dd2ace878328009a25e080d8703aa53b04", "parents": ["7a18800b893dee5ba5d051de33f7a10daa8fb9c2"], "tags": []}, {"author": "tiago \u003ctiago.paez11@gmail.com\u003e", "branch": "default", "desc": "Bug 948882 - Move inline scripts and styles into separate file for toolkit/crashreporter/content/crashes.xhtml (about:crashes). r=freddyb,gijs\n\nMozReview-Commit-ID: AdM1JIOaRIx", "files": ["toolkit/crashreporter/content/crashes.css", "toolkit/crashreporter/content/crashes.js", "toolkit/crashreporter/content/crashes.xhtml", "toolkit/crashreporter/jar.mn"], "git_node": null, "git_parents": [null], "node": "1034f8be097fd6d2f8eda8f7f7d277b92d91ff41", "parents": ["c2b039dd2ace878328009a25e080d8703aa53b04"], "tags": []}, {"author": "Andi-Bogdan Postelnicu \u003cbpostelnicu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1453795 - PSM-Security - Initialize member fields in classes/ structures. r=keeler", "files": ["security/certverifier/CertVerifier.h", "security/manager/ssl/PublicKeyPinningService.cpp", "s