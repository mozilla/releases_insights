perix.co.uk\u003e", "branch": "default", "desc": "Bug 1477458 - Add test for XML Pretty Print with restrictive CSP. r=bz a=ritu\n\nMozReview-Commit-ID: 3OkdYbkci40", "files": ["dom/base/test/reftest/reftest.list", "dom/base/test/reftest/test_xmlPrettyPrint_csp-ref.xml", "dom/base/test/reftest/test_xmlPrettyPrint_csp.xml", "dom/base/test/reftest/test_xmlPrettyPrint_csp.xml^headers^"], "git_node": null, "git_parents": [null], "node": "7f9a3b5d43164f001b31d504e7642425fa788740", "parents": ["e0d2d99c8e402743be026c40368e56e4106bd7e6"], "tags": []}, {"author": "Eugen Sawin \u003cesawin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1437988 - [1.5] Add progress tracking and expose progress via a delegate callback. r=jchen,snorp,droeh a=ritu", "files": ["mobile/android/base/java/org/mozilla/gecko/customtabs/CustomTabsActivity.java", "mobile/android/base/java/org/mozilla/gecko/webapps/WebAppActivity.java", "mobile/android/chrome/geckoview/GeckoViewProgressContent.js", "mobile/android/chrome/geckoview/geckoview.js", "mobile/android/chrome/geckoview/jar.mn", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/GeckoSessionTestRuleTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/util/Callbacks.kt", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSession.java", "mobile/android/geckoview_example/src/main/java/org/mozilla/geckoview_example/GeckoViewActivity.java"], "git_node": null, "git_parents": [null], "node": "9dcf2844400a88a44cc9c39a7e88e9af867ba264", "parents": ["7f9a3b5d43164f001b31d504e7642425fa788740"], "tags": []}, {"author": "Eugen Sawin \u003cesawin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1437988 - [2.0] Use progress tracking events for custom tabs progress bar. r=droeh a=ritu", "files": ["mobile/android/base/java/org/mozilla/gecko/customtabs/CustomTabsActivity.java"], "git_node": null, "git_parents": [null], "node": "94572bfa7c3b448672ce944d1292406c193e50d9", "parents": ["9dcf2844400a88a44cc9c39a7e88e9af867ba264"], "tags": []}, {"author": "Michal Novotny \u003cmichal.novotny\u003e", "branch": "default", "desc": "Bug 1477684 - rcwn blocking some xmlHttpRequests, r=valentin a=ritu\n\nRemove conditional and byte range headers when network won the race for case we send the request again due to 401 response.", "files": ["netwerk/protocol/http/nsHttpChannel.cpp"], "git_node": null, "git_parents": [null], "node": "5d23a4e11e09af2f1d1b47f2a6f9ab2236ac96ce", "parents": ["94572bfa7c3b448672ce944d1292406c193e50d9"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1476605 - Fix Error rep failure when stacktrace is a longString; r=sole. a=ritu\n\nThe actual fix for this issue will come in a future\nreps bundle when https://github.com/devtools-html/debugger.html/pull/6705\ngets merged.\nBut, I do want this change to be uplifted to release, and it should be\neasier to only apply this simple change than the whole next release\nwhich would contain unrelated code changes.\nAlso, this patch introduces a test to make sure we don't ever regress\nthis.\n\nMozReview-Commit-ID: 3QPrx3TLln0", "files": ["devtools/client/shared/components/reps/reps.js", "devtools/client/webconsole/test/mochitest/browser.ini", "devtools/client/webconsole/test/mochitest/browser_webconsole_error_with_longstring_stack.js"], "git_node": null, "git_parents": [null], "node": "fb6b3071abd1c2c1162e2795987d4ca1b4b3c4d2", "parents": ["5d23a4e11e09af2f1d1b47f2a6f9ab2236ac96ce"], "tags": []}, {"author": "rahul-shiv \u003crahul.shivaprasad@gmail.com\u003e", "branch": "default", "desc": "Bug 1478883 - Tagging operations should use DONTBUILD in commit message r=Callek a=ritu\n\nMozReview-Commit-ID: 6QBQG3m907I", "files": ["taskcluster/ci/release-early-tagging/kind.yml", "taskcluster/taskgraph/transforms/task.py"], "git_node": null, "git_parents": [null], "node": "75ba8d41ce3b3891db0e4b005bbbd2f9556503d6", "parents": ["fb6b3071abd1c2c1162e2795987d4ca1b4b3c4d2"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1472140 - 1. Set first paint flag when resuming and resizing composition; r=rbarker a=ritu\n\nWhen resuming composition in a new GeckoView, we wait for the first\npaint signal in order to uncover the SurfaceView. This patch makes sure\nthat we always send the first paint signal.\n\nMozReview-Commit-ID: EZeOR80d8HY", "files": ["gfx/layers/ipc/UiCompositorControllerParent.cpp", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoView.java", "widget/android/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "b7c86a171b24ced6528348c195a1cd0269657b25", "parents": ["75ba8d41ce3b3891db0e4b005bbbd2f9556503d6"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1472140 - 2. Set text input / accessibility views with the session; r=esawin a=ritu\n\nInstead of changing the text input / accessibility views during window\nattachment / detachment, we should change them during session attachment\n/ detachment because those views are associated with the session.\n\nMozReview-Commit-ID: G89rnc9ySS1", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoView.java"], "git_node": null, "git_parents": [null], "node": "d0ffdf9419b5d5ecf83b24a222144756239f0ea0", "parents": ["b7c86a171b24ced6528348c195a1cd0269657b25"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1472140 - 3. Remove ForceIsFirstPaint ipdl call; r=kats a=ritu\n\nRemove the PCompositorBridge::ForceIsFirstPaint call that's no longer\nused anywhere.", "files": ["gfx/layers/ipc/CompositorBridgeParent.cpp", "gfx/layers/ipc/CompositorBridgeParent.h", "gfx/layers/ipc/CrossProcessCompositorBridgeParent.h", "gfx/layers/ipc/PCompositorBridge.ipdl", "gfx/layers/ipc/UiCompositorControllerParent.cpp"], "git_node": null, "git_parents": [null], "node": "43ad096a472bf75f105573c958aa7c704b42b5e2", "parents": ["d0ffdf9419b5d5ecf83b24a222144756239f0ea0"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1477539 - Sanitizer.jsm must cleanup content preferences, r=Gijs a=ritu", "files": ["browser/modules/Sanitizer.jsm"], "git_node": null, "git_parents": [null], "node": "953f3ace7cf47f27a11c003e5893f363bfa236cd", "parents": ["43ad096a472bf75f105573c958aa7c704b42b5e2"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1479631 - Fix media.memory_caches_combined_limit_kb value on Android. r=drno a=ritu\n\nIt was accidentally changed from 524288 to 32768 on Android by bug 1448222.\nThis commit changes it back.", "files": ["modules/libpref/init/StaticPrefList.h"], "git_node": null, "git_parents": [null], "node": "60840467a49edb37b04d59c6e1487251e5ded4f5", "parents": ["953f3ace7cf47f27a11c003e5893f363bfa236cd"], "tags": []}], "date": 1533217742, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "nerli@mozilla.com"}, "9572": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nes-CL -\u003e fbb05587c584\nes-ES -\u003e a37c535d6f36\nes-MX -\u003e 0e02b8f65de2\net -\u003e 0064abc0dbdb\neu -\u003e fb7e0f4cb2b8\nfa -\u003e d9fed4094f6c\nff -\u003e 084fa8d3a5c0\nfi -\u003e b26a12267f60\nfr -\u003e d688d262c821\nfy-NL -\u003e 4cab16009e60\nga-IE -\u003e 51cd66f29630\ngd -\u003e 079207af901b\ngl -\u003e 42e54beb14e0\ngn -\u003e 61d37c9f757d\ngu-IN -\u003e 2414ba9bde02\nhe -\u003e cbe05b6078bd\nhi-IN -\u003e 8c24159e8953\nhr -\u003e a0640b308857\nhsb -\u003e 89af128502e4\nhu -\u003e a39b139fb196\nhy-AM -\u003e 1a00aa3e13fa\nid -\u003e 33cba7cc1f30\nis -\u003e b841a5eb8195\nja -\u003e 9711f4ca9034\nka -\u003e 27804304a1