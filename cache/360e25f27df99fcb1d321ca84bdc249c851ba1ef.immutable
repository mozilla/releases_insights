14 - avoid needless flattening in AndroidDecoderModule; r=jesup", "files": ["dom/media/platforms/android/AndroidDecoderModule.cpp", "dom/media/platforms/android/AndroidDecoderModule.h"], "git_node": null, "git_parents": [null], "node": "275b9ead049c085cc9e1e1a4240a5f8b551e7fc1", "parents": ["280327567bdf4ec76081a97c63dc1ec9f76550c7"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1468406 part 1 - Add NativeObject::realm(), forwarding to JSObject::realm() for now. r=luke", "files": ["js/src/vm/NativeObject.h"], "git_node": null, "git_parents": [null], "node": "8695dbfdc556824ad30259b41fc4e0b9c76911c6", "parents": ["275b9ead049c085cc9e1e1a4240a5f8b551e7fc1"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1468406 part 2 - Simplify JS_GlobalObjectTraceHook. r=jonco", "files": ["js/src/jsapi.cpp", "js/src/vm/JSObject-inl.h", "js/src/vm/JSObject.h"], "git_node": null, "git_parents": [null], "node": "7c8ab030787bed72c414d65df4c8053ef053e387", "parents": ["8695dbfdc556824ad30259b41fc4e0b9c76911c6"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1468406 part 3 - Add some obj-\u003eas\u003cFoo\u003e() casts to eliminate some JSObject::realm() calls. r=evilpie", "files": ["js/src/jit/VMFunctions.cpp", "js/src/jit/VMFunctions.h", "js/src/jsfriendapi.cpp", "js/src/vm/EnvironmentObject.cpp", "js/src/vm/HelperThreads.cpp", "js/src/vm/Interpreter-inl.h", "js/src/vm/Interpreter.cpp", "js/src/vm/TypeInference.cpp"], "git_node": null, "git_parents": [null], "node": "db80d5a4d8e9f5d9f4356661cf8290f9f2b20ce1", "parents": ["7c8ab030787bed72c414d65df4c8053ef053e387"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1455256 - Port more components to WorkerRef - part 1 - WorkerProxyToMainThreadRunnable, r=asuth", "files": ["dom/bindings/BindingU