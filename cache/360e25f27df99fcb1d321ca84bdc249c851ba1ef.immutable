la.com/D2542", "files": ["devtools/client/inspector/test/doc_inspector_embed.html", "dom/base/nsObjectLoadingContent.cpp", "testing/web-platform/meta/content-security-policy/svg/object-in-svg-foreignobject.sub.html.ini"], "git_node": null, "git_parents": [null], "node": "86868b564603f7fe0e58da069383677da018e88a", "parents": ["bd835a3a039abe6168f40c8435aba4c504402082"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1481869 - Correct in-content reporting payload r=Dolske a=lizzard\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3124", "files": ["browser/modules/BrowserUsageTelemetry.jsm"], "git_node": null, "git_parents": [null], "node": "26da3a2d48f9b89c6ff9d7682aa4db85c0107606", "parents": ["86868b564603f7fe0e58da069383677da018e88a"], "tags": []}, {"author": "Nihanth Subramanya \u003cnhnt11@gmail.com\u003e", "branch": "default", "desc": "Bug 1480610 - Add minimal stub for fxmonitor add-on into build system. r=johannh a=lizzard", "files": ["browser/extensions/fxmonitor/manifest.json", "browser/extensions/fxmonitor/moz.build", "browser/extensions/moz.build"], "git_node": null, "git_parents": [null], "node": "f853ee4fbc7de43edd2e3b1418b58a9a31ec40c2", "parents": ["26da3a2d48f9b89c6ff9d7682aa4db85c0107606"], "tags": []}, {"author": "Jeff Gilbert \u003cjgilbert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1482289 - Enlarge index buffer validation cache size to handle CAD workloads. - r=kvark a=lizzard\nMozReview-Commit-ID: 8DF3o4mLYZ6", "files": ["dom/canvas/WebGLBuffer.cpp"], "git_node": null, "git_parents": [null], "node": "09d46665a5c5dd9026d052e480d7eb61f462d808", "parents": ["f853ee4fbc7de43edd2e3b1418b58a9a31ec40c2"], "tags": []}], "date": 1534153765, "git_changesets": [null, null, null, null], "user": "ebalazs@mozilla.com"}, "9649": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n