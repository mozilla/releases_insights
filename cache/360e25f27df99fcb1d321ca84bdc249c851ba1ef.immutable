node": null, "git_parents": [null], "node": "a21ffe6a30df4d840a236cc5e4971e1b097efc29", "parents": ["9673563a0d712f9abc63fd0b728a8793d6b4f078"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nfr -\u003e b5bdb8b00f7d", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "eac6e7c7f0d2069263bb83d2ca48b80e0eb0e6ee", "parents": ["a21ffe6a30df4d840a236cc5e4971e1b097efc29"], "tags": []}], "date": 1533668433, "git_changesets": [null, null], "user": "ffxbld"}, "9616": {"changesets": [{"author": "Jamie Nicol \u003cjnicol@mozilla.com\u003e", "branch": "default", "desc": "Bug 1474883 - Ensure D2D glyph cache is pruned after rendering 1000 transformed glyphs. r=bas, a=RyanVM\n\nRendering glyphs at many different rotations was causing the D2D glyph\ncache to grow very large. Calling EndDraw/BeginDraw will prune the\ncache, but is costly, so only do it for every 1000 glyphs.\n\nMozReview-Commit-ID: HUFpxDvYAzQ", "files": ["gfx/2d/DrawTargetD2D1.cpp", "gfx/2d/DrawTargetD2D1.h"], "git_node": null, "git_parents": [null], "node": "a376138dcac609585fe2795580927d71d91d091c", "parents": ["eac6e7c7f0d2069263bb83d2ca48b80e0eb0e6ee"], "tags": []}, {"author": "Edgar Chen \u003cechen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1450989 - Capture the action and target as part of the form submission creation. r=bz, a=RyanVM", "files": ["dom/base/FormData.cpp", "dom/html/HTMLFormElement.cpp", "dom/html/HTMLFormElement.h", "dom/html/HTMLFormSubmission.cpp", "dom/html/HTMLFormSubmission.h"], "git_node": null, "git_parents": [null], "node": "b8104bdbefa9b2040222a907f706c8239c55a2b9", "parents": ["a376138dcac609585fe2795580927d71d91d091c"], "tags": []}, {"author": "Matt Howell \u003cmhowell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1473113 - Defer initializing the MAR index until it's needed. r=rstrong, a=RyanVM", "files": ["modules/libmar/src/mar.h", "modules/libmar/src/mar_read.c"], "git_node": null, "git_parents": [null], "node": "a3659f1ac0dca72d8afeff1b6227127e8fe3d6ec", "parents": ["b8104bdbefa9b2040222a907f706c8239c55a2b9"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1476088 - Additional search submission telemetry. r=florian, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D2165", "files": ["toolkit/components/search/nsSearchService.js", "toolkit/components/search/tests/xpcshell/test_sendSubmissionURL.js", "toolkit/components/search/tests/xpcshell/xpcshell.ini", "toolkit/components/telemetry/docs/data/environment.rst"], "git_node": null, "git_parents": [null], "node": "124fc13916039d660910ce324175c0e093c4e28e", "parents": ["a3659f1ac0dca72d8afeff1b6227127e8fe3d6ec"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1475571 - Replace follow-on addon with in tree telemetry. r=mikedeboer,florian, a=RyanVM", "files": ["browser/base/content/test/performance/browser_preferences_usage.js", "browser/extensions/moz.build", "browser/modules/BrowserUsageTelemetry.jsm", "toolkit/components/search/nsSearchService.js", "toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "053a2a490c333e3053351a7e1b0788dc5dff9eac", "parents": ["124fc13916039d660910ce324175c0e093c4e28e"], "tags": []}], "date": 1533677338, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9617": {"changesets": [{"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1373234 - Avoid races in tests involving menu creation. r=mixedpuppy, a=test-only\n\nbrowser.menus.create and browser.contextMenus.create are asynchronous\nAPIs. For compatibility reasons, they cannot return a promise (since\nthey already return an integer).\n\nThis modifies all tests that use either of these APIs, to ensure that\nthe test waits for the callback of the last menus/contextMenus.create\ncall before continuing with the test.\n\nIn some cases in browser_ext_menus.js I did not add any callbacks,\nbecause there were other asynchronous API calls (browser.tabs API)\nthat already guaranteed that the test made a round-trip to the parent\nprocess before continuing.\n\nThis fixes:\n- Bug 1462862 (browser_ext_contextMenus_icons.js)\n- Bug 1403429 (browser_ext_contextMenus_onclick.js)\n- Bug 1321182 (browser_ext_contextMenus.js)\n- Bug 1373234 (browser_ext_menus.js)\n\nMozReview-Commit-ID: IZFUyIw8Tbl", "files": ["browser/components/extensions/test/browser/browser_ext_contextMenus.js", "browser/components/extensions/test/browser/browser_ext_contextMenus_icons.js", "browser/components/extensions/test/browser/browser_ext_contextMenus_onclick.js", "browser/components/extensions/test/browser/browser_ext_menus.js"], "git_node": null, "git_parents": [null], "node": "0713cd1a0cb972756ddf15d64431976e1737fb98", "parents": ["053a2a490c333e3053351a7e1b0788dc5dff9eac"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1373234 - Small cleanup in browser_ext_contextMenus*.js tests. r=mixedpuppy, a=test-only\n\nUse sendMessage/awaitMessage instead of notifyPass/awaitFinish in tests\nwhere this is not the last completion callback.\n\nRemove an unneeded browser.contextMenus.onClicked.addListener call.\n\nMozReview-Commit-ID: Akpla9tiAlD", "files": ["browser/components/extensions/test/browser/browser_ext_contextMenus.js", "browser/components/extensions/test/browser/browser_ext_contextMenus_icons.js"], "git_node": null, "git_parents": [null], "node": "1da2d2a309c3b07796727f7704d652aa59a8566c", "parents": ["0713cd1a0cb972756ddf15d64431976e1737fb98"], "tags": []}, {"author": "Dimi Lee \u003cdlee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1407123 - Wait for the update task to be finished before running next test case. r=francois, a=test-only\n\nThe test_partialUpdateV4() test case doesn't wait for the update task\nto be finished. It checks the status in the HTTP server side and then calls\nrun_next_test(). However, when XPCShell test is done, it will trigger\nthe shutdown process and hence interrupt the ongoing update task.\n\nThis cause the xpcshell test receives an error since the update is\ninterrupted and returns an error like NS_ERROR_UC_UPDATE_SHUTDOWNING.\n\nThis patch also fixes a javascript error that we didn't stop the httpd\nserver when cleanup.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D2360", "files": ["toolkit/components/url-classifier/tests/unit/test_listmanager.js"], "git_node": null, "git_parents": [null], "node": "75b021eb6f7f70e03aaa571c78c9e8a0502de821", "parents": ["1da2d2a309c3b07796727f7704d652aa59a8566c"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1454627 - Re-enable browser_ext_user_events.js (bug 1381305). r=mixedpuppy, a=test-only\n\nRe-enable the test that was disabled in bug 1381305 and fix the\nunderlying issue that caused th intermittent failure in the first place.\n\nMozReview-Commit-ID: BL9wS2fogaf", "files": ["browser/components/extensions/test/browser/browser-common.ini", "browser/components/extensions/test/browser/browser_ext_user_events.js"], "git_node": null, "git_parents": [null], "node": "30a17d2d7779b6e32b5e9bb4d013a8cfa1934f14", "parents": ["75b021eb6f7f70e03aaa571c78c9e8a0502de821"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1454627 - Run \"onclick\" event of menu with user input. r=mixedpuppy, a=test-only\n\nMozReview-Commit-ID: r1URJfOKUB", "files": ["browser/components/extensions/child/ext-menus.js", "browser/components/extensions/test/browser/browser_ext_user_events.js"], "git_node": null, "git_parents": [null], "node": "5c573fbddd4b2b5dc6d3812b24685c989e2fc85d", "parents": ["30a17d2d7779b6e32b5e9bb4d013a8cfa1934f14"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1454627 - Fix timing issue in browser_ext_user_events.js. r=mixedpuppy, a=test-only\n\nThe hard-coded wait exists to avoid a test failure caused by a\nnon-functional click event in an options browser. However, that\nstill does not get rid of the intermittent failure.\n\nTo really avoid the timing issue, check whether onclick was fired\nafter supposedly triggering a click, and if not, wait and retry.\n\nMozReview-Commit-ID: 9eg6sz1s1e3", "files": ["browser/components/extensions/test/browser/browser_ext_user_events.js"], "git_node": null, "git_parents": [null], "node": "fd81c0f6fb7f78e637235744e980d9498b58b77b", "parents": ["5c573fbddd4b2b5dc6d3812b24685c989e2fc85d"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1417052 - Use unique keyword in browser_ext_omnibox.js. r=aswan, a=test-only\n\nManually verified using the STR from\nhttps://bugzilla.mozilla.org/show_bug.cgi?id=1417052#c47\n\nI am not re-enabling the test by default because the same test file is\nreported to have another intermittent (bug 1416103).\n\nMozReview-Commit-ID: 1xsyjMMby1H", "files": ["browser/components/extensions/test/browser/browser-common.ini", "browser/components/extensions/test/browser/browser_ext_omnibox.js"], "git_node": null, "git_parents": [null], "node": "afb2c70029f6a6401c67cf671072be88d95e1f27", "parents": ["fd81c0f6fb7f78e637235744e980d9498b58b77b"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1416103 - Re-enable browser_ext_omnibox.js everywhere. r=aswan, a=test-only\n\nLikely fixed by the patch for bug 1417052\n\nRan the test with --repeat=50 on Linux and did not observe any failures.\n\nMozReview-Commit-ID: FuMo8jdgJCn", "files": ["browser/components/extensions/test/browser/browser-common.ini"], "git_node": null, "git_parents": [null], "node": "1a80ac4f1ab7464dc0d2eeeeaba11ba37bf0aca0", "parents": ["afb2c70029f6a6401c67cf671072be88d95e1f27"], "tags": []}], "date": 1533692135, "git_changesets": [null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9618": {"changesets": [{"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1478183 - Update strings (including de) for about:welcome in Firefox 62. r=ursula, a=lizzard\n\nMozReview-Commit-ID: HjYrbTmNBuC", "files": ["browser/components/newtab/aboutNewTabService.js", "browser/components/newtab/tests/browser/browser_packaged_as_locales.js", "browser/extensions/activity-stream/install.rdf.in", "browser/extensions/activity-stream/locales/ach/strings.properties", "browser/extensions/activity-stream/locales/an/strings.properties", "browser/extensions/activity-stream/locales/ar/strings.properties", "browser/extensions/activity-stream/locales/az/strings.properties", "browser/extensions/activity-stream/locales/be/strings.properties", "browser/extensions/activity-stream/locales/bg/strings.properties", "browser/extensions/activity-stream/locales/br/strings.properties", "browser/extensions/activity-stream/locales/ca/strings.properties", "browser/extensions/activity-stream/locales/cak/strings.properties", "browser/extensions/activity-stream/locales/cs/strings.properties", "browser/extensions/activity-stream/locales/cy/strings.properties", "browser/extensions/activity-stream/locales/da/strings.properties", "browser/extensions/activity-stream/locales/de/strings.properties", "browser/extensions/activity-stream/locales/dsb/strings.properties", "browser/extensions/activity-stream/locales/el/strings.properties", "browser/extensions/activity-stream/locales/en-CA/strings.properties", "browser/extensions/activity-stream/locales/eo/strings.properties", "browser/extensions/activity-stream/locales/es-AR/strings.properties", "browser/extensions/activity-stream/locales/es-CL/strings.properties", "browser/extensions/activity-stream/locales/es-ES/strings.properties", "