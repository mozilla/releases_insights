, "user": "ffxbld"}, "9560": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging dd92dec96711e60a8c6a49ebe584fa23a453a292 with DEVEDITION_62_0b13_BUILD1 a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "dfa6bf6bc3b8cea9ccf00982bae4af931a5530c7", "parents": ["61883ca9a7a948bb11a9a1d12f7ee253f99b4a13"], "tags": []}], "date": 1532982969, "git_changesets": [null], "user": "ffxbld"}, "9561": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nes-CL -\u003e ca84e86adf6a", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "bbfc343f818df09a0841752aef7ab5776213bad4", "parents": ["dfa6bf6bc3b8cea9ccf00982bae4af931a5530c7"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\neo -\u003e 894060f259b1\nes-AR -\u003e 37f33f24fa12\nes-CL -\u003e 35553869d784\nsv-SE -\u003e caf47dd81a5a", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "217cbc03f5dd5dab710fcc346596588677c987d6", "parents": ["bbfc343f818df09a0841752aef7ab5776213bad4"], "tags": []}], "date": 1533013238, "git_changesets": [null, null], "user": "ffxbld"}, "9562": {"changesets": [{"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1451891 - Fix race conditions in __wrap_dlerror. r=glandium a=pascalc\n\n__wrap_dlerror uses a single pointer for all threads, which means one\nthread could get the dlerror result from another thread. Normally this\nwouldn't cause crashes. However, because dlerror results come from a\nper-thread buffer, if a thread exits and our saved dlerror result came\nfrom that thread, the saved pointer could then refer to invalid memory.\n\nThe proper way to fix this is to use TLS and have a per-thread pointer\nfor __wrap_dlerror. However, instead of using up a TLS slot, this patch\nkeeps the single pointer for custom messages, and fallback to per-thread\ndlerror call for system messages. While the race condition still exists,\nI think the risk is acceptable. Even when races occur, they should no\nlonger cause crashes.\n\nMozReview-Commit-ID: 4hGksidjiVz", "files": ["mozglue/linker/ElfLoader.cpp", "mozglue/linker/ElfLoader.h"], "git_node": null, "git_parents": [null], "node": "c43d2dbaf59e73747f25a2d8c5bcd68c28e5cadf", "parents": ["217cbc03f5dd5dab710fcc346596588677c987d6"], "tags": []}], "date": 1533043821, "git_changesets": [null], "user": "nbeleuzu@mozilla.com"}, "9563": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging dd92dec96711e60a8c6a49ebe584fa23a453a292 with DEVEDITION_62_0b13_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "4a084c06e9964ce8587128281e0aa8a80fe57738", "parents": ["c43d2dbaf59e73747f25a2d8c5bcd68c28e5cadf"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "6b5cdd788e14d38f021e4d5f6cdd477ad394a3f8", "parents": ["4a084c06e9964ce8587128281e0aa8a80fe57738"], "tags": []}], "date": 1533050586, "git_changesets": [null, null], "user": "ffxbld"}, "9564": {"changesets": [{"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "No bug - Tagging dd92dec96711e60a8c6a49ebe584fa23a453a292 with FIREFOX_62_0b13_RELEASE a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [nul