ext.cpp", "js/xpconnect/src/xpcprivate.h"], "git_node": null, "git_parents": [null], "node": "16ad556ccc7300cbfda54a14c49f650a82836f73", "parents": ["4b18075d2be22bc8fd1eeb0803a502cdce9782b4"], "tags": []}, {"author": "Andi-Bogdan Postelnicu \u003cbpostelnicu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1453795 - XPConnect - Initialize member fields in classes/ structures. r=peterv", "files": ["js/xpconnect/loader/ChromeScriptLoader.cpp", "js/xpconnect/src/BackstagePass.h", "js/xpconnect/src/XPCCallContext.cpp", "js/xpconnect/src/xpcprivate.h"], "git_node": null, "git_parents": [null], "node": "f18328bef6bb069e0b651c913281537b219b1dbd", "parents": ["16ad556ccc7300cbfda54a14c49f650a82836f73"], "tags": []}, {"author": "Olli Pettay \u003cOlli.Pettay@helsinki.fi\u003e", "branch": "default", "desc": "Bug 1470099 - Make CSSStyleDeclaration's wrapper use nursery heap and make last Release call ClearComputedStyle(), r=emilio", "files": ["dom/webidl/CSSStyleDeclaration.webidl", "layout/style/nsComputedDOMStyle.cpp"], "git_node": null, "git_parents": [null], "node": "412d616528061512809285bce66dc6457fdd02ee", "parents": ["f18328bef6bb069e0b651c913281537b219b1dbd"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1470105: Fix a typo in stylesheet cloning. r=jwatt\n\nSummary: Just something I noticed while writing unrelated code.\n\nReviewers: jwatt\n\nBug #: 1470105\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1747\n\nMozReview-Commit-ID: 7KMTT9Kmdwc\n", "files": ["servo/components/style/stylesheets/stylesheet.rs"], "git_node": null, "git_parents": [null], "node": "f5b8b5dbf6787ffe5317cec0aecd00dc1d95845d", "parents": ["412d616528061512809285bce66dc6457fdd02ee"], "tags": []}, {"author": "sotaro \u003csotaro.ikeda.g@gmail.com\u003e", "branch": "default", "desc": "Bug 1470090 - Fix LayerObserverEpoch handling r=nical", "files": ["dom/ipc/TabChild.cpp", "gfx/layers/wr/WebRenderBridgeParent.cpp"], "git_node": null, "git_parents": [null], "node": "688b3d9f8611dfb00a99e631538d2cfe5135ac7b", "parents": ["f5b8b5dbf6787ffe5317cec0aecd00dc1d95845d"], "tags": []}, {"author": "Narcis Beleuzu \u003cnbeleuzu@mozilla.com\u003e", "branch": "default", "desc": "Backed out 4 changesets (bug 1268889) for Windows GTest failures. CLOSED TREE\n\nBacked out changeset da427a67372e (bug 1268889)\nBacked out changeset 97528847b7b7 (bug 1268889)\nBacked out changeset b2320061fbcb (bug 1268889)\nBacked out changeset dd3b7047ea6f (bug 1268889)", "files": ["dom/base/nsGlobalWindowInner.cpp", "dom/base/nsGlobalWindowInner.h", "dom/ipc/ContentChild.cpp", "dom/ipc/ContentChild.h", "dom/ipc/ContentParent.cpp", "dom/ipc/PContent.ipdl", "dom/locales/en-US/chrome/security/security.properties", "image/ImageCacheKey.h", "image/imgICache.idl", "image/imgLoader.cpp", "layout/build/nsLayoutStatics.cpp", "modules/libpref/init/StaticPrefList.h", "testing/web-platform/meta/clear-site-data/__dir__.ini", "testing/web-platform/meta/clear-site-data/navigation.https.html.ini", "testing/web-platform/meta/clear-site-data/storage.https.html.ini", "toolkit/components/cleardata/ClearDataService.js", "toolkit/components/clearsitedata/ClearSiteData.cpp", "toolkit/components/clearsitedata/ClearSiteData.h", "toolkit/components/clearsitedata/moz.build", "toolkit/components/moz.build"], "git_node": null, "git_parents": [null], "node": "59322b179c0fdb4423d42b624da7bf64ee5a2327", "parents": ["688b3d9f8611dfb00a99e631538d2cfe5135ac7b"], "tags": []}, {"author": "Lars T Hansen \u003clhansen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1459900 - Struct types: read, write, validate.  r=luke\n\nWe introduce a simple \"struct\" type definition for Wasm.  A struct has\nfields of primitive types, including anyref, but no other information,\nnotably no information about subtype relationships.\n\nThe syntax is:\n\n  (type $tname (struct (field $fname i32) ...))\n\nwhere the $fnames are currently ignored.\n\n(In the future, the $fnames will denote the field numbers of their\nfields within the structure and will be used by the struct.get and\nstruct.set instructions in the text format.  If any $fname is bound in\nmultiple structures the bindings must resolve to the same field number\nand field type.)\n\nTo record the type information there is a new StructType type in\nWasmTypes.h.\n\nWe generalize the SigWithId table in ModuleEnvironment to instead be a\nTypeDef table, where a TypeDef is a tagged union of SigWithId and\nStructType.\n\nSimilarly, there is a new AstTypeDef base class for AstSig and\nAstStruct, and the sigs_ table in AstModule becomes a types_ table.\n\nWhen the ModuleEnvironment is about to be destroyed we move the\nStructType types into a dense structTypes_ table in the Module; a\nlater patch will make use of these types.  The structTypes_ get\nserialized and deserialized with the module.", "files": ["js/src/jit-test/tests/wasm/binary.js", "js/src/jit-test/tests/wasm/gc/structs.js", "js/src/wasm/AsmJS.cpp", "js/src/wasm/WasmAST.h", "js/src/wasm/WasmBaselineCompile.cpp", "js/src/wasm/WasmBinaryConstants.h", "js/src/wasm/WasmBinaryToAST.cpp", "js/src/wasm/WasmBinaryToText.cpp", "js/src/wasm/WasmGenerator.cpp", "js/src/wasm/WasmIonCompile.cpp", "js/src/wasm/WasmModule.cpp", "js/src/wasm/WasmModule.h", "js/src/wasm/WasmOpIter.h", "js/src/wasm/WasmTextToBinary.cpp", "js/src/wasm/WasmTypes.cpp", "js/src/wasm/WasmTypes.h", "js/src/wasm/WasmValidate.cpp", "js/src/wasm/WasmValidate.h"], "git_node": null, "git_parents": [null], "node": "ca90f5e47f465d8bf1d8c65f88efc34343bdf597", "parents": ["59322b179c0fdb4423d42b624da7bf64ee5a2327"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1470109 - Move ServiceWorkerCleanUp.jsm into toolkit/components/cleardata, r=johannh", "files": ["toolkit/components/cleardata/ServiceWorkerCleanUp.jsm", "toolkit/components/cleardata/moz.build", "toolkit/forgetaboutsite/ServiceWorkerCleanUp.jsm", "toolkit/forgetaboutsite/moz.build"], "git_node": null, "git_parents": [null], "node": "32b9774b0ca553be64be27f98271223e1bde2057", "parents": ["ca90f5e47f465d8bf1d8c65f88efc34343bdf597"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1268889 - Implement Clear-Site-Data header - part 1, r=mayhemer", "files": ["dom/locales/en-US/chrome/security/security.properties", "layout/build/nsLayoutStatics.cpp", "testing/web-platform/meta/clear-site-data/navigation.https.html.ini", "testing/web-platform/meta/clear-site-data/storage.https.html.ini", "toolkit/components/cleardata/ClearDataService.js", "toolkit/components/clearsitedata/ClearSiteData.cpp", "toolkit/components/clearsitedata/ClearSiteData.h", "toolkit/components/clearsitedata/moz.build", "toolkit/components/moz.build"], "git_node": null, "git_parents": [null], "node": "015ed5271d5d55912d65a44eb2ee2ab77827aea7", "parents": ["32b9774b0ca553be64be27f98271223e1bde2057"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1268889 - Implement Clear-Site-Data header - part 2 - pref, r=smaug", "files": ["modules/libpref/init/StaticPrefList.h", "testing/web-platform/meta/clear-site-data/__dir__.ini", "toolkit/components/clearsitedata/ClearSiteData.cpp"], "git_node": null, "git_parents": [null], "node": "d33b51527821f20db2e01bcccd894e49e9e0b7e4", "parents": ["015ed5271d5d55912d65a44eb2ee2ab77827aea7"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1268889 - Implement Clear-Site-Data header - part 3 - reload contexts, r=smaug", "files": ["dom/base/nsGlobalWindowInner.cpp", "dom/base/nsGlobalWindowInner.h", "dom/ipc/ContentChild.cpp", "dom/ipc/ContentChild.h", "dom/ipc/ContentParent.cpp", "dom/ipc/PContent.ipdl"], "git_node": null, "git_parents": [null], "node": "d6a2857d3e217aa3343555a2e258fe0812e003