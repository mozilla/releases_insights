sm"], "git_node": null, "git_parents": [null], "node": "e17c9454ca9479fe6f3552b714109b740cfa711f", "parents": ["cdb16820b53eca89322572a56d008cb8d4635df8"], "tags": []}, {"author": "Adam Gashlin \u003cagashlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1480144: Let Windows Restart Manager ride the trains. r=jimm a=ritu\n\nSummary:\nThe plan is to study the \"restart manager\" in 62 with a pref flip,\nand if that goes well enable it on release in 63. If it is to be\nenabled for the whole population in 63 it needs to ride the trains,\nso we'll let it be enabled by default as 63 goes to beta. There will\nbe time to uplift a backout so it won't reach the release population,\nif the 62 study indicates problems.\n\nReviewers: jmathies\n\nReviewed By: jmathies\n\nBug #: 1480144\n\nDifferential Revision: https://phabricator.services.mozilla.com/D2620", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "0249442a741cb771fdd23cd5670d07ac63f920e2", "parents": ["e17c9454ca9479fe6f3552b714109b740cfa711f"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1470306 - MessagePort unlinked should start the cleanup/close/shutdown procedure of the object, r=smaug a=ritu", "files": ["dom/messagechannel/MessagePort.cpp"], "git_node": null, "git_parents": [null], "node": "a07fb916fa61a068c5e8b22437ad5cbf9b6dbfad", "parents": ["0249442a741cb771fdd23cd5670d07ac63f920e2"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1470306 - Adding some MOZ_DIAGNOSTIC_ASSERT in MessagePort, r=smaug a=ritu", "files": ["dom/messagechannel/MessagePort.cpp", "dom/messagechannel/MessagePort.h"], "git_node": null, "git_parents": [null], "node": "c1927c01d7ed7678e0115e6ff728ac26069a45ad", "parents": ["a07fb916fa61a068c5e8b22437ad5cbf9b6dbfad"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1470306 - Ensure MessagePort is in the right state if the connection to PBackground fails, r=qdot a=ritu", "files": ["dom/messagechannel/MessagePort.cpp"], "git_node": null, "git_parents": [null], "node": "fb00c69a67877caee3c40d523b467ac87784b694", "parents": ["c1927c01d7ed7678e0115e6ff728ac26069a45ad"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1470306 - More assertions in MessagePort, r=qdot a=ritu\n\nStill trying to understand why we have MessagePort::CloseInternal crashes, here\nI introduce more assertions and a security check in case PBackground\ninitialization fails.", "files": ["dom/messagechannel/MessagePort.cpp"], "git_node": null, "git_parents": [null], "node": "3a3725e292e129729b50c60989a4e2012cf8112a", "parents": ["fb00c69a67877caee3c40d523b467ac87784b694"], "tags": ["DEVEDITION_62_0b14_BUILD1", "DEVEDITION_62_0b14_RELEASE", "FIREFOX_62_0b14_BUILD1", "FIREFOX_62_0b14_RELEASE"]}], "date": 1533231691, "git_changesets": [null, null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "9577": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\ngn -\u003e 109f94ad5c45\nth -\u003e 652e433e4b16", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "b9421bf289262721cff74f760e2fd40040f973df", "parents": ["3a3725e292e129729b50c60989a4e2012cf8112a"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\ngn -\u003e 109f94ad5c45\nth -\u003e 652e433e4b16", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "87a5bdd802def167ba232a22772c01e7f27f1b2a", "parents": ["b9421bf28926272