: [".hgtags"], "git_node": null, "git_parents": [null], "node": "ee81dc3697969815eb0f5aa7da0877a57565f8dc", "parents": ["0bf14e32fa165be93dee7c16820a5a4bef937120"], "tags": []}], "date": 1531846675, "git_changesets": [null], "user": "ffxbld"}, "9495": {"changesets": [{"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1469889 - Allow blacklisting search engines based on URL. r=florian a=lizzard", "files": ["toolkit/components/search/nsSearchService.js", "toolkit/components/search/tests/xpcshell/data/search_blacklist.json", "toolkit/components/search/tests/xpcshell/test_blacklist.js", "toolkit/components/search/tests/xpcshell/test_json_cache_blacklist.js", "toolkit/components/search/tests/xpcshell/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "74193d58a1e73b22b3f7091afa593cf664c2d5c9", "parents": ["ee81dc3697969815eb0f5aa7da0877a57565f8dc"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1475769 - Bail out from nsRefreshDriver::Tick before updating mMostRecentRefresh when the refresh driver is waiting for paint. r=mattwoodrow a=lizzard\n\nBefore this patch, there is a race condition that the refresh driver updates\nthe most recent refresh time but animations corresponding to the refresh driver\ndon't update their internal state, that causes the inconsistency that such\nanimations are regarded as finished on the most recent time whereas their\ninternal states represent the animations are still in active.  This is the one\nof the cause of bug 1466010, i.e. the display item corresponding to the\nanimation is going to be rebuilt without calling MarkNeedsDisplayItemRebuild.\n\nMozReview-Commit-ID: 9adzDV9E3ka", "files": ["layout/base/nsRefreshDriver.cpp", "layout/base/nsRefreshDriver.h"], "git_node": null, "git_parents": [null], "node": "03de027328011ffb4b48e05b1fdee10dcbcefe4a", "parents": ["74193d58a1e73b22b3f7091afa593cf664c2d5c9"], "tags": []}], "date": 1531856865, "git_changesets": [null, null], "user": "archaeopteryx@coole-files.de"}, "9496": {"changesets": [{"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1467256 - Wait until about:debugging UI in browser_application_panel_open-links.js. r=ladybenko, a=test-only\n\nMozReview-Commit-ID: 323WvitlWcy", "files": ["devtools/client/application/test/browser_application_panel_open-links.js", "devtools/server/actors/stylesheets.js"], "git_node": null, "git_parents": [null], "node": "ec603dd58a436d5f079da57d9bfdc1cd9037e093", "parents": ["03de027328011ffb4b48e05b1fdee10dcbcefe4a"], "tags": []}, {"author": "Bel\u00e9n Albeza \u003cbalbeza@mozilla.com\u003e", "branch": "default", "desc": "Bug 1467256 - Temporarily disable the test. r=nchevobbe, a=test-only\n\nMozReview-Commit-ID: sWZLg7PCvt", "files": ["devtools/client/application/test/browser.ini"], "git_node": null, "git_parents": [null], "node": "0b6675cbc84468c2fcfb12bce6484485381d7be6", "parents": ["ec603dd58a436d5f079da57d9bfdc1cd9037e093"], "tags": []}, {"author": "Bobby Holley \u003cbobbyholley@gmail.com\u003e", "branch": "default", "desc": "Bug 1452762 - Avoid interrupting the wrong script in watchdog tests. r=arai, a=test-only\n\nMy best guess as to the failures here is that we're not actually\nreaching the busyWait call by the time the interrupt callback fires,\nand thus we're killing unrelated scripts.\n\nMozReview-Commit-ID: GvCJzBcJlXm\n\nDifferential Revision: https://phabricator.services.mozilla.com/D2162", "files": ["js/xpconnect/tests/unit/head_watchdog.js"], "git_node": null, "git_parents": [null], "node": "0ebbe8b5e0ca59c24192681d77a6c1c028c36a54", "parents": ["0b6675cbc84468c2fcfb12bce6484485381d7be6"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1463443 - Disable browser_toolbar_overflow.js on debug linux 32bit. r=adw, a=test-only\n\nMozReview-Commit-ID: 1VtrrFhBZXF", "files": ["brows