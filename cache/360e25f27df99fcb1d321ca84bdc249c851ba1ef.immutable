onents/extensions/test/browser/browser_ext_menus.js"], "git_node": null, "git_parents": [null], "node": "fff218cba849af85e392ca103061b453c581fc87", "parents": ["84f7e9706a491a638585b6329205a015f768b5da"], "tags": []}, {"author": "Lina Cambridge \u003clina@yakshaving.ninja\u003e", "branch": "default", "desc": "Bug 1474033 - Ensure `PlacesUtils.bookmarks.moveToFolder` bumps the Sync change counter for items moved between different parents. r=Standard8 a=lizzard", "files": ["services/sync/tests/unit/test_bookmark_tracker.js", "toolkit/components/places/Bookmarks.jsm"], "git_node": null, "git_parents": [null], "node": "6aedd84a5388b511ba15f64e6efeaaec09079c58", "parents": ["fff218cba849af85e392ca103061b453c581fc87"], "tags": []}, {"author": "Nicolas B. Pierron \u003cnicolas.b.pierron@gmail.com\u003e", "branch": "default", "desc": "Bug 1464829 - Remove recover instruction results after bailouts. r=jandem a=lizzard", "files": ["js/src/jit/BaselineBailouts.cpp", "js/src/jit/JSJitFrameIter.h"], "git_node": null, "git_parents": [null], "node": "1f9ce3126115f82fa8440a311e175e0771183425", "parents": ["6aedd84a5388b511ba15f64e6efeaaec09079c58"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1473256 - Don't add a length property in AddLengthProperty if it's already present. r=anba a=lizzard", "files": ["js/src/builtin/Array.cpp", "js/src/jit-test/tests/basic/bug1473256.js"], "git_node": null, "git_parents": [null], "node": "0e7242cbb1ce425e8e8caf0457defc0e01881220", "parents": ["1f9ce3126115f82fa8440a311e175e0771183425"], "tags": []}, {"author": "Andrei Oprea \u003candrei.br92@gmail.com\u003e", "branch": "default", "desc": "Bug 1474244 - Prevent ASRouter uninit from being called for unrelated pref changes r=k88hudson a=lizzard\n\nMozReview-Commit-ID: 2LIyaZqd9bA", "files": ["browser/extensions/activity-stream/data/content/activity-stream.bundle.js", "browser/extensions/activity-stream/data/content/activity-stream.bundle.js.map", "browser/extensions/activity-stream/install.rdf.in", "browser/extensions/activity-stream/lib/ASRouterFeed.jsm", "browser/extensions/activity-stream/test/unit/asrouter/ASRouterFeed.test.js"], "git_node": null, "git_parents": [null], "node": "ce18b96ec82bfaf85bd85c6ad79dad52a063b152", "parents": ["0e7242cbb1ce425e8e8caf0457defc0e01881220"], "tags": []}], "date": 1531983153, "git_changesets": [null, null, null, null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "9500": {"changesets": [{"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1468801 - deprecate SkiaGL for Canvas2D. r=snorp a=lizzard", "files": ["layout/reftests/canvas/reftest.list", "layout/reftests/css-gradients/reftest.list", "mobile/android/app/mobile.js", "modules/libpref/init/all.js", "testing/web-platform/meta/webvtt/rendering/cues-with-video/processing-model/too_many_cues.html.ini"], "git_node": null, "git_parents": [null], "node": "3c6db05ccd3dd692715a07017f6f6bd4e83a82c4", "parents": ["ce18b96ec82bfaf85bd85c6ad79dad52a063b152"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1471045: Don't flush layout if the ready promise is not resolved yet. r=heycam a=lizzard\n\nThis prevents FOUC, and also matches the chromium logic:\n\n  https://cs.chromium.org/chromium/src/third_party/blink/renderer/core/css/font_face_set_document.cc?l=105&rcl=e70e652d516c7d14d50e547aae2da1690c4ae54c\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1827\n\nMozReview-Commit-ID: A6m5fAMXhae", "files": ["layout/style/FontFaceSet.cpp", "layout/style/FontFaceSet.h"], "git_node": null, "git_parents": [null], "node": "96f07d80f013bfb9a1ec95a79f28d0e3951be7dc", "parents": ["3c6db05ccd3dd692715a07017f6f6bd4e83a82c4"], "tags": []}, {"author": "Chris Pearce \u003ccpearce@mozilla.com\u003e", "branch": "default", "desc": "Bug 1470932 - Get principal from nsGlobalWindowInner directly in MediaManaager::IsActivelyCapturingOrHasAPermission(). r=baku a=lizzard\n\nnsGlobalWindowInner::GetExtantDoc() can potentially return null, and\nwe're not null checking its return value in\nMediaManaager::IsActivelyCapturingOrHasAPermission() which I think is the\ncause of this crash.\n\nSo instead of getting the principal from the window's extant doc, we can\nget the principal directly from the nsGlobalWindowInner.\n\nMozReview-Commit-ID: BUwiJGLss2a", "files": ["dom/media/MediaManager.cpp"], "git_node": null, "git_parents": [null], "node": "6f47058039b853b2c8d766a620483d2ff33b033d", "parents": ["96f07d80f013bfb9a1ec95a79f28d0e3951be7dc"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1474728 - Fix focus styles in all tabs menu r=dao a=lizzard\n\nMozReview-Commit-ID: K8Yxes8U3ff", "files": ["browser/themes/shared/tabs.inc.css"], "git_node": null, "git_parents": [null], "node": "83e495b4c9335e11c2cce23a30c01c821087c1c1", "parents": ["6f47058039b853b2c8d766a620483d2ff33b033d"], "tags": []}, {"author": "Anny Gakhokidze \u003cagakhokidze@mozilla.com\u003e", "branch": "default", "desc": "Bug 1473161 - Add missing bound check in nsContentUtils::DataTransferItemToImage. r=nika a=RyanVM\n\nMozReview-Commit-ID: 3dq5yWZwJiG", "files": ["dom/base/nsContentUtils.cpp", "dom/base/nsContentUtils.h"], "git_node": null, "git_parents": [null], "node": "a85b6c7cc4181d314cedcc865bb228ff44fab99e", "parents": ["83e495b4c9335e11c2cce23a30c01c821087c1c1"], "tags": []}, {"author": "Ian Moody \u003cmoz-ian@perix.co.uk\u003e", "branch": "default", "desc": "Bug 1474379 - Match regex against the entire panel ID. r=miker,rpl a=lizzard\n\nSo panels provided by extensions with IDs that contain words like \"inspector\"\ndon't break.\nInclude test in existing panel creation test.\n\nMozReview-Commit-ID: JerMCaKRgkl", "files": ["browser/components/extensions/test/browser/browser_ext_devtools_panel.js", "devtools/client/framework/toolbox.js"], "git_node": null, "git_parents": [null], "node": "6fffc0b497a3b306d929f7ed8221ac648748f5c0", "parents": ["a85b6c7cc4181d314cedcc865bb228ff44fab99e"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1474557 - Prevent ExtensionStorageIDB and child/ext-storage from caching a stale or rejected selectBackend promise. r=mixedpuppy a=lizzard\n\nMozReview-Commit-ID: Kgwtm7QXW9o", "files": ["toolkit/components/extensions/ExtensionStorageIDB.jsm", "toolkit/components/extensions/child/ext-storage.js", "toolkit/components/extensions/test/xpcshell/test_ext_storage_tab.js"], "git_node": null, "git_parents": [null], "node": "7fa538f4814b2e18309f4a1c0c092fbef2d2fcf2", "parents": ["6fffc0b497a3b306d929f7ed8221ac648748f5c0"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1474557 - Clear the dbPromise cached by ext-storage when IndexedDB raises an exception while opening the db. r=mixedpuppy a=lizzard\n\nMozReview-Commit-ID: 9qsDYI0wgmI", "files": ["toolkit/components/extensions/child/ext-storage.js", "toolkit/components/extensions/test/xpcshell/head_storage.js", "toolkit/components/extensions/test/xpcshell/test_ext_storage_tab.js", "toolkit/components/extensions/test/xpcshell/xpcshell-remote.ini", "toolkit/components/extensions/test/xpcshell/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "52e3d099d0632f231688d9b3142cb50a72d1aa2a", "parents": ["7fa538f4814b2e18309f4a1c0c092fbef2d2fcf2"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1475644 - Don't send URL in GeckoView crash reports r=jchen a=lizzard\n\nMozReview-Commit-ID: 1Fx1tfcjoQ6", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/CrashReporterService.java"], "git_node": null, "git_parents": [null], "node": "2cb21e6a62f8befbb2550d7770aa23d1314432cb", "parents": ["52e3d099d0632f231688d9b3142cb50a72d1aa2a"], "tags": []}, {"author": "Miko Mynttinen \u003cmikokm@gmail.com\u003e", "branch": "default", "desc": "Bug 1472465 - Update flattened nsDisplayOpacity geometry despite empty invalidation region r=mattwoodrow a=lizzard\n\nMozReview-Commit-ID: 7mrTuQ6gEoA", "files": ["layout/painting/FrameLayerBuilder.cpp", "layout/painting/nsDisplayList.h", "layout/reftests/bugs/bug1472465-1-ref.html", "layout/reftests/bugs/bug1472465-1.html", "layout/reftests/bugs/reftest.list"], "git_node": null, "git_parents": [null], "node": "076e903341b40e66d9622d108d1a5dbca7d1f73c", "parents": ["2cb21e6a62f8befbb2550d7770aa23d1314432cb"], "tags": []}, {"author": "Francesco Lodolo (:flod) \u003cflod@lodolo.net\u003e", "branch": "default", "desc": "Bug 1474553 - [br] Update Freelang searchplugin to https, update icon r=mkaply a=lizzard\n\nMozReview-Commit-ID: AxsKzQGrTOz", "files": ["browser/components/search/searchplugins/freelang.xml"], "git_node": null, "git_parents": [null], "node": "9573e5a35f1cee865ba27f02dc1ea0d7f8aa8183", "parents": ["076e903341b40e66d9622d108d1a5dbca7d1f73c"], "tags": []}], "date": 1531984415, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "9501": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nel -\u003e f9b4457800ce\nka -\u003e 6bbf762f33bd\npl -\u003e 043259e4ace4\npt-BR -\u003e 6405086a5b00", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "80a239ab930dc7afee86bb4fb8fc09e9f789655b", "parents": ["9573e5a35f1cee865ba27f02dc1ea0d7f8aa8183"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nel -\u003e a77798686447\ngn -\u003e ab0cd3eda02f\nit -\u003e a6b71b4e07c2\nka -\u003e d09c5c65aaba\npl -\u003e 043259e4ace4\npt-BR -\u003e c32091c0e71b\nte -\u003e 08cc42c20f00", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "3e9a3bae27fc7ebb3f73b073d9ec4bb6376f8254", "parents": ["80a239ab930dc7afee86bb4fb8fc09e9f789655b"], "tags": []}], "date": 1531988570, "git_changesets": [null, null], "user": "ffxbld"}, "9502": {"changesets": [{"author": "Shane Caraveo \u003cscaraveo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1455405 - Fix intermittent by using real events. r=rpl, a=test-only\n\nThis test was testing that files are loaded/executed/etc in the page, but\nwhat we really care about is that the webrequest api works.  Other tests\nare responsible for stuff like css and js actually work.  The patch does\nmaintain (fixed) the js test, but removes the css test for lack of a good\nway to properly wait for css to apply.\n\nMozReview-Commit-ID: B2uByaxNeK2", "files": ["toolkit/components/extensions/test/mochitest/file_script_good.js", "toolkit/components/extensions/test/mochitest/mochitest-common.ini", "toolkit/components/extensions/test/mochitest/test_ext_webrequest_basic.html"], "git_node": null, "git_parents": [null], "node": "1013e1d3ae845783d49fb70338c560968ef4a7d5", "parents": ["3e9a3bae27fc7ebb3f73b073d9ec4bb6376f8254"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1476149 - Intermittent verify failure in browser_formless_submit_chrome.js. r=Gijs, a=test-only\n\nMake the test select() urlbar text beforem moving to the right of it\n\nDifferential Revision: https://phabricator.services.mozilla.com/D2220", "files": ["toolkit/components/passwordmgr/test/browser/browser_formless_submit_chrome.js"], "git_node": null, "git_parents": [null], "node": "ec2f4b6b68d01f42cc0070e495b428a96eb8b01a", "parents": ["1013e1d3ae845783d49fb70338c560968ef4a7d5"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1371142 - Confirm that the page loaded is about:blank before continuing with the test. r=Gijs, a=test-only\n\nThis matches the behavior that is implemented in subdialogs.js where the load event handler is not removed until the new location is about:blank.\n\nMozReview-Commit-ID: FZHW6Z63M2M", "files": ["browser/components/preferences/in-content/tests/browser_subdialogs.js"], "git_node": null, "git_parents": [null], "node": "1e6bbba5527d056e3ce64c6d9556b9a27a8ac6a8", "parents": ["ec2f4b6b68d01f42cc0070e495b428a96eb8b01a"], "tags": []}, {"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP blocklist remote-settings - a=repo-update r=mtabara\n\nDifferential Revision: https://phabricator.services.mozilla.com/D2236", "files": ["browser/app/blocklist.xml", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/blocklists/addons.json"], "git_node": null, "git_parents": [null], "node": "78f265be217f6a73b505d788b3781bc35b4fb480", "parents": ["1e6bbba5527d056e3ce64c6d9556b9a27a8ac6a8"], "tags": ["DEVEDITION_62_0b10_BUILD1", "DEVEDITION_62_0b10_RELEASE", "FIREFOX_62_0b10_BUILD1", "FIREFOX_62_0b10_RELEASE"]}], "date": 1532008964, "git_changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "9503": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\npt-BR -\u003e dd200bc70b91\nte -\u003e 1394d8dc9823", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "98eb2288482c6745671daad36343def32505b20a", "parents": ["78f265be217f6a73b505d788b3781bc35b4fb480"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10