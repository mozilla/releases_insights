ll], "user": "ffxbld"}, "9459": {"changesets": [{"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1467385 - Use PanelMultiView APIs for keyboard navigation in the identity popup. r=Paolo a=lizzard\n\nPanelMultiView has its own concept of \"selected\", so we should use this rather than move focus\nusing advanceFocusIntoSubTree.\n\nMozReview-Commit-ID: DW2JqqggLl1", "files": ["browser/base/content/browser-siteIdentity.js", "browser/components/controlcenter/content/panel.inc.xul", "browser/components/customizableui/PanelMultiView.jsm", "browser/components/customizableui/test/browser_panel_keyboard_navigation.js"], "git_node": null, "git_parents": [null], "node": "7938e31cdc975bb8239ead5ef24d2362f125e2b9", "parents": ["2220abd172f0c6b576d720593e7f06ab65407c4f"], "tags": []}, {"author": "Bobby Holley \u003cbobbyholley@gmail.com\u003e", "branch": "default", "desc": "Bug 1431285 - Cap the number of style threads at six. r=emilio a=lizzard\n\nMozReview-Commit-ID: 3qI1mIvDn8j\n\nDifferential Revision: https://phabricator.services.mozilla.com/D1928", "files": ["servo/components/style/gecko/global_style_data.rs"], "git_node": null, "git_parents": [null], "node": "ea180e6624d84b154178bd36daae496f93ad0d15", "parents": ["7938e31cdc975bb8239ead5ef24d2362f125e2b9"], "tags": []}, {"author": "Jamie Nicol \u003cjnicol@mozilla.com\u003e", "branch": "default", "desc": "Bug 1468738 - Create new DisplayItemDatas if required for unmerged display items r=mattwoodrow a=lizzard", "files": ["layout/painting/FrameLayerBuilder.cpp"], "git_node": null, "git_parents": [null], "node": "9f52abcf637e7cc862cd12ddc4223055edd1dc66", "parents": ["ea180e6624d84b154178bd36daae496f93ad0d15"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1469000: Fix image to layout transform for invalidation. r=aosmond a=lizzard\n\nWhen computing image to layout transforms for invalidation, use the actual\nintrinsic size of the source image, instead of the layout intrinsic size, which\nmay be scaled by ResponsiveImageSelector since bug 1149357.\n\nI have absolutely no idea how to write a test for this, suggestions welcome.\n\nMozReview-Commit-ID: LP6C9fSvMi2", "files": ["layout/generic/nsImageFrame.cpp"], "git_node": null, "git_parents": [null], "node": "80347cdf232ed10421728e7a22a1cad6584861c3", "parents": ["9f52abcf637e7cc862cd12ddc4223055edd1dc66"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1473199: Make permission controls tabbable again in the identity popup. r=johannh a=lizzard\n\nNow that the PanelMultiView keyboard navigation code is being used for the identity popup, these need a class of subviewkeynav in order to be tabbable.\n\nMozReview-Commit-ID: 47drdy78s4F", "files": ["browser/base/content/browser-siteIdentity.js"], "git_node": null, "git_parents": [null], "node": "ae63660523100f864701a7ee4d299ea5b1d39b84", "parents": ["80347cdf232ed10421728e7a22a1cad6584861c3"], "tags": []}], "date": 1531327216, "git_changesets": [null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "9460": {"changesets": [{"author": "Florian Qu\u00e8ze \u003cflorian@queze.net\u003e", "branch": "default", "desc": "Bug 1448241 - Disable browser_urlbar_keyed_search.js and browser_urlbar_search.js on Windows 32 due to intermittent OOM failures. r=mconley, a=test-only", "files": ["browser/base/content/test/performance/browser.ini"], "git_node": null, "git_parents": [null], "node": "015e15a8ec84ec0e8741ab817ee27e9f0aad78ce", "parents": ["ae63660523100f864701a7ee4d299ea5b1d39b84"], "tags": []}, {"author": "Bobby Holley \u003cbobbyholley@gmail.com\u003e", "branch": "default", "desc": "Bug 1447856 - Make the watchdog tests actually wait for completion. r=arai, a=test-only\n\nMozReview-Commit-ID: KjvUxJSrmtk\n\nDifferential Revision: https://phabricator.services.mozilla.com/D2017", "files": ["js/xpconnect/tests/unit/head_watchdog.js", "js/xpconnect/tests/unit/test_watchdog_default.js", "js/xpconnect/tests/unit/test_watchdog_disable.js", "js/xpconnect/tests/unit/test_watchdog_enable.js", "js/xpconnect/tests/unit/test_watchdog_hibernate.js", "js/xpconnect/tests/unit/test_watchdog_toggle.js"], "git_node": null, "git_parents": [null], "node": "ad01105a9bfdf9ce7e624b896066aef553b23861", "parents": ["015e15a8ec84ec0e8741ab817ee27e9f0aad78ce"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1452153 - Fixing a DOM Worker assertion related to frozen/thrown windows. r=smaug, a=NPOTB", "files": ["dom/workers/WorkerPrivate.cpp"], "git_node": null, "git_parents": [null], "node": "fcb4c2a228bb5fd217fdc40cf39f2d73298ef6c1", "parents": ["ad01105a9bfdf9ce7e624b896066aef553b23861"], "tags": []}, {"author": "Shane Caraveo \u003cscaraveo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1471959 - Leave keaGroupName and signatureSchemeName undefined if value is none. r=rpl, a=lizzard\n\nMozReview-Commit-ID: 2Ca7xCMOPAH", "files": ["toolkit/components/extensions/schemas/web_request.json", "toolkit/modules/addons/SecurityInfo.jsm"], "git_node": null, "git_parents": [null], "node": "cb0560aa6642c222156e1f29ee64a5cc21b9ae61", "parents": ["fcb4c2a228bb5fd217fdc40cf39f2d73298ef6c1"], "tags": []}, {"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 1473192 - Recycle virtual content node when reassigning. r=jchen, a=lizzard", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/geckoview/SessionAccessibility.java"], "git_node": null, "git_parents": [null], "node": "a0fbaff943d70a06a347f49a7dcc3011bd8e966d", "parents": ["cb0560aa6642c222156e1f29ee64a5cc21b9ae61"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1473200: Provide accessibility context for permission controls in the identity popup. r=johannh, a=lizzard\n\nThe containers are given an ARIA role of group and labels are associated using aria-labelledby.\nFor example, this allows screen reader users to know which permission each control is associated with.\nOtherwise, they might hear only \"Clear this permission and ask again  button\", with no knowledge of what the permission is.\n\nMozReview-Commit-ID: LeiOmz6go9l", "files": ["browser/base/content/browser-siteIdentity.js", "browser/components/controlcenter/content/panel.inc.xul"], "git_node": null, "git_parents": [null], "node": "34073b01d86bf88632ffb35198329b0f4a9249a8", "parents": ["a0fbaff943d70a06a347f49a7dcc3011bd8e966d"], "tags": []}], "date": 1531339060, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9461": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\npl -\u003e d5dd05518465\npt-BR -\u003e 18db49b9c435\npt-PT -\u003e 57522ca1bc8d\nrm -\u003e ed7e5280a48a\nru -\u003e 4a2e0e5400b2\nsk -\u003e 5ad4d1810dd3\nte -\u003e 507087739a97\nth -\u003e cfb9c26cfd4f", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "c7bddd75937f15b31fa082ccaa700cf46c50c60f", "parents": ["34073b01d86bf88632ffb35198329b0f4a9249a8"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\npa-IN -\u003e 6f89e07eae6b\npl -\u003e c9b27f000486\npt-BR -\u003e 4a1c94a03af4\npt-PT -\u003e 51225c33ee27\nrm -\u003e b52c1f32e6fb\nru -\u003e 4a2e0e5400b2\nsk -\u003e 5ad4d1810dd3\nte -\u003e 507087739a97\nth -\u003e cfb9c26cfd4f", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "c71427ccf286810d2a31876d1df368a3c8090364", "parents": ["c7bddd75937f15b31fa082ccaa700cf46c50c60f"], "tags": []}], "date": 15313550