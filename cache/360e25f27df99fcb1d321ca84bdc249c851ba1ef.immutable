arents": [null], "node": "5cb524fe7be80371a7c0f5266c7903cb62c389ff", "parents": ["69d593f6097b0b3f3b0aac6a314241bba511e5e1"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1478036: Ensure that inproc nop-space patches use atomic writes; r=handyman a=lizzard", "files": ["mozglue/misc/interceptor/MMPolicies.h", "mozglue/misc/interceptor/PatcherNopSpace.h", "mozglue/misc/interceptor/TargetFunction.h"], "git_node": null, "git_parents": [null], "node": "aaab66845dc5ffb0e9e66833afbd7834112ade2c", "parents": ["5cb524fe7be80371a7c0f5266c7903cb62c389ff"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1478716 - Ensure we only call FT_Get_MM_Var once per face (and cache the result in the font entry), to avoid being bitten by freetype bug 52955 on Ubuntu. r=lsalzman a=lizzard", "files": ["gfx/thebes/gfxFT2FontBase.cpp", "gfx/thebes/gfxFT2FontBase.h", "gfx/thebes/gfxFT2FontList.cpp", "gfx/thebes/gfxFT2FontList.h", "gfx/thebes/gfxFcPlatformFontList.cpp", "gfx/thebes/gfxFcPlatformFontList.h", "gfx/thebes/gfxFontEntry.h"], "git_node": null, "git_parents": [null], "node": "eaa3a2a13a5d31b476f99e9ac29c62f35692c775", "parents": ["aaab66845dc5ffb0e9e66833afbd7834112ade2c"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1478720 - Increase the fractional adjustment applied to 'opsz' on macOS to avoid using the font's default setting, which may be mishandled by Core Text. r=lsalzman a=lizzard", "files": ["gfx/thebes/gfxMacFont.cpp"], "git_node": null, "git_parents": [null], "node": "07f7e41737eb3e874f3b26190333de4ce62bdb3e", "parents": ["eaa3a2a13a5d31b476f99e9ac29c62f35692c775"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1479642: Make Windows XULMenuitemAccessibleWrap::Name const so it overrides AccessibleWrap::Name. r=surkov a=lizzard\n\nThis again exposes the accelerator (e.g. Ctrl+T for New Tab) for menu items via IAccessible::accName on windows.\n\nBug 1438193 made Accessible::Name const.\nOn Windows, XULMenuitemAccessibleWrap::Name is overridden to append the accelerator to the name.\nUnfortunately, this override was missed when converting Name to const (and wasn't a compile error because it didn't use the override keyword).\nAs such, this override stopped being called; we always called the const version, since that's the one inherited into AccessibleWrap.\nMaking this const causes this override to be called.\n\nMozReview-Commit-ID: 7Gb199mzhHa", "files": ["accessible/windows/msaa/XULMenuAccessibleWrap.cpp", "accessible/windows/msaa/XULMenuAccessibleWrap.h"], "git_node": null, "git_parents": [null], "node": "d3320ef71ef2f89fdee994272383f4ea7b2124a0", "parents": ["07f7e41737eb3e874f3b26190333de4ce62bdb3e"], "tags": []}], "date": 1533543852, "git_changesets": [null, null, null, null, null, null], "user": "dluca@mozilla.com"}, "9597": {"changesets": [{"author": "Philip Chimento \u003cphilip.chimento@gmail.com\u003e", "branch": "default", "desc": "Bug 1458382 - Repeat GCC bug workaround in another place. r=sstangl a=lizzard", "files": ["js/src/jit/RegisterSets.h"], "git_node": null, "git_parents": [null], "node": "b1ca612ffb07f244735f83df37947652de43a6bf", "parents": ["d3320ef71ef2f89fdee994272383f4ea7b2124a0"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1471651 - Allow Non FQDN to be specified in policy. r=Felipe a=lizzard\n\nMozReview-Commit-ID: 4mVbOfTGIak", "files": ["browser/components/enterprisepolicies/Policies.jsm", "browser/components/enterprisepolicies/schemas/policies-schema.json", "browser/components/enterprisepolicies/tests/browser/browser_policies_simple_pref_policies.js"], "git_node": null, "git_parents": [null], "node": "6a8ce370f814923cf542c0c59ca9a7cee5b5f74c", "parents": ["b1ca612ffb07f244735f83df37947652de43a6bf"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1463846 - Switch enterprise only policies to be machine on Windows. r=Felipe a=lizzard\n\nMozReview-Commit-ID: 3lWwfzjVbhS", "files": ["browser/components/enterprisepolicies/schemas/policies-schema.json"], "git_node": null, "git_parents": [null], "node": "4a79d4e9efff569c6c93e125bbfdd341dd047ae3", "parents": ["6a8ce370f814923cf542c0c59ca9a7cee5b5f74c"], "tags": []}, {"author": "Jed Davis \u003cjld@mozilla.com\u003e", "branch": "default", "desc": "Bug 1467889 - Adjust some uses of XPCOM strings.  r=mrbkap r=mstange a=lizzard\n\nMozReview-Commit-ID: 5AG4WAmbLZz", "files": ["dom/base/nsContentUtils.cpp", "dom/ipc/ContentChild.cpp", "dom/ipc/TabParent.cpp", "tools/profiler/gecko/nsProfiler.cpp", "widget/nsClipboardProxy.cpp"], "git_node": null, "git_parents": [null], "node": "f7b6f9fd2de59474ed8f08b9545712070c69b60c", "parents": ["4a79d4e9efff569c6c93e125bbfdd341dd047ae3"], "tags": []}, {"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1404274 - Key Evaluation on the cloned JS objects; r=asuth a=lizzard", "files": ["dom/indexedDB/IDBCursor.cpp", "dom/indexedDB/IDBObjectStore.cpp", "dom/indexedDB/IDBObjectStore.h", "testing/web-platform/meta/IndexedDB/clone-before-keypath-eval.html.ini", "testing/web-platform/meta/IndexedDB/key_invalid.htm.ini", "testing/web-platform/meta/IndexedDB/keypath-exceptions.htm.ini"], "git_node": null, "git_parents": [null], "node": "e21cf620b8865d0d0f1c81c44123444185477643", "parents": ["f7b6f9fd2de59474ed8f08b9545712070c69b60c"], "tags": []}, {"author": "Razvan Caliman \u003crcaliman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1480086 - Restore styles for Rule view warning icon. r=gl a=lizzard\n\nMozReview-Commit-ID: 12xDt0Haj03", "files": ["devtools/client/themes/rules.css"], "git_node": null, "git_parents": [null], "node": "42533e38035088b7259618ada072fc1c8cb0b133", "parents": ["e21cf620b8865d0d0f1c81c44123444185477643"], "tags": []}], "date": 1533571828, "git_changesets": [null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "9598": {"changesets": [{"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Bug 1463846 - Switch enterprise only policies to be machine on Windows: fix conflicts. a=browser-chrome-fix", "files": ["browser/components/enterprisepolicies/schemas/policies-schema.json"], "git_node": null, "git_parents": [null], "node": "476aa14b33e32c344756376c78eca6f4e3d32a4f", "parents": ["42533e38035088b7259618ada072fc1c8cb0b133"], "tags": []}], "date": 1533576330, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "9599": {"changesets": [{"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1468249 - Avoid resizing the TP toggle in the main menu in touch mode. r=dao, a=ritu\n\nThis also fixes bug 1468311, because it made the touch control significantly more\nannoying. Now, the TP toggle in the main menu has the right size, but tapping outside\nof it still doesn't trigger it, though at least the menu is not closed so the user can\neasily tap again.\n\nMozReview-Commit-ID: eRfAEwXype", "files": ["browser/components/customizableui/content/panelUI.inc.xul", "browser/themes/shared/customizableui/panelUI.inc.css"], "git_node": null, "git_parents": [null], "node": "de436be5e56eced99d5a2c8c06fd401a1c74cb3a", "parents": ["476aa14b33e32c344756376c78eca6f4e3d32a4f"], "tags": []}, {"author": "Andrew Swan \u003caswan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1476177 - Fix platform matching in AMO metadata requests. r=mixedpuppy, a=lizzard\n\nMozReview-Commit-ID: EvjeXdCyLxi", "files": ["toolkit/mozapps/extensions/internal/AddonRepository.jsm", "toolkit/mozapps/extensions/test/xpcshell/data/test_AddonRepository_getAddonsByIDs.json", "toolkit/mozapps/extensions/test/xpcshell/test_AddonRepository.js"], "git_node": null, "git_parents": [null], "node": "83e81646f5005a861ef203bb34b3fbf9bfd29359", "parents": ["de436be5e56eced99d5a2c8c06fd401a1c74cb3a"], "tags": []}, {"author": "Adam Gashlin \u003cagashlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1480826 - Reenable telemetry.os_shutting_down probe. r=chutten, a=lizzard\n\nThis records whether the shutdown ping was generated during an OS shutdown.\n\nThis is the reverse of [[ https://bugzilla.mozilla.org/show_bug.cgi?id=1389992 | bug 1389992 ]] with appropriate changes to Scalars.yaml.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D2734", "files": ["toolkit/components/telemetry/Scalars.yaml", "toolkit/components/telemetry/TelemetrySend.jsm", "toolkit/components/telemetry/tests/unit/test_TelemetrySession.js"], "git_node": null, "git_parents": [null], "node": "c66300bc349b1ab7e2c13c0dc71d6d17ed5d4290", "parents": ["83e81646f5005a861ef203bb34b3fbf9bfd29359"], "tags": []}], "date": 1533578631, "git_changesets": [null, null, null], "user": "ryanvm@gmail.com"}, "9600": {"changesets": [{"author": "Andreea Pavel \u003capavel@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset c66300bc349b (bug 1480826) for build bustages", "files": ["toolkit/components/telemetry/Scalars.yaml", "toolkit/components/telemetry/TelemetrySend.jsm", "toolkit/components/telemetry/tests/unit/test_TelemetrySession.js"], "git_node": null, "git_parents": [null], "node": "42fef3b61d6611f8c927b319bef97a7fa46f7010", "parents": ["c66300bc349b1ab7e2c13c0dc71d6d17ed5d4290"], "tags": []}], "date": 1533579595, "git_changesets": [null], "user": "apavel@mozilla.com"}, "9601": {"changesets": [{"author": "Adam Gashlin \u003cagashlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1480826 - Reenable telemetry.os_shutting_down probe. r=chutten, a=lizzard\n\nThis records whether the shutdown ping was generated during an OS shutdown.\n\nThis is the reverse of [[ https://bugzilla.mozilla.org/show_bug.cgi?id=1389992 | bug 1389992 ]] with appropriate changes to Scalars.yaml.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D2734", "files": ["toolkit/components/telemetry/Scalars.yaml", "toolkit/components/telemetry/TelemetrySend.jsm", "toolkit/components/telemetry/tests/unit/test_TelemetrySession.js"], "git_node": null, "git_parents": [null], "node": "2545d974faf880a9c4d2c0cf5326c71e8f7127a2", "parents": ["42fef3b61d6611f8c927b319bef97a7fa46f7010"], "tags": []}], "date": 1533581043, "git_changesets": [null], "user": "apavel@mozilla.com"}, "9602": {"changesets": [{"author": "Bryce Van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1479579 - Update GMP fallback downloader for Widevine CDM 1.4.9.1088. r=rhelmer, a=lizzard\n\nMozReview-Commit-ID: 2f6ArUh12vz", "files": ["toolkit/content/gmp-sources/widevinecdm.json"], "git_node": null, "git_parents": [null], "node": "f7876ad4ed3ed8660fe0982e6898bcde59580f60", "parents": ["2545d974faf880a9c4d2c0cf5326c71e8f7127a2"], "tags": []}], "date": 1533581288, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "9603": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nbe -\u003e 1628de489900\nbg -\u003e e30557a49a1a\nfr -\u003e 44425acc0258\nhu -\u003e 9444c6753eb6\nsk -\u003e fcc228049e7d\ntr -\u003e 67b076eb7d0f", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "78d441ab1ddd170fc33d8560874c093c4a168fdd", "parents": ["f7876ad4ed3ed8660fe0982e6898bcde59580f60"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets DONTBUILD r=release a=l10n-bump\n\nar -\u003e 4981c236ff1b\nbe -\u003e d69b1b8ec4a7\nen-CA -\u003e b6a95e24f0b5\nes-MX -\u003e 26edba7b9667\nfr -\u003e 44425acc0258\nhu -\u003e 9444c6753eb6\nkk -\u003e 1905e19035f3\nnn-NO -\u003e 4948cfa