 1478003\n\nDifferential Revision: https://phabricator.services.mozilla.com/D2352", "files": ["toolkit/components/places/UnifiedComplete.js", "toolkit/components/places/tests/unifiedcomplete/autofill_tasks.js"], "git_node": null, "git_parents": [null], "node": "f15db10c801ca0df2210d54a4ee2a8f6d4386e47", "parents": ["340bb17cbcd8c8b7108e0a03a494b475b6d9f55c"], "tags": []}, {"author": "Nicolas B. Pierron \u003cnicolas.b.pierron@gmail.com\u003e", "branch": "default", "desc": "Bug 1418971 - Remove rematerialized frames after bailouts and exceptions. r=jandem a=lizzard", "files": ["js/src/jit/BaselineBailouts.cpp", "js/src/jit/JitFrames.cpp", "js/src/vm/Stack.cpp"], "git_node": null, "git_parents": [null], "node": "c2571cc8a086ca412c3797af972038ae90a392f4", "parents": ["f15db10c801ca0df2210d54a4ee2a8f6d4386e47"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1477469 - Check for null composition pointer; r=esawin a=lizzard\n\nCheck for null TextComposition pointer, which can apparently happen\nduring regular usage.\n\nMozReview-Commit-ID: 6nKjyBVL2vF", "files": ["widget/android/GeckoEditableSupport.cpp"], "git_node": null, "git_parents": [null], "node": "f9114bfa6fcb0647f15f6f783038206f7fef34ad", "parents": ["c2571cc8a086ca412c3797af972038ae90a392f4"], "tags": []}], "date": 1532939406, "git_changesets": [null, null, null, null], "user": "apavel@mozilla.com"}, "9551": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets DONTBUILD r=release a=l10n-bump\n\nes-CL -\u003e fa5f9234f929\nes-ES -\u003e 6b8b5860ccae\nfi -\u003e b4d4c45ce236\nfr -\u003e 400d0eaa747e\nfy-NL -\u003e 8978bec4c1b6\ngn -\u003e ae138d8a06bb\nhi-IN -\u003e 137efe34af48\nhsb -\u003e 0fe3beb4215c\nit -\u003e 9da80d3bab01\nka -\u003e f62a4e9e1f54\nko -\u003e e12c5c625c9a\nlt -\u003e f9c88cca24a2\nlv -\u003e 28762e5bb0a7\nmai -\u003e 74b8ff68a3c8\nms -