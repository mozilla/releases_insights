omList.h"], "git_node": null, "git_parents": [null], "node": "af8ef80f3326ee96a7a33f55a07ea2914756a92f", "parents": ["7f7a190b3d0de55a0e231d9a32b82e2ce0643697"], "tags": []}, {"author": "Coroiu Cristina \u003cccoroiu@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland a=merge on a CLOSED TREE", "files": [], "git_node": null, "git_parents": [null, null], "node": "a32be868e151ab9f1cf945976316f730292a8b09", "parents": ["af8ef80f3326ee96a7a33f55a07ea2914756a92f", "6b6f3f6ecf142908b3e437d3bc3fac75540a9bcb"], "tags": []}, {"author": "Dave Hunt \u003cdhunt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1466211 - Vendor requests via |mach vendor python|; r=ahal\n\nMozReview-Commit-ID: LMv2rYrwHWl", "files": ["Pipfile", "Pipfile.lock"], "git_node": null, "git_parents": [null], "node": "1695d4464c54359c3ea2d83374acf8a3500bd783", "parents": ["a32be868e151ab9f1cf945976316f730292a8b09"], "tags": []}, {"author": "Dave Hunt \u003cdhunt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1466211 - Vendor json-e via |mach vendor python|; r=ahal\n\nMozReview-Commit-ID: DPatUFNHDIR", "files": ["Pipfile", "Pipfile.lock", "third_party/python/json-e/MANIFEST.in", "third_party/python/json-e/PKG-INFO", "third_party/python/json-e/package.json", "third_party/python/json-e/setup.cfg", "third_party/python/json-e/setup.py"], "git_node": null, "git_parents": [null], "node": "4b197754381a7e5ec05ac0a1eae25343e44aef50", "parents": ["1695d4464c54359c3ea2d83374acf8a3500bd783"], "tags": []}, {"author": "Dave Hunt \u003cdhunt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1466211 - Vendor voluptuous via |mach vendor python|; r=ahal\n\nMozReview-Commit-ID: 21q9i0lStU3", "files": ["Pipfile", "Pipfile.lock", "third_party/python/voluptuous/CHANGELOG.md", "third_party/python/voluptuous/COPYING", "third_party/python/voluptuous/MANIFEST.in", "third_party/python/voluptuous/PKG-INFO", "third_party/python/voluptuous/README.md", "third_party/python/voluptuous/README.rst", "third_party/python/voluptuous/setup.cfg", "third_party/python/voluptuous/setup.py", "third_party/python/voluptuous/voluptuous/tests/__init__.py", "third_party/python/voluptuous/voluptuous/tests/tests.md", "third_party/python/voluptuous/voluptuous/tests/tests.py"], "git_node": null, "git_parents": [null], "node": "e04950c7c4960a5cba48b03d9821a0a49a590d9c", "parents": ["4b197754381a7e5ec05ac0a1eae25343e44aef50"], "tags": []}, {"author": "Dave Hunt \u003cdhunt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1466211 - Sort dependencies in Pipfile; r=ahal\n\nMozReview-Commit-ID: JtlHzdVlaZt", "files": ["Pipfile"], "git_node": null, "git_parents": [null], "node": "fe821d61ecbfcaf68ae180258249b3b9434213fe", "parents": ["e04950c7c4960a5cba48b03d9821a0a49a590d9c"], "tags": []}, {"author": "Dave Hunt \u003cdhunt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1466211 - Switch all |mach python-test| tests to run using pipenv; r=ahal\n\nMozReview-Commit-ID: AzmdDgAgZgI", "files": ["Pipfile", "Pipfile.lock", "python/Pipfile", "python/Pipfile.lock", "python/mach_commands.py", "python/mozbuild/mozbuild/base.py", "python/mozbuild/mozbuild/virtualenv.py"], "git_node": null, "git_parents": [null], "node": "23eb377e2e6d12ecf1ceb2c8e58fc41ccf89896f", "parents": ["fe821d61ecbfcaf68ae180258249b3b9434213fe"], "tags": []}, {"author": "Dave Hunt \u003cdhunt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1466211 - Use --python for selecting target Python when using |mach python-test|; r=ahal\n\nMozReview-Commit-ID: J8DSmX8mItb", "files": ["python/mach_commands.py", "python/mozbuild/mozbuild/virtualenv.py"], "git_node": null, "git_parents": [null], "node": "dfdf4ea83655c4663c5b75f5d096e5ebb75f7fed", "parents": ["23eb377e2e6d12ecf1ceb2c8e58fc41ccf89896f"], "tags": []}, {"author": "Dave Hunt \u003cdhunt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1466211 - Detect if we are running in a virtual environment; r=chmanchester\n\nWhen we're running using pipenv, we have more than one virtual environment. This means the current check to see if python matches the initial virtual environment gives a false positive when we're in a secondary virtual environment. This patch changes the condition to check if the current python path exists within the virtual environments root directory.\n\nMozReview-Commit-ID: AAONwLWsigL", "files": ["build/moz.configure/init.configure"], "git_node": null, "git_parents": [null], "node": "6680ca0acc27c781a81cbf89885d5bac2a13a5c0", "parents": ["dfdf4ea83655c4663c5b75f5d096e5ebb75f7fed"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1469307 - Pretty-print Attr objects in format.pprint. r=whimboo\n\nAttr objects are returned from Node.getAttribute() and this provides\na readable string like the one offered in devtools for them.\n\nMozReview-Commit-ID: 60Pb0AV1tjt", "files": ["testing/marionette/format.js"], "git_node": null, "git_parents": [null], "node": "ff262b71ac1622b5f18cd4b87c8a586af207c790", "parents": ["6680ca0acc27c781a81cbf89885d5bac2a13a5c0"], "tags": []}, {"author": "Razvan Caliman \u003crcaliman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1466225 - (Part 1) Rename browser_inspector_highlighter-cssshape_06.js r=pbro\n\nMozReview-Commit-ID: 4GY0pScutDI", "files": ["devtools/client/inspector/test/browser.ini", "devtools/client/inspector/test/browser_inspector_highlighter-cssshape_06-translate.js", "devtools/client/inspector/test/browser_inspector_highlighter-cssshape_06.js"], "git_node": null, "git_parents": [null], "node": "cf183f5fce6a303c2b6385d7fc7f6b4dcb69006d", "parents": ["ff262b71ac1622b5f18cd4b87c8a586af207c790"], "tags": []}, {"author": "Razvan Caliman \u003crcaliman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1466225 - (Part 2) Split scale and transform shape path editor test to prevent exceeding max test run time. r=pbro\n\nMozReview-Commit-ID: CT0bGAWmU36", "files": ["devtools/client/inspector/test/browser.ini", "devtools/client/inspector/test/browser_inspector_highlighter-cssshape_06-scale.js", "devtools/client/inspector/test/browser_inspector_highlighter-cssshape_06-translate.js"], "git_node": null, "git_parents": [null], "node": "1f05dd7f51b55b8cc74d8ebd662bf15376528f48", "parents": ["cf183f5fce6a303c2b6385d7fc7f6b4dcb69006d"], "tags": []}, {"author": "Margareta Eliza Balazs \u003cebalazs@mozilla.com\u003e", "branch": "default", "desc": "Backed out 7 changesets (bug 1466211) for bustage e.g. z/task_1529662815/src/js/src/configure --enable-ctypes --enable-optimize on a CLOSED TREE\n\nBacked out changeset 6680ca0acc27 (bug 1466211)\nBacked out changeset dfdf4ea83655 (bug 1466211)\nBacked out changeset 23eb377e2e6d (bug 1466211)\nBacked out changeset fe821d61ecbf (bug 1466211)\nBacked out changeset e04950c7c496 (bug 1466211)\nBacked out changeset 4b197754381a (bug 1466211)\nBacked out changeset 1695d4464c54 (bug 1466211)", "files": ["Pipfile", "Pipfile.lock", "build/moz.configure/init.configure", "python/Pipfile", "python/Pipfile.lock", "python/mach_commands.py", "python/mozbuild/mozbuild/base.py", "python/mozbuild/mozbuild/virtualenv.py", "third_party/python/json-e/MANIFEST.in", "third_party/python/json-e/PKG-INFO", "third_party/python/json-e/package.json", "third_party/python/json-e/setup.cfg", "third_party/python/json-e/setup.py", "third_party/python/voluptuous/CHANGELOG.md", "third_party/python/voluptuous/COPYING", "third_party/python/voluptuous/MANIFEST.in", "third_party/python/voluptuous/PKG-INFO", "third_party/python/voluptuous/README.md", "third_party/python/voluptuous/README.rst", "third_party/python/voluptuous/setup.cfg", "third_party/python/voluptuous/setup.py", "third_party/python/voluptuous/voluptuous/tests/__init__.py", "third_party/python/voluptuous/voluptuous/tests/tests.md", "third_party/python/voluptuous/voluptuous/tests/tests.py"], "git_node": null, "git_parents": [null], "node": "bfde37aecadd49f0f12bd975b0c1f96af17d39d3", "parents": ["1f05dd7f51b55b8cc74d8ebd662bf15376528f48"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1464858 - make visually hidden / screenreader content not display:none, r=eeejay\n\nMozReview-Commit-ID: JzO7tyO4wv3", "files": ["toolkit/themes/shared/aboutReader.css"], "git_node": null, "git_parents": [null], "node": "b444a5c91bd9e3975e3a60053e8382f5d705cf39", "parents": ["bfde37aecadd49f0f12bd975b0c1f96af17d39d3"], "tags": []}, {"author": "Bryce Van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1450845 - MediaDecoderStateMachine now ignores SeekToNextFrame if already seeking. r=jya\n\nSeekToNextFrame is handled differently than other seeks by the\nMediaDecoderStateMachine, and should not take place while other seeks already\nare. Bug 1410225 implemented some changes in HTMLMediaElement to prevent this,\nbut it's still possible to move to a seeking state in the MDSM and accept\nSeekToNextFrame (as in this bug).\n\nThis changeset changes the MDSM to reject SeekToNextFrame if a seek is already\nhappening. Since the MDSM now does this the changes from bug 1410225 can be\nremoved.\n\nThis has the functional change of the promise from SeekToNextFrame being\nrejected if the seek in not performed due to another seek. Previously the\npromise would succeed when the other seek completed. This seems sensible as the\nnext frame seek does not actually take place.\n\nMozReview-Commit-ID: HD9WRFq3LZV", "files": ["dom/html/HTMLMediaElement.cpp", "dom/media/MediaDecoderStateMachine.cpp"], "git_node": null, "git_parents": [null], "node": "be60095b4e99075e6bd51df875dd2111193cac9a", "parents": ["b444a5c91bd9e3975e3a60053e8382f5d705cf39"], "tags": []}, {"author": "Bryce Van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1450845 - Add crashtest for seekToNextFrame when a seek is already in progress. r=jya\n\nMozReview-Commit-ID: 892uIqNuLSg", "files": ["dom/media/test/crashtests/1450845.html", "dom/media/test/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "b369f6cf661f184de08aa64d0ce8af15bfa46413", "parents": ["be60095b4e99075e6bd51df875dd2111193cac9a"], "tags": []}, {"author": "Razvan Caliman \u003crcaliman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1465500 - Show list of font families declared but not used. r=gl\n\nMozReview-Commit-ID: 4GfpV8RmK0N", "files": ["devtools/client/inspector/fonts/components/FontEditor.js", "devtools/client/inspector/fonts/fonts.js", "devtools/client/inspector/fonts/test/browser.ini", "devtools/client/inspector/fonts/test/browser_fontinspector.html", "devtools/client/inspector/fonts/test/browser_fontinspector_family-unused.js", "devtools/client/inspector/fonts/utils/l10n.js", "devtools/client/locales/en-US/font-inspector.properties", "devtools/client/themes/fonts.css"], "git_node": null, "git_parents": [null], "node": "82f89fcfaa8271a0b9c21f1cc466636d0518087d", "parents": ["b369f6cf661f184de08aa64d0ce8af15bfa46413"], "tags": []}, {"author": "Ahilya Sinha \u003casinha@mozilla.com\u003e", "branch": "default", "desc": "Bug 1468869 - Add git-cinnabar support for wpt-manifest download, r=ato\n\nMozReview-Commit-ID: 7Nl4r7ty7Ji", "files": ["testing/web-platform/manifestdownload.py", "testing/web-platform/vcs.py"], "git_node": null, "git_parents": [null], "node": "424703a5d9e1796527cefff1992fed1b321de19b", "parents": ["82f89fcfaa8271a0b9c21f1cc466636d0518087d"], "tags": []}, {"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1463802 - Add reftest. r=Gankro\n\nMozReview-Commit-ID: BjwWLChVCZj", "files": ["gfx/tests/reftest/1463802-ref.html", "gfx/tests/reftest/1463802.html", "gfx/tests/reftest/reftest.list"], "git_node": null, "git_parents": [null], "node": "caadd3c8d7355bc3842c71429d6ee619be3e6ce6", "parents": ["424703a5d9e1796527cefff1992fed1b321de19b"], "tags": []}, {"author": "abhinav \u003cabhinav.koppula@gmail.com\u003e", "branch": "default