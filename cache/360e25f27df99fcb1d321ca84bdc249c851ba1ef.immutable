 "parents": ["5d3dcb2922cb7b7c16077626c5a50b7f50b1cdbf"], "tags": []}, {"author": "Nicolas B. Pierron \u003cnicolas.b.pierron@gmail.com\u003e", "branch": "default", "desc": "Bug 1470732 - Add test case. r=tcampbell a=lizzard", "files": ["js/src/jit-test/tests/basic/bug1470732.js"], "git_node": null, "git_parents": [null], "node": "94d94a0e3473e6398e36a54f59676f05440a4158", "parents": ["75dd2f223571bdb52189d66b2120cd38b6846002"], "tags": []}, {"author": "Eugen Sawin \u003cesawin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1465877 - [1.0] Add a mechanic to test whether we're running GeckoView in Fennec environment. r=snorp a=lizzard", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoAppShell.java"], "git_node": null, "git_parents": [null], "node": "e0394cc8f42d7f46ac3878193ef4fde9ee92b8dd", "parents": ["94d94a0e3473e6398e36a54f59676f05440a4158"], "tags": []}, {"author": "Eugen Sawin \u003cesawin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1465877 - [2.0] Keep track of modified settings to prevent overriding prefs when not desired. r=snorp a=lizzard", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoRuntime.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoRuntimeSettings.java"], "git_node": null, "git_parents": [null], "node": "5a6eba66a37822ac6ea8b0ae1dd2f8526d024b37", "parents": ["e0394cc8f42d7f46ac3878193ef4fde9ee92b8dd"], "tags": ["DEVEDITION_62_0b6_BUILD1", "DEVEDITION_62_0b6_RELEASE", "FIREFOX_62_0b6_BUILD1", "FIREFOX_62_0b6_RELEASE"]}], "date": 1530803735, "git_changesets": [null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "9437": {"changesets": [{"author": "\"Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e\"", "branch": "default", "desc": "No bug - Tagging 5a6eba66a37822ac6ea8b0ae1dd2f8526d024b37 with DEVEDITION_62_0b6_BUILD1 a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "cf