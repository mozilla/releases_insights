Bug 2046240 - Add SmartWindow Nimbus feature enabled variable  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D310539\n\nDifferential Revision: https://phabricator.services.mozilla.com/D312162\n", "files": ["browser/components/aiwindow/ui/modules/AIWindow.sys.mjs", "browser/components/aiwindow/ui/test/browser/browser_smartwindow_nimbus.js", "toolkit/components/nimbus/FeatureManifest.yaml"], "git_node": "b86a2a15b5013f2c41cbb1b72e005bcb9a5789af", "git_parents": ["22a4c8aa5d0a6759cc1a8efd960cbe9ba04d3fe7"], "node": "d90632d1de40f2b22dc71435b3801682f73abe59", "parents": ["3e68197d2568f64ed830090be40627e129d067eb"], "tags": []}], "date": 1784096823, "git_changesets": ["b86a2a15b5013f2c41cbb1b72e005bcb9a5789af"], "user": "pchevrel@mozilla.com"}, "27497": {"changesets": [{"author": "Punam Dahiya \u003cpdahiya@mozilla.com\u003e", "branch": "default", "desc": "Bug 2052627 - Store timestamp of last Smart Window usage  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D310507\n\nDifferential Revision: https://phabricator.services.mozilla.com/D312164\n", "files": ["browser/components/aiwindow/ui/modules/AIWindow.sys.mjs", "browser/components/aiwindow/ui/test/browser/browser.toml", "browser/components/aiwindow/ui/test/browser/browser_aiwindow_last_usage_timestamp.js", "browser/components/asrouter/docs/targeting-attributes.md", "browser/components/asrouter/modules/ASRouterTargeting.sys.mjs", "browser/components/asrouter/tests/browser/browser_asrouter_targeting.js"], "git_node": "0984eb0ca5164de35034f5880130f07f5eddcd16", "git_parents": ["b86a2a15b5013f2c41cbb1b72e005bcb9a5789af"], "node": "2b7795caaccc7b708804f2ae5f4eed537f6365b8", "parents": ["d90632d1de40f2b22dc71435b3801682f73abe59"], "tags": []}], "date": 1784096871, "git_changesets": ["0984eb0ca5164de35034f5880130f07f5eddcd16"], "user": "pchevrel@mozilla.com"}, "27498": {"changesets": [{"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 2054321 - Change the std::atomic configure check for libatomic requirement.  a=pascalc\n\nIt's probably that back when the test was added we weren't using double\natomics, which have different alignment constraints compared to\nuint64_t. Because of the alignment constraint difference on x86, we now\nend up requiring libatomic, which wasn't detected as required during\nconfigure.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D311700\n\nDifferential Revision: https://phabricator.services.mozilla.com/D312165\n", "files": ["build/moz.configure/libraries.configure"], "git_node": "db0dee974b7c5ab1d5f69e75c94411897f7b075f", "git_parents": ["0984eb0ca5164de35034f5880130f07f5eddcd16"], "node": "2fca3735b5d4f4b9902c5627b6a1fbc56c2493e3", "parents": ["2b7795caaccc7b708804f2ae5f4eed537f6365b8"], "tags": []}], "date": 1784096915, "git_changesets": ["db0dee974b7c5ab1d5f69e75c94411897f7b075f"], "user": "pchevrel@mozilla.com"}, "27499": {"changesets": [{"author": "Punam Dahiya \u003cpdahiya@mozilla.com\u003e", "branch": "default", "desc": "Bug 2054206 - Fix Smart Window Promo ghost button background  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D311646\n\nDifferential Revision: https://phabricator.services.mozilla.com/D312168\n", "files": ["browser/components/aiwindow/ui/components/smartwindow-promo/smartwindow-promo.css"], "git_node": "e635b8741a82b5a0ec8ca8301b4b8f95fd0d7acd", "git_parents": ["db0dee974b7c5ab1d5f69e75c94411897f7b075f"], "node": "281ccfac69149adf9c26929508d271e31763c4aa", "parents": ["2fca3735b5d4f4b9902c5627b6a1fbc56c2493e3"], "tags": []}], "date": 1784096962, "git_changesets": ["e635b8741a82b5a0ec8ca8301b4b8f95fd0d7acd"], "user": "pchevrel@mozilla.com"}, "27500": {"changesets": [{"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 2053637: Apply text cache updates for all text Accessibles.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D311460\n\nDifferential Revision: https://phabricator.services.mozilla.com/D312177\n", "files": ["accessible/ipc/RemoteAccessible.cpp"], "git_node": "05a69bfd9e954e781057ea41044c2a800832c13c", "git_parents": ["e635b8741a82b5a0ec8ca8301b4b8f95fd0d7acd"], "node": "2c637e7fcdf8b5c12b26811634083c69667c5941", "parents": ["281ccfac69149adf9c26929508d271e31763c4aa"], "tags": []}], "date": 1784101974, "git_changesets": ["05a69bfd9e954e781057ea41044c2a800832c13c"], "user": "pchevrel@mozilla.com"}, "27501": {"changesets": [{"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 2053635: Ensure the caret offset is valid.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D311457\n\nDifferential Revision: https://phabricator.services.mozilla.com/D312174\n", "files": ["accessible/ipc/DocAccessibleParent.cpp"], "git_node": "9603b25f435d30e1fc6178f8c538ed63ab6e0b9b", "git_parents": ["05a69bfd9e954e781057ea41044c2a800832c13c"], "node": "4afb9e2cd55a01d957b6a7ccfb7f3d8f4a7f4681", "parents": ["2c637e7fcdf8b5c12b26811634083c69667c5941"], "tags": []}], "date": 1784102110, "git_changesets": ["9603b25f435d30e1fc6178f8c538ed63ab6e0b9b"], "user": "pchevrel@mozilla.com"}, "27502": {"changesets": [{"author": "Travis Long \u003ctlong@mozilla.com\u003e", "branch": "default", "desc": "Bug 2050093 - Record custom distribution of consecutive active ticks.  a=pascalc\n\nAdd browser.engagement.consecutive_active_ticks, a labeled custom\ndistribution that records the length of each uninterrupted run of active\nticks when the user transitions to inactive. This complements the\nactive_ticks counters (which only track the total) by capturing how long\nusers stay continuously engaged.\n\nThe metric is labeled to track both streams side-by-side: the\n'active_ticks' label mirrors the legacy active_ticks counter (all\nevents), and 'active_ticks_non_synthesized' mirrors the corrected\nactive_ticks_non_synthesized counter from Bug 2050081 (excluding\nsynthesized mouse and pointer events).\n\nRecording reuses the existing user-interaction-active/inactive\nnotifications (and their non-synthesized variants). A run in progress\nwhen a ping is submitted is recorded in a later ping once it ends; runs\nactive at shutdown are dropped.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D311381\n\nDifferential Revision: https://phabricator.services.mozilla.com/D312040\n", "files": ["browser/modules/metrics.yaml", "toolkit/components/telemetry/pings/TelemetrySession.sys.mjs", "toolkit/components/telemetry/tests/unit/test_TelemetrySession_activeTicks.js"], "git_node": "95e97268bf78e758b88f10e6d1fdba6881346791", "git_parents": ["9603b25f435d30e1fc6178f8c538ed63ab6e0b9b"], "node": "32b33ca1894dd0356b1d50c73d1b1ca545ccb155", "parents": ["4afb9e2cd55a01d957b6a7ccfb7f3d8f4a7f4681"], "tags": []}, {"author": "Travis Long \u003ctlong@mozilla.com\u003e", "branch": "default", "desc": "Bug 2050099 - Record timing distribution for duration of inactive periods.  a=pascalc\n\nAdd browser.engagement.inactive_period_duration, a labeled timing\ndistribution that records the duration of each period the user was\nconsidered inactive, measured from when the user goes inactive until\nactivity resumes. Combined with consecutive_active_ticks (Bug 2050093),\nthis helps reason about user interaction patterns more holistically and\ninforms whether additional active-tick intervals should be introduced.\n\nLike consecutive_active_ticks, the metric is labeled to track both\nstreams side-by-side: the 'active_ticks' label uses the legacy\nuser-interaction notifications (all events), and\n'active_ticks_non_synthesized' uses the corrected variants from\nBug 2050081 (excluding synthesized mouse and pointer events).\n\nAn inactive period in progress when a ping is submitted is recorded in a\nlater ping once activity resumes; a period active at shutdown is dropped.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D311382\n\nDifferential Revision: https://phabricator.services.mozilla.com/D312041\n", "files": ["browser/modules/metrics.yaml", "toolkit/components/telemetry/pings/TelemetrySession.sys.mjs", "toolkit/components/telemetry/tests/unit/test_TelemetrySession_activeTicks.js"], "git_node": "acbfa93e97b723c66639788dbf7625be1c1d7a9e", "git_parents": ["95e97268bf78e758b88f10e6d1fdba6881346791"], "node": "40efca711187edb8dc6dbbf288f7ddf5993aea6e", "parents": ["32b33ca1894dd0356b1d50c73d1b1ca545ccb155"], "tags": []}], "date": 1784103273, "git_changesets": ["95e97268bf78e758b88f10e6d1fdba6881346791", "acbfa93e97b723c66639788dbf7625be1c1d7a9e"], "user": "pchevrel@mozilla.com"}, "27503": {"changesets": [{"author": "Nicolas Silva \u003cnsilva@mozilla.com\u003e", "branch": "default", "desc": "Bug 2052819 - Fix classification of parially masked tiles.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D311343\n\nDifferential Revision: https://phabricator.services.mozilla.com/D312234\n", "files": ["gfx/wr/webrender/src/quad.rs", "gfx/wr/wrench/reftests/split/clip-image-escape-ref.yaml", "gfx/wr/wrench/reftests/split/clip-image-escape.yaml", "gfx/wr/wrench/reftests/split/reftest.list"], "git_node": "697eff643cfa09e04509779c7fb2ee3039fbecba", "git_parents": ["acbfa93e97b723c66639788dbf7625be1c1d7a9e"], "node": "90a06e1ee544e21e00541232cf0116f8bf805132", "parents": ["40efca711187edb8dc6dbbf288f7ddf5993aea6e"], "tags": []}], "date": 1784105439, "git_changesets": ["697eff643cfa09e04509779c7fb2ee3039fbecba"], "user": "pchevrel@mozilla.com"}, "27504": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Bumping Firefox l10n changesets r=release a=l10n-bump\n\nach -\u003e 235fd5b0427bec104e6af4055756b286554fce17\naf -\u003e 235fd5b0427bec104e6af4055756b286554fce17\nan -\u003e 235fd5b0427bec104e6af4055756b286554fce17\nar -\u003e 235fd5b0427bec104e6af4055756b286554fce17\nast -\u003e 235fd5b0427bec104e6af4055756b286554fce