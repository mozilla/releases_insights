 "27048": {"changesets": [{"author": "Julien Cristau \u003cjcristau@mozilla.com\u003e", "branch": "default", "desc": "Bug 2048897 - fix update-verify-config failures on esr for win64-aarch64  a=pascalc DONTBUILD\n\nThat platform was discontinued on esr115 which confuses our scripts.\nSet last-watershed to 140.0esr to bypass the issue.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307745\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308189\n", "files": ["taskcluster/kinds/release-update-verify-config-next/kind.yml", "taskcluster/kinds/release-update-verify-config/kind.yml"], "git_node": "e25f539790bf69bf01fd0fe068e1f9e69a030fd1", "git_parents": ["83ab2687f685fc2899473d86c8d96d107869a9be"], "node": "15b49e7354ec3acc728cb1473037bf5f240fc583", "parents": ["1a470b63f3fe20db48b99934f18574b09217c99a"], "tags": []}, {"author": "Julien Cristau \u003cjcristau@mozilla.com\u003e", "branch": "default", "desc": "Bug 2046466 - add esr153 support to the task graph. r=taskgraph-reviewers,bhearsum a=pascalc DONTBUILD\n\nAlso remove some obsolete esr128 references.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307771\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308190\n", "files": [".cron.yml", "browser/locales/l10n.toml", "python/mozbuild/mozbuild/artifacts.py", "taskcluster/docs/attributes.rst", "taskcluster/docs/parameters.rst", "taskcluster/gecko_taskgraph/actions/merge_automation.py", "taskcluster/gecko_taskgraph/decision.py", "taskcluster/gecko_taskgraph/target_tasks.py", "taskcluster/gecko_taskgraph/transforms/update_verify_config.py", "taskcluster/gecko_taskgraph/transforms/zucchini_partial_rollout.py", "taskcluster/gecko_taskgraph/util/attributes.py", "taskcluster/gecko_taskgraph/util/scriptworker.py", "taskcluster/kinds/build/windows-mingw.yml", "taskcluster/kinds/cron-bouncer-check/kind.yml", "taskcluster/kinds/l10n-bump/kind.yml", "taskcluster/kinds/merge-automation/kind.yml", "taskcluster/kinds/release-balrog-scheduling/kind.yml", "taskcluster/kinds/release-balrog-submit-toplevel/kind.yml", "taskcluster/kinds/release-bouncer-aliases/kind.yml", "taskcluster/kinds/release-early-tagging/kind.yml", "taskcluster/kinds/release-update-verify-config-next/kind.yml", "taskcluster/kinds/release-update-verify-config/kind.yml", "taskcluster/kinds/release-update-verify-next/kind.yml", "taskcluster/kinds/release-version-bump/kind.yml", "taskcluster/kinds/update-test/kind.yml", "testing/web-platform/manifestdownload.py"], "git_node": "6554fc6393ee586df2a3fd47d47ae52d71faea5e", "git_parents": ["e25f539790bf69bf01fd0fe068e1f9e69a030fd1"], "node": "f0c8d124430bfd982905cc1a9a9a4459f693e236", "parents": ["15b49e7354ec3acc728cb1473037bf5f240fc583"], "tags": []}, {"author": "Julien Cristau \u003cjcristau@mozilla.com\u003e", "branch": "default", "desc": "Bug 2046466 - vendor mozilla-version v5.1.0. r=taskgraph-reviewers,bhearsum a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307772\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308191\n", "files": ["third_party/python/mozilla_version/mozilla_version-4.1.0.dist-info/LICENSE", "third_party/python/mozilla_version/mozilla_version-4.1.0.dist-info/METADATA", "third_party/python/mozilla_version/mozilla_version-4.1.0.dist-info/RECORD", "third_party/python/mozilla_version/mozilla_version-4.1.0.dist-info/WHEEL", "third_party/python/mozilla_version/mozilla_version-4.1.0.dist-info/top_level.txt", "third_party/python/mozilla_version/mozilla_version-5.1.0.dist-info/METADATA", "third_party/python/mozilla_version/mozilla_version-5.1.0.dist-info/RECORD", "third_party/python/mozilla_version/mozilla_version-5.1.0.dist-info/WHEEL", "third_party/python/mozilla_version/mozilla_version-5.1.0.dist-info/licenses/LICENSE", "third_party/python/mozilla_version/mozilla_version/gecko.py", "third_party/python/mozilla_version/mozilla_version/ios.py", "third_party/python/pyproject.toml", "third_party/python/requirements.txt", "third_party/python/uv.lock", "third_party/python/uv.lock.hash"], "git_node": "75693d3a368b8aa63ce4b3da625a1ce7a94f130f", "git_parents": ["6554fc6393ee586df2a3fd47d47ae52d71faea5e"], "node": "527d2b47f1297a80edb4432be5f0d8ad7368fd2d", "parents": ["f0c8d124430bfd982905cc1a9a9a4459f693e236"], "tags": []}, {"author": "Julien Cristau \u003cjcristau@mozilla.com\u003e", "branch": "default", "desc": "Bug 2048875 - fix `mach try release` task scheduling.  a=pascalc DONTBUILD\n\nThe `staging_release_builds` target tasks method is meant to schedule\nbuilds that would run on-push on the target branch.  It does that by\ncalling `filter_for_project` with patched `parameters[\"project\"]`. However\nbug 2017636 changed the implementation of the `\"release\"` project alias to\ncheck `parameters[\"level\"]` first, and we don't patch that, so anything\nwith `run-on-projects: [release]` got excluded.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307740\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308192\n", "files": ["taskcluster/gecko_taskgraph/target_tasks.py"], "git_node": "95e908d7ed3f0042831190502dd8a0ab7df55dfe", "git_parents": ["75693d3a368b8aa63ce4b3da625a1ce7a94f130f"], "node": "5646a23556962dcbe40a65748c86ae25739b5357", "parents": ["527d2b47f1297a80edb4432be5f0d8ad7368fd2d"], "tags": []}], "date": 1782224603, "git_changesets": ["e25f539790bf69bf01fd0fe068e1f9e69a030fd1", "6554fc6393ee586df2a3fd47d47ae52d71faea5e", "75693d3a368b8aa63ce4b3da625a1ce7a94f130f", "95e908d7ed3f0042831190502dd8a0ab7df55dfe"], "user": "pchevrel@mozilla.com"}, "27049": {"changesets": [{"author": "Zoya \u003czfatima@mozilla.com\u003e", "branch": "default", "desc": "Bug 2048173 - added import-bookmarks to nimbus to enable for beta and release  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307659\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308195\n", "files": ["mobile/android/fenix/app/nimbus.fml.yaml", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/utils/Settings.kt"], "git_node": "1e33163730084d95a01b730753c47bf6880ee1b6", "git_parents": ["95e908d7ed3f0042831190502dd8a0ab7df55dfe"], "node": "698719f1a20b012a9b368ef42bf5956e8f824eda", "parents": ["5646a23556962dcbe40a65748c86ae25739b5357"], "tags": []}], "date": 1782224643, "git_changesets": ["1e33163730084d95a01b730753c47bf6880ee1b6"], "user": "pchevrel@mozilla.com"}, "27050": {"changesets": [{"author": "pollymce \u003cpmceldowney@mozilla.com\u003e", "branch": "default", "desc": "Bug 2040618: Fix touch slop shenanigans.  a=pascalc DONTBUILD\n\nIt turns out touch slop isn't the right thing to use in this situation to differentiate between a tap and a swipe. It's the minimum distance to begin a drag, not a cutoff between a tap and swipe. So i've put the dp magic number back in! sorry andrey (:\n\nPull request: https://github.com/mozilla-firefox/firefox/pull/291\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308221\n", "files": ["mobile/android/fenix/app/longfox/src/main/kotlin/org/mozilla/fenix/longfox/LongFoxGameScreen.kt", "mobile/android/fenix/app/longfox/src/test/kotlin/org/mozilla/fenix/longfox/GameStateTest.kt"], "git_node": "82a8bef433ff3da4ee1a6170cee8d272c86fe0c0", "git_parents": ["1e33163730084d95a01b730753c47bf6880ee1b6"], "node": "407df8e1aa55f0694cc4a925b77b933e75ca4df4", "parents": ["698719f1a20b012a9b368ef42bf5956e8f824eda"], "tags": []}], "date": 1782224698, "git_changesets": ["82a8bef433ff3da4ee1a6170cee8d272c86fe0c0"], "user": "pchevrel@mozilla.com"}, "27051": {"changesets": [{"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1189155 - Convert remaining \"m\"-prefixed private tabbrowser properties to the underscore prefix.  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308018\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308251\n", "files"