]}], "date": 1782819566, "git_changesets": ["392081e1bb4d53f9e976c8b75c3ac6871906b500"], "user": "pchevrel@mozilla.com"}, "27190": {"changesets": [{"author": "Arnaud Bienner \u003cabienner@mozilla.com\u003e", "branch": "default", "desc": "Bug 2050407 - Revert \"Bug 1998648: Use SafeRefPtr to keep track of OriginInfos\"  a=pascalc\n\nThis reverts commit fe5756d36c1c02018d14eb557254fd19dd8608fa.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308398\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309526\n", "files": ["dom/quota/ActorsParent.cpp", "dom/quota/GroupInfo.cpp", "dom/quota/GroupInfo.h", "dom/quota/OriginInfo.h", "dom/quota/QuotaManager.h", "dom/quota/QuotaManagerImpl.h"], "git_node": "3d3e853d8661f7dd620b1aff0fe667bbc5b15508", "git_parents": ["392081e1bb4d53f9e976c8b75c3ac6871906b500"], "node": "436d81fa6fffc85b595abb027c2442eb4af55e09", "parents": ["974d0c9bb84674622325273e49c752ccc277d755"], "tags": []}, {"author": "Arnaud Bienner \u003cabienner@mozilla.com\u003e", "branch": "default", "desc": "Bug 2050407 - Quota management: make OriginInfo inherit from SupportsThreadSafeWeakPtr  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308399\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309527\n", "files": ["dom/quota/CanonicalQuotaObject.cpp", "dom/quota/CanonicalQuotaObject.h", "dom/quota/OriginInfo.h"], "git_node": "4452e96444eecf5c29160e56f8555ba0baf1795c", "git_parents": ["3d3e853d8661f7dd620b1aff0fe667bbc5b15508"], "node": "540345af255725edcf227f66d38b57929aacc8c4", "parents": ["436d81fa6fffc85b595abb027c2442eb4af55e09"], "tags": []}], "date": 1782819635, "git_changesets": ["3d3e853d8661f7dd620b1aff0fe667bbc5b15508", "4452e96444eecf5c29160e56f8555ba0baf1795c"], "user": "pchevrel@mozilla.com"}, "27191": {"changesets": [{"author": "Teodor Tanasoaia \u003cttanasoaia@mozilla.com\u003e", "branch": "default", "desc": "Bug 2045410.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308839\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309520\n", "files": ["dom/webgpu/SharedTextureD3D11.cpp", "dom/webgpu/SharedTextureDMABuf.cpp", "dom/webgpu/SharedTextureMacIOSurface.cpp", "dom/webgpu/ipc/WebGPUParent.cpp", "gfx/layers/RemoteTextureMap.cpp"], "git_node": "f31eac4b51514762fbc38c4cf1a2b5fa83a1a63c", "git_parents": ["4452e96444eecf5c29160e56f8555ba0baf1795c"], "node": "0ef5208712c98c26c36beccba9467fce109e22ae", "parents": ["540345af255725edcf227f66d38b57929aacc8c4"], "tags": []}], "date": 1782819672, "git_changesets": ["f31eac4b51514762fbc38c4cf1a2b5fa83a1a63c"], "user": "pchevrel@mozilla.com"}, "27192": {"changesets": [{"author": "Tooru Fujisawa \u003carai_a@mac.com\u003e", "branch": "default", "desc": "Bug 2050051 - Avoid clearing the cache when closing private window.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308984\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309488\n", "files": ["browser/extensions/webcompat/lib/shims.js", "browser/extensions/webcompat/manifest.json", "browser/extensions/webcompat/tests/browser/browser.toml", "browser/extensions/webcompat/tests/browser/browser_private_close.js", "browser/extensions/webcompat/tests/browser/image_cache.html", "browser/extensions/webcompat/tests/browser/image_cache.png"], "git_node": "fc164f1d2727dfd95d31c1d61f552f9a561c5654", "git_parents": ["f31eac4b51514762fbc38c4cf1a2b5fa83a1a63c"], "node": "d3dc4c93cfa4bd477fd2ed0397ead31296413efb", "parents": ["0ef5208712c98c26c36beccba9467fce109e22ae"], "tags": []}], "date": 1782819711, "git_changesets": ["fc164f1d2727dfd95d31c1d61f552f9a561c5654"], "user": "pchevrel@mozilla.com"}, "27193": {"changesets": [{"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 2041001 - Drop intermediary HTTPS result when following alias  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308991\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309321\n", "files": ["netwerk/dns/DNSPacket.cpp"], "git_node": "ead178a2ca624dc258f560b4bf1e00838b227129", "git_parents": ["fc164f1d2727dfd95d31c1d61f552f9a561c5654"], "node": "0fb77253a5584961eceeac9ec88d3efe939a05e1", "parents": ["d3dc4c93cfa4bd477fd2ed0397ead31296413efb"], "tags": []}], "date": 1782819778, "git_changesets": ["ead178a2ca624dc258f560b4bf1e00838b227129"], "user": "pchevrel@mozilla.com"}, "27194": {"changesets": [{"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 2050572 - Don't reuse `IMEContentObserver` if design mode has been changed  a=pascalc\n\n`IMEContentObserver` handles differently between `contenteditable` and\n`designMode` so that `IMEContentObserver` should be recreated for the\nsafe.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309246\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309313\n", "files": ["dom/events/IMEContentObserver.cpp", "dom/events/IMEContentObserver.h", "testing/web-platform/tests/editing/crashtests/change-from-contenteditable-to-design-mode.html"], "git_node": "cca421fb478f7cc94b928b7035bf418295a3b1cd", "git_parents": ["ead178a2ca624dc258f560b4bf1e00838b227129"], "node": "b158b4ffe222e458c4a2bc811bf212a8dbdab780", "parents": ["0fb77253a5584961eceeac9ec88d3efe939a05e1"], "tags": []}], "date": 1782819825, "git_changesets": ["cca421fb478f7cc94b928b7035bf418295a3b1cd"], "user": "pchevrel@mozilla.com"}, "27195": {"changesets": [{"author": "David Rubino \u003cdrubino@mozilla.com\u003e", "branch": "default", "desc": "Bug 2050775 - Defer Windows launch-on-login first-run enablement to browser-idle-startup.  a=pascalc\n\nThe first-run launch-on-login entry point ran in the browser-before-ui-startup\ncategory, where it awaited Nimbus's first Remote Settings fetch. Forcing Remote\nSettings initialization on the pre-UI critical path did significant disk I/O and\nregressed Talos startup file-I/O metrics (tp5n main_startup_fileio and friends),\nts_paint, and sessionrestore on Windows.\n\nThe Windows startup-apps registry key only needs to be written before the user\nreboots, so this work has ample slack. Move the registration to the\nbrowser-idle-startup category so it is dispatched once the browser is idle,\nkeeping the Nimbus/Remote Settings I/O off the startup measurement window. The\nfeature behavior is unchanged.\n\nAlso update the registration test to expect the browser-idle-startup category.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309204\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309558\n", "files": ["browser/components/BrowserComponents.manifest", "browser/components/defaultwindowslaunchonlogin/DefaultWindowsLaunchOnLogin.sys.mjs", "browser/components/defaultwindowslaunchonlogin/tests/test_DefaultWindowsLaunchOnLogin.js"], "git_node": "1458dcae3ecfe7fd325478533aafd859e6553f8b", "git_parents": ["cca421fb478f7cc94b928b7035bf418295a3b1cd"], "node": "101a16f0c446cd5d2707ccb79cd061c7accf86ac", "parents": ["b158b4ffe222e458c4a2bc811bf212a8dbdab780"], "tags": []}], "date": 1782822978, "git_changesets": ["1458dcae3ecfe7fd325478533aafd859e6553f8b"], "user": "pchevrel@mozilla.com"}, "27196": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging e39c605adc0fc049a165d7fe4a3f6517b761edf7 with FIREFOX_152_0_4_RELEASE a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "88e40892ab242b8da82ea92900d75d4696abce47", "git_parents": ["f1be70f005b6e2e91d3c16d9e279f64d692ce1c7"], "node": "e9de3bd3015ddf1b599cbde8c25c64d7a8b62552", "parents": ["0e231557e19f7c80262a9e50e0f9a619235d6a31"], "tags": []}], "date": 1782824140, "git_changesets": ["88e40892ab242b8da82ea92900d75d4696abce47"], "user": "ffxbld@lando.moz.tools"}, "27197": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging e39c605adc0fc049a165d7fe4a3f6517b761edf7 with FIREFOX-ANDROID_152_0_4_RELEASE a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "45bbf7ff5b37134bddef80604ffb057ea36a5c8a", "git_parents": ["88e40892ab242b8da82ea92900d75d4696abce47"], "node": "aefafc315914453de3eaa87b280ea1c486b35295", "parents": ["e9de3bd3015ddf1b599cbde8c25c64d7a8b62552"], "tags": []}], "date": 1782824202, "git_changesets": ["45bbf7ff5b37134bddef80604ffb057ea36a5c8a"], "user": "ffxbld@lando.moz.tools"}, "27198": {"changesets": [{"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 2006467 - Part 1: Use an arbitrary null principal for blob:system URIs,  a=pascalc\n\nThis patch changes the URL which resources loaded from `blob:system` URIs are\ngiven, and does not change the internal URI stored within the data store. This\nkeeps the existing \"broadcast principal\" behaviour, while restricting the\nprincipal given to data loaded from a `blob:system` URI.\n\nUnlike blob:null, a blob:system URL does not have a stable null principal.\nInstead, it has a unique null principal every time it is loaded. This behaviour\nis intended to be more similar to the behaviour of e.g. data: URIs.\n\nI am optimistic that this will be OK given that the blob URL is only intended\nto be used by system code, so shouldn't be exercised in ways which depends on\nmultiple blob URLs created by the same origin being able to access one-another.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D300875\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309050\n", "files": ["dom/file/uri/BlobURLProtocolHandler.cpp"], "git_node": "465d75832db879531d45949ef741c3ed8fd579ee", "git_parents": ["1458dcae3ecfe7fd325478533aafd859e6553f8b"], "node": "30835ac1a8c00df1bbabc7873774a54b277bcd50", "parents": ["101a16f0c446cd5d2707ccb79cd061c7accf86ac"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 2006467 - Part 2: Remove allowSystem for blobs,  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308173\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309051\n", "files": ["dom/ipc/BrowserParent.cpp", "netwerk/ipc/DocumentLoadListener.cpp"], "git_node": "c4acb4601b41dc971dad5fc4d3941fe29c8dcb45", "git_parents": ["465d75832db879531d45949ef741c3ed8fd579ee"], "node": "5f433bbc0908a0ba0727eb4b1f6afc9569be669d", "parents": ["30835ac1a8c00df1bbabc7873774a54b277bcd50"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 2006467 - Part 3: Remove system blob URL support from WorkerLoadInfo,  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308174\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309052\n", "files": ["dom/workers/WorkerLoadInfo.cpp"], "git_node": "b03913d3834223a57b6ec988282cb58e166c6e25", "git_parents": ["c4acb4601b41dc971dad5fc4d3941fe29c8dcb45"], "node": "09f0774502d4b13e9e947b6c0ee1974032df8843", "parents": ["5f433bbc0908a0ba0727eb4b1f6afc9569be669d"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 2006467 - Part 4: Remove browser_bug1104623.js,  a=pascalc\n\nThis test is validating the expected behaviour when creating a system\nprincipal worker from a `blob:system/` URL, which is no longer supported\nsince the changes in this patch stack. The test doesn't appear to have\nany value for other use-cases, so can be removed.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308602\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309053\n", "files": ["dom/workers/test/browser.toml", "dom/workers/test/browser_bug1104623.js"], "git_node": "55b36d023fce4058f8ef6477f31601f1dbc42ae9", "git_parents": ["b03913d3834223a57b6ec988282cb58e166c6e25"], "node": "d669194abd03cfdf36e807d1bdfe5c93cc12da54", "parents": ["09f0774502d4b13e9e947b6c0ee1974032df8843"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 2006467 - Part 5: Stop using blob based workers for onnx_fallback test,  a=pascalc\n\nThis test was added by bug 2012177 after the other blob-based workers\nwere removed in bug 2041607. It also needs to be removed now. This patch\nalso removes the helper function from head.js.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308628\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309054\n", "files": ["toolkit/components/ml/tests/browser/browser.toml", "toolkit/components/ml/tests/browser/browser_ml_best_onnx_fallback.js", "toolkit/components/ml/tests/browser/head.js", "toolkit/components/ml/tests/browser/ml_best_onnx_fallback_stub.worker.mjs"], "git_node": "1a802fc02293ed7364eb06419c322a246fdfff51", "git_parents": ["55b36d023fce4058f8ef6477f31601f1dbc42ae9"], "node": "c915d7b9b80563561a0beb87c31a9d5dad5b4ea9", "parents": ["d669194abd03cfdf36e807d1bdfe5c93cc12da54"], "tags": []}], "date": 1782824372, "git_changesets": ["465d75832db879531d45949ef741c3ed8fd579ee", "c4acb4601b41dc971dad5fc4d3941fe29c8dcb45", "b03913d3834223a57b6ec988282cb58e166c6e25", "55b36d023fce4058f8ef6477f31601f1dbc42ae9", "1a802fc02293ed7364eb06419c322a246fdfff51"], "user": "pchevrel@mozilla.com"}, "27199": {"changesets": [{"author": "Teodor Tanasoaia \u003cttanasoaia@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041912.  a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308847\n", "files": [".cargo/config.toml.in", "Cargo.lock", "gfx/wgpu_bindings/Cargo.toml", "gfx/wgpu_bindings/moz.yaml", "supply-chain/audits.toml", "third_party/rust/wgpu-core/.cargo-checksum.json", "third_party/rust/wgpu-core/src/command/compute.rs", "third_party/rust/wgpu-core/src/command/encoder.rs", "third_party/rust/wgpu-core/src/command/memory_init.rs", "third_party/rust/wgpu-core/src/command/mod.rs", "third_party