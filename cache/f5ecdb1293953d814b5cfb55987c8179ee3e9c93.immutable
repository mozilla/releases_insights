6736a9"], "node": "5af31aae5821c97b5cd3ad9d329a85595dd48500", "parents": ["a637059ee518f0266e118846f79077c2cf67d1e8"], "tags": []}], "date": 1782983089, "git_changesets": ["c576c64f0e70ed90e974702b74e2ca420a491c92"], "user": "pchevrel@mozilla.com"}, "27230": {"changesets": [{"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 2033102 - Add support for allowed_permissions ExtensionSettings policy.  a=pascalc\n\nallowed_permissions un-blocks blocked_permissions with one consistent model on\nboth the install path (mayInstallAddon) and the optional-permission path\n(permissions.request and the about:addons toggles): a per-id entry replaces \"*\"\nentirely, and a per-id allowed_permissions un-blocks its own\nblocked_permissions. \"*\"-level allowed_permissions is inert. To un-block a\npermission for an extension, list both blocked_permissions and\nallowed_permissions in that extension's per-id entry.\n\nThe effective blocked list is resolved once in getExtensionSettings, which\nmayInstallAddon and the optional-permission consumers all read.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307408\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309887\n", "files": ["browser/components/enterprisepolicies/schemas/policies-schema.json", "browser/components/enterprisepolicies/tests/xpcshell/test_extensionsettings_blocked_permissions.js", "toolkit/components/enterprisepolicies/EnterprisePoliciesParent.sys.mjs", "toolkit/components/extensions/parent/ext-permissions.js", "toolkit/mozapps/extensions/content/components/addon-permissions-list.mjs", "toolkit/mozapps/extensions/test/browser/browser_html_detail_permissions_policy_blocked.js"], "git_node": "566a5626281aac2cbaab322f896d590543ad5d21", "git_parents": ["c576c64f0e70ed90e974702b74e2ca420a491c92"], "node": "83ab49caa23905674b9dcd25eb967bf9a58f011b", "parents": ["5af31aae5821c97b5cd3ad9d329a85595dd48500"], "tags": []}], "date": 1782983134, "git_changesets": ["566a5626281aac2cbaab322f896d590543ad5d21"], "user": "pchevrel@mozilla.com"}, "27231": {"changesets": [{"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 2048048 - Fix policy issues with new tab preferences.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307332\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309878\n", "files": ["browser/components/enterprisepolicies/Policies.sys.mjs", "browser/components/enterprisepolicies/tests/browser/browser_policy_firefoxhome.js", "browser/components/enterprisepolicies/tests/xpcshell/test_simple_pref_policies.js"], "git_node": "a339736ad211d865bf95ae8a48c664d8a07adccc", "git_parents": ["566a5626281aac2cbaab322f896d590543ad5d21"], "node": "29a1c67c285595658932386e07e934a337d5c87d", "parents": ["83ab49caa23905674b9dcd25eb967bf9a58f011b"], "tags": []}], "date": 1782983177, "git_changesets": ["a339736ad211d865bf95ae8a48c664d8a07adccc"], "user": "pchevrel@mozilla.com"}, "27232": {"changesets": [{"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 2048696 - Merge a Windows GPO registry value with a same-named subkey instead of dropping it.  a=pascalc\n\nWindowsGPOParser read scalar values before child keys and assigned both to the\nsame object, so when a policy was present as both a value (a REG_SZ/REG_MULTI_SZ\nholding JSON) and a subkey of the same name -- e.g. an admin-supplied one-line\nExtensionSettings string plus an ExtensionSettings subkey written by a\nthird-party extension installer -- the subkey silently overwrote the value.\n\nMerge the two instead, scoped via MERGEABLE_POLICIES to the policies that can\nlegitimately be supplied either way and that independent parties write into\n(currently just ExtensionSettings). The value wins key collisions so a subkey\ncan't override entries like *. Each hive is parsed independently and combined\nper policy, so a machine policy still overrides a user policy and an HKCU entry\ncan't merge into or shadow an HKLM policy.\n\nThis intentionally diverges from Chrome, which on the same collision discards\nthe value and uses the subkey alone.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308248\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309876\n", "files": ["toolkit/components/enterprisepolicies/WindowsGPOParser.sys.mjs", "toolkit/components/enterprisepolicies/tests/browser/browser_policies_gpo.js"], "git_node": "10577cfc57007fca9a5d25f0e69a4d2759f9d986", "git_parents": ["a339736ad211d865bf95ae8a48c664d8a07adccc"], "node": "6d64781119a456867b67c5265cb6b4e26e40d70f", "parents": ["29a1c67c285595658932386e07e934a337d5c87d"], "tags": []}], "date": 1782983225, "git_changesets": ["10577cfc57007fca9a5d25f0e69a4d2759f9d986"], "user": "pchevrel@mozilla.com"}, "27233": {"changesets": [{"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 2033463 - Use AddonRepository to install AMO extensions when install_url is absent  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D297339\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309875\n", "files": ["browser/components/enterprisepolicies/Policies.sys.mjs", "browser/components/enterprisepolicies/tests/xpcshell/test_extensionsettings_install_without_url.js", "browser/components/enterprisepolicies/tests/xpcshell/xpcshell.toml"], "git_node": "b82868e24deb69c90dc02c43b91e1f0caa657379", "git_parents": ["10577cfc57007fca9a5d25f0e69a4d2759f9d986"], "node": "9efed7ae54a21fac6ca42abada0a53e7eec1a6fb", "parents": ["6d64781119a456867b67c5265cb6b4e26e40d70f"], "tags": []}], "date": 1782983274, "git_changesets": ["b82868e24deb69c90dc02c43b91e1f0caa657379"], "user": "pchevrel@mozilla.com"}, "27234": {"changesets": [{"author": "Yubin Jamora \u003cyjamora@mozilla.com\u003e", "branch": "default", "desc": "Bug 2047112 - Close all matching tabs including unloaded tab on NL  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308807\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309869\n", "files": ["browser/components/aiwindow/models/Chat.sys.mjs", "browser/components/aiwindow/models/ManageTabs.sys.mjs", "browser/components/aiwindow/models/Tools.sys.mjs", "browser/components/aiwindow/models/tests/xpcshell/test_ManageTabs.js", "browser/components/aiwindow/ui/components/ai-website-confirmation/ai-website-confirmation.mjs", "browser/components/aiwindow/ui/components/ai-website-select/ai-website-select.mjs", "browser/components/aiwindow/ui/modules/ToolUI.sys.mjs", "browser/components/aiwindow/ui/test/browser/test_website_confirmation_page.html", "browser/components/aiwindow/ui/test/xpcshell/test_ToolUI.js"], "git_node": "da9542fdf5fd3c3d9247adae4448bb22b55aed5a", "git_parents": ["b82868e24deb69c90dc02c43b91e1f0caa657379"], "node": "2a4ef0d7c6dbd665aaf53fc6f5c2b6f375a7b53f", "parents": ["9efed7ae54a21fac6ca42abada0a53e7eec1a6fb"], "tags": []}], "date": 1782983320, "git_changesets": ["da9542fdf5fd3c3d9247adae4448bb22b55aed5a"], "user": "pchevrel@mozilla.com"}, "27235": {"changesets": [{"author": "Mugurell \u003cMugurell@users.noreply.github.com\u003e", "branch": "default", "desc": "Bug 2049750 - Avoid consuming horizontal swipes in toolbar's vertical gestures handler  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308466\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309859\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/components/toolbar/gestures/ToolbarVerticalGesturesHandler.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/components/toolbar/gestures/ToolbarVerticalGesturesHandlerTest.kt"], "git_node": "26a3fe2dc89fd1cf86ef5a73fefbe681a2ad9888", "git_parents": ["da9542fdf5fd3c3d9247adae4448bb22b55aed5a"], "node": "1b255600870609dc255dc46be20ca93f5ecac1e0", "parents": ["2a4ef0d7c6dbd665aaf53fc6f5c2b6f375a7b53f"], "tags": []}], "date": 1782983366, "git_changesets": ["26a3fe2dc89fd1cf86ef5a73fefbe681a2ad9888"], "user": "pchevrel@mozilla.com"}, "27236": {"changesets": [{"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 2050990 - Call JS_NumberValue in ClientWebGLContext.cpp.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309205\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309809\n", "files": ["dom/canvas/ClientWebGLContext.cpp"], "git_node": "bc72b08684573c888d5e7dcd3ea6ce2d54128b79", "git_parents": ["26a3fe2dc89fd1cf86ef5a73fefbe681a2ad9888"], "node": "fcf15caa55d686e87105a64a24a32a574e6878e5", "parents": ["1b255600870609dc255dc46be20ca93f5ecac1e0"], "tags": []}], "date": 1782983480, "git_changesets": ["bc72b08684573c888d5e7dcd3ea6ce2d54128b79"], "user": "pchevrel@mozilla.com"}, "27237": {"changesets": [{"author": "Jens Stutte \u003cjstutte@mozilla.com\u003e", "branch": "default", "desc": "Bug 2048795 - Guard access to the GamepadPlatformService singleton by a StaticMutex.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308034\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309801\n", "files": ["dom/gamepad/GamepadPlatformService.cpp"], "git_node": "c216a4c0def0fe7e1f2c3e2c9b2f9c614323fbf0", "git_parents": ["bc72b08684573c888d5e7dcd3ea6ce2d54128b79"], "node": "f467facdca52b212af05353aa1ced1a1270c5109", "parents": ["fcf15caa55d686e87105a64a24a32a574e6878e5"], "tags": []}], "date": 1782983569, "git_changesets": ["c216a4c0def0fe7e1f2c3e2c9b2f9c614323fbf0"], "user": "pchevrel@mozilla.com"}, "27238": {"changesets": [{"author": "Jens Stutte \u003cjstutte@mozilla.com\u003e", "branch": "default", "desc": "Bug 2045510 - Reject snappy CompressedData chunks shorter than the CRC field.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305218\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309797\n", "files": ["xpcom/io/SnappyFrameUtils.cpp"], "git_node": "f6df50bc02311cc45be4c9f5ff27ca9ad153b741", "git_parents": ["c216a4c0def0fe7e1f2c3e2c9b2f9c614323fbf0"], "node": "5f114abb233119a109aa8df0c375905ce9cd1cfd", "parents": ["f467facdca52b212af05353aa1ced1a1270c5109"], "tags": []}], "date": 1782983612, "git_changesets": ["f6df50bc02311cc45be4c9f5ff27ca9ad153b741"], "user": "pchevrel@mozilla.com"}, "27239": {"changesets": [{"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 2050882 - Avoid crypto.getRandomValues() call at early startup  a=pascalc\n\nExtension.sys.mjs generates a random number at the startup of the first\nextension, to have a shared secret (between parent and child processes)\nserving as a key for a KeyedUUIDMapper in ExtensionDocumentId.sys.mjs.\n\nThis triggered a Talos regression because `crypto.getRandomValues()`\ninitializes NSS. This patch fixes the issue by replacing the call in\n`Extension.sys.mjs` with a new alternative that is independent of NSS.\n\nThe `crypto.getRandomValues()` call in ExtensionDocumentId.sys.mjs also\nswitches to this new method, mainly for consistency (not to avoid NSS\ninitialization, because that already happens next in `gMapper.init()`).\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309331\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309790\n", "files": ["toolkit/components/extensions/Extension.sys.mjs", "toolkit/components/extensions/ExtensionDocumentId.sys.mjs", "xpcom/base/KeyedUUIDMapper.cpp", "xpcom/base/nsIKeyedUUIDMapper.idl", "xpcom/tests/unit/test_KeyedUUIDMapper.js"], "git_node": "02d0638b6421092f77ecd85559c8ad321424a1f9", "git_parents": ["f6df50bc02311cc45be4c9f5ff27ca9ad153b741"], "node": "7c8615ea45acc5ad87761a3bee8bbadc9195c44c", "parents": ["5f114abb233119a109aa8df0c375905ce9cd1cfd"], "tags": []}], "date": 1782983777, "git_changesets": ["02d0638b6421092f77ecd85559c8ad321424a1f9"], "user": "pchevrel@mozilla.com"}, "27240": {"changesets": [{"author": "giorga \u003cgiorga@mozilla.com\u003e", "branch": "default", "desc": "Bug 2051090 - Fix crashed-tab UI \"submit crash report to Mozilla\" checkbox.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309341\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309788\n", "files": ["mobile/android/fenix/app/src/main/res/layout/view_crash_reporter.xml"], "git_node": "5e29239a28b6f15943525659888dad62bf9e187c", "git_parents": ["02d0638b6421092f77ecd85559c8ad321424a1f9"], "node": "8aa53d86bcca88ecd6817ea76ddb73324b0abe16", "parents": ["7c8615ea45acc5ad87761a3bee8bbadc9195c44c"], "tags": []}], "date": 1782983895, "git_changesets": ["5e29239a28b6f15943525659888dad62bf9e187c"], "user": "pchevrel@mozilla.com"}, "27241": {"changesets": [{"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 2050668 - WS: set mDataStarted before dispatching runnable  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308990\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309770\n", "files": ["netwerk/protocol/websocket/WebSocketChannel.cpp"], "git_node": "1f8f69a2661d1764899ac50fe06766f37cf5cd63", "git_parents": ["5e29239a28b6f15943525659888dad62bf9e187c"], "node": "50eee351415a8394d0f3b59d13669e1cda297574", "parents": ["8aa53d86bcca88ecd6817ea76ddb73324b0abe16"], "tags": []}], "date": 1782983945, "git_changesets": ["1f8f69a2661d1764899ac50fe06766f37cf5cd63"], "user": "pchevrel@mozilla.com"}, "27242": {"changesets": [{"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 2050657 - Fix more floating point setNumber calls.  a=pascalc\n\nPlus a DoubleValue because we might as well fix both EventDispatcher issues\nin one patch.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308928\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309811\n", "files": ["js/xpconnect/src/XPCConvert.cpp", "toolk