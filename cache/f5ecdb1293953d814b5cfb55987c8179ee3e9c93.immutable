"541cdfcad3b7acea4b4a2964d3bd9364f8e0ff32", "cadb932e6784625c90b0a44a642e47891e9d7952"], "user": "ffxbld@lando.moz.tools"}, "27089": {"changesets": [{"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 2045917 - [devtools] Wait for 100ms after focus() in browser_fontinspector_editor-variable.js  a=pascalc DONTBUILD\n\nI tried a lot of other approaches (wait for tick / blur / focus / actions etc...) but nothing seems to consistently make it pass.\nAdditionally wait on ruleview-updated, otherwise we still have intermittent failures.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306926\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308531\n", "files": ["devtools/client/inspector/fonts/test/browser_fontinspector_editor-variable.js"], "git_node": "315df88bbbe14580928f8a0ee89d0ac77d1320b2", "git_parents": ["cadb932e6784625c90b0a44a642e47891e9d7952"], "node": "b1b563d4ec973b649ff783baabc29be0c7f84599", "parents": ["337d936e4d9d7623e6784afe690b0a41d3a24c11"], "tags": []}], "date": 1782389151, "git_changesets": ["315df88bbbe14580928f8a0ee89d0ac77d1320b2"], "user": "pchevrel@mozilla.com"}, "27090": {"changesets": [{"author": "Alex Cottner \u003cacottner@mozilla.com\u003e", "branch": "default", "desc": "Bug 2049429 - Remote Settings clients should not poll for changes on startup with a stale timestamp  a=pascalc\n\nDo not poll for changes in remote-settings when startup events have stale timestamps.\nAdding telemetry status so we know when this happens.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308078\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308560\n", "files": ["services/settings/UptakeTelemetry.sys.mjs", "services/settings/metrics.yaml", "services/settings/remote-settings.sys.mjs", "services/settings/test/unit/test_remote_settings_poll.js"], "git_node": "788a95e49553b1931a4ef70aff5f8ce8eb9449d2", "git_parents": ["315df88bbbe14580928f8a0ee89d0ac77d1320b2"], "node": "e225a204c6a171b7e9725da1ff863a590dd34084", "parents": ["b1b563d4ec973b649ff783baabc29be0c7f84599"], "tags": []}], "date": 1782393173, "git_changesets": ["788a95e49553b1931a4ef70aff5f8ce8eb9449d2"], "user": "pchevrel@mozilla.com"}, "27091": {"changesets": [{"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 2044517 - Drop mChannelEntry on failure in registerTraceableChannel  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D304330\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308586\n", "files": ["dom/chrome-webidl/ChannelWrapper.webidl", "toolkit/components/extensions/test/xpcshell/test_ChannelWrapper.js", "toolkit/components/extensions/test/xpcshell/test_ext_webRequest_StreamFilter_redirect_race.js", "toolkit/components/extensions/test/xpcshell/xpcshell-common-e10s.toml", "toolkit/components/extensions/webrequest/ChannelWrapper.cpp", "toolkit/components/extensions/webrequest/WebRequest.sys.mjs"], "git_node": "704a8b480c1aab7af6b06d2024a816635fedcf1e", "git_parents": ["788a95e49553b1931a4ef70aff5f8ce8eb9449d2"], "node": "a7aca82c497a23f1e5e2c665689f0f78776b7dbe", "parents": ["e225a204c6a171b7e9725da1ff863a590dd34084"], "tags": []}], "date": 1782393231, "git_changesets": ["704a8b480c1aab7af6b06d2024a816635fedcf1e"], "user": "pchevrel@mozilla.com"}, "27092": {"changesets": [{"author": "pollymce \u003cpmceldowney@mozilla.com\u003e", "branch": "default", "desc": "Bug 2045749: Add game in new dialog to prevent talkback issues.  a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308587\n", "files": ["mobile/android/fenix/app/longfox/build.gradle", "mobile/android/fenix/app/longfox/src/main/kotlin/org/mozilla/fenix/longfox/LongFoxFeature.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/HomeFragment.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/logo/LogoController.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/home/logo/LogoControllerTest.kt"], "git_node": "fb8a464956ec1dbccc24b09c8c32945e076b5199", "git_parents": ["704a8b480c1aab7af6b06d2024a816635fedcf1e"], "node": "7e7fd1d6e697ba51a9fe300f8bf0a6efc503c84f", "parents": ["a7aca82c497a23f1e5e2c665689f0f78776b7dbe"], "tags": []}], "date": 1782393269, "git_changesets": ["fb8a464956ec1dbccc24b09c8c32945e076b5199"], "user": "pchevrel@mozilla.com"}, "27093": {"changesets": [{"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1982177 - Consistently use CSS pixels in sanitizePositionParams  a=pascalc\n\nThe `windows.create` and `windows.update` extension APIs specify `top`\nand `left` in CSS pixels. The `sanitizePositionParams` helper currently\ntreats them as interchangeable with desktop coordinates. This works if\nthe scale coincidentally matches, but results in wrong clamping and\npositioning results otherwise, as seen in the bug.\n\nThis patch fixes the issue by mapping CSS pixels to desktop pixels and\nback as needed, in ext-windows.js.\n\nAlthough not strictly necessary, getCssAvailRect in head.js was also\nupdated for consistency.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307887\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308588\n", "files": ["browser/components/extensions/parent/ext-windows.js", "browser/components/extensions/test/browser/browser-windows.toml", "browser/components/extensions/test/browser/browser_ext_windows_create_hidpi.js", "browser/components/extensions/test/browser/head.js"], "git_node": "3ca6ccba5039c89b3674aba07be93d8a4a497ce0", "git_parents": ["fb8a464956ec1dbccc24b09c8c32945e076b5199"], "node": "9683a274ea0e8082925365541ac2f01a0108dfc6", "parents": ["7e7fd1d6e697ba51a9fe300f8bf0a6efc503c84f"], "tags": []}], "date": 1782393309, "git_changesets": ["3ca6ccba5039c89b3674aba07be93d8a4a497ce0"], "user": "pchevrel@mozilla.com"}, "27094": {"changesets": [{"author": "Harrison Oglesby \u003coglesby.harrison@gmail.com\u003e", "branch": "default", "desc": "Bug 2049785 - Replace Google Lens icon in Firefox Android  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308326\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308604\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/components/lens/GoogleLensAIControlFeature.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/components/lens/LensCameraScreen.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/search/BrowserToolbarSearchMiddleware.kt", "mobile/android/fenix/app/src/main/res/drawable/ic_logo_google_lens_24.xml", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/search/BrowserToolbarSearchMiddlewareTest.kt"], "git_node": "9b5be5a2f7e7b1de34fd4b486d895471d4a1cb16", "git_parents": ["3ca6ccba5039c89b3674aba07be93d8a4a497ce0"], "node": "0eebdc7cb722b62678906e3f871364694e4d840b", "parents": ["9683a274ea0e8082925365541ac2f01a0108dfc6"], "tags": []}], "date": 1782393347, "git_changesets": ["9b5be5a2f7e7b1de34fd4b486d895471d4a1cb16"], "user": "pchevrel@mozilla.com"}, "27095": {"changesets": [{"author": "Gela \u003cgmalekpour@mozilla.com\u003e", "branch": "default", "desc": "Bug 2049948 - Fix Built-in VPN padding in horizontal mode in the Settings menu  a=pascalc\n\n{F73472669}\n\n{F73472683}\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308594\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308695\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/settings/IPProtectionPreference.kt"], "git_node": "128aae0c59d0a2755b0460dea6f21e0b8c03376c", "git_parents": ["9b5be5a2f7e7b1de34fd4b486d895471d4a1cb16"], "node": "15340c3dd7c9252c084e238e10aec174c57a5e41", "parents": ["0eebdc7cb722b62678906e3f871364694e4d840b"], "tags": []}], "date": 1782393385, "git_changesets": ["128aae0c59d0a2755b0460dea6f21e0b8c03376c"], "user": "pchevrel@mozilla.com"}, "27096": {"changesets": [{"author": "James Teh \u