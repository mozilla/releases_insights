1ad2f6a5be25c0d7617493225c9"], "node": "df4dc5b62030c985dd7e8e3377f632041c921a4c", "parents": ["1e2499c7ad166cd2b64cc34d06bcfe7f02bfe722"], "tags": []}], "date": 1782761602, "git_changesets": ["990d7eb3c7a7148725ab1c8fdba1ba05f1b816fa"], "user": "pchevrel@mozilla.com"}, "27176": {"changesets": [{"author": "Duncan McIntosh \u003cdmcintosh@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041097 - Don't display the Taskbar Tabs page action on file URIs.  a=pascalc\n\nWhile I'm here, fix the incorrect assertion messages (if a_____Visible then\nit's _not_ hidden) since they were confusing me as I tested this.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308308\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309366\n", "files": ["browser/components/taskbartabs/TaskbarTabsPageAction.sys.mjs", "browser/components/taskbartabs/test/browser/browser_taskbarTabs_pageAction.js"], "git_node": "8100edab6a372688cc7497d171d06129bbc69c4f", "git_parents": ["990d7eb3c7a7148725ab1c8fdba1ba05f1b816fa"], "node": "1b2ddfd660f693dbb68f7c3ca728cbfc51536cbf", "parents": ["df4dc5b62030c985dd7e8e3377f632041c921a4c"], "tags": []}], "date": 1782761623, "git_changesets": ["8100edab6a372688cc7497d171d06129bbc69c4f"], "user": "pchevrel@mozilla.com"}, "27177": {"changesets": [{"author": "iain holmes \u003ciholmes@mozilla.com\u003e", "branch": "default", "desc": "Bug 2048587 - Use preferences to track whether Nimbus wants the Set As Default Browser menu added.  a=pascalc\n\nNimbus' ::GetBool requires isEarlyStartup: true, but that requires an override to prevent a deprecation warning. As we don't need this setting early, we can switch to use Nimbus' setPref feature instead.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307550\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309360\n", "files": ["browser/app/profile/firefox.js", "toolkit/components/nimbus/FeatureManifest.yaml", "widget/cocoa/nsMenuBarX.mm"], "git_node": "3f98e8f779d1ccb9b19762eab9cd8a9e80e0a898", "git_parents": ["8100edab6a372688cc7497d171d06129bbc69c4f"], "node": "3bb0c1e53a434bb543a00d058f0e83a632d57139", "parents": ["1b2ddfd660f693dbb68f7c3ca728cbfc51536cbf"], "tags": []}], "date": 1782761687, "git_changesets": ["3f98e8f779d1ccb9b19762eab9cd8a9e80e0a898"], "user": "pchevrel@mozilla.com"}, "27178": {"changesets": [{"author": "Gela \u003cgmalekpour@mozilla.com\u003e", "branch": "default", "desc": "Bug 2048642 - Part 1: Introduce a new metric specifically for catastrophic failures  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308910\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309351\n", "files": ["mobile/android/fenix/app/metrics.yaml", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/browser/BaseBrowserFragment.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/HomeFragment.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/settings/IPProtectionFragment.kt"], "git_node": "345e9c2c11c34b85648fc9bf20a7e61b22e14d5d", "git_parents": ["3f98e8f779d1ccb9b19762eab9cd8a9e80e0a898"], "node": "4e294fa8eacee32c79e6b897710e85813a481d9f", "parents": ["3bb0c1e53a434bb543a00d058f0e83a632d57139"], "tags": []}, {"author": "Gela \u003cgmalekpour@mozilla.com\u003e", "branch": "default", "desc": "Bug 2048694 - Part 2: Record telemetry for when a generic network event occurs  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308912\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309352\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/components/ipprotection/IPProtectionTelemetryMiddleware.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/components/ipprotection/IPProtectionTelemetryMiddlewareTest.kt"], "git_node": "1ea2cfe516263a7709159d7f9bbd7d67f0eb891d", "git_parents": ["345e9c2c11c34b85648fc9bf20a7e61b22e14d5d"], "node": "56aa48ed2c79219ce935d077bb93ff81b029f91c", "parents": ["4e294fa8eacee32c79e6b897710e85813a481d9f"], "tags": []}], "date": 1782761728, "git_changesets": ["345e9c2c11c34b85648fc9bf20a7e61b22e14d5d", "1ea2cfe516263a7709159d7f9bbd7d67f0eb891d"], "user": "pchevrel@mozilla.com"}, "27179": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2045990 - Version LightweightThemeManager data.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308533\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309345\n", "files": ["toolkit/components/extensions/parent/ext-theme.js", "toolkit/components/extensions/test/xpcshell/test_ext_theme_startupData.js", "toolkit/mozapps/extensions/LightweightThemeManager.sys.mjs", "toolkit/mozapps/extensions/internal/XPIProvider.sys.mjs", "toolkit/mozapps/extensions/test/xpcshell/test_cleanup_theme_processedColors.js"], "git_node": "c004079d04e013f9b76437298c5aae5f70a44cf8", "git_parents": ["1ea2cfe516263a7709159d7f9bbd7d67f0eb891d"], "node": "c7642e8e0f3eb50e5dba1e6da9ba4c2825264c2d", "parents": ["56aa48ed2c79219ce935d077bb93ff81b029f91c"], "tags": []}], "date": 1782761766, "git_changesets": ["c004079d04e013f9b76437298c5aae5f70a44cf8"], "user": "pchevrel@mozilla.com"}, "27180": {"changesets": [{"author": "Simon Farre \u003csfarre@mozilla.com\u003e", "branch": "default", "desc": "Bug 2045396 - Abort parser that otherwise could trigger the running of script when it shouldn't  a=pascalc\n\nOnly \u003cembed\u003e and \u003cobject\u003e teardown seem to finalize parsing, and circumvent script-safety-aware checks which can trigger script running like the bug displays.\n\nnsParser::Terminate is eventually called via nsDocShell::Destroy() also, but this way we ensure the above doesn't happen, provided that NS_BINDING_ABORTED is passed in.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305221\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309305\n", "files": ["parser/htmlparser/nsParser.cpp"], "git_node": "a9937a1b73fd478cf59b2d8b48624fbda2575796", "git_parents": ["c004079d04e013f9b76437298c5aae5f70a44cf8"], "node": "a5dd0a2d67751be1bbe89822a9222819beceadbb", "parents": ["c7642e8e0f3eb50e5dba1e6da9ba4c2825264c2d"], "tags": []}], "date": 1782761865, "git_changesets": ["a9937a1b73fd478cf59b2d8b48624fbda2575796"], "user": "pchevrel@mozilla.com"}, "27181": {"changesets": [{"author": "Andreas Farre \u003cfarre@mozilla.com\u003e", "branch": "default", "desc": "Bug 2043462 - Make sure to clear pending load states for closed tabs.  a=pascalc\n\nCo-authored-by: Simon Farre \u003csfarre@mozilla.com\u003e\n\nOriginal Revision: https://phabricator.services.mozilla.com/D304023\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309301\n", "files": ["docshell/shistory/nsSHistory.cpp"], "git_node": "da4f6980b959b12c0e75503012320b065c67c018", "git_parents": ["a9937a1b73fd478cf59b2d8b48624fbda2575796"], "node": "4a0ec746d6f0429899fb8d60594169bf86b89109", "parents": ["a5dd0a2d67751be1bbe89822a9222819beceadbb"], "tags": []}], "date": 1782761923, "git_changesets": ["da4f6980b959b12c0e75503012320b065c67c018"], "user": "pchevrel@mozilla.com"}, "27182": {"changesets": [{"author": "Chris Peterson \u003ccpeterson@mozilla.com\u003e", "branch": "default", "desc": "Bug 2050731 - Update documented minimum clang version to 19.  a=pascalc DONTBUILD\n\nBug 2050342 bumped the minimum clang version from 17 to 19. We need to update\nthe docs, too.\n\nhttps://firefox-source-docs.mozilla.org/code-quality/coding-style/using_cxx_in_firefox_code.html\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308960\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309293\n", "files": ["docs/code-quality/coding-style/using_cxx_in_firefox_code.rst"], "git_node": "db91bf06fbb8f72fb181dc6d977536251f27a7b9", "git_parents": ["da4f6980b959b12c0e75503012320b065c67c018"], "node": "fc86f2084cba01803af863279e52353f8b848c77", "parents": ["4a0ec746d6f0429899fb8d60594169bf86b89109"], "tags": []}], "date": 1782761970, "git_changesets": ["db91bf06fbb8f72fb181dc6d977536251f27a7b9"], "user": "pchevrel@mozilla.com"}, "27183": {"changesets": [{"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 2039990 - Part 1: Add threadsafe CurrentRemoteType getter,  a=pascalc\n\nThis can be helpful within content processes to perform additional validation\nbefore sending IPC messages which would be rejected by principal validation.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302406\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309145\n", "files": ["dom/ipc/ContentChild.cpp", "dom/ipc/ContentChild.h"], "git_node": "1981fa033e656b080110c4d7aeaffdba4941f5a3", "git_parents": ["db91bf06fbb8f72fb181dc6d977536251f27a7b9"], "node": "f2897989092cafe53a0f47586837f4505f7f8089", "parents": ["fc86f2084cba01803af863279e52353f8b848c77"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 2039990 - Part 2: Add more principal validation to PBackground,  a=pascalc\n\nThis adds principal validation calls in the places where there are visible\nPrincipalInfo instances within PBackground, as well as adding\nPrincipalValidation helpers to BackgroundParent.h.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302407\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309146\n", "files": ["ipc/glue/BackgroundImpl.cpp", "ipc/glue/BackgroundParent.h", "ipc/glue/BackgroundParentImpl.cpp"], "git_node": "2b132bca27db56837180104568c7fee9aa42a4d9", "git_parents": ["1981fa033e656b080110c4d7aeaffdba4941f5a3"], "node": "13d7afa7f31b035bb28c10b7599fa174e3554d7a", "parents": ["f2897989092cafe53a0f47586837f4505f7f8089"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 2039990 - Part 3: Check ValidatePrincipal in child,  a=pascalc\n\nThis adds redundant checks into the content process for the ValidatePrincipal\nchecks added in the parent process in earlier patches in this stack. This is\nintended to reduce the likelihood of hitting one of those failures in the case\nwhere the check is overly restrictive, instead blocking access to storage APIs\nin those cases with an exception.\n\nThis should hopefully reduce the risk of enabling these checks in builds.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302408\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309147\n", "files": ["dom/broadcastchannel/BroadcastChannel.cpp", "dom/cache/BoundStorageKey.cpp", "dom/cache/CacheStorage.cpp", "dom/fs/child/FileSystemBackgroundRequestHandler.cpp", "dom/simpledb/SDBConnection.cpp", "dom/storage/LocalStorageManager.cpp", "dom/storage/StorageActivityService.cpp", "dom/workers/sharedworkers/SharedWorker.cpp", "ipc/glue/BackgroundChild.h", "ipc/glue/BackgroundImpl.cpp"], "git_node": "c3e06476febeb08006e2af979c7aff7b4a6fc513", "git_parents": ["2b132bca27db56837180104568c7fee9aa42a4d9"], "node": "453b6fa4882a216846be781d228f8dcfadeea0fe", "parents": ["13d7afa7f31b035bb28c10b7599fa174e3554d7a"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 2039990 - Part 4: Use ThreadsafeContentParentHandle in LocalStorage & ClientSource actors,  a=pascalc\n\nPipe ThreadsafeContentParentInfo throughout LocalStorage & ClientSource such\nthat the local storage state is more generally available there. This should\nhave no behaviour changes, and is just setup for the following parts.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302409\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309148\n", "files": ["dom/clients/manager/ClientManagerParent.cpp", "dom/clients/manager/ClientManagerService.cpp", "dom/clients/manager/ClientManagerService.h", "dom/clients/manager/ClientSourceParent.cpp", "dom/clients/manager/ClientSourceParent.h", "dom/localstorage/ActorsParent.cpp"], "git_node": "2ead64c84278507b3d23c8dea16c27515ff06df3", "git_parents": ["c3e06476febeb08006e2af979c7aff7b4a6fc513"], "node": "d493234ac26ecf53044f049776805086e36ba212", "parents": ["453b6fa4882a216846be781d228f8dcfadeea0fe"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 2039990 - Part 5: ValidatePrincipal in LocalStorage actors,  a=pascalc\n\nCall ValidatePrincipal on the principals in LocalStorage using the newly piped\nthrough ThreadsafeContentParentHandle to extract the remoteType.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302410\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309149\n", "files": ["dom/localstorage/ActorsParent.cpp"], "git_node": "92c001aada9689959f5815d54f994867d3c48d9c", "git_parents": ["2ead64c84278507b3d23c8dea16c27515ff06df3"], "node": "a83e57cb0b05b6a3de555e9e5b5888e0c8ba12a3", "parents": ["d493234ac26ecf53044f049776805086e36ba212"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 2039990 - Part 6: Call ValidatePrincipal from PrincipalVerifier,  a=pascalc\n\nThis call-site was already doing validation on principals for the Cache API.\nThe new checks make this validation more thorough.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302411\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309150\n", "files": ["dom/cache/PrincipalVerifier.cpp"], "git_node": "7282c412dce8e343082da0a8e27c31c60f79d7b0", "git_parents": ["92c001aada9689959f5815d54f994867d3c48d9c"], "node": "35e0e0ed59e409e5e71bc1efc99a17b603187888", "parents": ["a83e57cb0b05b6a3de555e9e5b5888e0c8ba12a3"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 2039990 - Part 7: Validate ClientSources on creation,  a=pascalc\n\nThis patch does not validate all places which pass around IPCClientInfo, as\nthat can be passed into a different process. Instead the validation is\nperformed when the ClientSource is bound.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302412\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309151\n", "files": ["dom/clients/manager/ClientSource.cpp", "dom/clients/manager/ClientSourceParent.cpp", "dom/clients/manager/ClientValidation.cpp", "dom/clients/manager/ClientValidation.h"], "git_node": "11e23b97b13f7c598654a3097ba8a9b449e458ed", "git_parents": ["7282c412dce8e343082da0a8e27c31c60f79d7b0"], "node": "c1dc2a84473e1fd0d89ffc5e190ab07d299f3921", "parents": ["35e0e0ed59e409e5e71bc1efc99a17b603187888"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 2039990 - Part 8: We cant access cache for a different origin,  a=pascalc\n\nThis test was failing after the changes in earlier parts, as it was explicitly\naccessing storage for another origin from within the content process. The test\nwas simplified to access the current document's origin instead, as it appears\nthat is the actual use-case for this API from DevTools.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302413\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309152\n", "files": ["dom/cache/test/mochitest/test_chrome_constructor.html"], "git_node": "1c20d5457d93cd8b341184fb431e9b5b837de5c4", "git_parents": ["11e23b97b13f7c598654a3097ba8a9b449e458ed"], "node": "7c5e212f8ad4014beae2a5addb5f2edcca3fe40e", "parents": ["c1dc2a84473e1fd0d89ffc5e190ab07d299f3921"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 2039990 - Part 9: Validate principals early during SharedWorker creation,  a=pascalc\n\nThis is a bit of an aggressive approach to the implementation, and will result\nin `ValidatePrincipal` failures firing in codepaths reachable from web content.\nSpecifically the checks in the SharedWorkerService will hit this for loads\nwhich would normally fail during network fetch.\n\nIn the future, we should refactor the implementation to avoid needing to do\nvalidation in this way, by deriving these values directly within the parent\nprocess.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302414\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309153\n", "files": ["dom/workers/sharedworkers/SharedWorker.cpp", "dom/workers/sharedworkers/SharedWorkerService.cpp", "dom/workers/sharedworkers/SharedWorkerService.h"], "git_node": "eb224f472714c7bfa44c85fef3e5d949fe2267b8", "git_parents": ["1c20d5457d93cd8b341184fb431e9b5b837de5c4"], "node": "bcdd6e04eb7c1ef58015cc039596c00194fe20ad", "parents": ["7c5e212f8ad4014beae2a5addb5f2edcca3fe40e"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 2039990 - Part 10: Validate principals during IndexedDB creation,  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307070\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309154\n", "files": ["dom/indexedDB/ActorsParent.cpp", "dom/indexedDB/IDBFactory.cpp"], "git_node": "dfe93155ba6426f9287b02e930fbc1e0d71fac51", "git_parents": ["eb224f472714c7bfa44c85fef3e5d949fe2267b8"], "node": "8d35dc1207136404933785edc9d841e909f262d2", "parents": ["bcdd6e04eb7c1ef58015cc039596c00194fe20ad"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 2039990 - Part 11: Allow some tests to access system IndexedDB from content,  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308595\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309155\n", "files": ["dom/indexedDB/ActorsParent.cpp", "dom/indexedDB/IDBFactory.cpp", "dom/indexedDB/IndexedDBCommon.cpp", "dom/indexedDB/IndexedDBCommon.h", "dom/indexedDB/test/test_message_manager_ipc.html", "dom/indexedDB/test/unit/xpcshell-head-child-process.js", "dom/indexedDB/test/unit/xpcshell-parent-process.toml", "modules/libpref/init/StaticPrefList.yaml"], "git_node": "193f8777674fb431ce752b26030d0eb0a41ea7ee", "git_parents": ["dfe93155ba6426f9287b02e930fbc1e0d71fac51"], "node": "13f5595c477acdeeb632c08d37ed50b2cfc695f5", "parents": ["8d35dc1207136404933785edc9d841e909f262d2"], "tags": []}], "date": 1782762230, "git_changesets": ["1981fa033e656b080110c4d7aeaffdba4941f5a3", "2b132bca27db56837180104568c7fee9aa42a4d9", "c3e06476febeb08006e2af979c7aff7b4a6fc513", "2ead64c84278507b3d23c8dea16c27515ff06df3", "92c001aada9689959f5815d54f994867d3c48d9c", "7282c412dce8e343082da0a8e27c31c60f79d7b0", "11e23b97b13f7c598654a3097ba8a9b449e458ed", "1c20d5457d93cd8b341184fb431e9b5b837de5c4", "eb224f472714c7bfa44c85fef3e5d949fe2267b8", "dfe93155ba6426f9287b02e930fbc1e0d71fac51", "193f8777674fb431ce752b26030d0eb0a41ea7ee"], "user": "pchevrel@mozilla.com"}, "27184": {"changesets": [{"author": "RebecaTudor \u003crebecatudor273@gmail.com\u003e", "branch": "default", "desc": "Bug 2039255 - Part 1: Fix context menu displaying over private browsing unlock screen  a=pascalc\n\nThese changes ensure that the context menu is hidden immediately when the\nprivate browsing session is locked and prevent the menu from appearing\nwhile the unlock screen is active.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302449\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309318\n", "files": ["mobile/android/android-components/components/feature/contextmenu/src/main/java/mozilla/components/feature/contextmenu/ContextMenuFeature.kt", "mobile/android/android-components/components/feature/contextmenu/src/test/java/mozilla/components/feature/contextmenu/ContextMenuFeatureTest.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/browser/BaseBrowserFragment.kt"], "git_node": "b35b36bb11efe2375478765ff31bf2741ec34a46", "git_parents": ["193f8777674fb431ce752b26030d0eb0a41ea7ee"], "node": "384cab4881d218a758c337bd9374e3368892863a", "parents": ["13f5595c477acdeeb632c08d37ed50b2cfc695f5"], "tags": []}, {"author": "RebecaTudor \u003crebecatudor273@gmail.com\u003e", "branch": "default", "desc": "Bug 2039255 - Part 2: Prevent permission prompts from displaying over the private browsing unlock screen.  a=pascalc\n\nThese changes ensure that the permission prompts are hidden immediately when the\nprivate browsing session is locked and prevent them from appearing\nwhile the unlock screen is active.\n\n Note: If a prompt is hidden, we don't want to dismiss it when the user taps\ninside the unlock screen, so the behavior remains the same.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302450\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309319\n", "files": ["mobile/android/android-components/components/feature/sitepermissions/src/main/java/mozilla/components/feature/sitepermissions/SitePermissionsFeature.kt", "mobile/android/android-components/components/feature/sitepermissions/src/test/java/mozilla/components/feature/sitepermissions/SitePermissionsFeatureTest.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/browser/BaseBrowserFragment.kt"], "git_node": "d8c14650e1e0d2dc6fc624b3355c29cf2d61ae90", "git_parents": ["b35b36bb11efe2375478765ff31bf2741ec34a46"], "node": "4057e65c0861884257177aaa79cea55ab49fad88", "parents": ["384cab4881d218a758c337bd9374e3368892863a"], "tags": []}, {"author": "RebecaTudor \u003crebecatudor273@gmail.com\u003e", "branch": "default", "desc": "Bug 2039255 - Part 3: Obscure private browsing content during system permission requests.  a=pascalc\n\nIssue:\n When PBM lock is active, system permission dialogs (Camera, Location, etc.)\nleave private tab content visible in the background, creating a privacy leak.\n Fix\n Implemented a security overlay that triggers during system permission requests:\n - Added systemPermissionRequestInProgress to BrowserState to track active system permission dialogs.\n - Updated SitePermissionsFeature to manage this state during permission requests.\n - Added BlackScreenOverlay and integrated it into BaseBrowserFragment to cover the screen when\nrequest is active in private mode.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305206\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309320\n", "files": ["mobile/android/android-components/components/browser/state/src/main/java/mozilla/components/browser/state/action/BrowserAction.kt", "mobile/android/android-components/components/browser/state/src/main/java/mozilla/components/browser/state/reducer/BrowserStateReducer.kt", "mobile/android/android-components/components/browser/state/src/main/java/mozilla/components/browser/state/reducer/SystemPermissionReducer.kt", "mobile/android/android-components/components/browser/state/src/main/java/mozilla/components/browser/state/state/BrowserState.kt", "mobile/android/android-components/components/browser/state/src/test/java/mozilla/components/browser/state/reducer/BrowserStateReducerKtTest.kt", "mobile/android/android-components/components/feature/sitepermissions/src/main/java/mozilla/components/feature/sitepermissions/SitePermissionsFeature.kt", "mobile/android/android-components/components/feature/sitepermissions/src/test/java/mozilla/components/feature/sitepermissions/SitePermissionsFeatureTest.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/browser/BaseBrowserFragment.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/pbmlock/BlackScreenOverlay.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/browser/BaseBrowserFragmentTest.kt"], "git_node": "a47c92b239b4250ef46f722fe81d0bc747a8ff81", "git_parents": ["d8c14650e1e0d2dc6fc624b3355c29cf2d61ae90"], "node": "f5b57307b00ae09292549de3e9fdf8b5785fc741", "parents": ["4057e65c0861884257177aaa79cea55ab49fad88"], "tags": []}], "date": 1782764562, "git_changesets": ["b35b36bb11efe2375478765ff31bf2741ec34a46", "d8c14650e1e0d2dc6fc624b3355c29cf2d61ae90", "a47c92b239b4250ef46f722fe81d0bc747a8ff81"], "user": "pchevrel@mozilla.com"}, "27185": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Import translations from main\n", "files": ["mobile/android/android-components/components/feature/media/src/main/res/values-uk/strings.xml", "mobile/android/android-components/components/feature/prompts/src/main/res/values-th/strings.xml", "mobile/android/android-components/components/feature/prompts/src/main/res/values-tr/strings.xml", "mobile/android/android-components/components/feature/prompts/src/main/res/values-uk/strings.xml", "mobile/android/android-components/components/feature/summarize/src/main/res/values-uk/strings.xml", "mobile/android/fenix/app/src/main/res/values-th/strings.xml", "mobile/android/fenix/app/src/main/res/values-uk/strings.xml"], "git_node": "2f432cd24bb303f6f1ac2e4c3c3dc2e5d1ba4de9", "git_parents": ["a47c92b239b4250ef46f722fe81d0bc747a8ff81"], "node": "4aeb26e815723327e4dd229442b507647209c9ad", "parents": ["f5b57307b00ae09292549de3e9fdf8b5785fc741"], "tags": []}], "date": 1782785689, "git_changesets": ["2f432cd24bb303f6f1ac2e4c3c3dc2e5d1ba4de9"], "user": "ffxbld@lando.moz.tools"}, "27186": {"changesets": [{"author": "Ryan VanderMeulen \u003crvandermeulen@mozilla.com\u003e", "branch": "default", "desc": "Bug 2051165 - Remove unused ub18 packages and drop launchpad source URLs  a=diannaS\n\nThe ub18-libc6, ub18-python-dbus, ub18-pygobject and ub18-pyatspi packages\nare no longer consumed by any docker image, so remove them along with the\npatch files that only they referenced.\n\nAlso switch the remaining ub18-python-psutil and ub18-coreutils packages off\nlaunchpad.net source URLs in favour of snapshot.ubuntu.com.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309271\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3