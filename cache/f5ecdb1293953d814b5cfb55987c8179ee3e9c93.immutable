788e2f068a749f68068e2f62\nro -\u003e 995185829d89c88c788e2f068a749f68068e2f62\nru -\u003e 995185829d89c88c788e2f068a749f68068e2f62\nsk -\u003e 995185829d89c88c788e2f068a749f68068e2f62\nsl -\u003e 995185829d89c88c788e2f068a749f68068e2f62\nson -\u003e 995185829d89c88c788e2f068a749f68068e2f62\nsq -\u003e 995185829d89c88c788e2f068a749f68068e2f62\nsr -\u003e 995185829d89c88c788e2f068a749f68068e2f62\nsv-SE -\u003e 995185829d89c88c788e2f068a749f68068e2f62\nta -\u003e 995185829d89c88c788e2f068a749f68068e2f62\nte -\u003e 995185829d89c88c788e2f068a749f68068e2f62\nth -\u003e 995185829d89c88c788e2f068a749f68068e2f62\ntl -\u003e 995185829d89c88c788e2f068a749f68068e2f62\ntr -\u003e 995185829d89c88c788e2f068a749f68068e2f62\ntrs -\u003e 995185829d89c88c788e2f068a749f68068e2f62\nuk -\u003e 995185829d89c88c788e2f068a749f68068e2f62\nur -\u003e 995185829d89c88c788e2f068a749f68068e2f62\nuz -\u003e 995185829d89c88c788e2f068a749f68068e2f62\nvi -\u003e 995185829d89c88c788e2f068a749f68068e2f62\nwo -\u003e 995185829d89c88c788e2f068a749f68068e2f62\nxh -\u003e 995185829d89c88c788e2f068a749f68068e2f62\nzam -\u003e 995185829d89c88c788e2f068a749f68068e2f62\nzh-CN -\u003e 995185829d89c88c788e2f068a749f68068e2f62\nzh-TW -\u003e 995185829d89c88c788e2f068a749f68068e2f62\n", "files": ["mobile/locales/l10n-changesets.json"], "git_node": "3b64e8be5c959c6784e4f17676551decabb546a6", "git_parents": ["e16cfee82abee75a9c3b79603e56feab3ab8167d"], "node": "fcc71af71c089d5fd852081575decf36b7e05b8d", "parents": ["2840a33714399efd54ced55755f9beebdec4fe9b"], "tags": ["DEVEDITION_153_0b1_BUILD2", "DEVEDITION_153_0b1_RELEASE", "FIREFOX-ANDROID_153_0b1_BUILD2", "FIREFOX-ANDROID_153_0b1_RELEASE", "FIREFOX_153_0b1_BUILD2", "FIREFOX_153_0b1_RELEASE"]}], "date": 1781690709, "git_changesets": ["e16cfee82abee75a9c3b79603e56feab3ab8167d", "3b64e8be5c959c6784e4f17676551decabb546a6"], "user": "ffxbld@lando.moz.tools"}, "26900": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging fcc71af71c089d5fd852081575decf36b7e05b8d with FIREFOX-ANDROID_153_0b1_BUILD2 a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "d1200f8500d702333940b76d0a75636e802ffff8", "git_parents": ["e8a5e397466b04d6a97b06c318dd2834538e69c6"], "node": "12009683ee1f8c53d11b4d6278e3b9673ce397b0", "parents": ["d7fb600d9bbae58bbbc50368166585621d719b2d"], "tags": []}], "date": 1781693644, "git_changesets": ["d1200f8500d702333940b76d0a75636e802ffff8"], "user": "ffxbld@lando.moz.tools"}, "26901": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging fcc71af71c089d5fd852081575decf36b7e05b8d with DEVEDITION_153_0b1_BUILD2 a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "b9615894f7961537b14b42e86323816442030a92", "git_parents": ["d1200f8500d702333940b76d0a75636e802ffff8"], "node": "745b49ca510602161a9001134649c1a469ccd358", "parents": ["12009683ee1f8c53d11b4d6278e3b9673ce397b0"], "tags": []}], "date": 1781693712, "git_changesets": ["b9615894f7961537b14b42e86323816442030a92"], "user": "ffxbld@lando.moz.tools"}, "26902": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging fcc71af71c089d5fd852081575decf36b7e05b8d with FIREFOX_153_0b1_BUILD2 a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "830c5acbefa3d03fb7c8854a3b2351c33dbcd899", "git_parents": ["b9615894f7961537b14b42e86323816442030a92"], "node": "51df7d8a2aafd61f662ca5b394e77dc0ade6e94d", "parents": ["745b49ca510602161a9001134649c1a469ccd358"], "tags": []}], "date": 1781693798, "git_changesets": ["830c5acbefa3d03fb7c8854a3b2351c33dbcd899"], "user": "ffxbld@lando.moz.tools"}, "26903": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "Automatic version bump NO BUG a=release CLOSED TREE DONTBUILD\n", "files": ["browser/config/version_display.txt", "mobile/android/version.txt"], "git_node": "d5a143f8eaf985c16e7db302a2f8341a6c4d6e18", "git_parents": ["3b64e8be5c959c6784e4f17676551decabb546a6"], "node": "b13985a0b310d29457e737dddb29cae3ce1abddd", "parents": ["fcc71af71c089d5fd852081575decf36b7e05b8d"], "tags": []}], "date": 1781704920, "git_changesets": ["d5a143f8eaf985c16e7db302a2f8341a6c4d6e18"], "user": "ffxbld@lando.moz.tools"}, "26904": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging fcc71af71c089d5fd852081575decf36b7e05b8d with FIREFOX-ANDROID_153_0b1_RELEASE a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "4a9c9835e8221e9b593ba5923880ce2f5dd16b0e", "git_parents": ["830c5acbefa3d03fb7c8854a3b2351c33dbcd899"], "node": "c53bad1ee38d93a5f430412941fbe20cdb82b7b4", "parents": ["51df7d8a2aafd61f662ca5b394e77dc0ade6e94d"], "tags": []}], "date": 1781704938, "git_changesets": ["4a9c9835e8221e9b593ba5923880ce2f5dd16b0e"], "user": "ffxbld@lando.moz.tools"}, "26905": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging fcc71af71c089d5fd852081575decf36b7e05b8d with FIREFOX_153_0b1_RELEASE a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "3bd8bd9b5cc47dc880cb55570fa21af004eeea54", "git_parents": ["4a9c9835e8221e9b593ba5923880ce2f5dd16b0e"], "node": "7e5337f4e448c6fe1d00abd7fc7b85d58726361d", "parents": ["c53bad1ee38d93a5f430412941fbe20cdb82b7b4"], "tags": []}], "date": 1781714290, "git_changesets": ["3bd8bd9b5cc47dc880cb55570fa21af004eeea54"], "user": "ffxbld@lando.moz.tools"}, "26906": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging fcc71af71c089d5fd852081575decf36b7e05b8d with DEVEDITION_153_0b1_RELEASE a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "b835b55b7b0c35ea8378cadbc6a3490f55eadc5f", "git_parents": ["3bd8bd9b5cc47dc880cb55570fa21af004eeea54"], "node": "c6d864954d5b29ceddf01e639f515163855ff6e7", "parents": ["7e5337f4e448c6fe1d00abd7fc7b85d58726361d"], "tags": []}], "date": 1781714350, "git_changesets": ["b835b55b7b0c35ea8378cadbc6a3490f55eadc5f"], "user": "ffxbld@lando.moz.tools"}, "26907": {"changesets": [{"author": "Stephen A Pohl \u003cspohl@mozilla.com\u003e", "branch": "default", "desc": "Bug 2047850: Read system print dialog results from the printInfo passed to the sheet on macOS.  a=RyanVM\n\nBug 2035195 migrated the macOS system print dialog from -[NSPrintPanel runModal] to the delegate-based -beginSheetWithPrintInfo:modalForWindow:delegate:didEndSelector:contextInfo: sheet API. With runModal, NSPrintPanel updates the printInfo of the current NSPrintOperation, so the completion code read the user's choices back from [[NSPrintOperation currentOperation] printInfo]. The sheet API instead writes the user's choices, including the print destination, back into the printInfo object that is passed to it, not into the copy held by the current NSPrintOperation.\n\nThe completion block kept reading from the current operation's copy, which is never modified by the sheet, so the destination selected in the dialog (for example \"Save as PDF\") was lost and the job most likely fell back to the default printer. Read the updated settings from the printInfo we passed to beginSheetWithPrintInfo: instead.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307188\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307342\n", "files": ["widget/cocoa/nsPrintDialogX.mm"], "git_node": "c9565d2c7f823e6ed2fb3e13616922d3d122b62b", "git_parents": ["d5a143f8eaf985c16e7db302a2f8341a6c4d6e18"], "node": "86240ace22b0c03e55602de5b1dd6fb505217163", "parents": ["b13985a0b310d29457e737dddb29cae3ce1abddd"], "tags": []}], "date": 1781721999, "git_changesets": ["c9565d2c7f823e6ed2fb3e13616922d3d122b62b"], "user": "rvandermeulen@mozilla.com"}, "26908": {"changesets": [{"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 2039575 - Work around crashes in CanAttachDOMCall on Raptor Lake CPUs.  a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307319\n", "files": ["js/src/jit/CacheIR.cpp"], "git_node": "5ca05e966a3865846e3a53c838b7680226c0c381", "git_parents": ["c9565d2c7f823e6ed2fb3e13616922d3d122b62b"], "node": "c8cbf79623488223669600fb6a2d842bb7d72ed9", "parents": ["86240ace22b0c03e55602de5b1dd6fb505217163"], "tags": []}], "date": 1781722022, "git_changesets": ["5ca05e966a3865846e3a53c838b7680226c0c381"], "user": "rvandermeulen@mozilla.com"}, "26909": {"changesets": [{"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 2046945 - Part 1: Fire intl:l10n-sources-changed when L10nRegistry sources mutate  a=diannaS\n\nLong-lived Localization instances cache the bundles they generate on first\nuse. Until now, no observer notification fired when sources were registered,\nupdated, or removed in L10nRegistry, so those caches were never invalidated;\nany source registered after startup (e.g. by AboutNewTabResourceMapping when\na train-hopped newtab XPI is active) was invisible to already-translated\ndocuments.\n\nWe introduce a new intl:l10n-sources-changed observer topic, fired by\nL10nRegistry in both the parent (L10nRegistrySendUpdateL10nFileSources) and\ncontent (RegisterFileSourcesFromParentProcess) processes after the registry\nhas been mutated. Localization::Observe now listens for it and drops cached\nbundles, mirroring its existing handling of intl:app-locales-changed.\n\nA dedicated topic is used rather than reusing intl:app-locales-changed so\nthe ~30 other observers that care only about negotiated-locale changes\n(font list, mozIntl caches, sidebar, tabbrowser, \u2026) aren't woken on every\nsource mutation.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307421\n", "files": ["intl/l10n/L10nRegistry.cpp", "intl/l10n/test/test_l10nregistry_observer.js", "intl/l10n/test/xpcshell.toml"], "git_node": "e8d3b69d5807fa2d32f4b7ad060cde5762ebeafd", "git_parents": ["5ca05e966a3865846e3a53c838b7680226c0c381"], "node": "0634577e74577cd7eefea109fc75fc8f62da72fd", "parents": ["c8cbf79623488223669600fb6a2d842bb7d72ed9"], "tags": []}, {"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 2046945 - Part 1.5: Have AboutNewTabChild retrigger translation of about:newtab on intl:l10n-sources-changed.  a=diannaS\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307422\n", "files": ["browser/actors/AboutNewTabChild.sys.mjs", "browser/components/newtab/AboutNewTabRedirector.sys.mjs"], "git_node": "97c0d86585ff8d8e67b28c5319adbf4c992e7cd3", "git_parents": ["e8d3b69d5807fa2d32f4b7ad060cde5762ebeafd"], "node": "010bdc17c4381237736a542007ecccb16a750263", "parents": ["0634577e74577cd7eefea109fc75fc8f62da72fd"], "tags": []}, {"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 2046945 - Part 2: Expose active langpack ids and a webextension-langpack-shutdown observer topic  a=diannaS\n\nConsumers of L10nRegistry that want to register sources alongside a\nlangpack's (for example, to provide a locale-specific override for an\nindividual resource) need two things this module didn't previously\nprovide: an authoritative enumeration of currently-active langpacks at\nthe time the consumer initializes, and lifecycle notifications symmetric\nto the existing webextension-langpack-startup topic.\n\nWe add a static Langpack.activeLangpackIds Set, mutated at the same\ncallsites that mutate the L10nRegistry, exposing the langpack metasource\nstrings (startupData.langpackId, which is *not* the addon's id). We then\nfire a new webextension-langpack-shutdown observer topic before the langpack\nremoves its L10nRegistry sources, so consumers can clean up parallel\nregistrations in the same metasource before it goes away.\n\nThe first consumer in AboutNewTabResourceMapping in the next patch in this\nseries.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307423\n", "files": ["toolkit/components/extensions/Extension.sys.mjs", "toolkit/mozapps/extensions/test/xpcshell/test_webextension_langpack.js"], "git_node": "f8b390e0422a23590990437a9e06e8dff670042a", "git_parents": ["97c0d86585ff8d8e67b28c5319adbf4c992e7cd3"], "node": "f3860d719548d334ba9331296085606687b0f9ce", "parents": ["010bdc17c4381237736a542007ecccb16a750263"], "tags": []}, {"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 2046945 - Part 3: Register newtab XPI Fluent source into each active langpack's metasource  a=diannaS\n\nThe L10nRegistry solver builds bundles atomically per (locale, metasource):\nso every required resource must be satisfiable from sources in that\nmetasource for that locale, or _no bundle is produced_.\n\nThe \"app\" metasource's non-newtab sources (toolkit, browser) are packaged en-US\nonly, so with a non-English langpack the (locale, \"app\") bundle can never be\nbuilt \u2014 and the train-hop newtab XPI's locale-specific strings are\nunreachable, falling through to en-US. That is why train-hop-only widget\nstrings (added to the XPI but not yet present in any langpack) were\nrendering in the wrong language.\n\nWe make AboutNewTabResourceMapping also register a shadow newtab\nL10nFileSource into each active langpack's metasource, enumerated via\nLangpack.activeLangpackIds and kept in sync with\nwebextension-langpack-startup/-shutdown observer notifications). Within the\n(locale, langpack) bundle, the solver now yields two valid orderings: one\nwith the langpack's older newtab.ftl, one with the XPI's. Fluent falls\nthrough the former on missing keys and resolves train-hop-only strings\nfrom the latter, while strings the langpack already translates continue\nto come from the langpack.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307424\n", "files": ["browser/components/newtab/AboutNewTabResourceMapping.sys.mjs", "browser/components/newtab/test/xpcshell/test_AboutNewTabResourceMapping_langpackShadow.js", "browser/components/newtab/test/xpcshell/xpcshell.toml"], "git_node": "f6884c6e8e31454cc3f5b553ad23e45bb64dcb05", "git_parents": ["f8b390e0422a23590990437a9e06e8dff670042a"], "node": "659b4c0b12ffb8b72ed85cf99ca975de33489933", "parents": ["f3860d719548d334ba9331296085606687b0f9ce"], "tags": []}], "date": 1781738023, "git_changesets": ["e8d3b69d5807fa2d32f4b7ad060cde5762ebeafd", "97c0d86585ff8d8e67b28c5319adbf4c992e7cd3", "f8b390e0422a23590990437a9e06e8dff670042a", "f6884c6e8e31454cc3f5b553ad23e45bb64dcb05"], "user": "dsmith@mozilla.com"}, "26910": {"changesets": [{"author": "Dianna Smith \u003cdsmith@mozilla.com\u003e", "branch": "default", "desc": "Revert \"Bug 2046945 - Part 3: Register newtab XPI Fluent source into each active langpack's metasource\" a=backout\n\nThis reverts commit f6884c6e8e31454cc3f5b553ad23e45bb64dcb05.\n", "files": ["browser/components/newtab/AboutNewTabResourceMapping.sys.mjs", "browser/components/newtab/test/xpcshell/test_AboutNewTabResourceMapping_langpackShadow.js", "browser/components/newtab/test/xpcshell/xpcshell.toml"], "git_node": "1d42c5900fd3b59d942b179060838ac58125ed59", "git_parents": ["f6884c6e8e31454cc3f5b553ad23e45bb64dcb05"], "node": "b83be8058db029dde934e7e1ca30f983549bac60", "parents": ["659b4c0b12ffb8b72ed85cf99ca975de33489933"], "tags": []}, {"author": "Dianna Smith \u003cdsmith@mozilla.com\u003e", "branch": "default", "desc": "Revert \"Bug 2046945 - Part 2: Expose active langpack ids and a webextension-langpack-shutdown observer topic\"  a=backout\n\nThis reverts commit f8b390e0422a23590990437a9e06e8dff670042a.\n", "files": ["toolkit/components/extensions/Extension.sys.mjs", "toolkit/mozapps/extensions/test/xpcshell/test_webextension_langpack.js"], "git_node": "e17e1402437a72cc742d12768762b566a98d0415", "git_parents": ["1d42c5900fd3b59d942b179060838ac58125ed59"], "node": "b69143ed53ebedb64fa37ad17842ac94fc1471c9", "parents": ["b83be8058db029dde934e7e1ca30f983549bac60"], "tags": []}, {"author": "Dianna Smith \u003cdsmith@mozilla.com\u003e", "branch": "default", "desc": "Revert \"Bug 2046945 - Part 1.5: Have AboutNewTabChild retrigger translation of about:newtab on intl:l10n-sources-changed.\" a=backout\n\nThis reverts commit 97c0d86585ff8d8e67b28c5319adbf4c992e7cd3.\n", "files": ["browser/actors/AboutNewTabChild.sys.mjs", "browser/components/newtab/AboutNewTabRedirector.sys.mjs"], "git_node": "b213ec5c480313efe0bb6fc6a9b3d1a593ce3b86", "git_parents": ["e17e1402437a72cc742d12768762b566a98d0415"], "node": "8ba2b00199c4b6548c050984041a57aebaa2b4cf", "parents": ["b69143ed53ebedb64fa37ad17842ac94fc1471c9"], "tags": []}, {"author": "Dianna Smith \u003cdsmith@mozilla.com\u003e", "branch": "default", "desc": "Revert \"Bug 2046945 - Part 1: Fire intl:l10n-sources-changed when L10nRegistry sources mutate\" for causing xpc failures a=backout\n\nThis reverts commit e8d3b69d5807fa2d32f4b7ad060cde5762ebeafd.\n", "files": ["intl/l10n/L10nRegistry.cpp", "intl/l10n/test/test_l10nregistry_observer.js", "intl/l10n/test/xpcshell.toml"], "git_node": "b4cb74fbe0190a3699b77e89eba8ecefa590f37e", "git_parents": ["b213ec5c480313efe0bb6fc6a9b3d1a593ce3b86"], "node": "07149107d6bbe441588f737c4ae75619adf2ab03", "parents": ["8ba2b00199c4b6548c050984041a57aebaa2b4cf"], "tags": []}], "date": 1781747408, "git_changesets": ["1d42c5900fd3b59d942b179060838ac58125ed59", "e17e1402437a72cc742d12768762b566a98d0415", "b213ec5c480313efe0bb6fc6a9b3d1a593ce3b86", "b4cb74fbe0190a3699b77e89eba8ecefa590f37e"], "user": "dsmith@mozilla.com"}, "26911": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging 6526f112c78ae37f378df206a6002289d72f39f2 with FIREFOX-ANDROID_152_0_1_BUILD1 a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "6c91c381203eb77119ea0577406d23dd125acc09", "g