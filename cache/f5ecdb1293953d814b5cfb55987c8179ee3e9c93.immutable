values/attrs.xml", "mobile/android/fenix/app/src/main/res/values/colors.xml", "mobile/android/fenix/app/src/main/res/values/styles.xml"], "git_node": "d0904a9b8492f0e82c02752579a74996e1565d0d", "git_parents": ["6e57a4bd3587806ed79726d3134ab7464ef5d125"], "node": "be63c1f168a66568892b0a4a97fa8e9fb139ccf9", "parents": ["9963d411b15282c9979844c4354ca10989480e0e"], "tags": []}, {"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 2011413 - Part 2: Align the private mode icon in the tab counter with the Nova Design specs  a=pascalc DONTBUILD\n\nFigma: https://www.figma.com/design/MjufE1X5fvkxZ0YneX4kRd/Android-Library--Nova-?node-id=72585-25275&m=dev\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306617\n\nDifferential Revision: https://phabricator.services.mozilla.com/D306907\n", "files": ["mobile/android/android-components/components/ui/icons/src/main/res/drawable/mozac_ic_private_mode_circle_fill_stroke_20.xml", "mobile/android/android-components/components/ui/icons/src/main/res/values/colors.xml", "mobile/android/fenix/app/src/main/res/values-night/colors.xml", "mobile/android/fenix/app/src/main/res/values/colors.xml"], "git_node": "d5edd36290d89b1ae8cad1fe4526e1093afca422", "git_parents": ["d0904a9b8492f0e82c02752579a74996e1565d0d"], "node": "8e694405ef81327d0bbdcacf6c46a7105e1d96fe", "parents": ["be63c1f168a66568892b0a4a97fa8e9fb139ccf9"], "tags": []}], "date": 1781780389, "git_changesets": ["d0904a9b8492f0e82c02752579a74996e1565d0d", "d5edd36290d89b1ae8cad1fe4526e1093afca422"], "user": "pchevrel@mozilla.com"}, "26919": {"changesets": [{"author": "Alastor Wu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 2045756 - Skip a renderer-referenced surface when matching by FFmpeg id in FFmpegVideoFramePool  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305429\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307085\n", "files": ["dom/media/platforms/ffmpeg/FFmpegVideoFramePool.cpp"], "git_node": "2b7fb7b54d6097d338a4632fd71efce8e4376517", "git_parents": ["d5edd36290d89b1ae8cad1fe4526e1093afca422"], "node": "f0b65e9f7f71097ea564bfdd62f6cc55ee06d20e", "parents": ["8e694405ef81327d0bbdcacf6c46a7105e1d96fe"], "tags": []}], "date": 1781780425, "git_changesets": ["2b7fb7b54d6097d338a4632fd71efce8e4376517"], "user": "pchevrel@mozilla.com"}, "26920": {"changesets": [{"author": "DrSeed Lu \u003cdr.seed.lu@gmail.com\u003e", "branch": "default", "desc": "Bug 2046497 - Update open tabs sidebar panel shortcut to Ctrl+Alt+U (Ctrl+U on macOS)  a=pascalc DONTBUILD\n\nThe previous Ctrl+Shift+L shortcut clashed with Bitwarden's autofill\nshortcut, and Bitwarden has around 1M users that could have been hit\nby this.\n\nAfter the AMO extension shortcut review, the new shortcuts\nare Ctrl+U on macOS and Ctrl+Alt+U on Windows and Linux.\n\nThis keeps the conflict impact under about 2,000 daily users.\n\nFor the implementation I followed the same pattern that\nviewGenaiChatSidebarKb already uses in browser-sets.inc.xhtml, where\nthe right modifiers get picked at build time based on the platform.\nThe browserSets.ftl entry moves from .key = L to .key = U.\n\nThe shortcut still appears in about:keyboard automatically through\nthe menubar menuitem setup I added in bug 2042921, so users with a\nconflicting extension can rebind it from there.\n\nAdds viewOpenTabsSidebarKb to known_errors in test_no_errors_clean_profile.py\nto prevent the same backout that happened on the first land attempt.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306038\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307104\n", "files": ["browser/base/content/browser-sets.inc.xhtml", "browser/components/sidebar/tests/browser/browser_opentabs_sidebar.js", "browser/components/tests/marionette/test_no_errors_clean_profile.py", "browser/locales/en-US/browser/browserSets.ftl"], "git_node": "9cb5198cd5f23608911982469b804a96387ec305", "git_parents": ["2b7fb7b54d6097d338a4632fd71efce8e4376517"], "node": "4ab4af440b01108fc62ce6f51dbe89680f804d72", "parents": ["f0b65e9f7f71097ea564bfdd62f6cc55ee06d20e"], "tags": []}], "date": 1781780502, "git_changesets": ["9cb5198cd5f23608911982469b804a96387ec305"], "user": "pchevrel@mozilla.com"}, "26921": {"changesets": [{"author": "az \u003cazebrowski@mozilla.com\u003e", "branch": "default", "desc": "Bug 2045742 -  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305387\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307108\n", "files": ["dom/media/mediasource/ContainerParser.cpp"], "git_node": "d41dacc8a10541bbb17597a9599b77b5d45a9bd9", "git_parents": ["9cb5198cd5f23608911982469b804a96387ec305"], "node": "77964eaf38ad874c6e7efce76be326017ed78100", "parents": ["4ab4af440b01108fc62ce6f51dbe89680f804d72"], "tags": []}], "date": 1781780560, "git_changesets": ["d41dacc8a10541bbb17597a9599b77b5d45a9bd9"], "user": "pchevrel@mozilla.com"}, "26922": {"changesets": [{"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 2045185.  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305786\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307123\n", "files": ["gfx/2d/DrawTargetSkia.cpp"], "git_node": "bbe85c1a2799b58588f700ed3b6218d7999cf16a", "git_parents": ["d41dacc8a10541bbb17597a9599b77b5d45a9bd9"], "node": "f4bd48cf2c943d551efb3f68688a1a683c2e3fef", "parents": ["77964eaf38ad874c6e7efce76be326017ed78100"], "tags": []}], "date": 1781780908, "git_changesets": ["bbe85c1a2799b58588f700ed3b6218d7999cf16a"], "user": "pchevrel@mozilla.com"}, "26923": {"changesets": [{"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 2045625.  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305785\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307124\n", "files": ["gfx/wr/swgl/src/rasterize.h"], "git_node": "d6abf4828bf79fdd854574f1d4be1f141c253b01", "git_parents": ["bbe85c1a2799b58588f700ed3b6218d7999cf16a"], "node": "aa75b87e4f17beb509099747034cd8c94f994fd9", "parents": ["f4bd48cf2c943d551efb3f68688a1a683c2e3fef"], "tags": []}], "date": 1781780952, "git_changesets": ["d6abf4828bf79fdd854574f1d4be1f141c253b01"], "user": "pchevrel@mozilla.com"}, "26924": {"changesets": [{"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 2045405 - Improve the error handling in `PresShell::CompleteMove`  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305544\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307162\n", "files": ["layout/base/PresShell.cpp"], "git_node": "665d89ec31283015e4e6702cd9eb6d850ef85b98", "git_parents": ["d6abf4828bf79fdd854574f1d4be1f141c253b01"], "node": "98df4f11e6f3be4fc132f1ada3ecb4430039a1e2", "parents": ["aa75b87e4f17beb509099747034cd8c94f994fd9"], "tags": []}], "date": 1781781009, "git_changesets": ["665d89ec31283015e4e6702cd9eb6d850ef85b98"], "user": "pchevrel@mozilla.com"}, "26925": {"changesets": [{"author": "Eden Chuang \u003cechuang@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041864 - Restrict privileged worker scripts to chrome script schemes  a=pascalc\n\nSystem-principal worker scripts were validated only by the broad\nURI_IS_UI_RESOURCE protocol flag. That flag is also carried by image/UI\ndata protocols (page-icon:, moz-icon:, moz-page-thumb:,\nmoz-newtab-wallpaper:, moz-newtab-remote-renderer:), which let a\nSystemPrincipal worker load its main script from one of them - e.g. from\nattacker-controlled page-icon: favicon bytes.\n\nRestrict privileged worker scripts to an explicit allowlist of the\nscript-bearing chrome schemes (resource, chrome, moz-src) via the new\nIsValidPrivilegedWorkerScriptURI helper. This allowlist is exactly the\nscript-serving subset of the schemes that previously passed the\nURI_IS_UI_RESOURCE check, so legitimate resource:// workers and\nchrome:/resource: worker debugger scripts are unaffected. blob: and\ndata: worker loading is also unchanged, since those paths are not gated\nby this system-principal check.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305995\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307203\n", "files": ["dom/workers/ScriptLoader.cpp", "dom/workers/WorkerLoadInfo.cpp", "dom/workers/test/browser.toml", "dom/workers/test/browser_system_worker_page_icon_rejected.js"], "git_node": "f54411de98d07296173535eac2eab59b7833081e", "git_parents": ["665d89ec31283015e4e6702cd9eb6d850ef85b98"], "node": "d4a778f0f837b1e2f1746b5c15264dc5ff0fa097", "parents": ["98df4f11e6f3be4fc132f1ada3ecb4430039a1e2"], "tags": []}], "date": 1781781186, "git_changesets": ["f54411de98d07296173535eac2eab59b7833081e"], "user": "pchevrel@mozilla.com"}, "26926": {"changesets": [{"author": "Eden Chuang \u003cechuang@mozilla.com\u003e", "branch": "default", "desc": "Bug 2005113 - Bind FetchBodyBase::mReadableStream to the body stream and rebind it on clone(). .  a=pascalc DONTBUILD\n\nCreate the body ReadableStream from the underlying body input stream directly.\nWhen clone() is called before the stream has been read and the underlying body\nis not cloneable, clone() replaces the original input stream; repoint the\nexisting unread native ReadableStream at the replacement so the original stream\nis not read from two places. This keeps native bodies native (cancellation of\nan unread stream still tears down the channel, and the consume path keeps\nreading the body input stream directly) without teeing native byte streams.\n\nThis no longer clones the body when creating the ReadableStream, so it does not\nbuffer the whole body; restore the huge-fetch crashtest expectations that were\ndisabled to avoid OOMing the 32-bit process.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D280568\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307205\n", "files": ["dom/fetch/Fetch.cpp", "dom/fetch/Fetch.h", "dom/fetch/Request.cpp", "dom/fetch/Response.cpp", "dom/streams/ReadableStream.h", "dom/streams/UnderlyingSourceCallbackHelpers.h"], "git_node": "0d96790924bb983272a7b532ee7109f3e5857bde", "git_parents": ["f54411de98d07296173535eac2eab59b7833081e"], "node": "0c2413066579e1808127671622c425d6e9eead4e", "parents": ["d4a778f0f837b1e2f1746b5c15264dc5ff0fa097"], "tags": []}], "date": 1781781576, "git_changesets": ["0d96790924bb983272a7b532ee7109f3e5857bde"], "user": "pchevrel@mozilla.com"}, "26927": {"changesets": [{"author": "t-p-white \u003ctowhite@mozilla.com\u003e", "branch": "default", "desc": "Bug 2014771 - Part 1: Delete legacy onboarding cards.  a=pascalc\n\n* Remove legacy onboarding cards and all references in code\n  * Remove the now-redundant onboarding theme options\n  * Remove redundant onboarding strings\n  * Update unit and UI tests\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306716\n\n(cherry picked from commit 12e4569dd0d12209ec1b8aba56244ef5f54e4a37)\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307224\n", "files": ["mobile/android/fenix/app/metrics.yaml", "mobile/android/fenix/app/onboarding.fml.yaml", "mobile/android/fenix/app/src/androidTest/java/org/mozilla/fenix/onboarding/view/OnboardingMapperTest.kt", "mobile/android/fenix/app/src/androidTest/java/org/mozilla/fenix/ui/robots/HomeScreenRobot.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/OnboardingFragment.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/OnboardingTelemetryRecorder.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/WidgetPinnedReceiver.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/redesign/view/OnboardingScreenRedesign.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/store/OnboardingPreferencesMiddleware.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/store/OnboardingPreferencesRepository.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/store/OnboardingStore.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/view/MarketingDataOnboardingPage.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/view/OnboardingMapper.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/view/OnboardingPage.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/view/OnboardingPageState.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/view/OnboardingPageUiData.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/view/OnboardingScreen.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/view/TermsOfServiceOnboardingPage.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/view/ThemeOnboardingPage.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/view/ToolbarOnboardingPage.kt", "mobile/android/fenix/app/src/main/res/drawable/ic_pick_a_theme.xml", "mobile/android/fenix/app/src/main/res/drawable/ic_pick_a_theme_dark.xml", "mobile/android/fenix/app/src/main/res/drawable/ic_pick_a_theme_light.xml", "mobile/android/fenix/app/src/main/res/drawable/ic_pick_a_theme_system_auto.xml", "mobile/android/fenix/app/src/main/res/raw/keep.xml", "mobile/android/fenix/app/src/main/res/values/strings.xml", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/onboarding/DefaultBrowserPromptManagerTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/onboarding/MarketingPageRemovalSupportTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/onboarding/store/DefaultOnboardingPreferencesRepositoryTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/onboarding/store/OnboardingPreferencesMiddlewareTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/onboarding/store/OnboardingStoreTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/onboarding/view/OnboardingMapperTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/onboarding/view/OnboardingPageUiDataTest.kt"], "git_node": "299097efe2694977acfc5491b5920dab33486035", "git_parents": ["0d96790924bb983272a7b532ee7109f3e5857bde"], "node": "d26b5af4b3814719c75567ed11c5707c6a87778c", "parents": ["0c2413066579e1808127671622c425d6e9eead4e"], "tags": []}, {"author": "t-p-white \u003ctowhite@mozilla.com\u003e", "branch": "default", "desc": "Bug 2014771 - Part 2: Remove the onboarding redesign flag and set as default flow.  a=pascalc\n\n* Renamed the redesigned cards to remove the \"Redesign\" suffix\n* Removed nimbus flag and preference, and any gating conditions\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306717\n\n(cherry picked from commit 073f75ddf022e34652a8017e45f92da96c48fd7a)\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307225\n", "files": ["mobile/android/fenix/app/onboarding.fml.yaml", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/OnboardingFragment.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/WidgetPinnedReceiver.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/redesign/view/MarketingDataOnboardingPageRedesign.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/redesign/view/OnboardingPageRedesign.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/redesign/view/OnboardingScreenRedesign.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/redesign/view/TermsOfServiceOnboardingPageRedesign.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/redesign/view/ToolbarOnboardingPageRedesign.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/view/Marketing