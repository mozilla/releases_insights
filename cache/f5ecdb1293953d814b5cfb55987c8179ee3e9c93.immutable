roid/fenix/app/src/main/res/values-fur/strings.xml", "mobile/android/fenix/app/src/main/res/values-hu/strings.xml", "mobile/android/fenix/app/src/main/res/values-ro/strings.xml"], "git_node": "c836c8d5ff38833e9d995cdec9b21a03de94d979", "git_parents": ["19e1463adb54259797c85f79214abb8bfd9bad3f"], "node": "d672bb23a775000b4ea5ef7fdb621788f50b22f8", "parents": ["542016101ad5efabbcb8111b2e990d77ad9abd1e"], "tags": []}], "date": 1781662514, "git_changesets": ["c836c8d5ff38833e9d995cdec9b21a03de94d979"], "user": "ffxbld@lando.moz.tools"}, "26894": {"changesets": [{"author": "Jonathan Almeida \u003cjonalmeida942@gmail.com\u003e", "branch": "default", "desc": "Bug 2047688 - Updated initial allowed regions for IPProtection  a=pascalc DONTBUILD\n\nThis is the initial pre-loaded list that will be updated over time.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306895\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307189\n", "files": ["mobile/android/fenix/app/nimbus.fml.yaml"], "git_node": "b44cfa9853801583c6fa1125123794fdc8b4707a", "git_parents": ["c836c8d5ff38833e9d995cdec9b21a03de94d979"], "node": "6e096429164b10a19535cc0180e70adadbe96dda", "parents": ["d672bb23a775000b4ea5ef7fdb621788f50b22f8"], "tags": []}], "date": 1781681620, "git_changesets": ["b44cfa9853801583c6fa1125123794fdc8b4707a"], "user": "pchevrel@mozilla.com"}, "26895": {"changesets": [{"author": "Karl Tomlinson \u003ckarlt+@karlt.net\u003e", "branch": "default", "desc": "Bug 2046555 Await async init tasks in AudioSinkWrapper::Shutdown()  a=pascalc DONTBUILD\n\nThis ensures that any pending tasks have the MediaDecoderStateMachine\nTaskQueue available to settle dependent promises.\n\nThe async init task Then() callback will determine that any audio sink is not\nneeded.\n\nThis is simpler than keeping track of all unsettled Promises and disconnecting.\nStream init is already often synchronous, where wanted.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306