dler.cpp", "testing/web-platform/meta/html/semantics/scripting-1/the-script-element/json-module/json-module-service-worker-test.https.html.ini", "testing/web-platform/tests/service-workers/service-worker/resources/import-scripts-mime-types-worker.js", "testing/web-platform/tests/service-workers/service-worker/resources/registration-tests-mime-types.js"], "git_node": "a7f65007adae748eaef196f12199432ba695cce2", "git_parents": ["6d976c1c276f5a33287665699cc8dc531f939cb5"], "node": "427d93afc62abfccf261403cf2ff9455741c3ef0", "parents": ["80b331facc17c086e0db4249cf767d5f5948f106"], "tags": []}], "date": 1783974282, "git_changesets": ["a7f65007adae748eaef196f12199432ba695cce2"], "user": "rvandermeulen@mozilla.com"}, "27459": {"changesets": [{"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 2053680 - Make denormal handling in Range::setDouble more conservative to handle float32 values correctly.  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D311277\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311863\n", "files": ["js/src/jit-test/tests/ion/bug2053680.js", "js/src/jit/RangeAnalysis.cpp"], "git_node": "df5c7a6b6b8c417e3bc9600612ff832fe6311dc3", "git_parents": ["a7f65007adae748eaef196f12199432ba695cce2"], "node": "95634917d6c8c9262de454012f7d8e0bc84b2d6d", "parents": ["427d93afc62abfccf261403cf2ff9455741c3ef0"], "tags": []}], "date": 1783974426, "git_changesets": ["df5c7a6b6b8c417e3bc9600612ff832fe6311dc3"], "user": "rvandermeulen@mozilla.com"}, "27460": {"changesets": [{"author": "Eden Chuang \u003cechuang@mozilla.com\u003e", "branch": "default", "desc": "Bug 2039452 - Validate file:// URIs in PExternalHelperApp against the sending process's remote type.  a=RyanVM\n\nThe parent derived the native helper-launch decision from a\ncontent-process supplied aWasFileChannel flag and URI rather than\nbinding it to the sending process's capabilities.\n\nStop sending aWasFileChannel over IPC and derive it on the parent from\nthe actual URI, and reject a file:// URI in PExternalHelperApp from a\nprocess that is not allowed to load local files (mirrors the file://\npolicy in ValidatePrincipalCouldPotentiallyBeLoadedBy).\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309577\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311928\n", "files": ["dom/ipc/ContentParent.cpp", "dom/ipc/ContentParent.h", "dom/ipc/PContent.ipdl", "uriloader/exthandler/ExternalHelperAppParent.cpp", "uriloader/exthandler/ExternalHelperAppParent.h", "uriloader/exthandler/nsExternalHelperAppService.cpp"], "git_node": "0bbc19df6935df5f5ed4472d07f8899cac2c4ce8", "git_parents": ["df5c7a6b6b8c417e3bc9600612ff832fe6311dc3"], "node": "84011579171a8fb5723f250bff7450142d555f3e", "parents": ["95634917d6c8c9262de454012f7d8e0bc84b2d6d"], "tags": []}], "date": 1783980342, "git_changesets": ["0bbc19df6935df5f5ed4472d07f8899cac2c4ce8"], "user": "rvandermeulen@mozilla.com"}, "27461": {"changesets": [{"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 2053326 - Check size_t range in ParseVariationDataSubtable.  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D311039\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311525\n", "files": ["gfx/ots/src/variations.cc"], "git_node": "5131469286f5e0256eaf447db3f0126b68410d2f", "git_parents": ["0bbc19df6935df5f5ed4472d07f8899cac2c4ce8"], "node": "5e9a8a732d436f67988f3dcbb182400f71d9e484", "parents": ["84011579171a8fb5723f250bff7450142d555f3e"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 2053326 - Check offset computations in ItemVariationData::Validate.  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D311040\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311526\n", "files": ["gfx/thebes/COLRFonts.cpp"], "git_node": "c2d468d4f34a01f29c251af3f6abf3a3c87019aa", "git_parents": ["5131469286f5e0256eaf447db3f0126b68410d2f"], "node": "306524d7f38744ccb9454b4310b38a1f6ac5c9e0", "parents": ["5e9a8a732d436f67988f3dcbb182400f71d9e484"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 2053326 - Also range-check the deltaData during ApplyVariation().  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D311070\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311527\n", "files": ["gfx/thebes/COLRFonts.cpp"], "git_node": "c8ec35faaac3af867b4b346d67cf8d107946abe6", "git_parents": ["c2d468d4f34a01f29c251af3f6abf3a3c87019aa"], "node": "967fc67b60b2685b4a55063fd29454a0b4da8078", "parents": ["306524d7f38744ccb9454b4310b38a1f6ac5c9e0"], "tags": []}], "date": 1783980395, "git_changesets": ["5131469286f5e0256eaf447db3f0126b68410d2f", "c2d468d4f34a01f29c251af3f6abf3a3c87019aa", "c8ec35faaac3af867b4b346d67cf8d107946abe6"], "user": "rvandermeulen@mozilla.com"}, "27462": {"changesets": [{"author": "Andreas Farre \u003cfarre@mozilla.com\u003e", "branch": "default", "desc": "Bug 2045468 - Make sure to check the correct browsing context.  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305611\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311831\n", "files": ["docshell/base/BrowsingContext.cpp", "docshell/base/BrowsingContext.h", "dom/base/nsContentUtils.h"], "git_node": "8e632997b2501d28f99996c5e8ff88eabddc3c78", "git_parents": ["c8ec35faaac3af867b4b346d67cf8d107946abe6"], "node": "e5860272f9f06329b25693c1e0bc3d4eafe2ec9d", "parents": ["967fc67b60b2685b4a55063fd29454a0b4da8078"], "tags": []}], "date": 1783980441, "git_changesets": ["8e632997b2501d28f99996c5e8ff88eabddc3c78"], "user": "rvandermeulen@mozilla.com"}, "27463": {"changesets": [{"author": "Matthew Gregan \u003ckinetik@flim.org\u003e", "branch": "default", "desc": "Bug 2052753 - Backport upstream cubeb fix for the ALSA drain contract.  a=RyanVM\n\nUpstream cubeb commit a665efba31740bd477cf2001a5cb289a63e85336 (\"alsa: fix\ndrain contract\"), carried as a local patch rather than bumping the vendored\nlibcubeb revision.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D310551\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311953\n", "files": ["media/libcubeb/alsa-drain-contract.patch", "media/libcubeb/moz.yaml", "media/libcubeb/src/cubeb_alsa.c", "media/libcubeb/test/test_callback_ret.cpp"], "git_node": "666183e683042771ac68b0b7665641690a613439", "git_parents": ["8e632997b2501d28f99996c5e8ff88eabddc3c78"], "node": "af72d33919ec572acf9a1d7f8036181aad8c146f", "parents": ["e5860272f9f06329b25693c1e0bc3d4eafe2ec9d"], "tags": []}, {"author": "Matthew Gregan \u003ckinetik@flim.org\u003e", "branch": "default", "desc": "Bug 2052753 - Update cubeb-pulse-rs to 5eb4d5b to reject start() on a draining stream.  a=RyanVM\n\nBackport of upstream cubeb-pulse-rs commit\n88194f91c8778fa608a19af7b91306094525595d, carried on the\nmozilla/cubeb-pulse-rs beta branch.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D310552\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311954\n", "files": [".cargo/config.toml.in", "Cargo.lock", "third_party/rust/cubeb-pulse/.cargo-checksum.json", "third_party/rust/cubeb-pulse/src/backend/stream.rs", "toolkit/library/rust/shared/Cargo.toml"], "git_node": "f72e3d576b4e8479c163f9568b6ffe4b1b2d1fe0", "git_parents": ["666183e683042771ac68b0b7665641690a613439"], "node": "582de8254528ec77273892392ac37ecb837ae22e", "parents": ["af72d33919ec572acf9a1d7f8036181aad8c146f"], "tags": []}], "date": 1783980492, "git_changesets": ["666183e683042771ac68b0b7665641690a613439", "f72e3d576b4e8479c163f9568b6ffe4b1b2d1fe0"], "user": "rvandermeulen@mozilla.com"}, "27464": {"changesets": [{"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1800120 - Part 1: Remove CreateWindowInDifferentProcess,  a=RyanVM\n\nThis method is now dead code, as we have shipped fission.autostart on\nall platforms since bug 1998306, and CreateWindowInDifferentProcess is\ndisabled when Fission is disabled.\n\nThis is intended to be a fairly straightforward change to remove the\nunnecessary IPC call, and does not clean up the implementation to remove\nthe now-dead codepaths from CommonCreateWindow. That is done in part 2.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D297450\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311332\n", "files": ["dom/ipc/ContentChild.cpp", "dom/ipc/ContentParent.cpp", "dom/ipc/ContentParent.h", "dom/ipc/PContent.ipdl"], "git_node": "dbe2abfcf8882667b50daa8614f97f8a7df18465", "git_parents": ["f72e3d576b4e8479c163f9568b6ffe4b1b2d1fe0"], "node": "506b7498595053b7517b28772e6f1614934a823c", "parents": ["582de8254528ec77273892392ac37ecb837ae22e"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1800120 - Part 2: Remove now-dead parameters in CommonCreateWindow,  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D297451\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311333\n", "files": ["dom/ipc/ContentChild.cpp", "dom/ipc/ContentParent.cpp", "dom/ipc/ContentParent.h"], "git_node": "19a90a329075d262e6e3e6d014dabfc11f4ba906", "git_parents": ["dbe2abfcf8882667b50daa8614f97f8a7df18465"], "node": "4683cac88e0e287ac8078c071bbfa5a225f59201", "parents": ["506b7498595053b7517b28772e6f1614934a823c"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1800120 - Part 3: Update test expectations for window-open-popup-behavior.html,  a=RyanVM\n\nThis patch updates the expectations for window-open-popup-behavior.html\non Android to reflect the fact that many of these tests appear to have\nonly been passing due to Android using CreateWindowInDifferentProcess.\n\nNow that codepath has been removed, the test is now failing more\nconsistently across platforms.\n\nI also removed the pass cases for linux-nofis, though I don't think we\nrun that configuration in treeherder anymore off the top of my head.\n\nIt appears that we fail this test due to a fundamental mismatch between\nour implementation and the WPT. Specifically it appears the test expects\nthat specifying noopener/noreferrer overrides all other window open\noptions, and always forces the document to open in a tab, not a popup.\nWe always respect the specified options even if noopener is set.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308619\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311334\n", "files": ["testing/web-platform/meta/html/browsers/the-window-object/window-open-popup-behavior.html.ini"], "git_node": "e34bae59287982f92c0b499375d6e2e16470f558", "git_parents": ["19a90a329075d262e6e3e6d014dabfc11f4ba906"], "node": "de3605340eb88754d348015b7ad9000c9283f070", "parents": ["4683cac88e0e287ac8078c071bbfa5a225f59201"], "tags": []}], "date": 1783980627, "git_changesets": ["dbe2abfcf8882667b50daa8614f97f8a7df18465", "19a90a329075d262e6e3e6d014dabfc11f4ba906", "e34bae59287982f92c0b499375d6e2e16470f558"], "user": "rvandermeulen@mozilla.com"}, "27465": {"changesets": [{"author": "owlishDeveloper \u003cbugzeeeeee@gmail.com\u003e", "branch": "default", "desc": "Bug 2049804 - GeckoView messaging improvements r=nika,geckoview-reviewers a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309219\n", "files": ["mobile/shared/actors/GeckoViewPermissionParent.sys.mjs", "mobile/shared/actors/GeckoViewPermissionProcessChild.sys.mjs"], "git_node": "f82e0c6d7ed01750c7187e7e86ceae7cc874d0a6", "git_parents": ["e34bae59287982f92c0b499375d6e2e16470f558"], "node": "fce95357f86d9374d6dd05933620b4bf651254c4", "parents": ["de3605340eb88754d348015b7ad9000c9283f070"], "tags": []}], "date": 1783994906, "git_changesets": ["f82e0c6d7ed01750c7187e7e86ceae7cc874d0a6"], "user": "rvandermeulen@mozilla.com"}, "27466": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Import translations from main\n", "files": ["mobile/android/android-components/components/browser/errorpages/src/main/res/values-ca/strings.xml", "mobile/android/android-components/components/compose/awesomebar/src/main/res/values-ca/strings.xml", "mobile/android/android-components/components/compose/base/src/main/res/values-ca/strings.xml", "mobile/android/android-components/components/compose/browser-toolbar/src/main/res/values-ca/strings.xml", "mobile/android/android-components/components/feature/addons/src/main/res/values-ca/strings.xml", "mobile/android/android-components/components/feature/app-links/src/main/res/values-ca/strings.xml", "mobile/android/android-components/components/feature/importer/src/main/res/values-ca/strings.xml", "mobile/android/android-components/components/feature/ipprotection/src/main/res/values-ca/strings.xml", "mobile/android/android-components/components/feature/ipprotection/src/main/res/values-da/strings.xml", "mobile/android/android-components/components/feature/ipprotection/src/main/res/values-pl/strings.xml", "mobile/android/android-components/components/feature/ipprotection/src/main/res/values-sl/strings.xml", "mobile/android/android-components/components/feature/media/src/main/res/values-ca/strings.xml", "mobile/android/android-components/components/feature/media/src/main/res/values-da/strings.xml", "mobile/android/android-components/components/feature/media/src/main/res/values-es-rES/strings.xml", "mobile/android/android-components/components/feature/media/src/main/res/values-pl/strings.xml", "mobile/android/android-components/components/feature/password-importer/src/main/res/values-ca/strings.xml", "mobile/android/android-components/components/feature/prompts/src/main/res/values-bqi/strings.xml", "mobile/android/android-components/components/feature/prompts/src/main/res/values-ca/strings.xml", "mobile/android/android-components/components/feature/prompts/src/main/res/values-da/strings.xml", "mobile/android/android-components/components/feature/prompts/src/main/res/values-es-rES/strings.xml", "mobile/android/android-components/components/feature/prompts/src/main/res/values-ka/strings.xml", "mobile/android/android-components/components/feature/prompts/src/main/res/values-pl/strings.xml", "mobile/android/android-components/components/feature/protection-dashboard/src/main/res/values-ca/strings.xml", "mobile/android/android-components/components/feature/protection-dashboard/src/main/res/values-da/strings.xml", "mobile/android/android-components/components/feature/protection-dashboard/src/main/res/values-pl/strings.xml", "mobile/android/android-components/components/feature/protection-dashboard/src/main/res/values-sl/strings.xml", "mobile/android/android-components/components/feature/summarize/src/main/res/values-ca/strings.xml", "mobile/android/android-components/components/feature/summarize/src/main/res/values-da/strings.xml", "mobile/android/android-components/components/feature/summarize/src/main/res/values-es-rES/strings.xml", "mobile/android/android-components/components/feature/summarize/src/main/res/values-pl/strings.xml", "mobile/android/android-components/components/feature/summarize/src/main/res/values-sl/strings.xml", "mobile/android/fenix/app/longfox/src/main/res/values-ca/strings.xml", "mobile/android/fenix/app/longfox/src/main/res/values-sl/strings.xml", "mobile/android/fenix/app/src/main/res/values-ar/strings.xml", "mobile/android/fenix/app/src/main/res/values-bqi/strings.xml", "mobile/android/fenix/app/src/main/res/values-ca/strings.xml", "mobile/android/fenix/app/src/main/res/values-cs/strings.xml", "mobile/android/fenix/app/src/main/res/values-da/strings.xml", "mobile/android/fenix/app/src/main/res/values-es-rES/strings.xml", "mobile/android/fenix/app/src/main/res/values-gn/strings.xml", "mobile/android/fenix/app/src/main/res/values-ka/strings.xml", "mobile/android/fenix/app/src/main/res/values-kk/strings.xml", "mobile/android/fenix/app/src/main/res/values-nn-rNO/strings.xml", "mobile/android/fenix/app/src/main/res/values-pl/strings.xml", "mobile/android/fenix/app/src/main/res/values-sl/strings.xml", "mobile/android/fenix/app/src/main/res/values-sv-rSE/strings.xml", "mobile/android/fenix/app/src/main/res/values-vi/strings.xml"], "git_node": "9e1f5a3caa409952a96c9612ceb75ffb07aa3723", "git_parents": ["f82e0c6d7ed01750c7187e7e86ceae7cc874d0a6"], "node": "964f796a7b390fcca3059b1a6cbf899cf97e8895", "parents": ["fce95357f86d9374d6dd05933620b4bf651254c4"], "tags": []}], "date": 1783995332, "git_changesets": ["9e1f5a3caa409952a96c9612ceb75ffb07aa3723"], "user": "ffxbld@lando.moz.tools"}, "27467": {"changesets": [{"author": "David Parks \u003cdaparks@mozilla.com\u003e", "branch": "default", "desc": "Bug 2052565: Sanity check WindowContext in PContent::GetClipboardDataInternal  a=RyanVM\n\nAlign with PContent::GetClipboardSnapshot*\n\nOriginal Revision: https://phabricator.services.mozilla.com/D310697\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311966\n", "files": ["dom/ipc/ContentParent.cpp"], "git_node": "4c336f1190214c79c1271ed3b381786103a78f4f", "git_parents": ["9e1f5a3caa409952a96c9612ceb75ffb07aa3723"], "node": "7ac74a2276821f9114b83e4f0afc863d3c986fbb", "parents": ["964f796a7b390fcca3059b1a6cbf899cf97e8895"], "tags": []}], "date": 1783995559, "git_changesets": ["4c336f1190214c79c1271ed3b381786103a78f4f"], "user": "rvandermeulen@mozilla.com"}, "27468": {"changesets": [{"author": "Beth Rennie \u003cbeth@brennie.ca\u003e", "branch": "default", "desc": "Bug 2053938 - Do not override changed default branch pref values when unenrolling from prefFlips  ,mconley  a=pascalc\n\nThe prefFlips feature was incorrectly determining the original value of\nprefs being set on the user branch. When a pref does not have a user\nbranch value, asking for it via `PrefUtils.getPref()` or\n`Services.prefs.get{Int,String,Bool}Pref()` will instead return the\ndefault branch if it exists. In that case, we will record the current\ndefault branch value as the pref's original user branch value.\n\nWhen unenrolling and restoring original values, if we set the user\nbranch value of a pref to be the same as the default branch value then\nit will no longer have a user branch value. However, if the default\nvalue of pref changes between enrollment and unenrollment, then we are\nrestoring the original default branch value to the user branch, which\nwill not match the current default branch value and will override the\nchanged default branch value.\n\nThe `setPref` annotation handled this behaviour correctly: it explicitly\nchecks when computing original values if the pref is being set on the\nuser branch and there currently is no user branch value. This behaviour\nhas been refactored into `PrefUtils.getPrefStrict`, which is now used by\nboth `setPref`-annotated variables and the `prefFlips` feature.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D311628\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311822\n", "files": ["toolkit/components/nimbus/lib/ExperimentManager.sys.mjs", "toolkit/components/nimbus/lib/PrefFlipsFeature.sys.mjs", "toolkit/components/nimbus/test/unit/test_ExperimentManager_prefs.js", "toolkit/components/nimbus/test/unit/test_prefFlips.js", "toolkit/modules/PrefUtils.sys.mjs"], "git_node": "5c6998c030485b2dba21502cffc1e0b1427472a1", "git_parents": ["4c336f1190214c79c1271ed3b381786103a78f4f"], "node": "3de7e911822a77c2e232cb008a6586b6aad0d86f", "parents": ["7ac74a2276821f9114b83e4f0afc863d3c986fbb"], "tags": []}], "date": 1784014137, "git_changesets": ["5c6998c030485b2dba21502cffc1e0b1427472a1"], "user": "pchevrel@mozilla.com"}, "27469": {"changesets": [{"author": "Ben Hearsum \u003cben@mozilla.com\u003e", "branch": "default", "desc": "Bug 2053231: Update mozilla-taskgraph to v4.4.0  a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311885\n", "files": ["taskcluster/requirements.in", "taskcluster/requirements.txt"], "git_node": "ab34ee6369605e174632af55180071df7195274f", "git_parents": ["5c6998c030485b2dba21502cffc1e0b1427472a1"], "node": "908368a5aa24435c2602f471c3cdba9e7ebcbfc2", "parents": ["3de7e911822a77c2e232cb008a6586b6aad0d86f"], "tags": []}, {"author": "Ben Hearsum \u003cben@mozilla.com\u003e", "branch": "default", "desc": "Bug 2047586: support setting revisions in merge automation actions  a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311886\n", "files": ["taskcluster/gecko_taskgraph/actions/merge_automation.py", "taskcluster/gecko_taskgraph/transforms/merge_automation.py"], "git_node": "f3c0de40cf6e602785c1f14da710932ab2edc134", "git_parents": ["ab34ee6369605e174632af55180071df7195274f"], "node": "376101b2c566241452b78b46e2f2c05b7b6011d8", "parents": ["908368a5aa24435c2602f471c3cdba9e7ebcbfc2"], "tags": []}], "date": 1784014259, "git_changesets": ["ab34ee6369605e174632af55180071df7195274f", "f3c0de40cf6e602785c1f14da710932ab2edc134"], "user": "pchevrel@mozilla.com"}, "27470": {"changesets": [{"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 2030362: CachedTableAccessible: Never descend into nested tables.  a=pascalc DONTBUILD\n\nThis could only happen due to incorrect authoring where a table was nested inside another table without an intervening cell.\nEven so, we should never treat cells in a nested table as part of an ancestor table.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D311450\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311991\n", "files": ["accessible/base/CachedTableAccessible.cpp", "accessible/ipc/DocAccessibleParent.cpp", "accessible/tests/browser/e10s/browser_caching_table.js"], "git_node": "be69c67728574dfd9f3c373b234aacdbc8c3fa26", "git_parents": ["f3c0de40cf6e602785c1f14da710932ab2edc134"], "node": "87c7900ab2f7e9135f5459ad7aa614fe932bd3c2", "parents": ["376101b2c566241452b78b46e2f2c05b7b6011d8"], "tags": []}], "date": 1784014390, "git_changesets": ["be69c67728574dfd9f3c373b234aacdbc8c3fa26"], "user": "pchevrel@mozilla.com"}, "27471": {"changesets": [{"author": "Tymur Boiko \u003ctboiko@nvidia.com\u003e", "branch": "default", "desc": "Bug 2047329 - DOM Media - Share VkDevice across Vulkan video decoders.  a=pascalc\n\nEach decoder was creating its own VkDevice via av_hwdevice_ctx_create,\ncausing already-playing videos (including inline ads) to stall, delay or freeze\nplayback in all tabs and crash the RDD process when two decoders initialized\nsimultaneously.\n\nIntroduce VulkanDeviceHolder, a process-wide singleton (mirroring\nVADisplayHolder for VA-API) that shares a single AVHWDeviceContext\n(VkDevice) across all decoders. The first decoder pays vkCreateDevice;\nsubsequent decoders get av_buffer_ref() on the same context.\n\nReplace vkDeviceWaitIdle in Cleanup() with vkWaitForFences on the\nper-decoder copy fences, so tearing down one decoder does not stall the\nshared device and block other running decoders.\n\nAdd device name validation in GetOrCreate() so a decoder on a different\nGPU does not silently reuse the wrong VkDevice. Release the sDeviceHolder\nlock before av_hwdevice_ctx_create to avoid holding it during the\npotentially slow vkCreateDevice, with race-safe re-acquisition afterward.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306576\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311999\n", "files": ["dom/media/platforms/ffmpeg/FFmpegVideoDecoder.cpp", "dom/media/platforms/ffmpeg/FFmpegVideoDecoder.h", "dom/media/platforms/ffmpeg/FFmpegVulkanVideoDecoder.cpp", "dom/media/platforms/ffmpeg/FFmpegVulkanVideoDecoder.h", "dom/media/platforms/ffmpeg/VulkanDeviceHolder.cpp", "dom/media/platforms/ffmpeg/VulkanDeviceHolder.h", "dom/media/platforms/ffmpeg/moz.build"], "git_node": "82a22a3dee754a39782ea75a75126bc1c6e451d4", "git_parents": ["be69c67728574dfd9f3c373b234aacdbc8c3fa26"], "node": "dc29772e70d954883107d9151b5f3a2fd12caaf0", "parents": ["87c7900ab2f7e9135f5459ad7aa614fe932bd3c2"], "tags": []}], "date": 1784014636, "git_changesets": ["82a22a3dee754a39782ea75a75126bc1c6e451d4"], "user": "pchevrel@mozilla.com"}, "27472": {"changesets": [{"author": "Conor \u003cconorboyle07@protonmail.com\u003e", "branch": "default", "desc": "Bug 1988166 - Only wrap sys/single_threaded.h when it actually exists.  a=pascalc\n\nsys/single_threaded.h is glibc/FreeBSD-specific and does not\nexist on musl libc, breaking the build.\n\nFollow the same approach as bug 1952657 (execinfo.h): move the\nheader out of the unconditional system_headers list and gate it\non a check_header() probe.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308106\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311985\n", "files": ["config/system-headers.mozbuild", "toolkit/moz.configure"], "git_node": "0c7262c4b049d4a9bdf25f1f60bdfbeb848089b2", "git_parents": ["82a22a3dee754a39782ea75a75126bc1c6e451d4"], "node": "a476033d2b7150a2ec43b298d75983b34df512f2", "parents": ["dc29772e70d954883107d9151b5f3a2fd12caaf0"], "tags": []}], "date": 1784014760, "git_changesets": ["0c7262c4b049d4a9bdf25f1f60bdfbeb848089b2"], "user": "pchevrel@mozilla.com"}, "27473": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Bumping Firefox l10n changesets r=release a=l10n-bump\n\nach -\u003e 67bd811cad5a526f395d6a2c95566f2b4702143a\naf -\u003e 67bd811cad5a526f395d6a2c95566f2b4702143a\nan -\u003e 67bd811cad5a526f395d6a2c95566f2b4702143a\nar -\u003e 67bd811cad5a526f395d6a2c95566f2b4702143a\nast -\u003e 67bd811cad5a526f395d6a2c95566f2b4702143a\naz -\u003e 67bd811cad5a526f395d6a2c95566f2b4702143a\nbe -\u003e 67bd811cad5a526f395d6a2c95566f2b4702143a\nbg -\u003e 