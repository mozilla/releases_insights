23dc55a47b7ace", "parents": ["7c39d5a702f3145195fde15d4eaab6b079d0f5cd"], "tags": []}], "date": 1782633053, "git_changesets": ["c183d1a1086ab174d83443b07ddc6973f2682d4b"], "user": "pchevrel@mozilla.com"}, "27154": {"changesets": [{"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 2025369.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308172\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309239\n", "files": ["dom/canvas/DrawTargetWebgl.cpp"], "git_node": "044ca9aad3874e038a5b59eb4c3779c69d15c1c1", "git_parents": ["c183d1a1086ab174d83443b07ddc6973f2682d4b"], "node": "a0fd2c4bdcdd5b03bbd96a2483118dcd329c81bc", "parents": ["126ef43952718aa6ff7cbd10d023dc55a47b7ace"], "tags": []}], "date": 1782633091, "git_changesets": ["044ca9aad3874e038a5b59eb4c3779c69d15c1c1"], "user": "pchevrel@mozilla.com"}, "27155": {"changesets": [{"author": "Dana Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "Bug 2013800 - add certificate error overrides using information from the parent process  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306508\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308926\n", "files": ["dom/base/Document.cpp", "dom/ipc/ContentParent.cpp", "dom/ipc/ContentParent.h", "dom/ipc/PContent.ipdl", "dom/ipc/PWindowGlobal.ipdl", "dom/ipc/WindowGlobalParent.cpp", "dom/ipc/WindowGlobalParent.h"], "git_node": "bf1cada1a16a9453fb8877bd595e1267c0b6441c", "git_parents": ["044ca9aad3874e038a5b59eb4c3779c69d15c1c1"], "node": "6e1ec99e35a733559e8e3d3bf4a20580afd1d64b", "parents": ["a0fd2c4bdcdd5b03bbd96a2483118dcd329c81bc"], "tags": []}], "date": 1782633160, "git_changesets": ["bf1cada1a16a9453fb8877bd595e1267c0b6441c"], "user": "pchevrel@mozilla.com"}, "27156": {"changesets": [{"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1979688 - Use # private fields for tabbrowser's internal state instead of underscore prefixes.  a=pascalc\n\nConvert tabbrowser's truly-private internal fields from _-prefixed\npseudo-private properties to # private fields, and remove dead field\ndeclarations surfaced by the conversion.\n\nCross-window tab swapping accesses the progress-listener maps on another\nwindow's gBrowser, where # brand checks fail because each window has its\nown Tabbrowser class identity, so those sites are routed through\n_-prefixed accessor methods. Bug 2049770 tracks moving Tabbrowser to a\nshared .sys.mjs module, which would remove the need for those accessors.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308317\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309226\n", "files": ["browser/components/tabbrowser/content/tabbrowser.js"], "git_node": "f54950d4c18f3e86b585dafbb9b6437ce06aec34", "git_parents": ["bf1cada1a16a9453fb8877bd595e1267c0b6441c"], "node": "f2f917e417b10bf9e8deb4657e4864ae62ca0b28", "parents": ["6e1ec99e35a733559e8e3d3bf4a20580afd1d64b"], "tags": []}], "date": 1782633445, "git_changesets": ["f54950d4c18f3e86b585dafbb9b6437ce06aec34"], "user": "pchevrel@mozilla.com"}, "27157": {"changesets": [{"author": "Edgar Chen \u003cechen@mozilla.com\u003e", "branch": "default", "desc": "Bug 2046215 - Associate image elements with form only if the form and the intended parent are in the same tree;  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305733\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309106\n", "files": ["parser/html/nsHtml5TreeOperation.cpp", "testing/web-platform/tests/html/semantics/forms/form-control-infrastructure/form_owner_and_table_2.html"], "git_node": "39e41b40da84fb6eee0b291cb3efb7137b6891c0", "git_parents": ["f54950d4c18f3e86b585dafbb9b6437ce06aec34"], "node": "7c3f5e2590e0a1ff32df98d4dd2c472fc626c765", "parents": ["f2f917e417b10bf9e8deb4657e4864ae62ca0b28"], "tags": []}], "date": 1782633567, "git_changesets": ["39e41b40da