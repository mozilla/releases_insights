": ["85cf23d865ea2dcfe9078a5d63ecda58655e53ca"], "node": "5882bd768ad75bf25ed9c926f0d64e31a15dbc80", "parents": ["7cd65cb3d272e395c0c3b18e00d57e0f572b2d7f"], "tags": []}], "date": 1782107782, "git_changesets": ["d8142a6a88fe49c963d77e8adc4a030900a386ce"], "user": "pchevrel@mozilla.com"}, "26999": {"changesets": [{"author": "pollymce \u003cpmceldowney@mozilla.com\u003e", "branch": "default", "desc": "Bug 2048200: Expose longfox secret setting to all release types.  a=pascalc DONTBUILD\n\nThis means that if people are in the longfox experiment and hate it, they can turn it off.\nconversely, if you are longfox curious you could switch it on!\n\nPull request: https://github.com/mozilla-firefox/firefox/pull/297\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307565\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/settings/HomeSettingsFragment.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/settings/SecretSettingsFragment.kt"], "git_node": "39dead8cb0faa697bd463f444713ab5939d7f8ae", "git_parents": ["d8142a6a88fe49c963d77e8adc4a030900a386ce"], "node": "a0733dc42bd9d25d48ea37fe192d6e6f41fb1192", "parents": ["5882bd768ad75bf25ed9c926f0d64e31a15dbc80"], "tags": []}], "date": 1782111055, "git_changesets": ["39dead8cb0faa697bd463f444713ab5939d7f8ae"], "user": "pchevrel@mozilla.com"}, "27000": {"changesets": [{"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 2043469 - Ensure heuristic history provider matches on urls, not just hashes.  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306187\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307536\n", "files": ["browser/components/urlbar/UrlbarProviderHistoryUrlHeuristic.sys.mjs", "browser/components/urlbar/tests/unit/test_providerHistoryUrlHeuristic.js"], "git_node": "1817930c139a93ffa15a226e66097b9a83c0eff2", "git_parents": ["39dead8cb0faa697bd463f444713ab5939d7f8ae"], "node