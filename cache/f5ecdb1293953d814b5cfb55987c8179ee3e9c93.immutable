7ba168906132452cb2306820723a"], "tags": []}], "date": 1783674362, "git_changesets": ["0bf4badefc418eafe84dc25337120830a878e3a5", "468c182677af5eec36ee252f3b5a2092df74d3a0"], "user": "ffxbld@lando.moz.tools"}, "27388": {"changesets": [{"author": "Randell Jesup \u003crjesup@mozilla.com\u003e", "branch": "default", "desc": "Bug 2045773: Add usrsctp TSN gap check  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309815\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311393\n", "files": ["netwerk/sctp/src/netinet/sctp_indata.c"], "git_node": "a20db9da364519a54ec0bb3292ec50accfee9d7d", "git_parents": ["468c182677af5eec36ee252f3b5a2092df74d3a0"], "node": "4ae04968176a800d82735770c254890bca2fc64d", "parents": ["745df81d8676435b54d8bfaa018346b09b092dff"], "tags": []}], "date": 1783681600, "git_changesets": ["a20db9da364519a54ec0bb3292ec50accfee9d7d"], "user": "pchevrel@mozilla.com"}, "27389": {"changesets": [{"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 2049714 part 1 - Use __builtin_isnan in JS::CanonicalizeNaN to ensure the check is inlined.  a=pascalc\n\nThis avoids a much slower out-of-line call for `std::isnan` on Linux.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309383\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311348\n", "files": ["js/public/Value.h"], "git_node": "b6be0ea50011a962a4deee390175f9a081f103c6", "git_parents": ["a20db9da364519a54ec0bb3292ec50accfee9d7d"], "node": "c95c1260b54f4fda52cc80f2efce35e9f8aa6a7e", "parents": ["4ae04968176a800d82735770c254890bca2fc64d"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 2049714 part 2 - Always canonicalize NaNs for doubles stored in JS::Value.  a=pascalc\n\nClang is smart enough to optimize away the NaN check for `setNumber(uint32_t)` and\n`setNumber(uint64_t)`.\n\n`JS::CanonicalizedDoubleValue` now forwards to `JS::DoubleValue`. We should remove it,\nbut this can happen in a follow-up bug. Similarly, `JS_NumberValue` just calls\n`JS::NumberValue` for now.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309384\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311349\n", "files": ["js/public/Value.h", "js/src/jsapi-tests/moz.build", "js/src/jsapi-tests/testValueNaN.cpp", "js/src/jsapi.h"], "git_node": "bd4a4b3d12b79a7a62c9595c87a05ccc98dd07bd", "git_parents": ["b6be0ea50011a962a4deee390175f9a081f103c6"], "node": "365ada2dfea7a482fe9b769b4d07d6e87bdd650b", "parents": ["c95c1260b54f4fda52cc80f2efce35e9f8aa6a7e"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 2049714 part 3 - Remove redundant JS::CanonicalizeNaN calls.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309385\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311350\n", "files": ["js/src/builtin/DataViewObject.cpp", "js/src/vm/StructuredClone.cpp", "js/src/wasm/WasmDebug.cpp", "js/src/wasm/WasmDebugFrame.cpp"], "git_node": "4edea712adef94a9f247d010b0d3c6c57cab8e72", "git_parents": ["bd4a4b3d12b79a7a62c9595c87a05ccc98dd07bd"], "node": "359b69690afc03c0f1251363de5d6897b3985255", "parents": ["365ada2dfea7a482fe9b769b4d07d6e87bdd650b"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 2049714 part 4 - Add set{Double,Number}AssumeCanonicalNaN and call them in the interpreter and Math builtins.  a=pascalc\n\nThese behave like `setDouble` and `setNumber` before part 2.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309386\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311351\n", "files": ["js/public/Value.h", "js/src/builtin/Math.cpp", "js/src/jsapi-tests/testValueNaN.cpp", "js/src/vm/Interpreter-inl.h"], "git_node": "9a5ad28957c139dca1883e65d2ccd2c61015f091", "git_parents": ["4edea712adef94a9f247d01