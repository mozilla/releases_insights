13262c"], "node": "71a09b5f6eeae9ca7b3b3bee5fba5a2311991052", "parents": ["cd28a9248abb84a48c43958e78a8a92b9a88c64e"], "tags": []}], "date": 1783933406, "git_changesets": ["ad844546d31a3c5c89b6771d3c0c224d8613262c", "a1ad0f3f4706d933cd0e49903748535434c97472"], "user": "ffxbld@lando.moz.tools"}, "27436": {"changesets": [{"author": "Gabriele Svelto \u003cgsvelto@mozilla.com\u003e", "branch": "default", "desc": "Bug 2052169 - Ensure the main process reliably detects when the crash helper goes down  a=pascalc\n\nThis solves two problems that can occur on Android and which make the\nmain process believe the crash helper is still alive when it is not\n(leading in turn to long timeouts and deadlocks). First of all the\nendpoints which we pass to the crash helper via Binder IPC are closed as\nsoon as we're done transfering them. Previously they wouldn't be closed\nuntil a GC run would finalize the ParcelFileDescriptor objects owning\nthem. Additionally we explicitly close those same endpoints when we\nencounter errors in the little amount of C++ code in the crash helper\nitself. Past that point the endpoints become owned file descriptors in\nRust code and will be closed automatically when need be.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D311078\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311600\n", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/crashhelper/CrashHelper.java", "toolkit/crashreporter/crash_helper/crashhelper_android.cpp"], "git_node": "209157d378bb12e16126d387a9cab623c6c9ac9c", "git_parents": ["a1ad0f3f4706d933cd0e49903748535434c97472"], "node": "9ae325e7eabfb987e7b45f2d19410a3ce3beb9bd", "parents": ["71a09b5f6eeae9ca7b3b3bee5fba5a2311991052"], "tags": []}], "date": 1783934065, "git_changesets": ["209157d378bb12e16126d387a9cab623c6c9ac9c"], "user": "pchevrel@mozilla.com"}, "27437": {"changesets": [{"author": "Meg Viar \u003clmegviar@gmail.com\u003e", "branch": "default", "desc": "Bug 2050140 - Add new action-only message type in messaging system  a=pascalc\n\nAdds a new `action_only` message template. These are messages with no UI that perform an action or collection of actions when delivered. ASRouter silently executes an allowlisted SpecialMessageAction, records a local impression, sends impression telemetry, and does not block the message (re-fire is governed by frequency caps).\n\nAn allowlist gate (`_isAllowedActionOnlyMessageAction`) ensures only allowlisted action types may run For now, the list is limited to \"CONFIRM_LAUNCH_ON_LOGIN\" (the first use case for this message type). Bug 2050517 will allow this list to be extended via remote-settings for greater off-train flexibility.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308617\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310807\n", "files": ["browser/components/asrouter/content-src/schemas/MessagingExperiment.schema.json", "browser/components/asrouter/content-src/schemas/make-schemas.py", "browser/components/asrouter/content-src/templates/OnboardingMessage/ActionOnlyMessage.schema.json", "browser/components/asrouter/content/asrouter-admin.bundle.js", "browser/components/asrouter/docs/action-only.md", "browser/components/asrouter/docs/index.rst", "browser/components/asrouter/modules/ASRouter.sys.mjs", "browser/components/asrouter/modules/ASRouterParentProcessMessageHandler.sys.mjs", "browser/components/asrouter/modules/ASRouterTelemetry.sys.mjs", "browser/components/asrouter/modules/ActorConstants.mjs", "browser/components/asrouter/tests/unit/ASRouter.test.js", "browser/components/asrouter/tests/xpcshell/test_ASRouterTelemetry.js", "toolkit/components/messaging-system/schemas/index.rst"], "git_node": "5020fac8f4e349f410d4e556754c98f1a0093973", "git_parents": ["209157d378bb12e16126d387a9cab623c6c9ac9c"], "node": "1838d51fd7d4f8b611952a1edd46fdbf7174be3e", "parents": ["9ae325e7eabfb987e7b45f2d19410a3ce3beb9bd"], "tags": []}, {"author": "Meg Viar \u003clmegviar@gmail.com\u003e", "branch": "default", "desc": "Bug 2053442 - Add PIN_FIREFOX_TO_TASKBAR to the action_only message allowlist  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D311088\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311153\n", "files": ["browser/components/asrouter/docs/action-only.md", "browser/components/asrouter/modules/ASRouter.sys.mjs", "browser/components/asrouter/tests/unit/ASRouter.test.js"], "git_node": "2ecd0540487e9bc16eef967979498f5ac79f293f", "git_parents": ["5020fac8f4e349f410d4e556754c98f1a0093973"], "node": "494add7e4c3364179aeaed5bbd8cbf589fd7c57e", "parents": ["1838d51fd7d4f8b611952a1edd46fdbf7174be3e"], "tags": []}], "date": 1783934133, "git_changesets": ["5020fac8f4e349f410d4e556754c98f1a0093973", "2ecd0540487e9bc16eef967979498f5ac79f293f"], "user": "pchevrel@mozilla.com"}, "27438": {"changesets": [{"author": "Jan-Niklas Jaeschke \u003cjjaschke@mozilla.com\u003e", "branch": "default", "desc": "Bug 2052570 - ChildIndexCache::ComputeIndexOf should return Nothing() for disconnected children.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D310645\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311793\n", "files": ["dom/base/crashtests/2052570.html", "dom/base/crashtests/crashtests.list", "dom/base/nsINode.cpp"], "git_node": "0141c89f9f9808795a91ffbffdd92aa992e5ea38", "git_parents": ["2ecd0540487e9bc16eef967979498f5ac79f293f"], "node": "23d6c50436307e15c8f40f0cc69d2a851a757d9f", "parents": ["494add7e4c3364179aeaed5bbd8cbf589fd7c57e"], "tags": []}], "date": 1783934390, "git_changesets": ["0141c89f9f9808795a91ffbffdd92aa992e5ea38"], "user": "pchevrel@mozilla.com"}, "27439": {"changesets": [{"author": "Meg Viar \u003clmegviar@gmail.com\u003e", "branch": "default", "desc": "Bug 2053515 - Add Windows Update Build Revision to os in the the Client Environment  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D311143\n\nDif