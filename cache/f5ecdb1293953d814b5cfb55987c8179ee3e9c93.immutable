ad3756e9db19359c58906ac6c29439d"], "node": "843237a77211944139d50df958d8829a3f2739ae", "parents": ["753949d46919a43c1c0105e49607eaa33c047a9e"], "tags": []}], "date": 1782394175, "git_changesets": ["e43a4988a248e8a7920926b55fcd99cf1b2205b2"], "user": "ffxbld@lando.moz.tools"}, "27100": {"changesets": [{"author": "Julian Seward \u003cjseward@acm.org\u003e", "branch": "default", "desc": "Bug 2043035.  .  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D303979\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308723\n", "files": ["js/src/wasm/WasmInstance.cpp", "js/src/wasm/WasmTable.cpp"], "git_node": "0b468dc9f17ecdc185fcfa412512d0e8632b0f88", "git_parents": ["072dfdf5f155d8cc28aa165613dcb9c7864968c4"], "node": "48795f5f213c28e5a46045e2da53faaa14090de1", "parents": ["b9df0ce22635179424f94ebe8fd79541ad8e5acf"], "tags": []}], "date": 1782394456, "git_changesets": ["0b468dc9f17ecdc185fcfa412512d0e8632b0f88"], "user": "pchevrel@mozilla.com"}, "27101": {"changesets": [{"author": "longsonr \u003clongsonr@gmail.com\u003e", "branch": "default", "desc": "Bug 2049407 Part 1 - Detach observers on canvas destruction  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308288\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308730\n", "files": ["dom/canvas/CanvasRenderingContext2D.cpp"], "git_node": "bd8aebb94e3159139c8754c960743fff204d4053", "git_parents": ["0b468dc9f17ecdc185fcfa412512d0e8632b0f88"], "node": "a0eb9a1faef6f8e3d0c8bb3de09b060e66bb1156", "parents": ["48795f5f213c28e5a46045e2da53faaa14090de1"], "tags": []}], "date": 1782394512, "git_changesets": ["bd8aebb94e3159139c8754c960743fff204d4053"], "user": "pchevrel@mozilla.com"}, "27102": {"changesets": [{"author": "Olli Pettay \u003cOlli.Pettay@helsinki.fi\u003e", "branch": "default", "desc": "Bug 2045414, be consistent with the promise resolve/reject handling,  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306588\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308733\n", "files": ["dom/promise/Promise.cpp"], "git_node": "a9d118f8663b7b51eaabdbdbb045547c1fec975b", "git_parents": ["bd8aebb94e3159139c8754c960743fff204d4053"], "node": "35db8d5737ec0a8f2a0036a4d220ca0799702a6e", "parents": ["a0eb9a1faef6f8e3d0c8bb3de09b060e66bb1156"], "tags": []}], "date": 1782394569, "git_changesets": ["a9d118f8663b7b51eaabdbdbb045547c1fec975b"], "user": "pchevrel@mozilla.com"}, "27103": {"changesets": [{"author": "Artur Iunusov \u003caiunusov@mozilla.com\u003e", "branch": "default", "desc": "Bug 2016438 - fix Windows performance regression  a=pascalc\n\n- due to the wrong UNC path detection\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305558\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308794\n", "files": ["third_party/sqlite3/moz.yaml", "third_party/sqlite3/patches/bug-2016438-win-dos-device-drive-path.patch", "third_party/sqlite3/src/sqlite3.c"], "git_node": "1e83cf3f1e1b7914f4c80c782b01eac2d0d13f6a", "git_parents": ["a9d118f8663b7b51eaabdbdbb045547c1fec975b"], "node": "39a49e2c6769904f2e0c66dc59580922e93c2ffe", "parents": ["35db8d5737ec0a8f2a0036a4d220ca0799702a6e"], "tags": []}], "date": 1782394915, "git_changesets": ["1e83cf3f1e1b7914f4c80c782b01eac2d0d13f6a"], "user": "pchevrel@mozilla.com"}, "27104": {"changesets": [{"author": "David Rubino \u003cdrubino@mozilla.com\u003e", "branch": "default", "desc": "Bug 2032645 - Unify Windows first run launch-on-login in browser-before-ui-startup, off by default, enabled via Nimbus.  a=pascalc\n\nBug 2038097 enabled launch-on-login by default for all install types but\nprovided a Nimbus override only on the stub installer's --first-startup path,\nso full installer, MSI, MSIX, and zip installs never consulted Nimbus on first\nrun. An earlier plan to run this during the about:welcome splash screen was\ndropped: the splash screen does not show on all configurations (Linux,\nenterprise-suppressed onboarding) and coupling an OS-integration task to\nonboarding UI is the wrong fit. The registry write only matters before the\nuser reboots Windows, so it does not need to run especially early.\n\nReplace both paths with a single first-run task registered at\nbrowser-before-ui-startup (Windows + official builds only, gated on\nnsIToolkitProfileService.isFirstRun). It waits for Nimbus's first Remote\nSettings update -- the correct first-run \"ready to report enrollment\" signal,\nsince NimbusFeatures.\u003cid\u003e.ready() only waits for the on-disk store, which is\nempty on a new profile -- then enables launch-on-login unless the resolved\nvalue is off.\n\nLaunch-on-login is gated on the browser.startup.windowsLaunchOnLogin.defaultEnabled\npref. The defaultWindowsLaunchOnLogin Nimbus feature's `enabled` variable is\nmapped to that pref via setPref in FeatureManifest.yaml, so a rollout or\nexperiment writes the pref on enrollment and the task simply reads it once\nNimbus is ready. The pref ships false, so launch-on-login stays off unless\nNimbus turns it on -- which keeps the 2026 long-term growth holdback (excluded\nfrom the rollout) cleanly off across all install types. Flipping the shipped\ndefault to true enables launch-on-login for everyone once the holdback ends.\n\nThe task is fire-and-forget: browser-before-ui-startup is not awaited, so a slow\nor hung Nimbus fetch never blocks UI startup, and a user who closes Firefox\nbefore it resolves simply ends up with launch-on-login disabled.\n\nRemove the now-unnecessary two-step pref handshake\n(DefaultWindowsLaunchOnLogin.applyExperimentOverride writing the pref, read\nlater by StartupOSIntegration.maybeCreateLaunchOnLoginOnFirstRun).\n\nTest changes:\n- Rewrite the defaultwindowslaunchonlogin xpcshell test to drive the new method\n  directly, covering pref-off, pref-on, the Nimbus-enrollment-to-pref setPref\n  linkage, not-first-run, developer-build, and Windows-policy-deny. Rename it to\n  test_DefaultWindowsLaunchOnLogin.js to match the module.\n- Remove test_maybeCreateLaunchOnLoginOnFirstRun.js, which covered the deleted\n  method.\n- Make browser_windows_launch_on_login_msix.js establish a known-disabled start\n  state so it no longer depends on first-run startup behavior.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305808\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308755\n", "files": ["browser/app/profile/firefox.js", "browser/components/BrowserComponents.manifest", "browser/components/defaultwindowslaunchonlogin/DefaultWindowsLaunchOnLogin.sys.mjs", "browser/components/defaultwindowslaunchonlogin/tests/test_DefaultWindowsLaunchOnLogin.js", "browser/components/defaultwindowslaunchonlogin/tests/test_nimbus_defaultWindowsLaunchOnLogin_firstStartup.js", "browser/components/defaultwindowslaunchonlogin/tests/xpcshell.toml", "browser/components/preferences/tests/browser_windows_launch_on_login_msix.js", "browser/components/shell/StartupOSIntegration.sys.mjs", "browser/components/shell/test/unit/test_maybeCreateLaunchOnLoginOnFirstRun.js", "browser/components/shell/test/unit/xpcshell.toml", "toolkit/components/nimbus/FeatureManifest.yaml"], "git_node": "a6650de8486449cf558356727be0c423d371eb58", "git_parents": ["1e83cf3f1e1b7914f4c80c782b01eac2d0d13f6a"], "node": "ded6007fe29c74eb95cb1899f53cc8ab6651d212", "parents": ["39a49e2c6769904f2e0c66dc59580922e93c2ffe"], "tags": []}], "date": 1782395276, "git_changesets": ["a6650de8486449cf558356727be0c423d371eb58"], "user": "pchevrel@mozilla.com"}, "27105": {"changesets": [{"author": "Jan-Niklas Jaeschke \u003cjjaschke@mozilla.com\u003e", "branch": "default", "desc": "Bug 2049404 - Remove unused method from nsINode, add mainthread checks.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308201\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308740\n", "files": ["dom/base/nsINode.cpp", "dom/base/nsINode.h"], "git_node": "f79f027486738263191425cabf9de740762549ed", "git_parents": ["a6650de8486449cf558356727be0c423d371eb58"], "node": "7560a15570232003e128c553789571d7d3d626cd", "parents": ["ded6007fe29c74eb95cb1899f53cc8ab6651d212"], "tags": []}], "date": 1782395309, "git_changesets": ["f79f027486738263191425cabf9de740762549ed"], "user": "pchevrel@mozilla.com"}, "27106": {"changesets": [{"author": "Olli Pettay \u003cOlli.Pettay@helsinki.fi\u003e", "branch": "default", "desc": "Bug 2045515, avoid leaking a slot,  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305076\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308739\n", "files": ["dom/html/HTMLSlotElement.cpp"], "git_node": "38710a4855e6d2bb04b46103c81bec95e40b71ab", "git_parents": ["f79f027486738263191425cabf9de740762549ed"], "node": "1338360c658778fb4793b9a8f9094b99e0e5f582", "parents": ["7560a15570232003e128c553789571d7d3d626cd"], "tags": []}], "date": 1782395348, "git_changesets": ["38710a4855e6d2bb04b46103c81bec95e40b71ab"], "user": "pchevrel@mozilla.com"}, "27107": {"changesets": [{"author": "Olli Pettay \u003cOlli.Pettay@helsinki.fi\u003e", "branch": "default", "desc": "Bug 2045514, bring back the old behavior of HTMLOptionsCollection usage,  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305077\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308737\n", "files": ["dom/html/HTMLOptionsCollection.cpp"], "git_node": "d9f878f5178c15cd16b7a674fde11a079c90c576", "git_parents": ["38710a4855e6d2bb04b46103c81bec95e40b71ab"], "node": "7593782fb9afe662fcb6074eaa2d78952f04694c", "parents": ["1338360c658778fb4793b9a8f9094b99e0e5f582"], "tags": []}], "date": 1782395415, "git_changesets": ["d9f878f5178c15cd16b7a674fde11a079c90c576"], "user": "pchevrel@mozilla.com"}, "27108": {"changesets": [{"author": "Julian Seward \u003cjseward@acm.org\u003e", "branch": "default", "desc": "Bug 2045443.  .  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305869\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308728\n", "files": ["js/src/wasm/WasmBaselineCompile.cpp"], "git_node": "0a293432ea7ad4b5ae11569b10fba25ddb85e4b3", "git_parents": ["d9f878f5178c15cd16b7a674fde11a079c90c576"], "node": "18904640e3c09cd537f99512b30a31160e9018ac", "parents": ["7593782fb9afe662fcb6074eaa2d78952f04694c"], "tags": []}], "date": 1782395577, "git_changesets": ["0a293432ea7ad4b5ae11569b10fba25ddb85e4b3"], "user": "pchevrel@mozilla.com"}, "27109": {"changesets": [{"author": "Nikolas Wipper \u003cnwipper@mozilla.com\u003e", "branch": "default", "desc": "Bug 1996558 - Encrypt SQLite databases from mozStorageService  a=pascalc\n\nThis patch is the baseline, follow-up fixes for comments have been added in the child stack.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D270165\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307712\n", "files": ["browser/components/backup/tests/marionette/manifest.toml", "dom/cache/Connection.cpp", "dom/cache/test/marionette/manifest.toml", "dom/cache/test/mochitest/test_cache_padding.html", "dom/indexedDB/test/marionette/manifest.toml", "modules/libpref/init/StaticPrefList.yaml", "netwerk/base/idna_glue/src/lib.rs", "security/keystore/KeyStorage.cpp", "security/keystore/KeyStorage.h", "security/keystore/Persist.cpp", "security/keystore/Persist.h", "security/keystore/Profile.cpp", "security/keystore/Profile.h", "security/keystore/moz.build", "security/keystore/tests/browser/browser.toml", "security/keystore/tests/browser/browser_connect.js", "security/keystore/tests/browser/browser_encrypt.js", "security/moz.build", "storage/mozIStorageAsyncConnection.idl", "storage/mozStorageConnection.cpp", "storage/mozStorageConnection.h", "storage/mozStorageService.cpp", "storage/test/unit/xpcshell.toml", "toolkit/components/places/ConcurrentConnection.cpp", "toolkit/components/places/Database.cpp", "toolkit/components/places/PlacesSemanticHistoryDatabase.sys.mjs", "toolkit/modules/Sqlite.sys.mjs"], "git_node": "7e64cc699fd6686fc07f9d9c6d96b7b3cf803278", "git_parents": ["0a293432ea7ad4b5ae11569b10fba25ddb85e4b3"], "node": "c668d80899af3a8cfed0520729fbbc64213f364f", "parents": ["18904640e3c09cd537f99512b30a31160e9018ac"], "tags": []}, {"author": "Benjamin Beurdouche \u003cbbeurdouche@mozilla.com\u003e", "branch": "default", "desc": "Bug 1996558 - Add shared mozilla::HexEncode/HexDecode helpers in xpcom/io  a=pascalc\n\nSeveral components hand-roll a byte\u003c-\u003ehex loop; gcp flagged (D301076) that the SQLite-encryption keystore was about to add yet another copy. Introduce shared mozilla::HexEncode (with an optional uppercase mode) and its inverse mozilla::HexDecode in xpcom/io, next to Base64Encode/Base64Decode, with gtests. mfbt would be the natural home but cannot depend on nsACString, so the helpers live in the XPCOM io/ module.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D303706\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307713\n", "files": ["xpcom/io/Hex.cpp", "xpcom/io/Hex.h", "xpcom/io/moz.build", "xpcom/tests/gtest/TestHex.cpp", "xpcom/tests/gtest/moz.build"], "git_node": "2f3846b550e927b33e13d2cc71f107286c11b257", "git_parents": ["7e64cc699fd6686fc07f9d9c6d96b7b3cf803278"], "node": "6443e5a62db6e608b8329322425553a045add155", "parents": ["c668d80899af3a8cfed0520729fbbc64213f364f"], "tags": []}, {"author": "Benjamin Beurdouche \u003cbbeurdouche@mozilla.com\u003e", "branch": "default", "desc": "Bug 1996558 - Address review feedback for SQLite encryption (excluding keystore).  a=pascalc\n\nFollow-up to D270165 addressing reviewer comments outside security/keystore/\nand adding a profile-encryption launch guard:\n\n- Add a database-at-rest launch guard. nsAppRunner reads an\n  EncryptedDatabases marker from compatibility.ini early in\n  XRE_mainStartup and refuses to launch (alert + clean exit) rather than\n  corrupt data when the profile's on-disk state and the\n  security.storage.encryption.sqlite.enabled pref disagree: an encrypted\n  profile opened by a pref-off build, or plaintext databases under a\n  pref-on build (the latter detected by reading the SQLite header's\n  8192-byte-page / 32-reserved-byte obfsvfs signature, no mozStorage).\n  The gate is skipped in backgroundtask mode. The EncryptedDatabases flag\n  is read in CheckCompatibility (which already parses compatibility.ini)\n  and written by a new nsIXULRuntime.markProfileEncryptedDatabases\n  (append-only, modeled on invalidateCachesOnRestart), with an xpcshell\n  test; the storage layer wires the marker write on profile-after-change\n  in the lockstore commit.\n- Drop duplicate hasKey/mDatabaseEncrypted assignment and clarify the\n  \"outside profile\" fallback comments in Connection::initialize.\n- Restore explicit `return rv` at the three sqlite3_open failure sites\n  that the original patch had switched to NS_ENSURE_SUCCESS.\n- Strengthen the security.storage.encryption.sqlite.enabled pref\n  description to flag it INTERNAL / DO NOT ENABLE pending the\n  enterprise-policy gate in the rest of the stack.\n- Replace the mozilla_net_percent_encode Rust addition in\n  netwerk/base/idna_glue with a call to NS_EscapeURLSpan(esc_FilePath |\n  esc_Forced) inside a new shared helper, storage::PreparePathForURI,\n  exported via storage/StoragePathUtil.h. NS_EscapeURLSpan covers '?',\n  '#', '&', space, etc. -- not just '%'.\n- Expose obfsvfs::kObfsPageSize from ObfuscatingVFS.h so that\n  Connection::GetDefaultPageSize and ObfuscatingVFS.cpp share the same\n  8192 constant instead of duplicating literals.\n- Use storage::PreparePathForURI in toolkit/components/places/\n  Database.cpp::AttachDatabase before building the file: URI, so paths\n  containing URI-significant bytes don't produce malformed URIs.\n- Make ExtractURIPathAndQuery tolerant of bare filesystem paths. PRAGMA\n  database_list returns normalized filenames (no file: prefix), so the\n  encrypted-clone branch was previously returning NS_ERROR_FAILURE and\n  breaking Connection::initializeClone for encrypted DBs with attached\n  databases.\n- Track the pending mozIStoragePendingStatement returned by\n  attachDatabase in Sqlite.sys.mjs's _pendingStatements map, matching\n  the _executeStatement pattern, so shutdown can cancel in-flight\n  ATTACH operations instead of leaking them.\n- Parameterize test_page_size_is_32k.js on the encryption pref (8 KiB\n  when on, 32 KiB when off) and drop its pref override in xpcshell.toml.\n- Strengthen the comment in dom/indexedDB/test/marionette/\n  manifest.toml about the PBM x obfsvfs interaction gap and reference a\n  pending follow-up bug.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301054\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307714\n", "files": ["browser/components/backup/tests/marionette/manifest.toml", "dom/cache/test/marionette/manifest.toml", "dom/indexedDB/test/marionette/manifest.toml", "modules/libpref/init/StaticPrefList.yaml", "netwerk/base/idna_glue/src/lib.rs", "storage/ObfuscatingVFS.cpp", "storage/ObfuscatingVFS.h", "storage/StoragePathUtil.cpp", "storage/StoragePathUtil.h", "storage/moz.build", "storage/mozStorageConnection.cpp", "storage/mozStorageConnection.h", "storage/test/unit/test_attach_database_uri_encoded_path.js", "storage/test/unit/test_page_size_is_32k.js", "storage/test/unit/xpcshell.toml", "toolkit/components/places/Database.cpp", "toolkit/locales/en-US/chrome/mozapps/profile/profileSelection.properties", "toolkit/modules/Sqlite.sys.mjs", "toolkit/profile/test/xpcshell/test_encrypted_databases_marker.js", "toolkit/profile/test/xpcshell/xpcshell.toml", "toolkit/xre/nsAppRunner.cpp", "xpcom/system/nsIXULRuntime.idl"], "git_node": "0af3c64767be92b2023603bdb02320e4521521c0", "git_parents": ["2f3846b550e927b33e13d2cc71f107286c11b257"], "node": "24099d6bc829c84b46c2f4462d5763b463935487", "parents": ["6443e5a62db6e608b8329322425553a045add155"], "tags": []}, {"author": "Benjamin Beurdouche \u003cbbeurdouche@mozilla.com\u003e", "branch": "default", "desc": "Bug 1996558 - Replace security/keystore with security/lockstore (LocalKey).  a=pascalc\n\nDelete the bespoke security/keystore module introduced by the parent\nrevision and route per-database obfsvfs keys through security/lockstore\nusing KekType::LocalKey. The lockstore collection name for each SQLite\ndatabase is the SHA-256 of the database's path relative to the active\nprofile directory; the underlying DEK is created extractable so that\nobfsvfs can consume the raw 32-byte key via the `?key=...` URI.\n\n- New storage/SQLiteEncryption.{h,cpp} exposes\n  mozilla::storage::GetEncryptionKey and ShutdownEncryptionKeystore\n  on top of lockstore_ffi.\n- Three consumers rewired: mozStorageService::Init drops the explicit\n  key::Init() call; mozStorageService::Observe(xpcom-shutdown-threads)\n  calls ShutdownEncryptionKeystore(); mozStorageConnection and\n  toolkit/components/places/Database.cpp call GetEncryptionKey.\n- security/keystore/ deleted and dropped from security/moz.build.\n- Browser-chrome tests moved to storage/test/browser/encryption/ with\n  the keystore.db existence assertion removed (lockstore manages its\n  own DB).\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301076\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307715\n", "files": ["modules/libpref/init/StaticPrefList.yaml", "security/certverifier/NSSCertDBTrustDomain.cpp", "security/keystore/KeyStorage.cpp", "security/keystore/KeyStorage.h", "security/keystore/Persist.cpp", "security/keystore/Persist.h", "security/keystore/Profile.cpp", "security/keystore/Profile.h", "security/keystore/moz.build", "security/keystore/tests/browser/browser.toml", "security/keystore/tests/browser/browser_connect.js", "security/keystore/tests/browser/browser_encrypt.js", "security/manager/ssl/PKCS11ModuleDB.cpp", "security/manager/ssl/nsNSSComponent.cpp", "security/moz.build", "storage/SQLiteEncryption.cpp", "storage/SQLiteEncryption.h", "storage/moz.build", "storage/mozStorageConnection.cpp", "storage/mozStorageService.cpp", "storage/test/browser/encryption/browser.toml", "storage/test/browser/encryption/browser_connect.js", "storage/test/browser/encryption/browser_encrypt.js", "storage/test/moz.build", "toolkit/components/places/Database.cpp", "toolkit/xre/nsAppRunner.cpp", "toolkit/xre/nsAppRunner.h"], "git_node": "37b67900d37aadae791aaed5bc21bba7b45585f9", "git_parents": ["0af3c64767be92b2023603bdb02320e4521521c0"], "node": "7c0d99c55aa4ac9a780641eeefbc747e2cd22670", "parents": ["24099d6bc829c84b46c2f4462d5763b463935487"], "tags": []}, {"author": "Benjamin Beurdouche \u003cbbeurdouche@mozilla.com\u003e", "branch": "default", "desc": "Bug 1996558 - Lock SQLite-encryption pref and route override through enterprise policy r=mkaply a=pascalc\n\nLock the pref in modules/libpref/init/all.js so end users cannot toggle\nit from about:config or user.js, and add it to the Preferences\nenterprise-policy allowlist so admins can still drive it from\npolicies.json.\n\nThe pref stays declared as a StaticPref in StaticPrefList.yaml; this\npatch only adds the locking and policy plumbing.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D297713\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307716\n", "files": ["browser/components/enterprisepolicies/Policies.sys.mjs", "modules/libpref/init/all.js", "storage/test/browser/encryption/browser.toml", "storage/test/browser/encryption/browser_connect.js", "storage/test/browser/encryption/browser_encrypt.js", "storage/test/unit/test_attach_database_uri_encoded_path.js", "storage/test/unit/xpcshell.toml", "toolkit/modules/Troubleshoot.sys.mjs", "tools/lint/libpref/__init__.py"], "git_node": "5e5bdd858425bb2419b24fa9a8b400b6f409ac68", "git_parents": ["37b67900d37aadae791aaed5bc21bba7b45585f9"], "node": "d75e31385393912e229785b90d6468197fc4d5e9", "parents": ["7c0d99c55aa4ac9a780641eeefbc747e2cd22670"], "tags": []}, {"author": "Benjamin Beurdouche \u003cbbeurdouche@mozilla.com\u003e", "branch": "default", "desc": "Bug 1996558 - Make perfdocs tolerate paths deleted within the changeset.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D303719\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307717\n", "files": ["python/mozperftest/mozperftest/perfdocs/perfdocs.py"], "git_node": "3989e5e8d995d01174f4ce172756d65a9bd20fc1", "git_parents": ["5e5bdd858425bb2419b24fa9a8b400b6f409ac68"], "node": "a1f86b6f8c890d5ca3e7b76a3a6d6ecafe81a6e9", "parents": ["d75e31385393912e229785b90d6468197fc4d5e9"], "tags": []}, {"author": "Benjamin Beurdouche \u003cbbeurdouche@mozilla.com\u003e", "branch": "default", "desc": "Bug 1996558 - Make DEK key_size an explicit keystore_create_dek parameter  a=pascalc\n\nBackported from enterprise-firefox 16d9ea9e4e79.\n\nThreads an explicit key_size through keystore_create_dek (LockstoreService,\nlockstore_ffi, keystore.rs, nsILockstore.idl); SQLiteEncryption passes\nkDekBytes and static_asserts kDekBytes == IPCStreamCipherStrategy::KeyType size.\n\nAlso updates the lockstore gtest call sites (TestLockstoreKeystore.cpp,\nTestLockstoreDatastore.cpp, TestLockstoreService.cpp) to the new 5-arg arity;\nthe enterprise commit updated only TestLockstoreService.cpp, leaving the other\ntwo on the old signature (a latent build break).\n\nOriginal Revision: https://phabricator.services.mozilla.com/D304993\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307718\n", "files": ["security/lockstore/LockstoreService.cpp", "security/lockstore/LockstoreService.h", "security/lockstore/gtest/TestLockstoreDatastore.cpp", "security/lockstore/gtest/TestLockstoreKeystore.cpp", "security/lockstore/lockstore_ffi/src/lib.rs", "security/lockstore/lockstore_rs/src/keystore.rs", "security/lockstore/nsILockstore.idl", "security/lockstore/tests/gtest/TestLockstoreService.cpp", "security/lockstore/tests/unit/test_nsILockstore.js", "storage/SQLiteEncryption.cpp"], "git_node": "cd0b29373400d07b2c603d31edabb0282ae5ba39", "git_parents": ["3989e5e8d995d01174f4ce172756d65a9bd20fc1"], "node": "91f693345b9173f211cdd5c94a0fbaf675eb21ff", "parents": ["a1f86b6f8c890d5ca3e7b76a3a6d6ecafe81a6e9"], "tags": []}, {"author": "Benjamin Beurdouche \u003cbbeurdouche@mozilla.com\u003e", "branch": "default", "desc": "Bug 1996558 - Encrypt rusqlite/skv SQLite databases by making obfsvfs the default VFS  a=pascalc\n\nBackported from enterprise-firefox ed9df1f698fa.\n\nobfsvfs is the SQLite default VFS; obfsOpen owns the at-rest policy so keyless\nsqlite3_open_v2 (rusqlite/skv/app-services) gets path-aware encryption. Per-file\nkey cached for shutdown journal finalization; PeekOnDiskHeader uses\npage_size==8192 && reserved==32; lockstore.keys.sqlite bootstrap bypass;\nno-CREATE-of-missing forwards to lower VFS.\n\n(Enterprise Password-KEK/primarySecret + vault routing remain enterprise-only,\nexcluded; .cargo vendor-reorder dropped.)\n\nOriginal Revision: https://phabricator.services.mozilla.com/D304994\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307719\n", "files": ["dom/indexedDB/ActorsParent.cpp", "storage/ObfuscatingVFS.cpp", "storage/SQLiteEncryption.cpp", "storage/SQLiteEncryption.h", "storage/mozStorageService.cpp", "storage/mozStorageService.h"], "git_node": "2264259f75f0ad2f1004640bfe8ba51553914e5d", "git_parents": ["cd0b29373400d07b2c603d31edabb0282ae5ba39"], "node": "240499b2ff91ead113981340f6db490f3a1da79c", "parents": ["91f693345b9173f211cdd5c94a0fbaf675eb21ff"], "tags": []}, {"author": "Benjamin Beurdouche \u003cbbeurdouche@mozilla.com\u003e", "branch": "default", "desc": "Bug 1996558 - Shut down the SQLite encryption keystore at XPCOMWillShutdown and stop caching the per-file DEK  a=pascalc\n\nThe keystore previously closed at quit-application (AppShutdownConfirmed), the earliest shutdown phase, which forced obfsvfs to cache the raw per-file DEK (ObfsFile::aKey plus WAL/journal partner-inheritance) so it could finalize a connection's journals after the keystore was already gone. That early teardown was justified by a comment claiming LateWriteChecks fires at AppShutdownNetTeardown; it actually fires at XPCOMShutdownThreads (toolkit.shutdown.lateWriteChecksStage=2), so there is ample headroom to keep the keystore alive much later.\n\nKeep lockstore available for late profile writes and shut it down last, at XPCOMWillShutdown -- after Places (profile-before-change) and QuotaManager/IndexedDB/DOM-storage (profile-before-change-qm) have closed their connections, and after AppShutdownTelemetry (past which nothing writes the profile). Both the storage-internal keystore handle (SQLiteEncryption) and the LockstoreService XPCOM handle now tear down on xpcom-will-shutdown; InitEncryptionKeystore refuses to register/open once already in or beyond XPCOMWillShutdown.\n\nWith lockstore alive that late, obfsvfs no longer needs to cache the DEK: WAL and journal opens fall through to the policy branch and re-derive the same per-database key from lockstore on demand (DeriveMainDbPath strips the -wal/-journal suffix), including the final checkpoint at a connection's close during shutdown. Remove ObfsFile::aKey, the partner-inheritance fast path, and the now-dead keyReady flag; pPartner is retained for checkpoint coordination.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306037\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307720\n", "files": ["security/lockstore/LockstoreService.cpp", "security/lockstore/LockstoreService.h", "storage/ObfuscatingVFS.cpp", "storage/SQLiteEncryption.cpp"], "git_node": "4f7cc0ab3b43fc7f36eafff33834b220ea76bb39", "git_parents": ["2264259f75f0ad2f1004640bfe8ba51553914e5d"], "node": "b8421896ba5a24a980d4ecef3ff3b577372f1d12", "parents": ["240499b2ff91ead113981340f6db490f3a1da79c"], "tags": []}, {"author": "Benjamin Beurdouche \u003cbbeurdouche@mozilla.com\u003e", "branch": "default", "desc": "Bug 1996558 - Make SQLite-encryption-sensitive xpcshell tests encryption-aware  a=pascalc\n\nInstead of opting these storage/toolkit tests out of SQLite encryption, assert\nthe correct behavior in BOTH the encrypted and plaintext configurations\n(detected via the security.storage.encryption.sqlite.enabled pref):\n\n- test_storage_service: a directory-as-database open surfaces NS_ERROR_FAILURE\n  through obfsvfs (and records no open telemetry) vs NS_ERROR_FILE_ACCESS_DENIED\n  / Glean \"access\" on the plain VFS.\n- test_vacuum: obfsvfs forces a fixed page size, so a VACUUM cannot change it\n  (expect unchanged vs 1024); and an encrypted database keeps full auto_vacuum\n  (1) rather than switching to incremental (2).\n- test_sqlite_autoVacuum: a fresh encrypted database reports full auto_vacuum\n  (1), which reclaims freed pages at commit, so there is no freelist for an idle\n  VACUUM to reclaim; assert that auto-reclaim behavior instead.\n- test_cache_size: the requested page size is ignored under encryption (cache\n  size is KiB-based and unchanged).\n- test_sqlite_secure_delete: an encrypted database never stores the plaintext on\n  disk, so the pre-delete \"string is present\" check only applies unencrypted;\n  the post-delete absence check holds in both modes.\n\nAdd test_encryption_rejects_plaintext, asserting the fail-closed contract\ndirectly: with encryption on, an in-profile database that is not encrypted (a\nforeign plaintext database) is refused rather than opened as plaintext; with\nencryption off it opens normally.\n\nFinally, the places, IndexedDB and dom/cache migration/upgrade tests ship\npre-built PLAINTEXT profile/database fixtures and migrate them to the current\nschema. An encrypting build cannot read those plaintext databases (obfsvfs\nrequires its own page format and there is no plaintext-\u003eencrypted migration by\ndesign), and never legitimately encounters a foreign plaintext profile. Their\nschema-migration logic is VFS-agnostic and is covered with encryption off, so\nrun those fixture tests with encryption disabled, each manifest entry carrying a\nshort comment.\n\nVerified passing both with and without SQLite encryption.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305033\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307721\n", "files": ["browser/components/asrouter/tests/browser/browser_asrouter_targeting.js", "browser/components/places/tests/unit/xpcshell.toml", "dom/cache/test/marionette/test_cacheapi_encryption_PBM.py", "dom/cache/test/xpcshell/xpcshell.toml", "dom/fs/test/gtest/parent/TestFileSystemUsageTracking.cpp", "dom/fs/test/xpcshell/xpcshell.toml", "dom/indexedDB/test/marionette/test_IDB_encryption_PBM.py", "dom/indexedDB/test/unit/xpcshell-parent-process.toml", "dom/indexedDB/test/unit/xpcshell-shared.toml", "dom/localstorage/test/unit/xpcshell.toml", "dom/quota/test/xpcshell/upgrades/xpcshell.toml", "dom/quota/test/xpcshell/xpcshell.toml", "dom/serviceworkers/test/browser_head.js", "extensions/permissions/test/unit/xpcshell.toml", "netwerk/test/unit/xpcshell.toml", "security/manager/ssl/tests/unit/xpcshell-smartcards.toml", "security/manager/ssl/tests/unit/xpcshell.toml", "storage/test/unit/test_cache_size.js", "storage/test/unit/test_connection_online_backup.js", "storage/test/unit/test_encryption_rejects_plaintext.js", "storage/test/unit/test_sqlite_secure_delete.js", "storage/test/unit/test_storage_service.js", "storage/test/unit/test_vacuum.js", "storage/test/unit/xpcshell.toml", "toolkit/components/extensions/test/xpcshell/xpcshell-common.toml", "toolkit/components/passwordmgr/test/unit/xpcshell.toml", "toolkit/components/places/tests/maintenance/xpcshell.toml", "toolkit/components/places/tests/migration/xpcshell.toml", "toolkit/components/places/tests/sync/xpcshell.toml", "toolkit/components/places/tests/unit/xpcshell.toml", "toolkit/components/url-classifier/tests/unit/xpcshell.toml", "toolkit/modules/tests/xpcshell/test_sqlite_autoVacuum.js", "toolkit/modules/tests/xpcshell/xpcshell.toml"], "git_node": "947307a4472957b7fee26ae266d9f2c6949231f2", "git_parents": ["4f7cc0ab3b43fc7f36eafff33834b220ea76bb39"], "node": "8c5fa675e9e03f5529dda0a3c2768319e2fec6b2", "parents": ["b8421896ba5a24a980d4ecef3ff3b577372f1d12"], "tags": []}, {"author": "Benjamin Beurdouche \u003cbbeurdouche@mozilla.com\u003e", "branch": "default", "desc": "Bug 1996558 - Disable profile backup when SQLite at-rest encryption is enabled.  a=pascalc\n\nProfile backup stages databases as raw obfsvfs ciphertext whose per-database\nkeys live only in the originating profile's lockstore, so an encrypted backup\ncannot be restored into another profile; and restoring a plaintext backup into\nan encrypting instance would copy databases that obfsvfs then rejects\nfail-closed, leaving a broken profile. Until portable encrypted backup/restore\nexists, gate both archiveEnabledStatus and restoreEnabledStatus on\nsecurity.storage.encryption.sqlite.enabled so backup and restore are\nunavailable while encryption is on. This is a no-op at the production default\n(encryption off).\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305032\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307722\n", "files": ["browser/components/backup/BackupService.sys.mjs", "browser/components/backup/tests/browser/browser.toml", "browser/components/backup/tests/chrome/chrome.toml", "browser/components/backup/tests/marionette/backup_test_base.py", "browser/components/backup/tests/marionette/test_backup.py", "browser/components/backup/tests/xpcshell/test_BackupService_enabled.js", "browser/components/backup/tests/xpcshell/xpcshell.toml", "browser/components/preferences/tests/browser_backup_visibility.js"], "git_node": "4c2e59d14f4594dffe8445fa6869673f6b5f739c", "git_parents": ["947307a4472957b7fee26ae266d9f2c6949231f2"], "node": "31f18e8c07143db513b4924c9933a71fcdd3fb25", "parents": ["8c5fa675e9e03f5529dda0a3c2768319e2fec6b2"], "tags": []}, {"author": "Lando \u003clando@lando.moz.tools\u003e", "branch": "default", "desc": "Bug 1996558: apply code formatting via Lando  a=pascalc\n\n# ignore-this-changeset\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307723\n", "files": ["dom/fs/test/gtest/parent/TestFileSystemUsageTracking.cpp", "security/lockstore/LockstoreService.cpp", "storage/ObfuscatingVFS.cpp", "toolkit/xre/nsAppRunner.cpp"], "git_node": "452d09160c625cda7e3f20d1da98d00b02499cd7", "git_parents": ["4c2e59d14f4594dffe8445fa6869673f6b5f739c"], "node": "6ff53ea010ca8c963e942c317b3ebf13aef93a00", "parents": ["31f18e8c07143db513b4924c9933a71fcdd3fb25"], "tags": []}], "date": 1782401706, "git_changesets": ["7e64cc699fd6686fc07f9d9c6d96b7b3cf803278", "2f3846b550e927b33e13d2cc71f107286c11b257", "0af3c64767be92b2023603bdb02320e4521521c0", "37b67900d37aadae791aaed5bc21bba7b45585f9", "5e5bdd858425bb2419b24fa9a8b400b6f409ac68", "3989e5e8d995d01174f4ce172756d65a9bd20fc1", "cd0b29373400d07b2c603d31edabb0282ae5ba39", "2264259f75f0ad2f1004640bfe8ba51553914e5d", "4f7cc0ab3b43fc7f36eafff33834b220ea76bb39", "947307a4472957b7fee26ae266d9f2c6949231f2", "4c2e59d14f4594dffe8445fa6869673f6b5f739c", "452d09160c625cda7e3f20d1da98d00b02499cd7"], "user": "pchevrel@mozilla.com"}, "27110": {"changesets": [{"author": "Julien Cristau \u003cjcristau@mozilla.com\u003e", "branch": "default", "desc": "Bug 2050562 - suppress macosx1015 mochitest-browser-chrome on beta.  a=RyanVM DONTBUILD\n\nAdd a \"test-backstop\" strategy (aliases skip-unless-backstop by default)\nand override it to \"always\" in the beta project overrides, alongside the\nexisting \"test\" override. Update the apply_bug2043540_optimization transform\nto use \"test-backstop\" instead of \"skip-unless-backstop\" directly, so that\nthe beta override correctly suppresses these tasks on every push.\n\nOn beta backstop=True on every push, so using skip-unless-backstop directly\ncaused macOS 10.15 mochitest-browser-chrome tasks to run on every push.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308844\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308849\n", "files": ["taskcluster/gecko_taskgraph/optimize/__init__.py", "taskcluster/gecko_taskgraph/transforms/test/other.py"], "git_node": "8c8aeab9422ba839709fa18abc8f8ae79d9b9ed8", "git_parents": ["452d09160c625cda7e3f20d1da98d00b02499cd7"], "node": "bfdaf0b727a1165c518637b44fa06de9fc7a0aff", "parents": ["6ff53ea010ca8c963e942c317b3ebf13aef93a00"], "tags": []}], "date": 1782429867, "git_changesets": ["8c8aeab9422ba839709fa18abc8f8ae79d9b9ed8"], "user": "rvandermeulen@mozilla.com"}, "27111": {"changesets": [{"author": "Roger Yang \u003croyang@mozilla.com\u003e", "branch": "default", "desc": "Bug 2049515 - Add UTM source detection for Reddit attribution.  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308143\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308764\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/components/metrics/InstallReferrerHandlingService.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/components/metrics/InstallReferrerHandlingServiceTest.kt"], "git_node": "518f2b8d05fd5db2be6b70b249540fef586e2625", "git_parents": ["8c8aeab9422ba839709fa18abc8f8ae79d9b9ed8"], "node": "05f1a0c84a458545937b623095c48d5d78173979", "parents": ["bfdaf0b727a1165c518637b44fa06de9fc7a0aff"], "tags": []}], "date": 1782429901, "git_changesets": ["518f2b8d05fd5db2be6b70b249540fef586e2625"], "user": "rvandermeulen@mozilla.com"}, "27112": {"changesets": [{"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 2049840 - Release urlpattern on main thread  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308461\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308581\n", "files": ["netwerk/cache2/Dictionary.cpp"], "git_node": "fd168549e7a87229ac02dce6faa8c7e87b54fb95", "git_parents": ["518f2b8d05fd5db2be6b70b249540fef586e2625"], "node": "bdc58402d2418fb4ce1042e034789c08e04a8105", "parents": ["05f1a0c84a458545937b623095c48d5d78173979"], "tags": []}], "date": 1782429939, "git_changesets": ["fd168549e7a87229ac02dce6faa8c7e87b54fb95"], "user": "rvandermeulen@mozilla.com"}, "27113": {"changesets": [{"author": "Elissa Cha \u003cecha@mozilla.com\u003e", "branch": "default", "desc": "Bug 2033002 - Add Preview Report support to Smart Window feedback modal  a=RyanVM\n\n- Add Preview Report support to the Smart Window feedback modal\n- Introduce `ContentToggle` and `TextboxTile` components to the ASRouter multistage template\n- Dynamically update preview and chat log payload based on toggle state\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305368\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308826\n", "files": ["browser/components/aboutwelcome/content/aboutwelcome.bundle.js", "browser/components/aboutwelcome/content/aboutwelcome.css", "browser/components/aiwindow/ui/components/ai-window/ai-window.mjs", "browser/components/aiwindow/ui/modules/FeedbackModal.sys.mjs", "browser/components/aiwindow/ui/test/xpcshell/test_FeedbackModal.js", "browser/components/asrouter/content-src/components/ContentTiles.jsx", "browser/components/asrouter/content-src/components/ContentToggle.jsx", "browser/components/asrouter/content-src/components/MultiStageAboutWelcome.jsx", "browser/components/asrouter/content-src/components/MultiStageProtonScreen.jsx", "browser/components/asrouter/content-src/components/TextBoxTile.jsx", "browser/components/asrouter/content-src/styles/_multistage.scss", "browser/components/asrouter/content/components/asrouter-newtab-multistage/asrouter-newtab-multistage.bundle.js", "browser/components/asrouter/content/components/asrouter-newtab-multistage/asrouter-newtab-multistage.css", "browser/components/asrouter/modules/OnboardingMessageProvider.sys.mjs", "browser/components/asrouter/tests/unit/content-src/components/ContentTiles.test.jsx", "browser/components/asrouter/tests/unit/content-src/components/ContentToggle.test.jsx", "browser/components/asrouter/tests/unit/content-src/components/TextBoxTile.test.jsx", "browser/locales-preview/aiWindow.ftl"], "git_node": "595684a75e04c9a1fc753f623440509a85c8a772", "git_parents": ["fd168549e7a87229ac02dce6faa8c7e87b54fb95"], "node": "f206b0d3ce482ee9c0b64e4244ed0e17a9758f68", "parents": ["bdc58402d2418fb4ce1042e034789c08e04a8105"], "tags": []}, {"author": "Elissa Cha \u003cecha@mozilla.com\u003e", "branch": "default", "desc": "Bug 2034541 - Add dedicated highly_sensitive metric for Smart Window feedback chat history  a=RyanVM\n\nThis patch adds a dedicated highly_sensitive microsurvey.smart_window.chat metric for the chat log and keeps the remaining feedback metadata in microsurvey.smart_window.user_feedback_data (technical). This separation allows the chat data to be handled independently and requires Sensitive Data Collection Review\n\nOriginal Revision: https://phabricator.services.mozilla.com/D304565\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308827\n", "files": ["browser/base/content/spotlight.js", "browser/components/aboutwelcome/modules/AboutWelcomeTelemetry.sys.mjs", "browser/components/aboutwelcome/tests/xpcshell/test_AboutWelcomeTelemetry.js", "browser/components/asrouter/metrics.yaml", "browser/components/asrouter/tests/browser/browser_multistage_spotlight_telemetry.js"], "git_node": "cf31792e2c0d44ecd7efb2a1c6037ac6340268fa", "git_parents": ["595684a75e04c9a1fc753f623440509a85c8a772"], "node": "a0a929d0110a3f13b4c883954f51ac1847a13e2d", "parents": ["f206b0d3ce482ee9c0b64e4244ed0e17a9758f68"], "tags": []}, {"author": "Elissa Cha \u003cecha@mozilla.com\u003e", "branch": "default", "desc": "Bug 2050195 - Fix glean.error.invalid_value for microsurvey.smart_window.chat metric  a=RyanVM\n\nFollow-up fix for the Smart Window user feedback chat metric where schema mismatches were causing `invalid_value` errors in Debug Ping Viewer.\nThese were not caught during local testing because artifact builds use JOG dynamic metrics and do not perform the same schema validation as full builds (see Bug 2050219).\nCan be verified by submitting Smart Window feedback on a full local build and confirming no `invalid_value` errors are reported for `microsurvey.smart_window.chat`.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308851\n", "files": ["browser/components/aboutwelcome/modules/AboutWelcomeTelemetry.sys.mjs", "browser/components/asrouter/metrics.yaml"], "git_node": "46c86540c530ec5933b4c8a0ac1091ddbb04a9ac", "git_parents": ["cf31792e2c0d44ecd7efb2a1c6037ac6340268fa"], "node": "3f7f6100f83464ae8b819d57d93765b3160e7dd9", "parents": ["a0a929d0110a3f13b4c883954f51ac1847a13e2d"], "tags": []}], "date": 1782429992, "git_changesets": ["595684a75e04c9a1fc753f623440509a85c8a772", "cf31792e2c0d44ecd7efb2a1c6037ac6340268fa", "46c86540c530ec5933b4c8a0ac1091ddbb04a9ac"], "user": "rvandermeulen@mozilla.com"}, "27114": {"changesets": [{"author": "Tom Schuster \u003ctschuster@mozilla.com\u003e", "branch": "default", "desc": "Bug 2049409.  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308227\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308718\n", "files": ["dom/security/sanitizer/Sanitizer.cpp"], "git_node": "42099bff5efee950a61a50b853bd3844ebe30bea", "git_parents": ["46c86540c530ec5933b4c8a0ac1091ddbb04a9ac"], "node": "44a9da7b5e2cbbe591ba111098d262749a3416e2", "parents": ["3f7f6100f83464ae8b819d57d93765b3160e7dd9"], "tags": []}], "date": 1782430030, "git_changesets": ["42099bff5efee950a61a50b853bd3844ebe30bea"], "user": "rvandermeulen@mozilla.com"}, "27115": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update remote-settings tld-suffixes ct-logs -  a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308891\n", "files": ["netwerk/dns/effective_tld_names.dat", "security/ct/CTKnownLogs.h", "security/manager/tools/log_list.json", "services/settings/dumps/blocklists/addons-bloomfilters.json", "services/settings/dumps/main/ai-window-prompts.json", "services/settings/dumps/security-state/intermediates.json", "toolkit/components/certviewer/content/components/logNameTable.mjs"], "git_node": "ae8e2e8b3f7a3886e92291d39d7259134d96f466", "git_parents": ["42099bff5efee950a61a50b853bd3844ebe30bea"], "node": "dc3ae74725765044fbfd56140950ead002010676", "parents": ["44a9da7b5e2cbbe591ba111098d262749a3416e2"], "tags": []}], "date": 1782431390, "git_changesets": ["ae8e2e8b3f7a3886e92291d39d7259134d96f466"], "user": "rvandermeulen@mozilla.com"}, "27116": {"changesets": [{"author": "Ryan VanderMeulen \u003crvandermeulen@mozilla.com\u003e", "branch": "default", "desc": "Bug 2036411 - Run the SafeArgs USELESS_CAST suppression before Kotlin compilation  a=diannaS\n\nThe suppression was wired as a finalizedBy task on generateSafeArgs, which only orders it\nafter generation, not before the Kotlin compile that consumes the generated sources. The\ntwo then race, and under strict-serial scheduling the compile reliably wins and fails the\ngenerated NavGraphDirections under -Werror. Fold the rewrite into each generateSafeArgs\ntask's own final action so the output is clean before the task completes.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306513\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308920\n", "files": ["build/test/python/test_android_gradle_build.py", "mobile/android/fenix/app/build.gradle"], "git_node": "f9c9ddeffe27f347b33d05b6d71c9fe6398c842c", "git_parents": ["ae8e2e8b3f7a3886e92291d39d7259134d96f466"], "node": "73467262cd575eb7b48ec26772b8fcf53d9d97fb", "parents": ["dc3ae74725765044fbfd56140950ead002010676"], "tags": []}, {"author": "Ryan VanderMeulen \u003crvandermeulen@mozilla.com\u003e", "branch": "default", "desc": "Bug 2036411 - Serialize the Searchfox Android indexing build to dodge semanticdb-javac races  a=diannaS\n\nThe semanticdb-javac plugin writes generated sources, which live in the objdir outside\nthe sourceroot, into a shared targetroot using a per-task counter for their filenames.\nConcurrent compile tasks then race on identically-named files such as\n1.BuildConfig.java.semanticdb, reading one mid-write and failing to parse the corrupted\nprotobuf. Cap the worker pool to one for compile-all when the mozsearch plugin is enabled\nso the indexing build runs strictly serially.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306514\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308921\n", "files": ["mobile/android/mach_commands.py"], "git_node": "8a04b5ff18a9af69e0416fde5f7cda265e275ef5", "git_parents": ["f9c9ddeffe27f347b33d05b6d71c9fe6398c842c"], "node": "9e6319901748418a5f3b8215270c3d01c4ad44f0", "parents": ["73467262cd575eb7b48ec26772b8fcf53d9d97fb"], "tags": []}], "date": 1782431947, "git_changesets": ["f9c9ddeffe27f347b33d05b6d71c9fe6398c842c", "8a04b5ff18a9af69e0416fde5f7cda265e275ef5"], "user": "rvandermeulen@mozilla.com"}, "27117": {"changesets": [{"author": "Ryan VanderMeulen \u003crvandermeulen@mozilla.com\u003e", "branch": "default", "desc": "Bug 2048008 - Remove clang-20 toolchain tasks.  a=diannaS\n\nAlso clean up an orphaned clang patch no longer referenced by any of the JSON configs.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307069\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308922\n", "files": ["build/build-clang/llvmorg-10-init-136-gb288d90b39f4.patch", "taskcluster/kinds/fetch/toolchains.yml", "taskcluster/kinds/toolchain/clang.yml", "taskcluster/kinds/toolchain/compiler-rt.yml", "taskcluster/kinds/toolchain/libunwind.yml", "taskcluster/kinds/toolchain/llvm-symbolizer.yml", "taskcluster/kinds/toolchain/sysroot.yml"], "git_node": "e61d309146cd121c2b59e6078921dade4dea6b48", "git_parents": ["8a04b5ff18a9af69e0416fde5f7cda265e275ef5"], "node": "40600de77aeb1608f7b71f3a549f9f04c1a234b4", "parents": ["9e6319901748418a5f3b8215270c3d01c4ad44f0"], "tags": []}, {"author": "Ryan VanderMeulen \u003crvandermeulen@mozilla.com\u003e", "branch": "default", "desc": "Bug 2048062 - Run apt-get update before installing build deps in the debian-packages image.  a=diannaS\n\nThe ubuntu2404 raw image pins an apt snapshot for reproducibility, and the\npackage lists from the parent image aren't usable in the debian-packages child,\nso apt-get install fails to locate any package. Refresh the lists first. The\nsnapshot pin is inherited by the child image, so the resolved package versions\nare unchanged.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307183\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308923\n", "files": ["taskcluster/docker/debian-packages/Dockerfile"], "git_node": "676f98b326906735e575046213c82b58d7faa44e", "git_parents": ["e61d309146cd121c2b59e6078921dade4dea6b48"], "node": "8160e371691ec87c0f91db585200d8c3eec41066", "parents": ["40600de77aeb1608f7b71f3a549f9f04c1a234b4"], "tags": []}], "date": 1782431990, "git_changesets": ["e61d309146cd121c2b59e6078921dade4dea6b48", "676f98b326906735e575046213c82b58d7faa44e"], "user": "rvandermeulen@mozilla.com"}, "27118": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Import translations from main\n", "files": ["mobile/android/android-components/components/feature/ipprotection/src/main/res/values-co/strings.xml", "mobile/android/android-components/components/feature/media/src/main/res/values-co/strings.xml", "mobile/android/android-components/components/feature/media/src/main/res/values-cs/strings.xml", "mobile/android/android-components/components/feature/media/src/main/res/values-es-rCL/strings.xml", "mobile/android/android-components/components/feature/prompts/sr