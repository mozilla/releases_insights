ndroid/fenix/app/src/main/res/values-te/strings.xml", "mobile/android/fenix/app/src/main/res/values-tg/strings.xml", "mobile/android/fenix/app/src/main/res/values-th/strings.xml", "mobile/android/fenix/app/src/main/res/values-tl/strings.xml", "mobile/android/fenix/app/src/main/res/values-tr/strings.xml", "mobile/android/fenix/app/src/main/res/values-trs/strings.xml", "mobile/android/fenix/app/src/main/res/values-tt/strings.xml", "mobile/android/fenix/app/src/main/res/values-ug/strings.xml", "mobile/android/fenix/app/src/main/res/values-uk/strings.xml", "mobile/android/fenix/app/src/main/res/values-ur/strings.xml", "mobile/android/fenix/app/src/main/res/values-uz/strings.xml", "mobile/android/fenix/app/src/main/res/values-vec/strings.xml", "mobile/android/fenix/app/src/main/res/values-vi/strings.xml", "mobile/android/fenix/app/src/main/res/values-yo/strings.xml", "mobile/android/fenix/app/src/main/res/values-zh-rCN/strings.xml", "mobile/android/fenix/app/src/main/res/values-zh-rTW/strings.xml", "mobile/android/focus-android/app/src/main/res/values-ga-rIE/strings.xml"], "git_node": "9d6d343b420c66ef00f2e3694c6669b12298329f", "git_parents": ["20a671d2d3e1af57ff6e959a41b4ab4a29120061"], "node": "32a320e27e49fa686dba6b7d2d9a44bdcbc8cfa7", "parents": ["71eaaa6265eebeae3d8dcd557cdaea46594dbbf3"], "tags": []}], "date": 1783908969, "git_changesets": ["9d6d343b420c66ef00f2e3694c6669b12298329f"], "user": "ffxbld@lando.moz.tools"}, "27414": {"changesets": [{"author": "Anna Kulyk \u003cakulyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 2019492 - Set type=\"list\" for Applications list in Settings to improve keyboard navigation  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309156\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311753\n", "files": ["browser/components/preferences/config/downloads.mjs", "browser/components/preferences/tests/applications/browser_applications_selection.js"], "git_node": "6e11683b4e657169e3d89d4c55fac074efcceb0d", "git_parents": ["9d6d343b420c66ef00f2e3694c6669b12298329f"], "node": "5c919c13c94212e949d95840b64e259daa9a3914", "parents": ["32a320e27e49fa686dba6b7d2d9a44bdcbc8cfa7"], "tags": []}], "date": 1783922539, "git_changesets": ["6e11683b4e657169e3d89d4c55fac074efcceb0d"], "user": "pchevrel@mozilla.com"}, "27415": {"changesets": [{"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 2052562: Don't allow moves into a detached subtree.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D310457\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311750\n", "files": ["accessible/ipc/DocAccessibleParent.cpp"], "git_node": "bd91584d520a6f4310dcfbae0259043a95830cd4", "git_parents": ["6e11683b4e657169e3d89d4c55fac074efcceb0d"], "node": "e2b21af095436d08beebf56fd99e4cb4ff427c4e", "parents": ["5c919c13c94212e949d95840b64e259daa9a3914"], "tags": []}], "date": 1783922574, "git_changesets": ["bd91584d520a6f4310dcfbae0259043a95830cd4"], "user": "pchevrel@mozilla.com"}, "27416": {"changesets": [{"author": "Hiroyuki Ikezoe \u003chikezoe.birchill@mozilla.com\u003e", "branch": "default", "desc": "Bug 2034907 - Keep the visual and layout scroll offsets in sync in FrameMetrics::UpdatePendingScrollInfo.  a=pascalc\n\nUpdatePendingScrollInfo sets the layout scroll offset to the raw main-thread\ndestination and clamps the visual scroll offset independently, leaving the two\noffsets in an inconsistent relationship. The two clamps disagree at sub-pixel\nprecision: the main thread clamps the destination in app units while\nCalculateScrollRange() clamps in CSS pixels (subtracting after converting,\nlanding on an adjacent float at a scroll extreme). For non-root content that\nleaves the visual and layout offsets a ULP apart, violating the invariant that\nthey coincide and tripping the assertion in UpdatePendingScrollInfo; the same\nindependent-clamp inconsistency also affects the layout-encloses-visual\nrelationship on root content.\n\nRe-establish the proper layout/visual relationship via\nRecalculateLayoutViewportOffset(), the same way every other visual-offset\nmutator does (e.g. AsyncPanZoomController::SetVisualScrollOffset).\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307420\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311749\n", "files": ["gfx/layers/FrameMetrics.cpp", "gfx/layers/apz/test/gtest/TestFrameMetrics.cpp", "gfx/layers/apz/test/gtest/moz.build"], "git_node": "b46d4b58a4c716a6314b550ed5e2de2de6a8e72a", "git_parents": ["bd91584d520a6f4310dcfbae0259043a95830cd4"], "node": "daeaaa4fc5ae3b179f711dc5fdc11a733cd8cea2", "parents": ["e2b21af095436d08beebf56fd99e4cb4ff427c4e"], "tags": []}], "date": 1783922783, "git_changesets": ["b46d4b58a4c716a6314b550ed5e2de2de6a8e72a"], "user": "pchevrel@mozilla.com"}, "27417": {"changesets": [{"author": "David Parks \u003cdaparks@mozilla.com\u003e", "branch": "default", "desc": "Bug 2052060: Check a received IStream's data length on Windows  a=pascalc\n\nSanity check for the length of an IStream read.  Also now removes partial files\nin the event of an error.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D310208\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311630\n", "files": ["widget/windows/nsClipboard.cpp"], "git_node": "2c390d80bfda9a4a231e402fdb1d9fe344420b71", "git_parents": ["b46d4b58a4c716a6314b550ed5e2de2de6a8e72a"], "node": "e77e8e4c388da194d50b8d41b3ed4923a1dea23a", "parents": ["daeaaa4fc5ae3b179f711dc5fdc11a733cd8cea2"], "tags": []}], "date": 1783923479, "git_changesets": ["2c390d80bfda9a4a231e402fdb1d9fe344420b71"], "user": "pchevrel@mozilla.com"}, "27418": {"changesets": [{"author": "Tooru Fujisawa \u003carai_a@mac.com\u003e", "branch": "default", "desc": "Bug 2050662 - Prevent relazification while the BytecodeRange is used.  a=pascalc\n\nGiven JSScript::AutoDelazify has been unused, modified it to more specific to\nthe case where the script already has the bytecode.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D311030\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311617\n", "files": ["js/src/jit-test/tests/debug/Script-getAllOffsets.js", "js/src/vm/BytecodeUtil-inl.h", "js/src/vm/JSScript.cpp", "js/src/vm/JSScript.h"], "git_node": "2d3f51cea64180599b215aeacee07d05e759137c", "git_parents": ["2c390d80bfda9a4a231e402fdb1d9fe344420b71"], "node": "a5635106585b2e08c7b35b3483869b503c44655f", "parents": ["e77e8e4c388da194d50b8d41b3ed4923a1dea23a"], "tags": []}], "date": 1783923524, "git_changesets": ["2d3f51cea64180599b215aeacee07d05e759137c"], "user": "pchevrel@mozilla.com"}, "27419": {"changesets": [{"author": "Alexandre Poirot \u003cpoirot.alex@gmail.com\u003e", "branch": "default", "desc": "Bug 2051247 - [devtools] Show (correct) stylesheet text content when using Local Mode or Network override.  a=pascalc\n\nNetworkObserver codebase makes it hard to only trigger Override and\nLocalMode hooks for DevTools requests.\nSo start observing DevTools requests in light of upcoming bug 2038986\nand ignore them in the frontend until we have proper frontend\nimplementation.\n\nWent for this intermediate simpler approach in order to try to uplift\nthis patch for make the style editor work when using local mode.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D310056\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311327\n", "files": ["devtools/client/netmonitor/src/connector/firefox-data-provider.js", "devtools/client/netmonitor/test/browser_mz.toml", "devtools/client/netmonitor/test/browser_net_overrides_with_styleeditor.js", "devtools/client/styleeditor/test/browser.toml", "devtools/client/styleeditor/test/browser_styleeditor_local_mode.js", "devtools/client/webconsole/webconsole-ui.js", "devtools/shared/network-observer/NetworkUtils.sys.mjs"], "git_node": "f1131f215fdaa8ac818b8f54b2c8ef8848d9b356", "git_parents": ["2d3f51cea64180599b215aeacee07d05e759137c"], "node": "dccb14589a6b46f2ef34cf97c3adcf1defb3b917", "parents": ["a5635106585b2e08c7b35b3483869b503c44655f"], "tags": []}, {"author": "Alexandre Poirot \u003cpoirot.alex@gmail.com\u003e", "branch": "default", "desc": "Bug 2052176 - [devtools] Save stylesheet to local mode folder files.  a=pascalc\n\nStyleEditor was still asking for a local path to save css files served\nfrom Local Mode. This is unfortunate as we can easily guess it.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D310104\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311328\n", "files": ["devtools/client/framework/LocalModeMappings.sys.mjs", "devtools/client/styleeditor/StyleEditorUI.sys.mjs", "devtools/client/styleeditor/test/browser_styleeditor_local_mode.js"], "git_node": "6fa0151afdf3f94314de9ab6fee41e08882e6b2f", "git_parents": ["f1131f215fdaa8ac818b8f54b2c8ef8848d9b356"], "node": "6a82c655f089e9327b62131ead585035eb0fb1eb", "parents": ["dccb14589a6b46f2ef34cf97c3adcf1defb3b917"], "tags": []}], "date": 1783925913, "git_changesets": ["f1131f215fdaa8ac818b8f54b2c8ef8848d9b356", "6fa0151afdf3f94314de9ab6fee41e08882e6b2f"], "user": "pchevrel@mozilla.com"}, "27420": {"changesets": [{"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 2052207 - Make OptimizeIteratorIndices optimization more robust.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D310355\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311515\n", "files": ["js/src/jit/IonAnalysis.cpp", "js/src/jit/MacroAssembler.cpp"], "git_node": "9e5f1415c83f58bb3bb2cfc1a40e0c5172e6b004", "git_parents": ["6fa0151afdf3f94314de9ab6fee41e08882e6b2f"], "node": "83b09d75d08d0ccca8f5cee667442abc36a82e84", "parents": ["6a82c655f089e9327b62131ead585035eb0fb1eb"], "tags": []}], "date": 1783928261, "git_changesets": ["9e5f1415c83f58bb3bb2cfc1a40e0c5172e6b004"], "user": "pchevrel@mozilla.com"}, "27421": {"chan