_WeatherFeed.js"], "git_node": "2b226d363b14fc2cd1aeeaab43c0b8c49a7ef7f6", "git_parents": ["bafd12763c895250c88f5c07cfacf17f22a9b2de"], "node": "37b8c785428e9f287c919e3c8afe6d8d34d7d85c", "parents": ["7a2d018292319513a472675254a45180de1b3a70"], "tags": []}], "date": 1781802407, "git_changesets": ["2b226d363b14fc2cd1aeeaab43c0b8c49a7ef7f6"], "user": "pchevrel@mozilla.com"}, "26942": {"changesets": [{"author": "Pascal Chevrel \u003cpascal@mozilla.com\u003e", "branch": "default", "desc": "Revert \"Bug 2034406 - Preserve vector commands in MozPrintCallback. r=lsalzman\" from beta at developer's request a=pascalc\n\nThis reverts commit a49a71cc6e3e96b3e6f50f61f8ba99aeb300873e.\n", "files": ["gfx/2d/2D.h", "gfx/2d/DrawTargetRecording.cpp", "gfx/2d/DrawTargetRecording.h", "layout/generic/nsHTMLCanvasFrame.cpp", "layout/generic/nsPageSequenceFrame.cpp", "layout/generic/nsPageSequenceFrame.h"], "git_node": "1fe0ec5ab47988259b2444ac69156585430ce4e3", "git_parents": ["2b226d363b14fc2cd1aeeaab43c0b8c49a7ef7f6"], "node": "7bc85398f24c6e379259e89856b905cd068febb2", "parents": ["37b8c785428e9f287c919e3c8afe6d8d34d7d85c"], "tags": []}], "date": 1781802913, "git_changesets": ["1fe0ec5ab47988259b2444ac69156585430ce4e3"], "user": "pchevrel@mozilla.com"}, "26943": {"changesets": [{"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 2047758 - Don't report string counts under explicit.  a=pascalc DONTBUILD\n\nPaths that start with explicit/ need to be actual memory measurements.\nThis patch changes the string count to be put at the top level of counts.\nI also changed the description to be a bit more direct about what we\nare measuring. All of the string counts from the different zones will\nget dumped together and it'll be a little harder to discern that the\nnotable string finder was cut off, because it won't be near the reporting\nfor the zone, like I think was the intent, but it is probably okay.\n\nI tested this by changing the string budget to 1 microsecond.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307143\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307594\n", "files": ["js/xpconnect/src/XPCJSRuntime.cpp"], "git_node": "5abb676f0fbd57cf574f45533f3d1609d0a07b84", "git_parents": ["1fe0ec5ab47988259b2444ac69156585430ce4e3"], "node": "2987aec45d7813ac30039fc95cc47f6b5ec80bf8", "parents": ["7bc85398f24c6e379259e89856b905cd068febb2"], "tags": []}], "date": 1781807506, "git_changesets": ["5abb676f0fbd57cf574f45533f3d1609d0a07b84"], "user": "pchevrel@mozilla.com"}, "26944": {"changesets": [{"author": "pollymce \u003cpmceldowney@mozilla.com\u003e", "branch": "default", "desc": "Bug 2047940: Refine longfox CTA.  a=pascalc\n\nWhen the button is going to launch longfox, changed the button text to \"help catch trackers\" and the animated TypewriterText to \"tap to play!\" These are the best strings we have available for 153. Hopefully they make it a bit clearer what is going to happen when you hit the button. Additionally, trimmed the padding underneath: this was a hangover from when the animated text was a CTA to launch longfox. We don't need that any more and it's pushing the other home page content down.\n\nBefore\n\n\u003cimg width=\"108\" height=\"234\" alt=\"image\" src=\"https://github.com/user-attachments/assets/6e844c0e-8747-4225-89de-e3aaf507c0ea\" /\u003e\n\u003cimg width=\"108\" height=\"234\" alt=\"image\" src=\"https://github.com/user-attachments/assets/798742a8-6454-40d2-99ad-97adda2dcde9\" /\u003e\n\nAfter\n\n\u003cimg width=\"108\" height=\"234\" alt=\"after-no-peek\" src=\"https://github.com/user-attachments/assets/b1e36f8a-3b13-470a-ba19-69a4ff03eb62\" /\u003e\n\u003cimg width=\"108\" height=\"234\" alt=\"after-with-peek\" src=\"https://github.com/user-attachments/assets/1983d8e3-ce7e-4b55-b9f0-2f6aedb18d29\" /\u003e\n\nPull request: https://github.com/mozilla-firefox/firefox/pull/293\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307557\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/trackingprotection/TrackersBlockedCard.kt"], "git_node": "f656821d4087d5c3f820d8e7df32a12a671fb51c", "git_parents": ["5abb676f0fbd57cf574f45533f3d1609d0a07b84"], "node": "3bb2c45f1f3a1d36ec7806854774370908fab826", "parents": ["2987aec45d7813ac30039fc95cc47f6b5ec80bf8"], "tags": []}], "date": 1781807571, "git_changesets": ["f656821d4087d5c3f820d8e7df32a12a671fb51c"], "user": "pchevrel@mozilla.com"}, "26945": {"changesets": [{"author": "Leo Tenenbaum \u003cltenenbaum@mozilla.com\u003e", "branch": "default", "desc": "Bug 2047718 - Check for unexpected DOM changes in more places in EnsureNoInvisibleWhiteSpaces.  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306863\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307553\n", "files": ["editor/libeditor/WhiteSpaceVisibilityKeeper.cpp"], "git_node": "a07ce9297cad492c4131cc989091a55592886d87", "git_parents": ["f656821d4087d5c3f820d8e7df32a12a671fb51c"], "node": "0ef89759b88112e852dcb9fd78d21421e6b39c43", "parents": ["3bb2c45f1f3a1d36ec7806854774370908fab826"], "tags": []}], "date": 1781807628, "git_changesets": ["a07ce9297cad492c4131cc989091a55592886d87"], "user": "pchevrel@mozilla.com"}, "26946": {"changesets": [{"author": "Jonathan Sudiaman \u003cjsudiaman@mozilla.com\u003e", "branch": "default", "desc": "Bug 2043614 - Fix history search not working when sorting by \"Website and date\" or \"Last visited\"  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305868\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307545\n", "files": ["browser/components/firefoxview/HistoryController.sys.mjs", "browser/components/sidebar/tests/browser/browser_history_sidebar.js", "toolkit/components/places/PlacesQuery.sys.mjs"], "git_node": "4c3e8e3f79a4a7ec913c1013400c17bd7031713e", "git_parents": ["a07ce9297cad492c4131cc989091a55592886d87"], "node":