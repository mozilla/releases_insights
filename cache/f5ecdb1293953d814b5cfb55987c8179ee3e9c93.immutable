.services.mozilla.com/D307348\n", "files": ["browser/components/aiwindow/ui/test/browser/browser_smartwindow_smartbar_model_select.js", "browser/components/aiwindow/ui/test/browser/head.js"], "git_node": "38ae2a4835e87110a0d6a0a3b1406bd1ac75ab9c", "git_parents": ["b696c1d90a8aec8ec2456a578c4437d03ddaf1e2"], "node": "5877b9f47fd14868df948948a28ed315257df4d4", "parents": ["6da3ba0a571a1842c669c8497b846ed541c2cde3"], "tags": []}, {"author": "Florian Zia \u003cfzia@mozilla.com\u003e", "branch": "default", "desc": "Bug 2044641 - Track the selected smartbar model override per tab  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D304967\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307349\n", "files": ["browser/components/aiwindow/models/Utils.sys.mjs", "browser/components/aiwindow/ui/components/ai-window/ai-window.mjs", "browser/components/aiwindow/ui/modules/AIWindowTabStatesManager.sys.mjs", "browser/components/aiwindow/ui/modules/AIWindowUI.sys.mjs", "browser/components/aiwindow/ui/test/browser/browser_smartwindow_smartbar_model_select.js", "browser/components/aiwindow/ui/test/browser/head.js"], "git_node": "4d4f67c6eefe96450ddb6e088cb3e17b7cfa44f0", "git_parents": ["38ae2a4835e87110a0d6a0a3b1406bd1ac75ab9c"], "node": "6cabddf97277e8ff78fbe831b1b793869dfbdea9", "parents": ["5877b9f47fd14868df948948a28ed315257df4d4"], "tags": []}], "date": 1782106270, "git_changesets": ["a5199a9aa87e72ab3d054d0ade44490946a342e1", "b696c1d90a8aec8ec2456a578c4437d03ddaf1e2", "38ae2a4835e87110a0d6a0a3b1406bd1ac75ab9c", "4d4f67c6eefe96450ddb6e088cb3e17b7cfa44f0"], "user": "pchevrel@mozilla.com"}, "26983": {"changesets": [{"author": "Florian Zia \u003cfzia@mozilla.com\u003e", "branch": "default", "desc": "Bug 2045884 - Animate smartbar placeholder on New Tab only  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306418\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307350\n", "files": ["browser/components/aiwindow/ui/components/ai-window/ai-window.mjs", "browser/components/aiwindow/ui/test/browser/browser.toml", "browser/components/aiwindow/ui/test/browser/browser_aiwindow_smartbar_placeholder.js", "browser/components/aiwindow/ui/test/browser/head.js", "browser/components/urlbar/content/SmartbarInputUtils.mjs"], "git_node": "17df48b3d86ee08f65c434260d7f815ec24bc8b5", "git_parents": ["4d4f67c6eefe96450ddb6e088cb3e17b7cfa44f0"], "node": "b318f907c11585038e6b74e1b38fac1a7498e497", "parents": ["6cabddf97277e8ff78fbe831b1b793869dfbdea9"], "tags": []}], "date": 1782106294, "git_changesets": ["17df48b3d86ee08f65c434260d7f815ec24bc8b5"], "user": "pchevrel@mozilla.com"}, "26984": {"changesets": [{"author": "Matthew Gregan \u003ckinetik@flim.org\u003e", "branch": "default", "desc": "Bug 2042033 - Update audioipc to c9dcbaee1624daad2fa6b1445fd047efde4f1ec0.  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305421\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307447\n", "files": [".cargo/config.toml.in", "Cargo.lock", "third_party/rust/audioipc2-client/.cargo-checksum.json", "third_party/rust/audioipc2-client/src/context.rs", "third_party/rust/audioipc2-client/src/stream.rs", "third_party/rust/audioipc2-server/.cargo-checksum.json", "third_party/rust/audioipc2-server/src/server.rs", "third_party/rust/audioipc2/.cargo-checksum.json", "third_party/rust/audioipc2/src/messages.rs", "toolkit/library/rust/shared/Cargo.toml"], "git_node": "cee317127bddbc4f38b7234b6840937f6ab087c8", "git_parents": ["17df48b3d86ee08f65c434260d7f815ec24bc8b5"], "node": "c1001da63d178a50cda866b33acffed68039bbac", "parents": ["b318f907c11585038e6b74e1b38fac1a7498e497"], "tags": []}], "date": 1782106314, "git_changesets": ["cee317127bddbc4f38b7234b6840937f6ab087c8"], "user": "pchevrel@mozilla.com"}, "26985": {"changesets": [{"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 2045172 - Make `ContentEventHandler` ignore selection ranges outside the ancestor limiter  a=pascalc DONTBUILD\n\nAll selection ranges should be in the ancestor limiter when it's set.\nHowever, due to bug 2046677, we don't dispatch `eBlur` event and\n`HTMLEditor` cannot reset the ancestor limiter with treating itself as\nblurred. Fixing it requires risky changes. Therefore, this patch makes\n`ContentEventHandler` ignores the invalid ranges for now to avoid\nthe assertion failures in `ContentCacheInChild`.\n\nAdditionally, this fixes `nsINode::GetSelectionRootContent()` and\n`nsFrameSelection::SetAncestorLimiter()` which may trigger the similar\nsituation and we can fix it safer.\n\n`nsINode::GetSelectionRootContent()`:\nWhen moving selection into `contenteditable=\"false\"` element in an\nediting host may not cause `blur` event. Therefore, the ancestor limiter\nshould be the editing host even if the target node of the examination is\nnot editable.\n\n`nsFrameSelection::SetAncestorLimiter()`:\nIt checks only the focus node is in the new ancestor limiter. However,\nnon-primary ranges may be outside of the limiter and the range may\nhave crossed the range ancestor limiter's element boundaries.\nTherefore, this method should check whether all ranges are valid for\nthe new ancestor limiter.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306596\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307459\n", "files": ["dom/base/FragmentOrElement.cpp", "dom/base/Selection.h", "dom/base/nsIContent.h", "dom/base/nsINode.cpp", "dom/base/nsINode.h", "dom/events/ContentEventHandler.cpp", "dom/events/ContentEventHandler.h", "editor/libeditor/HTMLEditor.cpp", "layout/base/nsDocumentViewer.cpp", "layout/generic/nsFrameSelection.cpp", "layout/generic/nsFrameSelection.h", "testing/web-platform/tests/editing/crashtests/move-focused-editing-host-and-add-selection-range-to-another-editing-host-behind-dialog.html", "widget/ContentCache.cpp"], "git_node": "3dc04f1d82dec0c57909d8e947d94501f14e3d3d", "git_parents": ["cee317127bddbc4f38b7234b6840937f6ab087c8"], "node": "bf67e79e54c12675e49fe873c05a21de2b5e1786", "parents": ["c1001da63d178a50cda866b33acffed68039bbac"], "tags": []}], "date": 1782106335, "git_changesets": ["3dc04f1d82dec0c57909d8e947d94501f14e3d3d"], "user": "pchevrel@mozilla.com"}, "26986": {"changesets": [{"author": "Greg Stoll \u003cgreg@gregstoll.com\u003e", "branch": "default", "desc": "Bug 2047275 - fix cross-compile unified build  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307297\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307462\n", "files": ["dom/webserial/PosixSerialPlatformService.cpp"], "git_node": "7a47031149d5f2843da335a46e5c6cc7da736575", "git_parents": ["3dc04f1d82dec0c57909d8e947d94501f14e3d3d"], "node": "a9ff4d14be29b79b8c52be729012fbc4eda97f43", "parents": ["bf67e79e54c12675e49fe873c05a21de2b5e1786"], "tags": []}], "date": 1782106360, "git_changesets": ["7a47031149d5f2843da335a46e5c6cc7da736575"], "user": "pchevrel@mozilla.com"}, "26987": {"changesets": [{"author": "Alexandra Borovova \u003caborovova@mozilla.com\u003e", "branch": "default", "desc": "Bug 2046390 - [webdriver-bidi] Apply preload scripts and geolocation override only on \"content-document-global-created\" for the window with the correct innerWindowId.  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306979\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307493\n", "files": ["remote/webdriver-bidi/modules/windowglobal/_configuration.sys.mjs"], "git_node": "79eaf92ad1820df0abf1c3c87b1de6194e68afc8", "git_parents": ["7a47031149d5f2843da335a46e5c6cc7da736575"], "node": "b9cc8af96a182e38c37a777d7149c6ac1b71d568", "parents": ["a9ff4d14be29b79b8c52be729012fbc4eda97f43"], "tags": []}], "date": 1782106796, "git_changesets": ["79eaf92ad1820df0abf1c3c87b1de6194e68afc8"], "user": "pchevrel@mozilla.com"}, "26988": {"changesets": [{"author": "Andrew Overholt \u003coverholt@mozilla.com\u003e", "branch": "default", "desc": "Bug 2044674 - Force LTR direction for QR code URL so it displays correctly in RTL builds.  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D304899\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307592\n", "files": ["browser/components/qrcode/qrcode-dialog.html", "browser/components/qrcode/test/browser/browser_qrcode_share_menu.js"], "git_node": "961c4f35a9fcceaaa8b33cc69cfab7cbadf13f8b", "git_parents": ["79eaf92ad1820df0abf1c3c87b1de6194e68afc8"], "node": "03f8020db2fcf87d323ef17d1947aed26d7c7bf6", "parents": ["b9cc8af96a182e38c37a777d7149c6ac1b71d568"], "tags": []}], "date": 1782106891, "git_changesets": ["961c4f35a9fcceaaa8b33cc69cfab7cbadf13f8b"], "user": "pchevrel@mozilla.com"}, "26989": {"changesets": [{"author": "mandysGit \u003cmcheang@mozilla.com\u003e", "branch": "default", "desc": "Bug 2030299 - Order token alias engine results by duplicate-alias precedence.  a=pascalc\n\nWhen multiple engines have the same alias, the keyword offer\nresults are now ordered by precedence used to resolve\nduplicate aliases: default engine, private default, appProvided\nengines, then any others (add-on, OpenSearch, user).\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307077\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307633\n", "files": ["browser/components/urlbar/UrlbarSearchUtils.sys.mjs", "browser/components/urlbar/tests/browser/browser_tokenAlias.js"], "git_node": "1443377d28ce724847863585fa4d6da65fd95994", "git_parents": ["961c4f35a9fcceaaa8b33cc69cfab7cbadf13f8b"], "node": "69ee55ab4b16d8ead166b6040d2993c42981c8c9", "parents": ["03f8020db2fcf87d323ef17d1947aed26d7c7bf6"], "tags": []}], "date": 1782106973, "git_changesets": ["1443377d28ce724847863585fa4d6da65fd95994"], "user": "pchevrel@mozilla.com"}, "26990": {"changesets": [{"author": "Timothy Nikkel \u003ctnikkel@gmail.com\u003e", "branch": "default", "desc": "Bug 2045159. Invalidate the scrolled rect cache when ScrollToImpl recomputes perspective overflow.  a=pascalc DONTBUILD\n\nBug 2044231 started using an AutoScrolledRectCache during\nScrollContainerFrame::ReflowFinished so the several GetScrolledRect() calls\nthere share a single computation. In debug builds the cache asserts that the\nscrolled rect stays constant while it is alive.\n\nReflowFinished calls ScrollToRestoredPosition (and a clamping ScrollToImpl)\nwhile the cache is alive. When the scroll container has perspective\ndescendants, ScrollToImpl calls RecomputePerspectiveChildrenOverflow, which\nrecomputes those descendants' overflow (it depends on the scroll position) and\nthereby changes mScrolledFrame's scrollable overflow. That overflow is an input\nto ComputeScrolledRect, so the scrolled rect legitimately changes while the\ncache is alive, and the UpdateOverflow() on the next line reads it back through\nthe cache and asserts.\n\nInvalidate the cache as soon as RecomputePerspectiveChildrenOverflow reports a\nchange, before the UpdateOverflow() that reads the rect, so that it (and any\nlater GetScrolledRect() calls in ReflowFinished) recompute the new value.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307937\n", "files": ["layout/generic/ScrollContainerFrame.cpp", "layout/generic/ScrollContainerFrame.h", "testing/web-platform/tests/css/css-transforms/crashtests/zero-perspective-002.html"], "git_node": "19c08599511501022ab12456832c36f1e120ce28", "git_parents": ["1443377d28ce724847863585fa4d6da65fd95994"], "node": "7138bb909edff97ca85930f1ac41ceeb794d8bf5", "parents": ["69ee55ab4b16d8ead166b6040d2993c42981c8c9"], "tags": []}], "date": 1782107282, "git_changesets": ["19c08599511501022ab12456832c36f1e120ce28"], "user": "pchevrel@mozilla.com"}, "26991": {"changesets": [{"author": "Michael Hynson \u003cmhynson@mozilla.com\u003e", "branch": "default", "desc": "Bug 2046492 - Fix VPN toolbar button width in Customize Mode.  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306024\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307904\n", "files": ["browser/themes/shared/toolbarbuttons.css"], "git_node": "d96580229be62c9943a87a85317dfb7cffbb2c94", "git_parents": ["19c08599511501022ab12456832c36f1e120ce28"], "node": "db2fdd832156cd67c7583f66f18156532314c531", "parents": ["7138bb909edff97ca85930f1ac41ceeb794d8bf5"], "tags": []}], "date": 1782107329, "git_changesets": ["d96580229be62c9943a87a85317dfb7cffbb2c94"], "user": "pchevrel@mozilla.com"}, "26992": {"changesets": [{"author": "John Lin \u003cjolin@mozilla.com\u003e", "branch": "default", "desc": "Bug 2047221 - validate crypto info before decoding.  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306897\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307877\n", "files": ["dom/media/MediaFormatReader.cpp"], "git_node": "48bbbb799e54a3c8468ecbf159e6594b10082359", "git_parents": ["d96580229be62c9943a87a85317dfb7cffbb2c94"], "node": "63eb0a02b9b1c5dd5102a9931880e57d3828e289", "parents": ["db2fdd832156cd67c7583f66f18156532314c531"], "tags": []}], "date": 1782107378, "git_changesets": ["48bbbb799e54a3c8468ecbf159e6594b10082359"], "user": "pchevrel@mozilla.com"}, "26993": {"changesets": [{"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 2045612 - Take ownership of the state in RestoreFormControlState.  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307613\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307825\n", "files": ["dom/html/nsGenericHTMLElement.cpp", "layout/base/nsILayoutHistoryState.idl", "layout/base/nsLayoutHistoryState.cpp"], "git_node": "136c4a35491bc51173c4df6fe35eb6bc546e3c99", "git_parents": ["48bbbb799e54a3c8468ecbf159e6594b10082359"], "node": "d6723b7312e8a1a3a4bdbee68df5d2df8ce3582e", "parents": ["63eb0a02b9