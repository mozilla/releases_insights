2d049"], "tags": []}], "date": 1782267360, "git_changesets": ["89e4be25edc6a532c260aed0a4405d615291c4cf"], "user": "ffxbld@lando.moz.tools"}, "27059": {"changesets": [{"author": "Stephanie Cunnane \u003cscunnane@mozilla.com\u003e", "branch": "default", "desc": "Bug 2047491 - Ensure CTRL+SHIFT+up/down reorders items correctly in moz-reorderable-lists.  a=pascalc DONTBUILD\n\nBug 2038148 fixed a moz-box-group item reordering bug. It handled item reordering via the mouse but missed the keyboard reordering case. This patch covers the keyboard reordering case.\n\nNote that in several places I've switched to working with engine ids vs. engine names. In the search service code, we are making a concerted effort to prefer engine ids to engine names, as engine ids are the more robust property to work with.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306819\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308303\n", "files": ["browser/components/preferences/tests/search/browser_search_engine_reorder.js", "toolkit/content/tests/widgets/test_moz_reorderable_list.html", "toolkit/content/widgets/moz-box-group/moz-box-group.mjs", "toolkit/content/widgets/moz-reorderable-list/moz-reorderable-list.mjs"], "git_node": "99a59ab81610b1b2a5c695d1f068dc8f813ca548", "git_parents": ["89e4be25edc6a532c260aed0a4405d615291c4cf"], "node": "80188d29af1daf3f8cbf80718e9fbb2f18b1b3f3", "parents": ["a73702898a87d3bd641becd31498668f349280c2"], "tags": []}], "date": 1782278569, "git_changesets": ["99a59ab81610b1b2a5c695d1f068dc8f813ca548"], "user": "pchevrel@mozilla.com"}, "27060": {"changesets": [{"author": "Morgan Rae Reschenberg \u003cmreschenberg@berkeley.edu\u003e", "branch": "default", "desc": "Bug 2043503: Update document accessible bounds when the body has its own accessible  a=pascalc DONTBUILD\n\nBounds for a doc acc are derived from the frame of that document's root content. When that root content has its own accessible, the update queued [here](https://searchfox.org/firefox-main/rev/6bf7902103ad0177a215d8cb494fcb923f5c3e57/accessible/base/nsAccessibilityService.cpp#607) refreshes that accessible but not the document itself. We need to ensure _both_ are updated.\n\nThis causes problems when hittesting because ChildAtPoint causes BoundsWithOffset to [mask every descendant against this rect](https://searchfox.org/firefox-main/rev/6bf7902103ad0177a215d8cb494fcb923f5c3e57/accessible/ipc/RemoteAccessible.cpp#1033-1043) when hit-testing, making the message body (and any content inside it) impossible to hittest when that rect has stale bounds.\n\nThere are a few cases to be concerned about here, and I've enumerated them in the comment below in nsAccessibilityService.cpp. I've also added two new tests. `bodyIsDocAcc` is a test that passes both with and without this patch, but should serve as a regression test for the future. `bodyIsOwnAcc` is the version that fails without the associated .cpp change.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307662\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308333\n", "files": ["accessible/base/nsAccessibilityService.cpp", "accessible/tests/browser/bounds/browser.toml", "accessible/tests/browser/bounds/browser_test_iframe_body_doc_bounds.js"], "git_node": "23406e9f863105d44e097bf14bcd77c00d88cdab", "git_parents": ["99a59ab81610b1b2a5c695d1f068dc8f813ca548"], "node": "d0dd14a3866f57365c15495bf4bb20fb9af85daa", "parents": ["80188d29af1daf3f8cbf80718e9fbb2f18b1b3f3"], "tags": []}], "date": 1782278612, "git_changesets": ["23406e9f863105d44e097bf14bcd77c00d88cdab"], "user": "pchevrel@mozilla.com"}, "27061": {"changesets": [{"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 2047729.  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307935\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308334\n", "files": ["gfx/2d/DrawTargetSkia.cpp"], "git_node": "10af25ef1d22085a4de2dfbc683b97859332ea19", "git_parents": ["23406e9f863105d44e097bf14bcd77c00d88cdab"], "node": "2ca5366ff45dfe58258bece9ede05229ac11d7a9", "parents": ["d0dd14a3866f57365c15495bf4bb20fb9af85daa"], "tags": []}], "date": 1782278670, "git_changesets": ["10af25ef1d22085a4de2dfbc683b97859332ea19"], "user": "pchevrel@mozilla.com"}, "27062": {"changesets": [{"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 2045741.  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306315\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308336\n", "files": ["dom/canvas/WebGLProgram.cpp"], "git_node": "1755285ee0b786c419fd1ba0f8fc0e7874310125", "git_parents": ["10af25ef1d22085a4de2dfbc683b97859332ea19"], "node": "32d28532067435ae848623c3890cb782fb17301d", "parents": ["2ca5366ff45dfe58258bece9ede05229ac11d7a9"], "tags": []}], "date": 1782278755, "git_changesets": ["1755285ee0b786c419fd1ba0f8fc0e7874310125"], "user": "pchevrel@mozilla.com"}, "27063": {"changesets": [{"author": "Duncan McIntosh \u003cdmcintosh@mozilla.com\u003e", "branch": "default", "desc": "Bug 2046553 - Set the 'install_timeout' telemetry field if the stub installer exit code is ERR_INSTALL_TIMEOUT.  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305971\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308345\n", "files": ["browser/installer/windows/nsis/telemetry.nsh"], "git_node": "131f23426fe82dea19b9983e476c847119f9cbbe", "git_parents": ["1755285ee0b786c419fd1ba0f8fc0e7874310125"], "node": "7a82d5c5f7572c53d5d6e049c37b01d5fd25e4f0", "parents": ["32d28532067435ae848623c3890cb782fb17301d"], "tags": []}], "date": 1782278817, "git_changesets": ["131f23426fe82dea19b9983e476c847119f9cbbe"], "user": "pchevrel@mozilla.com"}, "27064": {"changesets": [{"author": "Chun-Min Chang \u003cchun.m.chang@gmail.com\u003e", "branch": "default", "desc": "Bug 2045765 - pick commit bb497995ec67b7bb7ec5b519ed56e9de54d27d39 for soundtouch  a=pascalc DONTBUILD\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307875\n", "files": ["media/libsoundtouch/firfilter-max-channels.patch", "media/libsoundtouch/moz.yaml", "media/libsoundtouch/src/FIRFilter.cpp"], "git_node": "93494bfd9b0d6fb438c44c3e542f05c78e76360b", "git_parents": ["131f23426fe82dea19b9983e476c847119f9cbbe"], "node": "f39bfdb6bb3325d67c48b5bceec8da05266d1532", "parents": ["7a82d5c5f7572c53d5d6e049c37b01d5fd25e4f0"], "tags": []}], "date": 1782279482, "git_changesets": ["93494bfd9b0d6fb438c44c3e542f05c78e76360b"], "user": "pchevrel@mozilla.com"}, "27065": {"changesets": [{"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 2047957: Ensure cached line start offsets are valid.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307467\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308428\n", "files": ["accessible/base/TextLeafRange.cpp"], "git_node": "c01f1cc701efb3a190304b67603df0d78dd9aec5", "git_parents": ["93494bfd9b0d6fb438c44c3e542f05c78e76360b"], "node": "8f33466558b6ec1bce49260f4ec16126763ba374", "parents": ["f39bfdb6bb3325d67c48b5bceec8da05266d1532"], "tags": []}], "date": 1782279508, "git_changesets": ["c01f1cc701efb3a190304b67603df0d78dd9aec5"], "user": "pchevrel@mozilla.com"}, "27066": {"changesets": [{"author": "Shravan Narayan \u003cshravanrn@gmail.com\u003e", "branch": "default", "desc": "Bug 2048557 - Ensure rlbox_wasm2c calls to libc clock use macros for clock IDs r=gaston,mccr8 a=pascalc DONTBUILD\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308154\n", "files": ["third_party/rlbox_wasm2c_sandbox/src/wasm2c_rt_minwasi.c"], "git_node": "13048ba26f37eabb60a88af3b9df6230574e37e2", "git_parents": ["c01f1cc701efb3a190304b67603df0d78dd9aec5"], "node": "22a10f22c52fd5eca6bee69068c2b63f66ba644a", "parents": ["8f33466558b6ec1bce49260f4ec16126763ba374"], "tags": []}], "date": 1782283163, "git_changesets": ["13048ba26f37eabb60a88af3b9df6230574e37e2"], "user": "pchevrel@mozilla.com"}, "27067": {"changesets": [{"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 2047864 - Use @color over ?attr values for colorControlActivated so activated controls tint on Android 11 and below  a=pascalc\n\n- On Android 11 and below, colorControlActivated tint utilizes ColorStateList to resolve the color and does not work with theme attributes. Use the direct color token instead of theme attributes.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307930\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308455\n", "files": ["mobile/android/fenix/app/src/main/res/values/styles.xml"], "git_node": "34da430958e78336c5a08d0001a8e9111082b902", "git_parents": ["13048ba26f37eabb60a88af3b9df6230574e37e2"], "node": "09fcf989bbe50660268911eca40b7eb3bb8e732a", "parents": ["22a10f22c52fd5eca6bee69068c2b63f66ba644a"], "tags": []}], "date": 1782285826, "git_changesets": ["34da430958e78336c5a08d0001a8e9111082b902"], "user": "pchevrel@mozilla.com"}, "27068": {"changesets": [{"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 2027519 - [devtools] Use the real source url for sourcemap resolution  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D304524\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308465\n", "files": ["devtools/server/actors/source.js"], "git_node": "9e9282659c0825cabc4305b4786016b6029c83a8", "git_parents": ["34da430958e78336c5a08d0001a8e9111082b902"], "node": "83e45349bcd513062bcffe46d2aed9710b7c7a29", "parents": ["09fcf989bbe50660268911eca40b7eb3bb8e732a"], "tags": []}], "date": 1782285890, "git_changesets": ["9e9282659c0825cabc4305b4786016b6029c83a8"], "user": "pchevrel@mozilla.com"}, "27069": {"changesets": [{"author": "Calixte Denizet \u003ccalixte.denizet@gmail.com\u003e", "branch": "default", "desc": "Bug 2037770 - Honor iframe sandbox flags when handling pdf.js downloads  a=pascalc DONTBUILD\n\nCherry pick pdf.js changes from https://github.com/mozilla/pdf.js/commit/ece1e2ed0c58eb9641da33259d958fa9122b5804.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308463\n", "files": ["toolkit/components/pdfjs/content/PdfStreamConverter.sys.mjs", "toolkit/components/pdfjs/content/web/viewer-geckoview.mjs", "toolkit/components/pdfjs/content/web/viewer.mjs", "toolkit/components/pdfjs/test/browser.toml", "toolkit/components/pdfjs/test/browser_pdfjs_sandboxed_iframe.js", "toolkit/components/pdfjs/test/file_pdfjs_csp.sjs", "toolkit/components/pdfjs/test/file_pdfjs_csp_sandbox_opener.html", "toolkit/components/pdfjs/test/file_pdfjs_csp_sandbox_opener.html^headers^"], "git_node": "6479271b47cc16351415ac18f1b47b8b01e736e4", "git_parents": ["9e9282659c0825cabc4305b4786016b6029c83a8"], "node": "59cb83929071dba4ab4dfea8bea7757f3bb9e300", "parents": ["83e45349bcd513062bcffe46d2aed9710b7c7a29"], "tags": []}], "date": 1782288584, "git_changesets": ["6479271b47cc16351415ac18f1b47b8b01e736e4"], "user": "pchevrel@mozilla.com"}, "27070": {"changesets": [{"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 2048934 - Make mInVisitHeaders checks reentrant  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308013\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308470\n", "files": ["netwerk/protocol/http/ReplacedHttpResponse.cpp", "netwerk/protocol/http/ReplacedHttpResponse.h", "netwerk/protocol/http/nsHttpRequestHead.cpp", "netwerk/protocol/http/nsHttpRequestHead.h", "netwerk/protocol/http/nsHttpResponseHead.cpp", "netwerk/protocol/http/nsHttpResponseHead.h"], "git_node": "465cdc8878ad2f30341af4d2d126f4be782217a5", "git_parents": ["6479271b47cc16351415ac18f1b47b8b01e736e4"], "node": "672f67b500f3306f84fcc7d868b9005fcbb5d866", "parents": ["59cb8392907