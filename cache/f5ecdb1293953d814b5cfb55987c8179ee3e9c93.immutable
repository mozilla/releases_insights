x/app/src/main/res/values/static_strings.xml", "mobile/android/fenix/app/src/main/res/values/strings.xml"], "git_node": "1e6ede938fcb1f92a13ec3fa619a196643eb2a68", "git_parents": ["0b7ed8fc2390000b745211325c2f424f160f7920"], "node": "21d8f9d8333061cf628871fafebfd9bd7a876f80", "parents": ["1d9caf7d9804e44da79b7e6c2832a00274f0f582"], "tags": []}], "date": 1781628490, "git_changesets": ["1e6ede938fcb1f92a13ec3fa619a196643eb2a68"], "user": "pchevrel@mozilla.com"}, "26890": {"changesets": [{"author": "Pascal Chevrel \u003cpascal@mozilla.com\u003e", "branch": "default", "desc": "Revert \"Bug 2044082 - Add updates for dynamic compact mode based on a configurable threshold pref r=sfoster,desktop-theme-reviewers,tabbrowser-reviewers,sclements\" in beta 153 a=pascalc\n\nThis reverts commit 69e7b8a242062446bd8ddc09affaaaf1dbc4f2a0.\n", "files": ["browser/app/profile/firefox.js", "browser/base/content/browser.js", "browser/components/customizableui/test/browser.toml", "browser/components/customizableui/test/browser_uidensity_auto_compact.js", "browser/components/sidebar/sidebar-main.css", "browser/themes/shared/sidebar.css", "browser/themes/shared/tabbrowser/tabs.css"], "git_node": "09ee49dc27873d98337861d60d50d7f923711113", "git_parents": ["1e6ede938fcb1f92a13ec3fa619a196643eb2a68"], "node": "8a3e8c3904d0bb91da1eedbd3ec749c4173f88ef", "parents": ["21d8f9d8333061cf628871fafebfd9bd7a876f80"], "tags": []}], "date": 1781629243, "git_changesets": ["09ee49dc27873d98337861d60d50d7f923711113"], "user": "pchevrel@mozilla.com"}, "26891": {"changesets": [{"author": "sarah541 \u003csarahkhan1107@hotmail.com\u003e", "branch": "default", "desc": "Bug 2047473 - Order the sports widget pager chronologically and open it on the live match  a=RyanVM\n\nThe pager reordered cards (live pinned first, Champion/Third-place and upcoming\nFinal pinned near the front). Show them in natural chronological order instead -\noldest past, through live, to the latest upcoming - and surface the relevant card\nby scrolling to it rather than reordering.\n\nMatchCardBuilder now returns the chronological card list (removed orderedForPager\nand its CardBucket / bucket / isBracketFinishing helpers). sportsCardPages computes\nthe page to open on - first live, else first upcoming, else the last card - and\nSportsCardPager scrolls there. The landing happens once per composition against a\nprocess-scoped record of the user's last-settled page, so a freshly built widget\n(a new tab's homepage, a config change) re-applies that page while an in-session\nrefresh leaves it alone; the record resets only when the process is killed, so a\ncold start re-lands on the live / next-upcoming match.\n\nAdds SportsWidgetTest coverage for the initial-page selection.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306674\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307098\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/MatchCardBuilder.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/ui/SportsCardPager.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/ui/SportsWidget.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/home/sports/MatchCardBuilderTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/home/sports/ui/SportsWidgetTest.kt"], "git_node": "24b9cd773407545a8286c11d4762dea1e84b6a73", "git_parents": ["09ee49dc27873d98337861d60d50d7f923711113"], "node": "7ff822762855739aa56b86525b7a5866c5d1500f", "parents": ["8a3e8c3904d0bb91da1eedbd3ec749c4173f88ef"], "tags": []}, {"author": "Moyin \u003cmadeyemi@mozilla.com\u003e", "branch": "default", "desc": "Bug 2047933 - Fix the flash in the sports widget when displaying a third place champions card and a finals card in the pager  a=RyanVM\n\n**Before:**\n{F72832951}\n\n**After:**\n{F72833040}\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306976\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307099\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/ui/SportsCardPager.kt"], "git_node": "b95546c0ef72f0ffadb02eb448e341ee6f4a9875", "git_parents": ["24b9cd773407545a8286c11d4762dea1e84b6a73"], "node": "dfdc2526fbca370f4ebeef853147ecec128969f6", "parents": ["7ff822762855739aa56b86525b7a5866c5d1500f"], "tags": []}], "date": 1781653340, "git_changesets": ["24b9cd773407545a8286c11d4762dea1e84b6a73", "b95546c0ef72f0ffadb02eb448e341ee6f4a9875"], "user": "rvandermeulen@mozilla.com"}, "26892": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update remote-settings mobile-experiments mobile-merino-manifest ct-logs -  a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307120\n", "files": ["mobile/android/android-components/components/service/merino-manifest/src/main/assets/manifest/manifest.json", "mobile/android/fenix/app/src/main/res/raw/initial_experiments.json", "security/ct/CTKnownLogs.h", "security/manager/tools/log_list.json", "services/settings/dumps/blocklists/addons-bloomfilters.json", "services/settings/dumps/main/devtools-compatibility-browsers.json", "services/settings/dumps/security-state/intermediates.json"], "git_node": "19e1463adb54259797c85f79214abb8bfd9bad3f", "git_parents": ["b95546c0ef72f0ffadb02eb448e341ee6f4a9875"], "node": "542016101ad5efabbcb8111b2e990d77ad9abd1e", "parents": ["dfdc2526fbca370f4ebeef853147ecec128969f6"], "tags": []}], "date": 1781653372, "git_changesets": ["19e1463adb54259797c85f79214abb8bfd9bad3f"], "user": "rvandermeulen@mozilla.com"}, "26893": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Import translations from main\n", "files": ["mobile/android/android-components/components/browser/errorpages/src/main/res/values-co/strings.xml", "mobile/android/android-components/compon