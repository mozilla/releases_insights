it_node": "106fa551c233e4342bbceaa4490960c7cdd67992", "git_parents": ["0de1bad3406c7b4e4806c04984c393b8e5cca248"], "node": "0f6b083c2dc432241a1908e31f402ecdc06c9b97", "parents": ["619ba52176c2f18ca1c96a00c53b004a3d061068"], "tags": []}], "date": 1782885934, "git_changesets": ["106fa551c233e4342bbceaa4490960c7cdd67992"], "user": "pchevrel@mozilla.com"}, "27208": {"changesets": [{"author": "Maxx Crawford \u003cmcrawford@mozilla.com\u003e", "branch": "default", "desc": "Bug 2050518 - Add getTodayStats() to PrivacyMetricsService for today's tracking-protection counts  a=pascalc\n\nPrivacyMetricsService only exposes getWeeklyStats() (a 7-day aggregate). Add getTodayStats(), which returns today's per-category counts in the same PrivacyMetricsStats shape, reusing _aggregateStats(). It queries TrackingDBService.getEventsByDateRange(now, now): the query day-truncates both bounds and events are bucketed by UTC date, so this selects exactly today's row.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308833\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309700\n", "files": ["browser/components/protections/PrivacyMetricsService.sys.mjs", "browser/components/protections/test/xpcshell/test_PrivacyMetricsService.js"], "git_node": "4cb5ceb54bf8cb44a31649110b2501910865e048", "git_parents": ["106fa551c233e4342bbceaa4490960c7cdd67992"], "node": "15f576f96ef8eba11d2401b449b80d758de8ae60", "parents": ["0f6b083c2dc432241a1908e31f402ecdc06c9b97"], "tags": []}], "date": 1782885973, "git_changesets": ["4cb5ceb54bf8cb44a31649110b2501910865e048"], "user": "pchevrel@mozilla.com"}, "27209": {"changesets": [{"author": "Julien Pages \u003cjpages@mozilla.com\u003e", "branch": "default", "desc": "Bug 2021136 - Allow growable SharedArrayBuffer in WebAssembly.Memory structured clone.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307849\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309704\n", "files": ["js/src/jit-test/tests/wasm/wasm-shared-memory-resizable-cloning.js", "js/src/vm/StructuredClone.cpp"], "git_node": "e8ac7cf81e6bacd654c86856ad3ebe5b39506dc1", "git_parents": ["4cb5ceb54bf8cb44a31649110b2501910865e048"], "node": "f6940b900262f3b45c29c5d90ca1fa60627c3ab4", "parents": ["15f576f96ef8eba11d2401b449b80d758de8ae60"], "tags": []}], "date": 1782886014, "git_changesets": ["e8ac7cf81e6bacd654c86856ad3ebe5b39506dc1"], "user": "pchevrel@mozilla.com"}, "27210": {"changesets": [{"author": "Harrison Oglesby \u003coglesby.harrison@gmail.com\u003e", "branch": "default", "desc": "Bug 2050888 - Enable Google Lens by default in nightly and in secret settings in beta  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309097\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309641\n", "files": ["mobile/android/fenix/app/nimbus.fml.yaml", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/settings/SecretSettingsFragment.kt"], "git_node": "6dccd1d6a7748be7cf866958574f71f1cd255e76", "git_parents": ["e8ac7cf81e6bacd654c86856ad3ebe5b39506dc1"], "node": "a0a82f63697d9f7dc67e83f2c9c910c3713355fa", "parents": ["f6940b900262f3b45c29c5d90ca1fa60627c3ab4"], "tags": []}], "date": 1782886103, "git_changesets": ["6dccd1d6a7748be7cf866958574f71f1cd255e76"], "user": "pchevrel@mozilla.com"}, "27211": {"changesets": [{"author": "Karl Tomlinson \u003ckarlt+@karlt.net\u003e", "branch": "default", "desc": "Bug 2042242 Start fallback driver after queuing cubeb stream init  a=pascalc\n\nThis keeps cubeb operations in order and means that no other thread runs the\ngraph while mStreamName is passed to the cubeb operation thread.\n\nMaybeStartAudioStream() no longer uses Start() to queue the stream init,\nbecause it does not need to and removing this caller allows Start() to more\nsimply handle its remaining use cases.  MaybeStartAudioStream() never starts a\nfallback driver nor stops a previous driver because it is called from the\nfallback driver loop.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305794\n\nDifferential Revision: https://phabricator.services.mozilla.com/D309474\n", "files": ["dom/media/GraphDriver.cpp", "dom/media/GraphDriver.h"], "git_node": "ea18446140ddb8e80e831bf885ce4818aad75da5", "git_parents": ["6dccd1d6a7748be7cf866958574f71f1cd255e76"], "node": "36bee4ba46911f2b8fcf76166744e11c426e79b2", "parents": ["a0a82f63697d9f7dc67e83f2c9c910c3713355fa"], "tags": []}], "date": 1782886150, "git_changesets": ["ea18446140ddb8e80e831bf885ce4818aad75da5"], "user": "pchevrel@mozilla.com"}, "27212": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Bumping Firefox l10n changesets r=release a=l10n-bump\n\nach -\u003e fb2f01d2ce647337527b49f3ac69c623e586d002\naf -\u003e fb2f01d2ce647337527b49f3ac69c623e586d002\nan -\u003e fb2f01d2ce647337527b49f3ac69c623e586d002\nar -\u003e fb2f01d2ce647337527b49f3ac69c623e586d002\nast -\u003e fb2f01d2ce647337527b49f3ac69c623e586d002\naz -\u003e fb2f01d2ce647337527b49f3ac69c623e586d002\nbe -\u003e fb2f01d2ce647337527b49f3ac69c623e586d002\nbg -\u003e fb2f01d2ce647337527b49f3ac69c623e586d002\nbn -\u003e fb2f01d2ce647337527b49f3ac69c623e586d002\nbr -\u003e fb2f01d2ce647337527b49f3ac69c623e586d002\nbs -\u003e fb2f01d2ce647337527b49f3ac69c623e586d002\nca -\u003e fb2f01d2ce647337527b49f3ac69c623e586d002\nca-valencia -\u003e fb2f01d2ce647337527b49f3ac69c623e586d002\ncak -\u003e fb2f01d2ce647337527b49f3ac69c623e586d002\ncs -\u003e fb2f01d2ce647337527b49f3ac69c623e586d002\ncy -\u003e fb2f01d2ce647337527b49f3ac69c623e586d002\nda -\u003e fb2f01d2ce647337527b49f3ac69c623e586d002\nde -\u003e fb2f01d2ce647337527b49f3ac69c623e586d002\ndsb -\u003e fb2f01d2ce647337527b49f3ac69c623e586d002\nel -\u003e fb2f01d2ce647337527b49f3ac69c623e586d002\nen-CA -\u003e fb2f01d2ce647337527b49f3ac69c623e586d002\nen-GB -\u003e fb2f01d2ce647337527b49f3ac69c623e586d002\neo -\u003e fb2f01d2ce647337527b49f3