9eaf52df31c1fa73a679cb47d435d825f29", "parents": ["5041fc98f5302ee198fa23578635df7e4810c6dd"], "tags": []}], "date": 1781946179, "git_changesets": ["b5e07026084f57b8bce52890540b72daff752cb5", "7245b80b8b2899fe83df6fa401041d2e0294b49a"], "user": "ffxbld@lando.moz.tools"}, "26969": {"changesets": [{"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 2046945 - Part 1: Fire intl:l10n-sources-changed when L10nRegistry sources mutate  a=RyanVM\n\nLong-lived Localization instances cache the bundles they generate on first\nuse. Until now, no observer notification fired when sources were registered,\nupdated, or removed in L10nRegistry, so those caches were never invalidated;\nany source registered after startup (e.g. by AboutNewTabResourceMapping when\na train-hopped newtab XPI is active) was invisible to already-translated\ndocuments.\n\nWe introduce a new intl:l10n-sources-changed observer topic, fired by\nL10nRegistry in both the parent (L10nRegistrySendUpdateL10nFileSources) and\ncontent (RegisterFileSourcesFromParentProcess) processes after the registry\nhas been mutated. Localization::Observe now listens for it and drops cached\nbundles, mirroring its existing handling of intl:app-locales-changed.\n\nA dedicated topic is used rather than reusing intl:app-locales-changed so\nthe ~30 other observers that care only about negotiated-locale changes\n(font list, mozIntl caches, sidebar, tabbrowser, \u2026) aren't woken on every\nsource mutation.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307789\n", "files": ["intl/l10n/L10nRegistry.cpp", "intl/l10n/test/test_l10nregistry_observer.js", "intl/l10n/test/xpcshell.toml"], "git_node": "b2a5f48282680a1189e022e37f58cefcabc23674", "git_parents": ["7245b80b8b2899fe83df6fa401041d2e0294b49a"], "node": "4de228bdec9de0bd725795b9a5a123b44fe97024", "parents": ["4b5029eaf52df31c1fa73a679cb47d435d825f29"], "tags": []}, {"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 2046945 - Part 1.5: Have AboutNewTabChild retrigger translation of about:newtab on intl:l10n-sources-changed.  a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307790\n", "files": ["browser/actors/AboutNewTabChild.sys.mjs", "browser/components/newtab/AboutNewTabRedirector.sys.mjs"], "git_node": "32ba8eec3a9610a9d1bd83a0250c9810c94eff5d", "git_parents": ["b2a5f48282680a1189e022e37f58cefcabc23674"], "node": "f9c6814707921399173dbff983105ab921bac534", "parents": ["4de228bdec9de0bd725795b9a5a123b44fe97024"], "tags": []}, {"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 2046945 - Part 2: Expose active langpack ids and a webextension-langpack-shutdown observer topic  a=RyanVM\n\nConsumers of L10nRegistry that want to register sources alongside a\nlangpack's (for example, to provide a locale-specific override for an\nindividual resource) need two things this module didn't previously\nprovide: an authoritative enumeration of currently-active langpacks at\nthe time the consumer initializes, and lifecycle notifications symmetric\nto the existing webextension-langpack-startup topic.\n\nWe add a static Langpack.activeLangpackIds Set, mutated at the same\ncallsites that mutate the L10nRegistry, exposing the langpack metasource\nstrings (startupData.langpackId, which is *not* the addon's id). We then\nfire a new webextension-langpack-shutdown observer topic before the langpack\nremoves its L10nRegistry sources, so consumers can clean up parallel\nregistrations in the same metasource before it goes away.\n\nThe first consumer in AboutNewTabResourceMapping in the next patch in this\nseries.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307791\n", "files": ["toolkit/components/extensions/Extension.sys.mjs", "toolkit/mozapps/extensions/test/xpcshell/test_webextension_langpack.js"], "git_node": "05829d0f16c8079aa43cc60dd0d16fbad0f0d512", "git_parents": ["32ba8eec3a9610a9d1bd83a0250c9810c94eff5d"], "node": "125c257102d4c06ad5c04f50309d618cd75ab477", "parents": ["f9c6814707921399173dbff983105ab921bac534"], "tags": []}, {"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 2046945 - Part 3: Register newtab XPI Fluent source into each active langpack's metasource  a=RyanVM\n\nThe L10nRegistry solver builds bundles atomically per (locale, metasource):\nso every required resource must be satisfiable from sources in that\nmetasource for that locale, or _no bundle is produced_.\n\nThe \"app\" metasource's non-newtab sources (toolkit, browser) are packaged en-US\nonly, so with a non-English langpack the (locale, \"app\") bundle can never be\nbuilt \u2014 and the train-hop newtab XPI's locale-specific strings are\nunreachable, falling through to en-US. That is why train-hop-only widget\nstrings (added to the XPI but not yet present in any langpack) were\nrendering in the wrong language.\n\nWe make AboutNewTabResourceMapping also register a shadow newtab\nL10nFileSource into each active langpack's metasource, enumerated via\nLangpack.activeLangpackIds and kept in sync with\nwebextension-langpack-startup/-shutdown observer notifications). Within the\n(locale, langpack) bundle, the solver now yields two valid orderings: one\nwith the langpack's older newtab.ftl, one with the XPI's. Fluent falls\nthrough the former on missing keys and resolves train-hop-only strings\nfrom the latter, while strings the langpack already translates continue\nto come from the langpack.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307792\n", "files": ["browser/components/newtab/AboutNewTabResourceMapping.sys.mjs", "browser/components/newtab/test/xpcshell/test_AboutNewTabResourceMapping_langpackShadow.js", "browser/components/newtab/test/xpcshell/xpcshell.toml"], "git_node": "492645606a466f173e339250d1ee89a9c1129132", "git_parents": ["05829d0f16c8079aa43cc60dd0d16fbad0f0d512"], "node": "d088524499f1005bac92ac8b36fe67e9a80dc04b", "parents": ["125c257102d4c06ad5c04f50309d618cd75ab477"], "tags": []}, {"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 2048663 - Remove platform-fragile test_topic_separation_from_app_locales_changed  a=RyanVM\n\nThe test asserted that registering an L10nFileSource with a locale\nalready in availableLocales would not fire intl:app-locales-changed.\nBut L10nRegistry::getAvailableLocales builds its result from a Rust\nHashSet, whose iteration order is platform-randomized, and\nLocaleService::SetAvailableLocales compares as an order-sensitive\nnsTArray, so a no-op-for-the-set registration can still cascade\nthrough LocalesChanged on platforms where the order differs\n(reproducibly on Android shippable).\n\nThis was a belt-and-suspenders test I added for the first iteration of\nthe patches for bug 2046945, when we were having Localization.cpp flush\nits internal notion of bundles when the sources changed. Since we're\nno longer doing that, this test is just getting in the way.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307687\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307793\n", "files": ["intl/l10n/test/test_l10nregistry_observer.js"], "git_node": "820b69e141478bffe8d6e6e35c9ba39a5dac977d", "git_parents": ["492645606a466f173e339250d1ee89a9c1129132"], "node": "659ee4470e2e02b8aafa6eed90d5633fc3344949", "parents": ["d088524499f1005bac92ac8b36fe67e9a80dc04b"], "tags": []}], "date": 1781972447, "git_changesets": ["b2a5f48282680a1189e022e37f58cefcabc23674", "32ba8eec3a9610a9d1bd83a0250c9810c94eff5d", "05829d0f16c8079aa43cc60dd0d16fbad0f0d512", "492645606a466f173e339250d1ee89a9c1129132", "820b69e141478bffe8d6e6e35c9ba39a5dac977d"], "user": "rvandermeulen@mozilla.com"}, "26970": {"changesets": [{"author": "t-p-white \u003ctowhite@mozilla.com\u003e", "branch": "default", "desc": "Bug 2048329 - Expand microsurvey bottom sheet fully so the Submit button is visible without scrolling  a=RyanVM\n\n{F72932840}\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307352\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307734\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/microsurvey/ui/MicrosurveyBottomSheetFragment.kt"], "git_node": "9b2ff428d818c718c796c364d8d088fad1c16808", "git_parents": ["820b69e141478bffe8d6e6e35c9ba39a5dac977d"], "node": "9bf578367a292228177aa7eaaa68576f0c750ddf", "parents": ["659ee4470e2e02b8aafa6eed90d5633fc3344949"], "tags": []}], "date": 1781973124, "git_changesets": ["9b2ff428d818c718c796c364d8d088fad1c16808"], "user": "rvandermeulen@mozilla.com"}, "26971": {"changesets": [{"author": "Rolf Rando \u003crrando@mozilla.com\u003e", "branch": "default", "desc": "Bug 2047620 - Update handling of sorting of Semantic Search results in URLBar  a=RyanVM\n\nIn recent semantic search experiments, we found that in many instances the exact match results (type 'history') in telemetry were being pushed out by semantic matches of higher frecency score. Because semantic matches are of lower precision, this was driving overall CTR of the address bar history results section down.\n\nWe seek to remedy this in to ways:\n1) Deduplicate semantic and exact match results so that we have a clearer telemetry picture when both providers return the same results. We prefer exact match results because they have UI showing the matched string portion\n\n2) Put semantic results into a separate group so that semantic results rarely evict exact match results. In the expanded history view (which typically shows 10 entries) some exact matches may be shown.  Note that implementation of this change may cause higher frecency semantic items to show after exact match items.\n\n| Max UI Elements in Section | Detected Exact Match | Detected Semantic Items | Displayed Exact Match | Displayed Semantic |\n| 3                                |                    1 |                       2 |                     2 |                  1 |\n| 3                                |                    2 |                       2 |                     1 |                  2 |\n| 3                                |                    3 |                       2 |                     3 |                  0 |\n| 3                                |                    0 |                       3 |                     0 |                  3 |\n| 3                                |                    3 |                       0 |                     3 |                  0 |\n| 10                               |                    1 |                       2 |                     1 |                  2 |\n| 10                               |                    3 |                       2 |                     3 |                  2 |\n| 10                               |                    5 |                       2 |                     5 |                  2 |\n| 10                               |                   10 |                       2 |                     9 |                  1 |\n\nThere is an issue with phabricator checking the build/ Try tests here https://treeherder.mozilla.org/jobs?repo=try&landoInstance=lando-prod-2025&landoCommitID=58201\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306765\n\nDifferential Revision: https://phabricator.services.mozilla.com/D307709\n", "files": ["browser/components/urlbar/UrlbarMuxerStandard.sys.mjs", "browser/components/urlbar/UrlbarPrefs.sys.mjs", "browser/components/urlbar/UrlbarUtils.sys.mjs", "browser/components/urlbar/tests/unit/test_muxer.js", "toolkit/components/nimbus/FeatureManifest.yaml"], "git_node": "f8b21dc471b72239e8b4dda314f19ea2a8683596", "git_parents": ["9b2ff428d818c718c796c364d8d088fad1c16808"], "node": "95f3bf8c3c5b8cdb045dc3c56a9c896121ea87b4", "parents": ["9bf578367a292228177aa7eaaa68576f0c750ddf"], "tags": []}], "date": 1781973919, "git_changesets": ["f8b21dc471b72239e8b4dda314f19ea2a8683596"], "user": "rvandermeulen@mozilla.com"}, "26972": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Import translations from main\n", "files": ["mobile/android/android-components/components/feature/contextmenu/src/main/res/values-hu/strings.xml", "mobile/android/android-components/components/feature/ipprotection/src/main/res/values-gn/strings.xml", "mobile/android/android-components/components/feature/ipprotection/src/main/res/values-pa-rIN/strings.xml", "mobile/android/android-components/components/feature/media/src/main/res/values-bg/strings.xml", "mobile/android/android-components/components/feature/media/src/main/res/values-de/strings.xml", "mobile/android/android-components/components/feature/media/src/main/res/values-dsb/strings.xml", "mobile/android/android-components/components/feature/media/src/main/res/values-es-rAR/strings.xml", "mobile/android/android-components/components/feature/media/src/main/res/values-fr/strings.xml", "mobile/android/android-components/components/feature/media/src/main/res/values-fur/strings.xml", "mobile/android/android-components/components/feature/media/src/main/res/values-gl/strings.xml", "mobile/android/android-components/components/feature/media/src/main/res/values-gn/strings.xml", "mobile/android/android-components/components/feature/media/src/main/res/values-hsb/strings.xml", "mobile/android/android-components/components/feature/media/src/main/res/values-ia/strings.xml", "mobile/android/android-components/components/feature/media/src/main/res/values-it/strings.xml", "mobile/android/android-components/components/feature/media/src/main/res/values-iw/strings.xml", "mobile/android/android-components/components/feature/media/src/main/res/values-ko/strings.xml", "mobile/android/android-components/components/feature/media/src/main/res/values-nb-rNO/strings.xml", "mobile/android/android-components/components/feature/media/src/main/