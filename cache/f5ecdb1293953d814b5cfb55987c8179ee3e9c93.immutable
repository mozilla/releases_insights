135c7bdd5d037ecbd59a8d429b42807"], "user": "ffxbld@lando.moz.tools"}, "27342": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging d6222c84b8b1ad3cc36c5749afd40e05ebfd20d6 with FIREFOX-ANDROID_152_0_5_RELEASE a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "891968069ee03964ea40e4c7841d12ad9fe7f6aa", "git_parents": ["787e05279135c7bdd5d037ecbd59a8d429b42807"], "node": "c950dc965e907181eb15b5436463d2d32c7ea960", "parents": ["a8ae8c14464ab0ba349f672d97045c4855dba127"], "tags": []}], "date": 1783428400, "git_changesets": ["891968069ee03964ea40e4c7841d12ad9fe7f6aa"], "user": "ffxbld@lando.moz.tools"}, "27343": {"changesets": [{"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 2046575 - Ignore the now unsupported setting to hide local search shortcuts from the drop-downs.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308908\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310814\n", "files": ["browser/components/urlbar/content/SearchModeSwitcher.mjs", "browser/components/urlbar/tests/browser-searchMode/browser_searchModeSwitcher_basic.js"], "git_node": "c933db3b5df0ce495024c211d337dedec806858d", "git_parents": ["8a34d37f92fd7b7981cbead50ff336e5a2321e1b"], "node": "e016f639a73cae042d570c26fa1a61468801424c", "parents": ["725067947279e072ca364822260b184a9f538d30"], "tags": []}], "date": 1783430651, "git_changesets": ["c933db3b5df0ce495024c211d337dedec806858d"], "user": "pchevrel@mozilla.com"}, "27344": {"changesets": [{"author": "Meg Viar \u003clmegviar@gmail.com\u003e", "branch": "default", "desc": "Bug 2050140 - Add new action-only message type in messaging system  a=pascalc\n\nAdds a new `action_only` message template. These are messages with no UI that perform an action or collection of actions when delivered. ASRouter silently executes an allowlisted SpecialMessageAction, records a local impression, sends impression telemetry, and does not block the message (re-fire is governed by frequency caps).\n\nAn allowlist gate (`_isAllowedActionOnlyMessageAction`) ensures only allowlisted action types may run For now, the list is limited to \"CONFIRM_LAUNCH_ON_LOGIN\" (the first use case for this message type). Bug 2050517 will allow this list to be extended via remote-settings for greater off-train flexibility.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308617\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310807\n", "files": ["browser/components/asrouter/content-src/schemas/MessagingExperiment.schema.json", "browser/components/asrouter/content-src/schemas/make-schemas.py", "browser/components/asrouter/content-src/templates/OnboardingMessage/ActionOnlyMessage.schema.json", "browser/components/asrouter/content/asrouter-admin.bundle.js", "browser/components/asrouter/docs/action-only.md", "browser/components/asrouter/docs/index.rst", "browser/components/asrouter/modules/ASRouter.sys.mjs", "browser/components/asrouter/modules/ASRouterParentProcessMessageHandler.sys.mjs", "browser/components/asrouter/modules/ASRouterTelemetry.sys.mjs", "browser/components/asrouter/modules/ActorConstants.mjs", "browser/components/asrouter/tests/unit/ASRouter.test.js", "browser/components/asrouter/tests/xpcshell/test_ASRouterTelemetry.js", "toolkit/components/messaging-system/schemas/index.rst"], "git_node": "cb59debc127881ca841b4ff7eb935c363ae6c608", "git_parents": ["c933db3b5df0ce495024c211d337dedec806858d"], "node": "6c4ccef08e38977e055316558c765801d1131fcb", "parents": ["e016f639a73cae042d570c26fa1a61468801424c"], "tags": []}], "date": 1783430738, "git_changesets": ["cb59debc127881ca841b4ff7eb935c363ae6c608"], "user": "pchevrel@mozilla.com"}, "27345": {"changesets": [{"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 2050368 - Check for end of charstring.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308768\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310830\n", "files": ["gfx/cairo/cairo/src/cairo-type1-subset.c", "gfx/cairo/patches/0040-type1-decode-integer.patch"], "git_node": "f9882a8ae425459ba19b4de00581f52dbad5984f", "git_parents": ["cb59debc127881ca841b4ff7eb935c363ae6c608"], "node": "89b692835dae23e8ff6852ef5b7cafff80e29a8f", "parents": ["6c4ccef08e38977e055316558c765801d1131fcb"], "tags": []}], "date": 1783437078, "git_changesets": ["f9882a8ae425459ba19b4de00581f52dbad5984f"], "user": "pchevrel@mozilla.com"}, "27346": {"changesets": [{"author": "Emma Zuehlcke \u003cemz@mozilla.com\u003e", "branch": "default", "desc": "Bug 2049331 - Disable email tracking protection from the redesigned ETP Custom UI.  a=pascalc\n\nThe old ETP Custom UI couples the email tracking protection prefs to the\ntracking protection checkbox and scope menu, since email tracking\nprotection is surfaced through the same Tracking Content UI on the\nprotections panel. The settings redesign reimplemented these controls but\nnever wrote the email tracking prefs, so disabling Tracking Content no\nlonger disabled email tracking protection in private windows, reintroducing\nbug 1830054.\n\nMake the redesigned etpCustomTrackingProtectionEnabled toggle and\netpCustomTrackingProtectionEnabledContext scope settings write the email\ntracking prefs alongside the tracking protection prefs, mirroring the old\ndesign's behavior.\n\nThe original testDisableTPCheckBoxDisablesEmailTP guard only runs against\nthe old design; extend the redesign's test_custom_tracking_protection_controls\nto cover the email tracking prefs.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308079\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310806\n", "files": ["browser/components/preferences/config/privacy.mjs", "browser/components/preferences/tests/etp/browser_etp_customize_2.js"], "git_node": "395546f8e31e28828d13b75801a42835673fdd74", "git_parents": ["f9882a8ae425459ba19b4de00581f52dbad5984f"], "node": "6d4ecc4564609f2f3e815078705f18a5686257a8", "parents": ["89b692835dae23e8ff6852ef5b7cafff80e29a8f"], "tags": []}], "date": 1783437122, "git_changesets": ["395546f8e31e28828d13b75801a42835673fdd74"], "user": "pchevrel@mozilla.com"}, "27347": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2045198 - Don't bother checking ancestors for constructed check.  a=pascalc\n\nSince we don't allow @import, we can't get there with a constructed\nancestor.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309844\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310805\n", "files": ["layout/style/ServoCSSRuleList.cpp", "layout/style/StyleSheet.cpp", "layout/style/StyleSheet.h"], "git_node": "f4d93e3eea9e86033ab013784d6f8381cf4dda7c", "git_parents": ["395546f8e31e28828d13b75801a42835673fdd74"], "node": "8bf3b23ec062d1e7758ce1fbf808554025d99805", "parents": ["6d4ecc4564609f2f3e815078705f18a5686257a8"], "tags": []}], "date": 1783437173, "git_changesets": ["f4d93e3eea9e86033ab013784d6f8381cf4dda7c"], "user": "pchevrel@mozilla.com"}, "27348": {"changesets": [{"author": "Meg Viar \u003clmegviar@gmail.com\u003e", "branch": "default", "desc": "Bug 2050145 - Add targeting attribute for is launch on login  a=pascalc\n\nAdd a targeting attribute that is true if Firefox was launched on login (via `os-autostart` command line flag), otherwise false.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309125\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310799\n", "files": ["browser/components/asrouter/docs/targeting-attributes.md", "browser/components/asrouter/modules/ASRouterTargeting.sys.mjs", "browser/components/asrouter/tests/browser/browser_asrouter_targeting.js"], "git_node": "686b46367590e525e30a8d7602bc86e4ed6faf19", "git_parents": ["f4d93e3eea9e86033ab013784d6f8381cf4dda7c"], "node": "34f30014f41b54cb20df00f946c30f74892ad953", "parents": ["8bf3b23ec062d1e7758ce1fbf808554025d99805"], "tags": []}], "date": 1783437338, "git_changesets": ["686b46367590e525e30a8d7602bc86e4ed6faf19"], "user": "pchevrel@mozilla.com"}, "27349": {"changesets": [{"author": "Meg Viar \u003clmegviar@gmail.com\u003e", "branch": "default", "desc": "Bug 2050143 - Add a new REMOVE_LAUNCH_ON_LOGIN message action  a=pascalc\n\nAdds a special message action to remove launch on login. Adds schema documentation and tests for this action and the existing \"CONFIRM_LAUNCH_ON_LOGIN\" action.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309086\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310798\n", "files": ["toolkit/components/messaging-system/lib/SpecialMessageActions.sys.mjs", "toolkit/components/messaging-system/schemas/SpecialMessageActionSchemas/SpecialMessageActionSchemas.json", "toolkit/components/messaging-system/schemas/SpecialMessageActionSchemas/index.md", "toolkit/components/messaging-system/schemas/SpecialMessageActionSchemas/test/browser/browser.toml", "toolkit/components/messaging-system/schemas/SpecialMessageActionSchemas/test/browser/browser_sma_launch_on_login.js"], "git_node": "228a2906bb491a4d5488efe9cc351e559c7a9cf1", "git_parents": ["686b46367590e525e30a8d7602bc86e4ed6faf19"], "node": "37c8b94fa77f20a5c9483836244888fe3db6bb78", "parents": ["34f30014f41b54cb20df00f946c30f74892ad953"], "tags": []}], "date": 1783437386, "git_changesets": ["228a2906bb491a4d5488efe9cc351e559c7a9cf1"], "user": "pchevrel@mozilla.com"}, "27350": {"changesets": [{"author": "Pascal Chevrel \u003cpascal@mozilla.com\u003e", "branch": "default", "desc": "Revert \"Bug 2050140 - Add new action-only message type in messaging system a=pascalc\" for linting errors a=backout\n\nThis reverts commit cb59debc127881ca841b4ff7eb935c363ae6c608.\n", "files": ["browser/components/asrouter/content-src/schemas/MessagingExperiment.schema.json", "browser/compon