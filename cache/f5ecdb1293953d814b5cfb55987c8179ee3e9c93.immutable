 -\u003e 67bd811cad5a526f395d6a2c95566f2b4702143a\nsv-SE -\u003e 67bd811cad5a526f395d6a2c95566f2b4702143a\nta -\u003e 67bd811cad5a526f395d6a2c95566f2b4702143a\nte -\u003e 67bd811cad5a526f395d6a2c95566f2b4702143a\nth -\u003e 67bd811cad5a526f395d6a2c95566f2b4702143a\ntl -\u003e 67bd811cad5a526f395d6a2c95566f2b4702143a\ntr -\u003e 67bd811cad5a526f395d6a2c95566f2b4702143a\ntrs -\u003e 67bd811cad5a526f395d6a2c95566f2b4702143a\nuk -\u003e 67bd811cad5a526f395d6a2c95566f2b4702143a\nur -\u003e 67bd811cad5a526f395d6a2c95566f2b4702143a\nuz -\u003e 67bd811cad5a526f395d6a2c95566f2b4702143a\nvi -\u003e 67bd811cad5a526f395d6a2c95566f2b4702143a\nwo -\u003e 67bd811cad5a526f395d6a2c95566f2b4702143a\nxh -\u003e 67bd811cad5a526f395d6a2c95566f2b4702143a\nzam -\u003e 67bd811cad5a526f395d6a2c95566f2b4702143a\nzh-CN -\u003e 67bd811cad5a526f395d6a2c95566f2b4702143a\nzh-TW -\u003e 67bd811cad5a526f395d6a2c95566f2b4702143a\n", "files": ["mobile/locales/l10n-changesets.json"], "git_node": "3615e334b8d9f79059abbefb5c721d34433cc333", "git_parents": ["f322a0961de5b9839d74e63ee98268fb3add4331"], "node": "c1ce20ef266055e003ef3d000b054373a5a8b8fd", "parents": ["230936011f7c200bc034d96db1d4010b30bcf490"], "tags": []}], "date": 1784019781, "git_changesets": ["f322a0961de5b9839d74e63ee98268fb3add4331", "3615e334b8d9f79059abbefb5c721d34433cc333"], "user": "ffxbld@lando.moz.tools"}, "27474": {"changesets": [{"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 2052789 - Search dropped multi-line text in full instead of only one line.  a=pascalc\n\nDropping a multi-line text selection on the tab bar (or content area) is meant\nto search the whole selection, but only one line ended up being searched.\n\nTwo issues in ContentAreaDropListener._addLinksFromItem:\n\n- A line was treated as a URI whenever uriFixup returned a fixedURI. But\n  fixedURI is also set for a bare word that fixup would really resolve via\n  keyword search (e.g. \"American\" -\u003e host \"american\"). Such a line made the\n  whole drop look like a URI list, so every other line was discarded. Require\n  !keywordProviderId, matching the test _validateURI already applies.\n\n- The whole-text search entry kept its embedded newlines, which the later URI\n  fixup strips outright, welding the words on separate lines together. Collapse\n  whitespace to single spaces, as the urlbar does for keyword input.\n\nA genuine URL among prose lines still opens only the URL, unchanged.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D310853\n\nDifferential Revision: https://phabricator.services.mozilla.com/D312016\n", "files": ["browser/components/tabbrowser/test/browser/tabs/browser_tabDrop.js", "dom/base/ContentAreaDropListener.sys.mjs"], "git_node": "49ce020cbe174186d61869f09bfd4557f2d6686a", "git_parents": ["3615e334b8d9f79059abbefb5c721d34433cc333"], "node": "0692b54b9e8d58e1f4651996a219a9e0fcb6214e", "parents": ["c1ce20ef266055e003ef3d000b054373a5a8b8fd"], "tags": []}], "date": 1784022795, "git_changesets": ["49ce020cbe174186d61869f09bfd4557f2d6686a"], "user": "pchevrel@mozilla.com"}, "27475": {"changesets": [{"author": "Daisuke Akatsuka \u003cdaisuke@birchill.co.jp\u003e", "branch": "default", "desc": "Bug 2050846 - Set outline style explicitly for :focus-visible in panel-item  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D311469\n\nDifferential Revision: https://phabricator.services.mozilla.com/D312010\n", "files": ["toolkit/content/widgets/panel-list/panel-item.css"], "git_node": "cd888e52f51358f4ac55df79f9103b246bb95535", "git_parents": ["49ce020cbe174186d61869f09bfd4557f2d6686a"], "node": "2c01e0b40ad5cba6e62714a60f9d45daaeca2c25", "parents": ["0692b54b9e8d58e1f4651996a219a9e0fcb6214e"], "tags": []}], "date": 1784022893, "git_changesets": ["cd888e52f51358f4ac55df79f9103b246bb95535"], "user": "pchevrel@mozilla.com"}, "27476": {"changesets": [{"author": "Tom Schuster \u003ctschuster@mozilla.com\u003e", "branch": "default", "d