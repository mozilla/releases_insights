ba\ntrs -\u003e dbcfe34dcd5874b28b4e8e89c361b41fbde78bba\nuk -\u003e dbcfe34dcd5874b28b4e8e89c361b41fbde78bba\nur -\u003e dbcfe34dcd5874b28b4e8e89c361b41fbde78bba\nuz -\u003e dbcfe34dcd5874b28b4e8e89c361b41fbde78bba\nvi -\u003e dbcfe34dcd5874b28b4e8e89c361b41fbde78bba\nwo -\u003e dbcfe34dcd5874b28b4e8e89c361b41fbde78bba\nxh -\u003e dbcfe34dcd5874b28b4e8e89c361b41fbde78bba\nzam -\u003e dbcfe34dcd5874b28b4e8e89c361b41fbde78bba\nzh-CN -\u003e dbcfe34dcd5874b28b4e8e89c361b41fbde78bba\nzh-TW -\u003e dbcfe34dcd5874b28b4e8e89c361b41fbde78bba\n", "files": ["mobile/locales/l10n-changesets.json"], "git_node": "b1ef629e2c045cf5587a80de6501fb0f1103a74f", "git_parents": ["c015e21555367b5a216415063ed9352fa29dc490"], "node": "918a3179a761a0fe629b9c5a8e663ae45e0bdacb", "parents": ["3f35201618546a19de417cfb1e0a778c85959720"], "tags": []}], "date": 1783242198, "git_changesets": ["c015e21555367b5a216415063ed9352fa29dc490", "b1ef629e2c045cf5587a80de6501fb0f1103a74f"], "user": "ffxbld@lando.moz.tools"}, "27286": {"changesets": [{"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 2052394 - Fix the assertions in `IMEContentObserver::InitWithEditor()`  a=pascalc\n\nThe method tests `IsForDesignMode()` to check the regression caused by a\nchange of `GetMostDistantInclusiveEditableAncestorNode()` with debug\nassertions.\n\n`IsForDesignMode()` should return `true` only when the editor is an\n`HTMLEditor`. If the editor is a `TextEditor`, the text control element\nmay be in the design mode if the document entered into the design mode\nwhile the text control gets focus. In this case, `IsForDesignMode()`\nshould return `false` if the editor is a `TextEditor` because the\ninstance should work for the text control rather than for the design\nmode.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D310270\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310428\n", "files": ["dom/events/IMEContentObserver.cpp", "testing/web-platform/tests/editing/crashtests/designMode-on-when-textarea-gets-focus.html"], "git_node": "c89e78bbf823c04fb9815bf3efe5924c73ee05e2", "git_parents": ["b1ef629e2c045cf5587a80de6501fb0f1103a74f"], "node": "51fe183e79ee9c89f21175f855c8ed83a5f4dacc", "parents": ["918a3179a761a0fe629b9c5a8e663ae45e0bdacb"], "tags": []}], "date": 1783265716, "git_changesets": ["c89e78bbf823c04fb9815bf3efe5924c73ee05e2"], "user": "pchevrel@mozilla.com"}, "27287": {"changesets": [{"author": "Matthew Gregan \u003ckinetik@flim.org\u003e", "branch": "default", "desc": "Bug 2050477 -  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309927\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310427\n", "files": ["dom/media/VideoUtils.cpp", "dom/media/webm/WebMDemuxer.cpp"], "git_node": "1fb573bbfc68cffb31b32175f834564453f6f47f", "git_parents": ["c89e78bbf823c04fb9815bf3efe5924c73ee05e2"], "node": "5c348f0188b1e1f27fb05c4e11098a5f7d7de72b", "parents": ["51fe183e79ee9c89f21175f855c8ed83a5f4dacc"], "tags": []}], "date": 1783265912, "git_changesets": ["1fb573bbfc68cffb31b32175f834564453f6f47f"], "user": "pchevrel@mozilla.com"}, "27288": {"changesets": [{"author": "Andy Leiserson \u003caleiserson@mozilla.com\u003e", "branch": "default", "desc": "Bug 2050871 - Remember swap chain parameters at creation time  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309705\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310413\n", "files": ["dom/webgpu/Device.cpp", "dom/webgpu/Device.h", "dom/webgpu/ipc/WebGPUParent.cpp", "gfx/wgpu_bindings/src/client.rs", "gfx/wgpu_bindings/src/lib.rs", "gfx/wgpu_bindings/src/server.rs"], "git_node": "82dcace647d94092af8456cf6fecae01fcadeb23", "git_parents": ["1fb573bbfc68cffb31b32175f834564453f6f47f"], "node": "b8ed2dfa564e3d0a44bfe2dd27ba905c28b612df", "parents": ["5c348f0188b1e1f27fb05c4e11098a5f7d7de72b"], "tags": []}], "date": 1783265982, "git_changesets": ["82dcace647d94092af8456cf6fecae01fcadeb23"], "user": "pchevrel@mozilla.com"}, "27289": {"changesets": [{"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 2048801 - Validate fdselect entries before use.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308373\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310392\n", "files": ["gfx/cairo/cairo/src/cairo-cff-subset.c", "gfx/cairo/patches/0037-fdselect-checks.patch"], "git_node": "bbff50e8d41c7f5427388463ec3ef805cf53daa7", "git_parents": ["82dcace647d94092af8456cf6fecae01fcadeb23"], "node": "7de2481e4911fe15635af261a7f3d26e0b5f509e", "parents": ["b8ed2dfa564e3d0a44bfe2dd27ba905c28b612df"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 2049398 - Range-check glyph ID.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308374\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310393\n", "files": ["gfx/cairo/cairo/src/cairo-cff-subset.c", "gfx/cairo/cairo/src/cairo-scaled-font-subsets.c", "gfx/cairo/patches/0038-gid-range-check.patch"], "git_node": "336a99ad0d3c5afb9893c41b3184a434e5ca0d76", "git_parents": ["bbff50e8d41c7f5427388463ec3ef805cf53daa7"], "node": "ff656415209c6818ad3d70e0124fa1b7a005ccba", "parents": ["7de2481e4911fe15635af261a7f3d26e0b5f509e"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 2049399 - Check type1 stack size.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308375\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310394\n", "files": ["gfx/cairo/cairo/src/cairo-type1-subset.c", "gfx/cairo/patches/0039-type1-stack-check.patch"], "git_node": "76dcee93b9199a898ab9d7dd5f53472cb43e15ad", "git_parents": ["336a99ad0d3c5afb9893c41b3184a434e5ca0d76"], "node": "241ca109331794f656a2c067dc736954d45ef7be", "parents": ["ff656415209c6818ad3d70e0124fa1b7a005ccba"], "tags": []}], "date": 1783266080, "git_changesets": ["bbff50e8d41c7f5427388463ec3ef805cf53daa7", "336a99ad0d3c5afb9893c41b3184a434e5ca0d76", "76dcee93b9199a898ab9d7dd5f53472cb43e15ad"], "user": "pchevrel@mozilla.com"}, "27290": {"changesets": [{"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 2049981 - Check subtree in NewWindowGlobal,  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309680\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310384\n", "files": ["dom/ipc/BrowserParent.cpp"], "git_node": "2f6c092c2dd762e45ee3992649f2810f0c2daca0", "git_parents": ["76dcee93b9199a898ab9d7dd5f53472cb43e15ad"], "node": "11963d8402365fdd73c46e5d445b33119bc0a146", "parents": ["241ca109331794f656a2c067dc736954d45ef7be"], "tags": []}], "date": 1783266116, "git_changesets": ["2f6c092c2dd762e45ee3992649f2810f0c2daca0"], "user": "pchevrel@mozilla.com"}, "27291": {"changesets": [{"author": "Arnaud Bienner \u003cabienner@mozilla.com\u003e", "branch": "default", "desc": "Bug 2040696 - Revert bug 2025350 now bug 2027871 has been shipped  a=pascalc\n\nBug 2025350 (D290388) fixes a security issue by preventing integer overflows (by adding checks), before calling `JS_WriteUint32Pair`.\nFollow up bug 2027871 (D290702) was about changing `JS_WriteUint32Pair` directly to check the value here, to prevent possible similar bugs to happen (i.e. add more coverage).\n\nThis bug is about removing the initial checks, which are now redundant. I should probably have removed them as part of bug 2027871.\n\nNote: we will probably want to wait a bit (once 152 has been released for a bit of time) to be sure the follow up didn't introduce any regression, before landing this.\n\nBut I'm creating the bug/patch now to not forget about it.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301351\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310376\n", "files": ["dom/base/StructuredCloneBlob.cpp", "dom/ipc/ClonedErrorHolder.cpp"], "git_node": "9778f1fbb4d2667bb16e23f31aef65c490524cbd", "git_parents": ["2f6c092c2dd762e45ee3992649f2810f0c2daca0"], "node": "c85801cf02013ff5970f6c8cddcc51b50782c34e", "parents": ["11963d8402365fdd73c46e5d445b33119bc0a146"], "tags": []}], "date": 1783266226, "git_changesets": ["9778f1fbb4d2667bb16e23f31aef65c490524cbd"], "user": "pchevrel@mozilla.com"}, "27292": {"changesets": [{"author": "Tom Schuster \u003ctschuster@mozilla.com\u003e", "branch": "default", "desc": "Bug 2008369 - Validate principal in PContent::LoadURIExternal.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309362\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310358\n", "files": ["dom/ipc/ContentParent.cpp", "dom/ipc/ContentParent.h", "dom/ipc/PContent.ipdl", "uriloader/exthandler/nsExternalHelperAppService.cpp"], "git_node": "4c49fa5be7873a6bb9d69a040ab89587dfb5320f", "git_parents": ["9778f1fbb4d2667bb16e23f31aef65c490524cbd"], "node": "8b1a3b326cdd0940bd9873ab68d2847f06437c9b", "parents": ["c85801cf02013ff5970f6c8cddcc51b50782c34e"], "tags": []}], "date": 1783266286, "git_changesets": ["4c49fa5be7873a6bb9d69a040ab89587dfb5320f"], "user": "pchevrel@mozilla.com"}, "27293": {"changesets": [{"author": "Arnaud Bienner \u003cabienner@mozilla.com\u003e", "branch": "default", "desc": "Bug 2045729 - Quota manager: check received stream control is coming from the same Manager/origin  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308534\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310353\n", "files": ["dom/cache/CacheOpParent.cpp", "dom/cache/CacheStreamControlParent.cpp", "dom/cache/CacheStreamControlParent.h"], "git_node": "39e92e3ae8f3a3ad5932b9d6662ee442939eee22", "git_parents": ["4c49fa5be7873a6bb9d69a040ab89587dfb5320f"], "node": "e35398eeef0c52cc1410ce8251f650a1aa1595cb", "parents": ["8b1a3b326cdd0940bd9873ab68d2847f06437c9b"], "tags": []}], "date": 1783266332, "git_changesets": ["39e92e3ae8f3a3ad5932b9d6662ee442939eee22"], "user": "pchevrel@mozilla.com"}, "27294": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2045617 - Add some bounds checks to cairo_cff_font_read_fdselect.  a=pascalc\n\nAttached to https://gitlab.freedesktop.org/cairo/cairo/-/work_items/967\nas well.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306604\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310348\n", "files": ["gfx/cairo/cairo/src/cairo-cff-subset.c", "gfx/cairo/patches/0035-cff-fdselect-bounds.patch"], "git_node": "45d3fd09dff7f7ab82dd4f766b7f373d54abc068", "git_parents": ["39e92e3ae8f3a3ad5932b9d6662ee442939eee22"], "node": "1a930443c2363a2e2e45f23db70b580cb8b6a9d1", "parents": ["e35398eeef0c52cc1410ce8251f650a1aa1595cb"], "tags": []}], "date": 1783266389, "git_changesets": ["45d3fd09dff7f7ab82dd4f766b7f373d54abc068"], "user": "pchevrel@mozilla.com"}, "27295": {"changesets": [{"author": "Paul Adenot \u003cpaul@paul.cx\u003e", "branch": "default", "desc": "Bug 2045057 - Validate readback surface size in VideoFrame::Resource::CopyTo.  a=pascalc\n\nA compromised decoder process (RDD/Utility) can return a readback surface\nsmaller than the VideoFrame's coded/visible size. copyPlane() uses the coded\nsize to drive row copies, reading past the end of the temp surface allocated\nfrom the (attacker-controlled) readback descriptor. Validate that aRect fits\nwithin the actual readback surface before proceeding.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308749\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310320\n", "files": ["dom/media/webcodecs/VideoFrame.cpp", "dom/media/webcodecs/crashtests/2045057.html", "dom/media/webcodecs/crashtests/crashtests.list"], "git_node": "0a4329e229ecf6dfc9389d6498e0af0e64fce1e5", "git_parents": ["45d3fd09dff7f7ab82dd4f766b7f373d54abc068"], "node": "f7e1afec864dcc11e6b3dece2bd7437b63c9ea00", "parents": ["1a930443c2363a2e2e45f23db70b580cb8b6a9d1"], "tags": []}], "date": 1783266456, "git_changesets": ["0a4329e229ecf6dfc9389d6498e0af0e64fce1e5"], "user": "pchevrel@mozilla.com"}, "27296": {"changesets": [{"author": "Tom Schuster \u003ctschuster@mozilla.com\u003e", "branch": "default", "desc": "Bug 2050430.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309544\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310291\n", "files": ["dom/bindings/BindingUtils.cpp", "dom/reporting/ReportingUtils.cpp", "dom/reporting/ReportingUtils.h", "dom/reporting/tests/common_deprecated.js", "dom/security/featurepolicy/FeaturePolicyUtils.cpp"], "git_node": "0dff26abf3f346777720fe6dd54ca601be383f96", "git_parents": ["0a4329e229ecf6dfc9389d6498e0af0e64fce1e5"], "node": "61be5a38603e53e7b4425b1ff2a28738e82c18a9", "parents": ["f7e1afec864dcc11e6b3dece2bd7437b63c9ea00"], "tags": []}], "date": 1783266492, "git_changesets": ["0dff26abf3f346777720fe6dd54ca601be383f96"], "user": "pchevrel@mozilla.com"}, "27297": {"changesets": [{"author": "Yoshi Cheng-Hao Huang \u003callstars.chh@gmail.com\u003e", "branch": "default", "desc": "Bug 2042756 - Handle Debugger exception thrown during TLA module prolog.  a=pascalc\n\nSee https://bugzilla.mozilla.org/show_bug.cgi?id=2042756#c5\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309826\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310283\n", "files": ["js/src/vm/Modules.cpp"], "git_node": "718dd7a17295646a0013ae18c5717b18813bad6d", "git_parents": ["0dff26abf3f346777720fe6dd54ca601be383f96"], "node": "e20158aaa75c4ad39c773238f2d63748a67c62d1", "parents": ["61be5a38603e53e7b4425b1ff2a28738e82c18a9"], "tags": []}, {"author": "Yoshi Cheng-Hao Huang \u003callstars.chh@gmail.com\u003e", "branch": "default", "desc": "Bug 2042756 - Test.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309827\n\nDifferential