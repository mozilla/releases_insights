tor.services.mozilla.com/D310262\n", "files": ["gfx/angle/checkout/src/compiler/translator/IntermNode.cpp", "gfx/angle/checkout/src/compiler/translator/OutputHLSL.cpp"], "git_node": "7841ee47654c4ae9edd789f61f994225c2fe4281", "git_parents": ["623c35cba2c083bae13416fc6165ea3a9318101b"], "node": "f89cd6d4972ae33d73dbb8bc831f04eca6aca8df", "parents": ["eaf808f48b0c3d9a60fb400f9a116e3398349872"], "tags": []}], "date": 1783062119, "git_changesets": ["7841ee47654c4ae9edd789f61f994225c2fe4281"], "user": "pchevrel@mozilla.com"}, "27257": {"changesets": [{"author": "Matthew Gregan \u003ckinetik@flim.org\u003e", "branch": "default", "desc": "Bug 2045763.  a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310248\n", "files": ["media/libcubeb/delay-line-bounds.patch", "media/libcubeb/moz.yaml", "media/libcubeb/src/cubeb_resampler_internal.h"], "git_node": "6c9258d5fa8d05c41be6f11e299482eee1a8ac65", "git_parents": ["7841ee47654c4ae9edd789f61f994225c2fe4281"], "node": "90e78a8834da11d639229c20d015ce3c80f427c6", "parents": ["f89cd6d4972ae33d73dbb8bc831f04eca6aca8df"], "tags": []}], "date": 1783062151, "git_changesets": ["6c9258d5fa8d05c41be6f11e299482eee1a8ac65"], "user": "pchevrel@mozilla.com"}, "27258": {"changesets": [{"author": "Sotaro Ikeda \u003csotaro.ikeda.g@gmail.com\u003e", "branch": "default", "desc": "Bug 2051658  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309959\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310217\n", "files": ["gfx/webrender_bindings/RenderD3D11TextureHost.cpp"], "git_node": "0cd51a31e6b9cd4308128908e0d7dd763cecb138", "git_parents": ["6c9258d5fa8d05c41be6f11e299482eee1a8ac65"], "node": "3b33eb97d197d476f75c03596dbfd1c8a0fa853e", "parents": ["90e78a8834da11d639229c20d015ce3c80f427c6"], "tags": []}], "date": 1783062199, "git_changesets": ["0cd51a31e6b9cd4308128908e0d7dd763cecb138"], "user": "pchevrel@mozilla.com"}, "27259": {"changesets": [{"author": "Jack Brown \u003cjbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 2048027 - Add no_connectivity, captive_portal_state, and trr_only to load_aboutneterror -  a=pascalc\n\nAdds three extra keys to the `security.ui.neterror.load_aboutneterror` Glean event to differentiate between online vs. offline users who hit dnsNotFound (~3.1M DAU), which is currently invisible in telemetry.\n\nNew fields:\n- `no_connectivity`: whether Firefox classifies the user as offline via the OS link bit.\n- `captive_portal_state`: confirms the user is actually online.\n- `trr_only`: whether this is a TRR-only (DoH strict mode) failure.\n\nUsing the existing sendAsyncMessage/RPMAddMessageListener pattern for `captive_portal_state` like the other request-response pairs.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307895\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310205\n", "files": ["browser/base/content/test/about/browser_aboutNetError_telemetry.js", "docshell/base/nsDocShell.cpp", "toolkit/content/aboutNetErrorHelpers.mjs", "toolkit/content/metrics.yaml"], "git_node": "720306a1dde59dd668db576d31261a09a9265add", "git_parents": ["0cd51a31e6b9cd4308128908e0d7dd763cecb138"], "node": "002a0d16faca584408f20a49fa2e3b5d9ae96c93", "parents": ["3b33eb97d197d476f75c03596dbfd1c8a0fa853e"], "tags": []}], "date": 1783062237, "git_changesets": ["720306a1dde59dd668db576d31261a09a9265add"], "user": "pchevrel@mozilla.com"}, "27260": {"changesets": [{"author": "Randell Jesup \u003crjesup@mozilla.com\u003e", "branch": "default", "desc": "Bug 2045783: Clean up TRRQuery::CompleteLookup  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305279\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310199\n", "files": ["netwerk/dns/TRRQuery.cpp"], "git_node": "391aa9a5d9e0aae000c2859e418e9a6e278f2662", "git_parents": ["720306a1dde59dd668db576d31261a09a9265add"], "node": "4f8619b9f95e094b4e20ecfe7b0c47608db74799", "parents": ["002a0d16faca584408f20a49fa2e3b5d9ae96c93"], "tags": []}, {"author": "Randell Jesup \u003crjesup@mozilla.com\u003e", "branch": "default", "desc": "Bug 2045783: Add thread-safety checks to TRRQuery  a=pascalc\n\nBelt-and-suspenders; allows static analyisis\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305601\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310200\n", "files": ["netwerk/dns/TRRQuery.cpp", "netwerk/dns/TRRQuery.h"], "git_node": "bcdc63f961bc17cc0a46a2e7a78565137ffaf12f", "git_parents": ["391aa9a5d9e0aae000c2859e418e9a6e278f2662"], "node": "7fd8e702d7e686e3290436ff1b8e855aa4deb99b", "parents": ["4f8619b9f95e094b4e20ecfe7b0c47608db74799"], "tags": []}], "date": 1783062423, "git_changesets": ["391aa9a5d9e0aae000c2859e418e9a6e278f2662", "bcdc63f961bc17cc0a46a2e7a78565137ffaf12f"], "user": "pchevrel@mozilla.com"}, "27261": {"changesets": [{"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 2045865 - Use row_bytes rather than bitmap-\u003epitch when copying glyph.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307593\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310190\n", "files": ["gfx/cairo/cairo/src/cairo-ft-font.c", "gfx/cairo/patches/0037-pcf-row_bytes.patch"], "git_node": "7d474ca888c0eab5c580212946c95ec2d3f0c682", "git_parents": ["bcdc63f961bc17cc0a46a2e7a78565137ffaf12f"], "node": "482b260c19b8539d8319c40deec17bd9e50d4ae2", "parents": ["7fd8e702d7e686e3290436ff1b8e855aa4deb99b"], "tags": []}], "date": 1783062512, "git_changesets": ["7d474ca888c0eab5c580212946c95ec2d3f0c682"], "user": "pchevrel@mozilla.com"}, "27262": {"changesets": [{"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 2047719.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307948\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310171\n", "files": ["gfx/wr/swgl/src/gl.cc"], "git_node": "b32b181e1c20606ff28e5aa932cbb4e647855c28", "git_parents": ["7d474ca888c0eab5c580212946c95ec2d3f0c682"], "node": "12fa1b9150c762c6746efd1621ab2afbc02bba37", "parents": ["482b260c19b8539d8319c40deec17bd9e50d4ae2"], "tags": []}], "date": 1783062569, "git_changesets": ["b32b181e1c20606ff28e5aa932cbb4e647855c28"], "user": "pchevrel@mozilla.com"}, "27263": {"changesets": [{"author": "Antonio Borondo \u003caborondo@mozilla.com\u003e", "branch": "default", "desc": "Bug 2049995 - Make stub installer tests expect the ESR suffix in the legacy uninstall key  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309402\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310134\n", "files": ["browser/installer/windows/nsis/test_stub.nsi"], "git_node": "0d0d6dd70ccc679ba279567c3a4bfe69f5be3992", "git_parents": ["b32b181e1c20606ff28e5aa932cbb4e647855c28"], "node": "0b324929a0c2019085f8602a806f62697a17ac82", "parents": ["12fa1b9150c762c6746efd1621ab2afbc02bba37"], "tags": []}], "date": 1783062605, "git_changesets": ["0d0d6dd70ccc679ba279567c3a4bfe69f5be3992"], "user": "pchevrel@mozilla.com"}, "27264": {"changesets": [{"author": "az \u003cazebrowski@mozilla.com\u003e", "branch": "default", "desc": "Bug 2050110 - Avoid holding PDMFactorySupport mutex while registering invalidation listeners  a=pascalc\n\nPDMFactorySupport registered pref and gfxVar invalidation listeners while\nholding sInstanceMutex. That setup may require main thread initialization,\nincluding gfxVars initialization.\n\nMove listener registration before taking sInstanceMutex and initialize gfxVars\nas part of that main thread setup. Instance() now returns nullptr if\nregistration cannot complete or shutdown begins during the main thread hop to\navoid holding the mutex across work that can dispatch to the main thread.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309392\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310119\n", "files": ["dom/media/platforms/PDMFactorySupport.cpp", "dom/media/platforms/PDMFactorySupport.h"], "git_node": "559a2d5f3f71a1fe3fe15f13fda36fa5cd87e5ea", "git_parents": ["0d0d6dd70ccc679ba279567c3a4bfe69f5be3992"], "node": "5e09d790482035cf211e59d25109b7c4b7185ab3", "parents": ["0b324929a0c2019085f8602a806f62697a17ac82"], "tags": []}], "date": 1783062734, "git_changesets": ["559a2d5f3f71a1fe3fe15f13fda36fa5cd87e5ea"], "user": "pchevrel@mozilla.com"}, "27265": {"changesets": [{"author": "Bob Owen \u003cbobowencode@gmail.com\u003e", "branch": "default", "desc": "Bug 2045767 -  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305931\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310112\n", "files": ["dom/canvas/DrawTargetWebgl.cpp"], "git_node": "5a53b714d9829888b04f9a59512e18093bc2ad8b", "git_parents": ["559a2d5f3f71a1fe3fe15f13fda36fa5cd87e5ea"], "node": "fcab6fe52574d3495e2dd5037c2bc32ebf7bf6ee", "parents": ["5e09d790482035cf211e59d25109b7c4b7185ab3"], "tags": []}], "date": 1783064424, "git_changesets": ["5a53b714d9829888b04f9a59512e18093bc2ad8b"], "user": "pchevrel@mozilla.com"}, "27266": {"changesets": [{"author": "smayya \u003csmayya@mozilla.com\u003e", "branch": "default", "desc": "Bug 2049392 - improve nsStandardURL parsing. n=#necko  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309007\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310084\n", "files": ["netwerk/base/nsStandardURL.cpp"], "git_node": "a105dfefd54836dfca894ac9c0deeac26add20d8", "git_parents": ["5a53b714d9829888b04f9a59512e18093bc2ad8b"], "node": "6b2af918580d1d6bb11e448f3450b59b8b22aaf7", "parents": ["fcab6fe52574d3495e2dd5037c2bc32ebf7bf6ee"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 2045875 - Empty authority is not compatible with port  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306755\n\nDifferential Revision: https://ph