3c0bc07360c0813c\nsq -\u003e 526937eb297055a2e2b8a1023c0bc07360c0813c\nsr -\u003e 526937eb297055a2e2b8a1023c0bc07360c0813c\nsv-SE -\u003e 526937eb297055a2e2b8a1023c0bc07360c0813c\nta -\u003e 526937eb297055a2e2b8a1023c0bc07360c0813c\nte -\u003e 526937eb297055a2e2b8a1023c0bc07360c0813c\nth -\u003e 526937eb297055a2e2b8a1023c0bc07360c0813c\ntl -\u003e 526937eb297055a2e2b8a1023c0bc07360c0813c\ntr -\u003e 526937eb297055a2e2b8a1023c0bc07360c0813c\ntrs -\u003e 526937eb297055a2e2b8a1023c0bc07360c0813c\nuk -\u003e 526937eb297055a2e2b8a1023c0bc07360c0813c\nur -\u003e 526937eb297055a2e2b8a1023c0bc07360c0813c\nuz -\u003e 526937eb297055a2e2b8a1023c0bc07360c0813c\nvi -\u003e 526937eb297055a2e2b8a1023c0bc07360c0813c\nwo -\u003e 526937eb297055a2e2b8a1023c0bc07360c0813c\nxh -\u003e 526937eb297055a2e2b8a1023c0bc07360c0813c\nzam -\u003e 526937eb297055a2e2b8a1023c0bc07360c0813c\nzh-CN -\u003e 526937eb297055a2e2b8a1023c0bc07360c0813c\nzh-TW -\u003e 526937eb297055a2e2b8a1023c0bc07360c0813c\n", "files": ["mobile/locales/l10n-changesets.json"], "git_node": "590b566fcd13e82f5595047ddd3ae4eb93b197db", "git_parents": ["aee6fdc2bbbd630d2e32baef22baf7c5baf05335"], "node": "95bbe6ac7fb6f8ac42d49446c15f52dfbd3c0c44", "parents": ["9d4b1197bc3a945c7e1ba612108c0d1614a9f141"], "tags": []}], "date": 1783587823, "git_changesets": ["aee6fdc2bbbd630d2e32baef22baf7c5baf05335", "590b566fcd13e82f5595047ddd3ae4eb93b197db"], "user": "ffxbld@lando.moz.tools"}, "27363": {"changesets": [{"author": "Emma Zuehlcke \u003cemz@mozilla.com\u003e", "branch": "default", "desc": "Bug 2050000 - Block social media trackers from the redesigned ETP Custom UI.  a=pascalc\n\nThe old ETP Custom UI coupled the social tracking protection pref to the\ntracking protection scope menu, enabling it for all windows when the user\nblocks social tracking cookies. The settings redesign reimplemented these\ncontrols but never wrote the social tracking pref, so social media trackers\nwere no longer blocked in normal windows.\n\nMake the redesigned etpCustomTrackingProtectionEnabled toggle and\netpCustomTrackingProtectionEnabledContext scope settings write the social\ntracking pref alongside the tracking protection prefs, gated on the social\ntracking cookie pref, mirroring the old design's behavior.\n\nExtend the redesign's test_custom_tracking_protection_controls to cover the\nsocial tracking pref.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308988\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311300\n", "files": ["browser/components/preferences/config/privacy.mjs", "browser/components/preferences/tests/etp/browser_etp_customize_2.js"], "git_node": "56fabac86fa65a3452840e87cb84f0bfb97a4ebb", "git_parents": ["590b566fcd13e82f5595047ddd3ae4eb93b197db"], "node": "c7676a95a78d8f134b31d2e279b953eb36aa499e", "parents": ["95bbe6ac7fb6f8ac42d49446c15f52dfbd3c0c44"], "tags": []}, {"author": "Emma Zuehlcke \u003cemz@mozilla.com\u003e", "branch": "default", "desc": "Bug 2050749 - Force a tracker list update from the redesigned ETP Custom cryptominer/fingerprinter toggles.  a=pascalc\n\nThe legacy ETP Custom UI calls listManager.forceUpdates() when the user\ntoggles the Cryptominers or Known Fingerprinters checkboxes, refreshing the\nrelevant URL classifier tables immediately. The settings redesign bound these\ncontrols directly to their enabled prefs but dropped the list refresh, so\nprotection only took effect at the next scheduled list update.\n\nAdd onUserChange handlers to the etpCustomCryptominingProtectionEnabled and\netpCustomKnownFingerprintingProtectionEnabled settings that force an update of\nthe cryptomining/fingerprinting tracker tables, mirroring the old design's\nupdateCryptominingLists/updateFingerprintingLists behavior.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308994\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311301\n", "files": ["browser/components/preferences/config/privacy.mjs", "browser/components/preferences/tests/etp/browser_etp_customize_2.js"], "git_node": "68938b547d211702c473af55c2f8db98010c0184", "git_parents": ["56fabac86fa65a3452840e87cb84f0bfb97a4ebb"], "node": "21478b6eb9244db549920f81fa70f03ba872375c", "parents": ["c7676a95a78d8f134b31d2e279b953eb36aa499e"], "tags": []}, {"author": "Emma Zuehlcke \u003cemz@mozilla.com\u003e", "branch": "default", "desc": "Bug 2050750 - Record privacy.ui.fpp.click telemetry from the redesigned ETP Custom suspect fingerprinting controls.  a=pascalc\n\nThe legacy ETP Custom UI records the privacy.ui.fpp.click Glean events when\nthe user interacts with the suspect fingerprinting checkbox and scope menu.\nThe settings redesign reimplemented these controls but recorded no telemetry,\nso the probe (which never expires) stopped being collected from the new UI.\n\nRecord Glean.privacyUiFppClick.checkbox / .menu from the onUserChange handlers\nof the etpCustomSuspectFingerprintingProtectionEnabled and\netpCustomSuspectFingerprintingProtectionEnabledContext settings, mirroring the\nold design's instrumentation.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308995\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311302\n", "files": ["browser/components/preferences/config/privacy.mjs", "browser/components/preferences/tests/etp/browser_etp_customize_2.js"], "git_node": "162ca81359f1dffc879c0bb7a0ad16e1de532d97", "git_parents": ["68938b547d211702c473af55c2f8db98010c0184"], "node": "d94b65ff67c7fbd713686c59b96fc7a7e7aa8663", "parents": ["21478b6eb9244db549920f81fa70f03ba872375c"], "tags": []}], "date": 1783608599, "git_changesets": ["56fabac86fa65a3452840e87cb84f0bfb97a4ebb", "68938b547d211702c473af55c2f8db98010c0184", "162ca81359f1dffc879c0bb7a0ad16e1de532d97"], "user": "pchevrel@mozilla.com"}, "27364": {"changesets": [{"author": "Henri Sivonen \u003chsivonen@hsivonen.fi\u003e", "branch": "default", "desc": "Bug 2048944 - Restore ISO-2022-JP detection for plain text.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308005\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311296\n", "files": ["dom/html/nsHTMLDocument.cpp", "dom/html/nsHTMLDocument.h", "extensions/universalchardet/tests/bug2048944.text", "extensions/universalchardet/tests/chrome.toml", "extensions/universalchardet/tests/test_bug2048944.html", "parser/html/nsHtml5StreamParser.cpp"], "git_node": "aaf40d8834c2b71ad85376231793f45bf15bd867", "git_parents": ["162ca81359f1dffc879c0bb7a0ad16e1de532d97"], "node": "6b5e8e0e0aea79d8de84819640a18b39e58d6f4b", "parents": ["d94b65ff67c7fbd713686c59b96fc7a7e7aa8663"], "tags": []}], "date": 1783608635, "git_changesets": ["aaf40d8834c2b71ad85376231793f45bf15bd867"], "user": "pchevrel@mozilla.com"}, "27365": {"changesets": [{"author": "Matthew Gaudet \u003cmgaudet@mozilla.com\u003e", "branch": "default", "desc": "Bug 2052375 - Partially Revert \"Bug 1996693 - JS::PersistentRooted from PullWithDefaultReaderChunkStepMicrotask::mChunk\"  a=pascalc\n\nKeep the test though.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D310701\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311286\n", "files": ["dom/streams/ReadableStreamTee.cpp"], "git_node": "9783926affd3998e1c368570ae8f02f45610c8b5", "git_parents": ["aaf40d8834c2b71ad85376231793f45bf15bd867"], "node": "c1b0678a1671018e0fda8cf08ec30b5fd8207058", "parents": ["6b5e8e0e0aea79d8de84819640a18b39e58d6f4b"], "tags": []}], "date": 1783608675, "git_changesets": ["9783926affd3998e1c368570ae8f02f45610c8b5"], "user": "pchevrel@mozilla.com"}, "27366": {"changesets": [{"author": "Tymur Boiko \u003ctboiko@nvidia.com\u003e", "branch": "default", "desc": "Bug 2052037 - MOZ/GTK - Fix VAAPI regression for NV12 plane 1 format swap.  a=pascalc\n\nBug 2021722 introduced an RG88/GR88 plane-1 swap heuristic for NV12/P010\nthat unconditionally applied the format swap when the original format had no\nEGL modifier support, without verifying that the swapped format was actually\nsupported. On AMD Polaris, neither GR88 nor RG88 has EGL modifier support, so\nthe swap to RG88 caused fCreateImage to return EGL_BAD_MATCH.\n\nFix: only apply the swap when fQueryDmaBufModifiersEXT reports that the\nswapped format has at least one supported modifier.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309953\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311250\n", "files": ["widget/gtk/DMABufSurface.cpp"], "git_node": "1320500719b336058e207733b0e602a3be0add99", "git_parents": ["9783926affd3998e1c368570ae8f02f45610c8b5"], "node": "e5588879fe6a849a111195c4b6f323c57bc6ea34", "parents": ["c1b0678a1671018e0fda8cf08ec30b5fd8207058"], "tags": []}], "date": 1783608714, "git_changesets": ["1320500719b336058e207733b0e602a3be0add99"], "user": "pchevrel@mozilla.com"}, "27367": {"changesets": [{"author": "Mugurell \u003cMugurell@users.noreply.github.com\u003e", "branch": "default", "desc": "Bug 2050250 - Ensure the bottom sheet handle of the protections dashboard has 48dp height  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309785\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311244\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/trackingprotection/ProtectionsDashboardContent.kt"], "git_node": "e5eb348ac0a5fb6a5cb042e927b319fb2a0ebd2b", "git_parents": ["1320500719b336058e207733b0e602a3be0add99"], "node": "a76b3b1d74d0b8614b612e9e35584d4db0877532", "parents": ["e5588879fe6a849a111195c4b6f323c57bc6ea34"], "tags": []}], "date": 1783608751, "git_changesets": ["e5eb348ac0a5fb6a5cb042e927b319fb2a0ebd2b"], "user": "pchevrel@mozilla.com"}, "27368": {"changesets": [{"author": "Omar Gonzalez \u003cs9tpepper@apache.org\u003e", "branch": "default", "desc": "Bug 2047558 - Center Smart Window content area to Smartbar input  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309742\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311161\n", "files": ["browser/components/aiwindow/ui/components/ai-chat-content/ai-chat-content.css", "browser/components/aiwindow/ui/components/ai-window/ai-window.css"], "git_node": "b7a320f8040a1b8fc4ec05853883e51d6d3578cb", "git_parents": ["e5eb348ac0a5fb6a5cb042e927b319fb2a0ebd2b"], "node": "2aa93d053977040346934bf27ce36c87e4946e4e", "parents": ["a76b3b1d74d0b8614b612e9e35584d4db0877532"], "tags": []}], "date": 1783608789, "git_changesets": ["b7a320f8040a1b8fc4ec05853883e51d6d3578cb"], "user": "pchevrel@mozilla.com"}, "27369": {"changesets": [{"author": "Magnus Melin \u003cmkmelin+mozilla@iki.fi\u003e", "branch": "default", "desc": "Bug 2050420 - Avoid Error: can't access property \"focus\", defaultButton is undefined when the dialog doesn't have a default.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308779\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311137\n", "files": ["toolkit/content/widgets/dialog.js"], "git_node": "cc390b4cff03b440bc2d6700bc0aa86ef81d07b9", "git_parents": ["b7a320f8040a1b8fc4ec05853883e51d6d3578cb"], "node": "f9d76ba6c2e61ed672f5267bb9f91258957b2a59", "parents": ["2aa93d053977040346934bf27ce36c87e4946e4e"], "tags": []}], "date": 1783608829, "git_changesets": ["cc390b4cff03b440bc2d6700bc0aa86ef81d07b9"], "user": "pchevrel@mozilla.com"}, "27370": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2051021 - Detect and work around fontconfig regression in FcNameUnparse.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D310801\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311098\n", "files": ["gfx/thebes/gfxFcPlatformFontList.cpp"], "git_node": "25849773095a4fb35530e1c611c5b41e77361b57", "git_parents": ["cc390b4cff03b440bc2d6700bc0aa86ef81d07b9"], "node": "0b9424832436e48109dfd7d20e0cc24e9e31e86c", "parents": ["f9d76ba6c2e61ed672f5267bb9f91258957b2a59"], "tags": []}], "date": 1783608867, "git_changesets": ["25849773095a4fb35530e1c611c5b41e77361b57"], "user": "pchevrel@mozilla.com"}, "27371": {"changesets": [{"author": "Byron Campen \u003cdocfaraday@gmail.com\u003e", "branch": "default", "desc": "Bug 2043188: Simplify the buffer handling in RTCEncodedFrameBase.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305725\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311091\n", "files": ["dom/media/webrtc/jsapi/RTCEncodedFrameBase.cpp"], "git_node": "250b9ca2dffdc98f1a66d7f9cf9d8c80965a0537", "git_parents": ["25849773095a4fb35530e1c611c5b41e77361b57"], "node": "4f76153bdbcda969b2861658249ee55852999df6", "parents": ["0b9424832436e48109dfd7d20e0cc24e9e31e86c"], "tags": []}], "date": 1783608905, "git_changesets": ["250b9ca2dffdc98f1a66d7f9cf9d8c80965a0537"], "user": "pchevrel@mozilla.com"}, "27372": {"changesets": [{"author": "Nicolas Silva \u003cnsilva@mozilla.com\u003e", "branch": "default", "desc": "Bug 2044978 - Use SWGL fast paths more in ps_quad_textued.glsl.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307503\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311076\n", "files": ["gfx/wr/webrender/res/ps_quad_textured.glsl"], "git_node": "a461fadbfc5c3481d4e083828c78602bec1dc28e", "git_parents": ["250b9ca2dffdc98f1a66d7f9cf9d8c80965a0537"], "node": "3e9916baddc8fbfca150bf9ab3356288da2410f3", "parents": ["4f76153bdbcda969b2861658249ee55852999df6"], "tags": []}], "date": 1783608943, "git_changesets": ["a461fadbfc5c3481d4e083828c78602bec1dc28e"], "user": "pchevrel@mozilla.com"}, "27373": {"changesets": [{"author": "mcarare \u003c48995920+mcarare@users.noreply.github.com\u003e", "branch": "default", "desc": "Bug 2053032 - Make the SettingsScreen vertically scrollable  a=pascalc\n\nThe `SettingsScreen` used a `Column` with `fillMaxSize` but lacked a scroll state, which could prevent users from accessing all settings items on smaller screens or landscape orientation. This change adds `verticalScroll` with a `rememberScrollState` to the main container to ensure all content is accessible.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D310766\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311028\n", "files": ["mobile/android/focus-android/app/src/main/java/org/mozilla/focus/settings/SettingsScreen.kt"], "git_node": "53c95b9ab63abe50b7c3a6efc2f820eaf02b8bc6", "git_parents": ["a461fadbfc5c3481d4e083828c78602bec1dc28e"], "node": "e6a15c9734a92de846dd5a4aec692b7908a166ce", "parents": ["3e9916baddc8fbfca150bf9ab3356288da2410f3"], "tags": []}], "date": 1783608982, "git_changesets": ["53c95b9ab63abe50b7c3a6efc2f820eaf02b8bc6"], "user": "pchevrel@mozilla.com"}, "27374": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2052637 - Fix nsFrameSelection::GetPageToFrameSelect.  a=pascalc\n\nIn this test-case, rootFrameToSelect is the inner editor's frame, but\ncontentToSelect is the textarea, which is an ancestor.\n\nSo we go from `\u003ctextarea\u003e` all the way to the root frame finding\nscrollable frames which is not the intended behavior. Instead, we check\nnsLayoutUtils::IsProperAncestorFrame to make sure that we walk\ncorrectly.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D310594\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311023\n", "files": ["layout/generic/nsFrameSelection.cpp", "testing/web-platform/mozilla/tests/html/semantics/forms/the-textarea-element/textarea-pagedown-selection.html"], "git_node": "3e048105f17fe98b54a868f341bf993382dfea8a", "git_parents": ["53c95b9ab63abe50b7c3a6efc2f820eaf02b8bc6"], "node": "68fe31ab8b6bd8aea87cc504612a0c69d8a1657a", "parents": ["e6a15c9734a92de846dd5a4aec692b7908a166ce"], "tags": []}], "date": 1783609023, "git_changesets": ["3e048105f17fe98b54a868f341bf993382dfea8a"], "user": "pchevrel@mozilla.com"}, "27375": {"changesets": [{"author": "Mugurell \u003cMugurell@users.noreply.github.com\u003e", "branch": "default", "desc": "Bug 2048114 - Ensure settings items titles have w400 on all API levels  a=pascalc\n\nMaterial3 uses the `sanse-serif-medium` font for preferences titles which\nhas a 500 weight.\nWe were trying to reduce the weight to 400 through `textFontWeight` and\n`fontWeight` but only `textFontWeight` applies to TextViews and this only\nworks on Android 9+.\nUsing the `sans-serif` font will ensure w400 on all API levels.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307259\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311010\n", "files": ["mobile/android/fenix/app/src/main/res/values/styles.xml"], "git_node": "8f127034c3029a56354ffb33a590f700f9f369fd", "git_parents": ["3e048105f17fe98b54a868f341bf993382dfea8a"], "node": "fe64b2a1e34c7893b7e5936ccc96ac2f06612ddc", "parents": ["68fe31ab8b6bd8aea87cc504612a0c69d8a1657a"], "tags": []}], "date": 1783609061, "git_changesets": ["8f127034c3029a56354ffb33a590f700f9f369fd"], "user": "pchevrel@mozilla.com"}, "27376": {"changesets": [{"author": "stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 2046299 [Linux] Fix nsGNOMEShellService build with disabled DBus  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305817\n\nDifferential Revision: https://phabricator.services.mozilla.com/D311002\n", "files": ["browser/components/shell/nsGNOMEShellService.cpp", "browser/components/shell/nsShellService.h", "widget/gtk/moz.build", "widget/gtk/nsAppShell.cpp", "widget/gtk/nsDragServiceWayland.cpp", "widget/gtk/nsWidgetFactory.cpp"], "git_node": "3e07c10276c2dd592ce140beffcfc745409f2c71", "git_parents": ["8f127034c3029a56354ffb33a590f700f9f369fd"], "node": "5d074286779c34e3aed39c61244e52f1d26542b0", "parents": ["fe64b2a1e34c7893b7e5936ccc96ac2f06612ddc"], "tags": []}], "date": 1783609155, "git_changesets": ["3e07c10276c2dd592ce140beffcfc745409f2c71"], "user": "pchevrel@mozilla.com"}, "27377": {"changesets": [{"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 2046554 - Search engines should be removed from the settings UI when removed via enterprise policy.  a=pascalc\n\nThis takes the approach of the search preferences examining the list, as that is simpler than working an extra flag into the search service for \"hidden by enterprise policy\".\n\nThe approach has the advantage that we're using the exact enterprise policy settings list directly to hide the engines from the UI, and thus avoids any cases that the local saved settings could get out of sync with the enterprise policy settings.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309450\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310998\n", "files": ["browser/components/preferences/config/search.mjs", "browser/components/preferences/search.js", "browser/components/preferences/tests/search/browser-srd.toml", "browser/components/preferences/tests/search/browser_search_engineList_enterprise.js", "toolkit/components/search/SearchService.sys.mjs", "toolkit/components/search/SearchSettings.sys.mjs", "toolkit/components/search/SearchUtils.sys.mjs", "toolkit/components/search/tests/xpcshell/test_move_engine.js", "toolkit/components/search/tests/xpcshell/test_settings_migrate_14.js", "toolkit/components/search/tests/xpcshell/xpcshell.toml"], "git_node": "e4179627ba7463a2dcf0eb3e28130f72693327fa", "git_parents": ["3e07c10276c2dd592ce140beffcfc745409f2c71"], "node": "23d25885b0a85a4ce8936afa85c9165cc7552dd7", "parents": ["5d074286779c34e3aed39c61244e52f1d26542b0"], "tags": []}], "date": 1783609177, "git_changesets": ["e4179627ba7463a2dcf0eb3e28130f72693327fa"], "user": "pchevrel@mozilla.com"}, "27378": {"changesets": [{"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 2047650 - Weaken an assertion that did not handle spurious wakeups  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308901\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310894\n", "files": ["js/src/gc/ParallelMarking.cpp", "js/src/gc/ParallelMarking.h"], "git_node": "befaefee8e93867e5e222163c7404ea2e7854347", "git_parents": ["e4179627ba7463a2dcf0eb3e28130f72693327fa"], "node": "c75d6da28333b26cbf0cd9c008ea3a7fa9037a9f", "parents": ["23d25885b0a85a4ce8936afa85c9165cc7552dd7"], "tags": []}], "date": 1783609200, "git_changesets": ["befaefee8e93867e5e222163c7404ea2e7854347"], "user": "pchevrel@mozilla.com"}, "27379": {"changesets": [{"author": "Giulia Cardieri \u003cgcardieri@mozilla.com\u003e", "branch": "default", "desc": "Bug 2050943: Fix restore session when smart window is default  a=pascalc\n\n**Issue**: Restore previous session option is disabled when smart window is the default\n\n**What I found:**\n- `SessionStartup.sessionType` becomes 0 when a smart window is the default - indicating the session is null which makes restoring the session impossible\n- This is related to the `openBrowserWindow` changes I did in my previous patch. Even though a smart window as default is properly saved by session store, when we open a new window it reads the previous one as \"no session / 0\".\n\n**Root causes:**\n1. In `BrowserContentHandler`, method `openBrowserWindow` we check `lazy.SessionStartup.willRestore()` to ensure we won't overwrite the classic new tab url over the smart window new tab url. But this is being called too soon and makes Session Storage cache the session type value to 0, as there was no session yet, and when it tries to get the correct value from last session it ignores it because of the cached value. However, fixing this uncovers another bug.\n2. The smart window transparency part of `tabbrowser.js` assumed firstURI was always a string, which is not true as it could be a promise (other parts of the code already treat it as a promise).\n3. Even after fixing #1, smart window was visible for less than a second and overwritten by classic new tab (issue that I also saw in the previous patch). This is a separate problem: when a session is restored `restoreWindowFeatures` from `SessionStore.sys.mjs`decides if the window should be smart or classic based on the `shouldBeAIWindow` variable. But if we have the pref `startup.page=1` (deferred restore), the isAIWindow flag is lost and was assuming it was a classic window. At the end, I updated `shouldBeAIWindow` to check if smart window is the default, we are not fully restoring a session and this is the first window open - keep the window as smart.\n\n**Any new window with the smart as default pref should be smart.\nAny restored window should respect the original type, classic or smart**\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309619\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310884\n", "files": ["browser/components/BrowserContentHandler.sys.mjs", "browser/components/sessionstore/SessionStore.sys.mjs", "browser/components/sessionstore/test/marionette/test_restore_aiwindow.py", "browser/components/tabbrowser/content/tabbrowser.js"], "git_node": "a48f903d0835349149045a1e11a09348f7f6f2d6", "git_parents": ["befaefee8e93867e5e222163c7404ea2e7854347"], "node": "1749c9891229037a200dd160a641d351b669abe5", "parents": ["c75d6da28333b26cbf0cd9c008ea3a7fa9037a9f"], "tags": []}], "date": 1783609226, "git_changesets": ["a48f903d0835349149045a1e11a09348f7f6f2d6"], "user": "pchevrel@mozilla.com"}, "27380": {"changesets": [{"author": "mike a \u003cmavduevskiy@mozilla.com\u003e", "branch": "default", "desc": "Bug 2052599 - Fix vpn onboarding flow for signed  a=pascalc\n\n...in users.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D310430\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310882\n", "files": ["mobile/android/android-components/components/feature/ipprotection/src/main/java/mozilla/components/feature/ipprotection/store/Reducers.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/ipprotection/ui/IPProtectionBottomSheetFragment.kt"], "git_node": "9605de1528e1039a1b5e9fa582543fb003919665", "git_parents": ["a48f903d0835349149045a1e11a09348f7f6f2d6"], "node": "5a4144ae0b352dd1379dc4a9fc7812bebf369745", "parents": ["1749c9891229037a200dd160a641d351b669abe5"], "tags": []}], "date": 1783609265, "git_changesets": ["9605de1528e1039a1b5e9fa582543fb003919665"], "user": "pchevrel@mozilla.com"}, "27381": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2045407 - Validate surface format properly.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305381\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310849\n", "files": ["gfx/layers/DcompSurfaceImage.cpp", "gfx/layers/composite/TextureHost.cpp", "gfx/layers/d3d11/TextureD3D11.cpp", "gfx/layers/opengl/DMABUFTextureHostOGL.cpp", "gfx/layers/opengl/MacIOSurfaceTextureHostOGL.cpp", "gfx/layers/opengl/TextureHostOGL.cpp", "gfx/layers/wr/AsyncImagePipelineManager.cpp", "gfx/layers/wr/WebRenderBridgeParent.cpp", "gfx/layers/wr/WebRenderCommandBuilder.cpp", "gfx/layers/wr/WebRenderMessageUtils.h", "gfx/webrender_bindings/WebRenderTypes.h", "image/BlobSurfaceProvider.cpp", "layout/generic/TextDrawTarget.h"], "git_node": "d6b9233369871cbc0d857790842bf0da8e9899ae", "git_parents": ["9605de1528e1039a1b5e9fa582543fb003919665"], "node": "8d54d4f84b5bf9b2a93d362808ec68c821214068", "parents": ["5a4144ae0b352dd1379dc4a9fc7812bebf369745"], "tags": []}], "date": 1783609304, "git_changesets": ["d6b9233369871cbc0d857790842bf0da8e9899ae"], "user": "pchevrel@mozilla.com"}, "27382": {"changesets": [{"author": "Alexandre Poirot \u003cpoirot.alex@gmail.com\u003e", "branch": "default", "desc": "Bug 2044464 - [devtools] Emit an event from TargetCommand to track target location updates.  a=pascalc\n\nTargetFront's url and title are updated on very specific DOCUMENT_EVENT ressources reception.\nThis logic is quite complex and racy against this logic from TargetCommand.\nExpose a custom event to easily acknowledge the new location for all the\ntargets.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D304435\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310687\n", "files": ["devtools/client/framework/toolbox.js", "devtools/shared/commands/target/target-command.js"], "git_node": "5980574547498e11ff187ad1e5ef2f53332f4874", "git_parents": ["d6b9233369871cbc0d857790842bf0da8e9899ae"], "node": "23056e75e02f153d09fd407c9a2280e6b7463667", "parents": ["8d54d4f84b5bf9b2a93d362808ec68c821214068"], "tags": []}, {"author": "Alexandre Poirot \u003cpoirot.alex@gmail.com\u003e", "branch": "default", "desc": "Bug 2044464 - [devtools] Notify the user about Local Mode when loading files via file:// URL.  a=pascalc\n\nMove all LocalModeMappings out of toolbox (the local-mode-mappings-updated event).\nAlso move some logic from options panel to LocalModeMappings\n(getNextAvailableOrigin, createNewMapping).\n\nIf the file location isn't mapped yet, the notification offers two actions:\n* add to settings to permanently add a mapping while highlighting the\n  new setting in the options panel, so that the user know where to\n  configure it later on.\n* try a transient mapping that will be lost once devtools is closed.\n\nIn both cases the mapping is automatically loaded.\n\nIf the file location is mapped, it offers a navigation button.\n\nIn all cases, a \"don't show me this again\" button is shown to\npermanently dismiss all these type of notifications.\n\nNote that there is some smart logic to handle files versus folder,\nwhere we will always map the folder or file's folder. We then\ncompute the right URL if a file was given.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D294238\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310688\n", "files": ["devtools/client/framework/LocalModeMappings.sys.mjs", "devtools/client/framework/test/browser.toml", "devtools/client/framework/test/browser_toolbox_options_local_mode.js", "devtools/client/framework/test/browser_toolbox_options_local_mode_notice.js", "devtools/client/framework/test/local-mode/folder/test.html", "devtools/client/framework/toolbox-options.js", "devtools/client/locales/en-US/toolbox.ftl", "devtools/client/shared/components/NotificationBox.css", "devtools/client/shared/components/NotificationBox.js", "devtools/client/storage/test/browser_storage_file_url.js", "devtools/client/storage/test/storage-file-url.html", "devtools/client/storage/test/storage-indexeddb-duplicate-names.html"], "git_node": "c2f39034bf942ccb21d204a39f72d3672d2a7353", "git_parents": ["5980574547498e11ff187ad1e5ef2f53332f4874"], "node": "7d800bd9a520277bf7b6fb09bea2d5d5096631b4", "parents": ["23056e75e02f153d09fd407c9a2280e6b7463667"], "tags": []}], "date": 1783609353, "git_changesets": ["5980574547498e11ff187ad1e5ef2f53332f4874", "c2f39034bf942ccb21d204a39f72d3672d2a7353"], "user": "pchevrel@mozilla.com"}, "27383": {"changesets": [{"author": "Anna Kulyk \u003cakulyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 2052040 - Handle legacy object format for browser.backup.enabled_on.profiles in settings  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D309905\n\nDifferential Revision: https://phabricator.services.mozilla.com/D310125\n", "files": ["browser/components/preferences/config/permissions-data.mjs", "browser/components/preferences/tests/searchResults/browser-srd.toml", "browser/components/preferences/tests/searchResults/browser_search_backup_multi_profile_legacy_pref.js"], "git_node": "85d29de1cea63d71f3a7ea8fe6f774ff9cb5c9d0", "git_parents": ["c2f39034bf942ccb21d204a39f72d3672d2a7353"], "node": "b614a65643f83b20b842510aa56b55aba36c7049", "parents": ["7d800bd9a520277bf7b6fb09bea2d5d5096631b4"], "tags": []}], "date": 1783609395, "git_changesets": ["85d29de1cea63d71f3a7ea8fe6f774