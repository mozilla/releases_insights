1c0105e49607eaa33c047a9e", "parents": ["fe6c1575e3b2829a089e2438ad9a9952d839ecbd"], "tags": []}], "date": 1782349334, "git_changesets": ["ae35116d9ad3756e9db19359c58906ac6c29439d"], "user": "ffxbld@lando.moz.tools"}, "27081": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Import translations from main\n", "files": ["mobile/android/android-components/components/browser/errorpages/src/main/res/values-lt/strings.xml", "mobile/android/android-components/components/feature/ipprotection/src/main/res/values-bqi/strings.xml", "mobile/android/android-components/components/feature/protection-dashboard/src/main/res/values-bqi/strings.xml", "mobile/android/android-components/components/feature/summarize/src/main/res/values-bqi/strings.xml", "mobile/android/fenix/app/src/main/res/values-bqi/strings.xml", "mobile/android/fenix/app/src/main/res/values-el/strings.xml", "mobile/android/fenix/app/src/main/res/values-es/strings.xml", "mobile/android/fenix/app/src/main/res/values-fr/strings.xml", "mobile/android/fenix/app/src/main/res/values-lt/strings.xml", "mobile/android/fenix/app/src/main/res/values-tr/strings.xml", "mobile/android/fenix/app/src/main/res/values-zh-rTW/strings.xml"], "git_node": "bedc3094159ee72737b938b19a8d2d418c71830c", "git_parents": ["81f807d3d41927735dd12716a920b3406dca2293"], "node": "6c666eda765c9a18f68e7f939082503f2523c0a8", "parents": ["7987cadaabad6901e66efc22ea0fbdaebe5cc3c3"], "tags": []}], "date": 1782353876, "git_changesets": ["bedc3094159ee72737b938b19a8d2d418c71830c"], "user": "ffxbld@lando.moz.tools"}, "27082": {"changesets": [{"author": "Morgan Rae Reschenberg \u003cmreschenberg@berkeley.edu\u003e", "branch": "default", "desc": "Bug 2046009: Compute bounds for display:contents accessibles from accessible children  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306266\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308087\n", "files": ["accessible/generic/LocalAccessible.cpp", "accessible/ipc/RemoteAccessible.cpp", "accessible/ipc/RemoteAccessible.h", "accessible/tests/browser/bounds/browser_test_display_contents.js"], "git_node": "e96e72e8344ccd5a9eafb3087f7d030620b7b208", "git_parents": ["bedc3094159ee72737b938b19a8d2d418c71830c"], "node": "f03f0e8f348b32fffab28368e3375daf43e4d047", "parents": ["6c666eda765c9a18f68e7f939082503f2523c0a8"], "tags": []}, {"author": "Morgan Rae Reschenberg \u003cmreschenberg@berkeley.edu\u003e", "branch": "default", "desc": "Bug 2046009: Add performance tests for bounds, display:contents bounds  a=pascalc\n\nThis patch adds two performance tests to measure the cost of the naive solution to bounds computation for display:contents accessibles against our \"normal\" bounds ocmputation. Here's some data from a recent try run that shows how this algorithm compares to (a) our basic bounds algorithm and (b) other hot paths in our perf test suite.\n\nA summary, to save some time digging into the data:\n\nAs you might expect, a single `getBounds()` on a `display:contents` container with 10k children costs more than any other tracked per-op cost in the suite. The cost for this operation is ~3\u20135 milliseconds. The cost for 100 of these queries (the entire test run) is ~300-500 milliseconds.\n\nI think this is still worth shipping as a stop gap for the kind of navigation issues VoiceOver experiences as a result. I ALSO think we should dig in further and come up with a more performant situation.\n\nSeparately: Linux is an outlier on `browser_addManyNodes.js`... what's going on there...\n\nTry push: \u003chttps://treeherder.mozilla.org/jobs?repo=try&landoInstance=lando-prod-2025&landoCommitID=57011\u003e\n\n| Test | linux2404-64-shippable | mac1015-64-shippable-qr | win11-24h2-shippable | win11-24h2-hw-ref-shippable |\n|---|---:|---:|---:|---:|\n| `browser_bounds.js` | 0.472 ms | 0.274 ms | 0.289 ms | 0.425 ms |\n| `browser_displayContentsBounds.js` | 477.690 ms | 554.363 ms | 344.961 ms | 346.721 ms |\n\n| Test                               | linux2404-64-shippable | mac1015-64-shippable-qr | win11-24h2-shippable | win11-24h2-hw-ref-shippable |\n| ---------------------------------- | ---------------------: | ----------------------: | -------------------: | --------------------------: |\n| `browser_bounds.js`                |                4.72 \u00b5s |                 2.74 \u00b5s |              2.89 \u00b5s |                     4.25 \u00b5s |\n| `browser_displayContentsBounds.js` |             4776.90 \u00b5s |              5543.63 \u00b5s |           3449.61 \u00b5s |                  3467.21 \u00b5s |\n\nEach perftest runs a hot loop of N operations and reports the total wall time. Dividing\ntotal time by N gives an approximate time-per-call cost.\n\n| Test | N (ops) | linux | mac CI | win-main | win-ref |\n|---|---:|---:|---:|---:|---:|\n| `browser_addManyIds.js` (setAttribute id) | 10,000 | 5.76 \u00b5s | 6.65 \u00b5s | 3.58 \u00b5s | 3.28 \u00b5s |\n| `browser_addManyNodes.js` (append child div) | 100,000 | 246.61 \u00b5s | 38.12 \u00b5s | 23.45 \u00b5s | 23.63 \u00b5s |\n| `browser_bounds.js` (`getBounds` on framed) | 100 | 4.72 \u00b5s | 2.74 \u00b5s | 2.89 \u00b5s | 4.25 \u00b5s |\n| `browser_displayContentsBounds.js` (`getBounds` on display:contents) | 100 | 4,776.90 \u00b5s | 5,543.63 \u00b5s | 3,449.61 \u00b5s | 3,467.21 \u00b5s |\n| `browser_implicitRoleARIAExpanded.js` (append element w/ implicit role) | 10,000 | 22.06 \u00b5s | 20.50 \u00b5s | 11.40 \u00b5s | 13.19 \u00b5s |\n| `browser_reflowPseudoelements.js` (reflow pseudoelement) | 15,000 | 37.06 \u00b5s | 46.76 \u00b5s | 25.72 \u00b5s | 30.65 \u00b5s |\n| `browser_removeManySpellingErrors.js` (remove spell error) | 500 | 168.26 \u00b5s | 192.78 \u00b5s | 90.61 \u00b5s | 116.92 \u00b5s |\n\nOriginal Revision: https://phabricator.services.mozilla.com/D306267\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308088\n", "files": ["accessible/tests/browser/performance/browser_bounds.js", "accessible/tests/browser/performance/browser_displayContentsBounds.js", "accessible/tests/browser/performance/perftest.toml", "python/mozperftest/perfdocs/config.yml", "taskcluster/kinds/perftest/linux.yml", "taskcluster/kinds/perftest/macosx.yml", "taskcluster/kinds/perftest/windows11-24h2-ref.yml", "taskcluster/kinds/perftest/windows11-24h2.yml", "testing/perfdocs/generated/mozperftest.rst"], "git_node": "8a9b371cbf45f5f714267ebc5da618a065392366", "git_parents": ["e96e72e8344ccd5a9eafb3087f7d030620b7b208"], "node": "66093b348eb8824186e46c0f997de1938a231be8", "parents": ["f03f0e8f348b32fffab28368e3375daf43e4d047"], "tags": []}], "date": 1782375163, "git_changesets": ["e96e72e8344ccd5a9eafb3087f7d030620b7b208", "8a9b371cbf45f5f714267ebc5da618a065392366"], "user": "pchevrel@mozilla.com"}, "27083": {"changesets": [{"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 2049754 - Ensure the enterprise policies service is always initialised for test_searchconfig_google_additional.js.  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308352\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308363\n", "files": ["toolkit/components/search/tests/xpcshell/searchconfigs/test_searchconfig_google_additional.js"], "git_node": "3689b56c7760080d5484bbb035166c9bc1c264d9", "git_parents": ["8a9b371cbf45f5f714267ebc5da618a065392366"], "node": "7b274b2beabb0789ee6664ba095608d0bb819b06", "parents": ["66093b348eb8824186e46c0f997de1938a231be8"], "tags": []}], "date": 1782376282, "git_changesets": ["3689b56c7760080d5484bbb035166c9bc1c264d9"], "user": "pchevrel@mozilla.com"}, "27084": {"changesets": [{"author": "Tooru Fujisawa \u003carai_a@mac.com\u003e", "branch": "default", "desc": "Bug 2042605 - Do not cache linkedin insight.min.js.  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305776\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308472\n", "files": ["dom/script/ScriptLoader.cpp"], "git_node": "e2f733fa9012466daace48c9e5a632bc526937ff", "git_parents": ["3689b56c7760080d5484bbb035166c9bc1c264d9"], "node": "608191c41b0c5117a38626b1b52e418ac764f22b", "parents": ["7b274b2beabb0789ee6664ba095608d0bb819b06"], "tags": []}], "date": 1782376330, "git_changesets": ["e2f733fa9012466daace48c9e5a632bc526937ff"], "user": "pchevrel@mozilla.com"}, "27085": {"changesets": [{"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 2045482: Align with hasSpaceForInsts to simplify test case.  a=pascalc DONTBUILD\n\nAlign with `hasSpaceForInsts` so the test case doesn't need to emit\nthirty additional nop instructions.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305903\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308479\n", "files": ["js/src/jit/shared/IonAssemblerBufferWithConstantPools.h", "js/src/jsapi-tests/testAssemblerBuffer.cpp"], "git_node": "c7454b3291fef353a138a0ee9aea3405d9cb0a3f", "git_parents": ["e2f733fa9012466daace48c9e5a632bc526937ff"], "node": "44cf3c00d2e7071f2a909867ea0b58f381d08751", "parents": ["608191c41b0c5117a38626b1b52e418ac764f22b"], "tags": []}], "date": 1782376381, "git_changesets": ["c7454b3291fef353a138a0ee9aea3405d9cb0a3f"], "user": "pchevrel@mozilla.com"}, "27086": {"changesets": [{"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 2045607 - Hold a strong ref during GetFontAt lookup.  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D307564\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308505\n", "files": ["gfx/thebes/gfxTextRun.cpp"], "git_node": "b8e2709cd933e0bc103d79637a2f4520a2741d10", "git_parents": ["c7454b3291fef353a138a0ee9aea3405d9cb0a3f"], "node": "4188aadc8e61395a95a747403cbc1d6539f68701", "parents": ["44cf3c00d2e7071f2a909867ea0b58f381d08751"], "tags": []}], "date": 1782376429, "git_changesets": ["b8e2709cd933e0bc103d79637a2f4520a2741d10"], "user": "pchevrel@mozilla.com"}, "27087": {"changesets": [{"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 2049044 - Don't reuse `IMEContentObserver` if the editing host in the design mode is changed  a=pascalc\n\nBasically, `HTMLEditor`, `IMEContentObserver`, etc treat the `\u003cbody\u003e` as\nthe editing host in the design mode. However, if there is no `\u003cbody\u003e`,\nthey treats the document element as the editing host.\n\nWhen `IMEContentObserver` is initialized, its\n`mRootEditableNodeOrTextControlElement` is set to the `Document` if the\neditor is in the design mode. Then, passing any element to\n`IMEContentObserver::IsObservingElement()` gets `true` even after\nthe editing host has been changed.\n\nWhen the editing host is changed, `IMEContentObserver` needs to notify\nIME of all text changes and new selection range. However, there is no\nway to \"reset\" all contents in IME without a focus move notification.\nTherefore, if the editing host has been changed,\n`IMEContentObserver::MaybeReinitialize()` should stop reusing itself.\nThen, `IMEStateManager` will recreate `IMEContentObserver` and sends\n`blur` and `focus` to IME.\n\nNote that this patch changes the `mRootElement` computation within the\nnew method because of a bug of the no selection case in the design mode.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D308176\n\nDifferential Revision: https://phabricator.services.mozilla.com/D308717\n", "files": ["dom/events/IMEContentObserver.cpp", "dom/events/IMEContentObserver.h", "testing/web-platform/tests/editing/crashtests/selection-modify-after-body-removed-in-design-mode.html"], "git_node": "5a9c738cb771007225d1afecf96ee3dd80eeb855", "git_parents": ["b8e2709cd933e0bc103d79637a2f4520a2741d10"], "node": "a45aff0b7c24410c824e7139d0d9ee36901e79ef", "parents": ["4188aadc8e61395a95a747403cbc1d6539f68701"], "tags": []}], "date": 1782377846, "git_changesets": ["5a9c738cb771007225d1afecf96ee3dd80eeb855"], "user": "pchevrel@mozilla.com"}, "27088": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Bumping Firefox l10n changesets r=release a=l10n-bump\n\nach -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\naf -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\nan -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\nar -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\nast -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\naz -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\nbe -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\nbg -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\nbn -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\nbr -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\nbs -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\nca -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\nca-valencia -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\ncak -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\ncs -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\ncy -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\nda -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\nde -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\ndsb -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\nel -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\nen-CA -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\nen-GB -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\neo -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\nes-AR -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\nes-CL -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\nes-ES -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\nes-MX -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\net -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\neu -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\nfa -\u003e c32bc6dcc759e5675ea4716b7c12bfccb930633c\nff -\