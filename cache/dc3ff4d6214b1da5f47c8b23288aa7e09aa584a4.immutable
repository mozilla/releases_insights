ew-Commit-ID: 3VQM545aqpL", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "a1ac56679ed31c9b0160d72e216da9e46ea57c69", "parents": ["9924d1eaa5016331df8d779492dc8d01d2fb8d97"], "tags": []}, {"author": "Honza Bambas \u003chonzab.moz@firemni.cz\u003e", "branch": "default", "desc": "Bug 1388192 - Drop result principal URI from a cloned session history entry when opening view-source: page. r=bz, a=gchang", "files": ["docshell/base/nsDocShell.cpp"], "git_node": null, "git_parents": [null], "node": "6ea7b3eb8990bb0f7a16119f8545bcf429d88131", "parents": ["a1ac56679ed31c9b0160d72e216da9e46ea57c69"], "tags": []}], "date": 1502484335, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7607": {"changesets": [{"author": "Andrew Sutherland \u003casutherland@asutherland.org\u003e", "branch": "default", "desc": "Bug 1388584 - Bind ATTACH DATABASE path argument. r=adw, r=markh, a=sledru\n\nTests and a proper fix will land as part of bug 1389660, but that will be a few\ndays.", "files": ["storage/mozStorageConnection.cpp", "toolkit/components/places/Database.cpp"], "git_node": null, "git_parents": [null], "node": "70f2f3497546cd2fff2e7d4eba9efb9e9805146e", "parents": ["6ea7b3eb8990bb0f7a16119f8545bcf429d88131"], "tags": []}], "date": 1502573843, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "7608": {"changesets": [{"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1375857 - Fix browserAction Android menu items corrupting addon menu items cache. r=sebastian, a=lizzard\n\nMozReview-Commit-ID: C3uVEY6mnJM", "files": ["mobile/android/base/java/org/mozilla/gecko/BrowserApp.java"], "git_node": null, "git_parents": [null], "node": "b65bc1bf7a4179d134b8dc577f1af650a7bddb87", "parents": ["70f2f3497546cd2fff2e7d4eba9efb9e9805146e"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1386164 - Part 1. Use libevent2 headers instead of deprecated event.h. r=jesup, a=lizzard\n\nlibevent uses event.h header that is fuzzy name.  Since our in-tree libevent is libevent2, we should use libevent2 headers instead of deprecated event.h\n\nMozReview-Commit-ID: 6DjW9JEkNWL", "files": ["config/system-headers", "media/webrtc/trunk/webrtc/base/task_queue_libevent.cc"], "git_node": null, "git_parents": [null], "node": "7b672c34268cb2e8d813288235bdf6f34c4d9d29", "parents": ["b65bc1bf7a4179d134b8dc577f1af650a7bddb87"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1386164 - Part 2. Use MOZ_SYSTEM_LIBEVENT for webrtc. r=jesup, a=lizzard\n\nGYP of WebRTC should reference MOZ_SYSTEM_LIBEVENT values if available.\n\nMozReview-Commit-ID: CshsPrRidM8", "files": ["build/gyp.mozbuild", "media/webrtc/trunk/gtest/moz.build", "media/webrtc/trunk/webrtc/base/base.gyp"], "git_node": null, "git_parents": [null], "node": "a3904db13d09c4904f0d3ca8c9cba5bd10c0903e", "parents": ["7b672c34268cb2e8d813288235bdf6f34c4d9d29"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1386786 - Fix Android browserAction.setTitle/getTitle behavior on switching and closing tab. r=mixedpuppy, a=lizzard\n\nMozReview-Commit-ID: LFxnySvBBOz", "files": ["mobile/android/components/extensions/ext-browserAction.js", "mobile/android/modules/BrowserActions.jsm"], "git_node": null, "git_parents": [null], "node": "e7efe3c1a1c4e3a192cd8682ffeac2173dcb232a", "parents": ["a3904db13d09c4904f0d3ca8c9cba5bd10c0903e"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1386905 - Move away mRuleNode in nsTextEditorState::UnbindFromFrame before storing the value into text buffer. r=Ehsan, a=lizzard\n\nOtherwise SetValue may think it's still safe to notify, while it isn't.\n\nMozReview-Commit-ID: 6a3or1WXWAq", "files": ["dom/html/crashtests/1386905.html", "dom/html/crashtests/crashtests.list", "dom/html/nsTextEditorState.cpp"], "git_node": null, "git_parents": [null], "node": "71154d26091a721d399b9d8ab0eb03c5e306d63d", "parents": ["e7efe3c1a1c4e3a192cd8682ffeac2173dcb232a"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1387026 - Fix Android browserAction corrupting legacy Addon menu items on overlapping menu item id. r=sebastian, a=lizzard\n\nMozReview-Commit-ID: FWkJdAWu5Td", "files": ["mobile/android/base/java/org/mozilla/gecko/BrowserApp.java"], "git_node": null, "git_parents": [null], "node": "0f875d25932a5ffec9c9abc05c0f899a6990bdf8", "parents": ["71154d26091a721d399b9d8ab0eb03c5e306d63d"], "tags": []}, {"author": "Georg Fritzsche \u003cgeorg.fritzsche@googlemail.com\u003e", "branch": "default", "desc": "Bug 1302681 - Part 1: Extend Event Telemetry core for recording from addons. r=dexter, a=lizzard\n\nTo cut down on complexity, we don't require specifying any expiry versions.\nGiven that these events will be recorded non-persistently from off-train add-ons, they can be expired by shipping new add-on releases.\n\nWe also start to use the new \"record on release\" terminology here instead of opt-in/opt-out, but are not changing the internal functionality yet.\n\nTechnically, this is implemented by keeping a separate registry for the dynamic event information.\nBuilt-in & dynamic events are tracked with separate numeric ids, so introduce a common identifier for both, an EventKey.\nFor actual event storage, the events are treated the same as built-in events. They are simply bucketed into the 'dynamic' process storage.\nThis approach ends up duplicating code paths that use the event info, but keeps a single implementation for recording, storage & serialization.", "files": ["browser/modules/test/browser/browser_UsageTelemetry_content.js", "browser/modules/test/browser/browser_UsageTelemetry_content_aboutHome.js", "browser/modules/test/browser/browser_UsageTelemetry_searchbar.js", "browser/modules/test/browser/browser_UsageTelemetry_urlbar.js", "toolkit/components/telemetry/EventInfo.h", "toolkit/components/telemetry/Processes.yaml", "toolkit/components/telemetry/Telemetry.cpp", "toolkit/components/telemetry/TelemetryEvent.cpp", "toolkit/components/telemetry/TelemetryEvent.h", "toolkit/components/telemetry/TelemetrySession.jsm", "toolkit/components/telemetry/docs/collection/events.rst", "toolkit/components/telemetry/nsITelemetry.idl", "toolkit/components/telemetry/tests/unit/test_ChildEvents.js", "toolkit/components/telemetry/tests/unit/test_TelemetryEvents.js"], "git_node": null, "git_parents": [null], "node": "c4ab1285bf4064ab83c82d36d3f3ae3e42bdad63", "parents": ["0f875d25932a5ffec9c9abc05c0f899a6990bdf8"], "tags": []}, {"author": "Georg Fritzsche \u003cgeorg.fritzsche@googlemail.com\u003e", "branch": "default", "desc": "Bug 1302681 - Part 2: Fix about:telemetry for displaying dynamic events. r=chutten, a=lizzard\n\nFixes that about:telemetry only shows events if there are any present in processes.parent.\n\nFor some reason switching the processes in the events section also triggers HistogramSection.render(), which breaks when there are no histograms recorded in the selected process.\nThis patch fixes it to make things work.", "files": ["toolkit/content/aboutTelemetry.js"], "git_node": null, "git_parents": [null], "node": "a66c7da43621e6e5b877ad8cab1ad95ba5bdba9c", "parents": ["c4ab1285bf4064ab83c82d36d3f3ae3e42bdad63"], "tags": []}, {"author": "Georg Fritzsche \u003cgeorg.fritzsche@googlemail.com\u003e", "branch": "default", "desc": "Bug 1302681 - Part 3: Update documentation to cover dynamic events. r=dexter, a=lizzard", "files": ["toolkit/components/telemetry/docs/collection/events.rst"], "git_node": null, "git_parents": [null], "node": "e3682dd9a9cb9cd02bc3d61770b3bc24d884d0fe", "parents": ["a66c7da43621e6e5b877ad8cab1ad95ba5bdba9c"], "tags": []}, {"author": "Beekill95 \u003cnnn_bikiu0707@yahoo.com\u003e", "branch": "default", "desc": "Bug 1383073 - Move speculativeConnectOnTabHover to tabbrowser.xml so we don't have to worry about clearing mouseover listeners from tabs. r=dao, a=lizzard\n\nMozReview-Commit-ID: 6Q0EvtJGEIg", "files": ["browser/base/content/tabbrowser.xml", "browser/components/sessionstore/SessionStore.jsm", "browser/components/sessionstore/test/browser_speculative_connect.js"], "git_node": null, "git_parents": [null], "node": "edbb6431090cb9e791750c2c5fee1363a788449c", "parents": ["e3682dd9a9cb9cd02bc3d61770b3bc24d884d0fe"], "tags": []}, {"author": "Tooru Fujisawa \u003carai_a@mac.com\u003e", "branch": "default", "desc": "Bug 1388005 - Fix build without Ion. r=nbp, a=lizzard", "files": ["js/src/jit/BaselineBailouts.cpp", "js/src/jit/CodeGenerator.cpp", "js/src/jit/IonCacheIRCompiler.cpp", "js/src/jit/none/MacroAssembler-none.h", "js/src/wasm/WasmSignalHandlers.cpp"], "git_node": null, "git_parents": [null], "node": "7e969755ccb9a97afc81ddbc199fe077e0d75924", "parents": ["edbb6431090cb9e791750c2c5fee1363a788449c"], "tags": []}, {"author": "Shih-Chiang Chien \u003cschien@mozilla.com\u003e", "branch": "default", "desc": "Bug 1387285 - Release more member variable in HttpChannelChild on main thread. r=mayhemer, a=lizzard\n\nAfter bug 1338493 landed, HttpChannelChild might be released on STS thread.\nRedirected channel, intercept stream listener and context might not always be able to\nrelease off-main-thread. Therefore, we need to proxy release these members on main thread.\n\nMozReview-Commit-ID: 6mcja7WY1fK", "files": ["netwerk/protocol/http/HttpChannelChild.cpp", "netwerk/protocol/http/HttpChannelChild.h"], "git_node": null, "git_parents": [null], "node": "6fa2ccf0f6ce6e6d9a86fe21b7dae8a5fbb2eb6b", "parents": ["7e969755ccb9a97afc81ddbc199fe077e0d75924"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1387783 - Add lazy browser shims for fullZoom and textZoom. r=kevinjones, a=lizzard", "files": ["browser/base/content/tabbrowser.xml"], "git_node": null, "git_parents": [null], "node": "05d3c1eb0b02e8b9553ead543037614f0abc4911", "parents": ["6fa2ccf0f6ce6e6d9a86fe21b7dae8a5fbb2eb6b"], "tags": []}, {"author": "Paul Adenot \u003cpaul@paul.cx\u003e", "branch": "default", "desc": "Bug 1388372 - Fix assert and null check properly to account for the pass-through mode in gUM. r=jesup, a=lizzard\n\nMozReview-Commit-ID: 9kFZG0LwKRM", "files": ["dom/media/test/crashtests/1388372.html", "dom/media/test/crashtests/crashtests.list", "dom/media/webrtc/MediaEngineWebRTCAudio.cpp"], "git_node": null, "git_parents": [null], "node": "220da0b3e32deaf135134938df6b51f55aff1c26", "parents": ["05d3c1eb0b02e8b9553ead543037614f0abc4911"], "tags": []}, {"author": "Bobby Holley \u003cbobbyholley@gmail.com\u003e", "branch": "default", "desc": "Bug 1387499 - Clear the servo bits when dropping servo data. r=emilio, a=lizzard\n\nThis fixes the testcase in the bug, which removes and reinserts\nsome elements. Our invariants require us not to set the dirty\ndescendants bits on unstyled elements.\n\nMozReview-Commit-ID: 1eESZjNSURG", "files": ["dom/base/Element.cpp", "layout/base/ServoRestyleManager.cpp"], "git_node": null, "git_parents": [null], "node": "570ac5d020c8f43a0d1e8d9571236341b99e44e3", "parents": ["220da0b3e32deaf135134938df6b51f55aff1c26"], "tags": []}, {"author": "Bobby Holley \u003cbobbyholley@gmail.com\u003e", "branch": "default", "desc": "Bug 1387499 - Crashtest. r=me, a=lizzard\n\nMozReview-Commit-ID: 59I61PQIWHi", "files": ["layout/style/crashtests/1387499.html", "layout/style/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "4d85f7b5e426c7bd268ef84251491176ae28cff1", "parents": ["570ac5d020c8f43a0d1e8d9571236341b99e44e3"], "tags": []}, {"author": "Andrew Swan \u003caswan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1372448 - Remove broken \"new profile\" check when determining if an addon is sideloaded. r=kmag, a=sledru\n\nMozReview-Commit-ID: FA7JSMLrHmT", "files": ["toolkit/mozapps/extensions/internal/XPIProviderUtils.js", "toolkit/mozapps/extensions/test/xpcshell/test_seen.js", "toolkit/mozapps/extensions/test/xpcshell/test_seen_newprofile.js", "toolkit/mozapps/extensions/test/xpcshell/xpcshell-shared.ini"], "git_node": null, "git_parents": [null], "node": "1ad3a57bcf6ac42710c050bda21403762f718649", "parents": ["4d85f7b5e426c7bd268ef84251491176ae28cff1"], "tags": []}], "date": 1502673970, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7609": {"changesets": [{"author": "Cameron McCormack \u003ccam@mcc.id.au\u003e", "branch": "default", "desc": "Bug 1384741 - Part 1: Add facility to buffer up CSP violation reports. r=bz a=lizzard\n\nMozReview-Commit-ID: G4JLTmP1wD7", "files": ["dom/base/nsDocument.cpp", "dom/base/nsIDocument.h", "dom/security/nsCSPContext.cpp"], "git_node": null, "git_parents": [null], "node": "2ca70aa40eae0268d6abf65175aa93a7c14fa7a1", "parents": ["1ad3a57bcf6ac42710c050bda21403762f718649"], "tags": []}, {"author": "Cameron McCormack \u003ccam@mcc.id.au\u003e", "branch": "default", "desc": "Bug 1384741 - Part 2: Allow file_report_chromescript.js to listen for more than one CSP violation report. r=bz a=lizzard\n\nMozReview-Commit-ID: 8ym5OqSUTMW", "files": ["dom/security/test/csp/file_report_chromescript.js", "dom/security/test/csp/test_blocked_uri_in_reports.html", "dom/security/test/csp/test_report.html"], "git_node": null, "git_parents": [null], "node": "ce4bac7cc01ee52323fbd9b118a338622cfc068c", "parents": ["2ca70aa40eae0268d6abf65175aa93a7c14fa7a1"], "tags": []}, {"author": "Cameron McCormack \u003ccam@mcc.id.au\u003e", "branch": "default", "desc": "Bug 1384741 - Part 3: Buffer up CSP violation reports when pre-emptively checking cached font loads, and dispatch them when trying to use cached fonts. r=jfkthame a=lizzard\n\nMozReview-Commit-ID: 7hUI160sNqv", "files": ["