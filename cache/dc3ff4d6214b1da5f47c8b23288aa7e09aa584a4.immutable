node": "a566b0235ef9ead152b01156d4e9ddd4ff65bfef", "parents": ["4302ede51ff60c8779a7a1fe77215a8f351412ee"], "tags": []}, {"author": "Nevin Chen \u003ccnevinchen@gmail.com\u003e", "branch": "default", "desc": "Bug 1372040 - Temporary showing large icons for AdaptiveIconDrawable. r=maliu, a=lizzard\n\nI don't want to call BitmapUtils.getBitmapFromDrawable() here for AdaptiveIconDrawable cause there might be performance impact if I create bitmap in main thread.\nI'll use bug 1397174 to follow up this issue.\n\nMozReview-Commit-ID: 64FE2MOk5g0", "files": ["mobile/android/base/java/org/mozilla/gecko/prompts/PromptListAdapter.java"], "git_node": null, "git_parents": [null], "node": "df29a08ea4310d0de72c3b6bd721356191c7f40b", "parents": ["a566b0235ef9ead152b01156d4e9ddd4ff65bfef"], "tags": []}, {"author": "Felipe Gomes \u003cfelipc@gmail.com\u003e", "branch": "default", "desc": "Bug 1390703 - Bump Flash Click-to-Play rollout to 25% on release. r=bsmedberg, a=lizzard\n\nAlso bump it on Beta to 100% as we'll do the same on release shortly afterwards.\n\nMozReview-Commit-ID: E38mrF4kvUf", "files": ["browser/extensions/clicktoplay-rollout/bootstrap.js", "browser/extensions/clicktoplay-rollout/install.rdf.in"], "git_node": null, "git_parents": [null], "node": "94cf7f1ee06b817dd8fa4d76bf63cef15de3b4e2", "parents": ["df29a08ea4310d0de72c3b6bd721356191c7f40b"], "tags": []}], "date": 1505144871, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7737": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1377618 - Update Firefox 56 to NSS_3_32_1_RTM. r=kaie, a=gchang\nUPGRADE_NSS_RELEASE", "files": ["old-configure.in", "security/nss/TAG-INFO", "security/nss/coreconf/coreconf.dep", "security/nss/lib/nss/nss.h", "security/nss/lib/softoken/softkver.h", "security/nss/lib/ssl/ssl3con.c", "security/nss/lib/ssl/ssl3prot.h", "security/nss/lib/util/nss