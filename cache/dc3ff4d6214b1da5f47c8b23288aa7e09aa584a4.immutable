 ['android', 'android-api-15', 'android-multilocale']\nru -\u003e ['android', 'android-api-15', 'android-multilocale']\nsk -\u003e ['android', 'android-api-15', 'android-multilocale']\nsl -\u003e ['android', 'android-api-15', 'android-multilocale']\nson -\u003e ['android', 'android-api-15', 'android-multilocale']\nsq -\u003e ['android', 'android-api-15', 'android-multilocale']\nsr -\u003e ['android', 'android-api-15', 'android-multilocale']\nsv-SE -\u003e ['android', 'android-api-15', 'android-multilocale']\nta -\u003e ['android', 'android-api-15', 'android-multilocale']\nte -\u003e ['android', 'android-api-15', 'android-multilocale']\nth -\u003e ['android', 'android-api-15', 'android-multilocale']\ntr -\u003e ['android', 'android-api-15', 'android-multilocale']\ntrs -\u003e ['android', 'android-api-15']\nuk -\u003e ['android', 'android-api-15', 'android-multilocale']\nur -\u003e ['android', 'android-api-15', 'android-multilocale']\nuz -\u003e ['android', 'android-api-15', 'android-multilocale']\nwo -\u003e ['android', 'android-api-15']\nxh -\u003e ['android', 'android-api-15', 'android-multilocale']\nzam -\u003e ['android', 'android-api-15', 'android-multilocale']\nzh-CN -\u003e ['android', 'android-api-15', 'android-multilocale']\nzh-TW -\u003e ['android', 'android-api-15', 'android-multilocale']", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "9bc97c683930cd01c8ef87fdd8c437c24dd58196", "parents": ["617a29a825fa925de17201eba9fdc91b4ff14358"], "tags": []}], "date": 1504184429, "git_changesets": [null], "user": "ffxbld"}, "7700": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump\n\nfa -\u003e 2cab892828ba\nms -\u003e 67a6257b4169\nzh-TW -\u003e 4238999c0a7c", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "4b1ef71961265c0cac87732c2b09cf7861ba2176", "parents": ["9bc97c683930cd01c8ef87fdd8c437c24dd58196"], "tags": []}], "date": 1504195233, "git_changesets": [null], "user": "ffxbld"}, "7701": {"changesets": [{"author": "Chris Pearce \u003ccpearce@mozilla.com\u003e", "branch": "default", "desc": "Bug 1392485 - Hook QueryDosDeviceW() in GMP process so it works inside the sandbox. r=bobowen, r=dmajor, a=lizzard\n\nWe hook in kernelbase.dll rather than kernel32.dll, as hooking QueryDosDeviceW\nkernel32.dll is failing on our Win8 tests, it seems because QueryDosDeviceW in\nkernel32.dll redirects to kernelbase32.dll, and the redirect has insufficient\nspace for our hook in Win8. So hook in kernelbase.dll, where the redirect\nredirects to instead.\n\n\nMozReview-Commit-ID: JKRiKCd7Ibn", "files": ["dom/media/gmp/ChromiumCDMAdapter.cpp", "toolkit/xre/test/win/TestDllInterceptor.cpp"], "git_node": null, "git_parents": [null], "node": "956fb847d294678813d88551f87980151b5d9cf9", "parents": ["4b1ef71961265c0cac87732c2b09cf7861ba2176"], "tags": []}, {"author": "David Major \u003cdmajor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1392485 - Add REX.R mov to the disassembler. r=handyman, a=lizzard\n\nTo mitigate risk for beta uplift, the logic here is limited to what we need for QueryDosDeviceW on Win7x64. A better long-term fix would be to combine this with the more general mov logic in the REX.W section.\n\nMozReview-Commit-ID: BykQSYY61Ua", "files": ["xpcom/build/nsWindowsDllInterceptor.h"], "git_node": null, "git_parents": [null], "node": "55b8650bcc3bdbaca143433c8ad121ec80bbfa34", "parents": ["956fb847d294678813d88551f87980151b5d9cf9"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1392653 - Remove redundant LegacyExtensionUtils shutdown blocker. r=aswan, a=lizzard\n\nThe base Extension class now handles adding shutdown blockers and waiting for\nextension startup before beginning shutdown, so the redundant logic only\ncauses problems.\n\nMozReview-Commit-ID: 2gBWlmIs1KQ", "files": ["toolkit/components/extensions/LegacyExtensionsUtils.jsm"], "git_node": null, "git_parents": [null], "node": "c46525d6bf12e6a0bf18250bb7643312450fed97", "parents": ["55b8650bcc3bdbaca143433c8ad121ec80bbfa34"], "tags": []}, {"author": "Haik Aftandilian \u003chaftandilian@mozilla.com\u003e", "branch": "default", "desc": "Bug 1392988 - Firefox 55.02 on macOS High Sierra cannot play AES encrypted video. r=Alex_Gaynor, a=lizzard\n\nAdds access to video encoding/decoding services when running on macOS 10.13 High Sierra.\n\nMozReview-Commit-ID: 6h4dZ6gkFtp", "files": ["security/sandbox/mac/SandboxPolicies.h"], "git_node": null, "git_parents": [null], "node": "7b0b48569ec86d62017a87759e5b9f48bb0a4a25", "parents": ["c46525d6bf12e6a0bf18250bb7643312450fed97"], "tags": []}, {"author": "Scott Wu \u003cscottcwwu@gmail.com\u003e", "branch": "default", "desc": "Bug 1393799 - Add extra space around forms to ensure invalid fields are displayed properly. r=lchang, a=lizzard\n\nMozReview-Commit-ID: G9jTkJWlIVM", "files": ["browser/extensions/formautofill/skin/shared/editAddress.css"], "git_node": null, "git_parents": [null], "node": "76813e4100eaa0e97f167a0a409ebfc59ccb97a1", "parents": ["7b0b48569ec86d62017a87759e5b9f48bb0a4a25"], "tags": []}, {"author": "J. Ryan Stinnett \u003cjryans@gmail.com\u003e", "branch": "default", "desc": "Bug 1394473 - Fix up target=_blank links in RDM. r=ochameau, a=lizzard\n\nSometime during Firefox 56, the `dataTransfer` property was removed, so this\nstarted to fail.  It was a bit strange anyway, since we have a principal on the\nouter browser.\n\nAdds a test to cover this use case.\n\nMozReview-Commit-ID: 9UOCc77ZRxk", "files": ["devtools/client/responsive.html/browser/tunnel.js", "devtools/client/responsive.html/test/browser/browser.ini", "devtools/client/responsive.html/test/browser/browser_target_blank.js"], "git_node": null, "git_parents": [null], "node": "dcb3e24852c4b3ddc900d5e2430853cb9a51cdc4", "parents": ["76813e4100eaa0e97f167a0a409ebfc59ccb97a1"], "tags": ["DEVEDITION_56_0b8_RELEASE", "FIREFOX_56_0b8_BUILD1", "FIREFOX_56_0b8_RELEASE"]}], "date": 1504198352, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7702": {"changesets": [{"author": "ffxbld", "branch": "default", "desc": "No bug, Automated blocklist update from host bld-linux64-spot-304 - a=blocklist-update", "files": ["browser/app/blocklist.xml"], "git_node": null, "git_parents": [null], "node": "1ffd33f6b648abed6b9ec41e556dfd329ce08457", "parents": ["dcb3e24852c4b3ddc900d5e2430853cb9a51cdc4"], "tags": []}], "date": 1504260501, "git_changesets": [null], "user": "ffxbld"}, "7703": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "Automatic version bump. CLOSED TREE NO BUG a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "f1734581eec71b0e7dbd11e55698191ff3a7a227", "parents": ["1ffd33f6b648abed6b9ec41e556dfd329ce08457"], "tags": []}, {"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging dcb3e24852c4b3ddc900d5e2430853cb9a51cdc4 with FIREFOX_56_0b8_BUILD1, FIREFOX_56_0b8_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "685a2431a18bbfcd9851e4cdc7446c408553136b", "parents": ["f1734581eec71b0e7dbd11e55698191ff3a7a227"], "tags": []}], "date": 1504284012, "git_changesets": [null, null], "user": "ffxbld"}, "7704": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump\n\nbe -\u003e 439fef893bd1\neu -\u003e 4b4c2d503110\nhsb -\u003e d60a25dff773\nka -\u003e d36ed2b117c6\nko -\u003e 822029cb997e\nsk -\u003e 39fc51db0e00", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "6670eb6643baae711ed31f6ac66d