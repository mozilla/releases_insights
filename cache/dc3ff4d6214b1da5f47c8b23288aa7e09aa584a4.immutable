donManagerStartup.cpp"], "git_node": null, "git_parents": [null], "node": "cef728b1b47e99c14abacf85b022291688b82bb3", "parents": ["eee5b1dfb49fe75663a74dc9a0f094f42244f8f8"], "tags": []}, {"author": "Punam \u003cpdahiya@mozilla.com\u003e", "branch": "default", "desc": "Bug 1391486 - Cloud Storage - Handle browser.download.dir unspecified in new profile. r=Gijs, a=lizzard\n\nMozReview-Commit-ID: 3WfS5CQLtYY", "files": ["browser/components/preferences/in-content-new/main.js", "browser/components/preferences/in-content/main.js", "toolkit/components/cloudstorage/CloudStorage.jsm"], "git_node": null, "git_parents": [null], "node": "9f0bb349eced23af8fe8835d0bc3b0b40f1f1fe6", "parents": ["cef728b1b47e99c14abacf85b022291688b82bb3"], "tags": []}, {"author": "Robert Strong \u003crobert.bugzilla@gmail.com\u003e", "branch": "default", "desc": "Bug 1386224 - Use the active update and fallback to the latest update in the update history when determining whether to show the what's new page. r=mhowell, a=lizzard", "files": ["browser/components/nsBrowserContentHandler.js"], "git_node": null, "git_parents": [null], "node": "cb49f51c66fa8d62fff8818bad92ea1fde823958", "parents": ["9f0bb349eced23af8fe8835d0bc3b0b40f1f1fe6"], "tags": []}], "date": 1503342297, "git_changesets": [null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7647": {"changesets": [{"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1350637 - Part 1: Move PStorage stubs from PContent to PBackground. r=asuth, r=billm, a=lizzard", "files": ["dom/ipc/ContentChild.cpp", "dom/ipc/ContentChild.h", "dom/ipc/ContentParent.cpp", "dom/ipc/ContentParent.h", "dom/ipc/PContent.ipdl", "dom/ipc/moz.build", "dom/storage/LocalStorageCache.cpp", "dom/storage/PBackgroundStorage.ipdl", "dom/storage/PStorage.ipdl", "dom/storage/StorageIPC.cpp", "dom/storage/StorageIPC.h", "dom/storage/moz.build", "ipc/glue/BackgroundChildImpl.cpp", "ipc/glue/BackgroundChildImpl.h", "ipc/glue/BackgroundParentImpl.cpp", "ipc/glue/BackgroundParentImpl.h", "ipc/glue/PBackground.ipdl", "ipc/glue/moz.build", "ipc/ipdl/sync-messages.ini"], "git_node": null, "git_parents": [null], "node": "37a05ddf9427ac9a2976640fddab25b02bca0d94", "parents": ["cb49f51c66fa8d62fff8818bad92ea1fde823958"], "tags": []}, {"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1350637 - Part 2: Core changes for LocalStorage on PBackground. r=asuth, a=lizzard\n\n- stop inheriting StorageDBBridge in StorageDBThread and StorageDBChild\n- move StorageDBThread and StorageDBChild initialization out of LocalStorageCache\n- use IPC even for the intra-process communication in main process\n- rationalize a bit storage observer code\n- make StorageDBParent to always be created and destroyed on the background thread", "files": ["dom/storage/LocalStorageCache.cpp", "dom/storage/LocalStorageCache.h", "dom/storage/LocalStorageManager.cpp", "dom/storage/LocalStorageManager.h", "dom/storage/StorageDBThread.cpp", "dom/storage/StorageDBThread.h", "dom/storage/StorageIPC.cpp", "dom/storage/StorageIPC.h", "dom/storage/StorageObserver.cpp", "dom/storage/StorageObserver.h"], "git_node": null, "git_parents": [null], "node": "5b5c8f31b0a7dee674246143145f2b371b381cc8", "parents": ["37a05ddf9427ac9a2976640fddab25b02bca0d94"], "tags": []}, {"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1350637 - Part 3: Move mozilla::dom::Optional serialization helper to ipc/glue/IPCMessageUtils.h to make it available to other consumers. r=billm, a=lizzard", "files": ["dom/media/webrtc/WebrtcGlobal.h", "ipc/glue/IPCMessageUtils.h"], "git_node": null, "git_parents": [null], "node": "b0bed209e7f79d31b4b99037432d8679c2fc837c", "parents": ["5b5c8f31b0a7dee674246143145f2b371b381cc8"], "tags": []}, {"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1350637 - Part 4: Implement serialization for mozilla::OriginAttributesPattern, so we can use it on the receiver side of IPC without bouncing to the main thread. r=asuth, a=lizzard", "files": ["dom/quota/SerializationHelpers.h"], "git_node": null, "git_parents": [null], "node": "d06e37723df257098eae195357cf2c96ebbb9b58", "parents": ["b0bed209e7f79d31b4b99037432d8679c2fc837c"], "tags": []}, {"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1350637 - Part 5: Factor out the parent actor observer sink to work on the PBackground thread, fix the rest of observer handling to use IPC. r=asuth, a=lizzard", "files": ["dom/storage/PBackgroundStorage.ipdl", "dom/storage/StorageIPC.cpp", "dom/storage/StorageIPC.h", "dom/storage/StorageObserver.cpp"], "git_node": null, "git_parents": [null], "node": "9c97e6d93100df546293c587dd24505029aca383", "parents": ["d06e37723df257098eae195357cf2c96ebbb9b58"], "tags": []}, {"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1350637 - Part 6: Fix a deadlock when main process storage child actor triggers storage thread initialization. r=asuth, a=lizzard", "files": ["dom/storage/StorageDBThread.cpp", "dom/storage/StorageDBThread.h", "dom/storage/StorageIPC.cpp", "dom/storage/StorageIPC.h", "ipc/glue/BackgroundChildImpl.cpp", "ipc/glue/BackgroundChildImpl.h", "ipc/glue/BackgroundParentImpl.cpp", "ipc/glue/BackgroundParentImpl.h", "ipc/glue/PBackground.ipdl"], "git_node": null, "git_parents": [null], "node": "e77772fae3c20104120b483890df521c6a3e51ce", "parents": ["9c97e6d93100df546293c587dd24505029aca383"], "tags": []}, {"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1350637 - Part 7: Convert asynchronous StorageDBParent initialization to be synchronous and fix low disk space checking. r=asuth, a=lizzard", "files": ["dom/storage/StorageIPC.cpp"], "git_node": null, "git_parents": [null], "node": "8267e1dbf9bc47c26b0f8bf382ab62f6e14b3790", "parents": ["e77772fae3c20104120b483890df521c6a3e51ce"], "tags": []}, {"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1350637 - Part 8: Implement BackgroundParent::GetLiveActorArray. r=billm, a=lizzard", "files": ["ipc/glue/BackgroundImpl.cpp", "ipc/glue/BackgroundParent.h"], "git_node": null, "git_parents": [null], "node": "e78fed3a2212b824729b86b0ae917b745be98c81", "parents": ["8267e1dbf9bc47c26b0f8bf382ab62f6e14b3790"], "tags": []}, {"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1350637 - Part 9: Move Local Storage event broadcasting from PContent to PBackground. r=asuth, a=lizzard", "files": ["dom/ipc/ContentChild.cpp", "dom/ipc/ContentChild.h", "dom/ipc/ContentParent.cpp", "dom/ipc/ContentParent.h", "dom/ipc/PContent.ipdl", "dom/storage/LocalStorage.cpp", "ipc/glue/BackgroundChildImpl.cpp", "ipc/glue/BackgroundChildImpl.h", "ipc/glue/BackgroundParentImpl.cpp", "ipc/glue/BackgroundParentImpl.h", "ipc/glue/PBackground.ipdl"], "git_node": null, "git_parents": [null], "node": "4a23be8a70898109206ba683aaaeec61d61b32fe", "parents": ["e78fed3a2212b824729b86b0ae917b745be98c81"], "tags": []}, {"author": "Andrew Sutherland \u003casutherland@asutherland.org\u003e", "branch": "default", "desc": "Bug 1350637 - Part 10: Update LocalStorage e10s tests for change to PBackground. r=janv, a=lizzard\n\nThe e10s tests were written assuming a world where ContentTask.spawn and\nLocalStorage were both PContent.  Also, that Quantum DOM labeling wasn't\nsomething to worry about.  These assumptions no longer held, resulting in\nthe test intermittently failing if all changes hadn't propagated via\nPBackground to the tab under test by the time the ContentTask.spawn\nstate retrieval call made it to the tab's main thread.\n\nThis has been corrected by using \"storage\" events where already in use and\npolling where not in use.  Plase see the added comments for more details.", "files": ["dom/tests/browser/browser_localStorage_e10s.js", "dom/tests/browser/page_localstorage_e10s.html"], "git_node": null, "git_parents": [null], "node": "a8582d18b511da750ab9b5b6ee2ba80089321d16", "parents": ["4a23be8a70898109206ba683aaaeec61d61b32fe"], "tags": []}, {"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1350637 - Part 11: Fix a race between parent/child process. r=asuth, a=lizzard\n\nWhen a storage child actor gets the xpcom-shutdown notification, it releases\nthe actor singleton which asynchronously sends __delete__ to the parent and\ndestroys the child actor immediatelly. However, at the same time parent can be\nsending a message to the child which results in a routing error since the child\nactor doesn't exist anymore. The routing error causes a crash.\nThis patch prevents the race by doing the teardown in two steps. We send a\nmessage to the parent DeleteMe and parent then sends __delete__ to the child.", "files": ["dom/storage/PBackgroundStorage.ipdl", "dom/storage/StorageIPC.cpp", "dom/storage/StorageIPC.h"], "git_node": null, "git_parents": [null], "node": "6a21678800163e1bcbc70a6239cd62f3aefbbbe8", "parents": ["a8582d18b511da750ab9b5b6ee2ba80089321d16"], "tags": []}], "date": 1503342939, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7648": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1389160 - Add missing FileUtils.h #include to fix bustage. r=rhelmer, a=bustage", "files": ["toolkit/mozapps/extensions/AddonManagerStartup.cpp"], "git_node": null, "git_parents": [null], "node": "86e3368b6058c3a298a6fd973de1313cfe706795", "parents": ["6a21678800163e1bcbc70a6239cd62f3aefbbbe8"], "tags": ["DEVEDITION_56_0b5_RELEASE", "FENNEC_56_0b5_BUILD1", "FENNEC_56_0b5_RELEASE", "FIREFOX_56_0b5_BUILD1", "FIREFOX_56_0b5_RELEASE"]}], "date": 1503343945, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "7649": {"changesets": [{"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1383771 - Add widevine support to Nightly builds r=aki a=ritu\n\nOther related changes:\n* Only target.{zip,tar.gz,tar.bz} get the widevine signature (not the various installers).\n* Linux{32,64}-nightly are now repackaged. Their mar files are not signed during signed step anymore. It now happens after the repackage.\n* As a consequence, funsize routes for linux are now set to repackage-signing (instead of signing)\n* Signed upstream artifacts are now defined in a dedicated module (to avoid duplication)\n* Platforms defined in beetmover_repackage now allow regex (to reduce duplication too)\n* Mozharness configs: Delete unused (and misleading) `src_mozconfig` for windows. This value is actually not used when `run_configure` (in the same dict) is set to False.\n\nMozReview-Commit-ID: COKqevW9Mzn", "files": ["python/mozbuild/mozbuild/repackaging/dmg.py", "taskcluster/ci/beetmover-l10n/kind.yml", "taskcluster/ci/beetmover-repackage/kind.yml", "taskcluster/ci/beetmover/kind.yml", "taskcluster/ci/repackage-l10n/kind.yml", "taskcluster/ci/repackage-signing/kind.yml", "taskcluster/ci/repackage/kind.yml", "taskcluster/taskgraph/transforms/beetmover_repackage.py", "taskcluster/taskgraph/transforms/build_signing.py", "taskcluster/taskgraph/transforms/gecko_v2_whitelist.py", "taskcluster/taskgraph/transforms/nightly_l10n_signing.py", "taskcluster/taskgraph/transforms/repackage.py", "taskcluster/taskgraph/transforms/repackage_signing.py", "taskcluster/taskgraph/transforms/signing.py", "taskcluster/taskgraph/util/signed_artifacts.py", "testing/mozharness/configs/repackage/linux32_signed.py", "testing/mozharness/configs/repackage/linux64_signed.py", "testing/mozharness/configs/repackage/win32_signed.py", "testing/mozharness/configs/repackage/win64_signed.py"], "git_node": null, "git_parents": [null], "node": "e3c51a9aa108081c96ad8d5a993e6c513b00e84e", "parents": ["86e3368b6058c3a298a6fd973de1313cfe706795"], "tags": []}], "date": 1503362459, "git_changesets": [null], "user": "asasaki@mozilla.com"}, "7650": {"changesets": [{"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1377273 - Added focus styling for onboarding overlay button. r=mossop, r=gasolin, a=lizzard\n\nMozReview-Commit-ID: BZgx4ODL2at", "files": ["browser/extensions/onboarding/content/onboarding.css", "browser/extensions/onboarding/content/onboarding.js", "browser/extensions/onboarding/test/browser/browser.ini", "browser/extensions/onboarding/test/browser/browser_onboarding_accessibility.js"], "git_node": null, "git_parents": [null], "node": "db1c6a7e5ec638eb15a233faccb17f5007bf66f5", "parents": ["e3c51a9aa108081c96ad8d5a993e6c513b00e84e"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1387057 - Improved accessibliity of onboarding notification bar. r=mossop, a=lizzard\n\nMozReview-Commit-ID: Hx60C142g3u", "files": ["browser/extensions/onboarding/content/onboarding.css", "browser/extensions/onboarding/content/onboarding.js", "browser/extensions/onboarding/test/browser/browser_onboarding_accessibility.js"], "git_node": null, "git_parents": [null], "node": "ccdd5c4ad925466c442a62d0ca4c3d2baf9bde29", "parents": ["db1c6a7e5ec638eb15a233faccb17f5007bf66f5"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1389844 - Part 1: Add mochitest. r=gerald, a=lizzard\n\nSimilar to test_PlayEventsAutoPlaying.html, but here we load 10s of data and ensure autoplaying kicks in.\n\nMozReview-Commit-ID: ImpjFIcBIo1", "files": ["dom/media/mediasource/test/mochitest.ini", "dom/media/mediasource/test/test_PlayEventsAutoPlaying2.html"], "git_node": null, "git_parents": [null], "node": "7f465d33e70a0f92a0afc405a8cd0c3371165115", "parents": ["ccdd5c4ad925466c442a62d0ca4c3d2baf9bde29"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1389844 - Part 2: Add Intervals::ContainsWithStrictEnd method. r=gerald, a=lizzard\n\nMozReview-Commit-ID: JnIgYlmewUw", "files": ["dom/media/Intervals.h"], "git_node": null, "git_parents": [null], "node": "e33243e16a3a020509d64f95490e7524e2528ef8", "parents": ["7f465d33e70a0f92a0afc405a8cd0c3371165115"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1389844 - Part 3: Handle case where currentTime isn't contained in buffered range. r=gerald, a=lizzard\n\nWhen playback starts, currentTime is always 0, and even if the buffered data doesn't contain currentTime it is possible for playback to progress as we always allow up to 500ms gap in the buffered data.\n\nAs such, we must use fuzzing on the interval's start time when determining if we have future data.\n\nMozReview-Commit-ID: Ki9QxmKhfdY", "files": ["dom/media/mediasource/MediaSourceDecoder.cpp"], "git_node": null, "git_parents": [null], "node": "4600e5c1d8533ca46c68a9bd6788d5df83def5a9", "parents": ["e33243e16a3a020509d64f95490e7524e2528ef8"], "tags": []}, {"author": "Thomas Nguyen \u003ctnguyen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1376410 - Handle OOM when appending prefix to map. r=francois, r=hchang, a=lizzard\n\nMozReview-Commit-ID: 7MOHHAgEI1I", "files": ["toolkit/components/url-classifier/LookupCacheV4.cpp", "toolkit/components/url-classifier/VariableLengthPrefixSet.cpp"], "git_node": null, "git_parents": [null], "node": "51a04bed988d7da2618198818550f786ce481799", "parents": ["4600e5c1d8533ca46c68a9bd6788d5df83def5a9"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1391666 - Part 1: Mochitest to verify correct behavior. r=gerald, a=lizzard\n\nWe load 10s of encrypted video, which should trigger readyState being HAVE_ENOUGH_DATA\n\nMozReview-Commit-ID: 4VRLFHSFlDs", "files": ["dom/media/test/bipbop-cenc-video-10s.mp4", "dom/media/test/bipbop-cenc-video-10s.mp4^headers^", "dom/media/test/eme.js", "dom/media/test/mochitest.ini", "dom/media/test/test_eme_autoplay.html"], "git_node": null, "git_parents": [null], "node": "4e6b8a64e613a2400644deb2fee5fcacef3f1f03", "parents": ["51a04bed988d7da2618198818550f786ce481799"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1391666 - Part 2: Reset mWaitingForKey when we have data and autoplay attribute is set. r=cpearce, a=lizzard\n\nBy default, a media element that has never played is in paused mode. As such, we need to reset mWaitingForKey to NOT_WAITING_FOR_KEY otherwise, readyState will never become HAVE_ENOUGH_DATA.\n\nMozReview-Commit-ID: EIi3Crt4zHl", "files": ["dom/html/HTMLMediaElement.cpp"], "git_node": null, "git_parents": [null], "node": "53d7d0601775bdd794e1099ffaebe6afad3708f7", "parents": ["4e6b8a64e613a2400644deb2fee5fcacef3f1f03"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1391666 - Part 3: Change to HAVE_ENOUGH_DATA when possible. r=cpearce, a=lizzard\n\nIn bug 1312886, we made sure that readyState would never become HAVE_ENOUGH_DATA if we were waiting for a key.\nHowever, this is in effect useless as the next call to ChangeReadyState would have reset mWaitingForKey.\n\nIn practice, it only meant that we delayed the change from HAVE_FUTURE_DATA to HAVE_ENOUGH_DATA until the next call to UpdateReadyState.\n\nMozReview-Commit-ID: 2wnMeN8xxCS", "files": ["dom/html/HTMLMediaElement.cpp"], "git_node": null, "git_parents": [null], "node": "065ea81827aeffc6d1ea57ad7c31f5684a66bd87", "parents": ["53d7d0601775bdd794e1099ffaebe6afad3708f7"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1391666 - Part 4: Remove unecessary code. r=gerald, a=lizzard\n\nIt isn't possible for the End of Stream algorithm to cause an updateend event to fire. Regardless of the duration being modified.\n\nMozReview-Commit-ID: 5RppbtjkboN", "files": ["dom/media/test/eme.js"], "git_node": null, "git_parents": [null], "node": "21bc77a750df162c8336864e8fff060f1f179616", "parents": ["065ea81827aeffc6d1ea57ad7c31f5684a66bd87"], "tags": []}], "date": 1503368303, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7651": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset ccdd5c4ad925 (bug 1387057) for browser_onboarding_tours.js failures.", "files": ["browser/extensions/onboarding/content/onboarding.css", "browser/extensions/onboarding/content/onboarding.js", "browser/extensions/onboarding/test/browser/browser_onboarding_accessibility.js"], "git_node": null, "git_parents": [null], "node": "d6bca1edd1bc8789309225e062ef6a1519035548", "parents": ["21bc77a750df162c8336864e8fff060f1f179616"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset db1c6a7e5ec6 (bug 1377273) for browser_onboarding_tours.js failures.", "files": ["browser/extensions/onboarding/content/onboarding.css", "browser/extensions/onboarding/content/onboarding.js", "browser/extensions/onboarding/test/browser/browser.ini", "browser/extensions/onboarding/test/browser/browser_onboarding_accessibility.js"], "git_node": null, "git_parents": [null], "node": "c8da3a874d4ad8245711e7c618bb0d5a561f86d8", "parents": ["d6bca1edd1bc8789309225e062ef6a1519035548"], "tags": []}], "date": 1503372012, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "7652": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump\n\nhu -\u003e 40fd8270c5eb", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "8f55314ca1a9dda9b2e24c684b70cc51b7f74fe0", "parents": ["c8da3a874d4ad8245711e7c618bb0d5a561f86d8"], "tags": []}], "date": 1503406824, "git_changesets": [null], "user": "ffxbld"}, "7653": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "Automatic version bump. CLOSED TREE NO BUG a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "ecb5229130121808db46697818461e994464e45c", "parents": ["8f55314ca1a9dda9b2e24c684b70cc51b7f74fe0"], "tags": []}, {"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging 86e3368b6058c3a298a6fd973de1313cfe706795 with FIREFOX_56_0b5_BUILD1, FIREFOX_56_0b5_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "82aff8e44f99b22d64aef42847c13a58811daa40", "parents": ["ecb5229130121808db46697818461e994464e45c"], "tags": []}], "date": 1503419287, "git_changesets": [null, null], "user": "ffxbld"}, "7654": {"changesets": [{"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1386393 - Remove old docshell/test/unit/test_bug414201_jfif.js. rs=paolo, a=test-only\n\nMozReview-Commit-ID: A5Ip1e8Fw2r", "files": ["docshell/test/unit/test_bug414201_jfif.js", "docshell/test/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "f939a21ecba708df5bbe78dcc96fc54109c222f4", "parents": ["82aff8e44f99b22d64aef42847c13a58811daa40"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1374133 - Skip wpt choose-_blank-003.html for intermittent failures. a=test-only\n\nMozReview-Commit-ID: 2p6UqqedEZb", "files": ["testing/web-platform/meta/html/browsers/windows/browsing-context-names/choose-_blank-003.html.ini"], "git_node": null, "git_parents": [null], "node": "d34f45fcc7419a2e2ddb841d3c2072179e28290c", "parents": ["f939a21ecba708df5bbe78dcc96fc54109c222f4"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozill