pdate/updater/release_primary.der", "toolkit/mozapps/update/updater/release_secondary.der", "toolkit/mozapps/update/updater/xpcshellCertificate.der"], "git_node": null, "git_parents": [null], "node": "482eab1435c1c60fe8b0fe5c36562744dd94e60b", "parents": ["a8873e18732bc4a12b07f560e84c2cc251e1ee3a"], "tags": []}, {"author": "Robert Strong \u003crobert.bugzilla@gmail.com\u003e", "branch": "default", "desc": "Bug 1105689 - use SHA384 certificates to sign app update mar files. Part 5 - app update test change for the new test mar file size. r=mhowell, a=lizzard", "files": ["toolkit/mozapps/update/tests/data/sharedUpdateXML.js"], "git_node": null, "git_parents": [null], "node": "791e46c5e45e00fe4802d4050517762a7db7ce50", "parents": ["482eab1435c1c60fe8b0fe5c36562744dd94e60b"], "tags": []}, {"author": "Robert Strong \u003crobert.bugzilla@gmail.com\u003e", "branch": "default", "desc": "Bug 1105689 - use SHA384 certificates to sign app update mar files. Part 6 - app update test mar files signed with a SHA384 certificate. r=mhowell, a=lizzard", "files": ["toolkit/mozapps/update/tests/data/complete.mar", "toolkit/mozapps/update/tests/data/complete_mac.mar", "toolkit/mozapps/update/tests/data/old_version.mar", "toolkit/mozapps/update/tests/data/partial.mar", "toolkit/mozapps/update/tests/data/partial_mac.mar", "toolkit/mozapps/update/tests/data/simple.mar", "toolkit/mozapps/update/tests/data/wrong_product_channel.mar"], "git_node": null, "git_parents": [null], "node": "8b3ea08178d1e15029c515d0173fdf67c0c5ab6e", "parents": ["791e46c5e45e00fe4802d4050517762a7db7ce50"], "tags": []}], "date": 1502734649, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7617": {"changesets": [{"author": "muthuraj90ec \u003cmuthuraj90ec@gmail.com\u003e", "branch": "default", "desc": "Bug 1370403 - Synthesize contextmenu MouseEvent when performing webdriver actions. r=maja_zf, a=test-only\n\nMozReview-Commit-ID: 85nQTsTRttF", "files": ["testing/marionette/action.js", "testing/marionette/event.js", "testing/web-platform/tests/webdriver/tests/actions/mouse.py", "testing/web-platform/tests/webdriver/tests/actions/support/test_actions_wdspec.html"], "git_node": null, "git_parents": [null], "node": "9c5b86d50b9bdd3dba2f1938a64ac39fe8503f74", "parents": ["8b3ea08178d1e15029c515d0173fdf67c0c5ab6e"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1386977 - Handle popstate events for page loads. r=automatedtester, a=test-only\n\nIn case of websites manipulating the browser's history via history.pushState\nthere will be no usual page load events fired. Instead listeners for popstate\nevents have to be used.\n\nWhen such an event occurs we can directly return because the browser will\nnot load the underlying page. This only happens when navigating to another\npage first, or restarting Firefox.\n\nMozReview-Commit-ID: 3PceeYK9Co7", "files": ["testing/marionette/harness/marionette_harness/tests/unit/test_navigation.py", "testing/marionette/harness/marionette_harness/www/navigation_pushstate.html", "testing/marionette/harness/marionette_harness/www/navigation_pushstate_target.html", "testing/marionette/listener.js"], "git_node": null, "git_parents": [null], "node": "b6b61f8221fb1636fee4445b7a94b0df23ffeda6", "parents": ["9c5b86d50b9bdd3dba2f1938a64ac39fe8503f74"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1380512 - Fix intermittent on browser_webconsole_check_stubs_console_api. r=Honza, a=test-only\n\nThere was an error because of the console.dir call, which is calling\nthe server to fetch the properties of the inspected object.\nBut, since the console.dir call was the last command to be called,\nthe actor were cleared before the properties fetch call was done,\nresulting in an error on the server (no such actor for ID).\nTo fix this, we wait for the properties fetch call to be done\nbefore closing the tab.\n\nMozReview-Commit-ID: 9bsh3vHVPVa", "files": ["devtools/client/webconsole/new-console-output/test/fixtures/stub-generators/head.js"], "git_node": null, "git_parents": [null], "node": "1dd09478ec89230c01f0acbe33871ac5d48ca757", "parents": ["b6b61f8221fb1636fee4445b7a94b0df23ffeda6"], "tags": []}, {"author": "Henry Chang \u003chchang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1386391 - Poll to check if a document has loaded rather than a definite timeout. r=smaug, a=test-only\n\nMozReview-Commit-ID: B293QZe3LIz", "files": ["docshell/test/navigation/file_fragment_handling_during_load.html"], "git_node": null, "git_parents": [null], "node": "36c4a1d0b3bea5f7b55c54c7c2741e1dcc3a0c02", "parents": ["1dd09478ec89230c01f0acbe33871ac5d48ca757"], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1388733 - Ensure animations resume when the image surfaces are discarded while still decoding. r=tnikkel, a=gchang\n\nWhen an animated image has been discarded, we avoided marking the\ncomposited frame invalid unless it had been previously decoded. Most of\nthe time this was fine, but if the animated image was still decoding for\nthe first time, then we still had a composited frame lingering that we\ndid not mark as invalid. As a result, when we called\nRasterImage::LookupFrame (and indirectly\nFrameAnimator::GetCompositedFrame), it would always return the\ncomposited frame. This meant that RasterImage::Decode would never be\ncalled to trigger a redecode. At the same time,\nFrameAnimator::RequestRefresh would not cause us to advance the frame\nbecause the state was still discarded.\n\nWith this patch we separate out the concepts of \"has ever requested to\nbe decoded\" and \"has ever completed decoding.\" The former is now used to\ncontrol whether or not a composited frame is marked as invalid after we\ndiscover we currently have no surface for the animation -- this solves\nthe animation remaining frozen as we now request the redecode as\nexpected. The latter remains used to determine if we actually know the\ntotal number of frames.", "files": ["image/FrameAnimator.cpp", "image/FrameAnimator.h"], "git_node": null, "git_parents": [null], "node": "df818e102acdcce0430cd0d782b2fb46921f2f95", "parents": ["36c4a1d0b3bea5f7b55c54c7c2741e1dcc3a0c02"], "tags": []}, {"author": "Tooru Fujisawa \u003carai_a@mac.com\u003e", "branch": "default", "desc": "Bug 1379842 - Check content principal when dragging and dropping from browser. r=smaug, a=gchang", "files": ["browser/base/content/browser.js", "browser/base/content/tabbrowser.xml", "dom/base/contentAreaDropListener.js", "dom/base/nsIDroppedLinkHandler.idl", "toolkit/content/widgets/browser.xml"], "git_node": null, "git_parents": [null], "node": "dc46fc892938e6b8d449af75a129603ef55035c5", "parents": ["df818e102acdcce0430cd0d782b2fb46921f2f95"], "tags": []}, {"author": "Jonathan Kingston \u003cjkt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1388907 - Add @mozilla.com and @testpilot- extension identifiers for SVG context-fill icons. r=jwatt, a=gchang\n\nMozReview-Commit-ID: 7yHdgNfsrTc", "files": ["layout/svg/SVGContextPaint.cpp"], "git_node": null, "git_parents": [null], "node": "efabe9b3a88e0cb1bcb092b34e0291ac99759471", "parents": ["dc46fc892938e6b8d449af75a129603ef55035c5"], "tags": ["DEVEDITION_56_0b3_RELEASE", "FENNEC_56_0b3_BUILD1", "FENNEC_56_0b3_RELEASE", "FIREFOX_56_0b3_BUILD1", "FIREFOX_56_0b3_RELEASE"]}], "date": 1502806245, "git_changesets": [null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7618": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump\n\neu -\u003e 380ff1dcea35\nfi -\u003e 6e33f1ad4c31\nlv -\u003e f8f6e0b77527\nms -\u003e c2df516a5d57\npl -\u003e 9b38102b9a68\npt-PT -\u003e ab026876d176\nro -\u003e e3570297327d\nsl -\u003e dc1ee125b636\nte -\u003e b167121c4f3d", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "80b89d2e694fa19961f86439aa508e196991fb14", "parents": ["efabe9b3a88e0cb1bcb092b34e0291ac99759471"], "tags": []}], "date": 1502834424, "git_changesets": [null], "user": "ffxbld"}, "7619": {"changesets": [{"author": "Chris AtLee \u003ccatlee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1390375 - Stop extra DevEdition builds on Beta. r=Callek, a=release\n\nMozReview-Commit-ID: D8iJtNufQ6H", "files": ["taskcluster/ci/build/windows.yml", "taskcluster/ci/test/test-platforms.yml"], "git_node": null, "git_parents": [null], "node": "c9ec6aa5e7d2ad0a72ceafaa1d20a2be2d4c7021", "parents": ["80b89d2e694fa19961f86439aa508e196991fb14"], "tags": []}, {"author": "Ricky Chien \u003cricky060709@gmail.com\u003e", "branch": "default", "desc": "Bug 1388745 - Make \"find more search engines\" label highlightable. r=mconley, a=lizzard", "files": ["browser/components/preferences/in-content-new/search.xul"], "git_node": null, "git_parents": [null], "node": "2da5df1a3bdf41e8e2f9645f8a9e1761b944fdd0", "parents": ["c9ec6aa5e7d2ad0a72ceafaa1d20a2be2d4c7021"], "tags": []}, {"author": "J.C. Jones \u003cjjones@mozilla.com\u003e", "branch": "default", "desc": "Bug 1387820 - WebAuthn WD-05 Get Assertion Data Fix. r=keeler, a=lizzard\n\nThe WebAuthn WD-05 specification's Get Assertion method defines the returned\nAuthenticatorAssertionResponse as providing ClientData, AuthenticatorData, and\nthe Signature from the Authenticator. Our implementation is incorrectly setting\nAuthenticatorData and Signature:\n\nAuthenticatorData as a structure is intended to mirror the structure from\nthe AuthenticatorData [1] section of the Attestation CBOR Object [2] in the\nMakeCredential method, which we weren't doing _at all_. This is clarified in\nthe editor's draft of the specification, soon to be WD-06.\n\nSignature for U2F Authenticators is defined as the \"attestation signature\", [3]\nwhich is under-specified and we assumed would be the raw output from the U2F\nAuthenticator [4]. This should instead be the raw ANSI X9.62 signature with no\nadditional bytes. [5]\n\n[1] https://www.w3.org/TR/2017/WD-webauthn-20170505/#sec-authenticator-data\n[2] https://www.w3.org/TR/2017/WD-webauthn-20170505/#sec-attestation-data\n[3] https://www.w3.org/TR/2017/WD-webauthn-20170505/#fido-u2f-attestation\n[4] https://lists.w3.org/Archives/Public/public-webauthn/2017Aug/0078.html\n[5] https://bugzilla.mozilla.org/show_bug.cgi?id=1387820#c4\n\nMozReview-Commit-ID: DTIOILfS4pK", "files": ["dom/webauthn/WebAuthnManager.cpp", "dom/webauthn/WebAuthnUtil.cpp", "dom/webauthn/WebAuthnUtil.h", "dom/webauthn/tests/test_webauthn_loopback.html", "dom/webauthn/tests/u2futil.js"], "git_node": null, "git_parents": [null], "node": "ddc8a44892574b4cc02d044693e7a4c918b4fd14", "parents": ["2da5df1a3bdf41e8e2f9645f8a9e1761b944fdd0"], "tags": []}], "date": 1502836058, "git_changesets": [null, null, null], "user": "ryanvm@gmail.com"}, "7620": {"changesets": [{"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1390071 - part 2: Snap, fix desktop file location r=mtabara a=release\n\nMozReview-Commit-ID: 2hVBfrlK354", "files": ["taskcluster/docker/firefox-snap/snapcraft.yaml.in"], "git_node": null, "git_parents": [null], "node": "0c44b874c9f5de687e4f3bb72c60da65d6c5c5c8", "parents": ["ddc8a44892574b4cc02d044693e7a4c918b4fd14"], "tags": []}], "date": 1502885288, "git_changesets": [null], "user": "jlorenzo@mozilla.com"}, "7621": {"changesets": [{"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1390123 - part 2: Fix macaroon location r=mtabara a=release\n\nMozReview-Commit-ID: 2BRepPICsYE", "files": ["taskcluster/docker/firefox-snap/fetch_macaroons.sh"], "git_node": null, "git_parents": [null], "node": "5aa8102a8c5a9f0d87579c7eada4671ab94c1e72", "parents": ["0c44b874c9f5de687e4f3bb72c60da65d6c5c5c8"], "tags": []}], "date": 1502885382, "git_changesets": [null], "user": "jlorenzo@mozilla.com"}, "7622": {"changesets": [{"author": "Jared Hirsch \u003cohai@6a68.net\u003e", "branch": "default", "desc": "Bug 1389786 - Export Screenshots 10.12.0 to Firefox. r=kmag, a=gchang\n\nMozReview-Commit-ID: 1c6rq32TmOf", "files": ["browser/extensions/screenshots/bootstrap.js", "browser/extensions/screenshots/install.rdf", "browser/extensions/screenshots/webextension/manifest.json"], "git_node": null, "git_parents": [null], "node": "f6bfd0fdadbce2c1e1f76d89f651215a1f7c3b8e", "parents": ["5aa8102a8c5a9f0d87579c7eada4671ab94c1e72"], "tags": []}, {"author": "Jared Hirsch \u003cohai@6a68.net\u003e", "branch": "default", "desc": "Bug 1386333 - Remove Screenshots rollout pref. r=standard8, a=lizzard\n\nMozReview-Commit-ID: AW8igzQIDiH", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "a9df4b7dd62fcf41eab26c4f1679577283133883", "parents": ["f6bfd0fdadbce2c1e1f76d89f651215a1f7c3b8e"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1386821 - Init devtools if developer toolbar is enabled. r=ochameau, a=lizzard\n\nMozReview-Commit-ID: 57vThSXG4zq", "files": ["devtools/client/devtools-startup.js"], "git_node": null, "git_parents": [null], "node": "c105be29eb272522fed793fb71cdb2e9e029d4ed", "parents": ["a9df4b7dd62fcf41eab26c4f1679577283133883"], "tags": []}, {"author": "dw-dev \u003cdw-dev@gmx.com\u003e", "branch": "default", "desc": "Bug 1386805 - Changes to saveAsPDF() and printPreview(). r=mixedpuppy, a=gchang\n\nsaveAsPDF() - changed to return error message in lastError if called on Mac OS X.\n\nsaveAsPDF() - changed returned status values to lower case with underscores instead of spaces.\n\nprintPreview() - changed to return error message in lastError if print preview fails.\n\nMozReview-Commit-ID: KxWJ3ClqaHy", "files": ["browser/components/extensions/ext-tabs.js", "browser/components/extensions/schemas/tabs.json"], "git_node": null, "git_parents": [null], "node": "1a169abe9d0a50fdadd60f62bea934e9f0b0460a", "parents": ["c105be29eb272522fed793fb71cdb2e9e029d4ed"], "tags": []}, {"author": "Jan Beich \u003cjbeich@FreeBSD.org\u003e", "branch": "default", "desc": "Bug 1389733 - Add missing Skia compile guards. r=lsalzman, a=gchang\n\nMozReview-Commit-ID: BXYxGjj0j73", "files": ["gfx/2d/ScaledFontBase.cpp", "image/Downscaler.h"], "git_node": null, "git_parents": [null], "node": "ec091dee71a261abc7d8b91f1213eca6686f5356", "parents": ["1a169abe9d0a50fdadd60f62bea934e9f0b0460a"], "tags": []}, {"author": "Matt Howell \u003cmhowell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1390253 - Increase RAM threshold for automatic 64-bit installation. r=rstrong, a=gchang\n\nMozReview-Commit-ID: 1IDedw68lF6", "files": ["browser/installer/windows/nsis/stub.nsi"], "git_node": null, "git_parents": [null], "node": "2f22606fa551e802fb6a6f4fdbf8fb8367467679", "parents": ["ec091dee71a261abc7d8b91f1213eca6686f5356"], "tags": []}], "date": 1502908076, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7623": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "Automatic version bump. CLOSED TREE NO BUG a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "544103c9f35907b80f8f024f29f9058ebe868065", "parents": ["2f22606fa551e802fb6a6f4fdbf8fb8367467679"], "tags": []}, {"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging efabe9b3a88e0cb1bcb092b34e0291ac99759471 with FIREFOX_56_0b3_BUILD1, FIREFOX_56_0b3_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "36f2da27aa91c72fb93505a13089e78d7bdb1dd6", "parents": ["544103c9f35907b80f8f024f29f9058ebe868065"], "tags": []}], "date": 1502912236, "git_changesets": [null, null], "user": "ffxbld"}, "7624": {"changesets": [{"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1390087 - Ignore zones that we can't collect when scheduling zones for GC r=sfink a=gchang", "files": ["js/src/jit-test/tests/gc/bug-1390087.js", "js/src/jsgc.cpp"], "git_node": null, "git_parents": [null], "node": "594c90fb0183968b0d4ffe3ea2a5a5a0578be3bb", "parents": ["36f2da27aa91c72fb93505a13089e78d7bdb1dd6"], "tags": []}], "date": 1502959045, "git_changesets": [null], "user": "jcoppeard@mozilla.com"}, "7625": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging efabe9b3a88e0cb1bcb092b34e0291ac99759471 with FENNEC_56_0b3_BUILD1, FENNEC_56_0b3_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "933e3d98fb65f36c129ed3dc625c84636c42581c", "parents": ["594c90fb0183968b0d4ffe3ea2a5a5a0578be3bb"], "tags": []}], "date": 1502990035, "git_changesets": [null], "user": "ffxbld"}, "7626": {"changesets": [{"author": "Robert Strong \u003crobert.bugzilla@gmail.com\u003e", "branch": "default", "desc": "Bug 1387241 - Reland the LZMA and SHA384 mar generation scripts from Bug 1385780 after 56 Beta 3. r=bhearsum, r=rail, a=lhenry\nUpdate scripts to support both lzma and bzip2\nUpdate unused python script to support lzma. This also adds python 3.0 support to the script while still supporting pythin 2.7\nUpdate test scripts to support lzma", "files": ["python/mozbuild/mozbuild/repackaging/mar.py", "tools/update-packaging/common.sh", "tools/update-packaging/make_full_update.sh", "tools/update-packaging/make_incremental_update.sh", "tools/update-packaging/make_incremental_updates.py", "tools/update-packaging/test/catmanifest.sh", "tools/update-packaging/test/common.sh", "tools/update-packaging/test/diffmar.sh", "tools/update-packaging/test/from-mac/Contents/Resources/chrome.manifest", "tools/update-packaging/test/from/chrome.manifest", "tools/update-packaging/test/make_full_update.sh", "tools/update-packaging/test/to-mac/Contents/Resources/chrome.manifest", "tools/update-packaging/test/to/chrome.manifest", "tools/update-packaging/unwrap_full_update.pl"], "git_node": null, "git_parents": [null], "node": "84b06813d694b1b0e29b462bdbe27c3481b9d5bf", "parents": ["933e3d98fb65f36c129ed3dc625c84636c42581c"], "tags": []}, {"author": "Robert Strong \u003crobert.bugzilla@gmail.com\u003e", "branch": "default", "desc": "Bug 1387241 - Reland the LZMA and SHA384 mar generation scripts from Bug 1385780 after 56 Beta 3. r=bhearsum, a=lhenry\nAdds support to unwrap_full_update.pl to detect if the mar file's contents were compressed using bzip2 and if not to default to lzma.", "files": ["tools/update-packaging/unwrap_full_update.pl"], "git_node": null, "git_parents": [null], "node": "a0f80f524721018a1d57483eb419ebe01cca99cc", "parents": ["84b06813d694b1b0e29b462bdbe27c3481b9d5bf"], "tags": []}, {"author": "Robert Strong \u003crobert.bugzilla@gmail.com\u003e", "branch": "default", "desc": "Bug 1387241 - Reland the LZMA and SHA384 mar generation scripts from Bug 1385780 after 56 Beta 3. r=bhearsum, a=lhenry\nNew mar convertor script to convert a mar file from bzip2 to lzma and from lzma to bzip2.", "files": ["tools/update-packaging/change_mar_compression.pl"], "git_node": null, "git_parents": [null], "node": "5ffaf610754fda9ed6ab708fba70b5cf84050044", "parents": ["a0f80f524721018a1d57483eb419ebe01cca99cc"], "tags": []}, {"author": "Robert Strong \u003crobert.bugzilla@gmail.com\u003e", "branch": "default", "desc": "Bug 1387241 - Reland the LZMA and SHA384 mar generation scripts from Bug 1385780 after 56 Beta 3. r=bhearsum, a=lhenry\nsign mar files using the sha384 certificate", "files": ["taskcluster/taskgraph/transforms/build_signing.py", "taskcluster/taskgraph/transforms/nightly_l10n_signing.py", "taskcluster/taskgraph/transforms/repackage_signing.py"], "git_node": null, "git_parents": [null], "node": "1e4e744e26ec23b947ff997301c9fcd5cc1243ac", "parents": ["5ffaf610754fda9ed6ab708fba70b5cf84050044"], "tags": []}, {"author": "Robert Strong \u003crobert.bugzilla@gmail.com\u003e", "branch": "default", "desc": "Bug 1386402 - Change mar generation scripts to exit with an error if xz is not found on the system. r=bhearsum, a=lhenry", "files": ["tools/update-packaging/common.sh"], "git_node": null, "git_parents": [null], "node": "d95e1a324228b51db76c9e2e545c93abba9bb72a", "parents": ["1e4e744e26ec23b947ff997301c9fcd5cc1243ac"], "tags": []}, {"author": "Robert Strong \u003crobert.bugzilla@gmail.com\u003e", "branch": "default", "desc": "Installer patch - Bug 1386176 - Provide value in update url to indicate whether a Firefox 32 bit install hasn't been migrated to Firefox 64 bit previously. r=mhowell, a=lhenry", "files": ["browser/installer/windows/nsis/installer.nsi", "browser/installer/windows/nsis/shared.nsh"], "git_node": null, "git_parents": [null], "node": "e4070ef92b9a85959e05a0f4fd10752bcd572ddb", "parents": ["d95e1a324228b51db76c9e2e545c93abba9bb72a"], "tags": []}, {"author": "Robert Strong \u003crobert.bugzilla@gmail.com\u003e", "branch": "default", "desc": "App update patch - Bug 1386176 - Provide value in update url to indicate whether a Firefox 32 bit install hasn't been migrated to Firefox 64 bit previously. r=mhowell, a=lhenry", "files": ["toolkit/mozapps/update/nsUpdateService.js"], "git_node": null, "git_parents": [null], "node": "3145c49cc4161881309672ebc275c36f4c9a36c9", "parents": ["e4070ef92b9a85959e05a0f4fd10752bcd572ddb"], "tags": []}], "date": 1502991478, "git_changesets": [null, null, null, null, null, null, null], "user": "rstrong@mozilla.com"}, "7627": {"changesets": [{"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1390486 - Add \"dom.file.createInChild\" preference to recommended prefs. r=ato, a=test-only\n\nTo allow geckodriver to create file objects in child processes, this\npreference has to be set to true. As such it needs to be recommended\nin Marionette and set as default preference for geckodriver.\n\nMozReview-Commit-ID: 8bdbi5jH6Vc", "files": ["testing/geckodriver/CHANGES.md", "testing/geckodriver/src/prefs.rs", "testing/marionette/server.js"], "git_node": null, "git_parents": [null], "node": "53842188fe9d8febf556feb4a68837ec030641fc", "parents": ["3145c49cc4161881309672ebc275c36f4c9a36c9"], "tags": []}, {"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Bug 1389335 - Only check APZTestDataEnabled when APZPaintLogHelper is created. r=botond, a=test-only\n\nMozReview-Commit-ID: 50JCZSIcLIn", "files": ["gfx/layers/apz/testutil/APZTestData.h"], "git_node": null, "git_parents": [null], "node": "0537e2f37ee1352b0f1b041fe4ead43eacc36365", "parents": ["53842188fe9d8febf556feb4a68837ec030641fc"], "tags": []}, {"author": "Bryce Van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1371166 - Update media recorder principal test to behave more like MediaElement principal test. r=jib, a=test-only\n\nUpdate the MediaRecorder principal test to behave more like\ntest_mixed_principals.html. This involves preloading metadata and using a\nlonger video to test with. This particular combination currently results in\nmultiple requests being made for the resource, however this is not a robust\nsolution in that the behaviour of the MediaCache and associated objects may\nchange and break this. This fixes the issue for now as best I can tell, but\na follow up gtest or may be a more sensible long term solution.\n\nMozReview-Commit-ID: F9gnnzGt3Cu", "files": ["dom/media/test/test_mediarecorder_principals.html"], "git_node": null, "git_parents": [null], "node": "cd73acc0f943987c079c3ebb40a87886734f5fc8", "parents": ["0537e2f37ee1352b0f1b041fe4ead43eacc36365"], "tags": []}, {"author": "Bryce Van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1371166 - Drive by update to update var -\u003e let in test. r=jib, a=test-only\n\nMozReview-Commit-ID: TAP46fR2HP", "files": ["dom/media/test/test_mediarecorder_principals.html"], "git_node": null, "git_parents": [null], "node": "b8a21f125b3b89176371feef8f25f1d761a9db0a", "parents": ["cd73acc0f943987c079c3ebb40a87886734f5fc8"], "tags": []}, {"author": "Bryce Van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1371166 - Explicitly load videos via video.load to get a cross origin requests to take place. r=jib, a=test-only\n\nChange where load calls are used in media recorder principals test to more\nreliably force cross origin requests.\n\nMozReview-Commit-ID: 7La6ZIRmsTQ", "files": ["dom/media/test/test_mediarecorder_principals.html"], "git_node": null, "git_parents": [null], "node": "f1eb755a3736142b4236be5686798db86e344836", "parents": ["b8a21f125b3b89176371feef8f25f1d761a9db0a"], "tags": []}, {"author": "Bobby Holley \u003cbobbyholley@gmail.com\u003e", "branch": "default", "desc": "Bug 1390179 - Avoid leaving stale ANCESTOR_WAS_RECONSTRUCTED bits in the tree (from bholley:ancestor_reconstruct). r=emilio, a=gchang\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 99b4b7e9602ea1440d2d2ae6c32be30bd0c4f721", "files": ["servo/components/style/data.rs", "servo/components/style/dom.rs", "servo/components/style/gecko/wrapper.rs", "servo/components/style/traversal.rs"], "git_node": null, "git_parents": [null], "node": "889c7b194b5773e0d781a2950f150b5b89cf4c76", "parents": ["f1eb755a3736142b4236be5686798db86e344836"], "tags": []}, {"author": "Thomas Nguyen \u003ctnguyen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1388912 - Change text color of advisory link on SB warning page to white. r=johannh, a=gchang\n\nMozReview-Commit-ID: 9UgnKWjKNIq", "files": ["browser/themes/shared/blockedSite.css", "mobile/android/themes/core/netError.css"], "git_node": null, "git_parents": [null], "node": "1a8880e29288caf4dc9be1d67d62209d7bf48775", "parents": ["889c7b194b5773e0d781a2950f150b5b89cf4c76"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1387525 - Fix crash in webrtc::NetEqImpl::InsertPacketInternal. r=jesup, a=gchang\n\nThe webrtc.org code assumes we will always get a valid decoder for a known payload\ntype, but this is not true for our builds. This adds a check that we have a valid\ndecoder before calling IncomingPacket.\n\nMozReview-Commit-ID: GUJR7Qn28vh", "files": ["media/webrtc/trunk/webrtc/modules/audio_coding/neteq/neteq_impl.cc"], "git_node": null, "git_parents": [null], "node": "492951d0d127763ec1cb10f8cf25f16b61b50d72", "parents": ["1a8880e29288caf4dc9be1d67d62209d7bf48775"], "tags": []}, {"author": "Jason Laster \u003cjason.laster.11@gmail.com\u003e", "branch": "default", "desc": "Bug 1389503 - Don't fail when an SVG is not found. r=jdescottes, a=gchang", "files": ["devtools/client/debugger/new/debugger.js"], "git_node": null, "git_parents": [null], "node": "1e2abdc98512294903ff1c727d497b13b0bb3b8c", "parents": ["492951d0d127763ec1cb10f8cf25f16b61b50d72"], "tags": []}, {"author": "Bevis Tseng \u003cbtseng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1367497 - Improve Error Handling in {Add|Remove}ObjectLocked(). r=froydnj, r=jfkthame, a=gchang", "files": ["gfx/thebes/gfxFont.cpp", "gfx/thebes/gfxFont.h", "xpcom/ds/nsExpirationTracker.h"], "git_node": null, "git_parents": [null], "node": "91a92e4f9136f2c8da9c060d60644cf9d76a9afe", "parents": ["1e2abdc98512294903ff1c727d497b13b0bb3b8c"], "tags": []}], "date": 1502992612, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7628": {"changesets": [{"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1380512 - Fix intermittent on browser_webconsole_check_stubs_console_api. r=Honza, a=test-only\n\nThis hopefully fix the frequent intermittent on this test.\nIn the cleanPacket function, we are overriding the actor\nof arguments. Thus, some server-calls were using an unknown\nactorId, which resulted in errors.\nWe now create a new object for the argument for the stub so\nwe don't override anything.\n\nMozReview-Commit-ID: EcvVUqQS3Dt", "files": ["devtools/client/webconsole/new-console-output/test/fixtures/stub-generators/head.js", "devtools/client/webconsole/new-console-output/test/fixtures/stubs/consoleApi.js"], "git_node": null, "git_parents": [null], "node": "7bd3b1370946379745525af75aab7537c79fc59e", "parents": ["91a92e4f9136f2c8da9c060d60644cf9d76a9afe"], "tags": []}], "date": 1502993505, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "7629": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset 889c7b194b57 (bug 1390179) for bustage.", "files": ["servo/components/style/data.rs", "servo/components/style/dom.rs", "servo/components/style/gecko/wrapper.rs", "servo/components/style/traversal.rs"], "git_node": null, "git_parents": [null], "node": "2d2d2158cad1a5d6cd06a20cdb78a6537d6bc622", "parents": ["7bd3b1370946379745525af75aab7537c79fc59e"], "tags": []}, {"author": "Bobby Holley \u003cbobbyholley@gmail.com\u003e", "branch": "default", "desc": "Bug 1390179 - Avoid leaving stale ANCESTOR_WAS_RECONSTRUCTED bits in the tree (from bholley:ancestor_reconstruct). r=emilio, a=gchang\n\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 99b4b7e9602ea1440d2d2ae6c32be30bd0c4f721", "files": ["servo/components/style/data.rs", "servo/components/style/dom.rs", "servo/components/style/gecko/wrapper.rs", "servo/components/style/traversal.rs"], "git_node": null, "git_parents": [null], "node": "925fb6cf84e7243a387643ec1ef8fa8b8292e65e", "parents": ["2d2d2158cad1a5d6cd06a20cdb78a6537d6bc622"], "tags": []}], "date": 1502994183, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "7630": {"changesets": [{"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1389715 - Vendor latest robustcheckout. r=ted, a=release\n\nFrom revision 19db5f4b5b10f639d24e69a4f21e4e80c6e5bbdd of\nversion-control-tools. Previous revision was\n249a47720ddcf896a9f07600c429a1b4492b805e.\n\nChanges include:\n\n* Use new vfs APIs when available (bug 1359959)\n* Mark as compatible with Mercurial 4.2 (bug 1361182)\n* Retry after SSLError (bug 1354824)\n* Mark as compatible with Mercurial 4.3\n* Detect and recover from open locks (bug 1297153)\n\nThe most significant is the last one. TaskCluster can SIGKILL\n`hg`, leading to orphaned transactions and locks. This can lead\nto timeouts or use of a corrupt repository in some scenarios.\nThose problems should no longer occur.\n\nMozReview-Commit-ID: QAOSLyc0xD", "files": ["testing/mozharness/external_tools/robustcheckout.py"], "git_node": null, "git_parents": [null], "node": "591a279ca4c4c3889318a661d533c6de591ac86f", "parents": ["925fb6cf84e7243a387643ec1ef8fa8b8292e65e"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1385950 - Disable test_peerConnection_captureStream_canvas_webgl.html. r=kwierso, a=test-only\n\nMozReview-Commit-ID: 3L1v3Mjk29S", "files": ["dom/media/tests/mochitest/mochitest.ini"], "git_node": null, "git_parents": [null], "node": "57f261c06f4f26deabcb4374f35fa17b7c594267", "parents": ["591a279ca4c4c3889318a661d533c6de591ac86f"], "tags": []}], "date": 1503007322, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "7631": {"changesets": [{"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1389715 - Upgrade to Mercurial 4.3.1. r=ted, a=release\n\nThis is pretty straightforward: we just update some version numbers\nand hashes.\n\nThe tooltool artifacts were produced and uploaded by me, just like\nthe last ones. I have some patches to establish a proper toolchain\ntask to build Mercurial. But it is a bit of a rabbit hole due to the\nchicken-and-egg problem of Mercurial needing to be in Docker images.\nPreserving the existing install mechanism is the simplest path\nforward. Plus we need this patch so we can uplift so earlier releases\nget a secure Mercurial in their Docker images.\n\ncolor and pager are enabled by default in 4.2. So remove configuration\noptions for them that add no value.\n\nMozReview-Commit-ID: 9pkHX044kV8", "files": ["taskcluster/docker/recipes/install-mercurial.sh"], "git_node": null, "git_parents": [null], "node": "8646498722f98f24d8757542c0e65d6934018a96", "parents": ["57f261c06f4f26deabcb4374f35fa17b7c594267"], "tags": []}, {"author": "k88hudson \u003ckhudson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1389482 - Add legal and telemetry fixes to Activity Stream. r=ursula, a=lizzard\n\nMozReview-Commit-ID: GBuKpKgAbYe", "files": ["browser/extensions/activity-stream/common/Actions.jsm", "browser/extensions/activity-stream/data/content/activity-stream.bundle.js", "browser/extensions/activity-stream/data/content/activity-stream.css", "browser/extensions/activity-stream/data/content/tippytop/images/aliexpress-com.png", "browser/extensions/activity-stream/data/content/tippytop/images/aliexpress-com@2x.png", "browser/extensions/activity-stream/data/content/tippytop/images/allegro-pl.png", "browser/extensions/activity-stream/data/content/tippytop/images/allegro-pl@2x.png", "browser/extensions/activity-stream/data/content/tippytop/images/amazon-ca@2x.png", "browser/extensions/activity-stream/data/content/tippytop/images/amazon-com.png", "browser/extensions/activity-stream/data/content/tippytop/images/amazon-com@2x.png", "browser/extensions/activity-stream/data/content/tippytop/images/amazon-de@2x.png", "browser/extensions/activity-stream/data/content/tippytop/images/amazon-fr@2x.png", "browser/extensions/activity-stream/data/content/tippytop/images/amazon-uk@2x.png", "browser/extensions/activity-stream/data/content/tippytop/images/avito-ru.png", "browser/extensions/activity-stream/data/content/tippytop/images/avito@2x.png", "browser/extensions/activity-stream/data/content/tippytop/images/bbc-com.png", "browser/extensions/activity-stream/data/content/tippytop/images/bbc-uk@2x.png", "browser/extensions/activity-stream/data/content/tippytop/images/ebay-com.png", "browser/extensions/activity-stream/data/content/tippytop/images/ebay-de@2x.png", "browser/extensions/activity-stream/data/content/tippytop/images/ebay@2x.png", "browser/extensions/activity-stream/data/content/tippytop/images/facebook-com.png", "browser/extensions/activity-stream/data/content/tippytop/images/facebook-com@2x.png", "browser/extensions/activity-stream/data/content/tippytop/images/leboncoin-fr.png", "browser/extensions/activity-stream/data/content/tippytop/images/leboncoin@2x.png", "browser/extensions/activity-stream/data/content/tippytop/images/ok-ru.png", "browser/extensions/activity-stream/data/content/tippytop/images/ok@2x.png", "browser/extensions/activity-stream/data/content/tippytop/images/olx-pl.png", "browser/extensions/activity-stream/data/content/tippytop/images/olx-pl@2x.png", "browser/extensions/activity-stream/data/content/tippytop/images/reddit-com.png", "browser/extensions/activity-stream/data/content/tippytop/images/reddit-com@2x.png", "browser/extensions/activity-stream/data/content/tippytop/images/twitter-com.png", "browser/extensions/activity-stream/data/content/tippytop/images/twitter-com@2x.png", "browser/extensions/activity-stream/data/content/tippytop/images/vk-com.png", "browser/extensions/activity-stream/data/content/tippytop/images/vk-com@2x.png", "browser/extensions/activity-stream/data/content/tippytop/images/wikipedia-com@2x.png", "browser/extensions/activity-stream/data/content/tippytop/images/wikipedia-org.png", "browser/extensions/activity-stream/data/content/tippytop/images/wykop-pl.png", "browser/extensions/activity-stream/data/content/tippytop/images/wykop@2x.png", "browser/extensions/activity-stream/data/content/tippytop/images/youtube-com.png", "browser/extensions/activity-stream/data/content/tippytop/images/youtube-com@2x.png", "browser/extensions/activity-stream/data/content/tippytop/top_sites.json", "browser/extensions/activity-stream/lib/ActivityStream.jsm", "browser/extensions/activity-stream/lib/SnippetsFeed.jsm", "browser/extensions/activity-stream/lib/TelemetryFeed.jsm", "browser/extensions/activity-stream/lib/TelemetrySender.jsm", "browser/extensions/activity-stream/test/schemas/pings.js", "browser/extensions/activity-stream/test/unit/common/Actions.test.js", "browser/extensions/activity-stream/test/unit/lib/ActivityStreamMessageChannel.test.js", "browser/extensions/activity-stream/test/unit/lib/PlacesFeed.test.js", "browser/extensions/activity-stream/test/unit/lib/SnippetsFeed.test.js", "browser/extensions/activity-stream/test/unit/lib/TelemetryFeed.test.js", "browser/extensions/activity-stream/test/unit/lib/TelemetrySender.test.js", "browser/extensions/activity-stream/test/unit/unit-entry.js", "browser/extensions/activity-stream/test/unit/utils.js"], "git_node": null, "git_parents": [null], "node": "e531ebf93d7ba5053dffee3bacbc7c805b8b9888", "parents": ["8646498722f98f24d8757542c0e65d6934018a96"], "tags": []}], "date": 1503009743, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "7632": {"changesets": [{"author": "Nick Thomas \u003cnthomas@mozilla.com\u003e", "branch": "default", "desc": "Bug 1391473 - Add xz binaries to buildbot workers, r=aki a=release\n\nMozReview-Commit-ID: FCPuC7eqdct", "files": ["browser/config/tooltool-manifests/win32/l10n.manifest", "browser/config/tooltool-manifests/win64/l10n.manifest", "testing/mozharness/configs/single_locale/win32.py", "testing/mozharness/configs/single_locale/win32_devedition.py", "testing/mozharness/configs/single_locale/win64.py", "testing/mozharness/configs/single_locale/win64_devedition.py"], "git_node": null, "git_parents": [null], "node": "80312a6daa088138cc3d53b3944cd814759a623f", "parents": ["e531ebf93d7ba5053dffee3bacbc7c805b8b9888"], "tags": []}], "date": 1503028207, "git_changesets": [null], "user": "nthomas@mozilla.com"}, "7633": {"changesets": [{"author": "ffxbld", "branch": "default", "desc": "No bug, Automated blocklist update from host bld-linux64-spot-306 - a=blocklist-update", "files": ["browser/app/blocklist.xml"], "git_node": null, "git_parents": [null], "node": "ec091b2f1998e869d4ce0e466b0c218653bcbc43", "parents": ["80312a6daa088138cc3d53b3944cd814759a623f"], "tags": []}], "date": 1503051479, "git_changesets": [null], "user": "ffxbld"}, "7634": {"changesets": [{"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1254136 - Fix double registration for sessionstore-windows-restored. r=automatedtester, a=test-only\n\nA missing break statement caused a double execution of the code in\n\"profile-after-change\", which leads to two instantiations of the\nMarionette server colliding due to the same port.\n\nMozReview-Commit-ID: Dp6fncj463j", "files": ["testing/marionette/components/marionette.js", "testing/marionette/harness/marionette_harness/tests/unit/test_quit_restart.py"], "git_node": null, "git_parents": [null], "node": "fed67039c7b5313a562753da484e0489150c4e64", "parents": ["ec091b2f1998e869d4ce0e466b0c218653bcbc43"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1382057 - Skip browser_applications_selection.js on Linux. a=test-only", "files": ["browser/components/preferences/in-content-new/tests/browser.ini"], "git_node": null, "git_parents": [null], "node": "8dbb3f787e2bcb77cc9f8dbdc4215c79431945eb", "parents": ["fed67039c7b5313a562753da484e0489150c4e64"], "tags": []}, {"author": "Chun-Min Chang \u003cchun.m.chang@gmail.com\u003e", "branch": "default", "desc": "Bug 1384944 - Replace NS_ConvertASCIItoUTF16 by NS_ConvertUTF8toUTF16. r=padenot, a=gchang", "files": ["dom/media/CubebUtils.cpp"], "git_node": null, "git_parents": [null], "node": "e4803d1bcef0c47559758aba652a1ac7761630c0", "parents": ["8dbb3f787e2bcb77cc9f8dbdc4215c79431945eb"], "tags": []}, {"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 1363723 - Preserve array in aria owns hash. r=surkov, a=gchang", "files": ["accessible/generic/DocAccessible.cpp"], "git_node": null, "git_parents": [null], "node": "a60be780c0d78f4a2bc16efda26795005d19dc7f", "parents": ["e4803d1bcef0c47559758aba652a1ac7761630c0"], "tags": []}, {"author": "Nevin Chen \u003ccnevinchen@gmail.com\u003e", "branch": "default", "desc": "Bug 1390038 - Fix xml parsing error. r=dao, a=gchang\n\nMozReview-Commit-ID: 8sv7aH6ejIt", "files": ["mobile/android/chrome/content/aboutRights.xhtml"], "git_node": null, "git_parents": [null], "node": "9832bd5eb39dfba4f9c4be23bd010232bac59fac", "parents": ["a60be780c0d78f4a2bc16efda26795005d19dc7f"], "tags": []}, {"author": "Mason Chang \u003cmchang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1390002 - There are some paths to find out if dwrite is enabled, which inits gfxPlatform, which requires information from PopulateScreenInfo, which depends on the refresh driver existing. At this time however, we haven't initialized our vsync source so we crash. This moves vsync initialization earlier in the gfx pipeline. r=kats, a=gchang", "files": ["gfx/thebes/gfxPlatform.cpp"], "git_node": null, "git_parents": [null], "node": "09be13b2551d805bef7cb88f1e1c082dd67e3c78", "parents": ["9832bd5eb39dfba4f9c4be23bd010232bac59fac"], "tags": []}, {"author": "Bobby Holley \u003cbobbyholley@gmail.com\u003e", "branch": "default", "desc": "Bug 1389300 - Inherit style backend into NS_NewDOMDocument. r=smaug, r=heycam, a=gchang\n\nOur current machinery for enabling stylo requires a docshell - if there isn't\none, we default to the Gecko style system.\n\nWhen getComputedStyle operates on an element without a presshell, it uses the\ncaller's presshell instead. If the element has previously been styled with\none style system (but no longer has a presshell), and the caller uses a\ndifferent style backend, using the caller's style system can cause crashes when\nwe pull bits of cached data off the DOM (like cached style attributes).\n\nSo we want to throw when window.getComputedStyle(element) is called for a\n(window, element) pair with different style backends (which is what the next\npatch in this bug does).\n\nHowever, that causes a few failures where stylo-backed documents try to do\ngetComputedStyle on an XHR document (which, without a docshell, will use the\ngecko style system).\n\nSo this patch does some work to propagate the creator's style backend into\nvarious docshell-less documents. This should allow both chrome (which uses gecko)\nand content (which uses stylo) to use getComputedStyle on the response document\nfor XHRs they create.\n\nNote that the second patch in this bug will make\nchromeWin.getComputedStyle(contentObj) throw. If we discover code that does\nthat, we can just make it invoke the content's getComputedStyle method over Xrays.\n\nMozReview-Commit-ID: 5OsmHJKq5Ui", "files": ["dom/base/DOMImplementation.cpp", "dom/base/DOMParser.cpp", "dom/base/nsContentUtils.cpp", "dom/base/nsDocument.cpp", "dom/base/nsIDocument.h", "dom/xbl/nsXBLDocumentInfo.cpp", "dom/xhr/XMLHttpRequestMainThread.cpp", "dom/xhr/XMLHttpRequestMainThread.h", "dom/xml/XMLDocument.cpp", "gfx/thebes/gfxSVGGlyphs.cpp", "parser/html/nsParserUtils.cpp"], "git_node": null, "git_parents": [null], "node": "c261040950bfb7d7e575a9b73684cb6d48fa9678", "parents": ["09be13b2551d805bef7cb88f1e1c082dd67e3c78"], "tags": []}, {"author": "Bobby Holley \u003cbobbyholley@gmail.com\u003e", "branch": "default", "desc": "Bug 1389300 - Don't mix style backend types in nsComputedDOMStyle. r=heycam, a=gchang\n\nMozReview-Commit-ID: 8Decj2cxySY", "files": ["layout/style/nsComputedDOMStyle.cpp"], "git_node": null, "git_parents": [null], "node": "84f048b7dca0169ed9d43009eac05a379a70b3cb", "parents": ["c261040950bfb7d7e575a9b73684cb6d48fa9678"], "tags": []}, {"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 1376754 - Remove hide event target flag from accessible when event is dropped. r=surkov, a=gchang", "files": ["accessible/base/NotificationController.cpp"], "git_node": null, "git_parents": [null], "node": "78a5c6c95ab89c8a28525cb5e62aac3b8a02f080", "parents": ["84f048b7dca0169ed9d43009eac05a379a70b3cb"], "tags": []}], "date": 1503056624, "git_changesets": [null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7635": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump\n\nro -\u003e 1153c0e65cf3", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "006122d3bffe2e7e6a311d889282f0bd70e60620", "parents": ["78a5c6c95ab89c8a28525cb5e62aac3b8a02f080"], "tags": []}], "date": 1503061222, "git_changesets": [null], "user": "ffxbld"}, "7636": {"changesets": [{"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1388319 - Mark ServoStyleSet dirty in its Init. r=emilio, a=bustage\n\nMozReview-Commit-ID: 804KasIiS6E", "files": ["layout/style/ServoStyleSet.cpp"], "git_node": null, "git_parents": [null], "node": "554f6e2674fecadc3a66ec5a497bcaf7064068ee", "parents": ["006122d3bffe2e7e6a311d889282f0bd70e60620"], "tags": []}], "date": 1503067631, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "7637": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset 554f6e2674fe (bug 1388319)", "files": ["layout/style/ServoStyleSet.cpp"], "git_node": null, "git_parents": [null], "node": "02e56d2e2c64d34976067ee52df34c15344be1de", "parents": ["554f6e2674fecadc3a66ec5a497bcaf7064068ee"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changesets 84f048b7dca0 and c261040950bf (bug 1389300) for Stylo svg-as-image reftest failures.", "files": ["dom/base/DOMImplementation.cpp", "dom/base/DOMParser.cpp", "dom/base/nsContentUtils.cpp", "dom/base/nsDocument.cpp", "dom/base/nsIDocument.h", "dom/xbl/nsXBLDocumentInfo.cpp", "dom/xhr/XMLHttpRequestMainThread.cpp", "dom/xhr/XMLHttpRequestMainThread.h", "dom/xml/XMLDocument.cpp", "gfx/thebes/gfxSVGGlyphs.cpp", "layout/style/nsComputedDOMStyle.cpp", "parser/html/nsParserUtils.cpp"], "git_node": null, "git_parents": [null], "node": "b25f3c5ec90497426da80de98f38d53282b835ba", "parents": ["02e56d2e2c64d34976067ee52df34c15344be1de"], "tags": []}], "date": 1503071817, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "7638": {"changesets": [{"author": "Tom Prince", "branch": "THUNDERBIRD560b1_2017081901_RELBRANCH", "desc": "Bug 1387524 - Back out removal of MOZ_PRETTY to build Thunderbird 56 beta. a=jorgk\n\nBackout most of changeset 318f1bcd336e from bug 1329355 to support building releases on buildbot.\n\nMozReview-Commit-ID: K4QAA8IIpVX", "files": ["toolkit/locales/l10n.mk", "toolkit/mozapps/installer/package-name.mk"], "git_node": null, "git_parents": [null], "node": "105959300d145b1276215b7e779705df87180fb6", "parents": ["933e3d98fb65f36c129ed3dc625c84636c42581c"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "THUNDERBIRD560b1_2017081901_RELBRANCH", "desc": "Bug 1385905 - part2: HTMLEditRules::SplitParagraph() should insert normal \u003cbr\u003e element rather than moz-\u003cbr\u003e element if split element and/or new element is empty r=m_kato a=jorgk\n\nCurrently, HTMLEditRules::SplitParagraph() inserts moz-\u003cbr\u003e element when split element and/or new element causes empty line.  However, PlaintextSerializer ignores moz-\u003cbr\u003e elements.  Therefore, empty lines which are created by SplitParagraph() will be removed when it's converted to plaintext.\n\nSo, it should insert normal \u003cbr\u003e element for placeholder of empty lines instead.  Note that moz-\u003cbr\u003e elements are appeared as normal \u003cbr\u003e elements in the result of Element.innerHTML.  Additionally, Chromium always inserts a \u003cbr\u003e element for empty block elements which are created by Enter key press.  Therefore, using normal \u003cbr\u003e element in this case shouldn't cause any compatibility problems.\n\nMozReview-Commit-ID: FNV41zEFWqQ", "files": ["editor/libeditor/HTMLEditRules.cpp", "editor/libeditor/HTMLEditRules.h", "editor/libeditor/TextEditRules.cpp", "editor/libeditor/TextEditRules.h"], "git_node": null, "git_parents": [null], "node": "933fbae1415a6385e51b60d5ee40b3183a5b2d7f", "parents": ["105959300d145b1276215b7e779705df87180fb6"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "THUNDERBIRD560b1_2017081901_RELBRANCH", "desc": "Bug 1350152 - Don't rely on gBrowser in nsLoginManagerPrompter.js. r=mkaply a=jorgk\n\nIn bug 1266836 we fixed this code to properly work in e10s,\nbut made the mistake of using gBrowser in toolkit code, breaking\nXUL apps that don't have a gBrowser. This solution implements\na different code-path for non-e10s and returns a chrome\nwindow for consumers that don't offer a browser.\n\nMozReview-Commit-ID: 929ahDenzu5", "files": ["toolkit/components/passwordmgr/nsLoginManagerPrompter.js"], "git_node": null, "git_parents": [null], "node": "adccebcd50ec6b552c0d004fd26a55a4d5d98ed6", "parents": ["933fbae1415a6385e51b60d5ee40b3183a5b2d7f"], "tags": []}, {"author": "Jorg K \u003cjorgk@jorgk.com\u003e", "branch": "THUNDERBIRD560b1_2017081901_RELBRANCH", "desc": "Bug 1388166 - Handle case where chromeWin.getBrowser() doesn't exist. r=johannh a=jorgk", "files": ["toolkit/components/passwordmgr/nsLoginManagerPrompter.js"], "git_node": null, "git_parents": [null], "node": "7455f5305055bf1d2a30ad17459a0d6aed385523", "parents": ["adccebcd50ec6b552c0d004fd26a55a4d5d98ed6"], "tags": []}, {"author": "Mason Chang \u003cmchang@mozilla.com\u003e", "branch": "THUNDERBIRD560b1_2017081901_RELBRANCH", "desc": "Bug 1390002 - There are some paths to find out if dwrite is enabled, which inits gfxPlatform, which requires information from PopulateScreenInfo, which depends on the refresh driver existing. At this time however, we haven't initialized our vsync source so we crash. This moves vsync initialization earlier in the gfx pipeline. r=kats, a=jorgk DONTBUILD", "files": ["gfx/thebes/gfxPlatform.cpp"], "git_node": null, "git_parents": [null], "node": "db099741d3daf7263ce4072847c95d9a714449e5", "parents": ["7455f5305055bf1d2a30ad17459a0d6aed385523"], "tags": []}], "date": 1503161980, "git_changesets": [null, null, null, null, null], "user": "mozilla@jorgk.com"}, "7639": {"changesets": [{"author": "tbirdbld", "branch": "THUNDERBIRD560b3_2017081915_RELBRANCH", "desc": "Automated checkin: version bump for thunderbird 56.0b3 release. DONTBUILD CLOSED TREE a=release", "files": [], "git_node": null, "git_parents": [null], "node": "126b591ebd3ee87b08c4a33d5a27d54c88e33e62", "parents": ["db099741d3daf7263ce4072847c95d9a714449e5"], "tags": ["THUNDERBIRD_56_0b3_BUILD1", "THUNDERBIRD_56_0b3_RELEASE"]}, {"author": "tbirdbld", "branch": "THUNDERBIRD560b3_2017081915_RELBRANCH", "desc": "Added THUNDERBIRD_56_0b3_RELEASE THUNDERBIRD_56_0b3_BUILD1 tag(s) for changeset 126b591ebd3e. DONTBUILD CLOSED TREE a=release", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "7ff109dc4607024990e15af24b8286ba96f3d416", "parents": ["126b591ebd3ee87b08c4a33d5a27d54c88e33e62"], "tags": []}], "date": 1503171098, "git_changesets": [null, null], "user": "tbirdbld"}, "7640": {"changesets": [{"author": "Mihai Tabara \u003cmtabara@mozilla.com\u003e", "branch": "default", "desc": "Bug 1391297 - Update MAR to sha384 past 56.0b4 in update-packaging Makefile. r=catlee a=release\n\nMozReview-Commit-ID: 25S1SdLmvdx", "files": ["tools/update-packaging/Makefile.in"], "git_node": null, "git_parents": [null], "node": "05a4dc75c125a80cbaacd44c7b7937c77dc384a8", "parents": ["b25f3c5ec90497426da80de98f38d53282b835ba"], "tags": ["DEVEDITION_56_0b4_RELEASE", "FIREFOX_56_0b4_BUILD5", "FIREFOX_56_0b4_RELEASE"]}], "date": 1503176158, "git_changesets": [null], "user": "mtabara@mozilla.com"}, "7641": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump\n\neu -\u003e bb700829af03\nru -\u003e aee79cd84afb", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "891d019c1fb56a8f96f8747077b9e33ded662424", "parents": ["05a4dc75c125a80cbaacd44c7b7937c77dc384a8"], "tags": []}], "date": 1503244831, "git_changesets": [null], "user": "ffxbld"}, "7642": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "Automatic version bump. CLOSED TREE NO BUG a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "32b732560adc31bcc0eddca47bcd6a863d8c906d", "parents": ["891d019c1fb56a8f96f8747077b9e33ded662424"], "tags": []}, {"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging 05a4dc75c125a80cbaacd44c7b7937c77dc384a8 with FIREFOX_56_0b4_BUILD5, FIREFOX_56_0b4_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "ed1d1dc4955b4b9a6545af31767316b96454ac16", "parents": ["32b732560adc31bcc0eddca47bcd6a863d8c906d"], "tags": []}], "date": 1503310624, "git_changesets": [null, null], "user": "ffxbld"}, "7643": {"changesets": [{"author": "Kim Moir \u003ckmoir@mozilla.com\u003e", "branch": "default", "desc": "Bug 1391283 - remove addon devel builds from beta r=Callek DONTBUILD a=test", "files": ["taskcluster/ci/build/linux.yml", "taskcluster/ci/build/macosx.yml", "taskcluster/ci/build/windows.yml"], "git_node": null, "git_parents": [null], "node": "f9fef2ff7756f03dca19671726c9aaf2647fe47a", "parents": ["ed1d1dc4955b4b9a6545af31767316b96454ac16"], "tags": []}], "date": 1503324281, "git_changesets": [null], "user": "kmoir@mozilla.com"}, "7644": {"changesets": [{"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1385621 - Fix `mach artifact toolchain` handling of download exceptions after bug 1364650. r=gps, a=NPOTB", "files": ["python/mozbuild/mozbuild/mach_commands.py"], "git_node": null, "git_parents": [null], "node": "1a06f6025f5988d0fff77d76d9eb8c84ea8f3f6c", "parents": ["f9fef2ff7756f03dca19671726c9aaf2647fe47a"], "tags": []}, {"author": "Tobias Schneider \u003ctschneider@mozilla.com\u003e", "branch": "default", "desc": "Bug 1369360 - (Intermittent intersection-observer/timestamp.html) Make testing for expected time origins more reliable. r=jgraham, a=test-only", "files": ["testing/web-platform/tests/intersection-observer/timestamp.html"], "git_node": null, "git_parents": [null], "node": "f94caff3f54289806e9343f022b0bcac2cef1661", "parents": ["1a06f6025f5988d0fff77d76d9eb8c84ea8f3f6c"], "tags": []}, {"author": "Henry Chang \u003chchang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1342298 - Synchronize with the loaded event for the newly added tab then start the test. r=ckerschb, a=test-only\n\nMozReview-Commit-ID: J6SqlfaOKGz", "files": ["dom/base/test/browser_bug902350.js"], "git_node": null, "git_parents": [null], "node": "f236b5a4397cdd0af004da8ad5640a46ba955801", "parents": ["f94caff3f54289806e9343f022b0bcac2cef1661"], "tags": []}, {"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1283609 - Part 1: Add an IToplevelProtocol::Open overload that takes an nsIEventTarget. r=billm, a=lizzard", "files": ["ipc/glue/MessageChannel.cpp", "ipc/glue/MessageChannel.h", "ipc/glue/ProtocolUtils.cpp", "ipc/glue/ProtocolUtils.h"], "git_node": null, "git_parents": [null], "node": "df048280b51310e530778e9d5535c85d0e41a889", "parents": ["f236b5a4397cdd0af004da8ad5640a46ba955801"], "tags": []}, {"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1283609 - Part 2: Rename BackgroundChild::SynchronouslyCreateForCurrentThread to BackgroundChild::GetOrCreateForCurrentThread. r=billm, a=lizzard", "files": ["dom/media/systemservices/CamerasChild.cpp", "dom/workers/RuntimeService.cpp", "dom/workers/WorkerThread.cpp", "ipc/glue/BackgroundChild.h", "ipc/glue/BackgroundImpl.cpp"], "git_node": null, "git_parents": [null], "node": "269bc08c27eda39cbf4e369d4ef6fa6d3aecf6b5", "parents": ["df048280b51310e530778e9d5535c85d0e41a889"], "tags": []}, {"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1283609 - Part 3: Core changes, stop using nested event loop in BackgroundChild::GetOrCreateForCurrentThread(). r=billm, a=lizzard\n\n- BackgroundChild::GetOrCreateForCurrentThread(nsIIPCBackgroundChildCreateCallback* aCallback) emulates former asynchronous behavior", "files": ["dom/ipc/ContentChild.h", "ipc/glue/BackgroundChild.h", "ipc/glue/BackgroundImpl.cpp"], "git_node": null, "git_parents": [null], "node": "a390db05a606297c64f029c6a35b87c86f6b5688", "parents": ["269bc08c27eda39cbf4e369d4ef6fa6d3aecf6b5"], "tags": []}, {"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1283609 - Part 4: Remove unused code. r=billm, a=lizzard", "files": ["ipc/glue/BackgroundImpl.cpp"], "git_node": null, "git_parents": [null], "node": "620514babf09ef317a17019feec534555f91b803", "parents": ["a390db05a606297c64f029c6a35b87c86f6b5688"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1388738 - Reuse devtools-startup initDevTools in DevToolsShim. r=ochameau, a=gchang\n\nMozReview-Commit-ID: 7Qr06CZBYuf", "files": ["devtools/shim/DevToolsShim.jsm"], "git_node": null, "git_parents": [null], "node": "ba9cc5295263af54d9ef4fedb7ecbbbc1cd9fa2c", "parents": ["620514babf09ef317a17019feec534555f91b803"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1388738 - Add comment for devtools-startup developerToggleCreated flag. r=ochameau, a=gchang\n\nMozReview-Commit-ID: FN4YuM7VpHf", "files": ["devtools/client/devtools-startup.js"], "git_node": null, "git_parents": [null], "node": "e9b8e3fb359c0e8956c148e0b37081ba0ca594e6", "parents": ["ba9cc5295263af54d9ef4fedb7ecbbbc1cd9fa2c"], "tags": []}, {"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1387583 - Avoid leaking a window in SelectParentHelper. r=jaws, a=gchang\n\nMozReview-Commit-ID: 6YILe7gi2fZ", "files": ["toolkit/modules/SelectParentHelper.jsm"], "git_node": null, "git_parents": [null], "node": "9b28ea0fe4e5cf75867ece02ca120fb5f6e5e92f", "parents": ["e9b8e3fb359c0e8956c148e0b37081ba0ca594e6"], "tags": []}, {"author": "Gian-Carlo Pascutto \u003cgcp@mozilla.com\u003e", "branch": "default", "desc": "Bug 1389078 - Remove (unneeded) usage of internal libc header. r=jld, a=gchang\n\nMozReview-Commit-ID: E7oppAtGRfD", "files": ["security/sandbox/linux/broker/SandboxBrokerRealpath.cpp"], "git_node": null, "git_parents": [null], "node": "9e27747354e0c803482fb55f66beb448f3c19062", "parents": ["9b28ea0fe4e5cf75867ece02ca120fb5f6e5e92f"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1389133 - Don't invalidate style content for missing widgets. r=karlt, a=gchang\n\nMozReview-Commit-ID: 2KfjYGvsiVv", "files": ["widget/gtk/WidgetStyleCache.cpp"], "git_node": null, "git_parents": [null], "node": "f233560347548f022964499bf241668fb4abc4a1", "parents": ["9e27747354e0c803482fb55f66beb448f3c19062"], "tags": []}], "date": 1503333960, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7645": {"changesets": [{"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1390550 - Update to latest libhyphen code from upstream. r=ryanvm, a=gchang", "files": ["intl/hyphenation/README.mozilla", "intl/hyphenation/hyphen/AUTHORS", "intl/hyphenation/hyphen/README", "intl/hyphenation/hyphen/hyphen.c"], "git_node": null, "git_parents": [null], "node": "7f8bf90b70e08a479b867133ffe053b201d3170e", "parents": ["f233560347548f022964499bf241668fb4abc4a1"], "tags": []}, {"author": "Andrew Sutherland \u003casutherland@asutherland.org\u003e", "branch": "default", "desc": "Bug 1389279 - storage::Service needs a death grip when removing strong observer references. r=bkelly, a=lizzard\n\nThe observer references were the only thing guranteed to keep the Service\nalive, leading to potential use-after-free during the iteration loop to\nmake sure all the connections were closed.  (Ironically, if they were\nfully closed and their instances destroyed, that's when bad things would\nhappen.)", "files": ["storage/mozStorageService.cpp"], "git_node": null, "git_parents": [null], "node": "e8eb71b4df6f142cfaaf532f5d9347bf0c153115", "parents": ["7f8bf90b70e08a479b867133ffe053b201d3170e"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1388647 - Part 1: IMEStateManager::OnChangeFocusInternal() shouldn't request to commit composition with sFocusedIMETabParent. r=m_kato, a=lizzard\n\nWhen a remote process has focus and it loses focus,\nIMEStateManager::OnChangeFocusInternal() sends NOTIFY_IME_OF_BLUR via\nIMEStateManager::NotifyIMEOfBlurForChildProcess().  Therefore,\nsFocusedIMETabParent and sFocusedIMEWidget are set to nullptr here. So, if a\nwindow becomes active, REQUEST_IME_TO_COMMIT_COMPOSITION in\nIMEStateManager::OnChangeFocusInternal() won't work because\nIMEStateManager::NotifyIME() ignores the request because of coming from wrong\nprocess.\n\nTherefore, IMEStateManager::OnChangeFocusInternal() needs to send\nREQUEST_TO_COMMIT_COMPOSITION with proper process information which is only\nstored by TextComposition instance.\n\nMozReview-Commit-ID: KNEvOoQtK1E", "files": ["dom/events/IMEStateManager.cpp"], "git_node": null, "git_parents": [null], "node": "498cc4ec01ce7c942419c8fd535caa77cdfc55e9", "parents": ["e8eb71b4df6f142cfaaf532f5d9347bf0c153115"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1388647 - Part 2: Make IMEInputHandler of Cocoa widget handle request to commit/cancel composition synchronously. r=m_kato, a=lizzard\n\nWhen Gecko started to support Cocoa widget, we needed to use NSInputManager.\nThat allowed applications to access only focused IME context.  Therefore, commit\ncomposition request handler for Cocoa is designed as handling asynchronosly if\nit's requested when the window is not active or is being inactivated.\n\nAdditionally, the asynchronous handling isn't perfect.  We hit some MOZ_ASSERT()\nnow in some places.  E.g., in SelectedRange(), it doesn't assume that it's\ncalled during deactive.\n\nOn the other hand, NSInputManager was alreay obsolete and we already stopped using it\n(bug 810225).  Instead, we're using NSTextInputContext and it allows applications\nto access IME anytime.  Therefore, if we make IMEInputHandler handles commit/cancel\ncomposition requests synchronsly, that behaves same as the other platforms.  So, we\ncan get rid of macOS specific issue completely.\n\nMozReview-Commit-ID: X7aWmGq95x", "files": ["widget/cocoa/TextInputHandler.h", "widget/cocoa/TextInputHandler.mm"], "git_node": null, "git_parents": [null], "node": "d5e6ccaef326591a59a2afb37c450ba3a0ae6409", "parents": ["498cc4ec01ce7c942419c8fd535caa77cdfc55e9"], "tags": []}, {"author": "Andrew Swan \u003caswan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1372750 - Pass startup/shutdown reasons to embedded webextensions. r=kmag, a=lizzard\n\nMozReview-Commit-ID: 3oJHM83Jbb0", "files": ["toolkit/mozapps/extensions/internal/XPIProvider.jsm"], "git_node": null, "git_parents": [null], "node": "22dfc30eaee2f690a28e144844f294e5689ff2af", "parents": ["d5e6ccaef326591a59a2afb37c450ba3a0ae6409"], "tags": []}, {"author": "Robert Helmer \u003crhelmer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1372750 - Allow generated embedded extensions to work in xpcshell tests. r=kmag, a=lizzard\n\nMozReview-Commit-ID: AkCnoUTldhI", "files": ["toolkit/components/extensions/ExtensionTestCommon.jsm"], "git_node": null, "git_parents": [null], "node": "5850f92e40c2cbb865c267b7b63c8835883db34e", "parents": ["22dfc30eaee2f690a28e144844f294e5689ff2af"], "tags": []}, {"author": "Henri Sivonen \u003chsivonen@hsivonen.fi\u003e", "branch": "default", "desc": "Bug 1385272 - Make plaintext serializer not crash when a \u003ctr\u003e is a child of a \u003ctr\u003e. r=Ehsan, a=gchang\n\nMozReview-Commit-ID: CMNIWYX8R07", "files": ["dom/base/crashtests/1385272-1.html", "dom/base/crashtests/crashtests.list", "dom/base/nsDocumentEncoder.cpp"], "git_node": null, "git_parents": [null], "node": "33443d73b7f4fce8af9edf8a414fcb811d4a0b61", "parents": ["5850f92e40c2cbb865c267b7b63c8835883db34e"], "tags": []}, {"author": "Alfredo.Yang \u003cayang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1389470 - Reduce table size on 32bit arch to avoid OOM. r=kinetik, a=lizzard\n\nMozReview-Commit-ID: C0O7Gnxbocy", "files": ["media/libstagefright/binding/mp4parse/src/lib.rs", "media/libstagefright/binding/mp4parse/src/tests.rs", "media/libstagefright/binding/update-rust.sh"], "git_node": null, "git_parents": [null], "node": "743f2fe4e06f7d40f8c02fe197360ed76baadf7e", "parents": ["33443d73b7f4fce8af9edf8a414fcb811d4a0b61"], "tags": []}, {"author": "Henry Chang \u003chchang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1388494 - Fix incomplete advisory info issue in about:blocked page. r=francois, a=gchang\n\nThis is a regression caused by bug 1366384 and needed to be uplifted to 56.\nYou will see this issue when \u003cspan id='[reason]_sitename'\u003e is missing\nin the blockedSite.xhtml content. When \u003cspan id=...\u003e is not found,\n\ndocument.getElementById(error + \"_sitename\").textContent\n\nwill throw an exception and the subsequent call to remove blank advisory\ninfo will be failed to remove.\n\nMozReview-Commit-ID: 55umwAegujo", "files": ["browser/base/content/blockedSite.xhtml"], "git_node": null, "git_parents": [null], "node": "5c4087baab4401370982b7ba72eba6426128afa1", "parents": ["743f2fe4e06f7d40f8c02fe197360ed76baadf7e"], "tags": []}, {"author": "Punam \u003cpdahiya@mozilla.com\u003e", "branch": "default", "desc": "Bug 1387153 - Preferences UI to support cloud storage download. r=Gijs, a=lizzard\n\n* Add third radio button to support cloud storage download preference\n* Handle download preferences and UI states, while switching between three options\n* Add method to check if provider is in use in Cloud Storage API\n* Preferences cloud storage strings saved as resource url\n* Updated old in-content with cloud storage pref UI changes\n* Turn cloud storage API on/off using generic pref\n\nMozReview-Commit-ID: AE3MlhgKp2C", "files": ["browser/components/preferences/in-content-new/main.js", "browser/components/preferences/in-content-new/main.xul", "browser/components/preferences/in-content/main.js", "browser/components/preferences/in-content/main.xul", "toolkit/components/cloudstorage/CloudStorage.jsm", "toolkit/components/cloudstorage/content/preferences.properties", "toolkit/components/cloudstorage/tests/unit/test_cloudstorage.js"], "git_node": null, "git_parents": [null], "node": "95e016111eb8d1cf9a4353d4bfc073c13443313f", "parents": ["5c4087baab4401370982b7ba72eba6426128afa1"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1391577 - style: Skip state pseudo-classes when finding a pseudo-element (from emilio:pseudo-crash). r=heycam, a=lizzard\n\nMozReview-Commit-ID: 1ICBijtcf2b\nSource-Repo: https://github.com/servo/servo\nSource-Revision: 4f3fb904ae6863aa86bb3c8b7abee5533478af13", "files": ["servo/components/style/invalidation/element/invalidator.rs"], "git_node": null, "git_parents": [null], "node": "c4306d552f7ae8fb567dc085cf58fb65bc421939", "parents": ["95e016111eb8d1cf9a4353d4bfc073c13443313f"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1391577 - Crashtest. r=heycam, a=lizzard\n\nMozReview-Commit-ID: I8th7nMpwnJ", "files": ["layout/style/crashtests/1391577.html", "layout/style/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "2df535c417bc90ec1256c7d54d8e281bc63180af", "parents": ["c4306d552f7ae8fb567dc085cf58fb65bc421939"], "tags": []}], "date": 1503338539, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7646": {"changesets": [{"author": "Alastor Wu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1388660 - Part 1: AudioData::IsAudible() should return false when its data is super small and near to zero. r=jwwang, a=lizzard\n\nWhen the value of data is too small to be heard, AudioData::IsAudible() should return false so that we won't show the sound indicator for silent media.\n\nIn this case, the loudness of reported video is -673 dBFS, it's impossible to be heard.\n\nMozReview-Commit-ID: Ewiko7RpkeX", "files": ["dom/media/MediaData.cpp"], "git_node": null, "git_parents": [null], "node": "a76b057966b73a0aef16723e37e879ac3d4891a2", "parents": ["2df535c417bc90ec1256c7d54d8e281bc63180af"], "tags": []}, {"author": "Alastor Wu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1388660 - Part 2: Add test. r=Ehsan, a=lizzard\n\nAdd a new file \"almostSilentAudioTrack.webm\" and the test to prevent showing\nthe sound indicator when playing that kinds of video.\n\nMozReview-Commit-ID: CeUhAePBuqs", "files": ["toolkit/content/tests/browser/almostSilentAudioTrack.webm", "toolkit/content/tests/browser/browser.ini", "toolkit/content/tests/browser/browser_sound_indicator_silent_video.js", "toolkit/content/tests/browser/file_almostSilentAudioTrack.html"], "git_node": null, "git_parents": [null], "node": "7a1e28ed93cfcdb9671f45c4f3379cf518c9900a", "parents": ["a76b057966b73a0aef16723e37e879ac3d4891a2"], "tags": []}, {"author": "Daosheng Mu \u003cdaoshengmu@gmail.com\u003e", "branch": "default", "desc": "Bug 1389227 - Avoid accessing invalid array index in vr controllers when stopping vibrate. r=kip, a=lizzard\n\nMozReview-Commit-ID: NR5FLllABm", "files": ["gfx/vr/gfxVROculus.cpp", "gfx/vr/gfxVROpenVR.cpp"], "git_node": null, "git_parents": [null], "node": "b6f681ea1788836f5241586c6319fa8eb75bca37", "parents": ["7a1e28ed93cfcdb9671f45c4f3379cf518c9900a"], "tags": []}, {"author": "Mike Cooper \u003cmcooper@mozilla.com\u003e", "branch": "default", "desc": "Bug 1388823 - Sync shield-recipe-client v65 from GitHub (commit ff1b680c). r=Gijs, a=lizzard\n\nMozReview-Commit-ID: F8uuFRyS4li", "files": ["browser/base/content/test/static/browser_all_files_referenced.js", "browser/extensions/shield-recipe-client/bootstrap.js", "browser/extensions/shield-recipe-client/content/AboutPages.jsm", "browser/extensions/shield-recipe-client/content/about-studies/about-studies.css", "browser/extensions/shield-recipe-client/content/about-studies/about-studies.html", "browser/extensions/shield-recipe-client/content/about-studies/about-studies.js", "browser/extensions/shield-recipe-client/content/about-studies/common.js", "browser/extensions/shield-recipe-client/content/about-studies/img/shield-logo.png", "browser/extensions/shield-recipe-client/content/about-studies/shield-studies.js", "browser/extensions/shield-recipe-client/content/shield-content-frame.js", "browser/extensions/shield-recipe-client/content/shield-content-process.js", "browser/extensions/shield-recipe-client/install.rdf.in", "browser/extensions/shield-recipe-client/jar.mn", "browser/extensions/shield-recipe-client/lib/ActionSandboxManager.jsm", "browser/extensions/shield-recipe-client/li