ts": ["2fc56beba60d733e0e6b8f2b5b8b4c912897ccfd"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset 25aa08f84e10 (bug 1386533) for causing frequent ASAN NS_ERROR_SOCKET_ADDRESS_IN_USE failures across various mochitest-bc tests.", "files": ["toolkit/modules/addons/WebRequest.jsm"], "git_node": null, "git_parents": [null], "node": "667773e6e8c173c6654d529e6e31afddd4659368", "parents": ["5cd93684772685fd5968f008dadf3725dfe47ce4"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset f1084f291de2 (bug 1386333) for Windows ts_paint crashes.", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "57026202f82d42b14c8b4b5a2c2b7035f4a3a215", "parents": ["667773e6e8c173c6654d529e6e31afddd4659368"], "tags": []}], "date": 1502383468, "git_changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "7603": {"changesets": [{"author": "Shane Caraveo \u003cscaraveo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1386533 - Fix host permitted matching. r=kmag, a=lizzard\n\nMozReview-Commit-ID: 81ANT5R1671", "files": ["toolkit/modules/addons/WebRequest.jsm"], "git_node": null, "git_parents": [null], "node": "2638feb177dd9104a3887fae2ce05931a6b41d6c", "parents": ["57026202f82d42b14c8b4b5a2c2b7035f4a3a215"], "tags": ["DEVEDITION_56_0b2_RELEASE", "FIREFOX_56_0b2_BUILD1", "FIREFOX_56_0b2_RELEASE"]}], "date": 1502388347, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "7604": {"changesets": [{"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1388628 - Disable reusing the selected tab for session restore. r=mikedeboer a=sylvestre", "files": ["browser/components/sessionstore/SessionStore.jsm"], "git_node": null, "git_parents": [null], "node": "f7e05dffb1ab4e0b9ed46fa2350c3b5fd4b9efe4", "parents": ["2638feb177dd9104a3887fae2ce05931a6b41d6c"], "tags": []}], "date": 1502455625, "git_changesets": [null], "user": "dgottwald@mozilla.com"}, "7605": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "Automatic version bump. CLOSED TREE NO BUG a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "f6d3f258b0437feecde76f28c0bd9903303f20fc", "parents": ["f7e05dffb1ab4e0b9ed46fa2350c3b5fd4b9efe4"], "tags": []}, {"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging 2638feb177dd9104a3887fae2ce05931a6b41d6c with FIREFOX_56_0b2_BUILD1, FIREFOX_56_0b2_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "7f3005046367008a49b33c00b53eb077451ccca4", "parents": ["f6d3f258b0437feecde76f28c0bd9903303f20fc"], "tags": []}], "date": 1502456967, "git_changesets": [null, null], "user": "ffxbld"}, "7606": {"changesets": [{"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1314670 - Create a new search engine behaviors test to replace the old individual ones. r=florian, a=test-only\n\nMozReview-Commit-ID: HQtFQVxiyvV", "files": ["browser/components/search/test/browser.ini", "browser/components/search/test/browser_ddg_behavior.js", "browser/components/search/test/browser_searchEngine_behaviors.js"], "git_node": null, "git_parents": [null], "node": "ab55f7d014e7d49cc9c3e9bd918f4adeafb74fc5", "parents": ["7f3005046367008a49b33c00b53eb077451ccca4"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1314670 - Rewrite the new search engine behaviors test to use async functionality. r=florian, a=test-only\n\nMozReview-Commit-ID: 396ci4r6ion", "files": ["browser/components/search/test/browser_searchEngine_behaviors.js"], "git_node": null, "git_parents": [null], "node": "cb14f9a3b393cc9435fd1162e0258ad83c85b178", "parents": ["ab55f7d014e7d49cc9c3e9bd