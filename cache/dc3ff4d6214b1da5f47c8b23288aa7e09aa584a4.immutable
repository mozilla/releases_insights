ivatebrowsing_placesTitleNoUpdate.js", "browser/components/privatebrowsing/test/browser/browser_privatebrowsing_placestitle.js"], "git_node": null, "git_parents": [null], "node": "910cb02453eadbf4a5a072d322d406e600266abe", "parents": ["8a2ac486ae2497c16500d6f63bfb588fab212299"], "tags": []}, {"author": "Stone Shih \u003csshih@mozilla.com\u003e", "branch": "default", "desc": "Bug 1292134 - Revise touch-action related test cases to wait for the scroll event to avoid resetting scrollLeft break the following scroll behaviors. r=kats, a=test-only\n\nMozReview-Commit-ID: JidGiZmyzk5", "files": ["dom/events/test/pointerevents/touch_action_helpers.js"], "git_node": null, "git_parents": [null], "node": "87d6a25221a73ab79a41e105f5405fd89d91bb57", "parents": ["910cb02453eadbf4a5a072d322d406e600266abe"], "tags": []}, {"author": "Amy Chung \u003camchung@mozilla.com\u003e", "branch": "default", "desc": "Bug 1376009 - Add mIPCOpen flag and check it before sending IPC messages to the parent. r=jdm, a=gchang", "files": ["netwerk/cookie/CookieServiceChild.cpp", "netwerk/cookie/CookieServiceChild.h"], "git_node": null, "git_parents": [null], "node": "32b050fa7a9bd4b7b7322e113efa978d6613afc9", "parents": ["87d6a25221a73ab79a41e105f5405fd89d91bb57"], "tags": []}, {"author": "Kevin Chen \u003ckechen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1362321 - Do not crash in gfxPlatform:Init if there is a TDR happening. r=bas, a=gchang", "files": ["dom/canvas/CanvasRenderingContext2D.cpp", "gfx/thebes/gfxPlatform.cpp", "gfx/thebes/gfxPlatform.h", "layout/base/PresShell.cpp", "layout/base/nsLayoutUtils.cpp", "layout/generic/nsBulletFrame.cpp", "layout/generic/nsColumnSetFrame.cpp"], "git_node": null, "git_parents": [null], "node": "2baaba7b398c96350ff6ce32fb3235a78be4da9b", "parents": ["32b050fa7a9bd4b7b7322e113efa978d6613afc9"], "tags": []}, {"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 1392757 - Be more resilient for data values we get in Android object navigation. r=yzen, a=gchang", "files": ["accessible/jsat/AccessFu.jsm"], "git_node": null, "git_parents": [null], "node": "e2a6a68b89183e6f2178fbd3e36fc62ca2b1732b", "parents": ["2baaba7b398c96350ff6ce32fb3235a78be4da9b"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1394311 - Use lowercase consistently for looking up the language group. r=manishearth, a=gchang\n\nThis should be the only callee affected, given\ngfxPlatformFontList::GetFontPrefLangFor already uses case-insensitive string\ncomparison.\n\nThis makes it also consistent with the rest of the functions in the file, which\nlowercase their inputs as well.\n\nMozReview-Commit-ID: 4fNUBdpayHL", "files": ["intl/locale/nsLanguageAtomService.cpp"], "git_node": null, "git_parents": [null], "node": "63632d8680a0f966234bcbe8836b12ae00a41cc4", "parents": ["e2a6a68b89183e6f2178fbd3e36fc62ca2b1732b"], "tags": []}, {"author": "Kevin Hsieh \u003ckevin.hsieh@ucla.edu\u003e", "branch": "default", "desc": "Bug 1394762 - Add testcase for Bug 1394311. r=manishearth, a=gchang\n\nMozReview-Commit-ID: 5jAZwRMYoHq", "files": ["layout/reftests/font-matching/1394311-ref.htm", "layout/reftests/font-matching/1394311.htm", "layout/reftests/font-matching/reftest.list"], "git_node": null, "git_parents": [null], "node": "346027fa6dc3beaa9b336a107276fbbd8d175005", "parents": ["63632d8680a0f966234bcbe8836b12ae00a41cc4"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1387889 - Don't pass along metastate of synthesized keys. r=esawin, a=gchang\n\nSome key events synthesized from strings can have modifier metastates.\nFor example, from the sharp S character, we synthesize an S key with Alt\nmetastate. However, we don't actually want to pass the Alt metastate to\nGecko because the Alt meta key is not actually pressed in this case.\n\nMozReview-Commit-ID: 5XYheyAgqdn", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoEditable.java"], "git_node": null, "git_parents": [null], "node": "2b4f305aed0addd8ebc65ba0b4667db9a81754b2", "parents": ["346027fa6dc3beaa9b336a107276fbbd8d175005"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1386787 - Throw for short structured clone reads. r=kanru, a=gchang", "files": ["js/src/vm/StructuredClone.cpp"], "git_node": null, "git_parents": [null], "node": "234a1abc97dd5c39c5ba8fecdee115fcdfbd4520", "parents": ["2b4f305aed0addd8ebc65ba0b4667db9a81754b2"], "tags": []}], "date": 1504105141, "git_changesets": [null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7694": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging 8081a895e4353e807a851485e412ed7a907c0b3f with FENNEC_56_0b7_BUILD1, FENNEC_56_0b7_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "76c905a48281455d562ef5bc32f6b028196bf478", "parents": ["234a1abc97dd5c39c5ba8fecdee115fcdfbd4520"], "tags": []}], "date": 1504134631, "git_changesets": [null], "user": "ffxbld"}, "7695": {"changesets": [{"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1375039 - Enable AWSY for linux64/osx nightly builds. r=bc, a=test-only", "files": ["taskcluster/ci/test/test-platforms.yml"], "git_node": null, "git_parents": [null], "node": "88ba464220c4f79f213ed2fba6af5fc5e76e3455", "parents": ["76c905a48281455d562ef5bc32f6b028196bf478"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1356376 - Wait for message manager to disconnect after closing content page. r=aswan, a=test-only\n\nThis may or may not fix the intermittent, but hopefully it will.\n\nMozReview-Commit-ID: BR0BtV4BPdq", "files": ["toolkit/components/extensions/ExtensionXPCShellUtils.jsm"], "git_node": null, "git_par