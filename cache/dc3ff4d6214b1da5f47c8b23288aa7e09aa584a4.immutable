Overlay.js"], "git_node": null, "git_parents": [null], "node": "5ee15d0b8f882d0f34d4aebd88fdc8bc9fd1316d", "parents": ["5fbb7413a6d4ec3aba41acf456d3efaeed02ce24"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1386937 - Fix typo in initialization check. r=trivial, a=gchang\n\nMozReview-Commit-ID: 7MD79wChHyG", "files": ["toolkit/components/extensions/ExtensionContent.jsm"], "git_node": null, "git_parents": [null], "node": "9aad906a960fc09af929d838d6fbce660f8f3c58", "parents": ["5ee15d0b8f882d0f34d4aebd88fdc8bc9fd1316d"], "tags": []}, {"author": "Eugen Sawin \u003cesawin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1386240 - Check success status when enabling or disabling geolocation events. r=jchen, a=gchang", "files": ["dom/system/android/AndroidLocationProvider.cpp", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoAppShell.java", "widget/android/GeneratedJNIWrappers.cpp", "widget/android/GeneratedJNIWrappers.h"], "git_node": null, "git_parents": [null], "node": "d5f3be22810a35fe32b0f10ff69dccae45ad543d", "parents": ["9aad906a960fc09af929d838d6fbce660f8f3c58"], "tags": []}, {"author": "Jason Laster \u003cjason.laster.11@gmail.com\u003e", "branch": "default", "desc": "Bug 1388128 - Debugger does not remove some breakpoints. r=jdescottes, a=gchang", "files": ["devtools/client/preferences/debugger.js"], "git_node": null, "git_parents": [null], "node": "d4b77eb2881c76a4db4c474892c5d0c2e477370d", "parents": ["d5f3be22810a35fe32b0f10ff69dccae45ad543d"], "tags": []}, {"author": "Liang-Heng Chen \u003cxeonchen@gmail.com\u003e", "branch": "default", "desc": "Bug 1382178 - Check null pointer before using. r=bagder, a=gchang\n\nMozReview-Commit-ID: CjfWL39mYSP", "files": ["netwerk/protocol/http/nsHttpChannel.cpp"], "git_node": null, "git_parents": [null], "node": "8506cad156854901571207236b6ec151eff19606", "parents": ["d4b77eb2881c76a4db4c474892c5d0c2e477370d"], "tags": []}, {"author": "Manish Goregaokar \u003cmanishearth@gmail.com\u003e", "branch": "default", "desc": "Bug 1387953 - Exit early before calling Servo_HasAuthorSpecifiedRules without element data. r=bholley, a=gchang\n\nMozReview-Commit-ID: VrtKytWlcg", "files": ["layout/base/nsPresContext.cpp"], "git_node": null, "git_parents": [null], "node": "8ca8d29fa8ab953ca40bc1fe92c687924be6a234", "parents": ["8506cad156854901571207236b6ec151eff19606"], "tags": []}, {"author": "Daosheng Mu \u003cdaoshengmu@gmail.com\u003e", "branch": "default", "desc": "Bug 1388274 - Adjust WebVR telemetry histogram's high bound for user time spent. r=francois, r=kip, a=gchang\n\nMozReview-Commit-ID: JcQZTgVmxr3", "files": ["dom/vr/VREventObserver.cpp", "gfx/vr/gfxVROculus.cpp", "gfx/vr/gfxVROpenVR.cpp", "toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "3d1029848041f9ed4e73a2c0541f1c62742a20ca", "parents": ["8ca8d29fa8ab953ca40bc1fe92c687924be6a234"], "tags": []}], "date": 1502716070, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7612": {"changesets": [{"author": "James Cheng \u003cjacheng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1390022 - Add Galaxy S4 SPH-L720 model into blacklist for disabling adaptive playback feature. r=jolin, a=sledru\n\nMozReview-Commit-ID: 1UOT759az4S", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/util/HardwareCodecCapabilityUtils.java"], "git_node": null, "git_parents": [null], "node": "b1ef43ea1d84b4d6faaec70fbc9a9c29cd74d1a3", "parents": ["3d1029848041f9ed4e73a2c0541f1c62742a20ca"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1388917 - Fix moving of SelectionState in PlaceholderTransaction's constructor. r=masayuki, a=gchang", "files": ["editor/libeditor/EditorBase.cpp", "editor/libeditor/PlaceholderTransaction.cpp"], "git_node": null, "git_parents": [null], "node": "4f7144901630bea10412fb779dbc7d48340daf0c", "parents": ["b1ef43ea1d84b4d6faaec70fbc9a9c29cd74d1a3"], "tags": []}, {"author": "Ben Kelly \u003cben@wanderview.com\u003e", "branch": "default", "desc": "Bug 1389184 - Avoid crashing in worker MemoryReporter if the GlobalScope is nullptr. r=asuth, a=gchang", "files": ["dom/workers/WorkerPrivate.cpp"], "git_node": null, "git_parents": [null], "node": "ee0bdebf299a39ca18cd8f587363aa9cb5258b14", "parents": ["4f7144901630bea10412fb779dbc7d48340daf0c"], "tags": []}, {"author": "Grigory Kruglov \u003cgkruglov@mozilla.com\u003e", "branch": "default", "desc": "Bug 1381359 - Hide AS Pin Site item from classic Top Sites context menu. r=sebastian, a=gchang\n\nOur home panel context menu is shared by classic top sites, history and bookmark panels.\nFor acitivty stream, we've added a new context menu, and a new type of pins. However,\nold context menu is still used for history and bookmarks. New style of pins allows for\nitems to be pinned from those panels to activity stream. This requires having both \"classic\"\npin buttons for old Top Sites panel, as well as the new AS Pin button.\n\nHowever, initial implementation forgot to disable the new AS Pin button for the classic\nTop Sites panel context menu. This caused two \"pin site\" menu items to appear, and the\nAS one would crash the browser if it's interacted with.\n\nWe'll be unifying context menus at some point, and removing the old Top Sites code,\nand so this simple patch should be sufficient.\n\nMozReview-Commit-ID: 3cxVTv6QP8L", "files": ["mobile/android/base/java/org/mozilla/gecko/home/TopSitesPanel.java"], "git_node": null, "git_parents": [null], "node": "4ae9b45662dd43910885008a1731daa4ff902c95", "parents": ["ee0bdebf299a39ca18cd8f587363aa9cb5258b14"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1388031 - Process normal traversal for throttled animation flush as well. r=bholley, a=gchang\n\nMozReview-Commit-ID: BirD8BDMifp", "files": ["dom/animation/EffectCompositor.cpp", "dom/animation/EffectCompositor.h", "layout/base/ServoRestyleManager.cpp", "layout/style/ServoStyleSet.cpp", "layout/style/ServoStyleSet.h", "layout/style/ServoTypes.h", "servo/ports/geckolib/glue.rs"], "git_node": null, "git_parents": [null], "node": "f3a8d9d0ccc868c06a7c1bebc59b148339f3934d", "parents": ["4ae9b45662dd43910885008a1731daa4ff902c95"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1388031 - Cleanup code that was used for verifying styling results for throttled animation flush in post traversal. r=bholley, a=gchang\n\nNow that we do process normal traversal even in the case of throttled animation\nflush so that we don't need to do special handling for the case.\n\nNote about the comment in has_current_styles():\nthe remaining animation hints is not caused by either this patch or the\nprevious patch in this patch series, it's been there in the first place, but\nit should be fixed somehow later. See bug 1389675.\n\nMozReview-Commit-ID: JojHufxNCiS", "files": ["layout/base/ServoRestyleManager.cpp", "layout/style/ServoBindingList.h", "layout/style/ServoStyleSet.cpp", "layout/style/ServoStyleSet.h", "servo/components/style/dom.rs", "servo/ports/geckolib/glue.rs"], "git_node": null, "git_parents": [null], "node": "4acb479ef69d56c0a3d51850f29ba7c209e3de7b", "parents": ["f3a8d9d0ccc868c06a7c1bebc59b148339f3934d"], "tags": []}, {"author": "Ethan \u003cettseng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1383495 - Spoof Navigator API platform as win64 when resisting fingerprinting is enabled. r=ehsan, a=gchang", "files": ["browser/components/resistfingerprinting/test/browser/browser_navigator.js", "netwerk/protocol/http/nsHttpHandler.cpp", "toolkit/components/resistfingerprinting/nsRFPService.h"], "git_node": null, "git_parents": [null], "node": "428d62670f7e2b8b932e6c784dea847809b233e7", "parents": ["4acb479ef69d56c0a3d51850f29ba7c209e3de7b"], "tags": []}, {"author": "Junior Hsu \u003cjuhsu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1388671 - Add null check to avoid crash. r=jduell, a=gchang", "files": ["netwerk/cookie/nsCookieService.cpp"], "git_node": null, "git_parents": [null], "node": "fc583fa366b03d3f691290293c2e57425f30d23a", "parents": ["428d62670f7e2b8b932e6c784dea847809b233e7"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1389381 - Part 1: Synchronously remove rending responses after aborting them. r=aswan, a=sledru\n\nPending responses are normally removed by the response's promise handlers. But\nsince promise handlers are called asynchronously, multiple calls to\nabortResponses can wind up handling the same already-aborted responses when\ncalled before we process the microtask queue.\n\nMozReview-Commit-ID: 4jy0O7PaoqP", "files": ["toolkit/components/extensions/MessageChannel.jsm"], "git_node": null, "git_parents": [null], "node": "3323f34f84bb5303aeb01dc6dd07d7ccb1abefb4", "parents": ["fc583fa366b03d3f691290293c2e57425f30d23a"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1389381 - Part 2: Add slop to the maximum size of a LimitedSet. r=aswan, a=sledru\n\nTruncating a Set can be relatively expensive, so truncating only after several\nexcessive entries have been added can save some cycles.\n\nMozReview-Commit-ID: DIAXQ3ow2fa", "files": ["toolkit/components/extensions/ExtensionUtils.jsm"], "git_node": null, "git_parents": [null], "node": "ffabdaaebceac4ac77c595703494b6f919d998e8", "parents": ["3323f34f84bb5303aeb01dc6dd07d7ccb1abefb4"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1389381 - Part 3: Loop over the entire set iterator when truncating a LimitedSet. r=aswan, a=sledru\n\nMozReview-Commit-ID: 3imHF9IRI2N", "files": ["toolkit/components/extensions/ExtensionUtils.jsm"], "git_node": null, "git_parents": [null], "node": "b301a9babee6ac845939eb93352988b321b09efd", "parents": ["ffabdaaebceac4ac77c595703494b6f919d998e8"], "tags": []}], "date": 1502720494, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7613": {"changesets": [{"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1390071 - Snap: Add required .desktop file r=mtabara a=release\n\nMozReview-Commit-ID: JtQlswCqZNl", "files": ["taskcluster/docker/firefox-snap/firefox.desktop", "taskcluster/docker/firefox-snap/runme.sh", "taskcluster/docker/firefox-snap/snapcraft.yaml.in"], "git_node": null, "git_parents": [null], "node": "5f81b09432e0f866815ef111c2bc761128adcd53", "parents": ["b301a9babee6ac845939eb93352988b321b09efd"], "tags": []}], "date": 1502723270, "git_changesets": [null], "user": "jlorenzo@mozilla.com"}, "7614": {"changesets": [{"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1390123 - Snap: Automate uploads to Ubuntu Store (edge channel) r=mtabara a=release\n\nMozReview-Commit-ID: 7JVwiUaxk0G", "files": ["taskcluster/docker/firefox-snap/fetch_macaroons.sh", "taskcluster/docker/firefox-snap/runme.sh"], "git_node": null, "git_parents": [null], "node": "32c6671592f98604fe929e86f2a1d52a34b52692", "parents": ["5f81b09432e0f866815ef111c2bc761128adcd53"], "tags": []}], "date": 1502723338, "git_changesets": [null], "user": "jlorenzo@mozilla.com"}, "7615": {"changesets": [{"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1387359 - Add developer toggle to CustomizableUI even if devtools already loaded. r=nchevobbe, a=lizzard\n\nAfter Bug 1359855, the developer toggle is added to CustomizableUI via devtools-startup.\nIt is added after browser-delayed-startup-finished is received. However when starting\ndevtools with --jsconsole, devtools will be initialized before we receive the event and\nthe toggle will never be added to the UI.\n\nIntroducing a new flag here dedicated to the developer toggle and adding a few comments\nto the devtools-startup:hookWindow() method which becomes a bit complex now.\n\nMozReview-Commit-ID: IhPFznt0O83", "files": ["devtools/client/devtools-startup.js"], "git_node": null, "git_parents": [null], "node": "8a94cd4f9c0740240d1a33d0e310d0a1d36901ab", "parents": ["32c6671592f98604fe929e86f2a1d52a34b52692"], "tags": []}, {"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 1385462 - Ensure GlyphRunIterator::NextRun returns false immediately if the textrun's only glyphrun does not have a valid font. r=lsalzman, a=lizzard", "files": ["gfx/thebes/gfxTextRun.cpp"], "git_node": null, "git_parents": [null], "node": "e08775132fa2aa7df8f0d2f35059651a47cc8e94", "parents": ["8a94cd4f9c0740240d1a33d0e310d0a1d36901ab"], "tags": []}, {"author": "Gabor Krizsanits \u003cgkrizsanits@mozilla.com\u003e", "branch": "default", "desc": "Bug 1378207 - Handle sandboxes with XOW protos in WebExtensionChildActor. r=rpl, a=lizzard\n\nSandbox can throw on property access if it does not have permission\nto access its own proto, even if the caller compartment had.", "files": ["devtools/server/actors/webextension.js"], "git_node": null, "git_parents": [null], "node": "ca6af5d8156575a85c8efdb9e11d6d3219e9c988", "parents": ["e08775132fa2aa7df8f0d2f35059651a47cc8e94"], "tags": []}, {"author": "Bobby Holley \u003cbobbyholley@gmail.com\u003e", "branch": "default", "desc": "Bug 1378207 - Stop bypassing the Xray layer when walking the prototype chain. r=krizsa, a=lizzard", "files": ["js/xpconnect/src/XPCJSID.cpp"], "git_node": null, "git_parents": [null], "node": "7ad9e8f27a03af75685299afa5a6a6b3c7777ba4", "parents": ["ca6af5d8156575a85c8efdb9e11d6d3219e9c988"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1380619 - Avoid unnecessary content process leaks in SchedulerGroup dispatch during shutdown. r=mystor, a=lizzard\n\nSchedulerGroup dispatch needs to replicate all the quirks of dispatching\ndirectly to threads, which means we need to handle cases where dispatch\nmight have failed and we have resources that we don't want to leak.", "files": ["xpcom/threads/SchedulerGroup.cpp", "xpcom/threads/SchedulerGroup.h"], "git_node": null, "git_parents": [null], "node": "572e7636edd17841d951f842f52184888138f163", "parents": ["7ad9e8f27a03af75685299afa5a6a6b3c7777ba4"], "tags": []}, {"author": "bechen@mozilla.com \u003cbechen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1385092 - Null check for the sParserWrapper. r=alwu, a=lizzard\n\nFrom the crash report and code logic, it is possible that the KillClearOnShutdown comes and the NS_XPCOM_SHUTDOWN_OBSERVER_ID never comes when getting obsercerService fail.\nSo add null check for the sParserWrapper and combine mShutdown to a new function.\n\nMozReview-Commit-ID: Cj5ph2JrO7v", "files": ["dom/html/TextTrackManager.cpp", "dom/html/TextTrackManager.h"], "git_node": null, "git_parents": [null], "node": "690335e86039d4501232c26aacef86862e89edc2", "parents": ["572e7636edd17841d951f842f52184888138f163"], "tags": []}, {"author": "Ian Bicking \u003cianb@colorstudy.com\u003e", "branch": "default", "desc": "Bug 1388805 - Export Screenshots 10.11.0 to Firefox. r=mossop, a=lizzard\n\nMozReview-Commit-ID: Ik7V2Wd6EOO", "files": ["browser/extensions/screenshots/install.rdf", "browser/extensions/screenshots/moz.build", "browser/extensions/screenshots/webextension/_locales/ach/messages.json", "browser/extensions/screenshots/webextension/_locales/ar/messages.json", "browser/extensions/screenshots/webextension/_locales/az/messages.json", "browser/extensions/screenshots/webextension/_locales/be/messages.json", "browser/extensions/screenshots/webextension/_locales/bg/messages.json", "browser/extensions/screenshots/webextension/_locales/bn_BD/messages.json", "browser/extensions/screenshots/webextension/_lo