ly-l10n/kind.yml"], "git_node": null, "git_parents": [null], "node": "1ec102ceb2da594ca03d8a7af51e11e4900c38eb", "parents": ["60ee1059ee6c76d9dff806aee85bb29bcd20fba0"], "tags": []}], "date": 1501761491, "git_changesets": [null], "user": "jlorenzo@mozilla.com"}, "7570": {"changesets": [{"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1386710 - Increase output timeout for firefox-ui harness invocation from 300s to 1000s. r=maja_zf, a=test-only\n\nThe page load timeout of Marionette is 300s long. By using the same value\nfor the firefox ui harness invocation from mozharness it can cause a race\ncondition. Lets increase the value to what the Marionette jobs use to be\nin sync.\n\nMozReview-Commit-ID: FUevLmRIMSF", "files": ["testing/mozharness/mozharness/mozilla/testing/firefox_ui_tests.py"], "git_node": null, "git_parents": [null], "node": "f404b283003599d33e9ed805fb69f1104a06274c", "parents": ["1ec102ceb2da594ca03d8a7af51e11e4900c38eb"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1386221 - Fix test for inspect binding on 56 beta. r=bgrins, a=test-only\n\nThe test was failing on 56 beta because the new console frontend isn't enabled there and thus\nthe ObjectInspector that were tested not in the old frontend.\nThis patch adds a branch in the test so we can wait for the correct element (VariableView or ObjectInspector)\ndepending on whether the new console frontend is enabled or not.\n\nMozReview-Commit-ID: HGGgr7CWMpe", "files": ["browser/components/extensions/test/browser/browser_ext_devtools_inspectedWindow_eval_bindings.js"], "git_node": null, "git_parents": [null], "node": "04450e033f1ca05de91f3c82293f57d3a0157c95", "parents": ["f404b283003599d33e9ed805fb69f1104a06274c"], "tags": []}, {"author": "Fischer.json \u003cfischer.json@gmail.com\u003e", "branch": "default", "desc": "Bug 1386226 - Perma failure when 56 merges to beta in browser/base/content/test/newtab/browser_newtab_focus.js. r=mossop, a=test-only\n\nThis commit\n\n- Fixes the focus count failure. The bug 1375793 turned on the onboarding on all channels but this test still checks `AppConstants.NIGHTLY_BUILD`. Hence although the onboarding is enabled on Beta, this test thought it is disabled and missed counting the onboarding elements. The solution is to remove `AppConstants.NIGHTLY_BUILD` condition.\n\n- Updates the `promiseTourNotificationOpened` function the same as the bug 1383070 btw\n\nMozReview-Commit-ID: 2TVyqDxMGS6", "files": ["browser/base/content/test/newtab/browser_newtab_focus.js"], "git_node": null, "git_parents": [null], "node": "cc969bb39edc291153d48d299721d48c1b7458ea", "parents": ["04450e033f1ca05de91f3c82293f57d3a0157c95"], "tags": []}, {"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1386246 - Don't expect async stacks in reflow tests. r=Gijs, a=test-only\n\nMozReview-Commit-ID: 490FB5ABU9K", "files": ["browser/base/content/test/performance/browser_windowopen_reflows.js"], "git_node": null, "git_parents": [null], "node": "7fb36f85c030c0faa8025047f7f2a10a9cf2bd24", "parents": ["cc969bb39edc291153d48d299721d48c1b7458ea"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1386412 - Fix race conditions in browser_service_workers_multi_content_process.js. r=ochameau, a=test-only\n\nMozReview-Commit-ID: JnvTkmDrbDo", "files": ["devtools/client/aboutdebugging/test/browser_service_workers_multi_content_process.js"], "git_node": null, "git_parents": [null], "node": "00ead85af43bbd41e35c005252f7e3c6d261560e", "parents": ["7fb36f85c030c0faa8025047f7f2a10a9cf2bd24"], "tags": []}, {"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1386337 - Disable Photon page actions when Photon is not enabled. r=Gijs, a=lizzard\n\nMozReview-Commit-ID: 3GrsscIxeyW", "files": ["browser/base/content/browser-pageActions.js", "browser/modules/PageActions.jsm", "browser/modules/test/browser/browser.ini"], "git_node": null, "git_parents": [null], "node": "4a72eaa119b8f2a0a6eb9012a5f373130ad33e83", "parents": ["00ead85af43bbd41e35c005252f7e3c6d261560e"], "tags": []}, {"author": "Olli Pettay \u003cOlli.Pettay@helsinki.fi\u003e", "branch": "default", "desc": "Bug 1371657 - Ensure editing UI is hidden when disabling editing. r=masayuki, a=ritu", "files": ["editor/libeditor/HTMLEditor.cpp"], "git_node": null, "git_parents": [null], "node": "ffbcc905a80aedaec00a145b8336a1164c9f404a", "parents": ["4a72eaa119b8f2a0a6eb9012a5f373130ad33e83"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1385822 - Don't save new scripts from child process after cache flush. r=erahm, a=jcristau\n\nMozReview-Commit-ID: GKInmHvwVMP", "files": ["js/xpconnect/loader/ScriptPreloader.cpp"], "git_node": null, "git_parents": [null], "node": "f07ddce64e8c9ed9e12d9d38162a9c774d3da127", "parents": ["ffbcc905a80aedaec00a145b8336a1164c9f404a"], "tags": []}, {"author": "Nicholas Hurley \u003churley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1381016 - Ensure we process FIN flags on all-padding final frames. r=swu, a=jcristau\n\nMozReview-Commit-ID: JuSGsYsmv4n", "files": ["netwerk/protocol/http/Http2Session.cpp"], "git_node": null, "git_parents": [null], "node": "5f16075f776817a88e6c853f80bd0720198b345e", "parents": ["f07ddce64e8c9ed9e12d9d38162a9c774d3da127"], "tags": []}, {"author": "Jared Hirsch \u003cohai@6a68.net\u003e", "branch": "default", "desc": "Bug 1386457 - Export Screenshots 10.10.0 to Firefox. r=mossop, a=jcristau\n\nMozReview-Commit-ID: EHo04J8Y2Wu", "files": ["browser/extensions/screenshots/bootstrap.js", "browser/extensions/screenshots/install.rdf", "browser/extensions/screenshots/webextension/manifest.json"], "git_node": null, "git_parents": [null], "node": "4fb347610eaf3ec0d6d29b55b590de060d5cc56f", "parents": ["5f16075f776817a88e6c853f80bd