082c83d0cbe82eb86b8", "parents": ["335fe07a77edada15fcf9f05366aa31a9d2ecc93"], "tags": []}], "date": 1505152823, "git_changesets": [null], "user": "ffxbld"}, "7739": {"changesets": [{"author": "Bas Schouten \u003cbschouten@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397040 - During D3D11TextureData::Create lock the device multithread mutex explicitly when accessing the device. r=mattwoodrow, a=lizzard\n\nMozReview-Commit-ID: Ip1c8jnJE7r", "files": ["gfx/layers/d3d11/TextureD3D11.cpp", "gfx/layers/d3d11/TextureD3D11.h"], "git_node": null, "git_parents": [null], "node": "9d789fc951a7f7bd72514eb841eabf9e5516c83c", "parents": ["ec899e5f6419773cb228e082c83d0cbe82eb86b8"], "tags": []}], "date": 1505152938, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "7740": {"changesets": [{"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1395127 - Fix Skia's AAA to work with even rounding. r=jrmuizel, a=lizzard\n\nMozReview-Commit-ID: FCzINJvD1Md", "files": ["gfx/skia/skia/src/core/SkAnalyticEdge.h", "layout/reftests/border-radius/reftest.list", "layout/reftests/dom/reftest.list", "layout/reftests/forms/input/color/reftest.list"], "git_node": null, "git_parents": [null], "node": "59563d7fc7b6e9067d05fd4c7559f3fb370afbbd", "parents": ["9d789fc951a7f7bd72514eb841eabf9e5516c83c"], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1397223 - Gracefully handle failures in SurfaceCacheImpl::StartTracking. r=tnikkel, a=lizzard\n\nWhen the surface cache starts tracking an unlocked surface, it must\ninsert it into the expiration tracker, so that it can be freed later if\nit is remains unused. ExpirationTrackerImpl::AddObjectLocked can fail\ndue to out-of-memory conditions or during shutdown, which we previously\nignored, and could leave us in a state where we think the surface is in\nthe tracker but is not. When we later try to mark the surface as used in\nthe tracker, it will hit a release assert because it doesn't exist. Now\nwe handle the insertion failure by discarding the surface. Marking the\nsurface as used can itself encounter a similar issue, and we handle it\nthe same way.", "files": ["image/SurfaceCache.cpp"], "git_node": null, "git_parents": [null], "node": "0b5841c7c3992c2c0a43cb77b51b3fd04b63b7d6", "parents": ["59563d7fc7b6e9067d05fd4c7559f3fb370afbbd"], "tags": []}], "date": 1505154870, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "7741": {"changesets": [{"author": "Julien Cristau \u003cjcristau@mozilla.com\u003e", "branch": "default", "desc": "Bug 1268470 - Part 1: Add BLOCK_WIN8_ONLY flag to dll blocklist. r=jimm, a=lizzard\n\nMozReview-Commit-ID: 8ZhqDv4YMOn", "files": ["mozglue/build/WindowsDllBlocklist.cpp"], "git_node": null, "git_parents": [null], "node": "72449a996b0a6f39bd5014651f86260d2d426254", "parents": ["0b5841c7c3992c2c0a43cb77b51b3fd04b63b7d6"], "tags": []}, {"author": "Julien Cristau \u003cjcristau@mozilla.com\u003e", "branch": "default", "desc": "Bug 1268470 - Part 2: Block klsihk64.dll on Windows 8. r=jimm, a=lizzard\n\nMozReview-Commit-ID: B2IrXnr46eP", "files": ["mozglue/build/WindowsDllBlocklist.cpp"], "git_node": null, "git_parents": [null], "node": "2ff31d388767a2815c6bd1df0d381dcc75b78c72", "parents": ["72449a996b0a6f39bd5014651f86260d2d426254"], "tags": []}, {"author": "Julien Cristau \u003cjcristau@mozilla.com\u003e", "branch": "default", "desc": "Bug 1268470 - Part 3: Restrict klsihk64.dll block to versions \u003c 14.0.457.0. r=jimm, a=lizzard\n\nMozReview-Commit-ID: CD7jpcGGr9s", "files": ["mozglue/build/WindowsDllBlocklist.cpp"], "git_node": null, "git_parents": [null], "node": "6bd183fc69218cdbb69a5f9407c69206dade6ae1", "parents": ["2ff31d388767a2815c6bd1df0d381dcc75b78c72"], "tags": ["DEVEDITION_56_0b11_RELEASE", "FENNEC_56_0b11_BUILD1", "FENNEC_56_0b11_RELEASE", "FIREFOX_56_0b11_BUILD1", "FIREFOX_56_0b11_RELEASE"]}], "date": 1505158396, "git_changesets": [null, null, null], "