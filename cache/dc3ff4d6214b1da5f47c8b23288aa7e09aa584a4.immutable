t/reftests/svg/svg-integration/box-decoration-break-02-ref.xhtml", "layout/reftests/svg/svg-integration/box-decoration-break-02.xhtml", "layout/reftests/svg/svg-integration/box-decoration-break-03.xhtml", "layout/reftests/svg/svg-integration/reftest.list"], "git_node": null, "git_parents": [null], "node": "2bd7fc8ce509baf357a1baa0356b1c29d40c4c2e", "parents": ["06894e19fc5bfa67b45e4d9d5e7fd10430ea2271"], "tags": []}, {"author": "Paul Adenot \u003cpaul@paul.cx\u003e", "branch": "default", "desc": "Bug 1388243. r=jesup, a=gchang\n\nMozReview-Commit-ID: Jexghw0QFrB", "files": ["dom/media/GraphDriver.cpp"], "git_node": null, "git_parents": [null], "node": "fb00d84ec8256da72ae02815a7754a2214bf3153", "parents": ["2bd7fc8ce509baf357a1baa0356b1c29d40c4c2e"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1389908 - Make sure the NSColorPanel never has a dangling target, and make sure to set the new target before calling setColor. r=spohl, a=gchang\n\nMozReview-Commit-ID: L71yb593eR2", "files": ["widget/cocoa/nsColorPicker.mm"], "git_node": null, "git_parents": [null], "node": "eb87d01a73ec69c07750e3ac3a554cbda5c39972", "parents": ["fb00d84ec8256da72ae02815a7754a2214bf3153"], "tags": []}, {"author": "maliu \u003cmax@mxli.us\u003e", "branch": "default", "desc": "Bug 1389990 - back out d5210a2cb19a (Bug 1365505 - Part1-Make the feature flag be exposed not only on nightly). r=kikuo, a=gchang\n\nMozReview-Commit-ID: BZfwYV4QUeS", "files": ["mobile/android/moz.configure"], "git_node": null, "git_parents": [null], "node": "f53fa9ca89b98c01ced273b0ad560aca051838ac", "parents": ["eb87d01a73ec69c07750e3ac3a554cbda5c39972"], "tags": []}, {"author": "maliu \u003cmax@mxli.us\u003e", "branch": "default", "desc": "Bug 1389990 - back out 80491c51a8e7 (Bug 1365505 - Part2-Turn on the pref for hls not only on nightly). r=kikuo, a=gchang\n\nMozReview-Commit-ID: 2oMz5RwsV3g", "files": ["mobile/android/app/mobile.js"], "git_node": null, "git_parents": [null], "node": "dc22f52502393f4a216a943d71afc88af5d898c0", "parents": ["f53fa9ca89b98c01ced273b0ad560aca051838ac"], "tags": []}, {"author": "Kate Ustiuzhanina \u003ckustiuzhanina@mozilla.com\u003e", "branch": "default", "desc": "Bug 1390441 - Fix usePingSenderOnShutdown test via reseting TelemetrySend in tests. r=gfritzsche, a=test-only", "files": ["toolkit/components/telemetry/tests/unit/test_TelemetryHealthPing.js"], "git_node": null, "git_parents": [null], "node": "d771f9fdb12ccdad8c40abb517c07c377e9884ac", "parents": ["dc22f52502393f4a216a943d71afc88af5d898c0"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1392700 - Use Mercurial 4.3 in mozharness tests. r=aki, a=test-only\n\nWe use Mercurial 4.3.1 pretty much everywhere in CI now.\nMozharness should be testing with it as well.\n\nMozReview-Commit-ID: HT2rocEvdIe", "files": ["taskcluster/ci/source-test/python-tests.yml", "testing/mozharness/requirements.txt", "testing/mozharness/tox.ini"], "git_node": null, "git_parents": [null], "node": "da38cb67c52b802a0f0a972c68b3a117cee80742", "parents": ["d771f9fdb12ccdad8c40abb517c07c377e9884ac"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1392700 - Initialize repository using latest requirements. r=aki, a=test-only\n\nWe use `hg init` to create the directory. Because this is what\ntypically occurs.\n\nWe also remove the disabling of \"dotencode\" in the hgrc. This was added\nin https://hg.mozilla.org/build/mozharness/rev/b1dbc0f56ff8 (bug 857853)\nfor reasons that are unclear to me. We should never disable dotencode\nbecause it may make some repositories not clonable on Windows\nfilesystems.\n\nDisabling dotencode will also interfere with the latest version of\nrobustcheckout, which requires its presence.\n\nMozReview-Commit-ID: 35qBsgwp0uW", "files": ["testing/mozharness/test/helper_files/.hgrc", "testing/mozharness/test/helper_files/init_hgrepo.sh"], "git_node": null, "git_parents": [null], "node": "dd7757fd49ffb0d1f987dda5438465f7d2e58d18", "parents": ["da38cb67c52b802a0f0a972c68b3a117cee80742"], "tags": []}, {"author": "Gregory Szorc \u003cgps@mozilla.com\u003e", "branch": "default", "desc": "Bug 1392700 - Vendor robustcheckout with capabilities detection. r=glob, a=test-only\n\nThe robustcheckout extension from revision\n134574b64ddfa4d7c31977d792761cceca67665a of the version-control-tools\nrepo is vendored without modifications.\n\nChanges since last time include printing of the Mercurial version and\nmore robust handling repositories not using modern storage\nrequirements.\n\nThis patch was not explicitly reviewed by glob. But glob reviewed all\nthe robustcheckout changes since the last vendor. So by the transitive\nproperty of code review...\n\nMozReview-Commit-ID: CejuVVGpaEy", "files": ["testing/mozharness/external_tools/robustcheckout.py"], "git_node": null, "git_parents": [null], "node": "502bf438bc3b62dca9565edeb6896f7324a9ca75", "parents": ["dd7757fd49ffb0d1f987dda5438465f7d2e58d18"], "tags": []}], "date": 1503489869, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7656": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump\n\nhu -\u003e 2e261b4f4ce8\nro -\u003e feadb219c763", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "df69fdfe00c8621ded6704361095a4eb9b185fc5", "parents": ["502bf438bc3b62dca9565edeb6896f7324a9ca75"], "tags": []}], "date": 1503507626, "git_changesets": [null], "user": "ffxbld"}, "7657": {"changesets": [{"author": "ffxbld \u003crelease@mozilla.com\u003e", "branch": "default", "desc": "No bug - Tagging 86e3368b6058c3a298a6fd973de1313cfe706795 with FENNEC_56_0b5_BUILD1, FENNEC_56_0b5_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "e33b936b6c2e3a26d93f045e772db9c187497ea9", "parents": ["df69fdfe00c8621ded6704361095a4eb9b185fc5"], "tags": []}], "date": 1503511185, "git_changesets": [null], "user": "ffxbld"}, "7658": {"changesets": [{"author": "Matthew Gregan \u003ckinetik@flim.org\u003e", "branch": "default", "desc": "Bug 1386957 - Uplift libcubeb fix for bug 1362764. r=padenot, a=lizzard", "files": ["media/libcubeb/bug1386957.patch", "media/libcubeb/src/cubeb_wasapi.cpp", "media/libcubeb/update.sh"], "git_node": null, "git_parents": [null], "node": "00944b797230fc688374776aea588c6e48f6cc30", "parents": ["e33b936b6c2e3a26d93f045e772db9c187497ea9"], "tags": []}, {"author": "James Cheng \u003cjacheng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1390453 - Don't call VerifyCdmHost_0 in non-official builds. r=cpearce, a=lizzard\n\nMozReview-Commit-ID: 3rzMDq0upBm", "files": ["dom/media/gmp/ChromiumCDMAdapter.cpp", "media/gmp-clearkey/0.1/gmp-clearkey.cpp"], "git_node": null, "git_parents": [null], "node": "553d2a5f53a3da40f55babcd83d239939e0dda5b", "parents": ["00944b797230fc688374776aea588c6e48f6cc30"], "tags": []}, {"author": "James Cheng \u003cjacheng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1390739 - Dispatch the task to main thread if the callback of CDM does not on main thread. r=cpearce, a=lizzard\n\nMozReview-Commit-ID: E5sjEKR4bRQ", "files": ["dom/media/gmp/ChromiumCDMChild.cpp", "dom/media/gmp/ChromiumCDMChild.h"], "git_node": null, "git_parents": [null], "node": "7b56dc8cc01b9d711a011a439dcc5ff48410ab8e", "parents": ["553d2a5f53a3da40f55babcd83d239939e0dda5b"], "tags": []}, {"author": "James Cheng \u003cjacheng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1390725 - Change the loading path of CDM host verification file on Mac. r=cpearce, a=lizzard\n\nThe plugin-container sig file is located in another place.\nNeed to handle it as a special case.\n\nMozReview-Commit-ID: 2e2gbM4CVDG", "files": ["dom/media/gmp/ChromiumCDMAdapter.cpp", "dom/media/gmp/ChromiumCDMAdapter.h", "dom/media/gmp/GMPChild.cpp", "dom/media/gmp/GMPChild.h"], "git_node": null, "git_parents": [null], "node": "c74cd9410e332fb20ebf2f7baab26f1d55ce2fe0", "parents": ["7b56dc8cc01b9d711a011a439dcc5ff48410ab8e"], "tags": []}, {"author": "James Cheng \u003cjacheng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1392175 - Change the loading path of CDM host verification file for XUL and firefox executable x on Mac. r=cpearce, a=lizzard\n\nMozReview-Commit-ID: 2nHrZjDbiQx", "files": ["dom/media/gmp/GMPChild.cpp"], "git_node": null, "git_parents": [null], "node": "eb7887cc44444f8f7e83311c5f63733a81ef55dd", "parents": ["c74cd9410e332fb20ebf2f7baab26f1d55ce2fe0"], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1389021 - Release the compositor thread after CompositorManagerParent IPDL reference is released. r=nical, a=lizzard\n\nWe need to ensure the compositor thread is released but we cannot upon\nfreeing CompositorManagerParent to do that. This is because it needs to\nlive longer than the thread so that shared memory allocated with this\ntop level protocol can be freed after the fact. As such, just release\nthe thread reference after IPDL has released CompositorManagerParent.\n\nMozReview-Commit-ID: 3eVziNDH59f", "files": ["gfx/layers/ipc/CompositorManagerParent.cpp", "gfx/layers/ipc/CompositorManagerParent.h"], "git_node": null, "git_parents": [null], "node": "b08da0b322263480e2a53e78c07bc2845b3d0193", "parents": ["eb7887cc44444f8f7e83311c5f63733a81ef55dd"], "tags": []}, {"author": "Carl Corcoran \u003ccarlco@gmail.com\u003e", "branch": "default", "desc": "Bug 1361410 - Don't hook BaseThreadInitThunk when WRusr.dll is loaded, mitigating a crash. r=dmajor, a=lizzard\n\nMozReview-Commit-ID: KqWq2bHT0CE", "files": ["mozglue/build/WindowsDllBlocklist.cpp"], "git_node": null, "git_parents": [null], "node": "ccd625c4e5f1001a96dc74bc4ee1e8956ad02ea7", "parents": ["b08da0b322263480e2a53e78c07bc2845b3d0193"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1392583 - Remove calls to FATAL() from audio_device_template.h for unimplemented functions. r=padenot, a=lizzard\n\nThis removes calls to FATAL() and replaces them with LOG() statements. The\nunimplemented functions already returned error codes.\n\nMozReview-Commit-ID: KgXVCIKWoLp", "files": ["media/webrtc/trunk/webrtc/modules/audio_device/android/audio_device_template.h"], "git_node": null, "git_parents": [null], "node": "9ea3c346233617a6f769a6bd2e07130d7db9d89f", "parents": ["ccd625c4e5f1001a96dc74bc4ee1e8956ad02ea7"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1282269 - Skip browser_dynamic_tool_enabling.js on Windows debug for permafailing after browser_browser_toolbox_debugger.js was skipped. a=test-only", "files": ["devtools/client/framework/test/browser.ini"], "git_node": null, "git_parents": [null], "node": "d51bedb9d492abba795601298b90a7670b19e228", "parents": ["9ea3c346233617a6f769a6bd2e07130d7db9d89f"], "tags": []}], "date": 1503522691, "git_changesets": [null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7659": {"changesets": [{"author": "Randell Jesup \u003crjesup@jesup.org\u003e", "branch": "default", "desc": "Bug 1374164: guarantee mImage is released by video sources before final-cc shutdown r=padenot,jib a=lizzard\n\nMozReview-Commit-ID: 5pdiqUcps9I", "files": ["dom/media/webrtc/MediaEngineCameraVideoSource.h"], "git_node": null, "git_parents": [null], "node": "84ec3c9fb45645b45ee29ec96877e3c5973cae2b", "parents": ["d51bedb9d492abba795601298b90a7670b19e228"], "tags": []}, {"author": "Randell Jesup \u003crjesup@jesup.org\u003e", "branch": "default", "desc": "Bug 1374164: Clear mImageContainer as well as mImage when stopping a gUM stream r=jib a=lizzard\nAlso removes hiding of mImage/mImageContainer/mMonitor by\nMediaEngineDefault, general cleanup of MediaEngineDefault shutdown, and\nfixing locking around access to protected members.\n\nMozReview-Commit-ID: 2oVttyizTw9", "files": ["dom/media/webrtc/MediaEngineCameraVideoSource.h", "dom/media/webrtc/MediaEngineDefault.cpp", "dom/media/webrtc/MediaEngineDefault.h", "dom/media/webrtc/MediaEngineRemoteVideoSource.cpp"], "git_node": null, "git_parents": [null], "node": "c9f31d1cd425266f7a7440b09dc03e2fb4dcf1de", "parents": ["84ec3c9fb45645b45ee29ec96877e3c5973cae2b"], "tags": []}], "date": 1503533859, "git_changesets": [null, null], "user": "rjesup@wgate.com"}, "7660": {"changesets": [{"author": "Kartikaya Gupta \u003ckgupta@mozilla.com\u003e", "branch": "default", "desc": "Bug 1381435 - Increase the touch_move_tolerance value on desktop, so taps in the tab bar are detected more reliably. r=botond, a=lizzard\n\nMozReview-Commit-ID: DHKsD4EQK3z", "files": ["gfx/thebes/gfxPrefs.h", "mobile/android/app/mobile.js", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "d5a2860a6b133142f2a59525ab9f765fce9c3be1", "parents": ["c9f31d1cd425266f7a7440b09dc03e2fb4dcf1de"], "tags": []}, {"author": "Randall Barker \u003crbarker@mozilla.com\u003e", "branch": "default", "desc": "Bug 1382292 - Revert PLANAR_YCBCR case in GLBlitHelper.cpp on Android so that when a canvas uses a video frame as source, it is not flipped. r=kvark, a=lizzard\n\nMozReview-Commit-ID: 1RZ5G1vkB7U", "files": ["gfx/gl/GLBlitHelper.cpp"], "git_node": null, "git_parents": [null], "node": "0902af3a36150c838b23c5bd1110e1586c9d909f", "parents": ["d5a2860a6b133142f2a59525ab9f765fce9c3be1"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1388129 - Fix interaction between quality scaler and scaleResolutionDownBy. r=jesup, a=lizzard\n\nCurrently we apply the scaleResolutionDownBy factor to the resolution\nrequested by the quality scaler. This can lead to a cycle where the quality\nscaler requests a slightly larger resolution and we scale it down even\nsmaller than the current resolution.\n\nThis changes things so that we only apply scaleResolutionDownBy to the\nincoming resolution and then take the minimum of the scaled resolution and\nthe resolution requested by the quality scaler.", "files": ["media/webrtc/trunk/webrtc/media/base/videoadapter.cc"], "git_node": null, "git_parents": [null], "node": "11a0a65894a4680d910ccfd40f9c58fad136b40a", "parents": ["0902af3a36150c838b23c5bd1110e1586c9d909f"], "tags": []}, {"author": "James Cheng \u003cjacheng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1392976 - Do not assert IsOnMessageLoopThread() in ChromiumCDMChild::GetCurrentWallTime(). r=cpearce, a=lizzard\n\nMozReview-Commit-ID: Je4uTzFtLih", "files": ["dom/media/gmp/ChromiumCDMChild.cpp"], "git_node": null, "git_parents": [null], "node": "c142cf8ec91dd97734f938d77e249ae311f51e98", "parents": ["11a0a65894a4680d910ccfd40f9c58fad136b40a"], "tags": []}], "date": 1503537206, "git_changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "7661": {"changesets": [{"author": "Brian Birtles \u003cbirtles@gmail.com\u003e", "branch": "default", "desc": "Bug 1339648 - Fix flaky file_transitions_replacement_on_busy_frame.html test. r=hiro, a=test-only\n\nThere are two issues with this test:\n\n(a) It fails to flush style when it intends to trigger the first transition.\n\n    Specifically, `getComputedStyle(div)` alone does not flush style. Instead we\n    need `getComputedStyle(div).transform`.\n\n    This patch replaces that line with a call to `div.getAnimations()` which\n    *does* flush style ensuring the first transition is triggered.\n\n(b) It fails to ensure that the first transition has progressed past the first\n    frame on the main thread before triggering the second transition.\n\n    If the first transition is still on its first frame, the computed value of\n    'transform' will be 'matrix(1, 0, 0, 1, 0, 0)'. If we then update the\n    specified value of 'transform' to 'translateX(0px)', no transition will be\n    generated (although the first transition will be canceled) since there is no\n    change.\n\n    This patch fixes that by making the end point of the second transition NOT\n    match the start point of the first transition (and not be somewhere inside\n    the range of the first transition).\n\nAs an extra precautionary measure, to be sure that the animation has started\nprogressing on both the main thread and compositor, this patch alters the\ninitial wait condition for the first transition to also wait on the first\ntransition's ready promise.\n\nMozReview-Commit-ID: E1OJuHBSMfr", "files": ["layout/style/test/file_transitions_replacement_on_busy_frame.html"], "git_node": null, "git_parents": [null], "node": "c0bd0885603f93a6e03eed0e00e786d438565791", "parents": ["c142cf8ec91dd97734f938d77e249ae311f51e98"], "tags": []}, {"author": "Cameron McCormack \u003ccam@mcc.id.au\u003e", "branch": "default", "desc": "Bug 1388113 - Hold on to pseudo-element atoms longer. r=bholley, a=gchang\n\nMozReview-Commit-ID: 98eW8VwVFPT", "files": ["dom/base/nsDOMWindowUtils.cpp", "layout/style/nsCSSPseudoElements.cpp", "layout/style/nsCSSPseudoElements.h"], "git_node": null, "git_parents": [null], "node": "3ff79328db1cd13f1ef5525a111038ee6d47a6ea", "parents": ["c0bd0885603f93a6e03eed0e00e786d438565791"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1381541 - queryCommandState should consider that parent node of selection is null. r=masayuki, a=gchang\n\nWhen parent node of selected node is null, crash might occur in GetCSSBackgroundColorState.  So when parent is null, we should return default value.  In this situation, Edge and Blink don't throw error, Gecko shouldn't return error too.\n\nMozReview-Commit-ID: 5C6jSAFkCso", "files": ["editor/libeditor/HTMLEditor.cpp", "editor/libeditor/crashtests/1381541.html", "editor/libeditor/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "4572266eacb3cff7139a320976f47bbc1a91c449", "parents": ["3ff79328db1cd13f1ef5525a111038ee6d47a6ea"], "tags": []}, {"author": "Andrew Sutherland \u003casutherland@asutherland.org\u003e", "branch": "default", "desc": "Bug 1383518 - Part 2: nsMIMEInputStream should conditionally implement nsIAsyncInputStream. r=bkelly, a=jcristau\n\nNS_AsyncCopy aborts if it receives an NS_BASE_STREAM_WOULD_BLOCK error result\nduring copying and it is unable to QI the source stream to an\nnsIAsyncInputStream.  IPCBlobInputStream can return this, especially if it's:\n- A freshly created aggregate stream as part of form submission of a type=file\n  where the Blob will come from the parent because of the file picker but the\n  stream is being uploaded from the child.\n- A ServiceWorker is involved, causing\n  HttpBaseChannel::EnsureUploadStreamIsCloneable to trigger an NS_AsyncCopy\n  very early in the process.\n\nIPCBlobInputStream implements nsIAsyncInputStream, and nsMultiplexInputStream\ndoes too (conditionally based on its child streams; if any are async, it takes\nstep to uniformly expose async behavior).  However, due to lack of sufficient\ntest coverage, nsMIMEInputStream did not get fixed as part of bug 1361443 when\nnsMultiplexInputStream gained its nsIAsyncInputStream powers.  We address that\nhere in the same fashion.\n\nPart 1 of this series addresses the test coverage issue.", "files": ["netwerk/base/nsMIMEInputStream.cpp"], "git_node": null, "git_parents": [null], "node": "ad3f7419411bb0b8b11b6f00807f08097070a4e6", "parents": ["4572266eacb3cff7139a320976f47bbc1a91c449"], "tags": []}, {"author": "Andrew Sutherland \u003casutherland@asutherland.org\u003e", "branch": "default", "desc": "Bug 1383518 - Part 0: Test whitespace cleanup. r=bkelly, a=jcristau\n\nThis test had trailing whitespace in a number of places, including one spot\ninside a \u003ctextarea\u003e that explicitly had a test expectation against it.\n\nSince it's popular to have text editors purge trailing whitespace, this patch\nconverts the one significant piece of trailing whitespace to use an HTML\nentity to encode a trailing ASCII space character.  This keeps that test happy.", "files": ["dom/html/test/test_formSubmission.html"], "git_node": null, "git_parents": [null], "node": "cd3e78210bf38de9eacf7bcc840de11ebe308611", "parents": ["ad3f7419411bb0b8b11b6f00807f08097070a4e6"], "tags": []}, {"author": "Andrew Sutherland \u003casutherland@asutherland.org\u003e", "branch": "default", "desc": "Bug 1383518 - Part 1: Augment test_formSubmission.html test to include ServiceWorker variants. r=bkelly, a=jcristau\n\nThis test causes the expected serviceworker failure messages in the child\nprocess and then hangs the test.", "files": ["dom/html/test/mochitest.ini", "dom/html/test/sw_formSubmission.js", "dom/html/test/test_formSubmission.html"], "git_node": null, "git_parents": [null], "node": "05183e252fc3ea344360c3f0c95ed5ea02b15503", "parents": ["cd3e78210bf38de9eacf7bcc840de11ebe308611"], "tags": []}], "date": 1503577844, "git_changesets": [null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "7662": {"changesets": [{"author": "Kim Moir \u003ckmoir@mozilla.com\u003e", "branch": "default", "desc": "Bug 1393207 - Mobile Firefox push to Play Store always re-sets the update rate to 10% a=jcristau r=jcristau DONTBUILD", "files": ["taskcluster/taskgraph/util/scriptworker.py"], "git_node": null, "git_parents": [null], "node": "aa85d946916fb694c7f8e0470af299a0b1dd0049", "parents": ["05183e252fc3ea344360c3f0c95ed5ea02b15503"], "tags": []}], "date": 1503590597, "git_changesets": [null], "user": "kmoir@mozilla.com"}, "7663": {"changesets": [{"author": "Julien Cristau \u003cjcristau@mozilla.com\u003e", "branch": "default", "desc": "Post Beta 5: Unset EARLY_BETA_OR_EARLIER. a=jcristau", "files": ["build/defines.sh"], "git_node": null, "git_parents": [null], "node": "0d22b3809fa05faf076bed6b4f03e8f950109446", "parents": ["aa85d946916fb694c7f8e0470af299a0b1dd0049"], "tags": []}], "date": 1503591256, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "7664": {"changesets": [{"author": "Scott Wu \u003cscottcwwu@gmail.com\u003e", "branch": "default", "desc": "Bug 1385813 - [Form Autofill] Set the width of edit address dialog on html markup rather than in css\n\nMozReview-Commit-ID: FtpIt0G76O9", "files": ["browser/extensions/formautofill/content/editAddress.xhtml", "browser/extensions/formautofill/skin/shared/editAddress.css"], "git_node": null, "git_parents": [null], "node": "4a3a57f3f8ccb4f8272256f5481badf6eb6677e9", "parents": ["0d22b3809fa05faf076bed6b4f03e8f950109446"], "tags": []}, {"author": "Luke Chang \u003clchang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1386120 - Flip \"dom.forms.autocomplete.formautofill\" according to the availability of Form Autofill feature. r=MattN, steveck\n\nMozReview-Commit-ID: 3kyDsQL15SO", "files": ["browser/extensions/formautofill/bootstrap.js"], "git_node": null, "git_parents": [null], "node": "105f53375b21d592a65f89f5d661d448f20354c2", "parents": ["4a3a57f3f8ccb4f8272256f5481badf6eb6677e9"], "tags": []}, {"author": "Matthew Noorenberghe \u003cmozilla@noorenberghe.ca\u003e", "branch": "default", "desc": "Bug 1387611 - Delay formautofill system add-on updates until the next restart. r=lchang\n\nMozReview-Commit-ID: 6f4FhTg0KaA", "files": ["browser/extensions/formautofill/bootstrap.js"], "git_node": null, "git_parents": [null], "node": "63ddd74e45786ff2aa6dd84581463932afe75cf7", "parents": ["105f53375b21d592a65f89f5d661d448f20354c2"], "tags": []}, {"author": "Luke Chang \u003clchang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1384185 - [Form Autofill] Fallback to form-history when available values from saved profiles are less than 3. r=steveck\n\nMozReview-Commit-ID: H2EB23IZ9D5", "files": ["browser/extensions/formautofill/FormAutofillContent.jsm", "browser/extensions/formautofill/test/mochitest/fo