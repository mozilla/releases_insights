23c", "git_parents": ["aeb1aa7449e12312457a0a4a3167e671ef40e34e"], "node": "649dab608e1d84779271b24f95786afb93495c24", "parents": ["e78b2937c46aecad67ecd30318a065d3c456f7e0"], "tags": []}], "date": 1778083153, "git_changesets": ["e52136bd560e07443b87077ba05b7bd29250923c"], "user": "dmeehan@mozilla.com"}, "26201": {"changesets": [{"author": "Yury Delendik \u003cydelendik@mozilla.com\u003e", "branch": "default", "desc": "Bug 2035998 - wasm: Fix Module.imports() builtin field check and type counters. r=rhunt a=dmeehan\n\nWasmModuleObject::imports() was using the module-name-only overload of\nImportMatchesBuiltinModule, hiding all wasm:js-string imports including\npolyfill ones (unknown field names). Switch to the two-argument overload\nthat checks both module and field name, consistent with validation and\ninstantiation. Also advance the per-kind type counters for hidden builtin\nimports so that subsequent visible imports reflect the correct type.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297654\n", "files": ["js/src/jit-test/tests/wasm/builtin-modules/js-string/import-reflection.js", "js/src/wasm/WasmJS.cpp"], "git_node": "c92745e030e981dedf2d5a90908d335baa5335da", "git_parents": ["e52136bd560e07443b87077ba05b7bd29250923c"], "node": "350dcb6f9c0ca46ad1224ef590da7c829a2a4148", "parents": ["649dab608e1d84779271b24f95786afb93495c24"], "tags": []}, {"author": "Haik Aftandilian \u003chaftandilian@mozilla.com\u003e", "branch": "default", "desc": "Bug 2036192 - Add profile container App Group to production entitlements for Release and Beta channels r=mac-reviewers,spohl a=dmeehan\n\nAdd the `\u003cteam ID\u003e.org.mozilla.firefox.browserprofiles` app group\nentitlement to the Release and Beta production entitlement lists so that\nRelease and Beta can access the shared container without triggering a\nmacOS permission request. This was added to Nightly with bug 1960091.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297816\n", "files": ["security/mac/hardenedruntime/production/firefox.browser.xml", "security/mac/hardenedruntime/production/firefoxdeveloperedition.browser.xml"], "git_node": "9b94d7257c40e114c45e4ab25e73a35be0f4d934", "git_parents": ["c92745e030e981dedf2d5a90908d335baa5335da"], "node": "0fb72fe8132177dbe5702dcd2afda2c393ae2eec", "parents": ["350dcb6f9c0ca46ad1224ef590da7c829a2a4148"], "tags": []}], "date": 1778083993, "git_changesets": ["c92745e030e981dedf2d5a90908d335baa5335da", "9b94d7257c40e114c45e4ab25e73a35be0f4d934"], "user": "dmeehan@mozilla.com"}, "26202": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging f886be72b68e40ef310bed24350a841eb9ee07e9 with FIREFOX_150_0_2_BUILD2 a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "56595a710702f06f6f11e61a4a3c8bfa40a30c7a", "git_parents": ["83adcdce105f3dd5a8d610529d8f960cb4a9ed52"], "node": "314e11605fa0a8d368b0fdc0853ad155cd8f9ba6", "parents": ["55c7b126786f4f66bce91c8a0a6d9aacc9afed41"], "tags": []}], "date": 1778084566, "git_changesets": ["56595a710702f06f6f11e61a4a3c8bfa40a30c7a"], "user": "ffxbld@lando.moz.tools"}, "26203": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging f886be72b68e40ef310bed24350a841eb9ee07e9 with FIREFOX-ANDROID_150_0_2_BUILD2 a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "7673eee6c3dcd797899e3633d1f74f3f2a9dfa02", "git_parents": ["56595a710702f06f6f11e61a4a3c8bfa40a30c7a"], "node": "b9b7785247e7b04de43f141a42d59dad3f180512", "parents": ["314e11605fa0a8d368b0fdc0853ad155cd8f9ba6"], "tags": []}], "date": 1778085196, "git_changesets": ["7673eee6c3dcd797899e3633d1f74f3f2a9dfa02"], "user": "ffxbld@lando.moz.tools"}, "26204": {"changesets": [{"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 2028758 - Avoid sending cookies for LOAD_DOCUMENT_NEEDS_COOKIE flags inherited to subresources,  a=dmeehan\n\nThese flags were being inherited to subresource loads through the load group's\nmLoadFlags member. This member put in special effort to strip nsIChannel flags\nthanks to nsIRequest::LOAD_REQUESTMASK, but did not strip the new(-er)\n`LOAD_HTML_OBJECT_DATA` and `LOAD_DOCUMENT_NEEDS_COOKIE` flags.\n\nThis meant that when I incorrectly assumed that `LOAD_DOCUMENT_NEEDS_COOKIE`\nimplied `LOAD_DOCUMENT_URI` from how the flag was being set, I started sending\ncookies down for HTML subresource requests as well as for main document\nrequests, likely leading to the performance regression.\n\nThis patch fixes the issue in 2 ways:\n\n1. It re-adds the `LOAD_DOCUMENT_URI` check which had previously avoided this\n   issue (`IsNavigation()`).\n\n2. It updates the mask used for nsLoadGroup flag inheritance to explicitly\n   exclude LOAD_DOCUMENT_NEEDS_COOKIE and LOAD_HTML_OBJECT_DATA, as those flags\n   should not be inherited to subresource requests.\n\nIn addition to the call-site in `nsLoadGroup`, the other user of\nLOAD_REQUESTMASK was also updated, as it appears to be used for image loads\nwhich originate from documents, and should likely also strip the flag.\n\nThe new flag is declared with %{C++ as XPIDL doesn't support `&` or `~`.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D291878\n\nDifferential Revision: https://phabricator.services.mozilla.com/D298880\n", "files": ["image/imgLoader.cpp", "netwerk/base/nsIRequest.idl", "netwerk/base/nsLoadGroup.cpp", "netwerk/protocol/http/HttpChannelParent.cpp"], "git_node": "26469128457aa74be6e96e25a3791b982bafdc68", "git_parents": ["9b94d7257c40e114c45e4ab25e73a35be0f4d934"], "node": "07f4e79476d3e0c053154ac5bb372c388fc8bddd", "parents": ["0fb72fe8132177dbe5702dcd2afda2c393ae2eec"], "tags": []}], "date": 1778090528, "git_changesets": ["26469128457aa74be6e96e25a3791b982bafdc68"], "user": "dmeehan@mozilla.com"}, "26205": {"changesets": [{"author": "scottdowne \u003csdowne@mozilla.com\u003e", "branch": "default", "desc": "Bug 2033625 - Newtab nova fixing widget header text to match content headers  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D297881\n\nDifferential Revision: https://phabricator.services.mozilla.com/D298862\n", "files": ["browser/extensions/newtab/content-src/components/Widgets/_Widgets.scss", "browser/extensions/newtab/css/activity-stream.css", "browser/extensions/newtab/css/nova/activity-stream.css"], "git_node": "0012c8bead3206f5f1b5c91234e8e46457383493", "git_parents": ["26469128457aa74be6e96e25a3791b982bafdc68"], "node": "bd4642ba3bc90d823f7286f2e4bdb2ec9e8a7f3d", "parents": ["07f4e79476d3e0c053154ac5bb372c388fc8bddd"], "tags": []}, {"author": "scottdowne \u003csdowne@mozilla.com\u003e", "branch": "default", "desc": "Bug 2036401 - Newtab nova widgets align with content breakpoints.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D297901\n\nDifferential Revision: https://phabricator.services.mozilla.com/D298865\n", "files": ["browser/extensions/newtab/content-src/components/DiscoveryStreamBase/_DiscoveryStreamBase.scss", "browser/extensions/newtab/content-src/components/Widgets/_Widgets.scss", "browser/extensions/newtab/css/activity-stream.css", "browser/extensions/newtab/css/nova/activity-stream.css"], "git_node": "0c17567dbd9ca8436b418251dc0f0b73878eedee", "git_parents": ["0012c8bead3206f5f1b5c91234e8e46457383493"], "node": "733ffc1a022da9d2d97c1999b78e5d53f36b027b", "parents": ["bd4642ba3bc90d823f7286f2e4bdb2ec9e8a7f3d"], "tags": []}, {"author": "scottdowne \u003csdowne@mozilla.com\u003e", "branch": "default", "desc": "Bug 2037281 - Newtab widget context menu button isn't set properly for contrast fix  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D298705\n\nDifferential Revision: https://phabricator.services.mozilla.com/D298860\n", "files": ["browser/extensions/newtab/content-src/components/Widgets/Widgets.jsx", "browser/extensions/newtab/content-src/components/Widgets/_Widgets.scss", "browser/extensions/newtab/css/activity-stream.css", "browser/extensions/newtab/css/nova/activity-stream.css", "browser/extensions/newtab/data/content/activity-stream.bundle.js"], "git_node": "9c211f94612de8263c9629bab649e117293d32b0", "git_parents": ["0c17567dbd9ca8436b418251dc0f0b73878eedee"], "node": "125217099bc9eda8d6fae41bd4be85f6bd292266", "parents": ["733ffc1a022da9d2d97c1999b78e5d53f36b027b"], "tags": []}], "date": 1778090707, "git_changesets": ["0012c8bead3206f5f1b5c91234e8e46457383493", "0c17567dbd9ca8436b418251dc0f0b73878eedee", "9c211f94612de8263c9629bab649e117293d32b0"], "user": "dmeehan@mozilla.com"}, "26206": {"changesets": [{"author": "Kai Engert \u003ckaie@kuix.de\u003e", "branch": "default", "desc": "Bug 2023572 - NSPR 4.39 RTM, no code change, only version number. r=jcristau UPGRADE_NSPR_RELEASE a=dmeehan DONTBUILD\n\nDifferential Revision: https://phabricator.services.mozilla.com/D298530\n", "files": ["nsprpub/TAG-INFO", "nsprpub/config/prdepend.h", "nsprpub/pr/include/prinit.h"], "git_node": "e74b0b5fbeb7fe960bbd1226694c4607811affc8", "git_parents": ["9c211f94612de8263c9629bab649e117293d32b0"], "node": "8275b0281e6bc89c0cc5c79e893965da7d4c4af6", "parents": ["125217099bc9eda8d6fae41bd4be85f6bd292266"], "tags": []}], "date": 1778108184, "git_changesets": ["e74b0b5fbeb7fe960bbd1226694c4607811affc8"], "user": "dmeehan@mozilla.com"}, "26207": {"changesets": [{"author": "Brad Werth \u003cbwerth@mozilla.com\u003e", "branch": "default", "desc": "Bug 2028081: Block hardware WebGL Linux for old Nvidia drivers.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D297998\n\nDifferential Revision: https://phabricator.services.mozilla.com/D298901\n", "files": ["widget/gtk/GfxInfo.cpp"], "git_node": "d152cacf25b4a8ca3069a5d4ac719642e3e4f390", "git_parents": ["e74b0b5fbeb7fe960bbd1226694c4607811affc8"], "node": "df44ec487301b5a45ec42374464c395ebeac9c7b", "parents": ["8275b0281e6bc89c0cc5c79e893965da7d4c4af6"], "tags": []}], "date": 1778108339, "git_changesets": ["d152cacf25b4a8ca3069a5d4ac719642e3e4f390"], "user": "dmeehan@mozilla.com"}, "26208": {"changesets": [{"author": "Kagami Sascha Rosylight \u003ckrosylight@proton.me\u003e", "branch": "default", "desc": "Bug 2036484 - Grab StrongWorkerRef while calling Permissions::Query  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D298315\n\nDifferential Revision: https://phabricator.services.mozilla.com/D298820\n", "files": ["dom/permission/Permissions.cpp", "testing/web-platform/tests/permissions/crashtests/permissions-query-worker.window.js"], "git_node": "5089e0ba7d26af4c31633911718771c344e4e2dd", "git_parents": ["d152cacf25b4a8ca3069a5d4ac719642e3e4f390"], "node": "1ed4be4e4c719bb1768c18ef7e25c182c323255d", "parents": ["df44ec487301b5a45ec42374464c395ebeac9c7b"], "tags": []}], "date": 1778108391, "git_changesets": ["5089e0ba7d26af4c31633911718771c344e4e2dd"], "user": "dmeehan@mozilla.com"}, "26209": {"changesets": [{"author": "t-p-white \u003ctowhite@mozilla.com\u003e", "branch": "default", "desc": "Bug 2037072 - Don't show the review prompt if the continuous onboarding has not been completed.  a=dmeehan\n\n`ReviewPromptMiddlewareTest` is not updated here because this change requires uplift. The test file was updated in https://bugzilla.mozilla.org/show_bug.cgi?id=2030917 (which added the `kotlin test lib` and updated a number of other test files), and including that update would require a large, potentially complicated set of additional uplifts.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D298531\n\nDifferential Revision: https://phabricator.services.mozilla.com/D298766\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/components/Components.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/reviewprompt/ReviewPromptMiddleware.kt"], "git_node": "89753ba2fb183d904716f1851debb48cea5c9a1e", "git_parents": ["5089e0ba7d26af4c31633911718771c344e4e2dd"], "node": "65cf19eb13f473f3c9dda7ad0f6de6b70ee91ac4", "parents": ["1ed4be4e4c719bb1768c18ef7e25c182c323255d"], "tags": []}], "date": 1778108472, "git_changesets": ["89753ba2fb183d904716f1851debb48cea5c9a1e"], "user": "dmeehan@mozilla.com"}, "26210": {"changesets": [{"author": "Glenn Watson \u003cgit@chillybin.org\u003e", "branch": "default", "desc": "Bug 2036730 - Emit a stable transform fingerprint for perspective-crossing rects in WebRender invalidation.  a=dmeehan\n\nWhen a primitive's 2D rect is mapped through a transform with a\nperspective component such that one or more corners fall at or behind\nthe camera plane (w \u003c= 0), `transform_point2d` returns None for those\ncorners and `compute_to_scratch` returned `VertRange::INVALID`. Two\nframes whose animated transforms both produced INVALID would then\ncompare as equal empty slices in `compare_prim`, silently bypassing\nper-tile invalidation.\n\nFast-path the common no-perspective case via\n`MatrixHelpers::has_perspective_component`. For perspective transforms,\ncompute homogeneous corners and either project them (all `w \u003e 0`) or\npush the homogeneous `(x, y, z, w)` of all four corners as a stable\nper-transform fingerprint when the rect crosses the camera plane.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D298447\n\nDifferential Revision: https://phabricator.services.mozilla.com/D298918\n", "files": ["gfx/wr/webrender/src/invalidation/vert_buffer.rs"], "git_node": "a1cb931e1f78f0250afdf6656b3f56c1630592d4", "git_parents": ["89753ba2fb183d904716f1851debb48cea5c9a1e"], "node": "df7b897600c1654a575f28d15bb8f59799d1e3aa", "parents": ["65cf19eb13f473f3c9dda7ad0f6de6b70ee91ac4"], "tags": []}], "date": 1778109297, "git_changesets": ["a1cb931e1f78f0250afdf6656b3f56c1630592d4"], "user": "dmeehan@mozilla.com"}, "26211": {"changesets": [{"author": "Mike Conley \u003cmike@conley.io\u003e", "branch": "default", "desc": "Bug 2037257 - Add support for AW_EVALUATE_SCREEN_TARGETING and AW_ADD_SCREEN_IMPRESSION to the ASRouter message set for beta 151. r=omc-reviewers,emcminn a=dmeehan\n\nDifferential Revision: https://phabricator.services.mozilla.com/D298856\n", "files": ["browser/components/DesktopActorRegistry.sys.mjs", "browser/components/asrouter/content/asrouter-admin.bundle.js", "browser/components/asrouter/modules/ASRouterParentProcessMessageHandler.sys.mjs", "browser/components/asrouter/modules/ActorConstants.mjs"], "git_node": "fa0572e532363fc72e6c481b4ef066bb0a2481da", "git_parents": ["a1cb931e1f78f0250afdf6656b3f56c1630592d4"], "node": "a2b6b0fa5e0cdbb63f62d50444a0e6623da316af", "parents": ["df7b897600c1654a575f28d15bb8f59799d1e3aa"], "tags": []}], "date": 1778109401, "git_changesets": ["fa0572e532363fc72e6c481b4ef066bb0a2481da"], "user": "dmeehan@mozilla.com"}, "26212": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Import translations from main\n", "files": ["mobile/android/android-components/components/browser/errorpages/src/main/res/values-hu/strings.xml", "mobile/android/android-components/components/feature/downloads/src/main/res/values-hu/strings.xml", "mobile/android/android-components/components/feature/importer/src/main/res/values-ka/strings.xml", "mobile/android/android-components/components/feature/importer/src/main/res/values-tr/strings.xml", "mobile/android/android-components/components/feature/summarize/src/main/res/values-hu/strings.xml", "mobile/android/android-components/components/feature/summarize/src/main/res/values-ru/strings.xml", "mobile/android/fenix/app/src/main/res/values-ar/strings.xml", "mobile/android/fenix/app/src/main/res/values-cs/strings.xml", "mobile/android/fenix/app/src/main/res/values-es-rAR/strings.xml", "mobile/android/fenix/app/src/main/res/values-es-rMX/strings.xml", "mobile/android/fenix/app/src/main/res/values-hu/strings.xml", "mobile/android/fenix/app/src/main/res/values-ka/strings.xml", "mobile/android/