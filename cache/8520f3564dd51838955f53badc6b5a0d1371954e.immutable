e"], "node": "c0a31a1b86e8ad2d8b4994081b42bbaca7a7c6e1", "parents": ["3fd38e2a62a537041fc743c11369bae2ce85a4f1"], "tags": []}], "date": 1777650013, "git_changesets": ["8b10444e2d6321acaf14cf0b3cd3c658ba3d081f"], "user": "ffxbld@lando.moz.tools"}, "26080": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging 4b7a3179cbb188f48af0b5b01419cc489caf2340 with FIREFOX_151_0b5_RELEASE a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "7e1d331bd7b1a323007bcf8c6d07143d0bfafb60", "git_parents": ["8b10444e2d6321acaf14cf0b3cd3c658ba3d081f"], "node": "d2c9434b1c0bd3b3650d616722845a905568ff5a", "parents": ["c0a31a1b86e8ad2d8b4994081b42bbaca7a7c6e1"], "tags": []}], "date": 1777650413, "git_changesets": ["7e1d331bd7b1a323007bcf8c6d07143d0bfafb60"], "user": "ffxbld@lando.moz.tools"}, "26081": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Update configs after merge day operations a=release\n\nIGNORE BROKEN CHANGESETS\nCLOSED TREE\n", "files": ["CLOBBER", "build/defines.sh"], "git_node": "ead7e9e48b2f1cb6361c96d40f0def4502c7920b", "git_parents": ["456736b947590185d0f15f65d12e9badf2eb29d1"], "node": "b448bbb794fcec7747a30110b51dbffa86242ee4", "parents": ["47aaea39432de0f543763f275ca6d655c8bd8102"], "tags": []}], "date": 1777651225, "git_changesets": ["ead7e9e48b2f1cb6361c96d40f0def4502c7920b"], "user": "ffxbld@lando.moz.tools"}, "26082": {"changesets": [{"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 2034352 - Make URL::SearchParams return an already_AddRefed  a=dmeehan\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297262\n", "files": ["dom/url/URL.cpp", "dom/url/URL.h"], "git_node": "00003048bf0cfc1861722dede2f616584a23bc78", "git_parents": ["ead7e9e48b2f1cb6361c96d40f0def4502c7920b"], "node": "7604e2873bf678e287e099cb12a08f40cfd94fa3", "parents": ["b448bbb794fcec7747a30110b51dbffa86242ee4"], "tags": []}], "date": 1777651602, "git_changesets": ["00003048bf0cfc1861722dede2f616584a23bc78"], "user": "dmeehan@mozilla.com"}, "26083": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2035665 - Don't expose UA widgets on openOrClosedShadowRoot to extensions.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D297525\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297606\n", "files": ["dom/base/Element.cpp", "dom/base/Element.h", "dom/webidl/Element.webidl", "toolkit/components/extensions/test/xpcshell/data/file_shadowdom.html", "toolkit/components/extensions/test/xpcshell/test_ext_shadowdom.js"], "git_node": "5257083ea85890b6b88ec9a9e0dbc1df9933f1c8", "git_parents": ["00003048bf0cfc1861722dede2f616584a23bc78"], "node": "80f0240709f2021136daaaaecd71822911083490", "parents": ["7604e2873bf678e287e099cb12a08f40cfd94fa3"], "tags": []}], "date": 1777651654, "git_changesets": ["5257083ea85890b6b88ec9a9e0dbc1df9933f1c8"], "user": "dmeehan@mozilla.com"}, "26084": {"changesets": [{"author": "Michael Hynson \u003cmhynson@mozilla.com\u003e", "branch": "default", "desc": "Bug 2033882 - Update VPN panel loading state.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296782\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297716\n", "files": ["browser/components/ipprotection/content/ipprotection-content.css", "browser/components/ipprotection/content/ipprotection-content.mjs", "browser/components/ipprotection/tests/browser/browser_ipprotection_content.js"], "git_node": "a91e71c82e619820528d239604c0e776879a3db7", "git_parents": ["5257083ea85890b6b88ec9a9e0dbc1df9933f1c8"], "node": "9079d9abf3a620d34c16614ef12c7c22ecc250d3", "parents": ["80f0240709f2021136daaaaecd71822911083490"], "tags": []}], "date": 1777651702, "git_changesets": ["a91e71c82e619820528d239604c0e776879a3db7"], "user": "dmeehan@mozilla.com"}, "26085": {"changesets": [{"author": "Bob Owen \u003cbobowencode@gmail.com\u003e", "branch": "default", "desc": "Bug 2033637.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295654\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297739\n", "files": ["gfx/angle/checkout/src/libANGLE/renderer/d3d/TextureD3D.cpp"], "git_node": "f17b462c3bba6f85dd93df72336289683426ccaf", "git_parents": ["a91e71c82e619820528d239604c0e776879a3db7"], "node": "147ba93c400c916f12ed32deb72b0cd836c0e013", "parents": ["9079d9abf3a620d34c16614ef12c7c22ecc250d3"], "tags": []}], "date": 1777651750, "git_changesets": ["f17b462c3bba6f85dd93df72336289683426ccaf"], "user": "dmeehan@mozilla.com"}, "26086": {"changesets": [{"author": "Harveer Singh \u003chsingh@mozilla.com\u003e", "branch": "default", "desc": "Bug 2025940: skip selecting current origin for eviction under storage pressure.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D297498\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297775\n", "files": ["dom/quota/ActorsParent.cpp"], "git_node": "d2421ead9134d09f0a3e0ea6579abdeefbe2a638", "git_parents": ["f17b462c3bba6f85dd93df72336289683426ccaf"], "node": "0925aab6f349e82a13859bd72750c3f28aecd0a3", "parents": ["147ba93c400c916f12ed32deb72b0cd836c0e013"], "tags": []}], "date": 1777651796, "git_changesets": ["d2421ead9134d09f0a3e0ea6579abdeefbe2a638"], "user": "dmeehan@mozilla.com"}, "26087": {"changesets": [{"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 2035353 - Fix rich search suggestion icon aspect ratios.  a=dmeehan\n\nI'd like to modify `RemoteImageProtocolHandler` so it takes a max dimension and\npreserves the image's aspect ratio, but for now I think we should stop passing a\nwidth and height to it so that it returns images at their native sizes and\naspect ratios. That's not any worse than before bug 2012436 D284071 landed.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D297215\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297804\n", "files": ["browser/components/urlbar/UrlbarUtils.sys.mjs", "toolkit/modules/FaviconUtils.sys.mjs"], "git_node": "91b73973ba4b3a88404d042aff8ae75e31a4b79b", "git_parents": ["d2421ead9134d09f0a3e0ea6579abdeefbe2a638"], "node": "e8798d78b4c448564f1b937f40716809987d3b5f", "parents": ["0925aab6f349e82a13859bd72750c3f28aecd0a3"], "tags": []}], "date": 1777651845, "git_changesets": ["91b73973ba4b3a88404d042aff8ae75e31a4b79b"], "user": "dmeehan@mozilla.com"}, "26088": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2035681 - Tweak how we layout the editor root with placeholder enabled.  a=dmeehan\n\nMake the placeholder overlap the editor root, rather than just\ncollapsing the editor root to 0.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D297622\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297844\n", "files": ["editor/reftests/caret-text-align-end-placeholder-ref.html", "editor/reftests/caret-text-align-end-placeholder.html", "editor/reftests/reftest.list", "layout/style/res/forms.css"], "git_node": "930573daff62c9835c2aa74739a17138acad5fc9", "git_parents": ["91b73973ba4b3a88404d042aff8ae75e31a4b79b"], "node": "d659b7284c77b55b03ea9c79ed4ff02759a4b49b", "parents": ["e8798d78b4c448564f1b937f40716809987d3b5f"], "tags": []}], "date": 1777651893, "git_changesets": ["930573daff62c9835c2aa74739a17138acad5fc9"], "user": "dmeehan@mozilla.com"}, "26089": {"changesets": [{"author": "Emily McMinn \u003cemcminn@mozilla.com\u003e", "branch": "default", "desc": "Bug 2035479 - Fix text colour for FeatureCallout chrome theming  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D297382\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297869\n", "files": ["browser/components/aboutwelcome/content/aboutwelcome.css", "browser/components/asrouter/content-src/styles/_feature-callout.scss"], "git_node": "aed744294e53b7eecc68b058637e55032b99025d", "git_parents": ["930573daff62c9835c2aa74739a17138acad5fc9"], "node": "8f1abf124dcd105b0a3e9396aeb4c83a42a66c54", "parents": ["d659b7284c77b55b03ea9c79ed4ff02759a4b49b"], "tags": []}], "date": 1777652008, "git_changesets": ["aed744294e53b7eecc68b058637e55032b99025d"], "user": "dmeehan@mozilla.com"}, "26090": {"changesets": [{"author": "Dianna Smith \u003cdsmith@mozilla.com\u003e", "branch": "default", "desc": "Bug 2030728 - Downgrade compose-bom to 2026.02.01  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D297626\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297870\n", "files": ["gradle/libs.versions.toml"], "git_node": "a857d587b8bc7552ddea28ed26b6462a51a0763c", "git_parents": ["aed744294e53b7eecc68b058637e55032b99025d"], "node": "39522010a30d969eeb4ef22ef5e70d5b448d1e87", "parents": ["8f1abf124dcd105b0a3e9396aeb4c83a42a66c54"], "tags": []}, {"author": "Ryan VanderMeulen \u003crvandermeulen@mozilla.com\u003e", "branch": "default", "desc": "Bug 2030728 - Add Robolectric repro test for IME OutputTransformation crash.  a=dmeehan\n\nCaptures the BasicTextField InputConnection via InterceptPlatformTextInput\nand drives batched IME calls directly. The targeted test reproduces the\nexact wild crash signature (StringIndexOutOfBoundsException at\nendBatchEdit -\u003e imeDelete -\u003e TextFieldBuffer.replace -\u003e PartialGapBuffer -\u003e\nString.charAt) on Compose Foundation 1.10.5; verified across BOMs:\n\n  BOM 2026.02.01 (Compose 1.10.4): targeted + symmetric tests pass\n  BOM 2026.03.01 (Compose 1.10.5): targeted test fails (wild crash)\n  BOM 2026.04.01 (Compose 1.11.0): all tests pass (upstream fix)\n\nTwo regression tests run against the downgrade BOM. Two additional tests\n(stress + empty-query) are @Ignored because they surface related 1.10.x\nout-of-bounds bugs in setComposition / commit-into-empty paths that 1.11\nalso fixes; they are intended to be re-enabled with the 1.11 bump along\nwith positive final-state assertions on all four tests.\n\nUpstream fix: https://android.googlesource.com/platform/frameworks/support/+/0707c0b\n\nOriginal Revision: https://phabricator.services.mozilla.com/D297700\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297871\n", "files": ["mobile/android/android-components/components/compose/browser-toolbar/src/test/java/mozilla/components/compose/browser/toolbar/ui/OutputTransformationCrashTest.kt"], "git_node": "25b71d1302f7fa7b5249bfd96a190f7af0a9d091", "git_parents": ["a857d587b8bc7552ddea28ed26b6462a51a0763c"], "node": "15ef4f753c8779e3246130784c1fa5c6c68143ac", "parents": ["39522010a30d969eeb4ef22ef5e70d5b448d1e87"], "tags": []}], "date": 1777652059, "git_changesets": ["a857d587b8bc7552ddea28ed26b6462a51a0763c", "25b71d1302f7fa7b5249bfd96a190f7af0a9d091"], "user": "dmeehan@mozilla.com"}, "26091": {"changesets": [{"author": "scottdowne \u003csdowne@mozilla.com\u003e", "branch": "default", "desc": "Bug 2035536 Newtab Nova css switcher to train hop update  a=dmeehan\n\nRight now Nova for newtab cannot be flipped on via trainhop or Nimbus or real time,\nbecause it'll create a startup race condition of both Nova and not Nova newtab.\nIt must ride the trains, and be flipped on via an update.\n\nIn order to enable this we need to deal with the nova css switcher in AboutNewTabChild.sys.mjs.\n\nThis patch is an attempt to safely and minimally move all nova specific css\nin the nova specific stylesheets, into the generic stylesheets,\nand put all the nova specific rules behind a nova-enabled selector.\n\nFor nightly we can keep the pref value in firefox.js because that won't train hop,\nand would still be off by default post train hop, and ready for Nimbus to turn it on.\n\nWe also removed the css switcher in AboutNewTabChild.sys.mjs, which won't train hop,\nbut we kept the old nova css file, so when we train hop onto release,\nthere is still a working reference to that file.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296888\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297883\n", "files": ["browser/actors/AboutNewTabChild.sys.mjs", "browser/extensions/newtab/AGENTS.md", "browser/extensions/newtab/content-src/components/Base/_Grid.scss", "browser/extensions/newtab/content-src/components/Widgets/Weather/_Weather.scss", "browser/extensions/newtab/content-src/styles/activity-stream.scss", "browser/extensions/newtab/content-src/styles/nova/_CardSections.scss", "browser/extensions/newtab/content-src/styles/nova/_tokens.scss", "browser/extensions/newtab/content-src/styles/nova/activity-stream.scss", "browser/extensions/newtab/css/activity-stream.css", "browser/extensions/newtab/css/nova/activity-stream.css"], "git_node": "ce6b0cb805e436e58691faf80287709ca1ed1309", "git_parents": ["25b71d1302f7fa7b5249bfd96a190f7af0a9d091"], "node": "ed3b226a7a6b6db6210137b4587f4dd3022fba4d", "parents": ["15ef4f753c8779e3246130784c1fa5c6c68143ac"], "tags": []}], "date": 1777652109, "git_changesets": ["ce6b0cb805e436e58691faf80287709ca1ed1309"], "user": "dmeehan@mozilla.com"}, "26092": {"changesets": [{"author": "alastor0325 \u003calastor0325@gmail.com\u003e", "branch": "default", "desc": "Bug 2035620 - Part 1: Wait for HDCP readiness after hardware reset before starting encrypted playback. r=media-playback-reviewers,jolin a=dmeehan\n\nWe start an HDCP 2.2 readiness check immediately upon detecting a hardware\nreset and defer starting encrypted playback until the check resolves.\n\nAfter a hardware context reset (e.g. during sleep/resume), HDCP takes time to\nreestablish on the display link even after the GPU recovers. Starting encrypted\nplayback before HDCP is ready causes policy errors that are the major source of\nSL3000 failures in the Netflix error data.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297234\n", "files": ["dom/media/ipc/MFCDMParent.cpp", "dom/media/ipc/MFCDMParent.h", "dom/media/ipc/MFMediaEngineParent.cpp", "dom/media/ipc/MFMediaEngineParent.h"], "git_node": "72e9585699ddc1907b786c01cbdb2cffddd326de", "git_parents": ["ce6b0cb805e436e58691faf80287709ca1ed1309"], "node": "ec22c6200808043ab2d83974910189e39808e624", "parents": ["ed3b226a7a6b6db6210137b4587f4dd3022fba4d"], "tags": []}, {"author": "alastor0325 \u003calastor0325@gmail.com\u003e", "branch": "default", "desc": "Bug 2035620 - Part 2: Treat MF_E_HARDWARE_DRM_UNSUPPORTED as SL3000\u2192SL2000 fallback. r=media-playback-reviewers,jolin a=dmeehan\n\nWe extend the existing hardware DRM fallback to also handle\nMF_E_HARDWARE_DRM_UNSUPPORTED.\n\nThis error is semantically identical to the already-handled\nMSPR_E_NO_DECRYPTOR_AVAILABLE \u2014 both mean hardware DRM is unavailable \u2014 but\nwas previously unhandled, causing affected sessions to loop instead of falling\nback to SL2000.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297235\n", "files": ["dom/media/ipc/MFMediaEngineParent.cpp", "dom/media/ipc/MFMediaEngineUtils.h"], "git_node": "0536ab9f2ae0cf4a360e4ce7d8f2738d11ef2beb", "git_parents": ["72e9585699ddc1907b786c01cbdb2cffddd326de"], "node": "69b7a926a00dbb544fa6b1219bbd2e20822a4a6c", "parents": ["ec22c6200808043ab2d83974910189e39808e624"], "tags": []}, {"author": "Lando \u003clando@lando.moz.tools\u003e", "branch": "default", "desc": "Bug 2035620: apply code formatting via Lando a=dmeehan\n\n# ignore-this-changeset\n", "files": ["dom/media/ipc/MFMediaEngineParent.cpp", "dom/media/ipc/MFMediaEngineUtils.h"], "git_node": "5ddd7607d149b5bd4605bcb1fa386682a34e8ae1", "git_parents": ["0536ab9f2ae0cf4a360e4ce7d8f2738d11ef2beb"], "node": "262b47b0eaeeaa7c371a2a3ec7008783d338f37a", "parents": ["69b7a926a00dbb544fa6b1219bbd2e20822a4a6c"], "tags": []}], "date": 1777652163, "git_changesets": ["72e9585699ddc1907b786c01cbdb2cffddd326de", "0536ab9f2ae0cf4a360e4ce7d8f2738d11ef2beb", "5ddd7607d149b5bd4605bcb1fa386682a34e8ae1"], "user": "dmeehan@mozilla.com"}, "26093": {"changesets": [{"author": "chloezhouny \u003cchloezhouny@gmail.com\u003e", "branch": "default", "desc": "Bug 2032568 - Add HCM/IC styles for smart window panel list  a=dmeehan\n\nFixes invisible text/icons on hover under Windows HCM.\n\nWrap the panel-list and panel-item color overrides (--panel-list-*, --button-background-color-hover/--active, etc.) in @media not (prefers-contrast) so HCM/IC falls through to the toolkit panel-list defaults and the design-system forced-colors values. Also use var(--background-color-box) for the Nova panel background \u2014 same value, but adapts to HCM.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297887\n", "files": ["browser/components/aiwindow/ui/components/smartwindow-panel-list/smartwindow-panel-list.css"], "git_node": "9a179a66934625cf631a05bec32367d2724def06", "git_parents": ["5ddd7607d149b5bd4605bcb1fa386682a34e8ae1"], "node": "adddfd1b4d12ac81462986d3108a5d037202f501", "parents": ["262b47b0eaeeaa7c371a2a3ec7008783d338f37a"], "tags": []}], "date": 1777658150, "git_changesets": ["9a179a66934625cf631a05bec32367d2724def06"], "user": "dmeehan@mozilla.com"}, "26094": {"changesets": [{"author": "kpatenio \u003ckpatenio@mozilla.com\u003e", "branch": "default", "desc": "Bug 2034577 \u2014 fix keyboard navigation for location picker.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D297466\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297893\n", "files": ["browser/base/content/appmenu-viewcache.inc.xhtml", "browser/components/ipprotection/IPProtectionPanel.sys.mjs", "browser/components/ipprotection/tests/browser/browser.toml", "browser/components/ipprotection/tests/browser/browser_ipprotection_keyboard_navigation.js", "browser/components/ipprotection/tests/browser/browser_ipprotection_locations_keyboard_navigation.js", "browser/components/ipprotection/tests/browser/head.js"], "git_node": "c4a05d7745887343e43ec81f4c55b75acdfd140f", "git_parents": ["9a179a66934625cf631a05bec32367d2724def06"], "node": "311ecfdb246064bb4d37ebd633eb01fbbed9b00b", "parents": ["adddfd1b4d12ac81462986d3108a5d037202f501"], "tags": []}, {"author": "kpatenio \u003ckpatenio@mozilla.com\u003e", "branch": "default", "desc": "Bug 2035944 \u2014 add metrics for ipp location picker.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D297531\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297894\n", "files": ["browser/components/ipprotection/IPProtectionPanel.sys.mjs", "browser/components/ipprotection/content/ipprotection-constants.mjs", "browser/components/ipprotection/content/ipprotection-locations.mjs", "browser/components/ipprotection/metrics.yaml", "browser/components/ipprotection/tests/browser/browser.toml", "browser/components/ipprotection/tests/browser/browser_ipprotection_location_selector_telemetry.js", "browser/components/ipprotection/tests/browser/head.js"], "git_node": "2defe43e501b12d48ef6c8d1362e5ed89365aefd", "git_parents": ["c4a05d7745887343e43ec81f4c55b75acdfd140f"], "node": "a239ebc8e56da798b99be49715a8a35d770542b3", "parents": ["311ecfdb246064bb4d37ebd633eb01fbbed9b00b"], "tags": []}], "date": 1777658198, "git_changesets": ["c4a05d7745887343e43ec81f4c55b75acdfd140f", "2defe43e501b12d48ef6c8d1362e5ed89365aefd"], "user": "dmeehan@mozilla.com"}, "26095": {"changesets": [{"author": "DonalMe \u003c76789979+DonalMe@users.noreply.github.com\u003e", "branch": "default", "desc": "Revert \"Bug 2032568 - Add HCM/IC styles for smart window panel list  a=dmeehan\" due to missing custom properties\n\nThis reverts commit 9a179a66934625cf631a05bec32367d2724def06.\n", "files": ["browser/components/aiwindow/ui/components/smartwindow-panel-list/smartwindow-panel-list.css"], "git_node": "958106b1d3125e71877f3a1d2ce1b5d279ab86c6", "git_parents": ["2defe43e501b12d48ef6c8d1362e5ed89365aefd"], "node": "7f1c344cf21