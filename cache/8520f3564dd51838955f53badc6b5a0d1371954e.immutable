n", "toolkit/components/messaging-system/schemas/TriggerActionSchemas/index.md", "toolkit/components/satchel/integrations/FirefoxRelay.sys.mjs"], "git_node": "0766a0f880d22b8ae7427f61f4bd8d70ccd1bf32", "git_parents": ["f9444cdbe719462bbb37acb491360325b4c96fff"], "node": "49b670397d7e1636c56812647d4bafab6dc35189", "parents": ["6345252b3e273cb3e75bc18bb3bf6e9ef1cfe662"], "tags": []}], "date": 1777385413, "git_changesets": ["0766a0f880d22b8ae7427f61f4bd8d70ccd1bf32"], "user": "dmeehan@mozilla.com"}, "25977": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging b927ab3727b38cd272bc154ef37184bc1e6893a6 with FIREFOX_115_35_1esr_RELEASE a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "74d7c1bf681f666ef661bfba283a5492072a1b77", "git_parents": ["841845d19efd6b55477426d24f49395e5553f431"], "node": "95653053673de611eb36e73edd481d846324080e", "parents": ["08cb700615f6cff9c0cf1450e1154cbb3a863604"], "tags": []}], "date": 1777385446, "git_changesets": ["74d7c1bf681f666ef661bfba283a5492072a1b77"], "user": "ffxbld@lando.moz.tools"}, "25978": {"changesets": [{"author": "Jan Grulich \u003cjgrulich@redhat.com\u003e", "branch": "default", "desc": "Bug 2029447 - WebRTC backport: [Pipewire] Fix mouse cursor data race.  a=dmeehan\n\nThis addresses a potential data race when the mouse cursor is updated\non the Pipewire thread and read by the capture thread.\n\nThis is a simple backport of an WebRTC upstream change.\n\nUpstream commit: 90b22181ec922900e26de71463b8e0ed47a5c2dd\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296092\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296639\n", "files": ["third_party/libwebrtc/modules/desktop_capture/linux/wayland/shared_screencast_stream.cc", "third_party/libwebrtc/moz-patch-stack/90b22181ec.no-op-cherry-pick-msg"], "git_node": "db30b87fb072beb58ada4500ce8e3a81dc900970", "git_parents": ["0766a0f880d22b8ae7427f61f4bd8d70ccd1bf32"], "node": "db5480dc32085252fbbe80289c1964ccf630d4ac", "parents": ["49b670397d7e1636c56812647d4bafab6dc35189"], "tags": []}], "date": 1777385595, "git_changesets": ["db30b87fb072beb58ada4500ce8e3a81dc900970"], "user": "dmeehan@mozilla.com"}, "25979": {"changesets": [{"author": "Jan Grulich \u003cjgrulich@redhat.com\u003e", "branch": "default", "desc": "Bug 2029785 - WebRTC backport: Fix use-after-free in ScreenCast and Camera portal D-Bus callbacks  a=dmeehan\n\nGDBus async callbacks fire on the GLib main thread with a raw pointer\nto the portal object. When the portal is destroyed on another thread,\nthe callback accesses freed memory.\n\nIntroduce PortalGuard, a ref-counted mutex-protected wrapper that\noutlives the portal. Callbacks lock the guard and check the portal\npointer before use. Stop() locks the same mutex to null the pointer,\nblocking until any in-flight callback finishes. Utility functions\nnow take scoped_refptr\u003cPortalGuard\u003e and manage refs internally.\n\nThis is a simple backport of an WebRTC upstream change.\n\nUpstream commit: 9dde36ebf937da0ab92837932b253cc3d42c8dc2\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296096\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296640\n", "files": ["third_party/libwebrtc/modules/desktop_capture/linux/wayland/base_capturer_pipewire.cc", "third_party/libwebrtc/modules/desktop_capture/linux/wayland/screen_capture_portal_interface.cc", "third_party/libwebrtc/modules/desktop_capture/linux/wayland/screen_capture_portal_interface.h", "third_party/libwebrtc/modules/desktop_capture/linux/wayland/screencast_portal.cc", "third_party/libwebrtc/modules/desktop_capture/linux/wayland/screencast_portal.h", "third_party/libwebrtc/modules/portal/BUILD.gn", "third_party/libwebrtc/modules/portal/portal_guard.h", "third_party/libwebrtc/modules/portal/xdg_desktop_portal_utils.cc", "third_party/libwebrtc/modules/portal/xdg_desktop_portal_utils.h", "third_party/libwebrtc/modules/video_capture/linux/camera_portal.cc", "third_party/libwebrtc/moz-patch-stack/9dde36ebf9.no-op-cherry-pick-msg"], "git_node": "ce8d5b580c5f5ba63806107ee28b03b7e4ad3f7c", "git_parents": ["db30b87fb072beb58ada4500ce8e3a81dc900970"], "node": "7c44c785746fa4a8a79b81f6e565e4bae57103af", "parents": ["db5480dc32085252fbbe80289c1964ccf630d4ac"], "tags": []}], "date": 1777385646, "git_changesets": ["ce8d5b580c5f5ba63806107ee28b03b7e4ad3f7c"], "user": "dmeehan@mozilla.com"}, "25980": {"changesets": [{"author": "Simon Farre \u003csimon.farre.cx@gmail.com\u003e", "branch": "default", "desc": "Bug 2034329 - Anchor DOMStringList to a specified realm.  a=dmeehan\n\nDOMStringList::GetParentObject() returned nullptr, so FindAssociatedGlobal in\nBindingUtils.h:1845 fell back to JS::CurrentGlobalOrNull(cx), stamping the JS\nwrapper into the first caller's compartment. If an extension content script got\nthere first, subsequent page access required a content\u2192extension CCW, which\nsecurity policy blocks, breaking sites like Gmail.\n\nFix by passing the Document (or inner window) as the DOMStringList parent, so\nFindAssociatedGlobal always anchors the wrapper to the content realm \u2014 the same\nmechanism that makes things like nsContentList immune to this problem.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296198\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296692\n", "files": ["dom/base/DOMStringList.cpp", "dom/base/DOMStringList.h", "dom/base/Document.cpp", "dom/base/Location.cpp", "dom/base/test/browser.toml", "dom/base/test/browser_bug2034329.js", "dom/base/test/file_bug2034329.html"], "git_node": "505b929075786ef7078a3e4ce412525a6d7c7bbc", "git_parents": ["ce8d5b580c5f5ba63806107ee28b03b7e4ad3f7c"], "node": "e1291f95773c640ccd6109e53bffea36fff79e10", "parents": ["7c44c785746fa4a8a79b81f6e565e4bae57103af"], "tags": []}], "date": 1777385754, "git_changesets": ["505b929075786ef7078a3e4ce412525a6d7c7bbc"], "user": "dmeehan@mozilla.com"}, "25981": {"changesets": [{"author": "Tom Schuster \u003ctschuster@mozilla.com\u003e", "branch": "default", "desc": "Bug 2034752 - Revert to ignoring the result of ProcessSecurityHeaders.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296697\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296717\n", "files": ["netwerk/protocol/http/nsHttpChannel.cpp"], "git_node": "6ff680b565ecd027acebf809524eed6cb9cfedcb", "git_parents": ["505b929075786ef7078a3e4ce412525a6d7c7bbc"], "node": "2dc1cc2367ac48fb010b5bf5fdb48d32b1af8223", "parents": ["e1291f95773c640ccd6109e53bffea36fff79e10"], "tags": []}], "date": 1777385802, "git_changesets": ["6ff680b565ecd027acebf809524eed6cb9cfedcb"], "user": "dmeehan@mozilla.com"}, "25982": {"changesets": [{"author": "Max Leonard Inden \u003cmail@max-inden.de\u003e", "branch": "default", "desc": "Bug 2034178 - update to Neqo v0.26.1 in FF v151  a=dmeehan\n\nUpdate to Neqo v0.26.1 more specifically include the following fix.\n\n- fix: gate SCONE Initial padding on connection parameter\n\nSee details in:\n\n- https://github.com/mozilla/neqo/releases/tag/v0.26.1\n- https://github.com/mozilla/neqo/pull/3574\n- https://github.com/mozilla/neqo/pull/3573\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296371\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296730\n", "files": [".cargo/config.toml.in", "Cargo.lock", "netwerk/socket/neqo_glue/Cargo.toml", "netwerk/test/http3server/Cargo.toml", "supply-chain/audits.toml", "third_party/rust/neqo-bin/.cargo-checksum.json", "third_party/rust/neqo-bin/Cargo.toml", "third_party/rust/neqo-common/.cargo-checksum.json", "third_party/rust/neqo-common/Cargo.toml", "third_party/rust/neqo-crypto/.cargo-checksum.json", "third_party/rust/neqo-crypto/Cargo.toml", "third_party/rust/neqo-http3/.cargo-checksum.json", "third_party/rust/neqo-http3/Cargo.toml", "third_party/rust/neqo-qpack/.cargo-checksum.json", "third_party/rust/neqo-qpack/Cargo.toml", "third_party/rust/neqo-transport/.cargo-checksum.json", "third_party/rust/neqo-transport/Cargo.toml", "third_party/rust/neqo-transport/src/connection/mod.rs", "third_party/rust/neqo-transport/src/connection/tests/handshake.rs", "third_party/rust/neqo-udp/.cargo-checksum.json", "third_party/rust/neqo-udp/Cargo.toml"], "git_node": "f7a264eac7681923a6f7556886e442bd1c7f639e", "git_parents": ["6ff680b565ecd027acebf809524eed6cb9cfedcb"], "node": "6e767352c29428efe9a5f9bbe6a4d85908efc1a9", "parents": ["2dc1cc2367ac48fb010b5bf5fdb48d32b1af8223"], "tags": []}], "date": 1777385850, "git_changesets": ["f7a264eac7681923a6f7556886e442bd1c7f639e"], "user": "dmeehan@mozilla.com"}, "25983": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging a24e9e115e02794f72dab9ef6081244403b0183a with FIREFOX_140_10_1esr_RELEASE a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "f1f66506e6d0cd8d6481b9b903fd592edd12c6a3", "git_parents": ["74d7c1bf681f666ef661bfba283a5492072a1b77"], "node": "ebdb3e71f2e0fd54f2fa1fedb079176bccad8e79", "parents": ["95653053673de611eb36e73edd481d846324080e"], "tags": []}], "date": 1777385875, "git_changesets": ["f1f66506e6d0cd8d6481b9b903fd592edd12c6a3"], "user": "ffxbld@lando.moz.tools"}, "25984": {"changesets": [{"author": "Sotaro Ikeda \u003csotaro.ikeda.g@gmail.com\u003e", "branch": "default", "desc": "Bug 2030323 - Add DcompSurfaceDescriptor validity check  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296269\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296865\n", "files": ["gfx/layers/DcompSurfaceImage.cpp", "gfx/layers/ipc/ContentCompositorBridgeParent.cpp"], "git_node": "98b217c52a89ce79bbc08085d48f0cd376c7df3e", "git_parents": ["f7a264eac7681923a6f7556886e442bd1c7f639e"], "node": "97de4181471c7fda865cab763ca2b83f317e6a5b", "parents": ["6e767352c29428efe9a5f9bbe6a4d85908efc1a9"], "tags": []}], "date": 1777386014, "git_changesets": ["98b217c52a89ce79bbc08085d48f0cd376c7df3e"], "user": "dmeehan@mozilla.com"}, "25985": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging 094f3362dcbcefdce34f05b355607cdce06a4ef4 with FIREFOX-ANDROID_150_0_1_RELEASE a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "d4826654755c96910d8d735d90def2f474d9f178", "git_parents": ["f1f66506e6d0cd8d6481b9b903fd592edd12c6a3"], "node": "1f2a5e10893fbe33bb0ff2d942b0cbedb90fa120", "parents": ["ebdb3e71f2e0fd54f2fa1fedb079176bccad8e79"], "tags": []}], "date": 1777386040, "git_changesets": ["d4826654755c96910d8d735d90def2f474d9f178"], "user": "ffxbld@lando.moz.tools"}, "25986": {"changesets": [{"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 2032043 - Cherry-pick commit 1803559c from upstream freetype.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296505\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296950\n", "files": ["modules/freetype2/src/truetype/ttinterp.c"], "git_node": "2bde8ae63aad351a8bb2da0e816662627b369b91", "git_parents": ["98b217c52a89ce79bbc08085d48f0cd376c7df3e"], "node": "a89b6bc6bcb826dd2d4cecbaa77d6815ec65fc02", "parents": ["97de4181471c7fda865cab763ca2b83f317e6a5b"], "tags": []}], "date": 1777386135, "git_changesets": ["2bde8ae63aad351a8bb2da0e816662627b369b91"], "user": "dmeehan@mozilla.com"}, "25987": {"changesets": [{"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 2033850 - Improve policies.json error handling.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295806\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296967\n", "files": ["toolkit/components/enterprisepolicies/EnterprisePoliciesParent.sys.mjs", "toolkit/components/enterprisepolicies/tests/browser/browser_policies_gpo.js"], "git_node": "30cacf35e828c23729ee3c47dd4de8703874543a", "git_parents": ["2bde8ae63aad351a8bb2da0e816662627b369b91"], "node": "ffa397ee8f9beda2c3a61d8372fa2cbecd980abd", "parents": ["a89b6bc6bcb826dd2d4cecbaa77d6815ec65fc02"], "tags": []}], "date": 1777386182, "git_changesets": ["30cacf35e828c23729ee3c47dd4de8703874543a"], "user": "dmeehan@mozilla.com"}, "25988": {"changesets": [{"author": "Jan-Niklas Jaeschke \u003cjjaschke@mozilla.com\u003e", "branch": "default", "desc": "Bug 2031820 - Set custom element namespace prefix after construction per spec.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295601\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296970\n", "files": ["dom/base/CustomElementRegistry.h", "dom/base/nsContentUtils.cpp", "dom/base/nsINode.cpp", "dom/base/nsINode.h", "dom/bindings/BindingUtils.cpp", "testing/web-platform/tests/custom-elements/Document-createElementNS-prefix-timing.html"], "git_node": "5b55ef8ec77946f489c1c074e43e90e8c5128fcb", "git_parents": ["30cacf35e828c23729ee3c47dd4de8703874543a"], "node": "fadf70123adca4e86db24931dfa5d64447c3b739", "parents": ["ffa397ee8f9beda2c3a61d8372fa2cbecd980abd"], "tags": []}], "date": 1777386229, "git_changesets": ["5b55ef8ec77946f489c1c074e43e90e8c5128fcb"], "user": "dmeehan@mozilla.com"}, "25989": {"changesets": [{"author": "Greg Stoll \u003cgstoll@mozilla.com\u003e", "branch": "default", "desc": "Bug 2032631.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295054\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296988\n", "files": ["browser/modules/PermissionUI.sys.mjs", "dom/webserial/PSerialManager.ipdl", "dom/webserial/Serial.cpp", "dom/webserial/Serial.h", "dom/webserial/SerialManagerChild.cpp", "dom/webserial/SerialManagerChild.h", "dom/webserial/SerialManagerParent.cpp", "dom/webserial/SerialManagerParent.h", "dom/webserial/SerialPermissionRequest.cpp", "dom/webserial/SerialPermissionRequest.h", "dom/webserial/SerialPortIPCTypes.h", "dom/webserial/SerialTypes.ipdlh", "dom/webserial/tests/browser/browser_webserial_chooser.js", "dom/webserial/tests/browser/browser_webserial_permission_gated.js", "dom/webserial/tests/mochitest/test_serial_lifecycle.html"], "git_node": "7061f15483f08cacfaa3b7721b18e08d64dd8bc4", "git_parents": ["5b55ef8ec77946f489c1c074e43e90e8c5128fcb"], "node": "dbf238000f6535adb246ace7e5319a27e5a46836", "parents": ["fadf70123adca4e86db24931dfa5d64447c3b739"], "tags": []}], "date": 1777386275, "git_changesets": ["7061f15483f08cacfaa3b7721b18e08d64dd8bc4"], "user": "dmeehan@mozilla.com"}, "25990": {"changesets": [{"author": "Alastor Wu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 2030296 - Part 3: Fix mContentIsHDR to check transfer function, not just pixel format. r=ahale a=dmeehan\n\n10-bit SDR video (e.g. BT.2020 wide color gamut with a standard gamma transfer\nfunction) decodes to P010 format. Previously, mContentIsHDR was set based solely\non pixel format, so any P010 content was unconditionally treated as HDR.\n\nOn HDR monitors (mUseHDR = true), mContentIsHDR drives GetSwapChainFormat() to\nselect an HDR swap chain format (e.g. DXGI_FORMAT_R10G10B10A2_UNORM) and\nGetOutputDXGIColorSpace() to configure the video processor for HDR10 output.\nWhen the source content is actually SDR, GetSourceDXGIColorSpace() correctly\nidentifies the input as G22 (SDR BT.2020) via the transfer function, but the\noutput is still configured for HDR10 due to mContentIsHDR being true. This\nmismatch between the SDR input color space and the HDR output configuration\ncauses incorrect video rendering. The issue does not occur on SDR monitors\nbecause mUseHDR is false there, so the HDR swap chain paths are never taken.\n\nFix by also checking the transfer function: only PQ, HLG, and LINEAR transfer\nfunctions indicate true HDR content. For 10-bit SDR content this means the swap\nchain is created in SDR format (BGRA8), which correctly avoids the HDR processing\npath. Note: this means 10-bit SDR wide color gamut content is rendered at 8-bit\noutput quality rather than 10-bit; properly preserving 10-bit for SDR WCG would\nrequire a distinct swap chain path and is left for future work.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296170\n", "files": ["gfx/webrender_bindings/DCLayerTree.cpp"], "git_node": "c6aa851d9b58e2377409a9fe84a9d770a0456f9a", "git_parents": ["7061f15483f08cacfaa3b7721b18e08d64dd8bc4"], "node": "baef6f7c5e1f0b832fcc2fdf36c69fb6ed457a18", "parents": ["dbf238000f6535adb246ace7e5319a27e5a46836"], "tags": []}, {"author": "Alastor Wu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 2030296 - Part 4: Use VideoInfo color space in ChromiumCDMParent instead of DefaultColorSpace heuristic. r=ahale a=dmeehan\n\nFor Widevine L3 (software CDM), the CDM outputs raw CPU YUV planes and\nChromiumCDMParent::CreateVideoFrame assembles them into a VideoData frame.\nmYUVColorSpace was set via DefaultColorSpace(), which returns BT.601 (\u003c720p)\nor BT.709 (\u003e=720p) based solely on frame height and never returns BT.2020.\n\nFor BT.2020 content this wrong value propagates through YCbCrDescriptor to\nTextureHost::PushDisplayItems, which passes it directly to WebRender's YUV\nshader as the color matrix, causing the wrong matrix to be used for YUV-to-RGB\nconversion. This could cause incorrect colors or visible corruption.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296171\n", "files": ["dom/media/gmp/ChromiumCDMParent.cpp"], "git_node": "959e463dea36eadabaa08a2b45c6390f03e5ec1a", "git_parents": ["c6aa851d9b58e2377409a9fe84a9d770a0456f9a"], "node": "d814de4dbdf21de4280b55f2e286aacee87fa05b", "parents": ["baef6f7c5e1f0b832fcc2fdf36c69fb6ed457a18"], "tags": []}, {"author": "Lando \u003clando@lando.moz.tools\u003e", "branch": "default", "desc": "Bug 2030296: apply code formatting via Lando a=dmeehan\n", "files": ["gfx/webrender_bindings/DCLayerTree.cpp"], "git_node": "039dc1875f99aad0fd806cdce3c95776919c368d", "git_parents": ["959e463dea36eadabaa08a2b45c6390f03e5ec1a"], "node": "76ed570f8ab63620ef9d89ba819a20b69075a828", "parents": ["d814de4dbdf21de4280b55f2e286aacee87fa05b"], "tags": []}], "date": 1777393743, "git_changesets": ["c6aa851d9b58e2377409a9fe84a9d770a0456f9a", "959e463dea36eadabaa08a2b45c6390f03e5ec1a", "039dc1875f99aad0fd806cdce3c95776919c368d"], "user": "dmeehan@mozilla.com"}, "25991": {"changesets": [{"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 2028005.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D291584\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296770\n", "files": ["storage/mozStorageSQLFunctions.cpp"], "git_node": "058ce3963b0abc8500b222dd179363981624a1c2", "git_parents": ["039dc1875f99aad0fd806cdce3c95776919c368d"], "node": "bd24ec897e8754a2f6a18a7097b488a975fb8dfc", "parents": ["76ed570f8ab63620ef9d89ba819a20b69075a828"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 2028005. Part 2.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D291585\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296771\n", "files": ["dom/storage/StorageIPC.cpp"], "git_node": "a018682a4aef7684a09f7391e81b66ba418d092d", "git_parents": ["058ce3963b0abc8500b222dd179363981624a1c2"], "node": "5655b72afe4f7824b1bdb213855cf2e997ff6c9b", "parents": ["bd24ec897e8754a2f6a18a7097b488a975fb8dfc"], "tags": []}], "date": 1777394109, "git_changesets": ["058ce3963b0abc8500b222dd179363981624a1c2", "a018682a4aef7684a09f7391e81b66ba418d092d"], "user": "dmeehan@mozilla.com"}, "25992": {"changesets": [{"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 2029697 - make 'Firefox default browser' image not shift layout by flexing moz-promo and setting a height,  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mo