s": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 2035009 - Fix vertical alignment of migration wizard panel-items.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296932\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297045\n", "files": ["browser/themes/shared/migration/migration-wizard.css"], "git_node": "26476e22cac307b97a6370d29abaf0b92a70b601", "git_parents": ["b0e4bbb49e9550985ccf65a07da6fc7e6d85829f"], "node": "82fa07f846d944e2f59c612bf852119dc7c40e40", "parents": ["f6e7a62d4e2234ade6b88231dc81b402001ade79"], "tags": []}], "date": 1777481728, "git_changesets": ["b0e4bbb49e9550985ccf65a07da6fc7e6d85829f", "26476e22cac307b97a6370d29abaf0b92a70b601"], "user": "dmeehan@mozilla.com"}, "26021": {"changesets": [{"author": "Francesco Lodolo \u003cflod@lodolo.net\u003e", "branch": "default", "desc": "Bug 2035577 - l10n-bumper: set up TaskCluster config for release similar to beta,  a=dmeehan DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D297097\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297119\n", "files": ["taskcluster/kinds/l10n-bump/kind.yml"], "git_node": "bf5b17480953f265efb978600f4fe65728da8063", "git_parents": ["26476e22cac307b97a6370d29abaf0b92a70b601"], "node": "aabda633440bfc3698fd69cd10abdc163d2ce7e5", "parents": ["82fa07f846d944e2f59c612bf852119dc7c40e40"], "tags": []}], "date": 1777481784, "git_changesets": ["bf5b17480953f265efb978600f4fe65728da8063"], "user": "dmeehan@mozilla.com"}, "26022": {"changesets": [{"author": "Mugurell \u003cMugurell@users.noreply.github.com\u003e", "branch": "default", "desc": "Bug 2034336 - Avoid eagerly setting root view insets and rely on insets callback  a=dmeehan\n\nUpon testing we saw that on certain devices (Motorola G85 / Motorola Edge 50 Fusion)\neagerly setting rootView insets and then also in the insets callback can result in them\nbeing applied twice.\n\nReplacing the call to immediately set these insets with a call to request the insets\ncallback be notified will ensure they are set only once - from the insets callback and\nin this will ensure the root view is correctly padded when needed.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296128\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297244\n", "files": ["mobile/android/android-components/components/support/ktx/src/main/java/mozilla/components/support/ktx/android/view/Window.kt"], "git_node": "aef8a7321578f71d7b71fba1890dcb11bde5301c", "git_parents": ["bf5b17480953f265efb978600f4fe65728da8063"], "node": "90d2c171eb1eaedd85c134fd2653b5aa529d751b", "parents": ["aabda633440bfc3698fd69cd10abdc163d2ce7e5"], "tags": []}], "date": 1777481832, "git_changesets": ["aef8a7321578f71d7b71fba1890dcb11bde5301c"], "user": "dmeehan@mozilla.com"}, "26023": {"changesets": [{"author": "Ashley Hale \u003cahale@mozilla.com\u003e", "branch": "default", "desc": "Bug 2028843 - Combine several HDR prefs and add a force_enabled pref  a=dmeehan\n\nWe have quite a collection of prefs that enable HDR video, let's reduce\nthat to gfx.color_management.hdr and add a pref called\ngfx.color_management.hdr.force_enabled for testing HDR rendering code\npaths without an HDR display\n\nOriginal Revision: https://phabricator.services.mozilla.com/D294830\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297232\n", "files": ["gfx/config/gfxConfigManager.cpp", "gfx/layers/NativeLayerCA.mm", "gfx/layers/NativeLayerRemoteMac.mm", "gfx/layers/d3d11/VideoProcessorD3D11.cpp", "gfx/webrender_bindings/DCLayerTree.cpp", "layout/style/nsMediaFeatures.cpp", "modules/libpref/init/StaticPrefList.yaml"], "git_node": "2f5befed701d07482d93fdd55de6b3a7cc1bc7cf", "git_parents": ["aef8a7321578f71d7b71fba1890dcb11bde5301c"], "node": "256b14711901e599dcdd3bcd053f35f5b0b58897", "parents": ["90d2c171eb1eaedd85c134fd2653b5aa529d751b"], "tags": []}], "date": 1777482029, "git_changesets": ["2f5befed701d07482d93fdd55de6b3a7cc1bc7cf"], "user": "dmeehan@mozilla.com"}, "26024": {"changesets": [{"author": "Michael Froman \u003cmjfroman@mac.com\u003e", "branch": "default", "desc": "Bug 2034119 - Vendor libwebrtc from 9970791372 r=dbaker a=dmeehan\n\nUpstream commit: https://webrtc.googlesource.com/src/+/997079137283f693a0fac6a5350ae7f6f2cf3b59\n    [M147] Check vector sizes when crossfading from CNG/expand to normal.\n\n    Original change's description:\n    \u003e Check vector sizes when crossfading from CNG/expand to normal.\n    \u003e\n    \u003e This fixes a potential out-of-bounds write.\n    \u003e\n    \u003e Bug: chromium:502661101\n    \u003e Change-Id: I6f03b522643d7a55040d7f5403f342b32d47f0c7\n    \u003e Reviewed-on: https://webrtc-review.googlesource.com/c/src/+/464500\n    \u003e Commit-Queue: Jakob Ivarsson\u200e \u003cjakobi@webrtc.org\u003e\n    \u003e Reviewed-by: Henrik Lundin \u003chenrik.lundin@webrtc.org\u003e\n    \u003e Cr-Commit-Position: refs/heads/main@{#47447}\n\n    (cherry picked from commit ff1be2e8524fe63069fc2406d5e3f3ddccafee1a)\n\n    Bug: chromium:504499897,chromium:502661101\n    Change-Id: I6f03b522643d7a55040d7f5403f342b32d47f0c7\n    Reviewed-on: https://webrtc-review.googlesource.com/c/src/+/465260\n    Bot-Commit: rubber-stamper@appspot.gserviceaccount.com \u003crubber-stamper@appspot.gserviceaccount.com\u003e\n    Auto-Submit: Chrome Cherry Picker \u003cchrome-cherry-picker@chops-service-accounts.iam.gserviceaccount.com\u003e\n    Commit-Queue: rubber-stamper@appspot.gserviceaccount.com \u003crubber-stamper@appspot.gserviceaccount.com\u003e\n    Cr-Commit-Position: refs/branch-heads/7727@{#11}\n    Cr-Branched-From: 5788235ac856f62f1522d1491c4a8b00dba10c82-refs/heads/main@{#47086}\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295870\n", "files": ["third_party/libwebrtc/README.mozilla.last-vendor", "third_party/libwebrtc/modules/audio_coding/neteq/normal.cc", "third_party/libwebrtc/modules/audio_coding/neteq/normal.h", "third_party/libwebrtc/modules/audio_coding/neteq/normal_unittest.cc"], "git_node": "fef073eee5e09c168a6df593bef124c2c56cb2e0", "git_parents": ["2f5befed701d07482d93fdd55de6b3a7cc1bc7cf"], "node": "bff07a2207626525f16eb32807572a9b6342b373", "parents": ["256b14711901e599dcdd3bcd053f35f5b0b58897"], "tags": []}], "date": 1777482078, "git_changesets": ["fef073eee5e09c168a6df593bef124c2c56cb2e0"], "user": "dmeehan@mozilla.com"}, "26025": {"changesets": [{"author": "Nicolas Silva \u003cnical@fastmail.com\u003e", "branch": "default", "desc": "Bug 2029561 - Stick to f32 for computations in the quad ninepatch path.  a=dmeehan\n\nThis avoids i32 for intermediate calculations with large values (that don't fit in i32) under extreme scale factors. By the time we actually need to use i32 to express the render task size, the rect will have been clipped down to a reasonable screen space value.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296655\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297267\n", "files": ["gfx/wr/webrender/src/quad.rs", "gfx/wr/wrench/reftests/clip/extreme-scale-rounded-rect.yaml", "gfx/wr/wrench/reftests/clip/reftest.list"], "git_node": "ecb0cfcd7a99efb4d2ee5bc3ff052192c3d68451", "git_parents": ["fef073eee5e09c168a6df593bef124c2c56cb2e0"], "node": "8f791b4b056ca35d22946d0ac680c4ed92ea113a", "parents": ["bff07a2207626525f16eb32807572a9b6342b373"], "tags": []}], "date": 1777482126, "git_changesets": ["ecb0cfcd7a99efb4d2ee5bc3ff052192c3d68451"], "user": "dmeehan@mozilla.com"}, "26026": {"changesets": [{"author": "Dave Townsend \u003cdtownsend@oxymoronical.com\u003e", "branch": "default", "desc": "Bug 2029732: Verify that remote data matches the expected format.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296947\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297269\n", "files": ["toolkit/components/remote/nsUnixRemoteServer.cpp"], "git_node": "3789d76dfd3b202cb8d468fc1275fcf99dff2df9", "git_parents": ["ecb0cfcd7a99efb4d2ee5bc3ff052192c3d68451"], "node": "d434a50af669776185d286dde8a8f514c9de87e2", "parents": ["8f791b4b056ca35d22946d0ac680c4ed92ea113a"], "tags": []}], "date": 1777482177, "git_changesets": ["3789d76dfd3b202cb8d468fc1275fcf99dff2df9"], "user": "dmeehan@mozilla.com"}, "26027": {"changesets": [{"author": "Dale Harvey \u003cdale@arandomurl.com\u003e", "branch": "default", "desc": "Bug 2032991 - Enter search mode when installing new engine.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295384\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297273\n", "files": ["browser/components/urlbar/SearchModeSwitcher.sys.mjs", "browser/components/urlbar/tests/browser-searchMode/browser_searchModeSwitcher_opensearchInstall.js"], "git_node": "ffb22e01d0619aedc76b5d9aa54484af181ccec0", "git_parents": ["3789d76dfd3b202cb8d468fc1275fcf99dff2df9"], "node": "9807a3b8ef1cecab9f2c852a8fa1625060f524bd", "parents": ["d434a50af669776185d286dde8a8f514c9de87e2"], "tags": []}], "date": 1777482225, "git_changesets": ["ffb22e01d0619aedc76b5d9aa54484af181ccec0"], "user": "dmeehan@mozilla.com"}, "26028": {"changesets": [{"author": "Timothy Nikkel \u003ctnikkel@gmail.com\u003e", "branch": "default", "desc": "Bug 2035666. Disable libwebp avx2 support temporarily.  a=dmeehan\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297207\n", "files": ["media/libwebp/src/dsp/cpu.h", "media/libwebp/src/dsp/moz.build"], "git_node": "103ca6fa69c19b9402c29ec3c51e267272e0014a", "git_parents": ["ffb22e01d0619aedc76b5d9aa54484af181ccec0"], "node": "e0afe448e9f17a9fcf31f1dd5dcb03188d5c83a6", "parents": ["9807a3b8ef1cecab9f2c852a8fa1625060f524bd"], "tags": []}], "date": 1777482273, "git_changesets": ["103ca6fa69c19b9402c29ec3c51e267272e0014a"], "user": "dmeehan@mozilla.com"}, "26029": {"changesets": [{"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 2034722 - Return a combined capability even when device reports no capabilities.  a=dmeehan\n\nSome legit devices report no capabilities. In such cases we want to\nstart them with the requested capability and wait to see what we get.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296943\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297277\n", "files": ["dom/media/systemservices/CamerasParent.cpp"], "git_node": "e24810dc315be14594527466f3f313148b161838", "git_parents": ["103ca6fa69c19b9402c29ec3c51e267272e0014a"], "node": "e4e071abee0ff3088e714d378e73cc5b9a626669", "parents": ["e0afe448e9f17a9fcf31f1dd5dcb03188d5c83a6"], "tags": []}], "date": 1777482321, "git_changesets": ["e24810dc315be14594527466f3f313148b161838"], "user": "dmeehan@mozilla.com"}, "26030": {"changesets": [{"author": "Jan Grulich \u003cjgrulich@redhat.com\u003e", "branch": "default", "desc": "Bug 2029894 - WebRTC backport: Fix double mapoffset application in PipeWire video capture  a=dmeehan\n\nmmap() with mapoffset as the file offset already returns a pointer to\nthe data at that offset, so passing it again to SPA_MEMBER was reading\nmapoffset bytes past the mapped region. Also queue the buffer back to\nPipeWire before returning on mmap failure to avoid leaking it.\n\nThis is a simple backport of an WebRTC upstream change.\n\nUpstream commit: 9ee59b4ab343540923a23edd6429064c22571c3b\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296761\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297303\n", "files": ["third_party/libwebrtc/modules/video_capture/linux/video_capture_pipewire.cc", "third_party/libwebrtc/moz-patch-stack/9ee59b4ab3.no-op-cherry-pick-msg"], "git_node": "7a3bf67789047ef54ce347f23918d6c3354186eb", "git_parents": ["e24810dc315be14594527466f3f313148b161838"], "node": "77a0a2a8c1bf71006a278ca264eafba948b3d55d", "parents": ["e4e071abee0ff3088e714d378e73cc5b9a626669"], "tags": []}], "date": 1777482566, "git_changesets": ["7a3bf67789047ef54ce347f23918d6c3354186eb"], "user": "dmeehan@mozilla.com"}, "26031": {"changesets": [{"author": "Jan Grulich \u003cjgrulich@redhat.com\u003e", "branch": "default", "desc": "Bug 2029428 - WebRTC backport: Fix signal subscription leak in xdg-desktop-portal callbacks  a=dmeehan\n\nPrevent duplicate signal processing from a misbehaving portal by\nunsubscribing each response signal handler on first invocation.\nAlso unsubscribe the closed signal handler before re-registering.\n\nThis is a simple backport of an WebRTC upstream change.\n\nUpstream commit: 2ba7cce34e86a222c26e7254170cb179066bff5d\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296759\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297305\n", "files": ["third_party/libwebrtc/modules/desktop_capture/linux/wayland/screen_capture_portal_interface.cc", "third_party/libwebrtc/modules/desktop_capture/linux/wayland/screencast_portal.cc", "third_party/libwebrtc/modules/portal/xdg_desktop_portal_utils.cc", "third_party/libwebrtc/modules/portal/xdg_desktop_portal_utils.h", "third_party/libwebrtc/modules/video_capture/linux/camera_portal.cc", "third_party/libwebrtc/moz-patch-stack/2ba7cce34e.no-op-cherry-pick-msg"], "git_node": "ad4d1b6448ac2d5ce259cf3cbe681f76f44868e0", "git_parents": ["7a3bf67789047ef54ce347f23918d6c3354186eb"], "node": "efd3b3c38154b925c680dac7eb2a258a597a7a9f", "parents": ["77a0a2a8c1bf71006a278ca264eafba948b3d55d"], "tags": []}], "date": 1777482701, "git_changesets": ["ad4d1b6448ac2d5ce259cf3cbe681f76f44868e0"], "user": "dmeehan@mozilla.com"}, "26032": {"changesets": [{"author": "Edgar Chen \u003cechen@mozilla.com\u003e", "branch": "default", "desc": "Bug 2034041 - Keyboard Lock should use GetUnretargetedFullscreenElement() to check state;  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295853\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297306\n", "files": ["browser/base/content/test/fullscreen/browser_fullscreen_keyboard_lock_warning.js", "dom/base/Document.cpp", "testing/web-platform/meta/fullscreen/api/document-fullscreen-keyboard-lock-shadowdom.tentative.window.js.ini", "testing/web-platform/tests/fullscreen/api/document-fullscreen-keyboard-lock-shadowdom.tentative.window.js"], "git_node": "003d5fccfc9351554840d2a1deaa5411d4fd62ef", "git_parents": ["ad4d1b6448ac2d5ce259cf3cbe681f76f44868e0"], "node": "0cbe94451ffd41bd3c2a05e37b9d7801a8980064", "parents": ["efd3b3c38154b925c680dac7eb2a258a597a7a9f"], "tags": []}], "date": 1777482774, "git_changesets": ["003d5fccfc9351554840d2a1deaa5411d4fd62ef"], "user": "dmeehan@mozilla.com"}, "26033": {"changesets": [{"author": "Moritz Beier \u003cmbeier@mozilla.com\u003e", "branch": "default", "desc": "Bug 2032973 - Typing something in the urlbar and clicking an engine in the unified search button popup records a urlbar abandonment event.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296368\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297330\n", "files": ["browser/components/urlbar/SearchModeSwitcher.sys.mjs", "browser/components/urlbar/tests/engagementTelemetry/browser/browser.toml", "browser/components/urlbar/tests/engagementTelemetry/browser/browser_glean_telemetry_search_mode_switcher.js"], "git_node": "e84d0e96a1063a21ec4b4e46916cc3353e68afa8", "git_parents": ["003d5fccfc9351554840d2a1deaa5411d4fd62ef"], "node": "a1a08247552f4875978fb50812cea2810b30c845", "parents": ["0cbe94451ffd41bd3c2a05e37b9d7801a8980064"], "tags": []}], "date": 1777482823, "git_changesets": ["e84d0e96a1063a21ec4b4e46916cc3353e68afa8"], "user": "dmeehan@mozilla.com"}, "26034": {"changesets": [{"author": "Harveer Singh \u003chsingh@mozilla.com\u003e", "branch": "default", "desc": "Bug 2025956: WorkerScriptLoader owns its ErrorResult instead of holding a reference.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295907\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297351\n", "files": ["dom/workers/ScriptLoader.cpp", "dom/workers/ScriptLoader.h", "dom/workers/loader/WorkerModuleLoader.cpp"], "git_node": "e58873101a41c246c73467419c9f7771b06120f0", "git_parents": ["e84d0e96a1063a21ec4b4e46916cc3353e68afa8"], "node": "3d3d70f88d31c35b03cd7eacba4b9154196a1c44", "parents": ["a1a08247552f4875978fb50812cea2810b30c845"], "tags": []}], "date": 1777482941, "git_changesets": ["e58873101a41c246c73467419c9f7771b06120f0"], "user": "dmeehan@mozilla.com"}, "26035": {"changesets": [{"author": "Blazer Silving \u003cbreakingspell@gmail.com\u003e", "branch": "default", "desc": "Bug 2034962 - Adjust Tab List View spacing to fit Undo toast  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296836\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297368\n", "files": ["mobile/android/fenix/app/src/main/res/values/dimens.xml"], "git_node": "28d5b953aa579dddf0fbd6fa36ec44cc662b1582", "git_parents": ["e58873101a41c246c73467419c9f7771b06120f0"], "node": "fb455d24ec273a8c188ab26b30d9bc7379880905", "parents": ["3d3d70f88d31c35b03cd7eacba4b9154196a1c44"], "tags": []}], "date": 1777483346, "git_changesets": ["28d5b953aa579dddf0fbd6fa36ec44cc662b1582"], "user": "dmeehan@mozilla.com"}, "26036": {"changesets": [{"author": "Sam Johnson \u003csam@scj.me\u003e", "branch": "default", "desc": "Bug 2035355 - Fix duplicated panel shadow on macOS.  a=dmeehan\n\nAfter bug 1988296, arrowpanels on macOS have a box-shadow applied in addition to the existing native window shadow, which causes an unintentionally dark shadow with some border artifacts. This patch restores the previous behavior by removing the box-shadow.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296869\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297365\n", "files": ["toolkit/themes/shared/popup.css"], "git_node": "549a5ddc3a8464bceaa3ca11ccd4d275f521e4e2", "git_parents": ["28d5b953aa579dddf0fbd6fa36ec44cc662b1582"], "node": "5dfa7d8f252ff95ac8b6456458d524d4600a823a", "parents": ["fb455d24ec273a8c188ab26b30d9bc7379880905"], "tags": []}], "date": 1777483395, "git_changesets": ["549a5ddc3a8464bceaa3ca11ccd4d275f521e4e2"], "user": "dmeehan@mozilla.com"}, "26037": {"changesets": [{"author": "Sam Johnson \u003csam@scj.me\u003e", "branch": "default", "desc": "Bug 2035370 - Disable inner shadow rim for panels on macOS.  a=dmeehan\n\nmacOS Tahoe is a bit more aggressive at applying the window shadow inner rim, and it is being rendered for Firefox panels which weren't receiving it with previous versions of macOS. This makes panel borders effectively have the wrong colors.\n\nThe outer rim was already disabled for panels, so this patch follows suit for the inner rim.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296896\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297362\n", "files": ["widget/cocoa/nsCocoaWindow.mm"], "git_node": "ba4c547e2ef5f394222e4892453ef9ef5e6fc735", "git_parents": ["549a5ddc3a8464bceaa3ca11ccd4d275f521e4e2"], "node": "627d0ec964958dff0e4553c3f6865ec63c2dbaa4", "parents": ["5dfa7d8f252ff95ac8b6456458d524d4600a823a"], "tags": []}], "date": 1777483443, "git_changesets": ["ba4c547e2ef5f394222e4892453ef9ef5e6fc735"], "user": "dmeehan@mozilla.com"}, "26038": {"changesets": [{"author": "Reem H \u003c42309026+reemhamz@users.noreply.github.com\u003e", "branch": "default", "desc": "Bug 2030873 - Nova wallpapers reset functionality.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D294346\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297190\n", "files": ["browser/extensions/newtab/content-src/components/Base/Base.jsx", "browser/extensions/newtab/content-src/components/CustomizeMenu/ContentSection/ContentSection.jsx", "browser/extensions/newtab/content-src/components/CustomizeMenu/CustomizeMenu.jsx", "browser/extensions/newtab/content-src/components/CustomizeMenu/_CustomizeMenu.scss", "browser/extensions/newtab/content-src/components/WallpaperCategories/WallpaperCategories.jsx", "browser/extensions/newtab/css/activity-stream.css", "browser/extensions/newtab/css/nova/activity-stream.css", "browser/extensions/newtab/lib/ActivityStream.sys.mjs", "browser/extensions/newtab/test/jest/content-src/components/CustomizeMenu/ContentSection.test.jsx", "browser/extensions/newtab/test/jest/content-src/components/CustomizeMenu/CustomizeMenu.test.jsx", "browser/extensions/newtab/test/jest/content-src/components/WallpaperCategories/WallpaperCategories.test.jsx", "browser/extensions/newtab/test/unit/content-src/components/Base.test.jsx", "browser/extensions/newtab/test/unit/content-src/components/CustomizeMenu/ContentSection.test.jsx", "browser/extensions/newtab/test/unit/content-src/components/CustomizeMenu/CustomizeMenu.test.jsx"], "git_node": "45035b83dd73db4f2331a5da30bc5c4ddebc5beb", "git_parents": ["ba4c547e2ef5f394222e4892453ef9ef5e6fc735"], "node": "cb110af7b3851a1536bf51b2fa069bc0a8952131", "parents": ["627d0ec964958dff0e4553c3f6865ec63c2dbaa4"], "tags": []}], "date": 1777483530, "git_changesets": ["45035b83dd73db4f2331a5da30bc5c4ddebc5beb"], "user": "dmeehan@mozilla.com"}, "26039": {"changesets": [{"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 2034350 - Show both teams' icons in urlbar sports suggestions.  a=dmeehan\n\nThis changes `RealtimeSuggestProvider` slightly so that subclasses can override\ncreation of the image container rather than the image in the container.\n\n`SportsSuggestions` uses that to create two image containers, one for the home\nteam and one for the away team. Each container is updated independently\naccording to the corresponding team. Then, if both containers end up with the\nsame content (because the suggestion value doesn't include team icons), the\naway-team container is hidden so that we don't show the same thing twice.\n\nCurrently the contents of the image container depend on the suggestion value.\ni.e., if the value has an icon, then `SportsSuggestions` delegates to the base\nclass, and otherwise it creates a date chiclet and doesn't create an `img` at\nall. I found that it became pretty complex to keep that implementation when\ndealing with two image containers, so instead I tried to simplify things by\nalways creating an `img` and date chiclet and then using CSS to hide them as\nappropriate. I ended up rewriting the test because of that, and I removed some\ntasks that I think I added while this feature was initially in development and\nthat I don't think are necessary now.\n\nI verified with the Merino team that `icon` will be present in `home_team` and\n`away_team`, so I removed the check we have for `icon` in the value itself\n(outside the team objects).\n\nThere's a rule in the CSS that shows fallback icons but only for games not in\nthe future. AFAICT from the Figma, that's wrong, and I'm not sure why I did\nthat. The Figma says to show the chiclet \"if the logo can't load.\" So I fixed\nthat too. Now we'll only show a date chiclet if the sport is unrecognized, which\ncan happen on older Firefoxes when Merino serves new sports.\n\nFigma: https://www.figma.com/design/HlHYKdDVCszbbpjuovBDjg/Carrots---S-S-Online-Explorations?node-id=5604-40648&m=dev\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296016\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297204\n", "files": ["browser/components/urlbar/private/RealtimeSuggestProvider.sys.mjs", "browser/components/urlbar/private/SportsSuggestions.sys.mjs", "browser/components/urlbar/tests/quicksuggest/browser/browser.toml", "browser/components/urlbar/tests/quicksuggest/browser/browser_quicksuggest_sports.js", "browser/components/urlbar/tests/quicksuggest/browser/moz-flipped.png", "browser/components/urlbar/tests/quicksuggest/browser/moz.png", "browser/themes/shared/urlbar/view-nova.css", "browser/themes/shared/urlbar/view-proton.css"], "git_node": "849921ff7be6b3e4acd40970d3f6c93ede0b6e64", "git_parents": ["45035b83dd73db4f2331a5da30bc5c4ddebc5beb"], "node": "83e8120c6d21574b85721b5259d37d02f4f4cd00", "parents": ["cb110af7b3851a1536bf51b2fa069bc0a8952131"], "tags": []}, {"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 2035322 - Update urlbar sports suggestions l10n string for scheduled games.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296843\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297205\n", "files": ["browser/components/urlbar/content/enUS-searchFeatures.ftl", "browser/components/urlbar/tests/quicksuggest/browser/browser_quicksuggest_sports.js"], "git_node": "ab66b7a0bc019542f4e798e28889a47fa8b24a02", "git_parents": ["849921ff7be6b3e4acd40970d3f6c93ede0b6e64"], "node": "d80f739a3f84db62d8fb320810afbf6cbc77a62c", "parents": ["83e8120c6d21574b85721b5259d37d02f4f4cd00"], "tags": []}], "date": 1777483736, "git_changesets": ["849921ff7be6b3e4acd40970d3f6c93ede0b6e64", "ab66b7a0bc019542f4e798e28889a47fa8b24a02"], "user": "dmeehan@mozilla.com"}, "26040": {"changesets": [{"author": "Antonio Borondo \u003caborondo@mozilla.com\u003e", "branch": "default", "desc": "Bug 2023696 - Do not install the Desktop Launcher if the installation type is MSI  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D288528\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295567\n", "files": ["browser/installer/windows/nsis/get_installation_type.nsh", "browser/installer/windows/nsis/test_stub.nsi", "browser/installer/windows/nsis/uninstaller_helpers.nsh"], "git_node": "383b35436e5e668c78f7bf5b2018ecb898837718", "git_parents": ["ab66b7a0bc019542f4e798e28889a47fa8b24a02"], "node": "1a4ba08c05ee44b4a76a7217feafde7e757d4c1a", "parents": ["d80f739a3f84db62d8fb320810afbf6cbc77a62c"], "tags": []}, {"author": "Antonio Borondo \u003caborondo@mozilla.com\u003e", "branch": "default", "desc": "Bug 2023696 - If the installation type is full, only install the Desktop Launcher if /DesktopLauncher is passed  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D293855\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295568\n", "files": ["browser/installer/windows/Makefile.in", "browser/installer/windows/nsis/desktop_launcher_helpers.nsh", "browser/installer/windows/nsis/get_installation_type.nsh", "browser/installer/windows/nsis/test_stub.nsi", "browser/installer/windows/nsis/uninstaller_helpers.nsh"], "git_node": "8b39aa5a29fcb678f3093a94f9a6ebd55a082a38", "git_parents": ["383b35436e5e668c78f7bf5b2018ecb898837718"], "node": "e758be697bda690e41d23984afcb66b4c319fd31", "parents": ["1a4ba08c05ee44b4a76a7217feafde7e757d4c1a"], "tags": []}, {"author": "Antonio Borondo \u003caborondo@mozilla.com\u003e", "branch": "default", "desc": "Bug 2023696 - Avoid duplicate desktop shortcuts in single-process updates  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D293856\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295569\n", "files": ["browser/installer/windows/nsis/uninstaller_helpers.nsh"], "git_node": "cd10079d0575ada221f5ad73734bd275b20fc39a", "git_parents": ["8b39aa5a29fcb678f3093a94f9a6ebd55a082a38"], "node": "ce9b826b076c1a0cc2b740c7ea62dabc762a412b", "parents": ["e758be697bda690e41d23984afcb66b4c319fd31"], "tags": []}, {"author": "Antonio Borondo \u003caborondo@mozilla.com\u003e", "branch": "default", "desc": "Bug 2023696 - Add helper functions to manage the enterprise policy flag file  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D293857\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295570\n", "files": ["toolkit/mozapps/update/common/EnterprisePoliciesFlagFile.cpp", "toolkit/mozapps/update/common/EnterprisePoliciesFlagFile.h", "toolkit/mozapps/update/common/moz.build", "toolkit/mozapps/update/tests/gtest/EnterprisePoliciesFlagFileTests.cpp", "toolkit/mozapps/update/tests/gtest/TestDirHelpers.cpp", "toolkit/mozapps/update/tests/gtest/TestDirHelpers.h", "toolkit/mozapps/update/tests/gtest/moz.build", "toolkit/mozapps/update/tests/moz.build"], "git_node": "3ba1fbaa3908b1f93d570f533962727a01947c06", "git_parents": ["cd10079d0575ada221f5ad73734bd275b20fc39a"], "node": "d5f341c0f479cdc87e073f91dd11eeed2f2a2d15", "parents": ["ce9b826b076c1a0cc2b740c7ea62dabc762a412b"], "tags": []}, {"author": "Antonio Borondo \u003caborondo@mozilla.com\u003e", "branch": "default", "desc": "Bug 2023696 - Add function to check if enterprise policies are set via distribution/policies.json  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D293858\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295571\n", "files": ["toolkit/components/jsoncpp/moz.build", "toolkit/components/moz.build", "toolkit/mozapps/update/common/EnterprisePolicies.cpp", "toolkit/mozapps/update/common/EnterprisePolicies.h", "toolkit/mozapps/update/common/moz.build", "toolkit/mozapps/update/tests/gtest/EnterprisePoliciesTests.cpp", "toolkit/mozapps/update/tests/gtest/moz.build"], "git_node": "2b3715735b2f2834dad075e77fa2d807f7ef5e80", "git_parents": ["3ba1fbaa3908b1f93d570f533962727a01947c06"], "node": "8e7c0495fd4c488897a6c25192500d6773957e5d", "parents": ["d5f341c0f479cdc87e073f91dd11eeed2f2a2d15"], "tags": []}, {"author": "Antonio Borondo \u003caborondo@mozilla.com\u003e", "branch": "default", "desc": "Bug 2023696 - Add function to check if enterprise policies are set via registry  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D293859\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295572\n", "files": ["toolkit/mozapps/update/common/EnterprisePolicies.cpp", "toolkit/mozapps/update/common/EnterprisePolicies.h", "toolkit/mozapps/update/tests/gtest/EnterprisePoliciesTests.cpp"], "git_node": "f3568cd3d2dcda57dbac181c89b069712de391f0", "git_parents": ["