s.mozilla.com/D298333\n", "files": ["browser/base/content/browser-sync.js", "browser/base/content/test/sync/browser_sync.js"], "git_node": "623e457eb9e75b1084ccc73e371bccb1c22e3a81", "git_parents": ["fc10e25a40604d4f97e2e859a6daaf32c4d9ce2e"], "node": "d191afb90676f43b782cd7bfbb2fe1a7b8a2a6b4", "parents": ["fe9f93676570b1942b776917301c016a20832bd5"], "tags": []}], "date": 1777923241, "git_changesets": ["623e457eb9e75b1084ccc73e371bccb1c22e3a81"], "user": "dmeehan@mozilla.com"}, "26145": {"changesets": [{"author": "Valentin Pollet \u003cvpollet@firefox.com\u003e", "branch": "default", "desc": "Bug 2029703 - define copy/move semantics for AutoOrtStatus  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296821\n\nDifferential Revision: https://phabricator.services.mozilla.com/D298371\n", "files": ["dom/onnx/InferenceSession.cpp"], "git_node": "f9767eba9ca159683c73a3b4ac6bcb2816e91f60", "git_parents": ["623e457eb9e75b1084ccc73e371bccb1c22e3a81"], "node": "398bf5ee44690ba0cbef0215a7ab7d088e7d5afa", "parents": ["d191afb90676f43b782cd7bfbb2fe1a7b8a2a6b4"], "tags": []}], "date": 1777923282, "git_changesets": ["f9767eba9ca159683c73a3b4ac6bcb2816e91f60"], "user": "dmeehan@mozilla.com"}, "26146": {"changesets": [{"author": "Gregory Mierzwinski \u003cgmierz1@live.ca\u003e", "branch": "default", "desc": "Bug 2036062 - Don't run perfdocs on non-nightly code-reviews.  a=dmeehan DONTBUILD\n\nThis patch adds a new transform to prevent perfdocs from being scheduled on try runs from reviewbot that are based on non-nightly branches (e.g. beta/esr/etc.). This task doesn't need to run there for code-reviews and only triggers false positives.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D297620\n\nDifferential Revision: https://phabricator.services.mozilla.com/D298369\n", "files": ["taskcluster/gecko_taskgraph/transforms/source_test.py"], "git_node": "c233dd4f5e453fead203ff0c1b9cfdda26c95b74", "git_parents": ["f9767eba9ca159683c73a3b4ac6bcb2816e91f60"], "node": "398ba7dcc022c8776587cf7b37d168532a2c0712", "parents": ["398bf5ee44690ba0cbef0215a7ab7d088e7d5afa"], "tags": []}], "date": 1777928608, "git_changesets": ["c233dd4f5e453fead203ff0c1b9cfdda26c95b74"], "user": "dmeehan@mozilla.com"}, "26147": {"changesets": [{"author": "Jim Blandy \u003cjimb@red-bean.com\u003e", "branch": "default", "desc": "Bug 2029910: Cairo: avoid overflow rendering FreeType glyphs.  a=dmeehan\n\nIn `_compute_xrender_bitmap_size`, avoid arithmetic overflow in\ncalculating the size needed for the glyph buffer by: rejecting\nunreasonable glyph sizes early, and using 64-bit temporaries to\nmultiply 32-bit values.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D298348\n", "files": ["gfx/cairo/cairo/src/cairo-ft-font.c"], "git_node": "a13d587f7a5aba1a8e869d75644f9853877faf9f", "git_parents": ["c233dd4f5e453fead203ff0c1b9cfdda26c95b74"], "node": "942377ffe6a90e55c1079e1d708c0da43a0a4535", "parents": ["398ba7dcc022c8776587cf7b37d168532a2c0712"], "tags": []}], "date": 1777928673, "git_changesets": ["a13d587f7a5aba1a8e869d75644f9853877faf9f"], "user": "dmeehan@mozilla.com"}, "26148": {"changesets": [{"author": "Calixte Denizet \u003ccalixte.denizet@gmail.com\u003e", "branch": "default", "desc": "Bug 2036802 - Uplift patchs in beta for fixing bugs with the merge feature  a=dmeehan\n\nDifferential Revision: https://phabricator.services.mozilla.com/D298288\n", "files": ["toolkit/components/pdfjs/content/build/pdf.mjs", "toolkit/components/pdfjs/content/build/pdf.scripting.mjs", "toolkit/components/pdfjs/content/build/pdf.worker.mjs", "toolkit/components/pdfjs/content/web/viewer-geckoview.mjs", "toolkit/components/pdfjs/content/web/viewer.css", "toolkit/components/pdfjs/content/web/viewer.mjs"], "git_node": "053cdbc0c550d64e3e7dd7f87def32faa5470ebc", "git_parents": ["a13d587f7a5aba1a8e869d75644f9853877faf9f"], "node": "190ab6a44e3bf5bf120749d34e7e9b6c157a4968", "parents": ["942377ffe6a90e55c1079e1d708c0da43a0a4535"], "tags": []