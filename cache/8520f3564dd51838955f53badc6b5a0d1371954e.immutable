r/installer/windows/nsis/test_stub.nsi", "browser/installer/windows/nsis/uninstaller_helpers.nsh"], "git_node": "b5f21a97ee48abb41a33e1876148a272e12229c7", "git_parents": ["61c1f51c6003de5b1ed68510f857f643ef52a678"], "node": "73e596adce6b1f03dcbebbc92bf7287f713a12ce", "parents": ["2e9aa6371f8cf27205b441a372738f202a6ee13c"], "tags": []}, {"author": "Antonio Borondo \u003caborondo@mozilla.com\u003e", "branch": "default", "desc": "Bug 2033931 - Normalize Windows header include for case-sensitive filesystems  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295816\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297346\n", "files": ["toolkit/mozapps/update/common/EnterprisePolicies.cpp"], "git_node": "72d24804af96ad01ce71740845417ccce52d3466", "git_parents": ["b5f21a97ee48abb41a33e1876148a272e12229c7"], "node": "20f939a94ec8e95ee62ad63d3838671bc73a2a73", "parents": ["73e596adce6b1f03dcbebbc92bf7287f713a12ce"], "tags": []}, {"author": "Antonio Borondo \u003caborondo@mozilla.com\u003e", "branch": "default", "desc": "Bug 2035145 - Link uuid in update-gtest to resolve FOLDERID_ProgramFilesX86 on MinGW  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296740\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297347\n", "files": ["toolkit/mozapps/update/tests/gtest/moz.build"], "git_node": "90e8dac96715a42f35a86c64888792cfcf1b6bd1", "git_parents": ["72d24804af96ad01ce71740845417ccce52d3466"], "node": "f219a1ef024693468c93dab5ea6a4c6473e102ba", "parents": ["20f939a94ec8e95ee62ad63d3838671bc73a2a73"], "tags": []}, {"author": "Antonio Borondo \u003caborondo@mozilla.com\u003e", "branch": "default", "desc": "Bug 2035214 - Clean UpdaterDeletedShortcut on uninstall  a=dmeehan\n\nThe uninstaller never removed the HKLM UpdaterDeletedShortcut flag, leaving it stale across uninstall/reinstall cycles. On the next update, the stale flag caused OnUpdateDesktopLauncher_HKLM to skip deleting the public desk