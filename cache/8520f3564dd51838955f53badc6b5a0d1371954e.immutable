-handling.patch", "media/libdav1d/moz.yaml", "third_party/dav1d/src/thread_task.c"], "git_node": "6465a1ede6818795f1ac7071ea447829d44664e5", "git_parents": ["d0b1936480fd4d72d305b9367d3ac965e58b7970"], "node": "97992e29489fcb3bcbe502595fa8b7b3ae5290b2", "parents": ["48adc49b655ff942db57e85bf2f407626dddd5c8"], "tags": []}], "date": 1777748965, "git_changesets": ["6465a1ede6818795f1ac7071ea447829d44664e5"], "user": "dmeehan@mozilla.com"}, "26109": {"changesets": [{"author": "unifolia \u003cjlewis@mozilla.com\u003e", "branch": "default", "desc": "Bug 2028676 - Answer to user's question not obvious to screen reader users  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D294494\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297964\n", "files": ["browser/components/aiwindow/ui/components/ai-chat-content/ai-chat-content.css", "browser/components/aiwindow/ui/components/ai-chat-content/ai-chat-content.mjs", "browser/components/aiwindow/ui/components/ai-chat-message/ai-chat-message.mjs", "browser/components/aiwindow/ui/test/browser/browser_aichat_content_message_event.js"], "git_node": "dc13e85e40d262e47191b9d078c89cc61e8f760b", "git_parents": ["6465a1ede6818795f1ac7071ea447829d44664e5"], "node": "b69e6761a9cecedddfe81510da2b3f3cbceb228f", "parents": ["97992e29489fcb3bcbe502595fa8b7b3ae5290b2"], "tags": []}], "date": 1777749012, "git_changesets": ["dc13e85e40d262e47191b9d078c89cc61e8f760b"], "user": "dmeehan@mozilla.com"}, "26110": {"changesets": [{"author": "Timothy Nikkel \u003ctnikkel@gmail.com\u003e", "branch": "default", "desc": "Bug 2035879.  a=dmeehan\n\n[PATCH] D3D11: Fix overflow in compressed 3D texture deferred-init\nFrom 5141d2393c8495286cfa8823c7f664e2b6780286 Mon Sep 17 00:00:00 2001\nThe ANGLE D3D11 backend computed the zero-fill buffer size for\nblock-compressed 3D textures using an unchecked\n32-bit multiplication that did not account for block height.\nThis produced a value four times larger than the actual\ncompressed image size and could overflow for sufficiently large\ntextures.\n\nThis fix:\n1. Uses InternalFormat::computeCompressedImageSize to correctly\ncalculate the required buffer size for compressed textures,\ntaking block dimensions into account.\n2. Employs angle::CheckedNumeric for uncompressed texture size\ncalculations to prevent potential integer overflows.\n3. Adds a regression test DeferredInit3DOverflow\nthat uses large texture dimensions (2048x2048x320) to verify\nthere is no ASAN error.\n\nBug: b/497896137\nFixed: b/501314630\nChange-Id: I76f0fb008af34e8ac78870318e608d16ed4ddd93\nReviewed-on: https://chromium-review.googlesource.com/c/angle/angle/+/7728091\nReviewed-by: Shahbaz Youssefi \u003csyoussefi@chromium.org\u003e\nCommit-Queue: Shahbaz Youssefi \u003csyoussefi@chromium.org\u003e\nAuto-Submit: Shrek Shao \u003cshrekshao@google.com\u003e\n(cherry picked from commit 838c9be2bc21df9ab804428d53bf61fa906be4b4)\nReviewed-on: https://chromium-review.googlesource.com/c/angle/angle/+/7783400\nReviewed-by: Geoff Lang \u003cgeofflang@chromium.org\u003e\n---\n src/libANGLE/renderer/d3d/TextureD3D.cpp      | 20 +++++--\n .../gl_tests/BPTCCompressedTextureTest.cpp    | 52 +++++++++++++++++++\n 2 files changed, 69 insertions(+), 3 deletions(-)\n\nDifferential Revision: https://phabricator.services.mozilla.com/D298018\n", "files": ["gfx/angle/checkout/src/libANGLE/renderer/d3d/TextureD3D.cpp"], "git_node": "bdbcc96fb559d97c939f79d481028bb81d19405f", "git_parents": ["dc13e85e40d262e47191b9d078c89cc61e8f760b"], "node": "1af6534ca796e65638c68d5d693e0dc0037de0d1", "parents": ["b69e6761a9cecedddfe81510da2b3f3cbceb228f"], "tags": []}], "date": 1777749058, "git_changesets": ["bdbcc96fb559d97c939f79d481028bb81d19405f"], "user": "dmeehan@mozilla.com"}, "26111": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Import translations from main\n", "files": ["mobile/android/android-c