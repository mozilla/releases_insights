61dc8b27d0349d9c92a8c\nxh -\u003e 9f6ba21d20ffd06347561dc8b27d0349d9c92a8c\nzam -\u003e 9f6ba21d20ffd06347561dc8b27d0349d9c92a8c\nzh-CN -\u003e 9f6ba21d20ffd06347561dc8b27d0349d9c92a8c\nzh-TW -\u003e 9f6ba21d20ffd06347561dc8b27d0349d9c92a8c\n", "files": ["mobile/locales/l10n-changesets.json"], "git_node": "65be029dc6ab1f1df8085cc169b2374a0ac33581", "git_parents": ["5134e96dfe7e06ccbad76191dc8b7e12ffdec203"], "node": "eed651d1383ea87281e7e7f5137b77156540de00", "parents": ["3cec01e5985f3c267a3fb74327a34402db0e3023"], "tags": []}], "date": 1776935188, "git_changesets": ["5134e96dfe7e06ccbad76191dc8b7e12ffdec203", "65be029dc6ab1f1df8085cc169b2374a0ac33581"], "user": "ffxbld@lando.moz.tools"}, "25877": {"changesets": [{"author": "Henri Sivonen \u003chsivonen@hsivonen.fi\u003e", "branch": "default", "desc": "Bug 2033279 - Make --enable-rust-simd work with Rust 1.95.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295287\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295749\n", "files": [".cargo/config.toml.in", "Cargo.lock", "Cargo.toml", "supply-chain/audits.toml", "supply-chain/config.toml", "third_party/rust/encoding_rs/.cargo-checksum.json", "third_party/rust/encoding_rs/.cargo_vcs_info.json", "third_party/rust/encoding_rs/Cargo.toml", "third_party/rust/encoding_rs/Cargo.toml.orig", "third_party/rust/encoding_rs/src/x_user_defined.rs"], "git_node": "9627b27835a875c010b3d742abda4f8500ebf0bd", "git_parents": ["65be029dc6ab1f1df8085cc169b2374a0ac33581"], "node": "eb1e0017b1315867e3bb5b71223bad4845803255", "parents": ["eed651d1383ea87281e7e7f5137b77156540de00"], "tags": []}], "date": 1776946737, "git_changesets": ["9627b27835a875c010b3d742abda4f8500ebf0bd"], "user": "dmeehan@mozilla.com"}, "25878": {"changesets": [{"author": "Titouan Thibaud \u003ctthibaud@mozilla.com\u003e", "branch": "default", "desc": "Bug 2033313 - Fix transparent background on `Fill with clipboard` box.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295313\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295826\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/HomeFragment.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/toolbar/HomepageToolbarColors.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/search/awesomebar/AwesomeBarComposable.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/search/awesomebar/ClipboardSuggestionBar.kt"], "git_node": "69a3d88ac33884de2ff18309c35b819bfe8b718e", "git_parents": ["9627b27835a875c010b3d742abda4f8500ebf0bd"], "node": "9ca09418b982003019f21bfec1ae407e98996541", "parents": ["eb1e0017b1315867e3bb5b71223bad4845803255"], "tags": []}], "date": 1776946785, "git_changesets": ["69a3d88ac33884de2ff18309c35b819bfe8b718e"], "user": "dmeehan@mozilla.com"}, "25879": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2033384 - Tweak colgroup child suppression.  a=dmeehan\n\nThis code comes all the way back from bug 480979.\n\nWhat happens here is as follows:\n\n * There are two table-column items, with their relevant anonymous\n   wrapper. Why the page uses `display: table-column` for this escapes\n   my understanding.\n * We insert the header next to them. We compute the parent frame to be\n   the (anonymous) nsTableColumnGroup frame, because it's our sibling's\n   parent.\n * We decide you're not a column, and thus you get suppressed. We don't\n   create FrameConstructionItems for it.\n * We don't realize in WipeContainingBlock that things went wrong, and\n   fail miserably.\n\nFortunately we can tweak this to perform the suppression later in the\npipeline.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295265\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295831\n", "files": ["layout/base/nsCSSFrameConstructor.cpp", "testing/web-platform/tests/css/css-tables/insert-after-col-ref.html", "testing/web-platform/tests/css/css-tables/insert-after-col.html"], "git_node": "39faabfea64de98c2e63ccfb4f7901097c1b0595", "git_parents": ["69a3d88ac33884de2ff18309c35b819bfe8b718e"], "node": "e003345e56c393dac7e0d496aa3631eae8a7c6a2", "parents": ["9ca09418b982003019f21bfec1ae407e98996541"], "tags": []}], "date": 1776946827, "git_changesets": ["39faabfea64de98c2e63ccfb4f7901097c1b0595"], "user": "dmeehan@mozilla.com"}, "25880": {"changesets": [{"author": "Rebecca King \u003crking@mozilla.com\u003e", "branch": "default", "desc": "Bug 2032605 - Add conditional attention dot to IP Protection toolbar button -  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295063\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295852\n", "files": ["browser/app/profile/firefox.js", "browser/components/ipprotection/IPProtection.sys.mjs", "browser/components/ipprotection/IPProtectionPanel.sys.mjs", "browser/components/ipprotection/IPProtectionToolbarButton.sys.mjs", "browser/components/ipprotection/tests/browser/browser_ipprotection_toolbar.js", "browser/components/ipprotection/tests/browser/head.js", "browser/themes/shared/toolbarbuttons.css"], "git_node": "83d5d8f01ae820bdac6f8fdbc317490177ab3e13", "git_parents": ["39faabfea64de98c2e63ccfb4f7901097c1b0595"], "node": "2c5ef22e5a355825f3ca2d6783438201c78aa3a7", "parents": ["e003345e56c393dac7e0d496aa3631eae8a7c6a2"], "tags": []}, {"author": "kpatenio \u003ckpatenio@mozilla.com\u003e", "branch": "default", "desc": "Bug 2031544 \u2014 show site exclusion confirmation hint once per unique excluded site only.  a=dmeehan\n\n- Updates IPProtectionToolbarButton to track a set of visited excluded sites\n- If a site origin is already tracked, do not show the confirmation hint\n- Simplifies tests in browser_ipprotection_confirmation_hints_site_exclusion.js and adds a new one ensuring we show a hint once per unique site\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295411\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295885\n", "files": ["browser/components/ipprotection/IPProtectionToolbarButton.sys.mjs", "browser/components/ipprotection/tests/browser/browser_ipprotection_confirmation_hints_site_exclusion.js"], "git_node": "6721671a8ab4130cc30c888ee26d750b1efc92ae", "git_parents": ["83d5d8f01ae820bdac6f8fdbc317490177ab3e13"], "node": "e44dadb11cc7ba1e732dfecb48f2508e008d6ffb", "parents": ["2c5ef22e5a355825f3ca2d6783438201c78aa3a7"], "tags": []}], "date": 1776947075, "git_changesets": ["83d5d8f01ae820bdac6f8fdbc317490177ab3e13", "6721671a8ab4130cc30c888ee26d750b1efc92ae"], "user": "dmeehan@mozilla.com"}, "25881": {"changesets": [{"author": "Elissa Cha \u003cecha@mozilla.com\u003e", "branch": "default", "desc": "Bug 2029237 - Disable smart cursor interaction  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D294791\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295878\n", "files": ["browser/components/genai/GenAI.sys.mjs", "browser/components/genai/tests/browser/browser_chat_contextmenu.js", "browser/components/genai/tests/browser/browser_chat_shortcuts.js"], "git_node": "1283d9840790da800b2c77545a62b6ef56bd99c2", "git_parents": ["6721671a8ab4130cc30c888ee26d750b1efc92ae"], "node": "8df157370a697c946ae61938517df7ac6b5707cf", "parents": ["e44dadb11cc7ba1e732dfecb48f2508e008d6ffb"], "tags": []}], "date": 1776947123, "git_changesets": ["1283d9840790da800b2c77545a62b6ef56bd99c2"], "user": "dmeehan@mozilla.com"}, "25882": {"changesets": [{"author": "fmasalha \u003cfmasalha@mozilla.com\u003e", "branch": "default", "desc": "Bug 2029616 - Added a dismiss button to the error screens for s2s  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D292909\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295926\n", "files": ["mobile/android/android-components/components/feature/summarize/src/main/java/mozilla/components/feature/summarize/