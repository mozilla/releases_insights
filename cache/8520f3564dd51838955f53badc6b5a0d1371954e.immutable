bc46c313c6e129493430212e4f10"], "user": "ffxbld@lando.moz.tools"}, "25953": {"changesets": [{"author": "Sebastian Hengst \u003caryx.github@gmx-topmail.de\u003e", "branch": "default", "desc": "Bug 2034531 - run full set mozilla-beta tasks every 3 hours.  a=dmeehan DONTBUILD\n\n* Save resources by running it every 3 instead of every hour.\n* Run it after the mobile localization strings land at 9am UTC.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296141\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296694\n", "files": [".cron.yml"], "git_node": "5d40e224f5a451261c5ce7d5affa48dcf0354372", "git_parents": ["6cbb4280496f85c9d29025d16efe060c5996c221"], "node": "246225c050fb518adf82fcdbbcd76fcc9b7f718e", "parents": ["30c8452599e8eaeb40dfcef15deac39fe85a9fb2"], "tags": []}], "date": 1777307831, "git_changesets": ["5d40e224f5a451261c5ce7d5affa48dcf0354372"], "user": "dmeehan@mozilla.com"}, "25954": {"changesets": [{"author": "Malte J\u00fcrgens \u003cmaltejur@mozilla.com\u003e", "branch": "default", "desc": "Bug 2034761 - Update test expectations for upgrade-insecure-requests/gen/srcdoc-inherit.meta/unset/iframe-tag.https.html WPT  a=dmeehan DONTBUILD\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296667\n", "files": ["testing/web-platform/meta/upgrade-insecure-requests/gen/srcdoc-inherit.meta/unset/iframe-tag.https.html.ini"], "git_node": "71074f4d60c70d1d37ef8a6933734385b587d630", "git_parents": ["5d40e224f5a451261c5ce7d5affa48dcf0354372"], "node": "7f149d4e2e3c0bb23cc1c31d4651ed3f19a5d7d6", "parents": ["246225c050fb518adf82fcdbbcd76fcc9b7f718e"], "tags": []}], "date": 1777307882, "git_changesets": ["71074f4d60c70d1d37ef8a6933734385b587d630"], "user": "dmeehan@mozilla.com"}, "25955": {"changesets": [{"author": "Lars Eggert \u003clars@eggert.org\u003e", "branch": "default", "desc": "Bug 2031968 - Fire DNS completion callbacks outside nsHostResolver locks  a=dmeehan\n\nResolveHost, CompleteLookupLocked, CompleteLookupByTypeLocked, and CancelAsyncRequest all invoked OnResolveHostComplete callbacks while holding mDBLock (write) + mQueue.mLock. If a callback re-entered ResolveHost on the same thread the non-reentrant RWLock deadlocked, as confirmed by a new gtest (TestDNSDeadlock) that catches the cycle via Mozilla's deadlock detector. Fix: collect callbacks into a CallbackArray while the locks are held, release both locks, then fire.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D294637\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296105\n", "files": ["netwerk/dns/nsHostResolver.cpp", "netwerk/dns/nsHostResolver.h", "netwerk/test/gtest/TestDNS.cpp", "netwerk/test/gtest/moz.build"], "git_node": "05f01522f2964d2f461e0f6a410c95cb70bdc963", "git_parents": ["71074f4d60c70d1d37ef8a6933734385b587d630"], "node": "52b859dbc234b1d216b2bf226c89a80b029b3710", "parents": ["7f149d4e2e3c0bb23cc1c31d4651ed3f19a5d7d6"], "tags": []}], "date": 1777307925, "git_changesets": ["05f01522f2964d2f461e0f6a410c95cb70bdc963"], "user": "dmeehan@mozilla.com"}, "25956": {"changesets": [{"author": "Lars Eggert \u003clars@eggert.org\u003e", "branch": "default", "desc": "Bug 2034587 - Fix race in TestDNS test r=kershaw,necko-reviewers a=test-only DONTBUILD\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296229\n", "files": ["netwerk/test/gtest/TestDNS.cpp"], "git_node": "b5c4cbc3c475f734ccc444dda3d12ff56de802f4", "git_parents": ["05f01522f2964d2f461e0f6a410c95cb70bdc963"], "node": "38502820ae9cb27d39956ee8d57a53b8a43bf581", "parents": ["52b859dbc234b1d216b2bf226c89a80b029b3710"], "tags": []}], "date": 1777308223, "git_changesets": ["b5c4cbc3c475f734ccc444dda3d12ff56de802f4"], "user": "dmeehan@mozilla.com"}, "25957": {"changesets": [{"author": "Rebecca King \u003crking@mozilla.com\u003e", "branch": "default", "desc": "Bug 2033505 - Update strings for VPN section in about:settings -  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295324\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296707\n", "files": ["browser/components/preferences/config/privacy.mjs"], "git_node": "3f157a4516b24fef65b2280aba3c15b3b9a4bafa", "git_parents": ["b5c4cbc3c475f734ccc444dda3d12ff56de802f4"], "node": "7671c94c051f53a598399260cde1aa61fd4c4b5a", "parents": ["38502820ae9cb27d39956ee8d57a53b8a43bf581"], "tags": []}], "date": 1777308422, "git_changesets": ["3f157a4516b24fef65b2280aba3c15b3b9a4bafa"], "user": "dmeehan@mozilla.com"}, "25958": {"changesets": [{"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 2032644 - [devtools] Increase waitFor interval in browser_net_sse-basic.js  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295763\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296641\n", "files": ["devtools/client/netmonitor/test/browser_net_sse-basic.js"], "git_node": "ff8774c2f8081c063b9052711e98c9a86a158b23", "git_parents": ["3f157a4516b24fef65b2280aba3c15b3b9a4bafa"], "node": "9529114b8243c2d7010c1d6141a0a176fe66350e", "parents": ["7671c94c051f53a598399260cde1aa61fd4c4b5a"], "tags": []}], "date": 1777308465, "git_changesets": ["ff8774c2f8081c063b9052711e98c9a86a158b23"], "user": "dmeehan@mozilla.com"}, "25959": {"changesets": [{"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 2033782 - [devtools] Fix container query tooltip contrast in dark mode. .  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295747\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296676\n", "files": ["devtools/client/themes/tooltips.css"], "git_node": "a3d7977aabbc69fd0fcbfa041f7314cf7a7d94bc", "git_parents": ["ff8774c2f8081c063b9052711e98c9a86a158b23"], "node": "3b6cb7e1fdfe2a864c1480cef1b63d62a3213b37", "parents": ["9529114b8243c2d7010c1d6141a0a176fe66350e"], "tags": []}], "date": 1777308509, "git_changesets": ["a3d7977aabbc69fd0fcbfa041f7314cf7a7d94bc"], "user": "dmeehan@mozilla.com"}, "25960": {"changesets": [{"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 2034791 - Make VisitedModuleSet use stable cell hashing  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296332\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296669\n", "files": ["js/src/builtin/ModuleObject.h", "js/src/vm/Modules.cpp"], "git_node": "a2b5c548ec725eea504131c1bf1ca1cdfa4a14f6", "git_parents": ["a3d7977aabbc69fd0fcbfa041f7314cf7a7d94bc"], "node": "bb551693ec6596140c2ddb864bf14be3923458da", "parents": ["3b6cb7e1fdfe2a864c1480cef1b63d62a3213b37"], "tags": []}], "date": 1777308553, "git_changesets": ["a2b5c548ec725eea504131c1bf1ca1cdfa4a14f6"], "user": "dmeehan@mozilla.com"}, "25961": {"changesets": [{"author": "Maxx Crawford \u003cmcrawford@mozilla.com\u003e", "branch": "default", "desc": "Bug 2034620 - Fix UI issues with Lists, Timer, and Weather widgets.  a=dmeehan\n\n- Gate the \"Change size\" context menu on `widgets.system.maximized` for all three widgets\n- Scope Focus/Break button border-radius styles to `.classic-enabled` so Nova renders them as standard moz-buttons with proper spacing\n- Fix Lists empty-state text contrast in dark mode by limiting wallpaper-contrast-fix to the classic layout path\n- Add Nova card box-shadow and hover styles to Lists and FocusTimer\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296241\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296701\n", "files": ["browser/extensions/newtab/content-src/components/Widgets/FocusTimer/FocusTimer.jsx", "browser/extensions/newtab/content-src/components/Widgets/FocusTimer/_FocusTimer.scss", "browser/extensions/newtab/content-src/components/Widgets/Lists/Lists.jsx", "browser/extensions/newtab/content-src/components/Widgets/Lists/_Lists.scss", "browser/extensions/newtab/content-src/components/Widgets/Weather/Weather.jsx", "browser/extensions/newtab/content-src/components/Widgets/Widgets.jsx", "browser/extensions/newtab/css/activity-stream.css", "browser/extensions/newtab/css/nova/activity-stream.css", "browser/extensions/newtab/data/content/activity-stream.bundle.js", "browser/extensions/newtab/test/jest/content-src/components/Widgets/FocusTimer.test.jsx", "browser/extensions/newtab/test/jest/content-src/components/Widgets/Lists.test.jsx", "browser/extensions/newtab/test/jest/content-src/components/Widgets/Weather.test.jsx", "browser/extensions/newtab/test/unit/content-src/components/Widgets/FocusTimer.test.jsx", "browser/extensions/newtab/test/unit/content-src/components/Widgets/Lists.test.jsx"], "git_node": "5521a8c6516a8db6303aa9b0bdae513909bb4875", "git_parents": ["a2b5c548ec725eea504131c1bf1ca1cdfa4a14f6"], "node": "47ad6d1b7f0fcdad8b335214affe5602f4baa001", "parents": ["bb551693ec6596140c2ddb864bf14be3923458da"], "tags": []}], "date": 1777308597, "git_changesets": ["5521a8c6516a8db6303aa9b0bdae513909bb4875"], "user": "dmeehan@mozilla.com"}, "25962": {"changesets": [{"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 2032512 - Update weak ref state when target is transplanted  a=dmeehan\n\nThe problem here is that transplant doesn't udpate the target we have\nregistered for the weak ref and swapps it for a CCW. This breaks the weak ref\nand triggers and assertion when nuking (because we assume targets are not\nCCWs).\n\nThe fix is to update the state on transplant and update observing weakrefs so\nthey observe the new target.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D294959\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296672\n", "files": ["js/src/gc/FinalizationObservers.cpp", "js/src/gc/FinalizationObservers.h", "js/src/gc/GCRuntime.h", "js/src/jit-test/tests/gc/bug-2032512.js", "js/src/jit-test/tests/gc/transplant-weak-targets.js", "js/src/jsapi.cpp", "js/src/shell/js.cpp"], "git_node": "