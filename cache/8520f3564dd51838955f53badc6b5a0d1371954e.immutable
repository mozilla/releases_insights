d1e71bc4bb01903ba0c", "git_parents": ["55ad620da7c0e03292be2facc8320e2060ae6d57"], "node": "4c265f4855386855e709670bea4b455567653b4c", "parents": ["9a79e1423065d722470ee0608fe64910bef34d79"], "tags": []}], "date": 1776780516, "git_changesets": ["a680fc6dc8429257f20afd1e71bc4bb01903ba0c"], "user": "dmeehan@mozilla.com"}, "25847": {"changesets": [{"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "default", "desc": "Bug 2033602 -  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295397\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295427\n", "files": ["js/src/jit/MacroAssembler.cpp"], "git_node": "b7b9b787c82d872da9505d9018790312fbc60a2d", "git_parents": ["a680fc6dc8429257f20afd1e71bc4bb01903ba0c"], "node": "6a3a42c7655004a2283cdf365cc9fe682e85c87f", "parents": ["4c265f4855386855e709670bea4b455567653b4c"], "tags": []}], "date": 1776780707, "git_changesets": ["b7b9b787c82d872da9505d9018790312fbc60a2d"], "user": "dmeehan@mozilla.com"}, "25848": {"changesets": [{"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 2033691 - [devtools] Temporarily delay toolbox open on Linux opt  a=dmeehan\n\nStill investigating the race condition, adding a 1s delay before opening the toolbox avoids the issue for now.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295461\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295505\n", "files": ["devtools/client/accessibility/test/browser/head.js"], "git_node": "e33bdf75dcb644c397abbe7db731cc3b97b052cd", "git_parents": ["b7b9b787c82d872da9505d9018790312fbc60a2d"], "node": "6404bb745054193427a164a966780494ba013867", "parents": ["6a3a42c7655004a2283cdf365cc9fe682e85c87f"], "tags": []}], "date": 1776780748, "git_changesets": ["e33bdf75dcb644c397abbe7db731cc3b97b052cd"], "user": "dmeehan@mozilla.com"}, "25849": {"changesets": [{"author": "giorga \u003cgiorga@mozilla.com\u003e", "branch": "default", "desc": "Bug 2033339 - The tabs tray scroll position should be maintained at the spot where the tab was deleted.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295278\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295522\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/tabstray/ui/tabpage/TabLayout.kt"], "git_node": "128ab585e781f68abf41029571352366b06aed81", "git_parents": ["e33bdf75dcb644c397abbe7db731cc3b97b052cd"], "node": "bcdf2ffd13ef73e0b24f54341b3b09666877bff7", "parents": ["6404bb745054193427a164a966780494ba013867"], "tags": []}], "date": 1776780789, "git_changesets": ["128ab585e781f68abf41029571352366b06aed81"], "user": "dmeehan@mozilla.com"}, "25850": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging 1a6c5c6f11fca486436075d92fd82d51f706c775 with FIREFOX-ANDROID_150_0_RELEASE a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "bad4317a2ac648966ace59541c2069b076b21736", "git_parents": ["6081150e4850b2bcc1f70ebadb94ea770fabfc77"], "node": "e194372f2912d6beb7230ecd44bab14e86bd8706", "parents": ["d8290477cebcb3b03936a2e6f3bb3f36ac0ff74c"], "tags": []}], "date": 1776780849, "git_changesets": ["bad4317a2ac648966ace59541c2069b076b21736"], "user": "ffxbld@lando.moz.tools"}, "25851": {"changesets": [{"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 2030466 - Skip MERINO_MANIFEST resources when serializing icon requests to JSON  a=dmeehan\n\nEnabling the Merino manifest in BrowserIcons caused MerinoManifestIconPreparer\nto append IconRequest.Resource entries with the IconRequest.Resource.Type.MERINO_MANIFEST type.\nThese resources then reached IconMessage.toJSON() via IconDiskCache.putResources() /\nDiskIconProcessor.process(), where reverseLookup() threw\nIllegalArgumentException: \"Unknown type: MERINO_MANIFEST\" because the\nMERINO_MANIFEST type has no corresponding HTML rel-link value in the typeMap.\n\nTIPPY_TOP is another resource type already skipped in toJSON() for the\nsame reason. This patch extends the skip guard to also drop\nMERINO_MANIFEST resources before reverseLookup() is called, so they never\nreach the disk cache or the web-extension message bridge.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295186\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295555\n", "files": ["mobile/android/android-components/components/browser/icons/src/main/java/mozilla/components/browser/icons/extension/IconMessage.kt", "mobile/android/android-components/components/browser/icons/src/test/java/mozilla/components/browser/icons/extension/IconMessageKtTest.kt"], "git_node": "50177152ce905c5fa67c842a02fc7b47a8e87ba9", "git_parents": ["128ab585e781f68abf41029571352366b06aed81"], "node": "743fb717608e62163c44c553fa1e92b294d3aa75", "parents": ["bcdf2ffd13ef73e0b24f54341b3b09666877bff7"], "tags": []}], "date": 1776789145, "git_changesets": ["50177152ce905c5fa67c842a02fc7b47a8e87ba9"], "user": "dmeehan@mozilla.com"}, "25852": {"changesets": [{"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 2031921.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295127\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295556\n", "files": ["dom/canvas/WebGLContext.cpp", "modules/libpref/init/StaticPrefList.yaml"], "git_node": "baebc1f6f739ccee392b355a178fe301031c52ad", "git_parents": ["50177152ce905c5fa67c842a02fc7b47a8e87ba9"], "node": "f09cf2f1cc0e5ec119e708475b9126813c83b23e", "parents": ["743fb717608e62163c44c553fa1e92b294d3aa75"], "tags": []}], "date": 1776789290, "git_changesets": ["baebc1f6f739ccee392b355a178fe301031c52ad"], "user": "dmeehan@mozilla.com"}, "25853": {"changesets": [{"author": "Maxx Crawford \u003cmcrawford@mozilla.com\u003e", "branch": "default", "desc": "Bug 2033165 - Fix Nova page layout and component alignment  ?#home-newtab-reviewers  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295294\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295563\n", "files": ["browser/extensions/newtab/content-src/components/Base/_Base.scss", "browser/extensions/newtab/content-src/components/Base/_Grid.scss", "browser/extensions/newtab/content-src/components/DiscoveryStreamAdmin/DiscoveryStreamAdmin.scss", "browser/extensions/newtab/content-src/components/Logo/_Logo.scss", "browser/extensions/newtab/content-src/components/Search/_Search.scss", "browser/extensions/newtab/css/activity-stream.css", "browser/extensions/newtab/css/nova/activity-stream.css"], "git_node": "99c6672dbe3e3ef65c8678b60e0428e022e25410", "git_parents": ["baebc1f6f739ccee392b355a178fe301031c52ad"], "node": "9d6bc3e50774faf3a5cae5e5683c8db8a5f02499", "parents": ["f09cf2f1cc0e5ec119e708475b9126813c83b23e"], "tags": []}], "date": 1776789334, "git_changesets": ["99c6672dbe3e3ef65c8678b60e0428e022e25410"], "user": "dmeehan@mozilla.com"}, "25854": {"changesets": [{"author": "Jari Jalkanen \u003cjjjalkanen@gmail.com\u003e", "branch": "default", "desc": "Bug 2030461 - Use platform path separators with paths from nsIFile.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D293871\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295471\n", "files": ["dom/filesystem/FileSystemSecurity.cpp", "dom/filesystem/FileSystemUtils.cpp", "dom/filesystem/FileSystemUtils.h"], "git_node": "da7838b0452047ba6847e1e8836ecabe1001852d", "git_parents": ["99c6672dbe3e3ef65c8678b60e0428e022e25410"], "node": "5d03daaedee62f2ef44747c415279b48b5789c6e", "parents": ["9d6bc3e50774faf3a5cae5e5683c8db8a5f02499"], "tags": []}], "date": 1776807761, "git_changesets": ["da7838b0452047ba6847e1e8836ecabe1001852d"], "user": "dmeehan@mozilla.com"}, "25855": {"changesets": [{"author": "Alastor Wu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 2030296 - Part 1: Update mp4parse to 952f5173.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295343\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295619\n", "files": [".cargo/config.toml.in", "Cargo.lock", "third_party/rust/mp4parse/.cargo-checksum.json", "third_party/rust/mp4parse/src/lib.rs", "third_party/rust/mp4parse/src/tests.rs", "third_party/rust/mp4parse/src/unstable.rs", "third_party/rust/mp4parse_capi/.cargo-checksum.json", "third_party/rust/mp4parse_capi/Cargo.toml", "third_party/rust/mp4parse_capi/src/lib.rs", "third_party/rust/mp4parse_capi/tests/test_avis.rs", "third_party/rust/mp4parse_capi/tests/test_colour_info.rs", "third_party/rust/mp4parse_capi/tests/test_encryption.rs", "third_party/rust/mp4parse_capi/tests/test_fragment.rs", "toolkit/library/rust/shared/Cargo.toml"], "git_node": "b8a126c11c3a4e41330a37fe0abd4b7ebd719932", "git_parents": ["da7838b0452047ba6847e1e8836ecabe1001852d"], "node": "3be4ad577b95bd9fe6394fbd3c0300572cf8f9b8", "parents": ["5d03daaedee62f2ef44747c415279b48b5789c6e"], "tags": []}, {"author": "Alastor Wu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 2030296 - Part 2: Read NCLX colr box in MP4VideoInfo::Update().  a=dmeehan\n\nWhen parsing fMP4 video tracks, the colr box carrying CICP colour primaries,\ntransfer characteristics, and matrix coefficients was never read. This caused\nHDR10 content to fall back to BT.709 in downstream decoders, rendering\nnear-black on HDR displays.\n\nPopulate the colour space fields from the NCLX colr box data when present.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D294849\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295620\n", "files": ["dom/media/gtest/TestMP4Demuxer.cpp", "dom/media/mp4/DecoderData.cpp"], "git_node": "640e150b2f3999d67cb8c5206a9938108edc0557", "git_parents": ["b8a126c11c3a4e41330a37fe0abd4b7ebd719932"], "node": "4cfd2d1e87170b70fb9194e00d50383e983ccf6c", "parents": ["3be4ad577b95bd9fe6394fbd3c0300572cf8f9b8"], "tags": []}], "date": 1776807807, "git_changesets": ["b8a126c11c3a4e41330a37fe0abd4b7ebd719932", "640e150b2f3999d67cb8c5206a9938108edc0557"], "user": "dmeehan@mozilla.com"}, "25856": {"changesets": [{"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 2031028 - Part 1: Ensure stream is cloneable eagerly in RemoteLazyInputStreamStorage,  a=dmeehan\n\nThis should simplify the logic a bit, as we won't need to deal with the\nstream not being cloneable and needing replacement during GetStream.\nInstead, the stream will be made cloneable as it is added to the store,\nand can be reliably cloned in GetStream.\n\nI did this by factoring out this core part of `NS_CloneInputStream`, so\nthat the logic can be easily shared.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D293916\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295626\n", "files": ["dom/file/ipc/RemoteLazyInputStreamStorage.cpp", "dom/file/ipc/RemoteLazyInputStreamStorage.h", "xpcom/io/nsStreamUtils.cpp", "xpcom/io/nsStreamUtils.h"], "git_node": "5412826ce72f19b236a5a71928e7a8ac4f52dc0c", "git_parents": ["640e150b2f3999d67cb8c5206a9938108edc0557"], "node": "837763d6791dd10639dc94ceeb594fc33ce22e97", "parents": ["4cfd2d1e87170b70fb9194e00d50383e983ccf6c"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 2031028 - Part 2: Use NS_EnsureInputStreamIsCloneable in RemoteLazyInputStream,  a=dmeehan\n\nThere was already similar logic being performed manually in\nRemoteLazyInputStream. This switches the code to use the common helper,\navoiding the need for a manual re-implementation of the method.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D293917\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295627\n", "files": ["dom/file/ipc/RemoteLazyInputStream.cpp"], "git_node": "f15015b5058965f525edd63bdeda75210d971401", "git_parents": ["5412826ce72f19b236a5a71928e7a8ac4f52dc0c"], "node": "2ab8e2fa3d3874ec2e150b710484476b25b1752d", "parents": ["837763d6791dd10639dc94ceeb594fc33ce22e97"], "tags": []}], "date": 1776807854, "git_changesets": ["5412826ce72f19b236a5a71928e7a8ac4f52dc0c", "f15015b5058965f525edd63bdeda75210d971401"], "user": "dmeehan@mozilla.com"}, "25857": {"changesets": [{"author": "Alex Franchuk \u003cafranchuk@mozilla.com\u003e", "branch": "default", "desc": "Bug 2033134 - Fix StackTraces annotation serialization in test  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295308\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295634\n", "files": ["mobile/android/android-components/components/lib/crash/src/androidTest/java/mozilla/components/lib/crash/service/GleanCrashReporterServiceTest.kt"], "git_node": "fbaf2df70959c00ed67477dd7ff36c147faba7c3", "git_parents": ["f15015b5058965f525edd63bdeda75210d971401"], "node": "8832fc87dbaa01032e6539426e045d44564b70b2", "parents": ["2ab8e2fa3d3874ec2e150b710484476b25b1752d"], "tags": []}], "date": 1776807897, "git_changesets": ["fbaf2df70959c00ed67477dd7ff36c147faba7c3"], "user": "dmeehan@mozilla.com"}, "25858": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update remote-settings tld-suffixes mobile-experiments ct-logs -  a=dmeehan\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295651\n", "files": ["mobile/android/fenix/app/src/main/res/raw/initial_experiments.json", "netwerk/dns/effective_tld_names.dat", "security/ct/CTKnownLogs.h", "security/manager/tools/log_list.json", "services/settings/dumps/blocklists/addons-bloomfilters.json", "services/settings/dumps/main/ai-window-prompts.json", "services/settings/dumps/main/devtools-compatibility-browsers.json", "services/settings/dumps/main/search-config-v2.json", "services/settings/dumps/main/search-default-override-allowlist.json", "services/settings/dumps/security-state/intermediates.json"], "git_node": "de22a521da5d308477f5a4f769571319d8ade123", "git_parents": ["fbaf2df70959c00ed67477dd7ff36c147faba7c3"], "node": "9f04d8457309950b9e1524ec2193b750f97c6efe", "parents": ["8832fc87dbaa01032e6539426e045d44564b70b2"], "tags": []}], "date": 1776816083, "git_changesets": ["de22a521da5d308477f5a4f769571319d8ade123"], "user": "dmeehan@mozilla.com"}, "25859": {"changesets": [{"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 2032648 - Urlbar sports suggestions: Add cricket, golf, racing, and soccer fallback icons and improve sport-to-fallback-icon mapping.  a=dmeehan\n\nThis adds the new icons and updates the sport-to-fallback-icon mapping so it\nuses `sport_category`. Please see the bug for details.\n\nTo avoid confusion, I renamed the attribute used for the mapping accordingly, to\n`sport-category`, and I also renamed the dynamic name used for the user-visible\nsport text (e.g., \"MLB\", \"NBA\") from \"sport-name\" to \"sport\" so that it also\nmatches the `sport` property in the Merino response.\n\nI rewrote `browser_quicksuggest_sports.js` a little bit so that it's easier to\nupdate with new sports.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D294853\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295718\n", "files": ["browser/components/urlbar/private/SportsSuggestions.sys.mjs", "browser/components/urlbar/tests/quicksuggest/browser/browser_quicksuggest_sports.js", "browser/components/urlbar/tests/quicksuggest/unit/test_quicksuggest_sports.js", "browser/themes/shared/jar.inc.mn", "browser/themes/shared/urlbar/icons/sports-cricket.svg", "browser/themes/shared/urlbar/icons/sports-golf.svg", "browser/themes/shared/urlbar/icons/sports-racing.svg", "browser/themes/shared/urlbar/icons/sports-soccer.svg", "browser/themes/shared/urlbar/view-nova.css", "browser/themes/shared/urlbar/view-proton.css"], "git_node": "d3614c2f2fcde665c078971bcad5e5125e