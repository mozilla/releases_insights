t/errors/error-lookup.mjs", "toolkit/content/errors/net-errors.mjs", "toolkit/content/net-error-card.mjs"], "git_node": "ae66294cbe344ca51dd5899b374703ba94195978", "git_parents": ["d6636beba2a2893c2627d2e5f53f30c5c0b8adb3"], "node": "289237d777688d5f0286e2be6bab75a42e38b91b", "parents": ["57ccf8db74f1f65cb8c10af3b72d4abcafa45de8"], "tags": []}, {"author": "Jack Brown \u003cjbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 2027209 - Update netInterrupt Felt Privacy error page content -  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D294693\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297092\n", "files": ["browser/base/content/test/about/browser.toml", "browser/base/content/test/about/browser_aboutNetError_netInterrupt.js", "browser/base/content/test/about/browser_aboutNetError_telemetry.js", "toolkit/content/errors/net-errors.mjs", "toolkit/content/net-error-card.mjs", "toolkit/themes/shared/aboutNetError.css"], "git_node": "6d23858c08d5ead4516bb36948128faf17a48c09", "git_parents": ["ae66294cbe344ca51dd5899b374703ba94195978"], "node": "8004bb58d93d0ce9933a83e09b5e22e49d9e3f7d", "parents": ["289237d777688d5f0286e2be6bab75a42e38b91b"], "tags": []}, {"author": "Jack Brown \u003cjbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 2027209 - Update connectionFailure and netTimeout Felt Privacy error page content -  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295527\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297093\n", "files": ["browser/base/content/test/about/browser.toml", "browser/base/content/test/about/browser_aboutNetError_connectionFailure.js", "browser/base/content/test/about/browser_aboutNetError_netInterrupt.js", "browser/base/content/test/about/browser_aboutNetError_timeout.js", "browser/base/content/test/about/head.js", "toolkit/content/errors/net-errors.mjs"], "git_node": "6b0acfb761651c1ab89aa0907d15eb7a206df0dd", "git_parents": ["6d23858c08d5ead4516bb36948128faf17a48c09"], "node": "608a480a39219a408479e2663d4805397445bab8", "parents": ["8004bb58d93d0ce9933a83e09b5e22e49d9e3f7d"], "tags": []}], "date": 1777422800, "git_changesets": ["ae66294cbe344ca51dd5899b374703ba94195978", "6d23858c08d5ead4516bb36948128faf17a48c09", "6b0acfb761651c1ab89aa0907d15eb7a206df0dd"], "user": "dmeehan@mozilla.com"}, "26007": {"changesets": [{"author": "Andy Leiserson \u003caleiserson@mozilla.com\u003e", "branch": "default", "desc": "Bug 2027883 - Fix integer overflow in cairo PDF surface image emission  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D292028\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297156\n", "files": ["gfx/cairo/cairo/src/cairo-pdf-surface.c"], "git_node": "bbfcce9906cc0045a71c43f64c471c4d9f6015bf", "git_parents": ["6b0acfb761651c1ab89aa0907d15eb7a206df0dd"], "node": "eedefb565245594da31f591c378bddcf2f4ad4c2", "parents": ["608a480a39219a408479e2663d4805397445bab8"], "tags": []}], "date": 1777422845, "git_changesets": ["bbfcce9906cc0045a71c43f64c471c4d9f6015bf"], "user": "dmeehan@mozilla.com"}, "26008": {"changesets": [{"author": "alastor0325 \u003calastor0325@gmail.com\u003e", "branch": "default", "desc": "Bug 2033640 - Clear stale CDM registration from PMP server when recreating CDM.  a=dmeehan\n\nRemove the old CDM's registration from the shared Protected Media Path server\nbefore dropping it, mirroring the existing shutdown path.\n\nWithout this, the old registration persists in the PMP server when a new CDM\nregisters after a hardware context reset. With two conflicting registrations\npresent, PlayReady cannot determine which CDM to use and returns\nMF_E_INCOMPATIBLE_SAMPLE_PROTECTION (0xC00D7176), causing a startplay failure\non the recovery attempt.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295635\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297162\n", "files": ["dom/media/ipc/MFCDMParent.cpp"], "git_node": "2c6f9766eef09664eb3aaaf3fedc27b8b08297dc", "git_parents": ["bbfcce9906cc0045a71c43f64c471c4d9f6015bf"], "node": "543f3f7917ea01ef02bd91d5bbb1a350a83efb29", "parents": ["eedefb565245594da31f591c378bddcf2f4ad4c2"], "tags": []}], "date": 1777422888, "git_changesets": ["2c6f9766eef09664eb3aaaf3fedc27b8b08297dc"], "user": "dmeehan@mozilla.com"}, "26009": {"changesets": [{"author": "Ashley Hale \u003cahale@mozilla.com\u003e", "branch": "default", "desc": "Bug 2033180 - Gracefully handle VideoProcessorBlt errors for HLG video by showing as non-HDR  a=dmeehan\n\nThis also handles BT2100 PQ errors by processing as BT709 which might\ncause some color distortion but seems to look right in practice, still\ndisplays as BT2100 PQ HDR in that case.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295131\n\nDifferential Revision: https://phabricator.services.mozilla.com/D297169\n", "files": ["gfx/webrender_bindings/DCLayerTree.cpp", "gfx/webrender_bindings/DCLayerTree.h"], "git_node": "54faee48aa7192e7915682d0f8ef9a4fa6c5e3ef", "git_parents": ["2c6f9766eef09664eb3aaaf3fedc27b8b08297dc"], "node": "967acf2b837809120ed1bc1b9af1faa68e610031", "parents": ["543f3f7917ea01ef02bd91d5bbb1a350a83efb29"], "tags": []}], "date": 1777422931, "git_changesets": ["54faee48aa7192e7915682d0f8ef9a4fa6c5e3ef"], "user": "dmeehan@mozilla.com"}, "26010": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Import translations from main\n", "files": ["mobile/android/android-components/components/browser/engine-system/src/main/res/values-zh-rTW/strings.xml", "mobile/android/android-components/components/browser/errorpages/src/main/res/values-ur/strings.xml", "mobile/android/android-components/components/browser/menu/src/main/res/values-ur/strings.xml", "mobile/android/android-components/components/compose/awesomebar/src/main/res/values-ur/strings.xml", "mobile/android/android-components/compon