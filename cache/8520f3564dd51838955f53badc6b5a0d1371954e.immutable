e34c1", "parents": ["d05094165a04d828d5bd3ea1046267e941c6f30d"], "tags": []}], "date": 1777908090, "git_changesets": ["00ff0e014f2c7411ed0efde45c8c3f3948b81f7b"], "user": "ffxbld@lando.moz.tools"}, "26125": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update remote-settings tld-suffixes ct-logs -  a=dmeehan\n\nDifferential Revision: https://phabricator.services.mozilla.com/D298085\n", "files": ["netwerk/dns/effective_tld_names.dat", "security/ct/CTKnownLogs.h", "security/manager/tools/log_list.json", "services/settings/dumps/blocklists/addons-bloomfilters.json", "services/settings/dumps/security-state/intermediates.json"], "git_node": "871562673ecf7d0c34abddd1393e54a3a03ff342", "git_parents": ["0c6c93b0606c3f6e7394b0de8ddf2c72096678ec"], "node": "2a7844ae1da020d2fa6e24e9b236c88b741ac232", "parents": ["3c78b7db28f099d3f172fd95c3f81ae81c752b40"], "tags": []}], "date": 1777909603, "git_changesets": ["871562673ecf7d0c34abddd1393e54a3a03ff342"], "user": "dmeehan@mozilla.com"}, "26126": {"changesets": [{"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 2033610 - Check cairo image surface for error.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D298051\n\nDifferential Revision: https://phabricator.services.mozilla.com/D298158\n", "files": ["gfx/cairo/cairo/src/win32/cairo-dwrite-font.cpp", "gfx/cairo/patches/0032-Bug-2033610-Check-cairo-image-surface-for-error.patch"], "git_node": "9cef2a3bc8fc05b93e24d494809c69dcd35d2cf5", "git_parents": ["871562673ecf7d0c34abddd1393e54a3a03ff342"], "node": "216ba9c10dea1a1fa4727095c3fee09008b6f74f", "parents": ["2a7844ae1da020d2fa6e24e9b236c88b741ac232"], "tags": []}], "date": 1777909644, "git_changesets": ["9cef2a3bc8fc05b93e24d494809c69dcd35d2cf5"], "user": "dmeehan@mozilla.com"}, "26127": {"changesets": [{"author": "Lars Eggert \u003clars@eggert.org\u003e", "branch": "default", "desc": "Bug 2033073 - Retry stale PSK resumptions when no early data was offered  a=dmeehan\n\nThe DECRYPT_ERROR_ALERT retry added in this bug only fires when\nmEarlyDataWasAvailable is true. Servers that don't advertise\nmax_early_data_size (e.g. wptserve, many real-world servers) never\nhit it, so a stale persisted session ticket surfaces as a fatal\n\"Secure Connection Failed\" instead of being evicted and retried.\n\n- Move PossibleZeroRTTRetryError() into the outer Close() restart\n  condition so the retry path runs regardless of early-data state.\n- Extend the alert list with illegal_parameter, handshake_failure,\n  decode_error, internal_error, missing_extension, and others that\n  PSK rejection can plausibly trigger. Cert-validation alerts stay\n  excluded since they would fail identically on a fresh handshake.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D297580\n\nDifferential Revision: https://phabricator.services.mozilla.com/D298185\n", "files": ["modules/libpref/init/StaticPrefList.yaml", "netwerk/base/FuzzySocketControl.cpp", "netwerk/protocol/http/HappyEyeballsTransaction.cpp", "netwerk/protocol/http/HappyEyeballsTransaction.h", "netwerk/protocol/http/Http2Session.h", "netwerk/protocol/http/TlsHandshaker.cpp", "netwerk/protocol/http/nsAHttpTransaction.h", "netwerk/protocol/http/nsHttpConnection.cpp", "netwerk/protocol/http/nsHttpTransaction.cpp", "netwerk/protocol/http/nsHttpTransaction.h", "netwerk/test/unit/head_channels.js", "netwerk/test/unit/test_retry_illegal_parameter.js", "netwerk/test/unit/test_retry_psk_no_early_data.js", "netwerk/test/unit/test_websocket_server.js", "netwerk/test/unit/xpcshell.toml", "security/manager/ssl/CommonSocketControl.cpp", "security/manager/ssl/nsITLSSocketControl.idl", "security/manager/ssl/tests/unit/tlsserver/cmd/FaultyServer.cpp"], "git_node": "f86ca77a5e3dad16ff9191552f380000de6b55ed", "git_parents": ["9cef2a3bc8fc05b93e24d494809c69dcd35d2cf5"], "node": "ef9ce10695acb50d0fc065a6370c530b1080f234", "parents": ["216ba9c10dea1a1fa4727095c3fee09008b6f74f"], "tags": []}], "date": 1777909687, "git_changesets": ["f86ca77a5e3dad16ff9191552f380000de6b55ed"], "user": "dmeehan@mozilla.com"}, "26128": {"changesets": [{"author": "Jari Jalkanen \u003cjjalkanen@mozilla.com\u003e", "branch": "default", "desc": "Bug 2027255: Clean up and document reference pointer actor lifecycle.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295899\n\nDifferential Revision: https://phabricator.services.mozilla.com/D298186\n", "files": ["dom/file/MutableBlobStorage.cpp"], "git_node": "4444ca3279fcaff8c1a10eefa0db77b05b245dce", "git_parents": ["f86ca77a5e3dad16ff9191552f380000de6b55ed"], "node": "e7a00705593ceafb64128ddaeba97fef7e7ca2f8", "parents": ["ef9ce10695acb50d0fc065a6370c530b1080f234"], "tags": []}], "date": 1777909728, "git_changesets": ["4444ca3279fcaff8c1a10eefa0db77b05b245dce"], "user": "dmeehan@mozilla.com"}, "26129": {"changesets": [{"author": "Jari Jalkanen \u003cjjalkanen@mozilla.com\u003e", "branch": "default", "desc": "Bug 2025412: Simplify OPFS move and rename interfaces.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295928\n\nDifferential Revision: https://phabricator.services.mozilla.com/D298188\n", "files": ["dom/fs/api/FileSystemHandle.h", "dom/fs/child/FileSystemRequestHandler.cpp"], "git_node": "36b3edd3378a44ce11a838a7cdef03a37208ca10", "git_parents": ["4444ca3279fcaff8c1a10eefa0db77b05b245dce"], "node": "f9f6f08ebb3464469cdde9e46f04e47fe4471504", "parents": ["e7a00705593ceafb64128ddaeba97fef7e7ca2f8"], "tags": []}], "date": 1777909768, "git_changesets": ["36b3edd3378a44ce11a838a7cdef03a37208ca10"], "user": "dmeehan@mozilla.com"}, "26130": {"changesets": [{"author": "Eden Chuang \u003cechuang@mozilla.com\u003e", "branch": "default", "desc": "Bug 2024418 - Make Console::StoreCallData() and Console::UnstoreCallData be not re-entrant during RetrievingConsoleEvents.  a=dmeehan\n\nOriginal Revision: https://phabricator.serv