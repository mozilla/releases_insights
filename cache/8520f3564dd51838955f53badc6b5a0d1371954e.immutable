mozilla.com/D298668\n\nDifferential Revision: https://phabricator.services.mozilla.com/D299579\n", "files": ["browser/components/search/test/browser/telemetry/browser_search_telemetry_sources.js", "browser/components/urlbar/SearchModeSwitcher.sys.mjs", "browser/components/urlbar/tests/browser-UrlbarInput/browser_searchTerms_searchModeSwitcher.js", "browser/components/urlbar/tests/browser-searchMode/browser_searchModeSwitcher_basic.js", "browser/components/urlbar/tests/browser-searchMode/browser_searchModeSwitcher_searchMode.js", "browser/components/urlbar/tests/browser/searchbar/browser_searchbarOverflow.js", "browser/components/urlbar/tests/engagementTelemetry/browser/browser_glean_telemetry_search_mode_switcher.js"], "git_node": "2b4696d44a5680ade4166ff79320b87b0c26d38b", "git_parents": ["ec33d5f0901d604de84abd6da39357681979442c"], "node": "4a8bf52096fe8156c60adc1d329ccd2e2b5b32d7", "parents": ["eb42b9eb00cac49227a5ca7dd3ae201bdf832f3f"], "tags": []}], "date": 1778445731, "git_changesets": ["2b4696d44a5680ade4166ff79320b87b0c26d38b"], "user": "dmeehan@mozilla.com"}, "26270": {"changesets": [{"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 2028319, part 1 - Make IsDataInBuffer into a regular method.  a=dmeehan\n\nIt is only called in one place. This makes later changes simpler.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D298569\n\nDifferential Revision: https://phabricator.services.mozilla.com/D299590\n", "files": ["dom/xul/nsXULContentSink.cpp", "dom/xul/nsXULContentSink.h"], "git_node": "ec05b3a16da190587298b31c31935f71a909a46c", "git_parents": ["2b4696d44a5680ade4166ff79320b87b0c26d38b"], "node": "9d12b398f36b86b1271e883db7bd155296c36791", "parents": ["4a8bf52096fe8156c60adc1d329ccd2e2b5b32d7"], "tags": []}, {"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 2028319, part 2 - Convert XULContentSinkImpl::mText to an nsTArray, and make AddText take a Span.  a=dmeehan\n\nmTextSize becomes mText.Capacity().\nmTextLength becomes mText.Length().\n\nConvert various variables to size_t for consistency.\n\nnsTArray internally uses some kind of fancy growth strategy, so the memory usage\nwon't be exactly the same, but hopefully that doesn't matter. The way it\ninternally tracks length and capacity like we need is very convenient.\n\nSkip the end of the loop if there is no space remaining, because it won't do\nanything. To make things clearer, don't calculate how many characters are to be\ncopied until we've determined that there is still space.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D298570\n\nDifferential Revision: https://phabricator.services.mozilla.com/D299591\n", "files": ["dom/xul/nsXULContentSink.cpp", "dom/xul/nsXULContentSink.h"], "git_node": "7e7b9c8334eff0fad1b5cbc6647d99b6c673cf2a", "git_parents": ["ec05b3a16da190587298b31c31935f71a909a46c"], "node": "72f207f6f16404b276c198b46c733f1ceb19cc5e", "parents": ["9d12b398f36b86b1271e883db7bd155296c36791"], "tags": []}, {"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 2028319, part 3 - Convert nsXMLContentSink::mText to an AutoTArray, and make AddText take a Span.  a=dmeehan\n\nBasically a simpler version of the previous patch.\n\nNS_ACCUMULATION_BUFFER_SIZE becomes mText.Capacity().\nmTextLength becomes mText.Length().\n\nOriginal Revision: https://phabricator.services.mozilla.com/D299215\n\nDifferential Revision: https://phabricator.services.mozilla.com/D299592\n", "files": ["dom/xml/nsXMLContentSink.cpp", "dom/xml/nsXMLContentSink.h", "dom/xml/nsXMLFragmentContentSink.cpp"], "git_node": "180afd451e740f47c5044dc22e0afd30b5ff5d99", "git_parents": ["7e7b9c8334eff0fad1b5cbc6647d99b6c673cf2a"], "node": "1dad9a4e7c6f9facb387733b9310a7be663bc25b", "parents": ["72f207f6f16404b276c198b46c733f1ceb19cc5e"], "tags": []}], "date": 1778445770, "git_changesets": ["ec05b3a16da190587298b31c31935f71a909a46c", "7e7b9c8334eff0fad1b5cbc6647d99b6c673cf2a", "180afd451e740f47c5044dc22e0afd30b5ff5d99"], "user": "dmeehan@mozilla.com"}, "26271": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update remote-settings mobile-experiments ct-logs -  a=dmeehan\n\nDifferential Revision: https://phabricator.services.mozilla.com/D299589\n", "files": ["mobile/android/fenix/app/src/main/res/raw/initial_experiments.json", "security/ct/CTKnownLogs.h", "security/manager/tools/log_list.json", "services/settings/dumps/blocklists/addons-bloomfilters.json", "services/settings/dumps/main/ai-window-prompts.json", "services/settings/dumps/security-state/onecrl.json"], "git_node": "64686f8854a92cacdc719372b387fb36c1e896c2", "git_parents": ["180afd451e740f47c5044dc22e0afd30b5ff5d99"], "node": "0a9f8d02f5557a3a0a62329bee6548988903e41e", "parents": ["1dad9a4e7c6f9facb387733b9310a7be663bc25b"], "tags": []}], "date": 1778445921, "git_changesets": ["64686f8854a92cacdc719372b387fb36c1e896c2"], "user": "dmeehan@mozilla.com"}, "26272": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Import translations from main\n", "files": ["mobile/android/android-components/components/browser/errorpages/src/main/res/values-fur/strings.xml", "mobile/android/android-components/components/compose/base/src/main/res/values-sr/strings.xml", "mobile/android/android-components/components/feature/summarize/src/main/res/values-cs/strings.xml", "mobile/android/fenix/app/src/main/res/values-cs/strings.xml", "mobile/android/fenix/app/src/main/res/values-es-rCL/strings.xml", "mobile/android/fenix/app/src/main/res/values-es-rMX/strings.xml", "mobile/android/fenix/app/src/main/res/values-ia/strings.xml", "mobile/android/fenix/app/src/main/res/values-iw/strings.xml", "mobile/android/fenix/app/src/main/res/values-ja/strings.xml", "mobile/android/fenix/app/src/main