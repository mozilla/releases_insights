a6d5", "git_parents": ["eba9d89cf91041148fda846024793d0e352b81fd"], "node": "0e207bebc6154f417b2ba134dd641a887c222a0d", "parents": ["e115d1da405f5696c9603c4b316eed113f25201a"], "tags": []}], "date": 1777053082, "git_changesets": ["8f5fd13d82bb9811121f9dea5cfb02e8de7ba6d5"], "user": "dmeehan@mozilla.com"}, "25916": {"changesets": [{"author": "Alexandra Borovova \u003caborovova@mozilla.com\u003e", "branch": "default", "desc": "Bug 2033269 - Update metadata for pointerevents/touch-action-with-swipe-dir-change.html.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295224\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295829\n", "files": ["testing/web-platform/meta/pointerevents/touch-action-with-swipe-dir-change.html.ini"], "git_node": "d277d4c6fe54f4fb8cb078563d5c3f2d62b9e268", "git_parents": ["8f5fd13d82bb9811121f9dea5cfb02e8de7ba6d5"], "node": "c9e8670415d1f11e620b1565f9fcfdb233792a10", "parents": ["0e207bebc6154f417b2ba134dd641a887c222a0d"], "tags": []}], "date": 1777053124, "git_changesets": ["d277d4c6fe54f4fb8cb078563d5c3f2d62b9e268"], "user": "dmeehan@mozilla.com"}, "25917": {"changesets": [{"author": "Mugurell \u003cMugurell@users.noreply.github.com\u003e", "branch": "default", "desc": "Bug 2027911 - Set e2e strategy for shown fragments as soon as they're attached.  a=dmeehan\n\nThe bug report showed that the current `doOnPreDraw` - after the fragment's layout is built\nbut before it is drawn on screen - is too slow for out needs.\n\nMoved to using `doOnAttach` instead that runs when that view is attached to a window - if the\nview is already attached it runs immediately, otherwise it runs the next time the view attaches.\nIt is a one-shot callback that automatically gets disposed after the first run.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295765\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296356\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/e2e/EdgeToEdgeFragmentLifecycleCallbacks.kt"], "git_node": "563c7e8f8bfaac21dbb3d111ee574ed66ba3da4d", "git_parents": ["d277d4c6fe54f4fb8cb078563d5c3f2d62b9e268"], "node": "77dbec293348d1f0841ae5701dedd4f6c4f34a80", "parents": ["c9e8670415d1f11e620b1565f9fcfdb233792a10"], "tags": []}, {"author": "Mugurell \u003cMugurell@users.noreply.github.com\u003e", "branch": "default", "desc": "Bug 2029378 - Avoid updating the e2e strategy when navigating to fragments with a DialogFragment parent  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295817\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296357\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/e2e/EdgeToEdgeFragmentLifecycleCallbacks.kt"], "git_node": "39aa8def758eddc5122273aba76682832e1fc25a", "git_parents": ["563c7e8f8bfaac21dbb3d111ee574ed66ba3da4d"], "node": "f764222a059ecf377443d4fc3cfcf363a127031b", "parents": ["77dbec293348d1f0841ae5701dedd4f6c4f34a80"], "tags": []}], "date": 1777053215, "git_changesets": ["563c7e8f8bfaac21dbb3d111ee574ed66ba3da4d", "39aa8def758eddc5122273aba76682832e1fc25a"], "user": "dmeehan@mozilla.com"}, "25918": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2033469 - Fix autoscroll check for \u003ctextarea\u003e.  a=dmeehan\n\n\u003ctextarea\u003e is scrollable even without a computed overflow of \"auto\".\n\nWe're already checking scrollTopMax etc which are the real \"is this\nscrollable\" check.\n\nThis needs a test.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295300\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296361\n", "files": ["toolkit/actors/AutoScrollChild.sys.mjs", "toolkit/content/tests/browser/browser_bug295977_autoscroll_overflow.js"], "git_node": "d2d335b1f9ead9e11e8c485ccfc4c7a249087108", "git_parents": ["39aa8def758eddc5122273aba76682832e1fc25a"], "node": "29b632db8eafc7bf560c0106844b1ef1ac978