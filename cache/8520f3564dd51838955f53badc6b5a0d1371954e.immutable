-\u003e b1049dd5beffcdc19c360d77b89102e4a0aaf39e\nzh-TW -\u003e b1049dd5beffcdc19c360d77b89102e4a0aaf39e\n", "files": ["mobile/locales/l10n-changesets.json"], "git_node": "de4106f29fe8c6d66c4c9f07b31215d636f44081", "git_parents": ["e0563106abf70bdf8302a196d3e1a86cea096722"], "node": "d8d675e1bfbee35c97f0e39fbfc43a58d89ff9ee", "parents": ["4f47cf2c3ec4fa3c5f4e12ace60c700f731e5ff3"], "tags": []}], "date": 1778144620, "git_changesets": ["e0563106abf70bdf8302a196d3e1a86cea096722", "de4106f29fe8c6d66c4c9f07b31215d636f44081"], "user": "ffxbld@lando.moz.tools"}, "26214": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging f886be72b68e40ef310bed24350a841eb9ee07e9 with FIREFOX_150_0_2_RELEASE a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "0d0e6d86569546b6a2cb63a2a6553f5ac4fe61c3", "git_parents": ["7673eee6c3dcd797899e3633d1f74f3f2a9dfa02"], "node": "0476f1b85e3ad90dec7ef4dad3ea3e72da2ea6d1", "parents": ["b9b7785247e7b04de43f141a42d59dad3f180512"], "tags": []}], "date": 1778156868, "git_changesets": ["0d0e6d86569546b6a2cb63a2a6553f5ac4fe61c3"], "user": "ffxbld@lando.moz.tools"}, "26215": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging 6220f392be743517c45c0a46b455d7a57c0b9891 with FIREFOX_140_10_2esr_RELEASE a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "9def335f33162db8452b91c9d2bab6e4f5f7c068", "git_parents": ["0d0e6d86569546b6a2cb63a2a6553f5ac4fe61c3"], "node": "14bc459619bedde21f97703d259f51ca4edb3c26", "parents": ["0476f1b85e3ad90dec7ef4dad3ea3e72da2ea6d1"], "tags": []}], "date": 1778157403, "git_changesets": ["9def335f33162db8452b91c9d2bab6e4f5f7c068"], "user": "ffxbld@lando.moz.tools"}, "26216": {"changesets": [{"author": "Alice Boxhall \u003calice@igalia.com\u003e", "branch": "default", "desc": "Bug 2029571 - Ensure form association still works correctly when ID and form attr are equal.  a=dmeehan\n\nThe linked bug was being triggered because the ID and form attribute were the same, which caused a sequence of events such that the form association was not correctly set up:\n- When the element with the form attribute is created, nsGenericHTMLElement::AfterSetAttr() calls into AddFormAttributeObserver(),\n- which calls Element::AddAttrAssociatedElementObserver(),\n- which initialises its mLastKnownAttrElement to the element with the identical form and ID attribute, as GetAttrAssociatedElementInternal() calls into GetElementByIdInDocOrSubtree()\n- Then, when the element is bound to the document, UpdateFormOwner() calls into AddFormAttributeObserver() again,\n- which calls into Element::AddAttrAssociatedElementObserver() again\n- which returns the *old* value for mLastKnownAttrElement.\n\nThis change ensures that when the element is bound to a new tree, it checks for attr-associated element updates from the ID scope changing, and calls listeners if the attr-associated element has changed.\nThis causes FormAttributeUpdated to fire, ensuring the correct form is associated with the element.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D293534\n\nDifferential Revision: https://phabricator.services.mozilla.com/D298794\n", "files": ["dom/base/Element.cpp", "testing/web-platform/tests/html/semantics/forms/form-control-infrastructure/form_attribute.html"], "git_node": "746d4bedc0f56b78c6d5da64d3199f82358fd796", "git_parents": ["de4106f29fe8c6d66c4c9f07b31215d636f44081"], "node": "a674fa1bf19790d6b7ff1f5a007bb630d5826d30", "parents": ["d8d675e1bfbee35c97f0e39fbfc43a58d89ff9ee"], "tags": []}], "date": 1778157556, "git_changesets": ["746d4bedc0f56b78c6d5da64d3199f82358fd796"], "user": "dmeehan@mozilla.com"}, "26217": {"changesets": [{"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 2032367 - Fix extension window type to \"normal\" on Android  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D298529\n\nDifferential Revision: https://phabricator.services.mozilla.com/D298965\n", "files": ["mobile/shared/components/extensions/ext-android.js", "mobile/shared/components/extensions/test/mochitest/test_ext_tabs_query.html"], "git_node": "f2150010b6bb8a9f0e232b5058bf5c2a9efa7a3d", "git_parents": ["746d4bedc0f56b78c6d5da64d3199f82358fd796"], "node": "548148599da29e6b8e5b623ae93bdae9049d06eb", "parents": ["a674fa1bf19790d6b7ff1f5a007bb630d5826d30"], "tags": []}], "date": 1778157658, "git_changesets": ["f2150010b6bb8a9f0e232b5058bf5c2a9efa7a3d"], "user": "dmeehan@mozilla.com"}, "26218": {"changesets": [{"author": "Hubert B Manilla \u003chmanilla@mozilla.com\u003e", "branch": "default", "desc": "Bug 2035205 - [devtools] Fix browser_net_frame to properly assert request stackframes  a=dmeehan DONTBUILD\n\nThe test was not properly asserting the expected values of the stacktrace.\nI guess because it was failing before D295965\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296908\n\nDifferential Revision: https://phabricator.services.mozilla.com/D299031\n", "files": ["devtools/client/netmonitor/test/browser_al.toml", "devtools/client/netmonitor/test/browser_net_frame.js"], "git_node": "f5cb475d4b509a22549295310a0b18811267dc85", "git_parents": ["f2150010b6bb8a9f0e232b5058bf5c2a9efa7a3d"], "node": "30f1db10c09e0fbe3c82b4759be9651d0ecc3498", "parents": ["548148599da29e6b8e5b623ae93bdae9049d06eb"], "tags": []}], "date": 1778157698, "git_changesets": ["f5cb475d4b509a22549295310a0b18811267dc85"], "user": "dmeehan@mozilla.com"}, "26219": {"changesets": [{"author": "Noah Bond \u003cnbond@mozilla.com\u003e", "branch": "default", "desc": "Bug 2035885 - Move TabManagementFragment back to a regular Fragment  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D297514\n\nDifferential Revision: https://phabricator.services.mozilla.com/D299000\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/tabstray/controller/TabMana