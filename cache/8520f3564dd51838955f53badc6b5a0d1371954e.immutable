ets": [{"author": "Jens Stutte \u003cjstutte@mozilla.com\u003e", "branch": "default", "desc": "Bug 2037545 - Defer base_chunk_dealloc out of BaseAlloc::free's locked region.  a=dmeehan\n\nbase_chunk_dealloc transitively re-enters BaseAlloc::alloc via chunk_record's\nextent_node_t allocation. Since Mutex is non-recursive (Linux pthread adaptive,\nmacOS os_unfair_lock), this self-deadlocks on Linux and traps with SIGILL on\nmacOS. Capture the chunk under the lock and dealloc after dropping it; the\nalloc path already takes the symmetric precaution via base_chunk_alloc.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D299319\n\nDifferential Revision: https://phabricator.services.mozilla.com/D299540\n", "files": ["memory/build/BaseAlloc.cpp"], "git_node": "8f996aa797d80b4b14de443922e9aeafcf3a8fe9", "git_parents": ["272574cd6ab33151543790df7c06486d3f60b146"], "node": "50d7d01270297dd03c580225af19d8231839bb7b", "parents": ["283a251871f4475841aba7e96234803e0aec00a2"], "tags": []}], "date": 1778345019, "git_changesets": ["8f996aa797d80b4b14de443922e9aeafcf3a8fe9"], "user": "dmeehan@mozilla.com"}, "26264": {"changesets": [{"author": "Stephanie Cunnane \u003cscunnane@mozilla.com\u003e", "branch": "default", "desc": "Bug 2037402 - Ensure panel-list opened above moz-select doesn't overlap the button.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D298983\n\nDifferential Revision: https://phabricator.services.mozilla.com/D299550\n", "files": ["toolkit/content/tests/widgets/test_panel_list_anchoring.html", "toolkit/content/widgets/panel-list/panel-list.mjs"], "git_node": "db1dca0177886c8468bae789ad9d691f85dabf19", "git_parents": ["8f996aa797d80b4b14de443922e9aeafcf3a8fe9"], "node": "2993099cd095bfab35b0c0bd59445ca8dd3e2ed1", "parents": ["50d7d01270297dd03c580225af19d8231839bb7b"], "tags": []}], "date": 1778345057, "git_changesets": ["db1dca0177886c8468bae789ad9d691f85dabf19"], "user": "dmeehan@mozilla.com"}, "26265": {"changesets": [{"aut