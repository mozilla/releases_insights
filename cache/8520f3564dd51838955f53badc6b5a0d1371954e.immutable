mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP -  a=dmeehan\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296452\n", "files": ["security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc"], "git_node": "88ab99e0989ec40318a3742fd1d8490a123d71f7", "git_parents": ["4f2636b6c969f2e9f4f72908a55841294800e0fe"], "node": "ffa7e9db2434f0e1a4f6abf53e0bb6af1139102d", "parents": ["c2f0a330c3dcdb191a0371a6a9368fecbdba6d99"], "tags": []}], "date": 1777122947, "git_changesets": ["88ab99e0989ec40318a3742fd1d8490a123d71f7"], "user": "dmeehan@mozilla.com"}, "25926": {"changesets": [{"author": "Punam Dahiya \u003cpdahiya@mozilla.com\u003e", "branch": "default", "desc": "Bug 2021973 - Smartbar inputCTA Search with submenu  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D292548\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296482\n", "files": ["browser/components/aiwindow/ui/components/input-cta/input-cta.css", "browser/components/aiwindow/ui/components/input-cta/input-cta.mjs", "browser/components/aiwindow/ui/components/input-cta/input-cta.stories.mjs", "browser/components/aiwindow/ui/test/browser/browser.toml", "browser/components/aiwindow/ui/test/browser/browser_aiwindow_smartbar.js", "browser/components/aiwindow/ui/test/browser/browser_aiwindow_smartbar_input_cta.js", "browser/components/urlbar/content/SmartbarInput.mjs", "browser/locales-preview/aiWindow.ftl"], "git_node": "10dee3617f8393889bbcb9d73a5279f6a7aa5c6f", "git_parents": ["88ab99e0989ec40318a3742fd1d8490a123d71f7"], "node": "16c87bfadcc74ada5cc6733f752a698410702c32", "parents": ["ffa7e9db2434f0e1a4f6abf53e0bb6af1139102d"], "tags": []}], "date": 1777123047, "git_changesets": ["10dee3617f8393889bbcb9d73a5279f6a7aa5c6f"], "user": "dmeehan@mozilla.com"}, "25927": {"changesets": [{"author": "Elissa Cha \u003cecha@mozilla.com\u003e", "branch": "default", "desc": "Bug 2029229 - Enable back/forward navigation across Smart Window states  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D292872\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296395\n", "files": ["browser/components/aiwindow/ui/modules/AIWindow.sys.mjs", "browser/components/aiwindow/ui/test/browser/browser_aiwindow_immersive.js", "browser/themes/shared/browser-shared.css"], "git_node": "a6a06099167a7f6bc386f2eb6f55002840e391df", "git_parents": ["10dee3617f8393889bbcb9d73a5279f6a7aa5c6f"], "node": "ac678107de85e810a176497162b1875a972b31e9", "parents": ["16c87bfadcc74ada5cc6733f752a698410702c32"], "tags": []}], "date": 1777123133, "git_changesets": ["a6a06099167a7f6bc386f2eb6f55002840e391df"], "user": "dmeehan@mozilla.com"}, "25928": {"changesets": [{"author": "Maxx Crawford \u003cmcrawford@mozilla.com\u003e", "branch": "default", "desc": "Bug 2031707 - Sync weather pref between about:preferences#home and Nova widget panel.  a=dmeehan\n\nIn Nova mode, the Customization Panel weather toggle writes widgets.weather.enabled, but about:preferences#home was bound to the classic showWeather pref, leaving the two out of sync.\n\nFix both the settings-redesign path (_setupHomeGroup) and the legacy path (PREFS_FOR_SETTINGS) in AboutPreferences to read/write widgets.weather.enabled (with widgets.system.weather.enabled as the system gate) when nova.enabled is true.\n\nUpdate WeatherFeed.isEnabled() and onPrefChangedAction to react to widgets.weather.enabled in Nova mode, and update Base.jsx and ContentSection.jsx to use the correct pref for weatherEnabled and the fallback weather toggle. Add nova-cleanup comments to all new Nova-conditional branches.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295118\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296447\n", "files": ["browser/components/preferences/tests/home/browser_homepage_firefox_home.js", "browser/extensions/newtab/content-src/components/Base/Base.jsx", "browser/extensions/newtab/content-src/components/CustomizeMenu/ContentSection/ContentSection.jsx", "browser/extensions/newtab/data/content/activity-stream.bundle.js", "browser/extensions/newtab/lib/AboutPreferences.sys.mjs", "browser/extensions/newtab/lib/WeatherFeed.sys.mjs", "browser/extensions/newtab/test/jest/content-src/components/Base.test.jsx", "browser/extensions/newtab/test/unit/lib/AboutPreferences.test.js", "browser/extensions/newtab/test/xpcshell/test_WeatherFeed.js"], "git_node": "73d03246ff5ee7b269f6df8c8c6a9f63322fdf0b", "git_parents": ["a6a06099167a7f6bc386f2eb6f55002840e391df"], "node": "0613cb2cd7669f399276150804f64f7a85cb3602", "parents": ["ac678107de85e810a176497162b1875a972b31e9"], "tags": []}], "date": 1777123176, "git_changesets": ["73d03246ff5ee7b269f6df8c8c6a9f63322fdf0b"], "user": "dmeehan@mozilla.com"}, "25929": {"changesets": [{"author": "Roger Yang \u003croyang@mozilla.com\u003e", "branch": "default", "desc": "Bug 2034530 - Move third party sharing configuration to before Adjust initialization.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296145\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296191\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/components/metrics/AdjustMetricsService.kt"], "git_node": "85a6dee0226c831a543350791170f819ce7070f9", "git_parents": ["73d03246ff5ee7b269f6df8c8c6a9f63322fdf0b"], "node": "a200287f14aa9584ac74e7ec31ab44b30126076c", "parents": ["0613cb2cd7669f399276150804f64f7a85cb3602"], "tags": []}], "date": 1777123220, "git_changesets": ["85a6dee0226c831a543350791170f819ce7070f9"], "user": "dmeehan@mozilla.com"}, "25930": {"changesets": [{"author": "Jan-Ivar Bruaroey \u003cjib@mozilla.com\u003e", "branch": "default", "desc": "Bug 2029899 - Use default string initialization r=webrtc-reviewers,bwc a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295914\n\nDifferential Revision: https://phabricator.services.mozilla.com/D295948