 call\n  start \"\" \"https://bing.com/search?q=test\"\ntwice and then go to about:glean and force metrics telemetry to be send.\nThis will only work if the browser is configured as default browser.\n\nThe automated test can be executed with:\n  ./mach test browser/components/tests/browser/browser_telemetry_activation.js\n\nOriginal Revision: https://phabricator.services.mozilla.com/D290452\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296066\n", "files": ["browser/base/content/metrics.yaml", "browser/components/BrowserContentHandler.sys.mjs", "browser/components/tests/browser/browser.toml", "browser/components/tests/browser/browser_telemetry_activation.js", "browser/components/tests/browser/browser_to_handle_telemetry.js"], "git_node": "a7373829d263cc4af5106e0790d028e62c894146", "git_parents": ["33584c84d3ae3ad73e7b167030c7784c3327b1a8"], "node": "af955404b355d749835f66ce6024783ad44f1b4e", "parents": ["378ab48f37fa09c6b7772451ee639cc9e6db76b5"], "tags": []}], "date": 1776969545, "git_changesets": ["a7373829d263cc4af5106e0790d028e62c894146"], "user": "dmeehan@mozilla.com"}, "25896": {"changesets": [{"author": "Lars Eggert \u003clars@eggert.org\u003e", "branch": "default", "desc": "Bug 2033073 - Retry connections that fail with SSL_ERROR_DECRYPT_ERROR_ALERT  a=dmeehan\n\nWhen a persisted TLS session ticket is rejected by a server with a fatal\ndecrypt_error alert (e.g. session ticket encryption key rotation),\nPossibleZeroRTTRetryError now covers SSL_ERROR_DECRYPT_ERROR_ALERT, causing\nthe existing retry path to evict the stale token and retry with a full\nhandshake instead of surfacing \"Secure Connection Failed\".\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295702\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296104\n", "files": ["netwerk/protocol/http/nsHttp.cpp", "netwerk/test/unit/head_channels.js", "netwerk/test/unit/test_retry_0rtt.js", "netwerk/test/unit/test_retry_decrypt_error.js", "netwerk/test/unit/xpcshell.toml", "security/manager/ssl/tests/unit/tlsserver/cmd/FaultyServer.cpp"], "git_node": "bb61e518e1334953771cff15791fd53f02a243f9", "git_parents": ["a7373829d263cc4af5106e0790d028e62c894146"], "node": "56729b4fae7f795173a587798f543b1175fdc2aa", "parents": ["af955404b355d749835f66ce6024783ad44f1b4e"], "tags": []}], "date": 1776969594, "git_changesets": ["bb61e518e1334953771cff15791fd53f02a243f9"], "user": "dmeehan@mozilla.com"}, "25897": {"changesets": [{"author": "Beth Rennie \u003cbeth@brennie.ca\u003e", "branch": "default", "desc": "Bug 2033611 - Selectively clear opt-in list when updating recipes with a select set of features  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295565\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296108\n", "files": ["toolkit/components/nimbus/lib/ExperimentManager.sys.mjs", "toolkit/components/nimbus/lib/RemoteSettingsExperimentLoader.sys.mjs", "toolkit/components/nimbus/test/unit/test_RemoteSettingsExperimentLoader_updateRecipes.js"], "git_node": "603a2979318c5fcc07c205805b1e0735153900bd", "git_parents": ["bb61e518e1334953771cff15791fd53f02a243f9"], "node": "a2a249e3374d188fd48ded24d11709483fe7e5fb", "parents": ["56729b4fae7f795173a587798f543b1175fdc2aa"], "tags": []}], "date": 1776969711, "git_changesets": ["603a2979318c5fcc07c205805b1e0735153900bd"], "user": "dmeehan@mozilla.com"}, "25898": {"changesets": [{"author": "Irene Ni \u003cini@mozilla.com\u003e", "branch": "default", "desc": "Bug 2034098 - Adjust New Tab sponsored tile character count for Nova.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D295856\n\nDifferential Revision: https://phabricator.services.mozilla.com/D296122\n", "files": ["browser/extensions/newtab/content-src/styles/nova/_TopSites.scss", "browser/extensions/newtab/css/nova/activity-stream.css"], "git_node": "165599ce46416e2bed10b8cae791c57cf0e3a4a7", "git_parents": ["603a2979318c5fcc07c205805b1e0735153900bd"], "node":