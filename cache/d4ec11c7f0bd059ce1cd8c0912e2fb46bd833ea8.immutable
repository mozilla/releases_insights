n-result/ai-action-result.mjs", "browser/components/aiwindow/ui/test/browser/browser_aiwindow_ai_action_result.js", "browser/locales-preview/aiWindowContent.ftl"], "git_node": "f2125831cb4f791ab0269458fa0d3070575a0ddb", "git_parents": ["852bca8bfef27631a29f52263c31e477decaf051"], "node": "0366dcb36fa2271ec16e5979696049e9005987f4", "parents": ["5181cef885e288bdbda19177bd3525da137f69eb"], "tags": []}, {"author": "Yubin Jamora \u003cyjamora@mozilla.com\u003e", "branch": "default", "desc": "Bug 2037611 - Add action log container in tool call  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302565\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305433\n", "files": ["browser/components/aiwindow/ui/components/ai-chat-content/ai-chat-content.mjs", "browser/components/aiwindow/ui/components/ai-window/ai-window.mjs", "browser/components/aiwindow/ui/modules/ChatConversation.sys.mjs", "browser/components/aiwindow/ui/modules/ToolActionLog.sys.mjs", "browser/components/aiwindow/ui/moz.build", "browser/components/aiwindow/ui/test/xpcshell/test_ChatConversation.js", "browser/components/aiwindow/ui/test/xpcshell/test_ToolActionLog.js", "browser/components/aiwindow/ui/test/xpcshell/xpcshell.toml"], "git_node": "622746718ce3598d02c3a1415966964e192ba8a7", "git_parents": ["f2125831cb4f791ab0269458fa0d3070575a0ddb"], "node": "7cd130e1af18f6dbdfe5a47ba49484284d670812", "parents": ["0366dcb36fa2271ec16e5979696049e9005987f4"], "tags": []}, {"author": "Yubin Jamora \u003cyjamora@mozilla.com\u003e", "branch": "default", "desc": "Bug 2037612 - Render tool call rows in action log  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302886\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305434\n", "files": ["browser/components/aiwindow/ui/components/ai-chat-content/ai-chat-content.css", "browser/components/aiwindow/ui/components/ai-chat-content/ai-chat-content.mjs", "browser/components/aiwindow/ui/components/ai-chat-message/ai-chat-message.css", "browser/components/aiwindow/ui/components/ai-window/ai-window.mjs", "browser/components/aiwindow/ui/modules/ToolActionLog.sys.mjs", "browser/components/aiwindow/ui/test/browser/browser.toml", "browser/components/aiwindow/ui/test/browser/browser_aichat_content_action_log_order.js", "browser/components/aiwindow/ui/test/xpcshell/test_ToolActionLog.js", "browser/locales-preview/aiWindowContent.ftl"], "git_node": "0d63c38db654857f48f3bd5f3a3ac0caf41b7304", "git_parents": ["622746718ce3598d02c3a1415966964e192ba8a7"], "node": "db3f920c0eeefaf73de89bdc7d96016564d542c8", "parents": ["7cd130e1af18f6dbdfe5a47ba49484284d670812"], "tags": []}], "date": 1781035429, "git_changesets": ["f2125831cb4f791ab0269458fa0d3070575a0ddb", "622746718ce3598d02c3a1415966964e192ba8a7", "0d63c38db654857f48f3bd5f3a3ac0caf41b7304"], "user": "rvandermeulen@mozilla.com"}, "26825": {"changesets": [{"author": "chloezhouny \u003cchloezhouny@gmail.com\u003e", "branch": "default", "desc": "Bug 2034438 - Mark assistant search history entries as having user interaction so Back doesn't skip them  a=RyanVM\n\nWhen the assistant runs the search tool, it navigates the user's tab to the SERP programmatically. Because the navigation isn't a user gesture and the user typically doesn't scroll or click on the SERP before asking a follow-up, the resulting nsISHEntry never gets its hasUserInteraction flag set. With browser.navigation.requireUserInteraction on (the default), the Back button then skips that entry on the way back from any subsequent page, making it look like the SERP was never in history at all.\n\nSet hasUserInteraction = true on the new SHEntry right after the navigation completes in RunSearch.#performSearchAndWait, since the search was explicitly requested by the user via the assistant.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302900\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305708\n", "files": ["browser/components/aiwindow/models/Tools.sys.mjs", "browser/components/aiwindow/ui/test/browser/browser.toml", "browser/components/aiwindow/ui/test/browser/browser_run_search_back_navigation.js"], "git_node": "f69797987e838d35137d8f94b0eec1e1cba32bde", "git_parents": ["0d63c38db654857f48f3bd5f3a3ac0caf41b7304"], "node": "c3e6b67c3f8bce348e2639cfe1f10cb9442f6fdb", "parents": ["db3f920c0eeefaf73de89bdc7d96016564d542c8"], "tags": []}], "date": 1781036529, "git_changesets": ["f69797987e838d35137d8f94b0eec1e1cba32bde"], "user": "rvandermeulen@mozilla.com"}, "26826": {"changesets": [{"author": "Ryan VanderMeulen \u003crvandermeulen@mozilla.com\u003e", "branch": "default", "desc": "Revert \"Bug 2035568 - Add animated illustrations to about:welcome r=omc-reviewers,sachung\" for various regressions.\n\nThis reverts commit 85de3c6cffc83d182eb48db240454efc674e4935.\n", "files": ["browser/components/aboutwelcome/assets/br-clouds-animated.svg", "browser/components/aboutwelcome/assets/br-clouds.svg", "browser/components/aboutwelcome/assets/br-fox-heart-animated.svg", "browser/components/aboutwelcome/assets/br-fox-house-animated.svg", "browser/components/aboutwelcome/assets/br-fox-mirror-animated.svg", "browser/components/aboutwelcome/assets/br-fox-paint-animated.svg", "browser/components/aboutwelcome/assets/br-fox-rock-animated.svg", "browser/components/aboutwelcome/jar.mn", "browser/components/aboutwelcome/modules/AboutWelcomeDefaults.sys.mjs"], "git_node": "e875b59274cd35da5ec52d29958b927cdb5d5586", "git_parents": ["f69797987e838d35137d8f94b0eec1e1cba32bde"], "node": "485c61e8ad50456e46e6418c0d4f5f36122f5670", "parents": ["c3e6b67c3f8bce348e2639cfe1f10cb9442f6fdb"], "tags": []}], "date": 1781037317, "git_changesets": ["e875b59274cd35da5ec52d29958b927cdb5d5586"], "user": "rvandermeulen@mozilla.com"}, "26827": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update remote-settings tld-suffixes mobile-merino-manifest ct-logs -  a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305702\n", "files": ["mobile/android/android-components/components/service/merino-manifest/src/main/assets/manifest/manifest.json", "netwerk/dns/effective_tld_names.dat", "security/ct/CTKnownLogs.h", "security/manager/tools/log_list.json", "services/settings/dumps/blocklists/addons-bloomfilters.json", "services/settings/dumps/main/devtools-compatibility-browsers.json", "services/settings/dumps/main/newtab-wallpapers-v2.json", "services/settings/dumps/security-state/intermediates.json"], "git_node": "b3f76da4eb931c6ec008f5edce93dd0a1ab0382f", "git_parents": ["e875b59274cd35da5ec52d29958b927cdb5d5586"], "node": "3f05891f48e7da96b331ec06036d188cf2eb763e", "parents": ["485c61e8ad50456e46e6418c0d4f5f36122f5670"], "tags": []}], "date": 1781037470, "git_changesets": ["b3f76da4eb931c6ec008f5edce93dd0a1ab0382f"], "user": "rvandermeulen@mozilla.com"}, "26828": {"changesets": [{"author": "Moyin \u003cmadeyemi@mozilla.com\u003e", "branch": "default", "desc": "Bug 2044743: Add Share menu option to Sports Widget  a=RyanVM\n\n{F72263088}\n\n{F72263087}\n\n{F72263086}\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305179\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305654\n", "files": ["mobile/android/fenix/app/metrics.yaml", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/HomeFragment.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/fake/FakeHomepagePreview.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sessioncontrol/SessionControlInteractor.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/SportsController.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/SportsInteractor.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/ui/ChampionsCard.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/ui/SportWidgetMenu.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/ui/SportsCardPager.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/ui/SportsWidget.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/ui/Homepage.kt", "mobile/android/fenix/app/src/main/res/values/strings.xml", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/home/SessionControlInteractorTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/home/sports/SportsControllerTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/home/sports/ui/SportsWidgetTest.kt"], "git_node": "76ac32786785dc1f653c77050e19b5cd3aea9dfa", "git_parents": ["b3f76da4eb931c6ec008f5edce93dd0a1ab0382f"], "node": "2580400a82a83e8f06855db7394876c766dda063", "parents": ["3f05891f48e7da96b331ec06036d188cf2eb763e"], "tags": []}], "date": 1781048844, "git_changesets": ["76ac32786785dc1f653c77050e19b5cd3aea9dfa"], "user": "rvandermeulen@mozilla.com"}, "26829": {"changesets": [{"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 2045924 - Handle is_top_pick AMP suggestions from Merino.  a=RyanVM\n\nThis modifies the \"is top pick?\" logic in `AmpSuggestions` so it checks for\n`suggestion.is_top_pick`.\n\nI considered modifying `UrlbarProviderQuickSuggest` so that it checks for\n`is_top_pick` in all Merino suggestions, AMP and otherwise, but decided against\nit for a couple of reasons:\n\n(1) It would be more complicated since the `UrlbarResult`-creation code in the\nprovider is more complex, and `UrlbarResult.isBestMatch` is currently read-only\n(only has a getter, not a setter).\n\n(2) It's not what the product requirements call for. It would be scope creep and\nmight not be what we want at all. It might end up causing problems later.\n\nThis also fixes a problem in `check_results()` in the xpcshell `head.js` where\nit logs the actual result. I've hit this before and hit it again now and decided\nto fix it. It stopped working at some point -- the actual result is always\nlogged as an empty object like `actual={}` -- I think when we added proper\ngetters and setters to `UrlbarResult`.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305422\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305714\n", "files": ["browser/components/urlbar/private/AmpSuggestions.sys.mjs", "browser/components/urlbar/tests/quicksuggest/unit/test_quicksuggest_amp.js", "browser/components/urlbar/tests/quicksuggest/unit/test_quicksuggest_merino.js", "browser/components/urlbar/tests/unit/head.js"], "git_node": "a10766e05d88580b75664ee3e98a5beeff9a001a", "git_parents": ["76ac32786785dc1f653c77050e19b5cd3aea9dfa"], "node": "88997b938f297a22d80810f868cf04419c71b2b2", "parents": ["2580400a82a83e8f06855db7394876c766dda063"], "tags": []}], "date": 1781048900, "git_changesets": ["a10766e05d88580b75664ee3e98a5beeff9a001a"], "user": "rvandermeulen@mozilla.com"}, "26830": {"changesets": [{"author": "Dale Harvey \u003cdale@arandomurl.com\u003e", "branch": "default", "desc": "Bug 2039608 - Ensure correct engine used for searches.  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301495\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305746\n", "files": ["browser/components/urlbar/content/SearchModeSwitcher.mjs", "browser/components/urlbar/tests/browser-searchMode/browser_searchModeSwitcher_basic.js"], "git_node": "6ca5082f5444dc8c5074a665773b74a628aac560", "git_parents": ["a10766e05d88580b75664ee3e98a5beeff9a001a"], "node": "30e3953f7325d5b6a8b8be9b0566679eff224448", "parents": ["88997b938f297a22d80810f868cf04419c71b2b2"], "tags": []}, {"author": "Dale Harvey \u003cdale@arandomurl.com\u003e", "branch": "default", "desc": "Bug 2030838 - Dont rebuild engine list during key navigation.  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D303330\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305747\n", "f