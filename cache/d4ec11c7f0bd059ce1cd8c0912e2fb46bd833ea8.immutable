"git_parents": ["f19e463b9d66026b8b6a282ed74e2371461353e2"], "node": "d8773698335739e3a3420e36696658c1fa09c8b5", "parents": ["f55647982adec227ff3186265bfd72c575419364"], "tags": []}], "date": 1780131865, "git_changesets": ["f19e463b9d66026b8b6a282ed74e2371461353e2", "53c5e0e1a0ec2dc7e67e5bb6091547e3e3332b04"], "user": "ffxbld@lando.moz.tools"}, "26616": {"changesets": [{"author": "Max Emig \u003cmozilla@emigm.ax\u003e", "branch": "default", "desc": "Bug 2041134 - Fix invalid Thunderbird tarball sourcestamp.txt regression.  a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303372\n", "files": ["python/mozbuild/mozbuild/mach_commands.py"], "git_node": "8272ee375418e905ad8109fcd081bdde01073db9", "git_parents": ["53c5e0e1a0ec2dc7e67e5bb6091547e3e3332b04"], "node": "0b9416175c23bd9b85ba23ea8c78fba1c1977d67", "parents": ["d8773698335739e3a3420e36696658c1fa09c8b5"], "tags": []}], "date": 1780169864, "git_changesets": ["8272ee375418e905ad8109fcd081bdde01073db9"], "user": "rvandermeulen@mozilla.com"}, "26617": {"changesets": [{"author": "Jeff Muizelaar \u003cjmuizelaar@mozilla.com\u003e", "branch": "default", "desc": "Bug 2042881 - Configure audio send stream bitrate range and BWE allocation.  a=RyanVM\n\nThis is in preparation for enabling transport-cc on audio. Once an audio codec\nnegotiates transport-cc rtcp-fb, libwebrtc's BWE and probing paths activate on\ngqthe audio send stream. If min_bitrate_bps, max_bitrate_bps, and\ninclude_in_congestion_control_allocation are left at their defaults,\nAudioSendStream::Start (audio/audio_send_stream.cc:366-376) skips\nAccountForAudioPacketsInPacedSender, IncludeOverheadInPacedSender,\nSetAsPartOfAllocation, and ConfigureBitrateObserver. The pacer then charges no\nbytes for audio and audio is not a BitrateAllocator observer, so when BWE\nprobing fires, PacketRouter::GeneratePadding finds the audio module supports\npadding (TWCC makes supports_bwe_extension_ true) and emits padding-only\npackets on the audio media SSRC. RTPSenderAudio::SendAudio is not on that path,\nso they carry no audio-level extension; on receive,\nChannelReceive::ReceivePacket hands the zero-payload result to the frame\ntransformer, surfacing \"audio frames\" with no audioLevel to encoded-receive\nscript transforms which causes\nwebrtc-encoded-transform/tentative/RTCEncodedAudioFrame-audiolevel.html to\nfail.\n\nHasCongestionControlAck() returns false today, so behavior is unchanged;\nTurning on transport-cc will return true when it's enabled.\n\nThis mirrors Chrome's WebRtcAudioSendStream::UpdateAllowedBitrateRange.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302806\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303618\n", "files": ["dom/media/webrtc/libwebrtcglue/AudioConduit.cpp", "dom/media/webrtc/libwebrtcglue/CodecConfig.h"], "git_node": "030a09ccd8c2bf6122f72d3870c3c08504e4e6b8", "git_parents": ["8272ee375418e905ad8109fcd081bdde01073db9"], "node": "7f501c0d326283b0142cb8c41144364faa2dc6fe", "parents": ["0b9416175c23bd9b85ba23ea8c78fba1c1977d67"], "tags": []}], "date": 1780169950, "git_changesets": ["030a09ccd8c2bf6122f72d3870c3c08504e4e6b8"], "user": "rvandermeulen@mozilla.com"}, "26618": {"changesets": [{"author": "Nathan Barrett \u003cnbarrett@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041777 - Update strings for contentsharing service  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D303217\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303530\n", "files": ["browser/components/contentsharing/ContentSharingUtils.sys.mjs", "browser/components/contentsharing/content/content-sharing-modal.css", "browser/components/contentsharing/content/content-sharing-modal.mjs", "browser/locales/en-US/browser/contentSharing.ftl"], "git_node": "5e6f8f865722288c1fc85c562dd87b38085b4ddd", "git_parents": ["030a09ccd8c2bf6122f72d3870c3c08504e4e6b8"], "node": "bc2865571e8053eca4f91afebe69b4bc3b1620d1", "parents": 