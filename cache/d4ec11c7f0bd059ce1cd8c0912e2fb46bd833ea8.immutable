021 - TabDragStart should contain the source key for if it is a tab vs tab group  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301532\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305343\n", "files": ["mobile/android/fenix/app/metrics.yaml", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/tabstray/TabsTrayTelemetryMiddleware.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/tabstray/browser/compose/interactable/InteractableGrid.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/tabstray/browser/compose/interactable/InteractableList.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/tabstray/browser/compose/legacy/ReorderableGrid.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/tabstray/browser/compose/legacy/ReorderableList.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/tabstray/controller/TabInteractionHandler.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/tabstray/redux/action/TabsTrayAction.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/tabstray/ui/TabManagementFragment.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/tabstray/ui/tabpage/TabLayout.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/tabstray/TabsTrayTelemetryMiddlewareTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/tabstray/browser/compose/InteractableGridTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/tabstray/browser/compose/InteractableListTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/tabstray/browser/compose/legacy/ReorderableGridTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/tabstray/browser/compose/legacy/ReorderableListTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/tabstray/redux/reducer/TabsTrayStoreReducerTest.kt"], "git_node": "4e7a95cdd44f47666a19a828e7bf65c0a715d1d5", "git_parents": ["e1db7980b1579f39e62b1501c9d0c2a0d1d8b508"], "node": "b15f0fb6cdc2be9cb65af026d725ed348d870b2b", "parents": ["00d7086dd8e14790621864645c4e32feb2b9cd84"], "tags": []}], "date": 1780958232, "git_changesets": ["e1db7980b1579f39e62b1501c9d0c2a0d1d8b508", "4e7a95cdd44f47666a19a828e7bf65c0a715d1d5"], "user": "rvandermeulen@mozilla.com"}, "26795": {"changesets": [{"author": "Ryan VanderMeulen \u003crvandermeulen@mozilla.com\u003e", "branch": "default", "desc": "Revert \"Bug 2034632: Fall back to monomorphic inlining if a trial-inlined ICScript hasn't been used r=jandem\" for various regressions.\n\nThis reverts commit b63e150126d7cdeaddc9c00ca085ee389f8a41e1.\n", "files": ["js/src/jit/JitScript.h", "js/src/jit/WarpOracle.cpp"], "git_node": "2612bf0fb75969dd6b6e036968544cc693defd5d", "git_parents": ["4e7a95cdd44f47666a19a828e7bf65c0a715d1d5"], "node": "930548ad05958441b63e0e3432053bfcc3946f63", "parents": ["b15f0fb6cdc2be9cb65af026d725ed348d870b2b"], "tags": []}], "date": 1780958852, "git_changesets": ["2612bf0fb75969dd6b6e036968544cc693defd5d"], "user": "rvandermeulen@mozilla.com"}, "26796": {"changesets": [{"author": "Hiroyuki Ikezoe \u003chikezoe.birchill@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041846 - Use PuppetWidget for window less browser even on headless mode.  a=RyanVM\n\nSince bug 1353814 we have used PuppetWidget on non-headless mode and\nit's been working. There's no reason we don't on headless mode. Rather\nnot using PuppetWidget causes unexpected results such as bug 1782541 or\nbug 1776966.\n\nThe browser test in this commit is replicating what a background page in\nan extension behaves.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302174\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305385\n", "files": ["gfx/tests/browser/browser.toml", "gfx/tests/browser/browser_windowless_browser_no_paint.js", "xpfe/appshell/nsAppShellService.cpp"], "git_node": "f8f9be5c16501dde2f4f1c307e869d4d01c12ce1", "git_parents": ["2612bf0fb75969dd6b6e036968544cc693defd5d"], "node": "d909b94c653a908dbe0731188d2b7505f93b13ae", "parents": ["930548ad05958441b63e0e3432053bfcc3946f63"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe.birchill@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041846 - Mostly revert bug 1782541.  a=RyanVM\n\nThis reverts commit cc22a4ec3b3f53adaeee5332c47dfb3272f32484 other than\nthe browser-test.js change.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302175\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305386\n", "files": ["gfx/layers/wr/WebRenderBridgeParent.cpp", "gfx/layers/wr/WebRenderBridgeParent.h"], "git_node": "746adb5a5e1b12c6a91ee6976c853b2898d30168", "git_parents": ["f8f9be5c16501dde2f4f1c307e869d4d01c12ce1"], "node": "48cbd6dc51677fdc05721357c9430e6aa20c14fb", "parents": ["d909b94c653a908dbe0731188d2b7505f93b13ae"], "tags": []}], "date": 1780962555, "git_changesets": ["f8f9be5c16501dde2f4f1c307e869d4d01c12ce1", "746adb5a5e1b12c6a91ee6976c853b2898d30168"], "user": "rvandermeulen@mozilla.com"}, "26797": {"changesets": [{"author": "Moritz Beier \u003cmbeier@mozilla.com\u003e", "branch": "default", "desc": "Bug 2042893 - Make sure middle click paste into address bar replaces existing content.  a=RyanVM\n\nThis happened because converting urlbar-input-container from a xul hbox to an html div caused \"click\" events to not fire because \"click\" only fires for the primary mouse button in HTML.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D303007\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305379\n", "files": ["browser/components/urlbar/content/UrlbarInput.mjs", "browser/components/urlbar/tests/browser/browser_middleClick.js"], "git_node": "2f7b9aeec3ed788a8f610145d2479c64256beb05", "git_parents": ["746adb5a5e1b12c6a91ee6976c853b2898d30168"], "node": "5e7c4237cbe1c263d172392bfd5485babbd46adf", "parents": ["48cbd6dc51677fdc05721357c9430e6aa20c14fb"], "tags": []}], "date": 1780962582, "git_changesets": ["2f7b9aeec3ed788a8f610145d2479c64256beb05"], "user": "rvandermeulen@mozilla.com"}, "26798": {"changesets": [{"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041913 - Ignore the now unsupported setting (post settings redesign) to hide search engines from drop-downs.  a=RyanVM\n\nThis is keyed on the settings redesign preference. This seemed to be the simplest way to ensure the old setting was respected at the right time.\n\nThe tests are not testing the results of the settings redesign, so we force the preference to false there as that's simplest.\n\nThere will be a separate clean-up stage where we'll remove support for the old setting.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D304748\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305170\n", "files": ["browser/components/search/test/browser/browser_contentSearch.js", "browser/components/search/test/browser/browser_hiddenOneOffs_diacritics.js", "browser/components/search/test/browser/browser_searchbar_openpopup.js", "browser/components/urlbar/tests/browser/browser_oneOffs.js", "browser/components/urlbar/tests/unit/test_UrlbarSearchUtils.js", "browser/components/urlbar/tests/unit/test_providerTabToSearch.js", "toolkit/components/search/SearchEngine.sys.mjs", "toolkit/components/search/tests/xpcshell/test_hideOneOffButton.js", "toolkit/components/search/tests/xpcshell/test_settings_migration_hideOneOffs.js", "toolkit/components/search/tests/xpcshell/test_telemetry_installed_engine_counts.js", "toolkit/components/search/tests/xpcshell/xpcshell.toml"], "git_node": "e63bc4206cd60211fa4756c0a255c0517b69b081", "git_parents": ["2f7b9aeec3ed788a8f610145d2479c64256beb05"], "node": "78f139f34ccc55739cbc35fbb50bc24817f44da2", "parents": ["5e7c4237cbe1c263d172392bfd5485babbd46adf"], "tags": []}], "date": 1780962670, "git_changesets": ["e63bc4206cd60211fa4756c0a255c0517b69b081"], "user": "rvandermeulen@mozilla.com"}, "26799": {"changesets": [{"author": "Josh Aas \u003cjaas@kflag.net\u003e", "branch": "default", "desc": "Bug 2041228 - Fix a regression on macOS in which paragraph movement does not work correctly.  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301836\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305418\n", "files": ["layout/generic/nsFrameSelection.cpp", "layout/generic/nsFrameSelection.h", "layout/generic/nsIFrame.cpp", "layout/generic/test/chrome.toml", "layout/generic/test/test_paragraph_movement_scroll.html", "layout/generic/test/test_paragraph_movement_shadow_dom.html"], "git_node": "b89d5c2b348ca9d652b7dcd1954282a4312c8061", "git_parents": ["e63bc4206cd60211fa4756c0a255c0517b69b081"], "node": "338cad5d7d88e73c3e99445634568b04eb4efc4b", "parents": ["78f139f34ccc55739cbc35fbb50bc24817f44da2"], "tags": []}], "date": 1780962729, "git_changesets": ["b89d5c2b348ca9d652b7dcd1954282a4312c8061"], "user": "rvandermeulen@mozilla.com"}, "26800": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Import translations from main\n", "files": ["mobile/android/android-components/components/compose/base/src/main/res/values-sl/strings.xml", "mobile/android/android-components/components/feature/app-links/src/main/res/values-co/strings.xml", "mobile/android/android-components/components/feature/app-links/src/main/res/values-pa-rIN/strings.xml", "mobile/android/android-components/components/feature/app-links/src/main/res/values-pt-rPT/strings.xml", "mobile/android/android-components/components/feature/app-links/src/main/res/values-sl/strings.xml", "mobile/android/android-components/components/feature/password-importer/src/main/res/values-co/strings.xml", "mobile/android/android-components/components/feature/password-importer/src/main/res/values-pa-rIN/strings.xml", "mobile/android/android-components/components/feature/protection-dashboard/src/main/