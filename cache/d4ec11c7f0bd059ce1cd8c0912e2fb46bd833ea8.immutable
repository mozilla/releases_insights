c8225acd066652"], "node": "ca3e4246291089a87f2f4a21ad23ed1fcf02c9cb", "parents": ["a604c8b73c4344bee629a39f83ef72d52e930917"], "tags": []}], "date": 1781026328, "git_changesets": ["32c6bf630675e57650084de6218e7a0005b9494f"], "user": "rvandermeulen@mozilla.com"}, "26820": {"changesets": [{"author": "halemu \u003chalemu@mozilla.com\u003e", "branch": "default", "desc": "Bug 2044754 - Fix paddings and margins of pinnable_sites components to match designs  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305214\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305425\n", "files": ["browser/components/aboutwelcome/content/aboutwelcome.bundle.js", "browser/components/aboutwelcome/content/aboutwelcome.css", "browser/components/asrouter/content-src/components/MultiStageProtonScreen.jsx", "browser/components/asrouter/content-src/styles/_multistage.scss", "browser/components/asrouter/content/components/asrouter-newtab-multistage/asrouter-newtab-multistage.bundle.js", "browser/components/asrouter/content/components/asrouter-newtab-multistage/asrouter-newtab-multistage.css", "browser/components/asrouter/modules/PanelTestProvider.sys.mjs"], "git_node": "a4f5eb2ec85309278059bcd2aa74249433d9edd3", "git_parents": ["32c6bf630675e57650084de6218e7a0005b9494f"], "node": "55e019ff9245f0b813cb4360c79373f223033992", "parents": ["ca3e4246291089a87f2f4a21ad23ed1fcf02c9cb"], "tags": []}], "date": 1781028725, "git_changesets": ["a4f5eb2ec85309278059bcd2aa74249433d9edd3"], "user": "rvandermeulen@mozilla.com"}, "26821": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging f370c6c6f27f7491a822b050ce37fd85f4425d7f with FIREFOX_115_37_0esr_BUILD1 a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "6a181bd7f6da708c728576fcd16c0fe1054ba11a", "git_parents": ["cf9ccb3e00e540fbf42fd1452c3bd54928ea218d"], "node": "1f276f7ed1d0ee73e25dc34c28a787fe874fb99f", "parents": ["cb57d56