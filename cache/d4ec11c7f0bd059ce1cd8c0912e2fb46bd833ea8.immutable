a6da30", "git_parents": ["d1db3d71841c1d7762f20bfe53d3bd08683d9ad0"], "node": "d3342a6da26b518d578ffde44ee7ad2582988eb9", "parents": ["f6cbafd04f996d312e507a63baa7fdbc54938c55"], "tags": []}], "date": 1779803142, "git_changesets": ["0ff010addf88e4988de2d662066c7282f6a6da30"], "user": "ffxbld@lando.moz.tools"}, "26502": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging 57cea197cdb443d17c9fa345edddefb192e37226 with FIREFOX-ANDROID_151_0_2_RELEASE a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "9701733ae8d1312808cb41fbc47be6a53749e281", "git_parents": ["0ff010addf88e4988de2d662066c7282f6a6da30"], "node": "a3b922a9953d977c5e41dc18025baf7dbf3a11cb", "parents": ["d3342a6da26b518d578ffde44ee7ad2582988eb9"], "tags": []}], "date": 1779803308, "git_changesets": ["9701733ae8d1312808cb41fbc47be6a53749e281"], "user": "ffxbld@lando.moz.tools"}, "26503": {"changesets": [{"author": "Eden Chuang \u003cechuang@mozilla.com\u003e", "branch": "default", "desc": "Bug 2017517 - Cleaning dispatched WorkerRunnables first after Worker switches to \"Killing\" state.  a=RyanVM\n\nCurrently, we have no good way to track the relationship between StrongWorkerRef and WorkerThreadRunnables for shutdown to ensure there is a StrongWorkerRef for the WorkerThreadRunnable dispatching and execution during Worker's shutdown.\n\nThis patch is a workaround for the general situation of performing shutdown work on the Worker thread without holding or  unexpectedly releasing the StrongWorkerRef.\n\nThe idea of this patch is that the WorkerThreadRunnable dispatched to the WorkerEventTarget should be executed before breaking the connection between the WorkerEventTarget and the WorkerPrivate, especially for the Hybrid one. So this patch cleans up the dispatched WorkerThreadRunnables during the Worker state transition, by executing runnables after switching to the \"Killing\" state.\n\nBecause once the Worker is in \"Killing,\" dispatching WorkerThreadRunnables will fail, the Worker will not hang by continuously runnable dispatching.\n\nThe following are the detailed steps of the patch.\n\n  # When the Worker is in \"Canceling,\" and there are no WorkerRefs, Timeouts, ChildWorkers, and pending runnables, the Worker transitions to the \"Killing\" state.\n  # After the Worker is in \"Killing\", if runnables are dispatched in other threads between step 1 and step 2, execute the dispatched runnables.\n  # Calling WorkerGlobalScopeBase::NoteShuttingDown() to shut down the StorageManager and releasing WorkerPrivate::mRemoteWorkerNonLifeCycleOpController, what we perform in WorkerPrivate::NotifyInternal() for \"Killing\" state.\n\nThe patch is a workaround because it can not perfectly handle the case of async shutdown behavior without StrongWorkerRef.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D299723\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302457\n", "files": ["dom/workers/WorkerPrivate.cpp"], "git_node": "039cf15a03b231ab6fc874f19f939e9a1083a049", "git_parents": ["75514ef0c8c425749a3eac333b6b2177601cbc21"], "node": "5f0029160e2c0bce552be6cb1d459b3ba7901602", "parents": ["8b2e887280d8c8ef3f32f1b789d473a36c55434e"], "tags": []}], "date": 1779806528, "git_changesets": ["039cf15a03b231ab6fc874f19f939e9a1083a049"], "user": "rvandermeulen@mozilla.com"}, "26504": {"changesets": [{"author": "Rong Bao \u003cwebmaster@csmantle.top\u003e", "branch": "default", "desc": "Bug 2040038 - Don't check for stack top validity when ASan is enabled.  a=RyanVM\n\nASan allocates on-stack objects on its own fake stack to track memory\noperations. Since stack top validity check expects onStackChar to be on\nthe same stack as the constructing thread, ASan breaks this assumption\nand will cause random assertion failures, when its own fake stack\nhappens to be allocated higher than the thread's real stack.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302223\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302422\n", "files": ["tools/profiler/tests/gtest/GeckoProfiler.cpp"], "git_node": "336f780d13b78d2f482d52e2132ee118ad8238cc", "git_parents": ["039cf15a03b231ab6fc874f19f939e9a1083a049"], "node": "e265d0381c3e2e7aa83205ae6028e203fbb0f07d", "parents": ["5f0029160e2c0bce552be6cb1d459b3ba7901602"], "tags": []}], "date": 1779806555, "git_changesets": ["336f780d13b78d2f482d52e2132ee118ad8238cc"], "user": "rvandermeulen@mozilla.com"}, "26505": {"changesets": [{"author": "Segun Famisa \u003csfamisa@mozilla.com\u003e", "branch": "default", "desc": "Bug 2039924 - Make the bookmarks store stable for the composition cycle  a=RyanVM\n\nWhen some flows are remembered and the store instance changes, if the remembered flows are not keyed, on recomposition, they would continue to observe state from a store that no longer exists, so no updates will be provided.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D300808\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302496\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/bookmarks/BookmarksScreen.kt"], "git_node": "028a148b56c09d042dcd46fd5cc8c445c3c44a09", "git_parents": ["336f780d13b78d2f482d52e2132ee118ad8238cc"], "node": "c4a710e0f9262f19e35f32c1d1ac815f110e7817", "parents": ["e265d0381c3e2e7aa83205ae6028e203fbb0f07d"], "tags": []}], "date": 1779806582, "git_changesets": ["028a148b56c09d042dcd46fd5cc8c445c3c44a09"], "user": "rvandermeulen@mozilla.com"}, "26506": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2041235 - Avoid triggering table selection outside text control.  a=RyanVM\n\nI haven't been able to reproduce this bug consistently, but I did manage\nto trigger some assertions here:\n\nhttps://searchfox.org/firefox-main/rev/8097ef6fac6522ded33f1e2d4d521c16331be5db/dom/base/nsContentUtils.cpp#8470-8477\n\nAnd pretty sure it's the same root cause... Before my patch, mouse\nevents weren't routed outside the scroller which papered over this\nissue.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302364\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302486\n", "files": ["layout/generic/nsIFrame.cpp"], "git_node": "b9cb0aad94da04814cc2b5b7268c6c8851741c91", "git_parents": ["028a148b56c09d042dcd46fd5cc8c445c3c44a09"], "node": "c6a64fff89d9b7620f5a7d19dc45dfb034107c60", "parents": ["c4a710e0f9262f19e35f32c1d1ac815f110e7817"], "tags": []}], "date": 1779806649, "git_changesets": ["b9cb0aad94da04814cc2b5b7268c6c8851741c91"], "user": "rvandermeulen@mozilla.com"}, "26507": {"changesets": [{"author": "Devota Aabel \u003cdaabel@mozilla.com\u003e", "branch": "default", "desc": "Bug 2023185- Remove Collections onboarding placeholder card from homepage.  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D297483\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302546\n", "files": ["mobile/android/fenix/app/src/androidTest/java/org/mozilla/fenix/ui/CollectionTest.kt", "mobile/android/fenix/app/src/androidTest/java/org/mozilla/fenix/ui/DeepLinkTest.kt", "mobile/android/fenix/app/src/androidTest/java/org/mozilla/fenix/ui/HomeScreenTest.kt", "mobile/android/fenix/app/src/androidTest/java/org/mozilla/fenix/ui/efficiency/selectors/HomeSelectors.kt", "mobile/android/fenix/app/src/androidTest/java/org/mozilla/fenix/ui/robots/HomeScreenRobot.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/components/Components.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/components/appstate/AppAction.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/components/appstate/AppState.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/components/appstate/AppStoreReducer.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/compose/PlaceholderCard.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/blocklist/BlocklistMiddleware.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/collections/Collections.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/collections/CollectionsState.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/fake/FakeHomepagePreview.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sessioncontrol/SessionControlController.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sessioncontrol/SessionControlInteractor.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/store/HomepageState.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/ui/CollectionsPlaceholder.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/ui/Homepage.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/utils/Settings.kt", "mobile/android/fenix/app/src/main/res/values/preference_keys.xml", "mobile/android/fenix/app/src/main/res/values/strings.xml", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/components/AppStoreTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/home/DefaultSessionControlControllerTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/home/SessionControlInteractorTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/home/blocklist/BlocklistMiddlewareTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/utils/SettingsTest.kt"], "git_node": "195d64ce70e868aa5dd8fede80eb5ab594a5b3da", "git_parents": ["b9cb0aad94da04814cc2b5b7268c6c8851741c91"], "node": "0d0b2330314250a751a673849bb15462b8fe232f", "parents": ["c6a64fff89d9b7620f5a7d19dc45dfb034107c60"], "tags": []}], "date": 1779816447, "git_changesets": ["195d64ce70e868aa5dd8fede80eb5ab594a5b3da"], "user": "rvandermeulen@mozilla.com"}, "26508": {"changesets": [{"author": "Finn Terdal \u003cfterdal@mozilla.com\u003e", "branch": "default", "desc": "Bug 2040048 - Close tab group menu when opening share modal  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301142\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302553\n", "files": ["browser/components/contentsharing/tests/browser/browser_testShareTabGroup.js", "browser/components/tabbrowser/content/tabgroup-menu.js"], "git_node": "351e8f41e71136e9948bfbec12a716a41e246246", "git_parents": ["195d64ce70e868aa5dd8fede80eb5ab594a5b3da"], "node": "8b1b5c0cd6b23209816c8ce369225e4db72522ff", "parents": ["0d0b2330314250a751a673849bb15462b8fe232f"], "tags": []}], "date": 1779816673, "git_changesets": ["351e8f41e71136e9948bfbec12a716a41e246246"], "user": "rvandermeulen@mozilla.com"}, "26509": {"changesets": [{"author": "Finn Terdal \u003cfterdal@mozilla.com\u003e", "branch": "default", "desc": "Bug 2037635 - Prepare AI features tests for the SRD pref flip  a=RyanVM\n\nDuplicates the AI features browser-chrome manifest so the suite runs under\nboth browser.settings-redesign.enabled=false (legacy) and =true (SRD). Same\ntest files on both sides via dupe-manifest=true; the AI features pane is\nconfig-based and renders identically under either pref state.\n\nAlso removes a stray no-op pushPrefEnv for \"browser.settings-redesign.enable\"\n(typo, missing trailing \"d\") from browser_aiFeatures_visibility.js \u2014 the\nmanifest now owns the pref.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D299886\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302489\n", "files": ["browser/components/preferences/moz.build", "browser/components/preferences/tests/aiFeatures/browser-srd.toml", "browser/components/preferences/tests/aiFeatures/browser.toml", "browser/components/preferences/tests/aiFeatures/browser_aiFeatures_visibility.js", "browser/components/preferences/tests/aiFeatures/head.js", "browser/components/preferences/tests/head.js"], "git_node": "91098a34cb4b4ed7813d203f7defe6170bf552a6", "git_parents": ["351e8f41e71136e9948bfbec12a716a41e246246"], "node": "7d83ab1351b2c98da8cb8b645157bed06207f5ed", "parents": ["8b1b5c0cd6b23209816c8ce369225e4db72522ff"], "tags": []}], "date": 1779816743, "git_changesets": ["91098a34cb4b4ed7813d203f7defe6170bf552a6"], "user": "rvandermeulen@mozilla.com"}, "26510": {"changesets": [{"author": "Shane Hughes \u003cshughes@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041497 - Refactor write_in_microsurvey ping determination.  a=RyanVM\n\nStop passing `write_in_microsurvey` from `AWGetFeatureConfig` to the\n`AWSendEventTelemetry` call. Instead, the surface that provides the\n`AWSendEventTelemetry` method will just insert it in the method\ndefinition and pass it straight to `AboutWelcomeTelemetry`. This means\nthe React component does not have to be aware of the property at all.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301946\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302344\n", "files": ["browser/base/content/spotlight.js", "browser/components/aboutwelcome/content-src/aboutwelcome.jsx", "browser/components/aboutwelcome/content/aboutwelcome.bundle.js", "browser/components/aboutwelcome/modules/AboutWelcomeTelemetry.sys.mjs", "browser/components/aboutwelcome/tests/xpcshell/test_AboutWelcomeTelemetry.js", "browser/components/asrouter/content-src/components/ActionChecklist.jsx", "browser/components/asrouter/content-src/components/AddonsPicker.jsx", "browser/components/asrouter/content-src/components/ContentTiles.jsx", "browser/components/asrouter/content-src/components/LanguageSwitcher.jsx", "browser/components/asrouter/content-src/components/MultiStageAboutWelcome.jsx", "browser/components/asrouter/content-src/components/MultiStageProtonScreen.jsx", "browser/components/asrouter/content/components/asrouter-newtab-multistage/asrouter-newtab-multistage.bundle.js", "browser/components/asrouter/modules/ASRouterTelemetry.sys.mjs", "browser/components/asrouter/modules/FeatureCallout.sys.mjs", "browser/components/asrouter/modules/Spotlight.sys.mjs"], "git_node": "e28f24c0dd3b1b9b6aa62aabf09f781a19c441ef", "git_parents": ["91098a34cb4b4ed7813d203f7defe6170bf552a6"], "node": "a110467549e05d8f40e06c10ab86652ab18a917c", "parents": ["7d83ab1351b2c98da8cb8b645157bed06207f5ed"], "tags": []}, {"author": "Elissa Cha \u003cecha@mozilla.com\u003e", "branch": "default", "desc": "Bug 2040721 - Integrate Smart Window feedback telemetry into microsurvey submit flow  a=RyanVM\n\n- Move Smart Window feedback modal configs into `OnboardingMessageProvider` and fetch them via ASRouter\n- Update Spotlight / AboutWelcome telemetry handling to inject and record `smart_window_user_feedback_data` on microsurvey pings\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301620\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302345\n", "files": ["browser/base/content/spotlight.js", "browser/components/aboutwelcome/modules/AboutWelcomeTelemetry.sys.mjs", "browser/components/aboutwelcome/tests/xpcshell/test_AboutWelcomeTelemetry.js", "browser/components/aiwindow/ui/components/ai-window/ai-window.mjs", "browser/components/aiwindow/ui/modules/FeedbackModal.sys.mjs", "browser/components/aiwindow/ui/test/xpcshell/test_FeedbackModal.js", "browser/components/asrouter/modules/OnboardingMessageProvider.sys.mjs", "browser/components/asrouter/modules/Spotlight.sys.mjs"], "git_node": "b1858eabacfdf95705efeb474ba0f49d6b46abb6", "git_parents": ["e28f24c0dd3b1b9b6aa62aabf09f781a19c441ef"], "node": "2d2625334de3624ef893779138f156280f13a113", "parents": ["a110467549e05d8f40e06c10ab86652ab18a917c"], "tags": []}], "date": 1779816886, "git_changesets": ["e28f24c0dd3b1b9b6aa62aabf09f781a19c441ef", "b1858eabacfdf95705efeb474ba0f49d6b46abb6"], "user": "rvandermeulen@mozilla.com"}, "26511": {"changesets": [{"author": "Maile Lucks \u003cmaile.lucks@gmail.com\u003e", "branch": "default", "desc": "Bug 2025054 - Fix incorrect check on browsing context pass the embedder element to browserLoaded -  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D296140\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302592\n", "files": ["browser/components/aiwindow/ui/test/browser/browser_aichat_open_link.js", "browser/components/aiwindow/ui/test/browser/browser_aiwindow_url_security.js"], "git_node": "e651415eb41ecfef9ef445199f5c5f7e0e1ecb34", "git_parents": ["b1858eabacfdf95705efeb474ba0f49d6b46abb6"], "node": "fced4b2b874134d67514db932c12e9055c0f9800", "parents": ["2d2625334de3624ef893779138f156280f13a113"], "tags": []}], "date": 1779825667, "git_changesets": ["e651415eb41ecfef9ef445199f5c5f7e0e1ecb34"], "user": "rvandermeulen@mozilla.com"}, "26512": {"changesets": [{"author": "Alastor Wu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 2038494 - Part 1: Map HEVC's lack-of-extension state and assert the support-helper invariant.  a=RyanVM\n\nGive HEVC a real lack-of-extension entry in the codec-support definition\ntable so the diagnostic and Glean paths can distinguish a missing HEVC\nextension from any other unsupported codec, and assert in the support\nhelper that any codec routed through the lack-of-extension arm has a\nreal mapping declared.\n\nBug 1990057 widened the lack-of-extension tracking to any codec missing\nits Media Foundation component, but only AV1 had a real codec-side\nmapping. The shared default placeholder leaked through the support\nhelper into the merged cross-process set, and about:support then marked\nevery codec sharing that placeholder as missing an extension, hiding\ntheir hardware-decode columns.\n\nA new gtest case covers the AV1 and HEVC lack-of-extension mappings.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301641\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302569\n", "files": ["dom/media/gtest/TestMediaCodecsSupport.cpp", "dom/media/platforms/MediaCodecsSupport.cpp"], "git_node": "dd6b7bc2ad29929aee0b46641339b95e7881be6c", "git_parents": ["e651415eb41ecfef9ef445199f5c5f7e0e1ecb34"], "node": "5a9d645a48f408d8987af0772f6b5ef381b0ab38", "parents": ["fced4b2b874134d67514db932c12e9055c0f9800"], "tags": []}, {"author": "Alastor Wu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 2038494 - Part 2: Only mark codecs with a real lack-of-extension mapping when their Media Foundation MFT is missing.  a=RyanVM\n\nRestrict the Windows Media Foundation initialization path so the\nlack-of-extension flag is recorded only for codecs whose codec-support\ndefinition declares such a mapping. Today that means AV1 and HEVC; any\nother codec returning the same component-missing error has simply lost\nits built-in decoder and is plainly unsupported.\n\nThis complements the support-helper guard added previously by narrowing\nthe producer side so the lack-of-extension signal originates only from\ncodecs whose definition declares one. The choice of codecs to mark is\ntied to the support-helper's mapping table, not to which Microsoft Store\nextensions exist in practice.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301642\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302570\n", "files": ["dom/media/platforms/wmf/WMFDecoderModule.cpp"], "git_node": "edda6c39236feea8aaa982314ea3afb0e4b712f7", "git_parents": ["dd6b7bc2ad29929aee0b46641339b95e7881be6c"], "node": "ce6405199b2dc06b127c20cfb1ca595d23ea95f9", "parents": ["5a9d645a48f408d8987af0772f6b5ef381b0ab38"], "tags": []}], "date": 1779825714, "git_changesets": ["dd6b7bc2ad29929aee0b46641339b95e7881be6c", "edda6c39236feea8aaa982314ea3afb0e4b712f7"], "user": "rvandermeulen@mozilla.com"}, "26513": {"changesets": [{"author": "Thomas Wisniewski \u003ctwisniewski@mozilla.com\u003e", "branch": "default", "desc": "Bug 2039461 - generate content scripts at build-time for new-style webcompat JS interventions;  a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302594\n", "files": ["browser/extensions/webcompat/codegen.py", "browser/extensions/webcompat/intervention_schema.json", "browser/extensions/webcompat/manifest.json", "browser/extensions/webcompat/preprocessed_intervention_files.mozbuild", "browser/extensions/webcompat/runtests.py", "browser/extensions/webcompat/templates/hide_alerts.js", "browser/extensions/webcompat/templates/hide_messages.js", "browser/extensions/webcompat/templates/log_console_message.js", "browser/extensions/webcompat/templates/modify_meta_viewport.js", "browser/extensions/webcompat/tests/build/test_css_in_json_passes_lint.py", "browser/extensions/webcompat/tests/build/test_file_generation.py", "browser/extensions/webcompat/tests/build/test_generated_files_pass_lint.py", "mobile/android/android-components/components/feature/webcompat/build.gradle"], "git_node": "aa7baaa5c3bcc2acbad5717c74885cdfd268a1d0", "git_parents": ["edda6c39236feea8aaa982314ea3afb0e4b712f7"], "node": "bff2100258b6b065364bc624280e4ba415d2b16d", "parents": ["ce6405199b2dc06b127c20cfb1ca595d23ea95f9"], "tags": []}], "date": 1779825775, "git_changesets": ["aa7baaa5c3bcc2acbad5717c74885cdfd268a1d0"], "user": "rvandermeulen@mozilla.com"}, "26514": {"changesets": [{"author": "Rebecca King \u003crking@mozilla.com\u003e", "branch": "default", "desc": "Bug 2040718 - Update language referencing number of locations in ipProtection.ftl -  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301368\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302585\n", "files": ["browser/components/ipprotection/content/ipprotection-content.css", "browser/components/ipprotection/content/ipprotection-unauthenticated.mjs", "browser/components/ipprotection/tests/browser/browser_ipprotection_content_unauthenticated.js", "browser/components/preferences/config/privacy.mjs", "browser/locales/en-US/browser/ipProtection.ftl", "browser/themes/shared/icons/gift.svg", "browser/themes/shared/jar.inc.mn"], "git_node": "9f437a3544e1bce872e9d584c2fbd7d9f8823449", "git_parents": ["aa7baaa5c3bcc2acbad5717c74885cdfd268a1d0"], "node": "a133d39bfae1152d7f89ee7242083e57341e9e96", "parents": ["bff2100258b6b065364bc624280e4ba415d2b16d"], "tags": []}], "date": 1779825813, "git_changesets": ["9f437a3544e1bce872e9d584c2fbd7d9f8823449"], "user": "rvandermeulen@mozilla.com"}, "26515": {"changesets": [{"author": "kpatenio \u003ckpatenio@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041113 \u2014 add isUrlbarToggleEligible video wrapper method and update youtube wrapper to ignore preview videos for urlbar pip eligibility.  a=RyanVM\n\nThis patch adds a new isUrlbarToggleEligible method to PictureInPictureChildVideoWrapper.\n- This allows identifying whether a video should count towards the url bar toggle crteria\n- To run the check, a new wrapper instance needs to be applied earlier, upon calling updateUrlbarPipVideoEligibility\n- The wrapper is only applied if a site override exists\n- The only affected wrapper right now is youtube.js\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301959\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302579\n", "files": ["browser/extensions/pictureinpicture/video-wrappers/youtube.js", "toolkit/actors/PictureInPictureChild.sys.mjs"], "git_node": "fdf5fe0821c1aa54a24737b2de66f9f8dd742cbb", "git_parents": ["9f437a3544e1bce872e9d584c2fbd7d9f8823449"], "node": "37b09f109d4ed833e85247ea7aac8fa6f7784756", "parents": ["a133d39bfae1152d7f89ee7242083e57341e9e96"], "tags": []}], "date": 1779825850, "git_changesets": ["fdf5fe0821c1aa54a24737b2de66f9f8dd742cbb"], "user": "rvandermeulen@mozilla.com"}, "26516": {"changesets": [{"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 2039829 - IP-Protection activator add-on: add VPN state and region conditions  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D300736\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302599\n", "files": ["browser/extensions/ipp-