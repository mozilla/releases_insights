, "tags": []}, {"author": "Roger Yang \u003croyang@mozilla.com\u003e", "branch": "default", "desc": "Bug 2039424 - Extend install referrer attribution handling and partner sharing.  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D303517\n\nDifferential Revision: https://phabricator.services.mozilla.com/D304859\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/components/metrics/AdjustMetricsService.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/components/metrics/AdjustThirdPartySharingController.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/components/metrics/InstallReferrerHandlingService.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/components/metrics/InstallReferrerWorker.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/utils/Settings.kt", "mobile/android/fenix/app/src/main/res/values/preference_keys.xml", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/components/metrics/AdjustMetricsServiceTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/components/metrics/InstallReferrerHandlingServiceTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/components/metrics/InstallReferrerWorkerTest.kt"], "git_node": "4c7a6e8cfc02757acc6482d2b63ddef797021fe6", "git_parents": ["3f5cde068ddd5215b3fd84c6ca8ed2136e4aac16"], "node": "2cb00a1c7edf2272136c7c7990d899d258c7003e", "parents": ["d8e6af445c58ff5331a0091077008f28ca2c6db7"], "tags": []}, {"author": "Roger Yang \u003croyang@mozilla.com\u003e", "branch": "default", "desc": "Bug 2044150 - Add Reddit install attribution handling.  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D304128\n\nDifferential Revision: https://phabricator.services.mozilla.com/D304860\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/components/metrics/AdjustMetricsService.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/components/metrics/AdjustThirdPartySharingController.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/components/metrics/InstallReferrerHandlingService.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/components/metrics/InstallReferrerWorker.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/utils/Settings.kt", "mobile/android/fenix/app/src/main/res/values/preference_keys.xml", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/components/metrics/AdjustMetricsServiceTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/components/metrics/InstallReferrerHandlingServiceTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/components/metrics/InstallReferrerWorkerTest.kt"], "git_node": "45bff5d860822b12f360bc785f396064906f0091", "git_parents": ["4c7a6e8cfc02757acc6482d2b63ddef797021fe6"], "node": "3a01fde8750e017014a32a70e681e6528fc0083b", "parents": ["2cb00a1c7edf2272136c7c7990d899d258c7003e"], "tags": []}], "date": 1780605249, "git_changesets": ["f231c8afc761c6ad74520efb48426864d3bdd1b8", "b1ea7834fef9f82bdc73c04a627cdd87d4ff216c", "3f5cde068ddd5215b3fd84c6ca8ed2136e4aac16", "4c7a6e8cfc02757acc6482d2b63ddef797021fe6", "45bff5d860822b12f360bc785f396064906f0091"], "user": "rvandermeulen@mozilla.com"}, "26744": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update remote-settings ct-logs -  a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D304875\n", "files": ["security/ct/CTKnownLogs.h", "security/manager/tools/log_list.json", "services/settings/dumps/blocklists/addons-bloomfilters.json", "services/settings/dumps/blocklists/addons-bloomfilters/addons-mlbf.bin", "services/settings/dumps/blocklists/addons-bloomfilters/addons-mlbf.bin.meta.json", "services/settings/dumps/blocklists/addons-bloomfilters/softblocks-addons-mlbf.bin", "services/settings/dumps/blocklists/addons-bloomfilters/softblocks-addons-mlbf.bin.meta.json", "services/settings/dumps/security-state/intermediates.json"], "git_node": "a4de2ca450ae29f0f9c3390e766e7b1ba28d9068", "git_parents": ["45bff5d860822b12f360bc785f396064906f0091"], "node": "addfa68adaf985fe30ea23a07b6c58ded64733eb", "parents": ["3a01fde8750e017014a32a70e681e6528fc0083b"], "tags": []}], "date": 1780605277, "git_changesets": ["a4de2ca450ae29f0f9c3390e766e7b1ba28d9068"], "user": "rvandermeulen@mozilla.com"}, "26745": {"changesets": [{"author": "sarah541 \u003csarahkhan1107@hotmail.com\u003e", "branch": "default", "desc": "Bug 2044091 - Reorder sports widget pager cards to lead with celebrations and bracket finishers  a=RyanVM\n\nThe pager previously sorted cards into three coarse buckets (LIVE \u003e PAST \u003e\nUPCOMING) with chronological order within each. This buried the most-relevant\ncards in several end-of-tournament scenarios -- the champion card landed last\nin a long followed-team pager; an upcoming Final the user's team is about to\nplay landed at the very end; and the no-team view showed TPP before Final\npurely because Saturday precedes Sunday.\n\nReplace orderedForPager with a single rule applied to both views:\n\n  1. Live matches (chronological)\n  2. Champion card (Final decided, TournamentWinner outcome)\n  3. Third Place card (TPP decided, ThirdPlace outcome; independent of #2)\n  4. Upcoming bracket-finishing matches by date (TPP Sat before Final Sun)\n  5. Other past matches reverse-chronologically, so the team's most recent KO\n     round sits next to the celebrations rather than buried under group-stage\n     history\n  6. Other upcoming matches chronologically\n\nAdds seven scenario tests covering the followed-team and no-team paths\nacross the pre-tournament, mid-tournament, between-TPP-and-Final, and\npost-Final phases.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D303821\n\nDifferential Revision: https://phabricator.services.mozilla.com/D304891\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/MatchCardBuilder.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/home/sports/MatchCardBuilderTest.kt"], "git_node": "153a3fc0b18a0f344d554511fb5276baa3a3459f", "git_parents": ["a4de2ca450ae29f0f9c3390e766e7b1ba28d9068"], "node": "e270df658904c3f2b3f55a4d10f6eacc2520345e", "parents": ["addfa68adaf985fe30ea23a07b6c58ded64733eb"], "tags": []}, {"author": "sarah541 \u003csarahkhan1107@hotmail.com\u003e", "branch": "default", "desc": "Bug 2044439 - Throttle and dedupe Sports Widget API fetches, with Nimbus override and mock-server bypass  a=RyanVM\n\nEvery dispatch site that triggers a sports-widget refresh (HomeFragment.onResume,\nrefresh button, debug-tool toggles, post-CountriesSelected when cache is empty)\npreviously hit the Merino WCS endpoint with no rate limit and no concurrency\nguard. A user mashing the refresh button or rapidly swiping between Home and\nanother tab could fire dozens of requests per second, all of which return the\nsame cached payload (Merino caches upstream data for ~3 min).\n\nGuard fetchAndBuild with two checks:\n\n1. In-flight dedup. Track the launched coroutine in a Job? field; drop any new\n   dispatch while it's still active. Costs nothing when there's no contention\n   and prevents concurrent round-trips when there is.\n\n2. Min-interval throttle, default 60 s. Stamp lastFetchAtMs on attempt (not on\n   success) so a failing endpoint can't be hammered by tapping retry. Worst-case\n   live-score latency becomes ~4 min (client 60 s + upstream 3 min cache)\n   instead of unbounded.\n\nThe interval is Nimbus-controlled via the new\n`homepage-sports-widget.fetch-throttle-seconds` variable (Int, default 60),\nexposed as Settings.sportsWidgetFetchThrottleMs and read at middleware\nconstruction. Lets the team lower the throttle remotely if upstream Merino\nTTL is reduced.\n\nThe throttle is bypassed when settings.useMockWorldCupServer is true so QA\ncan drive state changes via refresh, Home onResume, and the debug drawer's\n\"Apply session\" button without waiting on the timer. The bypass is a lambda\nevaluated per dispatch, not snapshotted at construction, so toggling the\ndebug drawer takes effect immediately. The in-flight dedup is preserved even\nin bypass mode \u2014 concurrent calls to the same endpoint are wasteful regardless\nof whether they hit mock or production.\n\nTests cover both guards across the default, custom-interval, failure, and\nbypass paths.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D304151\n\nDifferential Revision: https://phabricator.services.mozilla.com/D304892\n", "files": ["mobile/android/fenix/app/nimbus.fml.yaml", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/components/Components.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/SportsWidgetMiddleware.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/utils/Settings.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/home/sports/SportsWidgetMiddlewareTest.kt"], "git_node": "a64267f2d4dd83df845f05f62e0675bd2403af76", "git_parents": ["153a3fc0b18a0f344d554511fb5276baa3a3459f"], "node": "88a00ac84b1e86e50b9151e4faebafd05dfe7151", "parents": ["e270df658904c3f2b3f55a4d10f6eacc2520345e"], "tags": []}, {"author": "sarah541 \u003csarahkhan1107@hotmail.com\u003e", "branch": "default", "desc": "Bug 2044649 - Don't lead the sports pager with the Final and Third Place during the group stage  a=RyanVM\n\nFollow-up to Bug 2044091. The no-team pager always carries the Final and\nThird Place playoff (pinned by BRACKET_FINISHING_STAGES) so their schedule\nstays visible. The reordering change placed the upcoming bracket-finishing\nsegment ahead of past and other-upcoming cards unconditionally, so during the\ngroup stage the finals -- still weeks away -- led the pager ahead of the group\nmatches being played now.\n\nPin the upcoming Final / Third Place to the front only when there are no other\nupcoming matches, i.e. when they are genuinely the next matches up late in the\ntournament. While earlier rounds still have upcoming games, the finals sort by\ndate into their natural place at the tail.\n\nThe end-of-tournament scenarios are unaffected: at that point there are no\nother upcoming matches, so the finals still lead. Adds a regression test\nasserting the group-stage order keeps the finals last.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D304423\n\nDifferential Revision: https://phabricator.services.mozilla.com/D304893\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/MatchCardBuilder.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/home/sports/MatchCardBuilderTest.kt"], "git_node": "51c286dc3d146e7c7a2bd2a20241d5802c1fe900", "git_parents": ["a64267f2d4dd83df845f05f62e0675bd2403af76"], "node": "1e005da1efdd38581853f45fb8277052c4dc07b3", "parents": ["88a00ac84b1e86e50b9151e4faebafd05dfe7151"], "tags": []}, {"author": "sarah541 \u003csarahkhan1107@hotmail.com\u003e", "branch": "default", "desc": "Bug 2044622 - Surface penalty shootout scores in the sports widget  a=RyanVM\n\nTwo gaps left penalty results invisible:\n\nMapping: MatchesResponseMapper detected a shootout by matching the period\nstring exactly against \"FT(P)\" / \"P\", but the feed marks a live shootout with\n\"PEN\" and, once the match is final, flips the period back to \"FT\" and carries\nthe result only in home_penalty / away_penalty. Detect either a penalty period\n(case-insensitive \"pen\" substring) or populated penalty fields -- the feed only\nfills those on a shootout. Penalties are never inferred from a level regulation\nscore.\n\nRendering: the compact related-match row read only home_score / away_score and\nsuffixed plain Final, so a FinalAfterPenalties match showed just \"2 - 2\" with no\nshootout score. Render it as \"2 - 2 \u00b7 Penalties (3-5)\" -- the regulation score\nfollowed by the shootout score -- for both live Penalties and finished\nFinalAfterPenalties, reusing the existing \"Penalties\" label.\n\nAccessibility: the penalty row's content description mirrors the featured match\ncard, announcing each score next to its team (\"France 2 South Africa 2\") rather\nthan the visual \"2 - 2\" dash form, then the shootout result.\n\nUpdates the mapper tests to the real \"PEN\" marker plus the finished-on-FT\nfallback, and adds a related-row preview for the penalty format.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D304509\n\nDifferential Revision: https://phabricator.services.mozilla.com/D304894\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/MatchesResponseMapper.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/ui/RelatedMatches.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/home/sports/MatchesResponseMapperTest.kt"], "git_node": "a4d353fcd3b82a90db9f7e137975e71cd7121a34", "git_parents": ["51c286dc3d146e7c7a2bd2a20241d5802c1fe900"], "node": "d9296aef6f2e9495ce3e49304725fedc3b7ed2c5", "parents": ["1e005da1efdd38581853f45fb8277052c4dc07b3"], "tags": []}], "date": 1780611818, "git_changesets": ["153a3fc0b18a0f344d554511fb5276baa3a3459f", "a64267f2d4dd83df845f05f62e0675bd2403af76", "51c286dc3d146e7c7a2bd2a20241d5802c1fe900", "a4d353fcd3b82a90db9f7e137975e71cd7121a34"], "user": "rvandermeulen@mozilla.com"}, "26746": {"changesets": [{"author": "Jack Brown \u003cjbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 2035787 - Treat error page illustrations as decorative images - r=bolsson a=RyanVM\n\nRegarding the illustrations on the Felt Privacy error pages:\nhttps://www.w3.org/WAI/tutorials/images/decision-tree/\n\n\u003e\n\u003e Does the image contribute meaning to the current page or context?\n\nI'd argue it does, and in the \"Yes\" column there's: \"it shows content that is redundant to real text nearby,\" which I think is also true. An empty alt attribute is called for in this case.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302386\n\nDifferential Revision: https://phabricator.services.mozilla.com/D304889\n", "files": ["browser/base/content/test/about/browser_aboutNetError_feltprivacy_illustrations.js", "toolkit/content/errors/net-error-illustrations.mjs", "toolkit/content/net-error-card.mjs", "toolkit/locales/en-US/toolkit/neterror/certError.ftl", "toolkit/locales/en-US/toolkit/neterror/netError.ftl"], "git_node": "5ccee4af9eda9a59da2cb9fa61332e1dc3c9c1d9", "git_parents": ["a4d353fcd3b82a90db9f7e137975e71cd7121a34"], "node": "36af7789cfa1e3197c9a4f2d0c3b713085b2a56a", "parents": ["d9296aef6f2e9495ce3e49304725fedc3b7ed2c5"], "tags": []}], "date": 1780612591, "git_changesets": ["5ccee4af9eda9a59da2cb9fa61332e1dc3c9c1d9"], "user": "rvandermeulen@mozilla.com"}, "26747": {"changesets": [{"author": "Moyin \u003cmadeyemi@mozilla.com\u003e", "branch": "default", "desc": "Bug 2044970 - Automatically close the Country selector when a team has been selected or deselected  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D304722\n\nDifferential Revision: https://phabricator.services.mozilla.com/D304895\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/ui/Homepage.kt"], "git_node": "495e4633f9ec8b5e38f5f8f31aa8d660c300ad16", "git_parents": ["5ccee4af9eda9a59da2cb9fa61332e1dc3c9c1d9"], "node": "01ed7ef7ffbb92313fea0f493c8e8aca44962775", "parents": ["36af7789cfa1e3197c9a4f2d0c3b713085b2a56a"], "tags": []}, {"author": "Moyin \u003cmadeyemi@mozilla.com\u003e", "branch": "default", "desc": "Bug 2044981: Fix Standalone error card background color  a=RyanVM\n\n**Before**:\n{F71952792}\n\n**After**:\n{F71952795}\n\nOriginal Revision: https://phabricator.services.mozilla.com/D304731\n\nDifferential Revision: https://phabricator.services.mozilla.com/D304896\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/ui/SportsCardPager.kt"], "git_node": "ba6cac66b42e883e729b4cbc77cc69b4eade0e11", "git_parents": ["495e4633f9ec8b5e38f5f8f31aa8d660c300ad16"], "node": "f924f4c7c7f77286332c8a285ca74322f4c5a0a2", "parents": ["01ed7ef7ffbb92313fea0f493c8e8aca44962775"], "tags": []}, {"author": "Moyin \u003cmadeyemi@mozilla.com\u003e", "branch": "default", "desc": "Bug 2044974: Prevent long text from squishing the team flags  a=RyanVM\n\n**Before:**\n{F71956723}\n\n**After:**\n{F71955378}\n\nOriginal Revision: https://phabricator.services.mozilla.com/D304769\n\nDifferential Revision: https://phabricator.services.mozilla.com/D304897\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/ui/MatchCard.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/ui/RelatedMatches.kt"], "git_node": "61ffb603814b3a25d9b6e488f97546a4bddf607c", "git_parents": ["ba6cac66b42e883e729b4cbc77cc69b4eade0e11"], "node": "5edf4382f0afba4302f5b461e064793cd4fcd76a", "parents": ["f924f4c7c7f77286332c8a285ca74322f4c5a0a2"], "tags": []}, {"author": "Moyin \u003cmadeyemi@mozilla.com\u003e", "branch": "default", "desc": "Bug 2044713 - Sync countdown pill timer logic with Keep tabs card logic  a=RyanVM\n\nAfter the clock hits midnight, and the home page is resumed, the `Keep tabs on the World Cup` card is displayed.\n{F71961561}\n\nOriginal Revision: https://phabricator.services.mozilla.com/D304834\n\nDifferential Revision: https://phabricator.services.mozilla.com/D304898\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/CountdownCalculator.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/ui/SportsWidget.kt"], "git_node": "c7ca555d2896a1a80439771aa60a4d7d3084eb80", "git_parents": ["61ffb603814b3a25d9b6e488f97546a4bddf607c"], "node": "6d118707bc78323fabdbcef6e23da22a796c64df", "parents": ["5edf4382f0afba4302f5b461e064793cd4fcd76a"], "tags": []}], "date": 1780624548, "git_changesets": ["495e4633f9ec8b5e38f5f8f31aa8d660c300ad16", "ba6cac66b42e883e729b4cbc77cc69b4eade0e11", "61ffb603814b3a25d9b6e488f97546a4bddf607c", "c7ca555d2896a1a80439771aa60a4d7d3084eb80"], "user": "rvandermeulen@mozilla.com"}, "26748": {"changesets": [{"author": "t-p-white \u003ctowhite@mozilla.com\u003e", "branch": "default", "desc": "Bug 2044955 - Update the treatment-c primary and secondary button copy  a=RyanVM\n\n{F71948031}\n\nOriginal Revision: https://phabricator.services.mozilla.com/D304699\n\nDifferential Revision: https://phabricator.services.mozilla.com/D304729\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/redesign/view/MarketingDataOnboardingPageRedesign.kt", "mobile/android/fenix/app/src/main/res/values/strings.xml"], "git_node": "543a5e070a1f1825f2ab6ee5d079a46d67c66fed", "git_parents": ["c7ca555d2896a1a80439771aa60a4d7d3084eb80"], "node": "56f389810ded9851f834606df2c3976abe702129", "parents": ["6d118707bc78323fabdbcef6e23da22a796c64df"], "tags": []}], "date": 1780624641, "git_changesets": ["543a5e070a1f1825f2ab6ee5d079a46d67c66fed"], "user": "rvandermeulen@mozilla.com"}, "26749": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Import translations from main\n", "files": ["mobile/android/android-components/components/feature/importer/src/main/res/values-zh-rCN/strings.xml", "mobile/android/android-components/components/feature/password-importer/src/main/res/values-zh-rCN/strings.xml", "mobile/android/fenix/app/src/main/res/values-ar/strings.xml", "mobile/android/fenix/app/src/main/res/values-bg/strings.xml", "mobile/android/fenix/app/src/main/res/values-cs/strings.xml", "mobile/android/fenix/app/src/main/res/values-cy/strings.xml", "mobile/android/fenix/app/src/main/res/values-de/strings.xml", "mobile/android/fenix/app/src/main/res/values-dsb/strings.xml", "mobile/android/fenix/app/src/main/res/values-el/strings.xml", "mobile/android/fenix/app/src/main/res/values-en-rGB/strings.xml", "mobile/android/fenix/app/src/main/res/values-es-rAR/strings.xml", "mobile/android/fenix/app/src/main/res/values-es-rCL/strings.xml", "mobile/android/fenix/app/src/main/res/values-es-rES/strings.xml", "mobile/android/fenix/app/src/main/res/values-es-rMX/strings.xml", "mobile/android/fenix/app/src/main/res/values-eu/strings.xml", "mobile/android/fenix/app/src/main/res/values-fi/strings.xml", "mobile/android/fenix/app/src/main/res/values-fr/strings.xml", "mobile/android/fenix/app/src/main/res/values-fur/strings.xml", "mobile/android/fenix/app/src/main/res/values-fy-rNL/strings.xml", "mobile/android/fenix/app/src/main/res/values-gl/strings.xml", "mobile/android/fenix/app/src/main/res/values-gn/strings.xml", "mobile/android/fenix/app/src/main/res/values-hsb/strings.xml", "mobile/android/fenix/app/src/main/res/values-hu/strings.xml", "mobile/android/fenix/app/src/main/res/values-ia/strings.xml", "mobile/android/fenix/app/src/main/res/values-is/strings.xml", "mobile/android/fenix/app/src/main/res/values-it/strings.xml", "mobile/android/fenix/app/src/main/res/values-iw/strings.xml", "mobile/android/fenix/app/src/main/res/values-ja/strings.xml", "mobile/android/fenix/app/src/main/res/values-ka/strings.xml", "mobile/android/fenix/app/src/main/res/values-kk/strings.xml", "mobile/android/fenix/app/src/main/res/values-ko/strings.xml", "mobile/android/fenix/app/src/main/res/values-nb-rNO/strings.xml", "mobile/android/fenix/app/src/main/res/values-nn-rNO/strings.xml", "mobile/android/fenix/app/src/main/res/values-pt-rBR/strings.xml", "mobile/android/fenix/app/src/main/res/values-pt-rPT/strings.xml", "mobile/android/fenix/app/src/main/res/values-ru/strings.xml", "mobile/android/fenix/app/src/main/res/values-sk/strings.xml", "mobile/android/fenix/app/src/main/res/values-sv-rSE/strings.xml", "mobile/android/fenix/app/src/main/res/values-tr/strings.xml", "mobile/android/fenix/app/src/main/res/values-vi/strings.xml", "mobile/android/fenix/app/src/main/res/values-zh-rCN/strings.xml", "mobile/android/fenix/app/src/main/res/values-zh-r