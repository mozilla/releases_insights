, "files": [".hgtags"], "git_node": "f607e35e50639d807806032c325e6be50b851a55", "git_parents": ["318e4a5a825fc5ad17789779b4d8813077a823a8"], "node": "ca3b36fab1e930a9973f0151c8f3a598e9cd0bd9", "parents": ["7aa31d1e9c4a63820396773fe90443993c4b33f2"], "tags": []}], "date": 1779194175, "git_changesets": ["f607e35e50639d807806032c325e6be50b851a55"], "user": "ffxbld@lando.moz.tools"}, "26380": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging 2e36c464a92f1942683abbed6ceb442308db5eb0 with FIREFOX_140_11_0esr_RELEASE a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "4fde419f9d7bfcba94e6b610ed31509aa7fadb7c", "git_parents": ["f607e35e50639d807806032c325e6be50b851a55"], "node": "8a450aa24d31e8a24ea3c57eea713c84eb31593a", "parents": ["ca3b36fab1e930a9973f0151c8f3a598e9cd0bd9"], "tags": []}], "date": 1779194373, "git_changesets": ["4fde419f9d7bfcba94e6b610ed31509aa7fadb7c"], "user": "ffxbld@lando.moz.tools"}, "26381": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging fdf733c8d234ef2a5a7deee5b3285f87fa32b1d8 with FIREFOX-ANDROID_151_0_RELEASE a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "565a2d34117ecbe52d0d081f7f5985d696efa8a2", "git_parents": ["4fde419f9d7bfcba94e6b610ed31509aa7fadb7c"], "node": "bda7092a800f4ffa47cd57d99925da4c990433f0", "parents": ["8a450aa24d31e8a24ea3c57eea713c84eb31593a"], "tags": []}], "date": 1779194490, "git_changesets": ["565a2d34117ecbe52d0d081f7f5985d696efa8a2"], "user": "ffxbld@lando.moz.tools"}, "26382": {"changesets": [{"author": "Daniel Holbert \u003cdholbert@cs.stanford.edu\u003e", "branch": "default", "desc": "Bug 2038448: Move mozilla-specific mozPrintCallback WPT to its own directory and annotate an observed leak.  a=RyanVM DONTBUILD\n\nThis WPT is observed to leak over 370,000 bytes in a perma-failing way\non Windows and macOS debug builds. I'm rounding up to 400000 in the\nannotation, to account for that amount with some room for variability.\n\nAs discussed on Bug 2038448, we suspect this is due to a cycle of\nprint-related objects that can persist when using the system print dialog\n*and also* using silent-printing (as this test does, via pref flips in its .ini file).\n\nIdeally we should figure out a way to break this cycle during\nshutdown, or allow the test to wait for printing to complete and the\ncycle to be broken.  But in the meantime it doesn't seem like this\nleak impacts real users, so let's annotate the observed leak to stop\nthe test-failures.\n\nTo avoid losing strictness for other tests, I'm moving this test to\nits own subdirectory so that new leak-tolerance is specific to this test.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301007\n\nDifferential Revision: https://phabricator.services.mozilla.com/D301228\n", "files": ["testing/web-platform/mozilla/meta/dom/mozPrintCallback/__dir__.ini", "testing/web-platform/mozilla/meta/dom/mozPrintCallback/window-print-mozPrintCallback-async-001.html.ini", "testing/web-platform/mozilla/meta/dom/window-print-mozPrintCallback-async-001.html.ini", "testing/web-platform/mozilla/tests/dom/mozPrintCallback/window-print-mozPrintCallback-async-001.html", "testing/web-platform/mozilla/tests/dom/window-print-mozPrintCallback-async-001.html"], "git_node": "1fcfed246e55d7266b7bf231d5ba88bacb6a4748", "git_parents": ["ef57b3756e36ff82b5e544a40b21b1f208cb4e89"], "node": "0d62f758977d9b33716795383c2eda5f9a40fe90", "parents": ["de3c50a9ccee5ba3a11371500998267db649fa74"], "tags": []}], "date": 1779214990, "git_changesets": ["1fcfed246e55d7266b7bf231d5ba88bacb6a4748"], "user": "rvandermeulen@mozilla.com"}, "26383": {"changesets": [{"author": "Benjamin VanderSloot \u003cbvandersloot@mozilla.com\u003e", "branch": "default", "desc": "Bug 2040360 - Custom tracking protection cookies drop down missing \"block\" context -  a=RyanVM DONTBUILD\n\nOriginal Revision: