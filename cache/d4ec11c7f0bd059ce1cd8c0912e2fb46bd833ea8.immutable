b11", "git_parents": ["4f82780c76ffe508d6ce20d9e557422ea37ff679"], "node": "f04e0813edc6aebe9455fd91d9ff2f3e821d2516", "parents": ["bf55b0b5306c71ae1a6bcb4f1fe93317e563e5f0"], "tags": []}, {"author": "Moyin \u003cmadeyemi@mozilla.com\u003e", "branch": "default", "desc": "Bug 2043514: Update Sports Pager telemetry with source and type extras  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D303295\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303620\n", "files": ["mobile/android/fenix/app/metrics.yaml", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/fake/FakeHomepagePreview.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sessioncontrol/SessionControlInteractor.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/SportCardData.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/SportsController.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/SportsInteractor.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/ui/MatchCard.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/ui/SportsCardPager.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/ui/SportsWidget.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/ui/Homepage.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/home/sports/SportsControllerTest.kt"], "git_node": "e4e19929c254401bf1bbda644772879acaf47fc6", "git_parents": ["fe07a7cbe2c886d173dcf7421cbca371718bcb11"], "node": "ff5cbfaab25482f618d41765bd4078dd29c8e14b", "parents": ["f04e0813edc6aebe9455fd91d9ff2f3e821d2516"], "tags": []}, {"author": "Moyin \u003cmadeyemi@mozilla.com\u003e", "branch": "default", "desc": "Bug 2043663 - Update the Champions card implementation  a=dmeehan\n\nDepends on D303339\n\n{F71565308}\n\nOriginal Revision: https://phabricator.services.mozilla.com/D303407\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303621\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/SportsWidgetMiddleware.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/ui/SportsWidget.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/home/sports/SportsWidgetMiddlewareTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/home/sports/ui/SportsWidgetTest.kt"], "git_node": "932b7341787e571ee4387f3fd4d8dfa6370c6605", "git_parents": ["e4e19929c254401bf1bbda644772879acaf47fc6"], "node": "dfce4a5d97da1964e41c5e30a226c25f6815f1bd", "parents": ["ff5cbfaab25482f618d41765bd4078dd29c8e14b"], "tags": []}, {"author": "sarah541 \u003csarahkhan1107@hotmail.com\u003e", "branch": "default", "desc": "Bug 2043750 - Include extra-time goals when computing knockout winner  a=dmeehan\n\nwinnerOf summed regulation + penalty only. For a Final or third-place\nplayoff decided in extra time (no shootout), the API returns the ET goals\nin home_extra/away_extra; mapPastStatus collapses \"AET\" into\nMatchStatus.Final, so winnerOf is the only place that can disambiguate\nthe result -- and it was missing those fields.\n\nMove winnerOf onto SportsMatch (where ET fields still exist) and sum\nscore + extra + penalty. celebrationOutcomeFor now takes List\u003cSportsMatch\u003e;\nboth call sites already had the SportsMatch in scope. The UI Match model\nis left alone since nothing renders ET goals.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D303503\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303622\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/MatchCardBuilder.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/home/sports/MatchCardBuilderTest.kt"], "git_node": "e6d14d35e60d421630dd2e862481a4857a636863", "git_parents": ["932b7341787e571ee4387f3fd4d8dfa6370c6605"], "node": "b1fbfd689f348044d86814a3cc74db5c4747d93f", "parents": ["dfce4a5d97da1964e41c5e30a226c25f6815f1bd"], "tags": []}], "date": 1780229168, "git_changesets": ["fe07a7cbe2c886d173dcf7421cbca371718bcb11", "e4e19929c254401bf1bbda644772879acaf47fc6", "932b7341787e571ee4387f3fd4d8dfa6370c6605", "e6d14d35e60d421630dd2e862481a4857a636863"], "user": "dmeehan@mozilla.com"}, "26623": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2042929 - Reject remote print jobs on RecvCloneDocumentTreeInto.  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D303309\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303653\n", "files": ["dom/ipc/ContentParent.cpp"], "git_node": "4f8fe2dab880da2791b89d114613931b69ed981f", "git_parents": ["e6d14d35e60d421630dd2e862481a4857a636863"], "node": "cba43ec228bdd2db8d92e9f3a20aa168c82f8e2a", "parents": ["b1fbfd689f348044d86814a3cc74db5c4747d93f"], "tags": []}], "date": 1780252764, "git_changesets": ["4f8fe2dab880da2791b89d114613931b69ed981f"], "user": "rvandermeulen@mozilla.com"}, "26624": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2040926 - Remove Pip window special-case from ShouldAssociateWithWinAppSDK().  a=RyanVM\n\nIt seems it's no longer needed, and it might cause issues with\nthird-party software. Since we're at the beginning of the cycle it\nprobably makes sense to try this.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301499\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303651\n", "files": ["widget/windows/nsWindow.cpp"], "git_node": "7c6b281d869ed7f2af388ccb7a407aa2a5aba27f", "git_parents": ["4f8fe2dab880da2791b89d114613931b69ed981f"], "node": "8b5b5c6ffea9f9ffc6cd2abc4465d797e12ee407", "parents": ["cba43ec228bdd2db8d92e9f3a20aa168c82f8e2a"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2042533 - Make sure nsWindowTaskbarConcealer deals with PiP windows.  a=RyanVM\n\nThe PiP window is a `dialog`:\n\nhttps://searchfox.org/firefox-main/rev/a49121972a6140a227e2d0d585afbce3f9e5e11a/toolkit/components/pictureinpicture/PictureInPicture.sys.mjs#30\n\nThose can be dealt with the same way as other toplevels.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302630\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303652\n", "files": ["widget/windows/nsWindowTaskbarConcealer.cpp"], "git_node": "dba79999d3db3b54d8bb7df972b5bae08acb23c0", "git_parents": ["7c6b281d869ed7f2af388ccb7a407aa2a5aba27f"], "node": "581f1dc2e9abc0cf528db310167b9981469004ae", "parents": ["8b5b5c6ffea9f9ffc6cd2abc4465d797e12ee407"], "tags": []}], "date": 1780253048, "git_changesets": ["7c6b281d869ed7f2af388ccb7a407aa2a5aba27f", "dba79999d3db3b54d8bb7df972b5bae08acb23c0"], "user": "rvandermeulen@mozilla.com"}, "26625": {"changesets": [{"author": "Glenn Watson \u003cgit@chillybin.org\u003e", "branch": "default", "desc": "Bug 2043249 - Reduce ps_quad_box_shadow varying count from 15 to 13  a=RyanVM\n\nReconstruct the corner half-space plane constants and the element rect\nbounds in the fragment shader rather than passing them as varyings. This\nkeeps the shader below the GLES3 minimum varying limit that older GPUs\nreport, which previously caused a link failure and fallback to software\nWebRender.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D303185\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303663\n", "files": ["gfx/wr/webrender/res/ps_quad_box_shadow.glsl"], "git_node": "b5bc32389f81da2318de92e2bcf45dd622f04398", "git_parents": ["dba79999d3db3b54d8bb7df972b5bae08acb23c0"], "node": "2b63bbc42b2547d1fef3dbe40ad1bc1e819aa177", "parents": ["581f1dc2e9abc0cf528db310167b9981469004ae"], "tags": []}], "date": 1780256752, "git_changesets": ["b5bc32389f81da2318de92e2bcf45dd622f04398"], "user": "rvandermeulen@mozilla.com"}, "26626": {"chang