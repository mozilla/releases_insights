ome/sports/ui/SportsWidgetErrorCard.kt", "mobile/android/fenix/app/src/main/res/drawable/fox_expressive_face_tail.xml", "mobile/android/fenix/app/src/main/res/values/strings.xml", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/components/appstate/sports/SportsWidgetReducerTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/home/sports/SportsControllerTest.kt"], "git_node": "bd2b42da3f050d0d065718ef7832e04ffc1ca95e", "git_parents": ["69a38ac5e604f4d9994e762807c926fceba5a8a5"], "node": "87a9f34c009595c0c5f50361dc4d4b20909fd254", "parents": ["0ac0a347417676c7e52f403a9280f8a1e373e47d"], "tags": []}, {"author": "sarah541 \u003csarahkhan1107@hotmail.com\u003e", "branch": "default", "desc": "Bug 2040711 - Surface tournament-winner and third-place outcomes on sports widget FINAL and THIRD_PLACE_PLAYOFF cards  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301356\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302608\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/MatchCardBuilder.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/SportCardData.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/SportsWidgetMiddleware.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/home/sports/MatchCardBuilderTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/home/sports/SportsWidgetMiddlewareTest.kt"], "git_node": "ae837f46387a2dadfc8800fdd7e6b4d939e5e04e", "git_parents": ["bd2b42da3f050d0d065718ef7832e04ffc1ca95e"], "node": "0fa1481914ff986bbe4d87d7e51eda1b47b3ea6e", "parents": ["87a9f34c009595c0c5f50361dc4d4b20909fd254"], "tags": []}, {"author": "Moyin \u003cmadeyemi@mozilla.com\u003e", "branch": "default", "desc": "Bug 2040620 - Implement third place, Champion cards and nullable teams  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301513\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302609\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/fake/FakeHomepagePreview.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sessioncontrol/SessionControlInteractor.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/SportCardData.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/SportsController.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/SportsInteractor.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/fake/FakeSportsPreview.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/ui/ChampionsCard.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/ui/FlagContainer.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/ui/MatchCard.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/ui/RelatedMatches.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/ui/SportCardHeader.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/ui/SportWidgetMenu.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/ui/SportsCardPager.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/ui/SportsWidget.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/ui/Homepage.kt", "mobile/android/fenix/app/src/main/res/drawable/fox_hand_over_eyes.xml", "mobile/android/fenix/app/src/main/res/drawable/fox_sitting_looking_up.xml", "mobile/android/fenix/app/src/main/res/drawable/sports_widget_celebration.xml", "mobile/android/fenix/app/src/main/res/values/strings.xml", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/home/sports/MatchCardBuilderTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/home/sports/SportsControllerTest.kt"], "git_node": "866506fe2b3af5685990d91c6d5f25bb94a8e52d", "git_parents": ["ae837f46387a2dadfc8800fdd7e6b4d939e5e04e"], "node": "f5395d073e0a843630f9a7f961f6cc27bb891dc5", "parents": ["0fa1481914ff986bbe4d87d7e51eda1b47b3ea6e"], "tags": []}, {"author": "sarah541 \u003csarahkhan1107@hotmail.com\u003e", "branch": "default", "desc": "Bug 2040825 - Show generic experience for eliminated teams and pass eliminated teams to SportCountrySelector  a=RyanVM\n\nState wiring\n  ------------\n  - New SportsWidgetAction.EliminatedCountriesUpdated(Set\u003cString\u003e).\n  - Reducer writes sportsWidgetState.eliminatedCountries.\n  - SportsWidgetMiddleware computes the set from every match in the latest\n    fetch (any SportsTeam flagged eliminated, deduped) and dispatches it\n    alongside MatchCardStateUpdated after each successful fetch.\n  - The country-selector bottom sheet already consumes\n    sportsWidgetState.eliminatedCountries and CountryFlagItem already\n    greyscales eliminated flags via ColorFilter.colorMatrix \u2014 no UI\n    changes were needed in SportsCountrySelector.\n\n  Generic experience when all followed teams are eliminated\n  ---------------------------------------------------------\n  - SportsWidgetMiddleware.buildCards flips effectiveCodes to emptySet()\n    when allFollowedTeamsEliminated(result, codes) is true, routing\n    through buildForNoTeam so the user sees the bracket-wide view\n    instead of an empty team-specific pager.\n  - The user's selection is preserved in state \u2014 they can still see and\n    change it via the country selector. Only the rendering switches.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301451\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302610\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/components/appstate/AppAction.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/components/appstate/sports/SportsWidgetReducer.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/SportsWidgetMiddleware.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/components/appstate/sports/SportsWidgetReducerTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/home/sports/SportsWidgetMiddlewareTest.kt"], "git_node": "38f34346463c6b46aae2cf4d86d3896bd64d2f99", "git_parents": ["866506fe2b3af5685990d91c6d5f25bb94a8e52d"], "node": "55c3522e7638f95ce35b0ba9568177b372b07726", "parents": ["f5395d073e0a843630f9a7f961f6cc27bb891dc5"], "tags": []}, {"author": "sarah541 \u003csarahkhan1107@hotmail.com\u003e", "branch": "default", "desc": "Bug 2041156 - Show full schedule for no team selected for phase 2  a=RyanVM\n\n- buildForNoTeam previously filtered the group stage down to a single\n  \"next available day\" card. It now groups every match the response\n  returns by LocalDate and emits one MatchCard per day, in\n  chronological order, regardless of stage. The round label is derived\n  from each day's first match so mixed-stage responses label correctly.\n- buildForNoTeam no longer needs a today: LocalDate parameter.\n- orderedForPager continues to bucket live \u2192 past \u2192 upcoming with\n  chronological order preserved inside each bucket, so the pager\n\n{F70904278}\n  always lands on a live day if one exists.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301669\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302611\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/MatchCardBuilder.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/home/sports/MatchCardBuilderTest.kt"], "git_node": "4de67ab750eb107b7e21dba2e668a3fbd44f8d66", "git_parents": ["38f34346463c6b46aae2cf4d86d3896bd64d2f99"], "node": "44289db2bc22c28ae6f8fd25b0e450dfaa3c6db3", "parents": ["55c3522e7638f95ce35b0ba9568177b372b07726"], "tags": []}, {"author": "sarah541 \u003csarahkhan1107@hotmail.com\u003e", "branch": "default", "desc": "Bug 2041488 - Update stage values corresponding to API spec  a=RyanVM\n\nOriginal R