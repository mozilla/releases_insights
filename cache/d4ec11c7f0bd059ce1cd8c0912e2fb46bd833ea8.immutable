88af90627797784", "parents": ["98befb70e4f84900fa38fc09e64a22919230742c"], "tags": []}], "date": 1780945617, "git_changesets": ["d5466d407c22c37b67394be2a31ab43dc45386c0"], "user": "ffxbld@lando.moz.tools"}, "26785": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging c3ced093061480f46d51b9b7028ec647c6af5c14 with FIREFOX_151_0_4_BUILD1 a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "2a79c9a5d909bf588d52e1dc51231243980f1380", "git_parents": ["d5466d407c22c37b67394be2a31ab43dc45386c0"], "node": "33bdc92a95091df1eb40e7f787d93a8da33c639a", "parents": ["47a7b1d1d9a7df2502de4b40288af90627797784"], "tags": []}], "date": 1780945725, "git_changesets": ["2a79c9a5d909bf588d52e1dc51231243980f1380"], "user": "ffxbld@lando.moz.tools"}, "26786": {"changesets": [{"author": "Ben Visness \u003cbvisness@mozilla.com\u003e", "branch": "default", "desc": "Bug 2042724: Check uses_memory at validation time.  a=RyanVM\n\nAdds a new pass to validation that ensures that all imports of builtin\nfunctions with uses_memory have a memory available. This occurs after\nthe memory section but before the code section, so the code section can\nonly concern itself with providing the correct parameters. In addition,\nit ensures that the memory used is unshared.\n\nAlso fixes an issue where a LinkError encountered during builtin\ninstantiation would trigger a release assert.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D303914\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305363\n", "files": ["js/src/jit-test/tests/wasm/builtin-modules/bad-memory.js", "js/src/jit-test/tests/wasm/builtin-modules/directives.txt", "js/src/jit-test/tests/wasm/builtin-modules/uses-memory.js", "js/src/wasm/WasmBCMemory.cpp", "js/src/wasm/WasmBuiltinModule.cpp", "js/src/wasm/WasmOpIter.h", "js/src/wasm/WasmValidate.cpp"], "git_node": "87755acf2062d9b58b52ba6e5358e85e7efaed39", "git_parents": ["a1b0b9f8d771da8006cbe7e729354dd3ec1f35c8"], "node": "8ff7715f0237d0e130d9af663607f2927600cc71", "parents": ["241c49273969b2f94b1ad69084d57a843d8bb6c9"], "tags": []}], "date": 1780948775, "git_changesets": ["87755acf2062d9b58b52ba6e5358e85e7efaed39"], "user": "rvandermeulen@mozilla.com"}, "26787": {"changesets": [{"author": "Brad Werth \u003cbwerth@mozilla.com\u003e", "branch": "default", "desc": "Bug 2042451: Make AsyncImagePipelineManager::UpdateImageKeys hold strong reference to previous texture.  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D304584\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305201\n", "files": ["gfx/layers/wr/AsyncImagePipelineManager.cpp"], "git_node": "f44afadc3b81dc8a3da3e477f9c1fcd4468b001d", "git_parents": ["87755acf2062d9b58b52ba6e5358e85e7efaed39"], "node": "847eb8eebefa104f251974780d6ccc879dc9e6f0", "parents": ["8ff7715f0237d0e130d9af663607f2927600cc71"], "tags": []}], "date": 1780948802, "git_changesets": ["f44afadc3b81dc8a3da3e477f9c1fcd4468b001d"], "user": "rvandermeulen@mozilla.com"}, "26788": {"changesets": [{"author": "Ryan VanderMeulen \u003crvandermeulen@mozilla.com\u003e", "branch": "default", "desc": "Bug 2034574 - Cancel pending DelayedUpdate when ServiceWorkerRegistrationProxy stops listening.  a=diannaS\n\nWhen the ServiceWorkerRegistrationParent IPDL actor is revoked, RevokeActor\ndispatches StopListeningOnMainThread, which clears mReg but leaves any pending\nDelayedUpdate (and its one-shot timer) in place. When the timer eventually\nfires DelayedUpdate::Notify, the NS_ENSURE_TRUE(mProxy-\u003emReg, ...) early-return\nexits before clearing mProxy-\u003emDelayedUpdate / mTimer, leaking the\nProxy \u003c-\u003e DelayedUpdate refcount cycle along with the timer, the rejected\nupdate promise, and the bg event target it pinned.\n\nMirror MaybeShutdownOnMainThread by rejecting and clearing mDelayedUpdate from\nStopListeningOnMainThread, so the timer is cancelled the moment the proxy can\nno longer service the request.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D298164\n\nDifferential Revision: https://phabricator.services.mozilla.com/D304979\n", "files": ["dom/serviceworkers/ServiceWorkerRegistrationProxy.cpp"], "git_node": "05a135fb2bcb82633c815b8f212b9c7bff72a0cd", "git_parents": ["f44afadc3b81dc8a3da3e477f9c1fcd4468b001d"], "node": "40b9688505ee672e0a846a43ca7fc41a0dbe0f17", "parents": ["847eb8eebefa104f251974780d6ccc879dc9e6f0"], "tags": []}], "date": 1780948972, "git_changesets": ["05a135fb2bcb82633c815b8f212b9c7bff72a0cd"], "user": "dsmith@mozilla.com"}, "26789": {"changesets": [{"author": "kpatenio \u003ckpatenio@mozilla.com\u003e", "branch": "default", "desc": "Bug 2043706 \u2014 reduce applyWrapper calls for pip urlbar eligibility by checking hasUrlbarEligibilityOverride in pip overrides.  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D304593\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305252\n", "files": ["browser/extensions/pictureinpicture/data/picture_in_picture_overrides.js", "toolkit/actors/PictureInPictureChild.sys.mjs"], "git_node": "bfefbe5937705399d4224003928ab5ef6535071f", "git_parents": ["05a135fb2bcb82633c815b8f212b9c7bff72a0cd"], "node": "83ed569f99b1912f817a1cdfe8c57e527d9f0a92", "parents": ["40b9688505ee672e0a846a43ca7fc41a0dbe0f17"], "tags": []}], "date": 1780949027, "git_changesets": ["bfefbe5937705399d4224003928ab5ef6535071f"], "user": "rvandermeulen@mozilla.com"}, "26790": {"changesets": [{"author": "Segun Famisa \u003csfamisa@mozilla.com\u003e", "branch": "default", "desc": "Bug 2042386 - Allow LNA/LDA features to be enabled via nimbus flag while keeping the nightly defaults  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D303727\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305140\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/utils/Settings.kt"], "git_node": "59a6b1af0011c