com"}, "26548": {"changesets": [{"author": "Anna Kulyk \u003cakulyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 2037663 - Prepare search tests for the SRD pref flip  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301560\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302759\n", "files": ["browser/components/preferences/moz.build", "browser/components/preferences/tests/search/browser-srd.toml", "browser/components/preferences/tests/search/browser.toml", "browser/components/preferences/tests/search/browser_localSearchShortcuts.js", "browser/components/preferences/tests/search/browser_localSearchShortcuts_xul.js", "browser/components/preferences/tests/search/browser_searchChangedEngine.js", "browser/components/preferences/tests/search/browser_searchChangedEngine_xul.js", "browser/components/preferences/tests/search/browser_searchFindMoreLink.js", "browser/components/preferences/tests/search/browser_searchRestoreDefaults.js", "browser/components/preferences/tests/search/browser_searchScroll.js", "browser/components/preferences/tests/search/browser_search_category_filter.js", "browser/components/preferences/tests/search/browser_search_engineList.js", "browser/components/preferences/tests/search/browser_search_no_results_change_category.js", "browser/components/preferences/tests/search/browser_search_results.js", "browser/components/preferences/tests/search/browser_search_subdialog_tooltip_saved_addresses.js", "browser/components/preferences/tests/search/browser_search_subdialogs_within_preferences_1.js", "browser/components/preferences/tests/search/browser_search_subdialogs_within_preferences_2.js", "browser/components/preferences/tests/search/browser_search_subdialogs_within_preferences_3.js", "browser/components/preferences/tests/search/browser_search_subdialogs_within_preferences_4.js", "browser/components/preferences/tests/search/browser_search_subdialogs_within_preferences_5.js", "browser/components/preferences/tests/search/browser_search_subdialogs_within_preferences_6.js", "browser/components/preferences/tests/search/browser_search_subdialogs_within_preferences_7.js", "browser/components/preferences/tests/search/browser_search_subdialogs_within_preferences_8.js", "browser/components/preferences/tests/search/browser_search_subdialogs_within_preferences_9.js", "browser/components/preferences/tests/search/browser_search_subdialogs_within_preferences_site_data.js", "browser/components/preferences/tests/search/browser_search_userEngineDialog.js", "browser/components/preferences/tests/search/browser_search_userEngineDialog_xul.js", "browser/components/preferences/tests/search/browser_search_within_preferences_1.js", "browser/components/preferences/tests/search/browser_search_within_preferences_2.js", "browser/components/preferences/tests/search/browser_search_within_preferences_command.js", "browser/components/preferences/tests/searchResults/browser-srd.toml", "browser/components/preferences/tests/searchResults/browser.toml", "browser/components/preferences/tests/searchResults/browser_search_category_filter.js", "browser/components/preferences/tests/searchResults/browser_search_no_results_change_category.js", "browser/components/preferences/tests/searchResults/browser_search_results.js", "browser/components/preferences/tests/searchResults/browser_search_subdialog_tooltip_saved_addresses.js", "browser/components/preferences/tests/searchResults/browser_search_subdialogs_within_preferences_1.js", "browser/components/preferences/tests/searchResults/browser_search_subdialogs_within_preferences_2.js", "browser/components/preferences/tests/searchResults/browser_search_subdialogs_within_preferences_3.js", "browser/components/preferences/tests/searchResults/browser_search_subdialogs_within_preferences_4.js", "browser/components/preferences/tests/searchResults/browser_search_subdialogs_within_preferences_5.js", "browser/components/preferences/tests/searchResults/browser_search_subdialogs_within_preferences_6.js", "browser/components/preferences/tests/searchResults/browser_search_subdialogs_within_preferences_7.js", "browser/components/preferences/tests/searchResults/browser_search_subdialogs_within_preferences_8.js", "browser/components/preferences/tests/searchResults/browser_search_subdialogs_within_preferences_9.js", "browser/components/preferences/tests/searchResults/browser_search_subdialogs_within_preferences_site_data.js", "browser/components/preferences/tests/searchResults/browser_search_subdialogs_within_preferences_site_data_xul.js", "browser/components/preferences/tests/searchResults/browser_search_within_preferences_1.js", "browser/components/preferences/tests/searchResults/browser_search_within_preferences_2.js", "browser/components/preferences/tests/searchResults/browser_search_within_preferences_command.js", "browser/components/preferences/tests/searchResults/head.js"], "git_node": "76cd68967007ce9d4968af4e4396f56e5a4bb6b5", "git_parents": ["5021dfc1aff50a1eac5c1797310482245f3a20d4"], "node": "8a61bcdc3fed2b490586fb59a7522df8fedcd8f1", "parents": ["950f64bcf4bc8269c5b4381cf397d49aec23c3c4"], "tags": []}], "date": 1779911978, "git_changesets": ["76cd68967007ce9d4968af4e4396f56e5a4bb6b5"], "user": "rvandermeulen@mozilla.com"}, "26549": {"changesets": [{"author": "hannajones \u003chjones@mozilla.com\u003e", "branch": "default", "desc": "Bug 2039064 - Move enterprise nav notice above search  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301788\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302780\n", "files": ["browser/components/enterprisepolicies/tests/browser/browser_policies_notice_in_aboutpreferences.js", "browser/components/preferences/preferences.js", "browser/components/preferences/preferences.xhtml", "browser/components/preferences/widgets/nav-notice/nav-notice.css", "browser/themes/shared/preferences/preferences.css", "toolkit/themes/shared/desktop-jar.inc.mn", "toolkit/themes/shared/icons/organizational-unit.svg"], "git_node": "6316a76dfc4e601a76d36dab9bb9ef3a2cb3580c", "git_parents": ["76cd68967007ce9d4968af4e4396f56e5a4bb6b5"], "node": "c827712d6824ac23dfec0c47adaa9b47fb55ffd9", "parents": ["8a61bcdc3fed2b490586fb59a7522df8fedcd8f1"], "tags": []}], "date": 1779912039, "git_changesets": ["6316a76dfc4e601a76d36dab9bb9ef3a2cb3580c"], "user": "rvandermeulen@mozilla.com"}, "26550": {"changesets": [{"author": "James Teow \u003cjteow@mozilla.com\u003e", "branch": "default", "desc": "Bug 2037177 - Add telemetry for when users reintegrate URLs after blocking them via backspace -  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D299859\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302766\n", "files": ["browser/components/urlbar/UrlbarUtils.sys.mjs", "browser/components/urlbar/content/UrlbarInput.mjs", "browser/components/urlbar/metrics.yaml", "browser/components/urlbar/tests/browser-autofill/browser_reintegration_telemetry.js", "browser/components/urlbar/tests/unit/test_UrlbarUtils_backspaceBlocks.js", "browser/components/urlbar/tests/unit/xpcshell.toml"], "git_node": "5c75a98eb3ea2a5e31a3c2f8d70aa8ebf4556762", "git_parents": ["6316a76dfc4e601a76d36dab9bb9ef3a2cb3580c"], "node": "1b1b10bb6fbbad1b410c0a51c02b7cb6866bbbf5", "parents": ["c827712d6824ac23dfec0c47adaa9b47fb55ffd9"], "tags": []}, {"author": "James Teow \u003cjteow@mozilla.com\u003e", "branch": "default", "desc": "Bug 2040819 - Count adaptive autofill backspace dismissals per target across sessions  a=RyanVM\n\nPreviously the backspace soft-block fired only when the user backspaced\nthrough an autofill suggestion the threshold number of characters in a\nsingle session (e.g. `gma[il.com]` -\u003e `gm`). That was a misinterpretation\nof the intended design.\n\nThis patch moves the count off of UrlbarInput's _autofillBackspaceState\nand onto UrlbarUtils._backspaceBlocks, keyed by `\u003cscope\u003e:\u003chost\u003e`\nwhere scope is \"origin\" or \"page\". Each backspace on an autofill result\nticks the count up. Once it reaches autoFill.backspaceThreshold,\nblockAutofill fires and the entry's blockedAt timestamp is recorded for\nre-integration telemetry.\n\nPicking the autofill result or removing it via the result menu clears\nthe entry's count (the pick is a positive signal, the removal already\nblocks the suggestion).\n\nRenames trackBackspaceBlock to recordAutofillBackspace to reflect that\nthe helper now does the threshold check and the blockAutofill call, and\nadds clearAutofillBackspaceEntryForUrl for the pick/remove paths.\n\nAlso adds test_UrlbarUtils_autofillBackspaceCount.js to cover the new\nper-target accumulation and updates browser_backspace_dismissal.js\nfor the cross-session counting.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301692\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302767\n", "files": ["browser/components/urlbar/UrlbarProviderAutofill.sys.mjs", "browser/components/urlbar/UrlbarUtils.sys.mjs", "browser/components/urlbar/content/UrlbarInput.mjs", "browser/components/urlbar/tests/browser-autofill/browser.toml", "browser/components/urlbar/tests/browser-autofill/browser_backspace_dismissal.js", "browser/components/urlbar/tests/browser-autofill/browser_backspace_dismissal_guards.js", "browser/components/urlbar/tests/browser-autofill/browser_backspace_dismissal_reintegration.js", "browser/components/urlbar/tests/browser-autofill/browser_reintegration_telemetry.js", "browser/components/urlbar/tests/browser-autofill/head.js", "browser/components/urlbar/tests/unit/test_UrlbarUtils_autofillBackspaceCount.js", "browser/components/urlbar/tests/unit/test_UrlbarUtils_backspaceBlocks.js", "browser/components/urlbar/tests/unit/test_UrlbarUtils_getBackspaceBlock.js", "browser/components/urlbar/tests/unit/xpcshell.toml"], "git_node": "0969e30df113eae5d1eb719f0c1ab3624c08dbee", "git_parents": ["5c75a98eb3ea2a5e31a3c2f8d70aa8ebf4556762"], "node": "3d5fcfbba19d494651d4e221e639046497eaa6d5", "parents": ["1b1b10bb6fbbad1b410c0a51c02b7cb6866bbbf5"], "tags": []}, {"author": "James Teow \u003cjteow@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041664 - Read adaptive autofill prefs by name and migrate their Nimbus variables to setPref-  a=RyanVM\n\nRegarding the test changes: onNimbusChanged enrolled an adaptive autofill variable bound via fallbackPref.\nBecause enrollment doesn't touch the pref branch, onPrefChanged never fired.\n\nSwitching to setPref makes enrollment write the pref to the user branch, which fires onPrefChanged and\nbreaks the assertion.\n\nIn onPrefChanged, the assertions still passed post-migration (because the recording observer was\nattached after enrollment), but doCleanup failed: the test's later setBoolPref was interpreted by Nimbus\nas a non-experiment write to a setPref-managed pref, which triggers auto-unenrollment. Cleanup then tried\nto unenroll an already-deactivated experiment and threw.\n\nautoFillAdaptiveHistoryUseCountThreshold is left unchanged because its pref is a float but the Nimbus\nvariable must be declared as string.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302157\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302768\n", "files": ["browser/components/urlbar/UrlbarPrefs.sys.mjs", "browser/components/urlbar/UrlbarProviderAutofill.sys.mjs", "browser/components/urlbar/content/UrlbarInput.mjs", "browser/components/urlbar/tests/unit/test_UrlbarPrefs.js", "toolkit/components/nimbus/FeatureManifest.yaml"], "git_node": "e62aa5b3108fb26177c0426598043169f83537ba", "git_parents": ["0969e30df113eae5d1eb719f0c1ab3624c08dbee"], "node": "2fcb56e709ca23323c553150035f17e17228a11c", "parents": ["3d5fcfbba19d494651d4e221e639046497eaa6d5"], "tags": []}], "date": 1779912169, "git_changesets": ["5c75a98eb3ea2a5e31a3c2f8d70aa8ebf4556762", "0969e30df113eae5d1eb719f0c1ab3624c08dbee", "e62aa5b3108fb26177c0426598043169f83537ba"], "user": "rvandermeulen@mozilla.com"}, "26551": {"changesets": [{"author": "Noah Bond \u003cnbond@mozilla.com\u003e", "branch": "default", "desc": "Bug 2033617 - Update a tab group's last modified timestamp whenever a piece of metadata is updated  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D300847\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302930\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/debugsettings/tabs/TabGroupTools.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/tabgroups/storage/database/StoredTabGroupDao.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/tabgroups/storage/database/TabGroupAssignmentDao.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/tabgroups/storage/database/TabGroupDatabase.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/tabgroups/storage/database/TabGroupOperationsDao.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/tabgroups/storage/repository/TabGroupRepository.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/tabgroups/storage/DefaultTabGroupRepositoryTest.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/tabstray/redux/middleware/TabStorageMiddlewareTest.kt"], "git_node": "9420479984be499cf0deb40a730718bb1ac5ff14", "git_parents": ["e62aa5b3108fb26177c0426598043169f83537ba"], "node": "34d95338cdaa83c97ec55765c3420933de397b5a", "parents": ["2fcb56e709ca23323c553150035f17e17228a11c"], "tags": []}], "date": 1779927821, "git_changesets": ["9420479984be499cf0deb40a730718bb1ac5ff14"], "user": "rvandermeulen@mozilla.com"}, "26552": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Import translations from main\n", "files": ["mobile/android/android-components/components/feature/app-links/src/main/res/values-fy-rNL/strings.xml", "mobile/android/android-components/components/feature/app-links/src/main/res/values-ka/strings.xml", "mobile/android/android-components/components/feature/app-links/src/main/res/values-nl/strings.xml", "mobile/android/android-components/components/feature/protection-dashboard/src/main/res/values-cs/strings.xml", "mobile/android/fenix/app/longfox/src/main/res/values-cs/strings.xml", "mobile/android/fenix/app/longfox/src/main/res/values-ka/strings.xml", "mobile/android/fenix/app/longfox/src/main/res/values-nl/strings.xml", "mobile/android/fenix/app/src/main/res/values-cy/strings.xml", "mobile/android/fenix/app/src/main/res/values-is/strings.xml", "mobile/android/fenix/app/src/main/res/values-ka/strings.xml", "mobile/android/fenix/app/src/main/res/values-nl/strings.xml"], "git_node": "3abce71390b6440f5c3938095187c8d2a1f7a1f9", "git_parents": ["9420479984be499cf0deb40a730718bb1ac5ff14"], "node": "3fee518725dc06f266cb1be0c2c34fd09ef51a23", "parents": ["34d95338cdaa83c97ec55765c3420933de397b5a"], "tags": []}], "date": 1779934795, "git_changesets": ["3abce71390b6440f5c3938095187c8d2a1f7a1f9"], "user": "ffxbld@lando.moz.tools"}, "26553": {"changesets": [{"author": "Hiroyuki Ikezoe \u003chikezoe.birchill@mozilla.com\u003e", "branch": "default", "desc": "Bug 2036292 - Make PresShell::GetVisualViewportSize aware of the dynamic toolbar height.  a=RyanVM\n\nPreviously, GetVisualViewportSize() returned the raw mVisualViewportSize, so\ncallers via ScrollContainerFrame::GetVisualViewportSize() were unaware of the\ndynamic toolbar state. The toolbar awareness logic that was inline in\nVisualViewport.cpp is moved into GetVisualViewportSize() itself, so all callers\nget the correct size when the toolbar is collapsing or collapsed.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D297841\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302945\n", "files": ["dom/base/VisualViewport.cpp", "layout/base/PresShell.cpp", "layout/base/PresShell.h"], "git_node": "b6d9bf80192788bd03aa8da4aee667a707b06726", "git_parents": ["3abce71390b6440f5c3938095187c8d2a1f7a1f9"], "node": "c30955ee38a4cae0dcdb386019ef23e8482a36ed", "parents": ["3fee518725dc06f266cb1be0c2c34fd09ef51a23"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe.birchill@mozilla.com\u003e", "branch": "default", "desc": "Bug 2036292 - Skip calling ScrollToVisual if the target frame is already in the visual viewport.  a=RyanVM\n\nWhen scrollIntoView() is called on a position:fixed element that is already\nvisible in the visual viewport, ScrollFrameIntoVisualViewport() was still\ncalling ScrollToVisual() unnecessarily, causing a spurious visual scroll.\n\nAdd a check to skip the visual scroll if the element's rect (converted to\nlayout coordinates) is already contained within the current visual viewport.\nUsing layout coordinates is necessary since the visual viewport may have been\npanned from the origin, in which case a viewport-origin check would give a\nfalse negative for elements positioned beyond the visual viewport height.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D297842\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302946\n", "files": ["layout/base/PresShell.cpp", "mobile/android/geckoview/src/androidTest/assets/www/bug2028072.html", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/BaseSessionTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/InteractiveWidgetTest.kt"], "git_node": "c2aee2c54c2173af62de83d32a59d0623a1dbbf5", "git_parents": ["b6d9bf80192788bd03aa8da4aee667a707b06726"], "node": "dfd325a96686948e9f41e265c9fb289bd4e6ad04", "parents": ["c30955ee38a4cae0dcdb386019ef23e8482a36ed"], "tags": []}], "date": 1779935892, "git_changesets": ["b6d9bf80192788bd03aa8da4aee667a707b06726", "c2aee2c54c2173af62de83d32a59d0623a1dbbf5"], "user": "rvandermeulen@mozilla.com"}, "26554": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Bump