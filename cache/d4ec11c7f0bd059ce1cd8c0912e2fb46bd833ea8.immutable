b095414dcb907", "git_parents": ["f6f0df6fee1146a1fc256c6743baf3c4d87b34cf"], "node": "e0d78a91e58ceeae5d9ade9e5d9590ac6b631cee", "parents": ["9a1a9a61e007e04b37b5ab6e0a6fa747dbbf0f05"], "tags": []}], "date": 1779900227, "git_changesets": ["6302745cd5c0a0672bf06378da7b095414dcb907"], "user": "rvandermeulen@mozilla.com"}, "26539": {"changesets": [{"author": "Ashley Hale \u003cahale@mozilla.com\u003e", "branch": "default", "desc": "Bug 2042595 - Enumerate outputs on all adapters for multi-gpu systems  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302683\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302697\n", "files": ["gfx/thebes/DeviceManagerDx.cpp"], "git_node": "abff3d36610ae3ba4d9e4a2403c9e924b2c5d5e3", "git_parents": ["6302745cd5c0a0672bf06378da7b095414dcb907"], "node": "16e402cc2043b5c1544368200295ce40b72191e1", "parents": ["e0d78a91e58ceeae5d9ade9e5d9590ac6b631cee"], "tags": []}], "date": 1779900257, "git_changesets": ["abff3d36610ae3ba4d9e4a2403c9e924b2c5d5e3"], "user": "rvandermeulen@mozilla.com"}, "26540": {"changesets": [{"author": "Iain Ireland \u003ciireland@mozilla.com\u003e", "branch": "default", "desc": "Bug 2040903: Update alias set of ObjectToIterator  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301605\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302595\n", "files": ["js/src/jit/MIR.h", "js/src/jit/MIROps.yaml", "js/src/jit/ScalarReplacement.cpp"], "git_node": "4e007a4e6b34e4914fc2db0e0667dc4294c2373b", "git_parents": ["abff3d36610ae3ba4d9e4a2403c9e924b2c5d5e3"], "node": "3c15c75806d51aa04a1bfb653224fe01586bbc31", "parents": ["16e402cc2043b5c1544368200295ce40b72191e1"], "tags": []}], "date": 1779900284, "git_changesets": ["4e007a4e6b34e4914fc2db0e0667dc4294c2373b"], "user": "rvandermeulen@mozilla.com"}, "26541": {"changesets": [{"author": "Ryan VanderMeulen \u003crvandermeulen@mozilla.com\u003e", "branch": "default", "desc": "Bug 2042051 - Resolve expected chat model via getModelForChoice in Smart Window telemetry tests  a=dmeehan\n\nThese tests asserted telemetry's recorded chat model against hard-coded strings - directly in the smartbar\nand switcher tests, and via the FALLBACK_MODELS table in the smart-window settings test - so every Remote\nSettings publish that changes a model_choice_id mapping perma-fails them. Resolve through getModelForChoice\n(via a shared modelFor helper added to each test directory's head file) for the choices that actually flow\nthrough RS (1 and 2); leave choice 0 as the \"custom-model\" literal since the resolver short-circuits it.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302796\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302826\n", "files": ["browser/components/aiwindow/ui/test/browser/browser_aiwindow_smartbar_telemetry.js", "browser/components/aiwindow/ui/test/browser/browser_smartwindow_switcher_telemetry.js", "browser/components/aiwindow/ui/test/browser/head.js", "browser/components/preferences/tests/aiFeatures/browser_aiFeatures_smart_window_telemetry.js", "browser/components/preferences/tests/aiFeatures/head_smart_window.js"], "git_node": "75b78923f80ca0fcd014142e3ff1a6d6885a983b", "git_parents": ["4e007a4e6b34e4914fc2db0e0667dc4294c2373b"], "node": "aff013398879e555ee0b7abf8275a2bf74e7926e", "parents": ["3c15c75806d51aa04a1bfb653224fe01586bbc31"], "tags": []}, {"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update remote-settings mobile-experiments ct-logs -  a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302757\n", "files": ["mobile/android/fenix/app/src/main/res/raw/initial_experiments.json", "security/ct/CTKnownLogs.h", "services/settings/dumps/blocklists/addons-bloomfilters.json", "services/settings/dumps/main/ai-window-prompts.json"], "git_node": "9953108476dc01c4d8af51c07da99fd6cd3073c2", "git_parents": ["75b78923f80ca0fcd014142e3ff1a6d6885a983b"], "node": "2054a9ac6f0c0d90e65e0484e600d05b8dc2d674", "parents": ["aff013398879e555ee0b7abf8275a2bf74e7926e"], "tags": []}], "date": 1779902314, "git_changesets": ["75b78923f80ca0fcd014142e3ff1a6d6885a983b", "9953108476dc01c4d8af51c07da99fd6cd3073c2"], "user": "rvandermeulen@mozilla.com"}, "26542": {"changesets": [{"author": "Jared Hirsch \u003cohai@6a68.net\u003e", "branch": "default", "desc": "Bug 2025996 - Add triggers for link collection sharing experiment  a=RyanVM\n\nAdding triggers for upcoming off-train experiments in link collection sharing:\n\n* Add \"userBookmarkFolderActivity\" trigger that fires when the user\n  creates a bookmark folder or adds a new bookmark inside a\n  user-created folder.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D300426\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302833\n", "files": ["browser/components/asrouter/modules/ASRouterTriggerListeners.sys.mjs", "browser/components/asrouter/tests/browser/browser_trigger_listeners.js", "toolkit/components/messaging-system/schemas/TriggerActionSchemas/TriggerActionSchemas.json", "toolkit/components/messaging-system/schemas/TriggerActionSchemas/index.md"], "git_node": "243405e8c021d1f29b6114de8d968717bff46558", "git_parents": ["9953108476dc01c4d8af51c07da99fd6cd3073c2"], "node": "0f823ae7beace7908b7dd4c09ea391e54aded819", "parents": ["2054a9ac6f0c0d90e65e0484e600d05b8dc2d674"], "tags": []}], "date": 1779904884, "git_changesets": ["243405e8c021d1f29b6114de8d968717bff46558"], "user": "rvandermeulen@mozilla.com"}, "26543": {"changesets": [{"author": "Finn Terdal \u003cfterdal@mozilla.com\u003e", "branch": "default", "desc": "Bug 2040385 - Bookmark Folder Panel Opens Even After Removing Last Item  a=RyanVM\n\n_mayAddCommandsItems recalculates whether or not there are any items in\nthe context menu and conditionally shows the \"Open All In Tabs\" or\n\"\u003cEmpty\u003e\" text in the Bookmark Folder menu. Calling that right before we\nset the Empty status text fixes the bug by correctly calculating how\nmany elements are in the menu.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302627\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302778\n", "files": ["browser/components/contentsharing/tests/browser/browser.toml", "browser/components/contentsharing/tests/browser/browser_testShareFolderEmpties.js", "browser/components/places/content/browserPlacesViews.js"], "git_node": "87bd8a460992ec33258d94067bccb3cc8d1c48e6", "git_parents": ["243405e8c021d1f29b6114de8d968717bff46558"], "node": "da032857aa8da088f19dff7819271ba35cd42d89", "parents": ["0f823ae7beace7908b7dd4c09ea391e54aded819"], "tags": []}], "date": 1779904916, "git_changesets": ["87bd8a460992ec33258d94067bccb3cc8d1c48e6"], "user": "rvandermeulen@mozilla.com"}, "26544": {"changesets": [{"author": "Vincent Tunru \u003cgit@vincenttunru.com\u003e", "branch": "default", "desc": "Bug 2039281 - Unify Trust Panel breach detection methods.  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D300303\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302772\n", "files": ["browser/base/content/browser-trustPanel.js", "browser/components/urlbar/tests/browser/browser_trust_panel_icon.js"], "git_node": "8e93d52e2b4aa9654c6a228706d78a129b8aa6e9", "git_parents": ["87bd8a460992ec33258d94067bccb3cc8d1c48e6"], "node": "6cb7e3ebdb9389fb58baef7bc8a0a5d7c0a1a930", "parents": ["da032857aa8da088f19dff7819271ba35cd42d89"], "tags": []}], "date": 1779904944, "git_changesets": ["8e93d52e2b4aa9654c6a228706d78a129b8aa6e9"], "user": "rvandermeulen@mozilla.com"}, "26545": {"changesets": [{"author": "lougeniac64 \u003c5533446+lougeniaC64@users.noreply.github.com\u003e", "branch": "default", "desc": "Bug 2042504 - Hid send tab menu item in the app menu for unverified users  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302580\n\nDifferential Revision: https://phabricator.services.