, "a0c3ed2029b25480ae28b9c0b44de2c5f4606a36"], "user": "rvandermeulen@mozilla.com"}, "26569": {"changesets": [{"author": "Stuart Colville \u003cscolville@mozilla.com\u003e", "branch": "default", "desc": "Bug 2039118 - split out moreFromMozilla UTM tests and use waitForMutationCondition in settingControlRenders r=Gijs a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302058\n", "files": ["browser/components/preferences/tests/head.js", "browser/components/preferences/tests/moreFromMozilla/browser-srd.toml", "browser/components/preferences/tests/moreFromMozilla/browser_moreFromMozilla_config.js", "browser/components/preferences/tests/moreFromMozilla/browser_moreFromMozilla_utm_srd.js"], "git_node": "24ee617870077de9dd0ad614f37e49ae6c74bd68", "git_parents": ["a0c3ed2029b25480ae28b9c0b44de2c5f4606a36"], "node": "6a621c003163b6a9125477b3f17f0a9864228bc4", "parents": ["6b099ecd7257807dc252598b2cd75c895d635754"], "tags": []}], "date": 1779991527, "git_changesets": ["24ee617870077de9dd0ad614f37e49ae6c74bd68"], "user": "rvandermeulen@mozilla.com"}, "26570": {"changesets": [{"author": "t-p-white \u003ctowhite@mozilla.com\u003e", "branch": "default", "desc": "Bug 2039250 - Gate \"Open links in apps\" banner behind in-app-messages-enabled Nimbus flag.  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302458\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302992\n", "files": ["mobile/android/fenix/app/nimbus.fml.yaml", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/browser/OpenInAppOnboardingObserver.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/browser/OpenInAppOnboardingObserverTest.kt"], "git_node": "4defdd934aa20b51ffc49fb511d01a0eec5085ad", "git_parents": ["24ee617870077de9dd0ad614f37e49ae6c74bd68"], "node": "ba00f9db6d558d33afa29b838aea5d3484e107b8", "parents": ["6a621c003163b6a9125477b3f17f0a9864228bc4"], "tags": []}], "date": 1780015363, "git_changesets": ["4defdd934aa20b51ffc49fb511d01a0eec5085ad"], "user": "rvandermeulen@mozilla.com"}, "26571": {"changesets": [{"author": "Omar Gonzalez \u003cs9tpepper@apache.org\u003e", "branch": "default", "desc": "Bug 2033411 - load og:image urls with moz-remote-image protocol  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302671\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303234\n", "files": ["browser/components/genai/content/link-preview-card.mjs"], "git_node": "c94678c13edfcbee875fde7674c915634d3873a2", "git_parents": ["4defdd934aa20b51ffc49fb511d01a0eec5085ad"], "node": "dcbbbfa7d3bad6a5cf2bbc27e799d45050c4bb74", "parents": ["ba00f9db6d558d33afa29b838aea5d3484e107b8"], "tags": []}], "date": 1780015389, "git_changesets": ["c94678c13edfcbee875fde7674c915634d3873a2"], "user": "rvandermeulen@mozilla.com"}, "26572": {"changesets": [{"author": "Nicolas B. Pierron \u003cnicolas.b.pierron@mozilla.com\u003e", "branch": "default", "desc": "Bug 2042907 - Use the script loader's document in EvaluateScriptElements.  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302836\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303019\n", "files": ["dom/script/ScriptLoader.cpp"], "git_node": "a15e3a6bec6aec0cfddc2cb5491d93f703717179", "git_parents": ["c94678c13edfcbee875fde7674c915634d3873a2"], "node": "bf3e71f06c405832e07e58ec2ba1eed1df22f250", "parents": ["dcbbbfa7d3bad6a5cf2bbc27e799d45050c4bb74"], "tags": []}], "date": 1780015414, "git_changesets": ["a15e3a6bec6aec0cfddc2cb5491d93f703717179"], "user": "rvandermeulen@mozilla.com"}, "26573": {"changesets": [{"author": "Stephen A Pohl \u003cspohl@mozilla.com\u003e", "branch": "default", "desc": "Bug 2028944: Remove ReceiveNextEvent runloop spin from macOS relaunch startup.  a=RyanVM\n\nThe Carbon-era ReceiveNextEvent at startup was originally added in bug 377166 so the relaunched process's dock tile would take over from the exiting parent. [NSApplication sharedApplication] handles that via _NSDoOneTimeDockRegistration, so the explicit call is unnecessary. Removing it also avoids dispatching NSWorkspaceDidLaunchApplicationNotification before NSApp is wired up for accessibility, which broke external assistive technologies like VoiceControl on the relaunched process.\n\nThe marionette regression test is based on a debug script by Eitan Isaacson (:eeejay) in bug 2028944 comment 3.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301869\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303208\n", "files": ["toolkit/xre/nsAppRunner.cpp", "toolkit/xre/test/marionette/external_a11y_helper.py", "toolkit/xre/test/marionette/manifest.toml", "toolkit/xre/test/marionette/test_external_a11y_after_launch.py"], "git_node": "f4c5fd255608001052a50952218730d54baa2769", "git_parents": ["a15e3a6bec6aec0cfddc2cb5491d93f703717179"], "node": "7e140b4e99e6026a78a55ba04fcba0c96e3baefe", "parents": ["bf3e71f06c405832e07e58ec2ba1eed1df22f250"], "tags": []}], "date": 1780015441, "git_changesets": ["f4c5fd255608001052a50952218730d54baa2769"], "user": "rvandermeulen@mozilla.com"}, "26574": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update remote-settings tld-suffixes mobile-experiments ct-logs -  a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303189\n", "files": ["mobile/android/fenix/app/src/main/res/raw/initial_experiments.json", "netwerk/dns/effective_tld_names.dat", "security/ct/CTKnownLogs.h", "security/manager/tools/log_list.json", "services/settings/dumps/blocklists/addons-bloomfilters.json", "services/settings/dumps/main/ai-window-prompts.json", "services/settings/dumps/main/search-telemetry-v2.json", "services/settings/dumps/security-state/intermediates.json"], "git_node": "35f2622a687a4afa783550f64a9880eb8595c76f", "git_parents": ["f4c5fd255608001052a50952218730d54baa2769"], "node": "20d0c42ea1967d42674491c46925947bc869c041", "parents": ["7e140b4e99e6026a78a55ba04fcba0c96e3baefe"], "tags": []}], "date": 1780015468, "git_changesets": ["35f2622a687a4afa783550f64a9880eb8595c76f"], "user": "rvandermeulen@mozilla.com"}, "26575": {"changesets": [{"author": "Michael Froman \u003cmfroman@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041981 - Cherry-pick upstream libwebrtc commit 9a7f650bcd r=bwc a=RyanVM\n\nUpstream commit: https://webrtc.googlesource.com/src/+/9a7f650bcd14f241d20f88f4e1ea3b7300de72ac\n       [M148] Always release VideoEncoders before destruction.\n\n       Original change's description:\n       \u003e Always release VideoEncoders before destruction.\n       \u003e\n       \u003e Without a `Release()` call there is a potential for race conditions\n       \u003e between asynchronous encoder callbacks and the destructor sequence.\n       \u003e\n       \u003e Bug: chromium:504620824\n       \u003e Change-Id: I1fba23ef3a4a238503cdf8d2ea5831e815d7b902\n       \u003e Reviewed-on: https://webrtc-review.googlesource.com/c/src/+/465582\n       \u003e Auto-Submit: Erik Spr\u00e5ng \u003csprang@webrtc.org\u003e\n       \u003e Reviewed-by: Sergey Silkin \u003cssilkin@webrtc.org\u003e\n       \u003e Commit-Queue: Sergey Silkin \u003cssilkin@webrtc.org\u003e\n       \u003e Commit-Queue: Erik Spr\u00e5ng \u003csprang@webrtc.org\u003e\n       \u003e Cr-Commit-Position: refs/heads/main@{#47495}\n\n       (cherry picked from commit 21d9744bd599d106da9171fbb1ed09047d7178ca)\n\n       Bug: chromium:505251595,chromium:504620824\n       Change-Id: I1fba23ef3a4a238503cdf8d2ea5831e815d7b902\n       Reviewed-on: https://webrtc-review.googlesource.com/c/src/+/468940\n       Auto-Submit: Chrome Cherry Picker \u003cchrome-cherry-picker@chops-service-accounts.iam.gserviceaccount.com\u003e\n       Commit-Queue: rubber-stamper@appspot.gserviceaccount.com \u003crubber-stamper@appspot.gserviceaccount.com\u003e\n       Bot-Commit: rubber-stamper@appspot.gserviceaccount.com \u003crubber-stamper@appspot.gserviceaccount.com\u003e\n       Cr-Commit-Position: refs/branch-heads/7778@{#7}\n       Cr-Branched-From: ca896b7ffef011bbf6957c99d413c5aac602c99f-refs/heads/main@{#47319}\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302659\n", "files": ["third_party/libwebrtc/moz-patch-stack/9a7f650bcd.no-op-cherry-pick-msg", "third_party/libwebrtc/video/video_stream_encoder.cc", "third_party/libwebrtc/video/video_stream_encoder_unittest.cc"], "git_node": "93a69036a24100b3df1e53bcc06aa8e3cf0582b3", "git_parents": ["35f2622a687a4afa783550f64a9880eb8595c76f"], "node": "99b8047167f10f80c1a97a8e30eb48cf8c234af2", "parents": ["20d0c42ea1967d42674491c46925947bc869c041"], "tags": []}, {"author": "Michael Froman \u003cmfroman@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041981 - Cherry-pick upstream libwebrtc commit 305a870932 r=bwc a=RyanVM\n\nUpstream commit: https://webrtc.googlesource.com/src/+/305a870932d9c9de4bbfe3814d4946b2f6cf2c60\n       [M148] Refactor RTP header extension ID allocation to be persistent and shared.\n\n       Original change's description:\n       \u003e Refactor RTP header extension ID allocation to be persistent and shared.\n       \u003e\n       \u003e - Introduced RtpHeaderExtensionRecorder and RtpHeaderExtensionPicker in\n       \u003e call/payload_type_picker.\n       \u003e - Added SuggestRtpHeaderExtensionId and AddRtpHeaderExtensionMapping to\n       \u003e PayloadTypeSuggester interface.\n       \u003e - Implemented persistent RTP header extension ID mapping in\n       \u003e SdpPayloadTypeSuggester.\n       \u003e - Refactored pc/media_session.cc to use PayloadTypeSuggester for all\n       \u003e RTP header extension ID allocations, replacing UsedRtpHeaderExtensionIds.\n       \u003e - Ensured shared mapping between local and remote extensions for the\n       \u003e same transport.\n       \u003e - Maintained RFC 8285 compliance for one-byte and two-byte ID allocation.\n       \u003e - Updated tests to explicitly allow mixed extensions when two-byte IDs\n       \u003e are expected.\n       \u003e - Removed obsolete UsedRtpHeaderExtensionIds and its unit test.\n       \u003e\n       \u003e Bug: webrtc:503013383\n       \u003e Change-Id: Ic98522b1eec52c736a73bd034493f19ac6524b5a\n       \u003e Reviewed-on: https://webrtc-review.googlesource.com/c/src/+/465300\n       \u003e Auto-Submit: Harald Alvestrand \u003chta@webrtc.org\u003e\n       \u003e Commit-Queue: Harald Alvestrand \u003chta@webrtc.org\u003e\n       \u003e Reviewed-by: Tomas Gunnarsson \u003ctommi@webrtc.org\u003e\n       \u003e Cr-Commit-Position: refs/heads/main@{#47492}\n\n       (cherry picked from commit d1ae1e9ad4d183f4b00ad0962b35bba90162f038)\n\n       Bug: webrtc:503013383\n       Bug: chromium:513880244\n       Fixed: chromium:514078702\n       No-Try: true\n       Change-Id: If466bf7fa67e1277bcdd6b8af8c4f175ad0c9df7\n       Reviewed-on: https://webrtc-review.googlesource.com/c/src/+/472720\n       Reviewed-by: Harald Alvestrand \u003chta@webrtc.org\u003e\n       Reviewed-by: Mirko Bonadei \u003cmbonadei@webrtc.org\u003e\n       Commit-Queue: Jeremy Leconte \u003cjleconte@google.com\u003e\n       Cr-Commit-Position: refs/branch-heads/7778@{#8}\n       Cr-Branched-From: ca896b7ffef011bbf6957c99d413c5aac602c99f-refs/heads/main@{#47319}\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302660\n", "files": ["third_party/libwebrtc/api/rtp_parameters.h", "third_party/libwebrtc/call/BUILD.gn", "third_party/libwebrtc/call/fake_payload_type_suggester.h", "third_party/libwebrtc/call/payload_type.h", "third_party/libwebrtc/call/payload_type_picker.cc", "third_party/libwebrtc/call/payload_type_picker.h", "third_party/libwebrtc/moz-patch-stack/305a870932.no-op-cherry-pick-msg", "third_party/libwebrtc/pc/BUILD.gn", "third_party/libwebrtc/pc/media_session.cc", "third_party/libwebrtc/pc/media_session_unittest.cc", "third_party/libwebrtc/pc/sdp_payload_type_suggester.cc", "third_party/libwebrtc/pc/sdp_payload_type_suggester.h", "third_party/libwebrtc/pc/used_ids.h", "third_party/libwebrtc/pc/used_ids_unittest.cc"], "git_node": "f3c2e828bcc0c5ad068374d783a6dbfa77ecdc2c", "git_parents": ["93a69036a24100b3df1e53bcc06aa8e3cf0582b3"], "node": "36c065ce70c122386f502d9720b8344f011645c9", "parents": ["99b8047167f10f80c1a97a8e30eb48cf8c234af2"], "tags": []}, {"author": "Michael Froman \u003cmfroman@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041981 - Cherry-pick upstream libwebrtc commit d46237a72e r=bwc a=RyanVM\n\nUpstream commit: https://webrtc.googlesource.com/src/+/d46237a72ede7294840c375bed7b9df6f60cdca7\n       [M148] Validate CGImage dimensions in MouseCursorMonitorMac\n\n       Original change's description:\n       \u003e Validate CGImage dimensions in MouseCursorMonitorMac\n       \u003e\n       \u003e This adds missing height checks alongside the existing width checks\n       \u003e when processing and scaling the cursor image.\n       \u003e\n       \u003e Fixed: chromium:513268100\n       \u003e Change-Id: Ida1e58334a9d3bda429819e4af51b33afbd0a95d\n       \u003e Reviewed-on: https://webrtc-review.googlesource.com/c/src/+/472700\n       \u003e Reviewed-by: Alexander Cooper \u003calcooper@chromium.org\u003e\n       \u003e Auto-Submit: Johannes Kron \u003ckron@webrtc.org\u003e\n       \u003e Commit-Queue: Alexander Cooper \u003calcooper@chromium.org\u003e\n       \u003e Cr-Commit-Position: refs/heads/main@{#47715}\n\n       (cherry picked from commit b343cd4e280980f26b4feb80684f57d5b4324e12)\n\n       Bug: chromium:514925120,chromium:513268100\n       Change-Id: Ida1e58334a9d3bda429819e4af51b33afbd0a95d\n       Reviewed-on: https://webrtc-review.googlesource.com/c/src/+/473980\n       Commit-Queue: rubber-stamper@appspot.gserviceaccount.com \u003crubber-stamper@appspot.gserviceaccount.com\u003e\n       Bot-Commit: rubber-stamper@appspot.gserviceaccount.com \u003crubber-stamper@appspot.gserviceaccount.com\u003e\n       Auto-Submit: Chrome Cherry Picker \u003cchrome-cherry-picker@chops-service-accounts.iam.gserviceaccount.com\u003e\n       Cr-Commit-Position: refs/branch-heads/7778@{#9}\n       Cr-Branched-From: ca896b7ffef011bbf6957c99d413c5aac602c99f-refs/heads/main@{#47319}\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302661\n", "files": ["third_party/libwebrtc/modules/desktop_capture/mouse_cursor_monitor_mac.mm", "third_party/libwebrtc/moz-patch-stack/d46237a72e.no-op-cherry-pick-msg"], "git_node": "f35a1b297eb25aa0505abb92eedaf569ccccff66", "git_parents": ["f3c2e828bcc0c5ad068374d783a6dbfa77ecdc2c"], "node": "00a67c33763c51f6535aeab675774cc6672554f9", "parents": ["36c065ce70c122386f502d9720b8344f011645c9"], "tags": []}, {"author": "Michael Froman \u003cmfroman@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041981 - Cherry-pick upstream libwebrtc commit 26c6538381 r=bwc a=RyanVM\n\nUpstream commit: https://webrtc.googlesource.com/src/+/26c6538381a19e8ed58af0c22068db9f050d2967\n       [M148] Guard RestoreTokenManager add/reads with Mutex\n\n       Original change's description:\n       \u003e Guard RestoreTokenManager add/reads with Mutex\n       \u003e\n       \u003e The RestoreTokenManager is a singleton who's adds and reads could be\n       \u003e accessed by multiple threads simultaneously. To prevent any potential\n       \u003e issues/collisions, ensure that such accesses happen behind a lock.\n       \u003e\n       \u003e Bug: chromium:513049286\n       \u003e Change-Id: I44c1c7977a6d02e1ac3fbe00e6ffc7bc22e41e46\n       \u003e Reviewed-on: https://webrtc-review.googlesource.com/c/src/+/472480\n       \u003e Reviewed-by: Mark Foltz \u003cmfoltz@chromium.org\u003e\n       \u003e Auto-Submit: Alexander Cooper \u003calcooper@chromium.org\u003e\n       \u003e Commit-Queue: Mark Foltz \u003cmfoltz@chromium.org\u003e\n       \u003e Cr-Commit-Position: refs/heads/main@{#47711}\n\n       (cherry picked from commit b9f0b184cb5a487fcb4910efaf4f84483ddba284)\n\n       Bug: chromium:514926739,chromium:513049286\n       Change-Id: I44c1c7977a6d02e1ac3fbe00e6ffc7bc22e41e46\n       Reviewed-on: https://webrtc-review.googlesource.com/c/src/+/474060\n       Auto-Submit: Chrome Cherry Picker \u003cchrome-cherry-picker@chops-service-accounts.iam.gserviceaccount.com\u003e\n       Bot-Commit: rubber-stamper@appspot.gserviceaccount.com \u003crubber-stamper@appspot.gserviceaccount.com\u003e\n       Commit-Queue: rubber-stamper@appspot.gserviceaccount.com \u003crubber-stamper@appspot.gserviceaccount.com\u003e\n       Cr-Commit-Position: refs/branch-heads/7778@{#10}\n       Cr-Branched-From: ca896b7ffef011bbf6957c99d413c5aac602c99f-refs/heads/main@{#47319}\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302662\n", "files": ["third_party/libwebrtc/modules/desktop_capture/linux/wayland/restore_token_manager.cc", "third_party/libwebrtc/modules/desktop_capture/linux/wayland/restore_token_manager.h", "third_party/libwebrtc/moz-patch-stack/26c6538381.no-op-cherry-pick-msg"], "git_node": "b624703ad4badb62ffcbcfee91eae695f9817d91", "git_parents": ["f35a1b297eb25aa0505abb92eedaf569ccccff66"], "node": "814d18e86f9af652ae3d60eb5604318913210be9", "parents": ["00a67c33763c51f6535aeab675774cc6672554f9"], "tags": []}, {"author": "Michael Froman \u003cmfroman@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041981 - Cherry-pick upstream libwebrtc commit ac8b0016a8 r=bwc a=RyanVM\n\nUpstream commit: https://webrtc.googlesource.com/src/+/ac8b0016a84a52407e52b92af0671ed23196202c\n       [M148] [desktop capture] Fix TOCTOU race condition in CroppingWindowCapturer.\n\n       Original change's description:\n       \u003e [desktop capture] Fix TOCTOU race condition in CroppingWindowCapturer.\n       \u003e\n       \u003e Crop the frame using the window rectangle captured when the capture\n       \u003e was initiated, rather than re-querying the rectangle after the capture\n       \u003e finishes.\n       \u003e\n       \u003e Bug: chromium:504557432\n       \u003e Change-Id: I459d528ac343163fde9a9dbf6c40a542c1a04c61\n       \u003e Reviewed-on: https://webrtc-review.googlesource.com/c/src/+/467820\n       \u003e Reviewed-by: Stefan Holmer \u003cstefan@webrtc.org\u003e\n       \u003e Reviewed-by: Alexander Cooper \u003calcooper@chromium.org\u003e\n       \u003e Commit-Queue: Mark Foltz \u003cmfoltz@chromium.org\u003e\n       \u003e Cr-Commit-Position: refs/heads/main@{#47575}\n\n       (cherry picked from commit 22f071a33eb46cbabcbf05961127dde7a2e3d908)\n\n       Bug: chromium:514924157,chromium:504557432\n       Change-Id: I459d528ac343163fde9a9dbf6c40a542c1a04c61\n       Reviewed-on: https://webrtc-review.googlesource.com/c/src/+/474160\n       Reviewed-by: Alexander Cooper \u003calcooper@chromium.org\u003e\n       Commit-Queue: Alexander Cooper \u003calcooper@chromium.org\u003e\n       Auto-Submit: Chrome Cherry Picker \u003cchrome-cherry-picker@chops-service-accounts.iam.gserviceaccount.com\u003e\n       Reviewed-by: Mark Foltz \u003cmfoltz@chromium.org\u003e\n       Cr-Commit-Position: refs/branch-heads/7778@{#11}\n       Cr-Branched-From: ca896b7ffef011bbf6957c99d413c5aac602c99f-refs/heads/main@{#47319}\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302663\n", "files": ["third_party/libwebrtc/modules/desktop_capture/cropping_window_capturer.cc", "third_party/libwebrtc/modules/desktop_capture/cropping_window_capturer.h", "third_party/libwebrtc/moz-patch-stack/ac8b0016a8.no-op-cherry-pick-msg"], "git_node": "4a5a8556edb4a63b6ec8d9c32197ba390f6709ae", "git_parents": ["b624703ad4badb62ffcbcfee91eae695f9817d91"], "node": "68be36940850e3802838ee699ba7231368224df5", "parents": ["814d18e86f9af652ae3d60eb5604318913210be9"], "tags": []}, {"author": "Michael Froman \u003cmfroman@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041981 - Cherry-pick upstream libwebrtc commit e3ee86921c r=bwc a=RyanVM\n\nUpstream commit: https://webrtc.googlesource.com/src/+/e3ee86921c57b9f8921045e77f098604803cb66c\n       [M148] In SctpDataChannel use plain bool as safety flag.\n\n       Original change's description:\n       \u003e In SctpDataChannel use plain bool as safety flag.\n       \u003e\n       \u003e SctpDataChannel can be destroyed on various threads and thus safety flag\n       \u003e couldn't be properly invalidated in the destructor. Instead of relying\n       \u003e on it when posting async send, rely on reference counting of the full\n       \u003e object\n       \u003e\n       \u003e Bug: chromium:504716948\n       \u003e Change-Id: I1246fecac26d0761be006b069658d072183546bf\n       \u003e Reviewed-on: https://webrtc-review.googlesource.com/c/src/+/469980\n       \u003e Reviewed-by: Tomas Gunnarsson \u003ctommi@webrtc.org\u003e\n       \u003e Commit-Queue: Danil Chapovalov \u003cdanilchap@webrtc.org\u003e\n       \u003e Cr-Commit-Position: refs/heads/main@{#47635}\n\n       (cherry picked from commit 9b4ffb3281c02327968ed07389082fcb2dd77baa)\n\n       Bug: chromium:514923643,chromium:504716948\n       Change-Id: I1246fecac26d0761be006b069658d072183546bf\n       Reviewed-on: https://webrtc-review.googlesource.com/c/src/+/474800\n       Reviewed-by: Danil Chapovalov \u003cdanilchap@webrtc.org\u003e\n       Commit-Queue: Tomas Gunnarsson \u003ctommi@webrtc.org\u003e\n       Auto-Submit: Chrome Cherry Picker \u003cchrome-cherry-picker@chops-service-accounts.iam.gserviceaccount.com\u003e\n       Reviewed-by: Tomas Gunnarsson \u003ctommi@webrtc.org\u003e\n       Cr-Commit-Position: refs/branch-heads/7778@{#12}\n       Cr-Branched-From: ca896b7ffef011bbf6957c99d413c5aac602c99f-refs/heads/main@{#47319}\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302664\n", "files": ["third_party/libwebrtc/moz-patch-stack/e3ee86921c.no-op-cherry-pick-msg", "third_party/libwebrtc/pc/sctp_data_channel.cc", "third_party/libwebrtc/pc/sctp_data_channel.h", "third_party/libwebrtc/pc/sctp_data_channel_unittest.cc"], "git_node": "bfc6ecf3a9f3942a6c80f82b48f539b7989ae1c5", "git_parents": ["4a5a8556edb4a63b6ec8d9c32197ba390f6709ae"], "node": "d93944856e407d1a94c64b82f2ca1deacee9c41a", "parents": ["68be36940850e3802838ee699ba7231368224df5"], "tags": []}], "date": 1780020441, "git_changesets": ["93a69036a24100b3df1e53bcc06aa8e3cf0582b3", "f3c2e828bcc0c5ad068374d783a6dbfa77ecdc2c", "f35a1b297eb25aa0505abb92eedaf569ccccff66", "b624703ad4badb62ffcbcfee91eae695f9817d91", "4a5a8556edb4a63b6ec8d9c32197ba390f6709ae", "bfc6ecf3a9f3942a6c80f82b48f539b7989ae1c5"], "user": "rvandermeulen@mozilla.com"}, "26576": {"changesets": [{"author": "unifolia \u003cjlewis@mozilla.com\u003e", "branch": "default", "desc": "Bug 2037378 - Prevent SW assistant from reopening automatically when setting unchecked  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302395\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303196\n", "files": ["browser/components/aiwindow/ui/modules/AIWindowTabStatesManager.sys.mjs", "browser/components/aiwindow/ui/test/browser/browser_smartwindow_tab_switching.js"], "git_node": "b69ac5aef222e55db31fa0704cf080e1829458cf", "git_parents": ["bfc6ecf3a9f3942a6c80f82b48f539b7989ae1c5"], "node": "3a19c5368c982c17bf645aa18ccb7762abe7b07d", "parents": ["d93944856e407d1a94c64b82f2ca1deacee9c41a"], "tags": []}], "date": 1780020473, "git_changesets": ["b69ac5aef222e55db31fa0704cf080e1829458cf"], "user": "rvandermeulen@mozilla.com"}, "26577": {"changesets": [{"author": "groovecoder \u003c71928+groovecoder@users.noreply.github.com\u003e", "branch": "default", "desc": "Bug 2041052 - fix(relay): reduce excessive Relay API calls from getRelayProfileInfo()  a=RyanVM\n\ngetRelayProfileInfo() fires 2 API calls (profiles + addresses) on every\nASRouter targeting evaluation. At scale this overwhelmed the Relay service.\n\n- Add feature-pref guard: return null unless signon.firefoxRelay.feature\n  is \"enabled\", skipping all network calls for non-Relay users (~99% of\n  Firefox installs).\n- Deduplicate concurrent calls: store the in-flight promise in a\n  module-level variable so concurrent callers from JEXL targeting\n  (isRelayFreeTier + relayEmailMasksCount) share one network round-trip.\n- Add persistent pref-based cache: store result and timestamp in\n  signon.firefoxRelay.profileInfo.cache and\n  signon.firefoxRelay.profileInfo.cacheTimestamp so the cache survives\n  browser restarts. 24-hour TTL.\n- Return stale cache on API errors for graceful degradation.\n- Increase CachedTargetingGetter interval for relayProfileInfo from\n  6 hours to 24 hours.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301587\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303162\n", "files": ["browser/components/asrouter/modules/ASRouterTargeting.sys.mjs", "toolkit/components/satchel/integrations/FirefoxRelay.sys.mjs"], "git_node": "7c276eec1e2e137577dbd859a6c6b98774c3df00", "git_parents": ["b69ac5aef222e55db31fa0704cf080e1829458cf"], "node": "baefae71efc3a65e60b373eb11c02bda188ab135", "parents": ["3a19c5368c982c17bf645aa18ccb7762abe7b07d"], "tags": []}], "date": 1780020517, "git_changesets": ["7c276eec1e2e137577dbd859a6c6b98774c3df00"], "user": "rvandermeulen@mozilla.com"}, "26578": {"changesets": [{"author": "Vincent Tunru \u003cgit@vincenttunru.com\u003e", "branch": "default", "desc": "Bug 2024187 - Enable breach alerts in the Trust Panel.  a=RyanVM\n\nThis will enable the new breach alerts feature in the trust panel, and the setting to disable it.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302624\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302771\n", "files": ["browser/app/profile/firefox.js"], "git_node": "f304f82ee191c67ebea355e485f0aec72b2f3896", "git_parents": ["7c276eec1e2e137577dbd859a6c6b98774c3df00"], "node": "d2519f4d1c466259f98bae5f86a670826a232e58", "parents": ["baefae71efc3a65e60b373eb11c02bda188ab135"], "tags": []}], "date": 1780020622, "git_changesets": ["f304f82ee191c67ebea355e485f0aec72b2f3896"], "user": "rvandermeulen@mozilla.com"}, "26579": {"changesets": [{"author": "Emma Zuehlcke \u003cemz@mozilla.com\u003e", "branch": "default", "desc": "Bug 2038727 - Remove dead Firefox Private Network proxy card from about:protections  a=RyanVM\n\nThe proxy card has been gated off by default since 2019 (the\nbrowser.contentblocking.report.proxy.enabled pref defaults to false in\nfirefox.js), and even when forced on it only ever rendered for en-US\nusers in the US who did not have the long-discontinued Firefox Private\nNetwork extension installed. Remove the card, its parent-actor support,\nrelated prefs, logos, tests, and dependent test pref-pushes.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301746\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303076\n", "files": ["browser/actors/AboutProtectionsParent.sys.mjs", "browser/app/profile/firefox.js", "browser/base/content/logos/proxy-dark.svg", "browser/base/content/logos/proxy-light.svg", "browser/base/content/test/protectionsUI/browser_protectionsUI.js", "browser/base/content/test/protectionsUI/browser_protectionsUI_info_message.js", "browser/base/content/test/protectionsUI/browser_protectionsUI_milestones.js", "browser/base/content/test/static/head.js", "browser/base/jar.mn", "browser/components/protections/content/protections.css", "browser/components/protections/content/protections.html", "browser/components/protections/content/protections.mjs", "browser/components/protections/content/proxy-card.mjs", "browser/components/protections/jar.mn", "browser/components/protections/test/browser/browser.toml", "browser/components/protections/test/browser/browser_protections_proxy.js", "browser/components/protections/test/browser/browser_protections_telemetry.js", "browser/components/uitour/test/browser_UITour_showProtectionReport.js", "eslint-file-globals.config.mjs", "toolkit/modules/RemotePageAccessManager.sys.mjs"], "git_node": "c170be37fc02c0d338a15608b37c3e5d6e4338b3", "git_parents": ["f304f82ee191c67ebea355e485f0aec72b2f3896"], "node": "32ed976c4543c10c362aeac69e3f1a1d7d749ed0", "parents": ["d2519f4d1c466259f98bae5f86a670826a232e58"], "tags": []}, {"author": "Emma Zuehlcke \u003cemz@mozilla.com\u003e", "branch": "default", "desc": "Bug 2038727 - Localize VPN promo strings on about:protections  a=RyanVM\n\nMove the VPN promo card and banner strings out of the en-US-only\npreview namespace and into browser/locales/en-US/browser/protections.ftl\nso they are exposed to translators. Drop the inline \u003cbr\u003e tags that the\noriginal comments flagged as un-translatable; the IDs themselves stay\nunchanged so HTML and JS reference sites continue to work.\n\nWith the strings migrated, remove the preview/protections.ftl jar entry,\nthe \u003clink\u003e tag in protections.html, and the now-empty source FTL.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301747\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303077\n", "files": ["browser/components/protections/content/protections.ftl", "browser/components/protections/content/protections.html", "browser/components/protections/content/vpn-card.mjs", "browser/locales/en-US/browser/protections.ftl", "browser/locales/jar.mn"], "git_node": "28678e09727632f544211e2ccc49fde4556b814d", "git_parents": ["c170be37fc02c0d338a15608b37c3e5d6e4338b3"], "node": "ace57b23c4d5327155fa96e58f0a10a024825de7", "parents": ["32ed976c4543c10c362aeac69e3f1a1d7d749ed0"], "tags": []}], "date": 1780020840, "git_changesets": ["c170be37fc02c0d338a15608b37c3e5d6e4338b3", "28678e09727632f544211e2ccc49fde4556b814d"], "user": "rvandermeulen@mozilla.com"}, "26580": {"changesets": [{"author": "Elissa Cha \u003cecha@mozilla.com\u003e", "branch": "default", "desc": "Bug 2040509 - Add Nimbus/configuration support for Smart Window default experiment  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301884\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303204\n", "files": ["browser/components/aiwindow/ui/test/browser/browser.toml", "browser/components/aiwindow/ui/test/browser/browser_smartwindow_nimbus.js", "toolkit/components/nimbus/FeatureManifest.yaml"], "git_node": "7420263e8bdbe1908f9c87890214849dc5a6b8a3", "git_parents": ["28678e09727632f544211e2ccc49fde4556b814d"], "node": "02b7dbcfcdb966247f0d0cc98b68f9f971da9156", "parents": ["ace57b23c4d5327155fa96e58f0a10a024825de7"], "tags": []}], "date": 1780020868, "git_changesets": ["7420263e8bdbe1908f9c87890214849dc5a6b8a3"], "user": "rvandermeulen@mozilla.com"}, "26581": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Import translations from main\n", "files": ["mobile/android/android-components/components/feature/addons/src/main/res/values-bqi/strings.xml", "mobile/android/fenix/app/longfox/src/main/res/values-ka/strings.xml", "mobile/android/fenix/app/src/main/res/values-be/strings.xml", "mobile/android/fenix/app/src/main/res/values-bg/strings.xml", "mobile/android/fenix/app/src/main/res/values-cy/strings.xml", "mobile/android/fenix/app/src/main/res/values-de/strings.xml", "mobile/android/fenix/app/src/main/res/values-dsb/strings.xml", "mobile/android/fenix/app/src/main/res/values-en-rGB/strings.xml", "mobile/android/fenix/app/src/main/res/values-es-rAR/strings.xml", "mobile/android/fenix/app/src/main/res/values-eu/strings.xml", "mobile/android/fenix/app/src/main/res/values-fr/strings.xml", "mobile/android/fenix/app/src/main/res/values-gl/strings.xml", "mobile/android/fenix/app/src/main/res/values-gn/strings.xml", "mobile/android/fenix/app/src/main/res/values-hsb/strings.xml", "mobile/android/fenix/app/src/main/res/values-hu/strings.xml", "mobile/android/fenix/app/src/main/res/values-ia/strings.xml", "mobile/android/fenix/app/src/main/res/values-it/strings.xml", "mobile/android/fenix/app/src/main/res/values-iw/strings.xml", "mobile/android/fenix/app/src/main