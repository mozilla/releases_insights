 Revision: https://phabricator.services.mozilla.com/D301038\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303733\n", "files": ["netwerk/protocol/http/HttpBaseChannel.cpp", "netwerk/protocol/http/HttpChannelChild.cpp", "netwerk/protocol/http/InterceptedHttpChannel.cpp", "netwerk/protocol/http/TRRServiceChannel.cpp", "netwerk/protocol/http/nsHttpChannel.cpp"], "git_node": "4b202ad051884717c79287880ee6fd2b28320349", "git_parents": ["e647a011158dce70c67c4d5e06a7f9e99bd388ac"], "node": "72698770473b509444b04229689edb3c3753971e", "parents": ["a53e14b38ef4448dfa0685019c5cd07382fd138b"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 2036929 - Hold strong ref while calling nsIStreamListener methods  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302601\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303734\n", "files": ["dom/base/Document.cpp", "dom/base/nsObjectLoadingContent.cpp", "dom/base/nsSyncLoadService.cpp", "dom/fetch/FetchDriver.cpp", "dom/html/MediaDocument.cpp", "dom/jsurl/nsJSProtocolHandler.cpp", "dom/media/ChannelMediaResource.cpp", "dom/media/mediaelement/HTMLMediaElement.cpp", "dom/security/nsHTTPSOnlyStreamListener.cpp", "dom/xhr/XMLHttpRequestMainThread.cpp", "dom/xslt/xslt/txMozillaStylesheetCompiler.cpp", "image/SVGDocumentWrapper.cpp", "image/VectorImage.cpp", "image/decoders/icon/win/nsIconChannel.cpp", "image/imgLoader.cpp", "layout/style/StreamLoader.cpp", "mobile/android/components/geckoview/GeckoViewContentChannelChild.cpp", "modules/libjar/nsJARChannel.cpp", "modules/libjar/zipwriter/nsDeflateConverter.cpp", "modules/libjar/zipwriter/nsZipDataStream.cpp", "modules/libjar/zipwriter/nsZipWriter.cpp", "netwerk/base/nsAsyncStreamCopier.cpp", "netwerk/base/nsBaseChannel.cpp", "netwerk/base/nsIncrementalDownload.cpp", "netwerk/base/nsIncrementalStreamLoader.cpp", "netwerk/base/nsRequestObserverProxy.cpp", "netwerk/base/nsSimpleStreamListener.cpp", "netwerk/base/nsStreamListenerTee.cpp", "netwerk/base/nsStreamLoader.cpp", "netwerk/ipc/DocumentLoadListener.cpp", "netwerk/protocol/http/EarlyHintPreloader.cpp", "netwerk/protocol/http/HttpBaseChannel.cpp", "netwerk/protocol/http/HttpTransactionParent.cpp", "netwerk/protocol/http/OpaqueResponseUtils.cpp", "netwerk/protocol/http/ParentChannelListener.cpp", "netwerk/protocol/http/TRRServiceChannel.cpp", "netwerk/protocol/viewsource/nsViewSourceChannel.cpp", "netwerk/streamconv/converters/nsIndexedToHTML.cpp", "netwerk/streamconv/converters/nsMultiMixedConv.cpp", "parser/prototype/PrototypeDocumentParser.cpp", "toolkit/components/extensions/webrequest/ChannelWrapper.cpp", "toolkit/components/extensions/webrequest/StreamFilterParent.cpp", "uriloader/base/nsURILoader.cpp", "uriloader/exthandler/ExternalHelperAppChild.cpp", "uriloader/exthandler/ExternalHelperAppParent.cpp", "uriloader/preload/FetchPreloader.cpp", "uriloader/preload/gtest/TestFetchPreloader.cpp"], "git_node": "f536c76cc377686b0526e354054ee718372c96d2", "git_parents": ["4b202ad051884717c79287880ee6fd2b28320349"], "node": "2a773c1337e8681817aeb27212273c712d5a0636", "parents": ["72698770473b509444b04229689edb3c3753971e"], "tags": []}], "date": 1780332175, "git_changesets": ["e647a011158dce70c67c4d5e06a7f9e99bd388ac", "4b202ad051884717c79287880ee6fd2b28320349", "f536c76cc377686b0526e354054ee718372c96d2"], "user": "rvandermeulen@mozilla.com"}, "26639": {"changesets": [{"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 2041610 - Improve URL deserialization  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302308\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303712\n", "files": ["netwerk/base/nsStandardURL.cpp", "netwerk/base/nsStandardURL.h"], "git_node": "cc000d94c402ee81c9445c4561462ea9ec8fc6f6", "git_parents": ["f536c76cc377686b0526e354054ee718372c96d2"], "node": "b59d06af59e73f191d5789a137f983c7b0238501", "parents": ["2a773c1337e8681817aeb27212273c712d5a0636"], "tags": []}], "date": 1780332201, "git_changesets": ["cc000d94c402ee81c9445c4561462ea9ec8fc6f6"], "user": "rvandermeulen@mozilla.com"}, "26640": {"changesets": [{"author": "Edgar Chen \u003cechen@mozilla.com\u003e", "branch": "default", "desc": "Bug 2042268 - Properly clean up ObservableArray proxy;  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302983\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303717\n", "files": ["dom/bindings/Codegen.py"], "git_node": "41928d44efb55049028b3a4d4e312b37c702e05b", "git_parents": ["cc000d94c402ee81c9445c4561462ea9ec8fc6f6"], "node": "b0a8eb7de5615cecc62998988a84848be9345d99", "parents": ["b59d06af59e73f191d5789a137f983c7b0238501"], "tags": []}], "date": 1780332224, "git_changesets": ["41928d44efb55049028b3a4d4e312b37c702e05b"], "user": "rvandermeulen@mozilla.com"}, "26641": {"changesets": [{"author": "Jeff Muizelaar \u003cjmuizelaar@mozilla.com\u003e", "branch": "default", "desc": "Bug 1654642 - Enable transport-cc for audio codecs;  a=RyanVM\n\nWith transport-cc negotiated on audio, libwebrtc's BWE probe pacer emits\npadding-only packets on the audio media SSRC. These reach the encoded transform\nreceiver without the audio-level RTP header extension, so the audioLevel WPT\nfails.\n\nThis is libwebrtc-wide, not a Firefox regression from enabling transport-cc:\nChrome only passes because its mono opus default keeps audio packets below the\nBWE probe-activation threshold. Munging stereo opus into Chrome's SDP\nreproduces the same \"No audioLevel\" failure.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302221\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303744\n", "files": ["dom/media/webrtc/jsapi/DefaultCodecPreferences.cpp", "dom/media/webrtc/jsapi/DefaultCodecPreferences.h", "dom/media/webrtc/jsapi/PeerConnectionImpl.cpp", "dom/media/webrtc/jsapi/RTCRtpTransceiver.cpp", "dom/media/webrtc/jsep/JsepCodecDescription.h", "dom/media/webrtc/libwebrtcglue/AudioConduit.cpp", "dom/media/webrtc/libwebrtcglue/CodecConfig.h", "dom/media/webrtc/tests/mochitests/test_peerConnection_basicAudioVideoVerifyExtmap.html", "dom/media/webrtc/tests/mochitests/test_peerConnection_basicAudioVideoVerifyExtmapSendonly.html", "media/webrtc/signaling/gtest/MockJsepCodecPreferences.h", "media/webrtc/signaling/gtest/jsep_session_unittest.cpp", "media/webrtc/signaling/gtest/jsep_track_unittest.cpp", "modules/libpref/init/StaticPrefList.yaml", "testing/web-platform/meta/webrtc-encoded-transform/tentative/RTCEncodedAudioFrame-audiolevel.html.ini"], "git_node": "8b07a5525e1ade873192bb8b92c0e10f250f9418", "git_parents": ["41928d44efb55049028b3a4d4e312b37c702e05b"], "node": "dc7204e71b5365e283dde08cf0d6760f23455412", "parents": ["b0a8eb7de5615cecc62998988a84848be9345d99"], "tags": []}], "date": 1780332292, "git_changesets": ["8b07a5525e1ade873192bb8b92c0e10f250f9418"], "user": "rvandermeulen@mozilla.com"}, "26642": {"changesets": [{"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 2040294 - Activate the ignoring of the mozillaOnline distribution  a=RyanVM DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301017\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303730\n", "files": ["browser/app/profile/firefox.js"], "git_node": "5f7df87944127014e9ffb94a253e42ea75e754be", "git_parents": ["8b07a5525e1ade873192bb8b92c0e10f250f9418"], "node": "a147719f39f8b1723dd1ef1691dc69795101bc22", "parents": ["dc7204e71b5365e283dde08cf0d6760f23455412"], "tags": []}], "date": 1780332325, "git_changesets": ["5f7df87944127014e9ffb94a253e42ea75e754be"], "user": "rvandermeulen@mozilla.com"}, "26643": {"changesets": [{"author": "Lars Eggert \u003clars@eggert.org\u003e", "branch": "default", "desc": "Bug 2040637 - Reconcile ssl_tokens_cache_persistence pref with user.js  a=RyanVM\n\nSSLTokensCache::Init() runs before user prefs (user.js) are applied, so it\nsees the compile-time default for network.ssl_tokens_cache_persistence.\n\nInit() now registers the profile-after-change observer unconditionally\n(before the pref check). The handler reconciles persistence state with\nthe actual pref value: enabling write observers and the shutdown blocker\nif the pref is now true (Bug 2040637), or tearing them down if Init()\nset them up but the pref is now false (Bug 2034342).\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301474\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303702\n", "files": ["netwerk/base/SSLTokensCache.cpp", "netwerk/base/SSLTokensCache.h", "netwerk/test/unit/test_ssl_token_cache_persist.js", "netwerk/test/unit/test_ssl_token_cache_persist_disabled.js", "netwerk/test/unit/xpcshell.toml"], "git_node": "9cc607156c60cf39a6cabc459aecbb527859d2af", "git_parents": ["5f7df87944127014e9ffb94a253e42ea75e754be"], "node": "3fbd2ba39635486119ee8152599983fe3cbdbaff", "parents": ["a147719f39f8b1723dd1ef1691dc69795101bc22"], "tags": []}], "date": 1780332992, "git_changesets": ["9cc607156c60cf39a6cabc459aecbb527859d2af"], "user": "rvandermeulen@mozilla.com"}, "26644": {"changesets": [{"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 2036929 - Make nsUnknownDecoder::CheckListenerChain return error  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D303834\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303853\n", "files": ["netwerk/streamconv/converters/nsUnknownDecoder.cpp"], "git_node": "5ddf63af1de8d5d023631ea59bae9c4ae5e18fd6", "git_parents": ["9cc607156c60cf39a6cabc459aecbb527859d2af"], "node": "af33a68a6a8e5b9e76a8d3f45ad2cc35b1f3e31b", "parents": ["3fbd2ba39635486119ee8152599983fe3cbdbaff"], "tags": []}], "date": 1780338652, "git_changesets": ["5ddf63af1de8d5d023631ea59bae9c4ae5e18fd6"], "user": "rvandermeulen@mozilla.com"}, "26645": {"changesets": [{"author": "Michael Froman \u003cmfroman@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041981 - Cherry-pick upstream libwebrtc commit 9a7f650bcd r=bwc a=RyanVM\n\nUpstream commit: https://webrtc.googlesource.com/src/+/9a7f650bcd14f241d20f88f4e1ea3b7300de72ac\n       [M148] Always release VideoEncoders before destruction.\n\n       Original change's description:\n       \u003e Always release VideoEncoders before destruction.\n       \u003e\n       \u003e Without a `Release()` call there is a potential for race conditions\n       \u003e between asynchronous encoder callbacks and the destructor sequence.\n       \u003e\n       \u003e Bug: chromium:504620824\n       \u003e Change-Id: I1fba23ef3a4a238503cdf8d2ea5831e815d7b902\n       \u003e Reviewed-on: https://webrtc-review.googlesource.com/c/src/+/465582\n       \u003e Auto-Submit: Erik Spr\u00e5ng \u003csprang@webrtc.org\u003e\n       \u003e Reviewed-by: Sergey Silkin \u003cssilkin@webrtc.org\u003e\n       \u003e Commit-Queue: Sergey Silkin \u003cssilkin@webrtc.org\u003e\n       \u003e Commit-Queue: Erik Spr\u00e5ng \u003csprang@webrtc.org\u003e\n       \u003e Cr-Commit-Position: refs/heads/main@{#47495}\n\n       (cherry picked from commit 21d9744bd599d106da9171fbb1ed09047d7178ca)\n\n       Bug: chromium:505251595,chromium:504620824\n       Change-Id: I1fba23ef3a4a238503cdf8d2ea5831e815d7b902\n       Reviewed-on: https://webrtc-review.googlesource.com/c/src/+/468940\n       Auto-Submit: Chrome Cherry Picker \u003cchrome-cherry-picker@chops-service-accounts.iam.gserviceaccount.com\u003e\n       Commit-Queue: rubber-stamper@appspot.gserviceaccount.com \u003crubber-stamper@appspot.gserviceaccount.com\u003e\n       Bot-Commit: rubber-stamper@appspot.gserviceaccount.com \u003crubber-stamper@appspot.gserviceaccount.com\u003e\n       Cr-Commit-Position: refs/branch-heads/7778@{#7}\n       Cr-Branched-From: ca896b7ffef011bbf6957c99d413c5aac602c99f-refs/heads/main@{#47319}\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302659\n", "files": ["third_party/libwebrtc/moz-patch-stack/9a7f650bcd.no-op-cherry-pick-msg", "third_party/libwebrtc/video/video_stream_encoder.cc", "third_party/libwebrtc/video/video_stream_encoder_unittest.cc"], "git_node": "9c97c7d859798e244776f7da80f908f13b74cb37", "git_parents": ["5ddf63af1de8d5d023631ea59bae9c4ae5e18fd6"], "node": "ae62b572921e6c3fceeaef04b58e66f778566f20", "parents": ["af33a68a6a8e5b9e76a8d3f45ad2cc35b1f3e31b"], "tags": []}, {"author": "Michael Froman \u003cmfroman@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041981 - Cherry-pick upstream libwebrtc commit 305a870932 r=bwc a=RyanVM\n\nUpstream commit: https://webrtc.googlesource.com/src/+/305a870932d9c9de4bbfe3814d4946b2f6cf2c60\n       [M148] Refactor RTP header extension ID allocation to be persistent and shared.\n\n       Original change's description:\n       \u003e Refactor RTP header extension ID allocation to be persistent and shared.\n       \u003e\n       \u003e - Introduced RtpHeaderExtensionRecorder and RtpHeaderExtensionPicker in\n       \u003e call/payload_type_picker.\n       \u003e - Added SuggestRtpHeaderExtensionId and AddRtpHeaderExtensionMapping to\n       \u003e PayloadTypeSuggester interface.\n       \u003e - Implemented persistent RTP header extension ID mapping in\n       \u003e SdpPayloadTypeSuggester.\n       \u003e - Refactored pc/media_session.cc to use PayloadTypeSuggester for all\n       \u003e RTP header extension ID allocations, replacing UsedRtpHeaderExtensionIds.\n       \u003e - Ensured shared mapping between local and remote extensions for the\n       \u003e same transport.\n       \u003e - Maintained RFC 8285 compliance for one-byte and two-byte ID allocation.\n       \u003e - Updated tests to explicitly allow mixed extensions when two-byte IDs\n       \u003e are expected.\n       \u003e - Removed obsolete UsedRtpHeaderExtensionIds and its unit test.\n       \u003e\n       \u003e Bug: webrtc:503013383\n       \u003e Change-Id: Ic98522b1eec52c736a73bd034493f19ac6524b5a\n       \u003e Reviewed-on: https://webrtc-review.googlesource.com/c/src/+/465300\n       \u003e Auto-Submit: Harald Alvestrand \u003chta@webrtc.org\u003e\n       \u003e Commit-Queue: Harald Alvestrand \u003chta@webrtc.org\u003e\n       \u003e Reviewed-by: Tomas Gunnarsson \u003ctommi@webrtc.org\u003e\n       \u003e Cr-Commit-Position: refs/heads/main@{#47492}\n\n       (cherry picked from commit d1ae1e9ad4d183f4b00ad0962b35bba90162f038)\n\n       Bug: webrtc:503013383\n       Bug: chromium:513880244\n       Fixed: chromium:514078702\n       No-Try: true\n       Change-Id: If466bf7fa67e1277bcdd6b8af8c4f175ad0c9df7\n       Reviewed-on: https://webrtc-review.googlesource.com/c/src/+/472720\n       Reviewed-by: Harald Alvestrand \u003chta@webrtc.org\u003e\n       Reviewed-by: Mirko Bonadei \u003cmbonadei@webrtc.org\u003e\n       Commit-Queue: Jeremy Leconte \u003cjleconte@google.com\u003e\n       Cr-Commit-Position: refs/branch-heads/7778@{#8}\n       Cr-Branched-From: ca896b7ffef011bbf6957c99d413c5aac602c99f-refs/heads/main@{#47319}\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302660\n", "files": ["third_party/libwebrtc/api/rtp_parameters.h", "third_party/libwebrtc/call/BUILD.gn", "third_party/libwebrtc/call/fake_payload_type_suggester.h", "third_party/libwebrtc/call/payload_type.h", "third_party/libwebrtc/call/payload_type_picker.cc", "third_party/libwebrtc/call/payload_type_picker.h", "third_party/libwebrtc/moz-patch-stack/305a870932.no-op-cherry-pick-msg", "third_party/libwebrtc/pc/BUILD.gn", "third_party/libwebrtc/pc/media_session.cc", "third_party/libwebrtc/pc/media_session_unittest.cc", "third_party/libwebrtc/pc/sdp_payload_type_suggester.cc", "third_party/libwebrtc/pc/sdp_payload_type_suggester.h", "third_party/libwebrtc/pc/used_ids.h", "third_party/libwebrtc/pc/used_ids_unittest.cc"], "git_node": "39c33995cf6f991c6bb8436c0ba982528972ef00", "git_parents": ["9c97c7d859798e244776f7da80f908f13b74cb37"], "node": "dd1ebf59f06cac0cae2946f959d7eb99c8ed23b4", "parents": ["ae62b572921e6c3fceeaef04b58e66f778566f20"], "tags": []}, {"author": "Michael Froman \u003cmfroman@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041981 - Cherry-pick upstream libwebrtc commit d46237a72e r=bwc a=RyanVM\n\nUpstream commit: https://webrtc.googlesource.com/src/+/d46237a72ede7294840c375bed7b9df6f60cdca7\n       [M148] Validate CGImage dimensions in MouseCursorMonitorMac\n\n       Original change's description:\n       \u003e Validate CGImage dimensions in MouseCursorMonitorMac\n       \u003e\n       \u003e This adds missing height checks alongside the existing width checks\n       \u003e when processing and scaling the cursor image.\n       \u003e\n       \u003e Fixed: chromium:513268100\n       \u003e Change-Id: Ida1e58334a9d3bda429819e4af51b33afbd0a95d\n       \u003e Reviewed-on: https://webrtc-review.googlesource.com/c/src/+/472700\n       \u003e Reviewed-by: Alexander Cooper \u003calcooper@chromium.org\u003e\n       \u003e Auto-Submit: Johannes Kron \u003ckron@webrtc.org\u003e\n       \u003e Commit-Queue: Alexander Cooper \u003calcooper@chromium.org\u003e\n       \u003e Cr-Commit-Position: refs/heads/main@{#47715}\n\n       (cherry picked from commit b343cd4e280980f26b4feb80684f57d5b4324e12)\n\n       Bug: chromium:514925120,chromium:513268100\n       Change-Id: Ida1e58334a9d3bda429819e4af51b33afbd0a95d\n       Reviewed-on: https://webrtc-review.googlesource.com/c/src/+/473980\n       Commit-Queue: rubber-stamper@appspot.gserviceaccount.com \u003crubber-stamper@appspot.gserviceaccount.com\u003e\n       Bot-Commit: rubber-stamper@appspot.gserviceaccount.com \u003crubber-stamper@appspot.gserviceaccount.com\u003e\n       Auto-Submit: Chrome Cherry Picker \u003cchrome-cherry-picker@chops-service-accounts.iam.gserviceaccount.com\u003e\n       Cr-Commit-Position: refs/branch-heads/7778@{#9}\n       Cr-Branched-From: ca896b7ffef011bbf6957c99d413c5aac602c99f-refs/heads/main@{#47319}\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302661\n", "files": ["third_party/libwebrtc/modules/desktop_capture/mouse_cursor_monitor_mac.mm", "third_party/libwebrtc/moz-patch-stack/d46237a72e.no-op-cherry-pick-msg"], "git_node": "5aa80d35141989fa065bf941fdbc55589aa185b4", "git_parents": ["39c33995cf6f991c6bb8436c0ba982528972ef00"], "node": "e93395e227c6b31beb2ff63940142da29c3f9118", "parents": ["dd1ebf59f06cac0cae2946f959d7eb99c8ed23b4"], "tags": []}, {"author": "Michael Froman \u003cmfroman@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041981 - Cherry-pick upstream libwebrtc commit 26c6538381 r=bwc a=RyanVM\n\nUpstream commit: https://webrtc.googlesource.com/src/+/26c6538381a19e8ed58af0c22068db9f050d2967\n       [M148] Guard RestoreTokenManager add/reads with Mutex\n\n       Original change's description:\n       \u003e Guard RestoreTokenManager add/reads with Mutex\n       \u003e\n       \u003e The RestoreTokenManager is a singleton who's adds and reads could be\n       \u003e accessed by multiple threads simultaneously. To prevent any potential\n       \u003e issues/collisions, ensure that such accesses happen behind a lock.\n       \u003e\n       \u003e Bug: chromium:513049286\n       \u003e Change-Id: I44c1c7977a6d02e1ac3fbe00e6ffc7bc22e41e46\n       \u003e Reviewed-on: https://webrtc-review.googlesource.com/c/src/+/472480\n       \u003e Reviewed-by: Mark Foltz \u003cmfoltz@chromium.org\u003e\n       \u003e Auto-Submit: Alexander Cooper \u003calcooper@chromium.org\u003e\n       \u003e Commit-Queue: Mark Foltz \u003cmfoltz@chromium.org\u003e\n       \u003e Cr-Commit-Position: refs/heads/main@{#47711}\n\n       (cherry picked from commit b9f0b184cb5a487fcb4910efaf4f84483ddba284)\n\n       Bug: chromium:514926739,chromium:513049286\n       Change-Id: I44c1c7977a6d02e1ac3fbe00e6ffc7bc22e41e46\n       Reviewed-on: https://webrtc-review.googlesource.com/c/src/+/474060\n       Auto-Submit: Chrome Cherry Picker \u003cchrome-cherry-picker@chops-service-accounts.iam.gserviceaccount.com\u003e\n       Bot-Commit: rubber-stamper@appspot.gserviceaccount.com \u003crubber-stamper@appspot.gserviceaccount.com\u003e\n       Commit-Queue: rubber-stamper@appspot.gserviceaccount.com \u003crubber-stamper@appspot.gserviceaccount.com\u003e\n       Cr-Commit-Position: refs/branch-heads/7778@{#10}\n       Cr-Branched-From: ca896b7ffef011bbf6957c99d413c5aac602c99f-refs/heads/main@{#47319}\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302662\n", "files": ["third_party/libwebrtc/modules/desktop_capture/linux/wayland/restore_token_manager.cc", "third_party/libwebrtc/modules/desktop_capture/linux/wayland/restore_token_manager.h", "third_party/libwebrtc/moz-patch-stack/26c6538381.no-op-cherry-pick-msg"], "git_node": "3abec1470830afcfc4e59a4ca6a5a2d8b798d6b1", "git_parents": ["5aa80d35141989fa065bf941fdbc55589aa185b4"], "node": "6b6249186bfcb4779d454cc139a81de37b7860a7", "parents": ["e93395e227c6b31beb2ff63940142da29c3f9118"], "tags": []}, {"author": "Michael Froman \u003cmfroman@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041981 - Cherry-pick upstream libwebrtc commit ac8b0016a8 r=bwc a=RyanVM\n\nUpstream commit: https://webrtc.googlesource.com/src/+/ac8b0016a84a52407e52b92af0671ed23196202c\n       [M148] [desktop capture] Fix TOCTOU race condition in CroppingWindowCapturer.\n\n       Original change's description:\n       \u003e [desktop capture] Fix TOCTOU race condition in CroppingWindowCapturer.\n       \u003e\n       \u003e Crop the frame using the window rectangle captured when the capture\n       \u003e was initiated, rather than re-querying the rectangle after the capture\n       \u003e finishes.\n       \u003e\n       \u003e Bug: chromium:504557432\n       \u003e Change-Id: I459d528ac343163fde9a9dbf6c40a542c1a04c61\n       \u003e Reviewed-on: https://webrtc-review.googlesource.com/c/src/+/467820\n       \u003e Reviewed-by: Stefan Holmer \u003cstefan@webrtc.org\u003e\n       \u003e Reviewed-by: Alexander Cooper \u003calcooper@chromium.org\u003e\n       \u003e Commit-Queue: Mark Foltz \u003cmfoltz@chromium.org\u003e\n       \u003e Cr-Commit-Position: refs/heads/main@{#47575}\n\n       (cherry picked from commit 22f071a33eb46cbabcbf05961127dde7a2e3d908)\n\n       Bug: chromium:514924157,chromium:504557432\n       Change-Id: I459d528ac343163fde9a9dbf6c40a542c1a04c61\n       Reviewed-on: https://webrtc-review.googlesource.com/c/src/+/474160\n       Reviewed-by: Alexander Cooper \u003calcooper@chromium.org\u003e\n       Commit-Queue: Alexander Cooper \u003calcooper@chromium.org\u003e\n       Auto-Submit: Chrome Cherry Picker \u003cchrome-cherry-picker@chops-service-accounts.iam.gserviceaccount.com\u003e\n       Reviewed-by: Mark Foltz \u003cmfoltz@chromium.org\u003e\n       Cr-Commit-Position: refs/branch-heads/7778@{#11}\n       Cr-Branched-From: ca896b7ffef011bbf6957c99d413c5aac602c99f-refs/heads/main@{#47319}\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302663\n", "files": ["third_party/libwebrtc/modules/desktop_capture/cropping_window_capturer.cc", "third_party/libwebrtc/modules/desktop_capture/cropping_window_capturer.h", "third_party/libwebrtc/moz-patch-stack/ac8b0016a8.no-op-cherry-pick-msg"], "git_node": "632edc6091494a8d427c39cf9e20c29f0675797c", "git_parents": ["3abec1470830afcfc4e59a4ca6a5a2d8b798d6b1"], "node": "5725f0ab07797618eb6c7ad24d4510b74ffe905a", "parents": ["6b6249186bfcb4779d454cc139a81de37b7860a7"], "tags": []}], "date": 1780338791, "git_changesets": ["9c97c7d859798e244776f7da80f908f13b74cb37", "39c33995cf6f991c6bb8436c0ba982528972ef00", "5aa80d35141989fa065bf941fdbc55589aa185b4", "3abec1470830afcfc4e59a4ca6a5a2d8b798d6b1", "632edc6091494a8d427c39cf9e20c29f0675797c"], "user": "rvandermeulen@mozilla.com"}, "26646": {"changesets": [{"author": "John Oberhauser \u003cj.git@obez.io\u003e", "branch": "default", "desc": "Bug 2042115 - Fixing crash when deeplinking to the AI settings pag