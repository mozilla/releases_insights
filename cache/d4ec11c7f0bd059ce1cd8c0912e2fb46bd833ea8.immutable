3"], "node": "ecd541b11baf09c92bc2f6a10133590ff1ac39b8", "parents": ["b7cc6e6170b61bed8c2f1a074b8041fb2c96a3ab"], "tags": []}], "date": 1779832593, "git_changesets": ["38b40dadcbcd2ce922ca82b9f4bd885299fa3148"], "user": "rvandermeulen@mozilla.com"}, "26522": {"changesets": [{"author": "Nathan Barrett \u003cnbarrett@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041461 - Fix intermittent timeout in browser_testLoadingState.js  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302060\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302646\n", "files": ["browser/components/contentsharing/tests/browser/ContentSharingMockServer.sys.mjs", "browser/components/contentsharing/tests/browser/browser_testLoadingState.js"], "git_node": "1cedf7d70d1b2217aa173fac9b0955a786a3fd4a", "git_parents": ["38b40dadcbcd2ce922ca82b9f4bd885299fa3148"], "node": "8a4df47e6bbb4f44128a3351de11ce1ae314d97a", "parents": ["ecd541b11baf09c92bc2f6a10133590ff1ac39b8"], "tags": []}], "date": 1779832638, "git_changesets": ["1cedf7d70d1b2217aa173fac9b0955a786a3fd4a"], "user": "rvandermeulen@mozilla.com"}, "26523": {"changesets": [{"author": "Bob Hood \u003cbob.hood.2@gmail.com\u003e", "branch": "default", "desc": "Bug 1970532: Added blocklist entry for failing driver range  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301646\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302634\n", "files": ["widget/windows/GfxInfo.cpp"], "git_node": "c37fd92db738ce3c92bc81fdbb1a68cc6409e866", "git_parents": ["1cedf7d70d1b2217aa173fac9b0955a786a3fd4a"], "node": "e273f29f57654960aeaaca71167177fc3f0740e2", "parents": ["8a4df47e6bbb4f44128a3351de11ce1ae314d97a"], "tags": []}], "date": 1779833461, "git_changesets": ["c37fd92db738ce3c92bc81fdbb1a68cc6409e866"], "user": "rvandermeulen@mozilla.com"}, "26524": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2034870 - Make sure toolbox is opaque when animating macOS fullscreen menubar.  a=RyanVM\n\nThis patch effectively reverts the regressing bug, and adds an opaque\nbackdrop for themes with semi-transparent toolboxes.\n\nIt rejiggers a bit the aiwindow theme to get the desired rendering.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D298083\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302635\n", "files": ["browser/base/content/browser-fullScreenAndPointerLock.js", "browser/themes/addons/aiwindow/aiwindow-theme.css", "browser/themes/addons/aiwindow/manifest.in.json", "browser/themes/shared/browser-shared.css"], "git_node": "d0110ec57c3172a6f53ea51b25e9f82bfe1b6edc", "git_parents": ["c37fd92db738ce3c92bc81fdbb1a68cc6409e866"], "node": "646bdb4973eec4c9b9e6d674aa2a969f6eba6573", "parents": ["e273f29f57654960aeaaca71167177fc3f0740e2"], "tags": []}], "date": 1779833487, "git_changesets": ["d0110ec57c3172a6f53ea51b25e9f82bfe1b6edc"], "user": "rvandermeulen@mozilla.com"}, "26525": {"changesets": [{"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041887 - Don't pass an empty filename to fontconfig.  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302360\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302589\n", "files": ["gfx/thebes/gfxFcPlatformFontList.cpp", "layout/reftests/text-svgglyphs/reftest.list"], "git_node": "49f268bc2aab3b0bd48f38709c05a62b63fe16d3", "git_parents": ["d0110ec57c3172a6f53ea51b25e9f82bfe1b6edc"], "node": "f77cb355cbbcc6f65c6a63bcc4561a5077c2d499", "parents": ["646bdb4973eec4c9b9e6d674aa2a969f6eba6573"], "tags": []}], "date": 1779833514, "git_changesets": ["49f268bc2aab3b0bd48f38709c05a62b63fe16d3"], "user": "rvandermeulen@mozilla.com"}, "26526": {"changesets": [{"author": "hannajones \u003chjones@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041430  - Add telemetry probe for Passwords and autofill pane  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301885\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302665\n", "files": ["browser/modules/BrowserUsageTelemetry.sys.mjs", "browser/modules/metrics.yaml", "browser/modules/test/browser/browser_UsageTelemetry_interaction.js"], "git_node": "46599c54dc885773dce3a0fb447e07aa4c578da7", "git_parents": ["49f268bc2aab3b0bd48f38709c05a62b63fe16d3"], "node": "84bce6cc867f99bfa5a9b830e9da517aca361b59", "parents": ["f77cb355cbbcc6f65c6a63bcc4561a5077c2d499"], "tags": []}], "date": 1779843291, "git_changesets": ["46599c54dc885773dce3a0fb447e07aa4c578da7"], "user": "rvandermeulen@mozilla.com"}, "26527": {"changesets": [{"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 2038467 - Don't sync shadow text by setComposingRegion.  a=RyanVM\n\nThis is a regression by bug 2012938.\n\nAndroid IME (`InputConnection`) often requests current editable text\nby synchronous. But Gecko has its on content process, so we have two\ndata for Java side (`ShadowText)` and content side (`CurrentText`). This\nis synchronous when Gecko notifies IME of text/selection changes.\n\nAfter bug 2012938 fix, it doesn't notify Gecko of IME composing range\nduring batch mode to avoid unnecessary selection changes. After ending\nbatch mode, we will send current composing ranges. Without text changes,\nIME content observer doesn't notify widget of any changes. So calling\n`onIMESynchronized` causes unexpected text/selection changes. Then text\ntransaction is broken.\n\nSo we shouldn't call it and not sync shadow text on ending batch mode.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D300235\n\nDifferential Revision: https://phabricator.services.mozilla.com/D302668\n", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/TextInputDelegateTest.kt", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoEditable.java"], "git_node": "f77394d89ce7e5be05e7ed5106cb779c78fb1603", "git_parents": ["46599c54dc885773dce3a0fb447e07aa4c578da7"], "node": "dc69b2b0e7d6b4d06da347430402f11e9b240c5c", "parents": ["84bce6cc867f99bfa5a9b830e9da517aca361b59"], "tags": []}], "date": 1779843329, "git_changesets": ["f77394d89ce7e5be05e7ed5106cb779c78fb1603"], "user": "rvandermeulen@mozilla.com"}, "26528": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Import translations from main\n", "files": ["mobile/android/android-components/components/feature/app-links/src/main/res/values-es/strings.xml", "mobile/android/android-components/components/feature/app-links/src/main/res/values-eu/strings.xml", "mobile/android/android-components/components/feature/app-links/src/main/res/values-fi/strings.xml", "mobile/android/android-components/components/feature/app-links/src/main/res/values-gn/strings.xml", "mobile/android/android-components/components/feature/prompts/src/main/res/values-gn/strings.xml", "mobile/android/android-components/components/feature/protection-dashboard/src/main/res/values-fi/strings.xml", "mobile/android/fenix/app/longfox/src/main/res/values-es/strings.xml", "mobile/android/fenix/app/longfox/src/main/res/values-eu/strings.xml", "mobile/android/fenix/app/longfox/src/main/res/values-fi/strings.xml", "mobile/android/fenix/app/longfox/src/main/res/values-gn/strings.xml", "mobile/android/fenix/app/src/main/res/values-el/strings.xml", "mobile/android/fenix/app/src/main/res/values-es/strings.xml", "mobile/android/fenix/app/src/main/res/values-eu/strings.xml", "mobile/android/fenix/app/src/main/res/values-fi/strings.xml", "mobile/android/fenix/app/src/main/res/values-gn/strings.xml"], "git_node": "e4f0841f67444bcb94b08f41accc0b0c312a9211", "git_parents": ["f77394d89ce7e5be05e7ed5106cb779c78fb1603"], "node": "a4cd62160cb356a02f1549e1fb6cfbd4d1d4c2eb", "parents": ["dc69b2b0e7d6b4d06da347430402f11e9b240c5c"], "tags": []}], "date