.ipdlh", "gfx/src/nsDeviceContext.cpp", "gfx/src/nsDeviceContext.h", "gfx/thebes/D3D11Checks.cpp", "gfx/thebes/D3D11Checks.h", "gfx/thebes/DeviceManagerDx.cpp", "gfx/thebes/DeviceManagerDx.h", "gfx/thebes/gfxPlatform.cpp", "layout/style/nsMediaFeatures.cpp", "widget/Screen.cpp", "widget/Screen.h", "widget/ScreenManager.cpp", "widget/android/ScreenHelperAndroid.cpp", "widget/cocoa/ScreenHelperCocoa.mm", "widget/gtk/ScreenHelperGTK.cpp", "widget/headless/HeadlessScreenHelper.cpp", "widget/uikit/ScreenHelperUIKit.mm", "widget/windows/ScreenHelperWin.cpp"], "git_node": "b9b6ada2534c66494f893286652a46f0dee0feb6", "git_parents": ["f30006c35bdd271d3c262b6e8918ef366187aa11"], "node": "c97ce64dc343c8d743dfc8ccfb0fd3cdafcae6f5", "parents": ["3b146be1ad6f87c92f67728c0c074770aaf1e895"], "tags": []}, {"author": "Ryan VanderMeulen \u003crvandermeulen@mozilla.com\u003e", "branch": "default", "desc": "Revert \"Bug 2025322 - Enable HDR video on Windows in release a=dmeehan\"\n\nThis reverts commit a67ed3791ae1c789ef21708cc83cb3ad920d24b3.\n", "files": ["modules/libpref/init/StaticPrefList.yaml"], "git_node": "809bb0b66b95cd2930e5dce609f41e62106a94b4", "git_parents": ["b9b6ada2534c66494f893286652a46f0dee0feb6"], "node": "d8e53b34a2dcf5b87397f51ebcd40ffe4d5b8898", "parents": ["c97ce64dc343c8d743dfc8ccfb0fd3cdafcae6f5"], "tags": []}], "date": 1781062042, "git_changesets": ["f30006c35bdd271d3c262b6e8918ef366187aa11", "b9b6ada2534c66494f893286652a46f0dee0feb6", "809bb0b66b95cd2930e5dce609f41e62106a94b4"], "user": "rvandermeulen@mozilla.com"}, "26834": {"changesets": [{"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 2044831 - Change tryNoteStart location in ForOfLoopControl::emitPrepareForNonLocalJumpFromScope.  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305106\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305673\n", "files": ["js/src/frontend/ForOfLoopControl.cpp"], "git_node": "ff50082edb2c0f13fbb4f219ca77d9217746f514", "git_parents": ["809bb0b66b95cd2930e5dce609f41e62106a94b4"], "node": "119685ebdf4c30e7026e3761a47fea5d1f1d8557", "parents": ["d8e53b34a2dcf5b87397f51ebcd40ffe4d5b8898"], "tags": []}], "date": 1781063776, "git_changesets": ["ff50082edb2c0f13fbb4f219ca77d9217746f514"], "user": "rvandermeulen@mozilla.com"}, "26835": {"changesets": [{"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 2045572 - Check for too-large stubs before discarding stubs in TryFoldingGuardShapes.  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305119\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305668\n", "files": ["js/src/jit/StubFolding.cpp"], "git_node": "b6787e9ba71271397a78164de765cca8d9eaed6b", "git_parents": ["ff50082edb2c0f13fbb4f219ca77d9217746f514"], "node": "c65aecd44c07b178e165aa6ea5fcc8fd3e702ace", "parents": ["119685ebdf4c30e7026e3761a47fea5d1f1d8557"], "tags": []}], "date": 1781063855, "git_changesets": ["b6787e9ba71271397a78164de765cca8d9eaed6b"], "user": "rvandermeulen@mozilla.com"}, "26836": {"changesets": [{"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 2045307 - Use cell's zone in MacroAssembler::emitWeapMapBarrierFastPath.  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305465\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305674\n", "files": ["js/public/HeapAPI.h", "js/src/jit/MacroAssembler.cpp"], "git_node": "529fde2053dd9421017dbef62c6bb56caa9bab1d", "git_parents": ["b6787e9ba71271397a78164de765cca8d9eaed6b"], "node": "838bbf45cd906c5faf9167cf211d92a9a92cea54", "parents": ["c65aecd44c07b178e165aa6ea5fcc8fd3e702ace"], "tags": []}], "date": 1781063885, "git_changesets": ["529fde2053dd9421017dbef62c6bb56caa9bab1d"], "user": "rvandermeulen@mozilla.com"}, "26837": {"changesets": [{"author": "Vincent Hilla \u003cvhilla@mozilla.com\u003e", "branch": "default", "desc": "Bug 2045516 - Mark CreateAboutBlankDocumentViewer MOZ_CAN_RUN_SCRIPT.  a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305615\n", "files": ["docshell/base/nsDocShell.cpp", "docshell/base/nsDocShell.h", "docshell/base/nsIDocShell.idl", "dom/base/nsFrameLoader.h", "dom/base/nsGlobalWindowOuter.cpp", "dom/base/nsGlobalWindowOuter.h", "dom/base/nsPIDOMWindow.h", "dom/ipc/BrowserChild.h", "dom/ipc/ContentChild.cpp"], "git_node": "883de558f02d8a86b82431692f8bdadb754620dc", "git_parents": ["529fde2053dd9421017dbef62c6bb56caa9bab1d"], "node": "9fef868e496c7c14befb5572bd2d946d8de3a890", "parents": ["838bbf45cd906c5faf9167cf211d92a9a92cea54"], "tags": []}], "date": 1781063914, "git_changesets": ["883de558f02d8a86b82431692f8bdadb754620dc"], "user": "rvandermeulen@mozilla.com"}, "26838": {"changesets": [{"author": "Ashley Hale \u003cahale@mozilla.com\u003e", "branch": "default", "desc": "Bug 2029402 - cherrypick a gl_FragColor bug fix in ANGLE  a=RyanVM\n\nSome of the changes weren't brought in:\n\n- Rust changes aren't being brought in yet because the base didn't have the parallel Rust implementation of the compiler.\n- We forgo tests to simplify rebasing, under the assumption that upstream will keep these tests and not regress.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305452\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305567\n", "files": ["gfx/angle/checkout/src/compiler/translator/tree_ops/EmulateGLFragColorBroadcast.cpp"], "git_node": "3f5331b69aed98cf604f825c52a25dfb88d8f6f0", "git_parents": ["883de558f02d8a86b82431692f8bdadb754620dc"], "node": "ab509508c37e7b51342bb5215e265e0a6304c99e", "parents": ["9fef868e496c7c14befb5572bd2d946d8de3a890"], "tags": []}], "date": 1781063941, "git_changesets": ["3f5331b69aed98cf604f825c52a25dfb88d8f6f0"], "user": "rvandermeulen@mozilla.com"}, "26839": {"changesets": [{"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 2045398 - Check namespace of id attribute.  a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305356\n", "files": ["accessible/generic/DocAccessible.cpp"], "git_node": "5e6e8416f49dad835abc58dc16a4fec65b33739b", "git_parents": ["3f5331b69aed98cf604f825c52a25dfb88d8f6f0"], "node": "e8b106707c6ae1b8519248c2782a6de46b48408c", "parents": ["ab509508c37e7b51342bb5215e265e0a6304c99e"], "tags": []}], "date": 1781063968, "git_changesets": ["5e6e8416f49dad835abc58dc16a4fec65b33739b"], "user": "rvandermeulen@mozilla.com"}, "26840": {"changesets": [{"author": "sarah541 \u003csarahkhan1107@hotmail.com\u003e", "branch": "default", "desc": "Bug 2045922 - Show the next round's decided fixtures in the sports widget while the current round is active  a=RyanVM\n\nThe bracket-wide (no-team) pager previously showed only one round at a time:\nthe active round plus the always-pinned Final / Third-Place cards. As the\nknockout bracket fills in, surface the immediate next round's fixtures too, as\nsoon as they are decided.\n\nIn the no-team branch of buildCards, also keep matches of the next round (the\nlowest-ordinal round above the active one present in the response) whose teams\naren't both undetermined. A fixture appears the moment one side is set, rendered\nas the known team vs \"TBD\"; fixtures with neither side decided are withheld so\nthe pager doesn't fill with \"TBD vs TBD\" placeholders. The previous round still\ndrops out only when the new round goes live (active-round logic unchanged).\n\nAdds nextRound() and isFullyTbd() helpers and SportsWidgetMiddlewareTest\ncoverage for the one-side-decided, all-TBD, and immediate-next-round-only cases.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305417\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305666\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/sports/SportsWidgetMiddleware.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/home/sports/SportsWidgetMiddlewareTest.kt"], "git_node": "6c35392200f0a3401ee309f68b61cb530fb76685", "git_parents": ["5e6e8416f49dad835abc58dc16a4fec65b33739b"], "node": "1a71746c891f6ff1887fd1e8b58151ace4ad29d6", "parents": ["e8b106707c6ae1b8519248c2782a6de46b48408c"], "tags": []}], "date": 1781064047, "git_changesets": ["6c35392200f0a3401ee309f68b61cb530fb76685"], "user": "rvandermeulen@mozilla.com"}, "26841": {"changesets": [{"author": "Roger Yang \u003croyang@mozilla.com\u003e", "branch": "default", "desc": "Bug 2045919 - Move the growth event 6 tracking into Adjust metrics service.  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305412\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305638\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/components/metrics/AdjustMetricsService.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/OnboardingFragment.kt"], "git_node": "2f64d5d4efc38aaa1476cc30aa81b546672610d0", "git_parents": ["6c35392200f0a3401ee309f68b61cb530fb76685"], "node": "dc17469bf2ccc365749f2ee9e7c99b40f17b485b", "parents": ["1a71746c891f6ff1887fd1e8b58151ace4ad29d6"], "tags": []}], "date": 1781064085, "git_changesets": ["2f64d5d4efc38aaa1476cc30aa81b546672610d0"], "user": "rvandermeulen@mozilla.com"}, "26842": {"changesets": [{"author": "Ryan VanderMeulen \u003crvandermeulen@mozilla.com\u003e", "branch": "default", "desc": "Revert \"Bug 2045307 - Use cell's zone in MacroAssembler::emitWeapMapBarrierFastPath. a=RyanVM\" for bustage.\n\nThis reverts commit 529fde2053dd9421017dbef62c6bb56caa9bab1d.\n", "files": ["js/public/HeapAPI.h", "js/src/jit/MacroAssembler.cpp"], "git_node": "e83305f19513d25a955ae426e2eba13b91d832ad", "git_parents": ["2f64d5d4efc38aaa1476cc30aa81b546672610d0"], "node": "91cc3d2892f9380783a9c2b39f246d7ed3068c92", "parents": ["dc17469bf2ccc365749f2ee9e7c99b40f17b485b"], "tags": []}], "date": 1781064672, "git_changesets": ["e83305f19513d25a955ae426e2eba