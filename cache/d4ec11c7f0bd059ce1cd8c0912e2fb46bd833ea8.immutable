: 1780627525, "git_changesets": ["20fb668e009213072ec6cfb9e440b74f0f4c790a"], "user": "rvandermeulen@mozilla.com"}, "26752": {"changesets": [{"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 2044457 - Report total of installed search engines and their types to telemetry.  a=RyanVM\n\nThis reports the numbers of each type of visible search engine to telemetry. It also reports the counts of disabled and hidden search engines as well.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D304477\n\nDifferential Revision: https://phabricator.services.mozilla.com/D304868\n", "files": ["toolkit/components/search/SearchService.sys.mjs", "toolkit/components/search/metrics.yaml", "toolkit/components/search/tests/xpcshell/test_telemetry_installed_engine_counts.js", "toolkit/components/search/tests/xpcshell/xpcshell.toml", "tools/@types/generated/lib.gecko.glean.d.ts"], "git_node": "7d09506717e3bedc9c834fc7597a6a48659ac011", "git_parents": ["20fb668e009213072ec6cfb9e440b74f0f4c790a"], "node": "bea2202e001f4db0c84bb4b2989b7056ad515eff", "parents": ["80687d4d477aaa0524d6df8f419a63e9f665b399"], "tags": []}], "date": 1780627551, "git_changesets": ["7d09506717e3bedc9c834fc7597a6a48659ac011"], "user": "rvandermeulen@mozilla.com"}, "26753": {"changesets": [{"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 2044222 - Check editing host on Thunderbird' mail composer.  a=RyanVM\n\nAlthough I don't know how to reproduce this, this crash spikes from\nThunderbird 151.\n\nWe should check whether editing host is not null when setting document\nlanguage for spell checker.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D304385\n\nDifferential Revision: https://phabricator.services.mozilla.com/D304945\n", "files": ["editor/spellchecker/EditorSpellCheck.cpp"], "git_node": "2d110ef55650d0d77e0bd58d9369d78566b7c689", "git_parents": ["7d09506717e3bedc9c834fc7597a6a48659ac011"], "node": 