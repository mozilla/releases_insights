er_breakout_state.js", "browser/components/urlbar/tests/browser/browser_contextualsearch.js"], "git_node": "e264ccf4fc2be71f2bea5034a92fbbfa0e75440e", "git_parents": ["a4677143404706390bb28de359136cf3965fbad7"], "node": "764519150df2809fd475ab6f1f6953d420261e90", "parents": ["44acd228e6ca75999bbe48f7dd7ce09a31129120"], "tags": []}], "date": 1780537853, "git_changesets": ["e264ccf4fc2be71f2bea5034a92fbbfa0e75440e"], "user": "rvandermeulen@mozilla.com"}, "26718": {"changesets": [{"author": "Paul Bone \u003cpbone@mozilla.com\u003e", "branch": "default", "desc": "Bug 2014781 - Restore the sub-page size class  a=RyanVM\n\nThis reverts Bug 1980056 part 6.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D297237\n\nDifferential Revision: https://phabricator.services.mozilla.com/D304632\n", "files": ["memory/build/Arena.h", "memory/build/Constants.h", "memory/build/Globals.h", "memory/build/Globals.inc", "memory/build/PHC.cpp", "memory/build/mozjemalloc.cpp", "memory/build/mozjemalloc_types.h", "memory/gtest/TestJemalloc.cpp", "memory/replace/logalloc/replay/Replay.cpp"], "git_node": "2423014dbbd10fc584d5854104502d361be37752", "git_parents": ["e264ccf4fc2be71f2bea5034a92fbbfa0e75440e"], "node": "33f9b62d2c7304d6595384f0837cdd18a905dffb", "parents": ["764519150df2809fd475ab6f1f6953d420261e90"], "tags": []}, {"author": "Paul Bone \u003cpbone@mozilla.com\u003e", "branch": "default", "desc": "Bug 2014781 - gPageSize follows gRealPageSize  a=RyanVM\n\nThis effectively backs out Bug 1980056 part 5 for a performance\nregression.  It also adds a comment about the performance regression.\n\nThis might be temporary depending on more testing, but for now we can\nhave some faster performance.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D297236\n\nDifferential Revision: https://phabricator.services.mozilla.com/D304633\n", "files": ["memory/build/Globals.h", "memory/build/mozjemalloc.cpp"], "git_node": "0ff8683d7ec4308fb7bc6c125bf12bb6cc01b638", "git_pare