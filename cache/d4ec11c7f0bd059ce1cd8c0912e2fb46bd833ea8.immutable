d@lando.moz.tools"}, "26806": {"changesets": [{"author": "Tom Schuster \u003ctschuster@mozilla.com\u003e", "branch": "default", "desc": "Bug 2042058 - Strip CustomElementData in nsTreeSanitizer.  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D303755\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305497\n", "files": ["dom/base/nsTreeSanitizer.cpp"], "git_node": "3b094e112ed0ac98ed0e2c1d5db6f1106777fa13", "git_parents": ["cd9cd8857e6fbbc40168e988cde7b7fbe08bb0c9"], "node": "9c9c8f3fe72d9d608de524892f440d8bb3bdf180", "parents": ["7327d7f675c886f84cd3dffb182afe4f79bfcbb6"], "tags": []}], "date": 1781009437, "git_changesets": ["3b094e112ed0ac98ed0e2c1d5db6f1106777fa13"], "user": "rvandermeulen@mozilla.com"}, "26807": {"changesets": [{"author": "Timothy Nikkel \u003ctnikkel@gmail.com\u003e", "branch": "default", "desc": "Bug 2039443.  a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305414\n", "files": ["media/libpng/apng.patch", "media/libpng/pngpread.c"], "git_node": "ff1325ee57fecf5bfe26156a23d9507c8e33b325", "git_parents": ["3b094e112ed0ac98ed0e2c1d5db6f1106777fa13"], "node": "f83675fa7c1043cc19427a74104f5491f864a251", "parents": ["9c9c8f3fe72d9d608de524892f440d8bb3bdf180"], "tags": []}], "date": 1781009465, "git_changesets": ["ff1325ee57fecf5bfe26156a23d9507c8e33b325"], "user": "rvandermeulen@mozilla.com"}, "26808": {"changesets": [{"author": "Erich Gubler \u003cerichdongubler@gmail.com\u003e", "branch": "default", "desc": "Bug 2042782 - fix(webgl): clamp `maxColorDrawBuffers` to `kMaxDrawBuffers`  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D303020\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305222\n", "files": ["dom/canvas/WebGLContextValidate.cpp"], "git_node": "31b46746886b4c15bce92456711567195799af42", "git_parents": ["ff1325ee57fecf5bfe26156a23d9507c8e33b325"], "node": "3c2a8d15eb9a5e424a75eb90cb88d2d36ab6ee95", "parents": ["f83675fa7c1043cc19427a74104f5491f864a251"], "tags": []}], "date": 1781009494, "git_changesets": ["31b46746886b4c15bce92456711567195799af42"], "user": "rvandermeulen@mozilla.com"}, "26809": {"changesets": [{"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041564: Fire a reorder event when a remote iframe document is removed.  a=RyanVM\n\nSee the code comment for the rationale.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302944\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305450\n", "files": ["accessible/ipc/DocAccessibleParent.cpp", "accessible/tests/browser/e10s/browser_caching_states.js", "accessible/tests/browser/e10s/browser_treeupdate_doc.js", "accessible/tests/browser/name_and_description/browser_name_general.js"], "git_node": "39a31c379584e3b829e4db62f522a87fdf23f881", "git_parents": ["31b46746886b4c15bce92456711567195799af42"], "node": "7852d6ffd00345978dab66e0e27c2291c2399214", "parents": ["3c2a8d15eb9a5e424a75eb90cb88d2d36ab6ee95"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 2043961: browser_caching_states.js: Fix race condition in slow document load.  a=RyanVM\n\nThe stale/busy state test relies on loading a document that is slow to load, but because it's an automated test, we need to be able to control the timing.\nPreviously, it used slow_image.sjs, which handles one request for the page load and blocks that first request until it receives a second request to finish the load.\nHowever, because we're loading the document in the content process and issuing the second (finish) request in the parent process, the requests can sometimes arrive out of order, with the finish request arriving first.\nslow_image.sjs doesn't know how to handle this and will just block the load request forever.\nTo fix this, switch to slow_doc.sjs (introduced in bug 1974131) which *does* know how to handle this race; see https://searchfox.org/firefox-main/rev/e28b34ab33dbf49364999070168cbb7e11e8e5bd/accessible/tests/browser/events/slow_doc.sjs#55\n\nThe potential for this problem existed before the fix for bug 2041564 and I was able to reproduce it locally with --verify on Linux even without that patch.\nHowever, that fix made it far more likely to occur as a tv intermittent, perhaps due to slight timing changes.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D304008\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305451\n", "files": ["accessible/tests/browser/e10s/browser.toml", "accessible/tests/browser/e10s/browser_caching_states.js"], "git_node": "269a0f87beef33199415f49632490aeeaccd53c9", "git_parents": ["39a31c379584e3b829e4db62f522a87fdf23f881"], "node": "b4b3ada86a33ea52c321035ac1a8530bb1de5a33", "parents": ["7852d6ffd00345978dab66e0e27c2291c2399214"], "tags": []}], "date": 1781009530, "git_changesets": ["39a31c379584e3b829e4db62f522a87fdf23f881", "269a0f87beef33199415f49632490aeeaccd53c9"], "user": "rvandermeulen@mozilla.com"}, "26810": {"changesets": [{"author": "Randell Jesup \u003crjesup@mozilla.com\u003e", "branch": "default", "desc": "Bug 2043675: Handle racing OnCacheEntryChecks  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D303496\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305456\n", "files": ["netwerk/cache2/CacheEntry.cpp"], "git_node": "72ff2383c6e061d61cb4502c32bea04bae24b97c", "git_parents": ["269a0f87beef33199415f49632490aeeaccd53c9"], "node": "86b51ce794cba6fc3a889b6464babd5424ccfdbc", "parents": ["b4b3ada86a33ea52c321035ac1a8530bb1de5a33"], "tags": []}], "date": 1781009561, "git_changesets": ["72ff2383c6e061d61cb4502c32bea04bae24b97c"], "user": "rvandermeulen@mozilla.com"}, "26811": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging c3ced093061480f46d51b9b7028ec647c6af5c14 with FIREFOX_151_0_4_RELEASE a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "ac78f3797eeab0a7c846bd49141fec1b040654da", "git_parents": ["2a79c9a5d909bf588d52e1dc51231243980f1380"], "node": "1ee1d5a6032aa6e2f49565960e0b59e90e9822c4", "parents": ["33bdc92a95091df1eb40e7f787d93a8da33c639a"], "tags": []}], "date": 1781011720, "git_changesets": ["ac78f3797eeab0a7c846bd49141fec1b040654da"], "user": "ffxbld@lando.moz.tools"}, "26812": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging c3ced093061480f46d51b9b7028ec647c6af5c14 with FIREFOX-ANDROID_151_0_4_RELEASE a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "cf9ccb3e00e540fbf42fd1452c3bd54928ea218d", "git_parents": ["ac78f3797eeab0a7c846bd49141fec1b040654da"], "node": "cb57d5665f14021959b2091f8d876a0659f36644", "parents": ["1ee1d5a6032aa6e2f49565960e0b59e90e9822c4"], "tags": []}], "date": 1781012069, "git_changesets": ["cf9ccb3e00e540fbf42fd1452c3bd54928ea218d"], "user": "ffxbld@lando.moz.tools"}, "26813": {"changesets": [{"author": "Tom Ritter \u003ctom@ritter.vg\u003e", "branch": "default", "desc": "Bug 2044142: Add unzip to the updatebot image r=freddyb a=NPOTB\n", "files": ["taskcluster/docker/updatebot/privileged-setup.sh"], "git_node": "bc05dc6ed1510e76d8d53598be78b8877c84e78e", "git_parents": ["72ff2383c6e061d61cb4502c32bea04bae24b97c"], "node": "9f59b9e48f42a940464f4dfdca520b3ccd329c43", "parents": ["86b51ce794cba6fc3a889b6464babd5424ccfdbc"], "tags": []}], "date": 1781013290, "git_changesets": ["bc05dc6ed1510e76d8d53598be78b8877c84e78e"], "user": "rvandermeulen@mozilla.com"}, "26814": {"changesets": [{"author": "mcarare \u003c48995920+mcarare@users.noreply.github.com\u003e", "branch": "default", "desc": "Bug 2045755 - Update tracking protection and cookie policy handling in Privacy & Security settings  a=RyanVM\n\nThis change ensures that when tracking protection or cookie settings are modified, the updated values are correctly passed and applied to the engine immediately.\n\n- Refactored `PrivacySecuritySettingsFragment` to use a lazy-initialized `EngineSharedPreferencesListener` instead of local instantiations.\n- Updated `EngineSharedPreferencesListener` and `EngineProvider` to support an optional `newCookieValue`, ensuring the engine uses the pending preference state during a change event.\n- Refined `CookiePolicy` mapping in `EngineProvider` to explicitly handle the \"no\" (ACCEPT_ALL) case and updated the default fallback to `ACCEPT_FIRST_PARTY_AND_ISOLATE_OTHERS`.\n- Updated tracking protection category toggles to pass the current status of each tracker type when updating the engine policy.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305203\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305585\n", "files": ["mobile/android/focus-android/app/src/main/java/org/mozilla/focus/components/EngineProvider.kt", "mobile/android/focus-android/app/src/main/java/org/mozilla/focus/engine/EngineSharedPreferencesListener.kt", "mobile/android/focus-android/app/src/main/java/org/mozilla/focus/settings/privacy/PrivacySecuritySettingsFragment.kt"], "git_node": "0c1b4169cc0eb52b8a6a09780356abeb093e18c0", "git_parents": ["bc05dc6ed1510e76d8d53598be78b8877c84e78e"], "node": "b36d465c6c353d7be176bb9b935cb2673e152b8c", "parents": ["9f59b9e48f42a940464f4dfdca520b3ccd329c43"], "tags": []}], "date": 1781022862, "git_changesets": ["0c1b4169cc0eb52b8a6a09780356abeb093e18c0"], "user": "rvandermeulen@mozilla.com"}, "26815": {"changesets": [{"author": "Julie De Lorenzo \u003cjdelorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 2037161 part 2: Update color tokens on the border and remove double border  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305346\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305636\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/tabgroups/TabGroupRow.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/tabstray/ui/tabitems/SharedTabItemUi.kt"], "git_node": "34b8dc646ad874e4c7454ce805238137cacdecc9", "git_parents": ["0c1b4169cc0eb52b8a6a09780356abeb093e18c0"], "node": "8be8b449758dce0090f6e4d34e4a7d907d987dd7", "parents": ["b36d465c6c353d7be176bb9b935cb2673e152b8c"], "tags": []}], "date": 1781023009, "git_changesets": ["34b8dc646ad874e4c7454ce805238137cacdecc9"], "user": "rvandermeulen@mozilla.com"}, "26816": {"changesets": [{"author": "avirvara \u003cavirvara@mozilla.com\u003e", "branch": "default", "desc": "Bug 2032959: Make AI feature list scrollable in block AI dialog  a=RyanVM\n\ntry: https://treeherder.mozilla.org/jobs?repo=try&revision=5a85e3f4a92234f0371086a252441d6027198b64\n\nOriginal Revision: https://phabricator.services.mozilla.com/D305102\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305470\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/settings/ai/AIControlsScreen.kt"], "git_node": "792cee5e9be65e6a59e8f244811fa91590c57d49", "git_parents": ["34b8dc646ad874e4c7454ce805238137cacdecc9"], "node": "47e3ca1e0a5b17fcc49af36a4755f11e238fb6d3", "parents": ["8be8b449758dce0090f6e4d34e4a7d907d987dd7"], "tags": []}], "date": 1781023057, "git_changesets": ["792cee5e9be65e6a59e8f244811fa91590c57d49"], "user": "rvandermeulen@mozilla.com"}, "26817": {"changesets": [{"author": "Tessa Heidkamp \u003ctheidkamp@mozilla.com\u003e", "branch": "default", "desc": "Bug 2038389 - Add await to realmHasPasswords call in pageInfo/security.js.  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302515\n\nDifferential Revision: https://phabricator.services.mozilla.com/D305487\n", "files": ["browser/base/content/pageinfo/security.js", "browser/base/content/test/pageinfo/browser_pageinfo_security.js"], "git_node": "f77504eff93662ebbea531d8c97447c262b69bd0", "git_parents": ["792cee5e9be65e6a59e8f244811fa91590c57d49"], "node": "30ba10f89a61d83e2cc8247bfb01087e11f79b2f", "parents": ["47e3ca1e0a5b17fcc49af36a4