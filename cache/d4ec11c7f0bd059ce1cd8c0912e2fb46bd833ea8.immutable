s": []}], "date": 1779308226, "git_changesets": ["cd2a0a20c5ba2b6e48ac6394e7a19c75ab1fb12d", "fc3e4c1756d86a8df90f2745cb3ec1b3025c0375"], "user": "rvandermeulen@mozilla.com"}, "26410": {"changesets": [{"author": "Dana Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "Bug 2040258 - fixup remaining references to nsIPK11Token  a=RyanVM\n\nBug 2037682 renamed this interface to nsIPKCS11Token.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301107\n\nDifferential Revision: https://phabricator.services.mozilla.com/D301609\n", "files": ["security/manager/pki/resources/content/changepassword.js", "security/manager/ssl/tests/unit/test_pkcs11_token.js", "toolkit/components/passwordmgr/LoginHelper.sys.mjs"], "git_node": "db8a674b0ff71cd085935b23d8c278826e65e7cc", "git_parents": ["fc3e4c1756d86a8df90f2745cb3ec1b3025c0375"], "node": "f7c4f761b1857e36a44e8f89e9f8eceb91a8842a", "parents": ["4376fb31b75ce08da597c1fdd413e8eca07d2783"], "tags": []}], "date": 1779308268, "git_changesets": ["db8a674b0ff71cd085935b23d8c278826e65e7cc"], "user": "rvandermeulen@mozilla.com"}, "26411": {"changesets": [{"author": "Hiroyuki Ikezoe \u003chikezoe.birchill@mozilla.com\u003e", "branch": "default", "desc": "Bug 2040693 - Fall back to UnknownWebkit for pref-disabled `-webkit-*` pseudos so insertRule doesn't throw. r=firefox-style-system-reviewers,emilio a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D301426\n", "files": ["servo/components/style/gecko/pseudo_element.rs", "servo/components/style/gecko/pseudo_element_definition.mako.rs", "servo/components/style/gecko/selector_parser.rs", "testing/web-platform/meta/compat/webkit-scrollbar-parse.html.ini", "testing/web-platform/tests/compat/webkit-scrollbar-parse.html"], "git_node": "a0674f58e72929d7a67d4197ea6def455e42b6a2", "git_parents": ["db8a674b0ff71cd085935b23d8c278826e65e7cc"], "node": "09cb8bfee40798180a1488eb066e6f2fa20c5d4d", "parents": ["f7c4f761b1857e36a44e8f89e9f8eceb91a8842a"], "tags": []}], "date": 1779309829, "git_changesets": ["a0674f58e72929d7a67d4197ea6def455e42b6a2"], "user": "rvandermeulen@mozilla.com"}, "26412": {"changesets": [{"author": "Hiroyuki Ikezoe \u003chikezoe.birchill@mozilla.com\u003e", "branch": "default", "desc": "Bug 2040214 - Allowlist animation-timeline parse error from smartbar.css in browser_parsable_css.js.  a=RyanVM\n\nI am assuming Smart Window isn't shipping in 152.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D300992\n\nDifferential Revision: https://phabricator.services.mozilla.com/D301624\n", "files": ["browser/base/content/test/static/browser_parsable_css.js"], "git_node": "7656ced9d4723d66b13f652e04a1c6bea00f244d", "git_parents": ["a0674f58e72929d7a67d4197ea6def455e42b6a2"], "node": "f2d585c23a9d4ef35f1ba69b642da9c173d9369c", "parents": ["09cb8bfee40798180a1488eb066e6f2fa20c5d4d"], "tags": []}], "date": 1779310477, "git_changesets": ["7656ced9d4723d66b13f652e04a1c6bea00f244d"], "user": "rvandermeulen@mozilla.com"}, "26413": {"changesets": [{"author": "Paul Adenot \u003cpaul@paul.cx\u003e", "branch": "default", "desc": "Bug 2025512 - Fix AsyncLogger thread safety and shutdown.  a=RyanVM\n\nJoin the internal thread in Stop() instead of detaching it, and add a\ndestructor to prevent use-after-free if AsyncLogger is destroyed while\nrunning. An mActiveLogs counter guards against racing with Stop():\nBeginLogging() uses a double-check so the spin in Stop() reliably ensures\nall in-flight pushes complete before joining.\n\nRemove AUTO_PROFILER_REGISTER_THREAD: only the calling thread needs\nregistration, not the logger thread.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D290940\n\nDifferential Revision: https://phabricator.services.mozilla.com/D301626\n", "files": ["dom/media/AsyncLogger.h"], "git_node": "a1bbe657c9607825b0c8604c1c56de6f35ffef39", "git_parents": ["7656ced9d4723d66b13f652e04a1c6bea00f244d"], "node": "a5f1255098a780a4e20ee89ab056bf8266d2f6aa", "parents": 