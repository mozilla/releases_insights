ode": "61ab8111e650b4819c4e462a7ff4d6d3501386b5", "parents": ["1779e3ec79675d898514d35f532dc549f1214cf4"], "tags": []}, {"author": "Andy Leiserson \u003caleiserson@mozilla.com\u003e", "branch": "default", "desc": "Bug 2034608 - Update wgpu to a2c9a1c6  a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303916\n", "files": [".cargo/config.toml.in", "Cargo.lock", "gfx/wgpu_bindings/Cargo.toml", "gfx/wgpu_bindings/moz.yaml", "supply-chain/audits.toml", "third_party/rust/naga/.cargo-checksum.json", "third_party/rust/naga/src/back/hlsl/help.rs", "third_party/rust/naga/src/back/hlsl/writer.rs"], "git_node": "4a997943e9b2f8fbf59b398c20c6ca2166cf5cf4", "git_parents": ["e4b3f9696025f02fcd38eb0ad3acf998f05ffbe6"], "node": "66126c7daa2497786ea0a913c788f5daaf9d02c5", "parents": ["61ab8111e650b4819c4e462a7ff4d6d3501386b5"], "tags": []}], "date": 1780356728, "git_changesets": ["e4b3f9696025f02fcd38eb0ad3acf998f05ffbe6", "4a997943e9b2f8fbf59b398c20c6ca2166cf5cf4"], "user": "rvandermeulen@mozilla.com"}, "26650": {"changesets": [{"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1950764 - Work around crash on Intel Raptor Lake CPU.  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301917\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303940\n", "files": ["Cargo.lock", "Cargo.toml", "third_party/rust/zlib-rs/src/deflate/sym_buf.rs", "third_party/rust/zlib-rs/src/lib.rs"], "git_node": "711ef51645a2745cc7367a539662ea939609fc2b", "git_parents": ["4a997943e9b2f8fbf59b398c20c6ca2166cf5cf4"], "node": "58489df1686773127b136b60187a8e4e6e518937", "parents": ["66126c7daa2497786ea0a913c788f5daaf9d02c5"], "tags": []}], "date": 1780356789, "git_changesets": ["711ef51645a2745cc7367a539662ea939609fc2b"], "user": "rvandermeulen@mozilla.com"}, "26651": {"changesets": [{"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 2042372: Make Android TraversalRule traverse search boxes.  a=RyanVM\n\nIn bug 1938624, I added a separate SEARCHBOX Gecko role.\nBefore then, role=\"searchbox\" and \u003cinput type=\"search\"\u003e used the ENTRY role.\nHowever, Android TraversalRule has an explicit list of roles and the new SEARCHBOX role wasn't added, making it impossible to navigate to controls with this role.\nTo fix this, SEARCHBOX has now been added to both DefaultMatch and ControlMatch.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D302976\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303939\n", "files": ["accessible/android/TraversalRule.cpp", "mobile/android/geckoview/src/androidTest/assets/www/accessibility/test-searchboxes.html", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/AccessibilityTest.kt"], "git_node": "d470851f930fe18009bb2633c42da98b1bd889da", "git_parents": ["711ef51645a2745cc7367a539662ea939609fc2b"], "node": "97b6471fd356c7ba8a6f64e4ecf0aa09044297da", "parents": ["58489df1686773127b136b60187a8e4e6e518937"], "tags": []}], "date": 1780356810, "git_changesets": ["d470851f930fe18009bb2633c42da98b1bd889da"], "user": "rvandermeulen@mozilla.com"}, "26652": {"changesets": [{"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 2043307: Check whether UiaRaiseNotificationEvent is available before trying to call it.  a=RyanVM\n\nUiaRaiseNotificationEvent is only available on Windows 10 version 1709 and later.\nPreviously, we tried to call it without checking whether it was available, causing crashes on (very) outdated versions of Windows 10.\nWe now explicitly check whether this function is available before trying to call it, gracefully doing nothing if we can't.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D303249\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303937\n", "files": ["accessible/windows/uia/uiaRawElmProvider.cpp"], "git_node": "e9ceb84c7f9634f67516a988a4de07a4d526e971", "git_parents": ["d470851f930fe18009bb2633c42da98b1bd889da"], "node": "8021a9cc35a3c55c6a4015d4f6234c9aed11c10b", "parents": ["97b6471fd356c7ba8a6f64e4ecf0aa09044297da"], "tags": []}], "date": 1780356832, "git_changesets": ["e9ceb84c7f9634f67516a988a4de07a4d526e971"], "user": "rvandermeulen@mozilla.com"}, "26653": {"changesets": [{"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041095 - Part 1: Fix setting-group subcategories and LegacyPaneMappings tests  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301929\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303845\n", "files": ["browser/components/preferences/tests/browser_legacy_pane_mappings.js", "browser/components/preferences/widgets/setting-group/setting-group.mjs"], "git_node": "a844a5a3113ee5ad989d9783fedcfc602a3b544f", "git_parents": ["e9ceb84c7f9634f67516a988a4de07a4d526e971"], "node": "e675809dedbefd5bf164f07283e3ca9bed77c200", "parents": ["8021a9cc35a3c55c6a4015d4f6234c9aed11c10b"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041095 - Part 2: Setup missing LegacyPaneMappings  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301930\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303846\n", "files": ["browser/components/extensions/test/browser/browser_ext_chrome_settings_overrides_home.js", "browser/components/preferences/config/LegacyPaneMappings.mjs", "browser/components/preferences/config/account-sync.mjs", "browser/components/preferences/config/privacy.mjs", "browser/components/preferences/config/search.mjs", "browser/components/preferences/config/tabs-browsing.mjs", "browser/components/preferences/tests/browser-srd.toml", "browser/components/preferences/tests/browser.toml", "browser/components/preferences/tests/browser_legacy_pane_mappings.js", "browser/extensions/newtab/lib/AboutPreferences.sys.mjs"], "git_node": "2fa3cdde9c557ed85d83df3ff858dccaeb8de21a", "git_parents": ["a844a5a3113ee5ad989d9783fedcfc602a3b544f"], "node": "274b5f16b979e69b012fa81ab617c43e986964a8", "parents": ["e675809dedbefd5bf164f07283e3ca9bed77c200"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 2041098 - Subcategory setting-group spotlight fixes  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301931\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303847\n", "files": ["browser/components/preferences/tests/chrome/head.js", "browser/components/preferences/tests/privacy/browser_privacy_status_card_srd.js", "browser/components/preferences/widgets/setting-control/setting-control.mjs", "browser/components/preferences/widgets/setting-element/setting-element.mjs", "browser/themes/shared/preferences/preferences.css"], "git_node": "4547db5dd6aeaaa161082b9c43df037b81f39966", "git_parents": ["2fa3cdde9c557ed85d83df3ff858dccaeb8de21a"], "node": "2d8628a20cdb0a01d503811def7b75d6d4745d90", "parents": ["274b5f16b979e69b012fa81ab617c43e986964a8"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 2038749 - Automatically search sub-panes in Settings  a=RyanVM\n\nWhen an element is marked with data-load-pane=\"paneFoo\" (set with\nloadPane: \"foo\" in the config) then that pane will be searched and the\nelement will be highlighted as a keyboard match based on matches in the\nrelated pane (or any sub-panes of that pane).\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301425\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303848\n", "files": ["browser/components/preferences/config/account-sync.mjs", "browser/components/preferences/config/aiFeatures.mjs", "browser/components/preferences/config/languages.mjs", "browser/components/preferences/config/passwords-autofill.mjs", "browser/components/preferences/config/privacy.mjs", "browser/components/preferences/config/tabs-browsing.mjs", "browser/components/preferences/findInPage.js", "browser/components/preferences/tests/browser-srd.toml", "browser/components/preferences/tests/browser_setting_pane_sub_pane.js", "browser/components/preferences/tests/browser_setting_pane_sub_pane_search.js", "browser/components/preferences/tests/head.js", "browser/components/preferences/widgets/setting-element/setting-element.mjs", "browser/extensions/newtab/lib/AboutPreferences.sys.mjs"], "git_node": "4f29a4ca01951ddc943a45127e4f5cdd6ee06fda", "git_parents": ["4547db5dd6aeaaa161082b9c43df037b81f39966"], "node": "44b87015994896bd83c286c17d9117084b9aa036", "parents": ["2d8628a20cdb0a01d503811def7b75d6d4745d90"], "tags": []}], "date": 1780364945, "git_changesets": ["a844a5a3113ee5ad989d9783fedcfc602a3b544f", "2fa3cdde9c557ed85d83df3ff858dccaeb8de21a", "4547db5dd6aeaaa161082b9c43df037b81f39966", "4f29a4ca01951ddc943a45127e4f5cdd6ee06fda"], "user": "rvandermeulen@mozilla.com"}, "26654": {"changesets": [{"author": "hannajones \u003chjones@mozilla.com\u003e", "branch": "default", "desc": "Bug 2016075 - Make it possible to change role of moz-message-bar  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301873\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303798\n", "files": ["toolkit/content/tests/widgets/test_moz_message_bar.html", "toolkit/content/widgets/moz-message-bar/moz-message-bar.mjs"], "git_node": "02c99f0a7f1b8af727f634c83d2efc88861e5576", "git_parents": ["4f29a4ca01951ddc943a45127e4f5cdd6ee06fda"], "node": "e8a08e3a64435c969a3fe7b908b2197c027eaf46", "parents": ["44b87015994896bd83c286c17d9117084b9aa036"], "tags": []}, {"author": "hannajones \u003chjones@mozilla.com\u003e", "branch": "default", "desc": "Bug 2037418 - Switch some about:preferences messages to use role='status'  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301910\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303799\n", "files": ["browser/components/preferences/config/about-firefox.mjs", "browser/components/preferences/config/aiFeatures.mjs", "browser/components/preferences/config/appearance.mjs", "browser/components/preferences/config/permissions-data.mjs", "browser/components/preferences/config/privacy.mjs", "browser/components/preferences/config/search.mjs", "browser/components/preferences/main.js"], "git_node": "e68e74b2170215f15237594f8fdf3b63819371e9", "git_parents": ["02c99f0a7f1b8af727f634c83d2efc88861e5576"], "node": "28df1ae0a473375152aff202d7fead4b62f3f618", "parents": ["e8a08e3a64435c969a3fe7b908b2197c027eaf46"], "tags": []}], "date": 1780365087, "git_changesets": ["02c99f0a7f1b8af727f634c83d2efc88861e5576", "e68e74b2170215f15237594f8fdf3b63819371e9"], "user": "rvandermeulen@mozilla.com"}, "26655": {"changesets": [{"author": "any1here \u003cany1here@duck.com\u003e", "branch": "default", "desc": "Bug 2042309 - Remove MOZ_DATA_REPORTING conditional from preferences  a=RyanVM\n\nOriginal Revision: https://phabricator.services.mozilla.com/D303169\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303800\n", "files": ["browser/components/preferences/config/permissions-data.mjs"], "git_node": "cc920de3a954a2f9db2318a00af2c7d05a9ef64c", "git_parents": ["e68e74b2170215f15237594f8fdf3b63819371e9"], "node": "d9a6243e850a0b1256594174c2fc346eefa82de4", "parents": ["28df1ae0a473375152aff202d7fead4b62f3f618"], "tags": []}], "date": 1780365150, "git_changesets": ["cc920de3a954a2f9db2318a00af2c7d05a9ef64c"], "user": "rvandermeulen@mozilla.com"}, "26656": {"changesets": [{"author": "Mark Kennedy \u003cmkennedy@mozilla.com\u003e", "branch": "default", "desc": "Bug 2004488 - Restore parent pane scroll position when navigating back from any pane in about:preferences  a=RyanVM\n\nRestores the user's scroll position when clicking browser back button\nwhen on a pane or sub-pane. Same behavior for the left arrow button\nnext to sub-pane titles, but only if the sub-pane wasn't loaded by\nnavigating to it from the URL-bar.\n\n* Supports restoring scroll position when going back from any pane (including sub panes)\n\n* Intentionally excludes breadcrumb clicks, since those are implicitly forward-moving entries\n\n* Uses ScrollOffets class but also refactors it to accommodate custom scroll targets and new use case in about:preferences\n\nOriginal Revision: https://phabricator.services.mozilla.com/D301302\n\nDifferential Revision: https://phabricator.services.mozilla.com/D303864\n", "files": ["browser/base/content/test/sanitize/head.js", "browser/components/preferences/preferences.js", "browser/components/preferences/tests/browser-srd.toml", "browser/components/preferences/tests/browser_bug1020245_openPreferences_to_paneContent.js", "browser/components/preferences/tests/browser_setting_pane_scroll_restoration.js", "browser/components/preferences/tests/browser_sub_pane_navigation_selection.js", "browser/components/preferences/tests/etp/browser_etp_advanced.js", "browser/components/preferences/tests/head.js", "browser/components/preferences/tests/siteData/head.js", "browser/components/preferences/widgets/setting-pane/setting-pane.mjs", "browser/components/search/test/browser/browser_searchbar_enter.js", "browser/components/urlbar/tests/browser/browser_oneOffs_settings.js", "toolkit/content/ScrollOffsets.mjs", "toolkit/content/jar.mn", "toolkit/content/tests/chrome/chrome.toml", "toolkit/content/tests/chrome/test_scroll_offsets.html", "toolkit/mozapps/extensions/content/components/addon-details.mjs", "toolkit/mozapps/extensions/content/components/addon-shortcuts.mjs", "toolkit/mozapps/extensions/content/view-controller.mjs"], "git_node": "0b68668a0a01bd93fc4902b93ab6557796b0acee", "git_parents": ["cc920de3a954a2f9db2318a00af2c7d05a9ef64c"], "node": "9637dfd69e898fe0a29799a845f4dfe4081ea1a6", "parents": ["d9a6243e850a0b1256594174c2fc346eefa82de4"], "tags": []}], "date": 1780365736, "git_changesets": ["0b6866