2a985d2b73e68", "parents": ["2280f918eed30cef5247d636e735a37905bdb6c8"], "tags": []}, {"author": "Simon Farre \u003csimon.farre.cx@gmail.com\u003e", "branch": "default", "desc": "Bug 2025969 - Copy txXPathNode as value  a=diannaS DONTBUILD\n\nCopy a value of txXPathNode to member, as the type has value semantics.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D290400\n\nDifferential Revision: https://phabricator.services.mozilla.com/D291241\n", "files": ["dom/xslt/xpath/txForwardContext.h"], "git_node": "e5aa3be4680c05bcad63c08b5c3b7e0f3f314cbd", "git_parents": ["feba0cfb8404391507594313eb7537f9e270d9a3"], "node": "76cd46d9df89b547aaa1dabdc81c36e5613b7715", "parents": ["b7e6a95fa7b878266f5e4b059592a985d2b73e68"], "tags": []}, {"author": "Simon Farre \u003csimon.farre.cx@gmail.com\u003e", "branch": "default", "desc": "Bug 2025971 - Use txSingleNodeContext getter of owned txXPathNode  a=diannaS DONTBUILD\n\neContext gets a copy of aNode. The function should use that one's member\nas it's not a shared reference, which we can't know the life time of.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D290389\n\nDifferential Revision: https://phabricator.services.mozilla.com/D291242\n", "files": ["dom/xslt/xpath/txPathExpr.cpp"], "git_node": "f8cc311b9911c06824ad69591b55f8ab688aa9ff", "git_parents": ["e5aa3be4680c05bcad63c08b5c3b7e0f3f314cbd"], "node": "c312c4f2df1c7137b6cd968fb7e3ea52531fae28", "parents": ["76cd46d9df89b547aaa1dabdc81c36e5613b7715"], "tags": []}], "date": 1775151724, "git_changesets": ["2c61e78bd38f4a85917a990c409ba6440200a030", "feba0cfb8404391507594313eb7537f9e270d9a3", "e5aa3be4680c05bcad63c08b5c3b7e0f3f314cbd", "f8cc311b9911c06824ad69591b55f8ab688aa9ff"], "user": "dsmith@mozilla.com"}, "25447": {"changesets": [{"author": "Randell Jesup \u003crjesup@mozilla.com\u003e", "branch": "default", "desc": "Bug 2024661: Clean up DeleteChannel  a=diannaS DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D28871