r/tools/log_list.json", "services/settings/dumps/blocklists/addons-bloomfilters.json", "services/settings/dumps/main/ai-window-prompts.json", "services/settings/dumps/main/devtools-compatibility-browsers.json", "services/settings/dumps/security-state/intermediates.json"], "git_node": "e269a3256eb85008e8b4bef3c84f42afb25f9e97", "git_parents": ["f794acf5300e6c195e16ac3585f1c45a6b7b6d66"], "node": "bc653b7592bb40860268a2fff4429e0f25eb8bd4", "parents": ["8330114a131eda2e1cd35229dcc5c66033f725df"], "tags": []}], "date": 1776198941, "git_changesets": ["e269a3256eb85008e8b4bef3c84f42afb25f9e97"], "user": "dsmith@mozilla.com"}, "25796": {"changesets": [{"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 2023880.  a=diannaS DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D292328\n\nDifferential Revision: https://phabricator.services.mozilla.com/D292972\n", "files": ["dom/media/ipc/RemoteMediaDataEncoderParent.cpp"], "git_node": "4794b557028c33fa3ad7e44fafd1bb3e142cde1b", "git_parents": ["e269a3256eb85008e8b4bef3c84f42afb25f9e97"], "node": "1123a944ae449bffbb25766a91bdce6deb4a3986", "parents": ["bc653b7592bb40860268a2fff4429e0f25eb8bd4"], "tags": []}], "date": 1776203123, "git_changesets": ["4794b557028c33fa3ad7e44fafd1bb3e142cde1b"], "user": "dsmith@mozilla.com"}, "25797": {"changesets": [{"author": "Daniel Baker \u003cdbaker@mozilla.com\u003e", "branch": "default", "desc": "Bug 2025517 - Clean up GmpPluginNotifier and VideoConduit shutdown ordering  a=diannaS DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D293431\n\nDifferential Revision: https://phabricator.services.mozilla.com/D294026\n", "files": ["dom/media/webrtc/libwebrtcglue/VideoConduit.cpp", "dom/media/webrtc/libwebrtcglue/WebrtcVideoCodecFactory.cpp", "dom/media/webrtc/libwebrtcglue/WebrtcVideoCodecFactory.h"], "git_node": "5b3eb04b30b83528c041bd7a852123b7a7db5e32", "git_parents": ["4794b557028c33fa3ad7e44fafd1bb3e142cde1b"], "node": "5cfff2e398b1f8d892cb7353d89d54cb535a054a", "parents": ["1123a944ae449bffbb25766a91bdce6deb4a3986"], "tags": []}], "date": 1776203216, "git_changesets": ["5b3eb04b30b83528c041bd7a852123b7a7db5e32"], "user": "dsmith@mozilla.com"}, "25798": {"changesets": [{"author": "Duncan McIntosh \u003cdmcintosh@mozilla.com\u003e", "branch": "default", "desc": "Bug 2025980 - Fix GetCommandLineW call and fix macro substitution in UseExistingInstallPathIfNoInstallDirArg.  a=diannaS\n\nThere's two fixes here:\n\n * System::Call expects a 'r' prefix before the register; previously\n   this just used '.0' when it should've been '.r0' (even though NSIS\n   syntax is '$0' and $R0 is '.r10'...)\n\n * When it replaced $INSTDIR with ${Path}, the value of ${Path} is $0\n   since it's plain macro substitution. But the if statement just\n   checked that $0 is empty! Store the original value of ${Path} on the\n   stack and exchange it in if needed.\n\nThe latter was not caught by the test suite because the test suite\npassed a literal string! Therefore, it never clobbered the register and\neverything seemed fine.\n\n(This is a bit wasteful given we call it with $0, since we push it\ntwice, but it should work.)\n\nWhile I'm here, also avoid $MockCommandLine leaking past the /D test.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D294023\n\nDifferential Revision: https://phabricator.services.mozilla.com/D294044\n", "files": ["browser/installer/windows/nsis/install_dir_helpers.nsh", "browser/installer/windows/nsis/test_stub.nsi"], "git_node": "6b189b68d4e31fb050880e400a97440cdc9f4428", "git_parents": ["5b3eb04b30b83528c041bd7a852123b7a7db5e32"], "node": "ef778e3df93d526fc8509f6a15ec56e2b5e90317", "parents": ["5cfff2e398b1f8d892cb7353d89d54cb535a054a"], "tags": []}], "date": 1776203547, "git_changesets": ["6b189b68d4e31fb050880e400a97440cdc9f4428"], "user": "dsmith@mozilla.com"}, "25799": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "