4a8ea2f50640938577", "git_parents": ["dbec7ffb0665a1fb3de663a1b37f9e617e4f03c7"], "node": "afc9e2a3094adc4fd4c187bd31469b685c67fc27", "parents": ["1d7f0089113239969180c8b1273d7144c937e2d7"], "tags": []}], "date": 1774795731, "git_changesets": ["eca73ff3597c286ed0e3ac4a8ea2f50640938577"], "user": "dsmith@mozilla.com"}, "25295": {"changesets": [{"author": "alastor0325 \u003calastor0325@gmail.com\u003e", "branch": "default", "desc": "Bug 2025458 - Ensure SetCDMProxy always runs on the task queue.  a=diannaS\n\nOriginal Revision: https://phabricator.services.mozilla.com/D289379\n\nDifferential Revision: https://phabricator.services.mozilla.com/D290303\n", "files": ["dom/media/ExternalEngineStateMachine.cpp"], "git_node": "79b02276b233387a39561b0763a3c49903f9098b", "git_parents": ["eca73ff3597c286ed0e3ac4a8ea2f50640938577"], "node": "db20cc2401596183646cf5d9c03ac99e86258d1f", "parents": ["afc9e2a3094adc4fd4c187bd31469b685c67fc27"], "tags": []}], "date": 1774795869, "git_changesets": ["79b02276b233387a39561b0763a3c49903f9098b"], "user": "dsmith@mozilla.com"}, "25296": {"changesets": [{"author": "James Teow \u003cjteow@mozilla.com\u003e", "branch": "default", "desc": "Bug 2001962 - Fix intermittent timeout in browser_searchModeSwitcher_keyNavigation.js -  a=diannaS\n\nbrowser_searchModeSwitcher_keyNavigation.js is timing out intermittently in CI\nbecause test_search_service_fail in browser_searchModeSwitcher_basic.js used\nforceInitializationStatusForTests(\"not initialized\"), which caused\nSearchService.init() to re-run #init() when a pref change fired during the test.\n\nThis reloaded the MozSearch engine from saved settings, and a subsequent\n_reloadEngines call tried to call engine.update() on it, which failed because\nthe test engine's WebExtension policy is not available outside its test.\nThis prevented the `engines-reloaded` notification from firing, causing\nupdateRemoteSettingsConfig in later tests to hang waiting for it.\n\nUse \"failed\" instead of \"not initialized\", which causes init() to short-circuit\nwithout re-running #init(). The test behavior is identical since #ensureInitialized\nstill throws for a \"failed\" status.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D290030\n\nDifferential Revision: https://phabricator.services.mozilla.com/D290739\n", "files": ["browser/components/urlbar/UrlbarSearchUtils.sys.mjs", "browser/components/urlbar/tests/browser/browser_searchModeSwitcher_basic.js"], "git_node": "1c5ee6f7fae354b470774cd3927385eee91ceb72", "git_parents": ["79b02276b233387a39561b0763a3c49903f9098b"], "node": "52ff14ddb89bd004bd37e46f0e40c1b8749c7639", "parents": ["db20cc2401596183646cf5d9c03ac99e86258d1f"], "tags": []}], "date": 1774796411, "git_changesets": ["1c5ee6f7fae354b470774cd3927385eee91ceb72"], "user": "dsmith@mozilla.com"}, "25297": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Import translations from main\n", "files": ["mobile/android/fenix/app/src/main/res/values-el/strings.xml", "mobile/android/fenix/app/src/main/res/values-eu/strings.xml", "mobile/android/fenix/app/src/main/res/values-it/strings.xml", "mobile/android/fenix/app/src/main/res/values-iw/strings.xml", "mobile/android/fenix/app/src/main/res/values-th/strings.xml", "mobile/android/fenix/app/src/main/res/values-tr/strings.xml", "mobile/android/fenix/app/src/main/res/values-vi/strings.xml", "mobile/android/focus-android/app/src/main/res/values-eu/strings.xml", "mobile/android/focus-android/app/src/main/res/values-sk/strings.xml", "mobile/android/focus-android/app/src/main/res/values-tr/strings.xml"], "git_node": "4d4f7b275ea52bfac5b4de42a9d744e03b6bc105", "git_parents": ["1c5ee6f7fae354b470774cd3927385eee91ceb72"], "node": "9634657705c28fbe2d4c1f25016d6b1dafefb6e3", "parents": ["52ff14ddb89bd004bd37e46f0e40c1b8749c7639"], "tags": []}], "date": 1774836871, "git_changesets": ["4d4f7b275ea52bfac5b4de42a9d744e03b6bc105"], "user": "ffxbld@lando.moz.tools"}, "25298": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2026299 - Improve FontFace promise resolution + followups.  a=diannaS\n\nMake promise resolution async, and a lot of the FontFaceSetImpl stuff\ndoesn't make sense anymore because FontFaceSetImpl _is_ thread-safe.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D289918\n\nDifferential Revision: https://phabricator.services.mozilla.com/D290411\n", "files": ["layout/style/FontFace.cpp", "layout/style/FontFaceImpl.cpp", "layout/style/FontFaceImpl.h", "layout/style/FontFaceSetImpl.cpp", "layout/style/PostTraversalTask.cpp", "layout/style/PostTraversalTask.h"], "git_node": "3e955f57d48ec3866cf4dd72dd6adf71f28d7a8b", "git_parents": ["4d4f7b275ea52bfac5b4de42a9d744e03b6bc105"], "node": "e2e6b623a742112b6aedcdbd9073919812969dc0", "parents": ["9634657705c28fbe2d4c1f25016d6b1dafefb6e3"], "tags": []}], "date": 1774836914, "git_changesets": ["3e955f57d48ec3866cf4dd72dd6adf71f28d7a8b"], "user": "dsmith@mozilla.com"}, "25299": {"changesets": [{"author": "Giulia Cardieri \u003cgcardieri@mozilla.com\u003e", "branch": "default", "desc": "Bug 2009612 - include settings telemetry and its tests  a=diannaS\n\nInclude telemetry for smart window preferences.\n\nEvents:\n- memories nuke: when the delete all memories is clicked\n- settings_memories: when the user checks/unchecks the memories checkboxes\n- settings_model: when the user changes the model selection\n- memories_panel_displayed: when the memories panel is visible\n\nMetrics:\n- model: when the model changes\n\nOther updates:\n- Using the MODELS constants for the model names\n- Added a head_smart_window as a script to avoid repeating functions (over 40 lines of repetition)\n\nPossible pain/reviewing points:\n- head_smart_window is added as a script, should we do another approach? I could add the functions in the head.js but then they would be imported by all tests which seems unnecessary\n- Global variable \"previousAssistantModel\" was needed to ensure when a custom model is selected we still know which model was previously set\n\nOriginal Revision: https://phabricator.services.mozilla.com/D288768\n\nDifferential Revision: https://phabricator.services.mozilla.com/D290506\n", "files": ["browser/components/aiwindow/metrics.yaml", "browser/components/aiwindow/ui/modules/AIWindow.sys.mjs", "browser/components/aiwindow/ui/modules/SmartWindowTelemetry.sys.mjs", "browser/components/preferences/config/aiFeatures.mjs", "browser/components/preferences/tests/browser.toml", "browser/components/preferences/tests/browser_aiFeatures_smart_window_memories.js", "browser/components/preferences/tests/browser_aiFeatures_smart_window_model_settings.js", "browser/components/preferences/tests/browser_aiFeatures_smart_window_telemetry.js", "browser/components/preferences/tests/head_smart_window.js"], "git_node": "88433fbe62c226f155ccf209fa5a4b83ebc39e7d", "git_parents": ["3e955f57d48ec3866cf4dd72dd6adf71f28d7a8b"], "node": "fb66bfab6ea9b04d9583d230163fec99d3849dd7", "parents": ["e2e6b623a742112b6aedcdbd9073919812969dc0"], "tags": []}], "date": 1774836953, "git_changesets": ["88433fbe62c226f155ccf209fa5a4b83ebc39e7d"], "user": "dsmith@mozilla.com"}, "25300": {"changesets": [{"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 2025445 - Fix redundant clear optimization to check if clip needs refresh.  a=diannaS\n\nDrawTargetWebgl's redundant clear optimization checks the current clip state to determine if\nthere is no effective clip. However, if drawing to Skia and not WebGL, there may be no current\nclip computed, or the clip state may be invalid.\n\nTo work around this, only use the current clip state if it is actually currently valid, and\notherwise compute a simple clip rectangle sufficient to validate if it contains the viewport\nwithout relying on cached clip state.\n\nOriginal Revision: https://ph