5533": {"changesets": [{"author": "Omar Gonzalez \u003cs9tpepper@apache.org\u003e", "branch": "default", "desc": "Bug 2026191 - guard starter prompts from loading into wrong tab  a=diannaS\n\nOriginal Revision: https://phabricator.services.mozilla.com/D290290\n\nDifferential Revision: https://phabricator.services.mozilla.com/D292032\n", "files": ["browser/components/aiwindow/ui/components/ai-window/ai-window.mjs", "browser/components/aiwindow/ui/modules/AIWindowUI.sys.mjs", "browser/components/aiwindow/ui/test/browser/browser_smartwindow_prompts.js", "browser/components/aiwindow/ui/test/browser/head.js"], "git_node": "e475a0e2c1c1a3a6b2766e256529769b144ee469", "git_parents": ["f87ed5323bdf9d152379f5202b9fc8cc26efb891"], "node": "be46ee5c3fd28321dfcad90a8334f210abad554d", "parents": ["8c3d8f89da73a29f78819a8c267275587fa49ca7"], "tags": []}, {"author": "Omar Gonzalez \u003cs9tpepper@apache.org\u003e", "branch": "default", "desc": "Bug 2024781 - sidebar should default to open on all tabs going from fullpage mode to sidebar mode  a=diannaS\n\nOriginal Revision: https://phabricator.services.mozilla.com/D290761\n\nDifferential Revision: https://phabricator.services.mozilla.com/D292024\n", "files": ["browser/components/aiwindow/ui/components/ai-window/ai-window.mjs", "browser/components/aiwindow/ui/modules/AIWindowTabStatesManager.sys.mjs", "browser/components/aiwindow/ui/modules/AIWindowUI.sys.mjs", "browser/components/aiwindow/ui/test/browser/browser_smartwindow_tab_switching.js"], "git_node": "7b51fd50a1fbdf8e794dde1dce918c0134231c9a", "git_parents": ["e475a0e2c1c1a3a6b2766e256529769b144ee469"], "node": "978d03123eadefec12fc2bdaef5d169197cae028", "parents": ["be46ee5c3fd28321dfcad90a8334f210abad554d"], "tags": []}], "date": 1775500311, "git_changesets": ["e475a0e2c1c1a3a6b2766e256529769b144ee469", "7b51fd50a1fbdf8e794dde1dce918c0134231c9a"], "user": "dsmith@mozilla.com"}, "25534": {"changesets": [{"author": "Olli Pettay \u003cOlli.Pettay@helsinki.fi\u003e", "branch": "default", "desc": "Bug 2028524, avoid leaking a document, r=farre, a=dsmith\n\nDifferential Revision: https://phabricator.services.mozilla.com/D291762\n", "files": ["docshell/base/nsDocShell.cpp"], "git_node": "8ceb03fd20f6f886d3c111d9e22a2d599f13c733", "git_parents": ["7b51fd50a1fbdf8e794dde1dce918c0134231c9a"], "node": "d89311407dab2df5d61d7f62686e478261736298", "parents": ["978d03123eadefec12fc2bdaef5d169197cae028"], "tags": []}, {"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 2027359. r=sotaro,gfx-reviewers, a=dsmith DONTBUILD\n\nDifferential Revision: https://phabricator.services.mozilla.com/D291395\n", "files": ["gfx/webrender_bindings/RenderTextureHost.h", "gfx/webrender_bindings/RenderTextureHostSWGL.h", "gfx/webrender_bindings/RenderTextureHostWrapper.cpp", "gfx/webrender_bindings/RenderTextureHostWrapper.h"], "git_node": "7377d376f6af7885fa3a15cb7b13c8a82c4f7e29", "git_parents": ["8ceb03fd20f6f886d3c111d9e22a2d599f13c733"], "node": "59c85af11183657be1c8a4ac3101f8486b1cbebc", "parents": ["d89311407dab2df5d61d7f62686e478261736298"], "tags": []}], "date": 1775501174, "git_changesets": ["8ceb03fd20f6f886d3c111d9e22a2d599f13c733", "7377d376f6af7885fa3a15cb7b13c8a82c4f7e29"], "user": "dsmith@mozilla.com"}, "25535": {"changesets": [{"author": "Francesco Lodolo \u003cflod@lodolo.net\u003e", "branch": "default", "desc": "Bug 2022452 - Uplift localization updates to release every Sunday,  a=diannaS DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D290106\n\nDifferential Revision: https://phabricator.services.mozilla.com/D292170\n", "files": [".cron.yml"], "git_node": "8a9f26edc17f33d5e46d5a7568792569cc2398bc", "git_parents": ["7377d376f6af7885fa3a15cb7b13c8a82c4f7e29"], "node": "52b1fc66436608fb0341141c8ff85da10655fcf0", "parents": ["59c85af11183657be1c8a4ac3101f8486b1cbebc"], "tags": []}], "date": 1775501904, "git_changesets": ["8a9f26edc17f33d5e46d5a7568792569cc2398bc"], "user": "dsmith@mozilla.com"}, "25536": {"changesets": [{"author": "Andrew Osmond \u003caosmond@gmail.com\u003e", "branch": "default", "desc": "Bug 2027161 - Simplify GMP plugin and actor lifetimes.  a=diannaS DONTBUILD\n\nWith OpenH264, each GMP video decoder/encoder has its own worker thread\nto perform the actual decoding/encoding. It posts back to the main\nthread which the IPDL actors live on. Many of its callbacks are\nsynchronous, meaning it blocks the worker thread until the main thread\nruns the dispatched task. When we try to destroy the plugin, it attempts\nto join with the worker thread. That means we cannot attempt to join\nwhile there are any outstanding synchronous calls, otherwise the threads\nwill deadlock.\n\nPreviously we managed this by having an event queue just for the GMP\nplugin callbacks, and tracking how many outstanding synchronous\ncallbacks we are expecting to be dispatched in the future. This is\ncomplicated and somewhat brittle.\n\nThe refactoring in this patch takes advantage of bug 1942129 which\ndecoupled the Shmem lifetime from the IPDL actor lifetime. This means\nthe buffers backing the GMP encoded/decoded frames can now live beyond\nGMPVideoDecoder/EncoderChild::ActorDestroy being called. Taking\nadvantage of that, we can take strong references to the IPDL actor that\nimplements the callbacks whenever there is an outstanding call that may\ntrigger a synchronous callback. This keeps everything alive long enough\nfor the callbacks to finish, and when the last reference is released, we\ncan safely destroy the decoder/encoder, and join the worker thread.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D291885\n\nDifferential Revision: https://phabricator.services.mozilla.com/D292074\n", "files": ["dom/media/gmp-plugin-openh264/gmp-fake-openh264.cpp", "dom/media/gmp/GMPChild.cpp", "dom/media/gmp/GMPContentChild.cpp", "dom/media/gmp/GMPPlatform.cpp", "dom/media/gmp/GMPPlatform.h", "dom/media/gmp/GMPService.cpp", "dom/media/gmp/GMPSharedMemManager.cpp", "dom/media/gmp/GMPSharedMemManager.h", "dom/media/gmp/GMPVideoDecoderChild.cpp", "dom/media/gmp/GMPVideoDecoderChild.h", "dom/media/gmp/GMPVideoDecoderParent.cpp", "dom/media/gmp/GMPVideoDecoderParent.h", "dom/media/gmp/GMPVideoEncodedFrameImpl.cpp", "dom/media/gmp/GMPVideoEncodedFrameImpl.h", "dom/media/gmp/GMPVideoEncoderChild.cpp", "dom/media/gmp/GMPVideoEncoderChild.h", "dom/media/gmp/GMPVideoEncoderParent.cpp", "dom/media/gmp/GMPVideoEncoderParent.h", "dom/media/gmp/GMPVideoHost.cpp", "dom/media/gmp/GMPVideoHost.h", "dom/media/gmp/GMPVideoi420FrameImpl.cpp", "dom/media/gmp/GMPVideoi420FrameImpl.h", "modules/libpref/init/StaticPrefList.yaml"], "git_node": "dd4ce08df5da50621c838af92a347c8655d88952", "git_parents": ["8a9f26edc17f33d5e46d5a7568792569cc2398bc"], "node": "5c5e37328c306c5696fcf6d02d540b29cf84f8dc", "parents": ["52b1fc66436608fb0341141c8ff85da10655fcf0"], "tags": []}], "date": 1775501948, "git_changesets": ["dd4ce08df5da50621c838af92a347c8655d88952"], "user": "dsmith@mozilla.com"}, "25537": {"changesets": [{"author": "serge-sans-paille \u003csguelton@mozilla.com\u003e", "branch": "default", "desc": "Bug 2026327 - Make StaticMutex default constructor constinit-compatible in DEBUG mode   a=diannaS DONTBUILD\n\nWhile we're at it, make the copy-constructor deleted instead of private\nin DEBUG mode.\n\nThis makes MOZ_RELEASE_CONSTINIT obsolete.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D290045\n\nDifferential Revision: https://phabricator.services.mozilla.com/D291183\n", "files": ["dom/media/ipc/MFCDMParent.cpp", "dom/media/ipc/RemoteMediaManagerChild.cpp", "dom/media/platforms/PDMFactory.cpp", "dom/media/platforms/ffmpeg/FFmpegDecoderModule.h", "dom/media/platforms/ffmpeg/FFmpegEncoderModule.h", "dom/media/platforms/ffmpeg/VALibWrapper.cpp", "gfx/2d/DWriteSettings.cpp", "mfbt/Attributes.h", "toolkit/components/telemetry/core/Telemetry.cpp", "widget/android/AndroidVsync.cpp", "xpcom/base/StaticMutex.h", "xpcom/ioutils/IOUtils.cpp"], "git_node": "de9a6890722f87dae3f7a67378cf5d0762e06bda", "git_parents": ["dd4ce08df5da50621c838af92a347c8655d88952"], "node": "9b98ba27c42efb6600db3c2c48e602f212a0a44a", "parents": ["5c5e37328c306c5696fcf6d02d540b29cf84f8dc"], "tags": []}], "date": 1775501988, "git_changesets": ["de9a6890722f87dae3f7a67378cf5d0762e06bda"], "user": "dsmith@mozilla.com"}, "25538": {"changesets": [{"author": "Greg Tatum \u003ctatum.creative@gmail.com\u003e", "branch": "default", "desc": "Bug 2023001 - Surface the error message in tool calls  a=diannaS\n\nErrors here were being hidden when tool calls failed.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D291338\n\nDifferential Revision: https://phabricator.services.mozilla.com/D292157\n", "files": ["browser/components/aiwindow/models/Chat.sys.mjs"], "git_node": "a96a08c0dfe733aee8b8afc3364603ad543305c4", "git_parents": ["de9a6890722f87dae3f7a67378cf5d0762e06bda"], "node": "adae428838a64fa3c2260b5a405b347c0b13cb9a", "parents": ["9b98ba27c42efb6600db3c2c48e602f212a0a44a"], "tags": []}, {"author": "Greg Tatum \u003ctatum.creative@gmail.com\u003e", "branch": "default", "desc": "Bug 2023001 - Refactor tool calling to make it less dynamic  a=diannaS\n\nThe current implementation of the code is quite dynamic with many\noptional arguments, and misdirection around dispatching tool calls. This\npatch simplifies the arguments by making them required, and more\nspecifically wiring the arguments to specific tool calls using a switch\nstatement.\n\nThis should make it easier to reason with this code when dealing with\nthe security characteristics of the tool calls.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D291339\n\nDifferential Revision: https://phabricator.services.mozilla.com/D292158\n", "files": ["browser/components/aiwindow/models/Chat.sys.mjs", "browser/components/aiwindow/models/Tools.sys.mjs", "browser/components/aiwindow/models/tests/browser/browser_conversation_stream.js", "browser/components/aiwindow/models/tests/browser_eval/head.js", "browser/components/aiwindow/models/tests/xpcshell/test_Chat.js", "browser/components/aiwindow/models/tests/xpcshell/test_Tools_GetOpenTabs.js", "browser/components/aiwindow/models/tests/xpcshell/test_Tools_GetUserMemories.js", "browser/components/aiwindow/models/tests/xpcshell/test_Tools_RunSearch.js", "browser/components/aiwindow/ui/components/ai-window/ai-window.mjs", "browser/components/aiwindow/ui/test/browser/browser_aiwindow_session_restore.js", "browser/components/aiwindow/ui/test/browser/browser_aiwindow_smartbar.js", "browser/components/aiwindow/ui/test/browser/browser_aiwindow_smartbar_ask.js", "browser/components/aiwindow/ui/test/browser/browser_smartwindow_prompts.js", "browser/components/aiwindow/ui/test/browser/browser_smartwindow_run_search.js", "browser/components/aiwindow/ui/test/browser/browser_smartwindow_telemetry.js"], "git_node": "e4a03a75aa38ac25aec0d45473c9da14a079e314", "git_parents": ["a96a08c0dfe733aee8b8afc3364603ad543305c4"], "node": "02d516f5ef38ba82bcbe16c16adc95e8c5ee8793", "parents": ["adae428838a64fa3c2260b5a405b347c0b13cb9a"], "tags": []}, {"author": "Greg Tatum \u003ctatum.creative@gmail.com\u003e", "branch": "default", "desc": "Bug 2023001 - Pass the conversation into tool calls rather than security properties  a=diannaS\n\nURL tracking needs to be tied to the conversation as well as the\nsecurity properties. Currently the security properties are passed in on\ntheir own, but in a future patch the URLs will get tracked in the tool\ncalls as well.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D291340\n\nDifferential Revision: https://phabricator.services.mozilla.com/D292159\n", "files": ["browser/components/aiwindow/models/Chat.sys.mjs", "browser/components/aiwindow/models/Tools.sys.mjs", "browser/components/aiwindow/models/tests/browser/browser_get_page_content.js", "browser/components/aiwindow/models/tests/xpcshell/head.js", "browser/components/aiwindow/models/tests/xpcshell/test_Chat.js", "browser/components/aiwindow/models/tests/xpcshell/test_SearchBrowsingHistory.js", "browser/components/aiwindow/models/tests/xpcshell/test_SecurityProperties.js", "browser/components/aiwindow/models/tests/xpcshell/test_Tools_GetOpenTabs.js", "browser/components/aiwindow/models/tests/xpcshell/test_Tools_GetPageContent.js", "browser/components/aiwindow/models/tests/xpcshell/test_Tools_GetUserMemories.js", "browser/components/aiwindow/models/tests/xpcshell/test_Tools_RunSearch.js", "browser/components/aiwindow/models/tests/xpcshell/test_Tools_SearchBrowsingHistory.js"], "git_node": "a7c47cc38a6cf10d441592743edbf164be273741", "git_parents": ["e4a03a75aa38ac25aec0d45473c9da14a079e314"], "node": "c324657438552aa9cb6ac103d682ad4a402cbc08", "parents": ["02d516f5ef38ba82bcbe16c16adc95e8c5ee8793"], "tags": []}, {"author": "Greg Tatum \u003ctatum.creative@gmail.com\u003e", "branch": "default", "desc": "Bug 2023001 - Remove citation management from parsing text  a=diannaS\n\nThe original bug that implemented this did not actually _do_ anything as\nit was just logging the results. This was attempting to create citations\nof the URLs seen in the conversation. With this old implementation the behavior\nwas implemented incorrectly. It attemped to parse markdown via\nregexes. It's generally never a good idea to write a parser in regex,\nand here it's a security issue as there will be mismatches between URLs\nthat are pulled from the text and URLs that are rendered for the user.\n\nWe should rely on structured data to provide the URLs in all cases.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D291341\n\nDifferential Revision: https://phabricator.services.mozilla.com/D292160\n", "files": ["browser/components/aiwindow/models/Chat.sys.mjs", "browser/components/aiwindow/models/CitationParser.sys.mjs", "browser/components/aiwindow/models/moz.build", "browser/components/aiwindow/models/tests/xpcshell/test_Chat.js", "browser/components/aiwindow/models/tests/xpcshell/test_CitationParser.js", "browser/components/aiwindow/models/tests/xpcshell/xpcshell.toml"], "git_node": "2f86a1d455052dd53e40dbedb59a227f28cbe699", "git_parents": ["a7c47cc38a6cf10d441592743edbf164be273741"], "node": "786765aa9c21d78f6f72ad4c6a66a6bb3cb42cce", "parents": ["c324657438552aa9cb6ac103d682ad4a402cbc08"], "tags": []}, {"author": "Greg Tatum \u003ctatum.creative@gmail.com\u003e", "branch": "default", "desc": "Bug 2023001 - Refactor search browser history to return structured results  a=diannaS\n\nOriginal Revision: https://phabricator.services.mozilla.com/D291342\n\nDifferential Revision: https://phabricator.services.mozilla.com/D292161\n", "files": ["browser/components/aiwindow/models/SearchBrowsingHistory.sys.mjs", "browser/components/aiwindow/models/tests/browser/browser_conversation_stream.js", "browser/components/aiwindow/models/tests/xpcshell/test_SearchBrowsingHistory.js", "browser/components/aiwindow/models/tests/xpcshell/test_Tools_SearchBrowsingHistory.js"], "git_node": "70ac810e380a251e701f19581c77a0e6c8906636", "git_parents": ["2f86a1d455052dd53e40dbedb59a227f28cbe699"], "node": "d3a57f16d152ed41f3b0f2c4dc85965e4144f328", "parents": ["786765aa9c21d78f6f72ad4c6a66a6bb3cb42cce"], "tags": []}, {"author": "Greg Tatum \u003ctatum.creative@gmail.com\u003e", "branch": "default", "desc": "Bug 2023001 - Only use the DOMExtractor for content extraction even with boilerplate removal  a=diannaS\n\nFor boilerplate removal, we can still pass the content through\nReadability, but the DOMExtraction code can run on the resulting DOM\ncode. This adds some additional complexity in that the DOMParser\ndocument doesn't have an associated window, and changes the behavior of\nDOMExtractor. To fix this, nodes need to know if they have an\nownerGlobal for things like visibility and innerText extraction.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D291344\n\nDifferential Revision: https://phabricator.services.mozilla.com/D292162\n", "files": ["browser/components/aiwindow/models/Tools.sys.mjs", "toolkit/components/pageextractor/DOMExtractor.sys.mjs", "toolkit/components/pageextractor/PageExtractor.d.ts", "toolkit/components/pageextractor/PageExtractorChild.sys.mjs", "toolkit/components/pageextractor/PageExtractorParent.sys.mjs", "toolkit/components/pageextractor/tests/browser/browser_dom_extractor.js", "toolkit/components/pageextractor/tests/browser/browser_dom_extractor_reader_mode.js", "toolkit/components/pageextractor/tests/browser/browser_page_metadata.js"], "git_node": "4311e671cce201d4d588c455d086d3f76d4c0b0f", "git_parents": ["70ac810e380a251e701f19581c77a0e6c8906636"], "node": "d1b221f8431511aec1e69df3078d0c842b60c7c5", "parents": ["d3a57f16d152ed41f3b0f2c4dc85965e4144f328"], "tags": []}, {"author": "Greg Tatum \u003ctatum.creative@gmail.com\u003e", "branch": "default", "desc": "Bug 2023001 - Move RunSearch to use PageExtractor#getText  a=diannaS\n\nOriginal Revision: https://phabricator.services.mozilla.com/D291606\n\nDifferential Revision: https://phabricator.services.mozilla.com/D292163\n", "files": ["browser/components/aiwindow/models/Tools.sys.mjs"], "git_node": "37fc6f21be1512fd7db54e9247fa3bec6f8702fa", "git_parents": ["4311e671cce201d4d588c455d086d3f76d4c0b0f"], "node": "b4c4a74e0ad4784da2871f7ae4df055f1e3f17c0", "parents": ["d1b221f8431511aec1e69df3078d0c842b60c7c5"], "tags": []}, {"author": "Greg Tatum \u003ctatum.creative@gmail.com\u003e", "branch": "default", "desc": "Bug 2023001 - Track seen URLs only in tool calls  a=diannaS\n\nOriginal Revision: https://phabricator.services.mozilla.com/D291343\n\nDifferential Revision: https://phabricator.services.mozilla.com/D292164\n", "files": ["browser/components/aiwindow/models/Chat.sys.mjs", "browser/components/aiwindow/models/ChatUtils.sys.mjs", "browser/components/aiwindow/models/Tools.sys.mjs", "browser/components/aiwindow/models/tests/browser/browser_get_page_content.js", "browser/components/aiwindow/models/tests/xpcshell/head.js", "browser/components/aiwindow/models/tests/xpcshell/test_Chat.js", "browser/components/aiwindow/models/tests/xpcshell/test_ChatUtils.js", "browser/components/aiwindow/models/tests/xpcshell/test_Tools_GetPageContent.js", "browser/components/aiwindow/ui/modules/ChatConversation.sys.mjs"], "git_node": "c92977852bcf753b4878aed527616e41ba93cb4b", "git_parents": ["37fc6f21be1512fd7db54e9247fa3bec6f8702fa"], "node": "ca54a2c6e33341fb976b3489239056758e97ee82", "parents": ["b4c4a74e0ad4784da2871f7ae4df055f1e3f17c0"], "tags": []}, {"author": "Greg Tatum \u003ctatum.creative@gmail.com\u003e", "branch": "default", "desc": "Bug 2023001 - Add the seen urls to the chat store  a=diannaS\n\nOriginal Revision: https://phabricator.services.mozilla.com/D291607\n\nDifferential Revision: https://phabricator.services.mozilla.com/D292165\n", "files": ["browser/components/aiwindow/ui/modules/AIWindowConstants.sys.mjs", "browser/components/aiwindow/ui/modules/ChatConversation.sys.mjs", "browser/components/aiwindow/ui/modules/ChatMigrations.sys.mjs", "browser/components/aiwindow/ui/modules/ChatSql.sys.mjs", "browser/components/aiwindow/ui/modules/ChatStore.sys.mjs", "browser/components/aiwindow/ui/modules/ChatUtils.sys.mjs", "browser/components/aiwindow/ui/test/xpcshell/test_ChatStore.js", "browser/components/aiwindow/ui/test/xpcshell/test_chat-utils.js"], "git_node": "344dcab5b314111a9466054ecb6a73ebc3206be1", "git_parents": ["c92977852bcf753b4878aed527616e41ba93cb4b"], "node": "c6de618db198fe7f0bf3cc6a32c6e55468c0697d", "parents": ["ca54a2c6e33341fb976b3489239056758e97ee82"], "tags": []}, {"author": "Greg Tatum \u003ctatum.creative@gmail.com\u003e", "branch": "default", "desc": "Bug 2023001 - Use the seen URLs in the conversation  a=diannaS\n\nThis changes the conversations to use \"seen urls\" rather than this\nmechanism of \"trusted urls\". As a conversation sees new URLs, they get\npassed to the message rendering layer for the decision process of\nunfurling the message.\n\nThe URLs get passed as they changed as discrete changes, and are append\nonly. They are tied to an individual conversation.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D291888\n\nDifferential Revision: https://phabricator.services.mozilla.com/D292166\n", "files": ["browser/app/profile/firefox.js", "browser/components/aiwindow/ui/actors/AIChatContentChild.sys.mjs", "browser/components/aiwindow/ui/actors/AIChatContentParent.sys.mjs", "browser/components/aiwindow/ui/components/ai-chat-content/ai-chat-content.mjs", "browser/components/aiwindow/ui/components/ai-chat-message/ai-chat-message.mjs", "browser/components/aiwindow/ui/components/ai-window/ai-window.mjs", "browser/components/aiwindow/ui/modules/ChatConversation.sys.mjs", "browser/components/aiwindow/ui/test/browser/browser_aiwindow_url_security.js"], "git_node": "500a3ffcb12fb359a2fabf30dcb82a416206ac6d", "git_parents": ["344dcab5b314111a9466054ecb6a73ebc3206be1"], "node": "afff13c214e2fe5d67be2edf8bd68deedfe68088", "parents": ["c6de618db198fe7f0bf3cc6a32c6e55468c0697d"], "tags": []}, {"author": "Taimur Hasan \u003cthasan@mozilla.com\u003e", "branch": "default", "desc": "Bug 2024388 - Add logging to the conversation, tool calls, and security;  a=diannaS\n\nOriginal Revision: https://phabricator.services.mozilla.com/D288287\n\nDifferential Revision: https://phabricator.services.mozilla.com/D292187\n", "files": ["browser/app/profile/firefox.js", "browser/components/aiwindow/models/Chat.sys.mjs", "browser/components/aiwindow/models/SecurityProperties.sys.mjs", "browser/components/aiwindow/models/Tools.sys.mjs"], "git_node": "093d6644411a5be10f6c0179fdbe1faedeac50fe", "git_parents": ["500a3ffcb12fb359a2fabf30dcb82a416206ac6d"], "node": "4c493d85a2db3977c634057882d54d0f07e0d40f", "parents": ["afff13c214e2fe5d67be2edf8bd68deedfe68088"], "tags": []}], "date": 1775503129, "git_changesets": ["a96a08c0dfe733aee8b8afc3364603ad543305c4", "e4a03a75aa38ac25aec0d45473c9da14a079e314", "a7c47cc38a6cf10d441592743edbf164be273741",