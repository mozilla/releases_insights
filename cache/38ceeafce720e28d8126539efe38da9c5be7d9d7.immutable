0e3"], "node": "ec505f7d4e535da99642af3765226ca6c8f6f710", "parents": ["18ef776aa7d668568f89011772baa753b1e4f42b"], "tags": []}], "date": 1776133086, "git_changesets": ["03cf4fcc3cfbe8355f4d685a03e1fa2b821b1dae"], "user": "ffxbld@lando.moz.tools"}, "25775": {"changesets": [{"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 2027265 - nsJARURI::SetSpecWithBase should not assume null terminated strings  a=diannaS DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D291153\n\nDifferential Revision: https://phabricator.services.mozilla.com/D294101\n", "files": ["modules/libjar/nsJARURI.cpp"], "git_node": "cfaa12a52b169e268de2d2d9cb13e903ebe584fb", "git_parents": ["03cf4fcc3cfbe8355f4d685a03e1fa2b821b1dae"], "node": "adb59e20c58b60fc401d79c18c9b1c12ae37e167", "parents": ["ec505f7d4e535da99642af3765226ca6c8f6f710"], "tags": []}], "date": 1776164969, "git_changesets": ["cfaa12a52b169e268de2d2d9cb13e903ebe584fb"], "user": "dsmith@mozilla.com"}, "25776": {"changesets": [{"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 2029754 - Check chunk to be decommitted is still in the empty chunks list  a=diannaS DONTBUILD\n\nThe problem is that we release the GC lock between decommitting chunks, at\nwhich point the chunk can be reused for something else.\n\nThis doesn't generally happen because prior to this decommit loop we free\nchunks in excess of the minimum empty chunk count which is set to 1 chunk by\ndefault, so the loop unsually only has one iteration.\n\nSince the list size is expected to be (very) small the contains check is OK.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D292496\n\nDifferential Revision: https://phabricator.services.mozilla.com/D294114\n", "files": ["js/src/gc/GC.cpp", "js/src/gc/GCRuntime.h", "js/src/gc/Heap.cpp"], "git_node": "3375dc02e6d67711eb6e63048cccaa5b040f980c", "git_parents": ["cfaa12a52b169e268de2d2d9cb13e903ebe584fb"], "node": "82fc29531b8d41ce5db44e02b1be42f85c0d3ef5", "parents": ["adb59e20c58b60fc401d79c18c9b1c12ae37e167"], "tags": []}], "date": 1776165007, "git_changesets": ["3375dc02e6d67711eb6e63048cccaa5b040f980c"], "user": "dsmith@mozilla.com"}, "25777": {"changesets": [{"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 2029728 - Check subroutine offset in private dict.  a=diannaS DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D293737\n\nDifferential Revision: https://phabricator.services.mozilla.com/D293885\n", "files": ["gfx/cairo/cairo/src/cairo-cff-subset.c"], "git_node": "e46f9f4cf2b770588c7d7edcafb3b3d92b8a0606", "git_parents": ["3375dc02e6d67711eb6e63048cccaa5b040f980c"], "node": "80dce9b40f229c3833de130e2a4eccfca23983f3", "parents": ["82fc29531b8d41ce5db44e02b1be42f85c0d3ef5"], "tags": []}], "date": 1776165394, "git_changesets": ["e46f9f4cf2b770588c7d7edcafb3b3d92b8a0606"], "user": "dsmith@mozilla.com"}, "25778": {"changesets": [{"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 2029295 - Add read barrier to mark symbols retrieved from weak maps in the atom marking bitmap for the zone  a=diannaS DONTBUILD\n\nExposeValueToActiveJS can't do this because it doesn't know the referring zone.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D292494\n\nDifferential Revision: https://phabricator.services.mozilla.com/D294113\n", "files": ["js/src/gc/WeakMap.cpp", "js/src/gc/WeakMap.h"], "git_node": "b4d1868a0f71d3e0e628fa1388d99ab110d7eb25", "git_parents": ["e46f9f4cf2b770588c7d7edcafb3b3d92b8a0606"], "node": "a0f271a60b901334c012c38f0ec5a367aae04871", "parents": ["80dce9b40f229c3833de130e2a4eccfca23983f3"], "tags": []}], "date": 1776165436, "git_changesets": ["b4d1868a0f71d3e0e628fa1388d99ab110d7eb25"], "user": "dsmith@mozilla.com"}, "25779": {"changesets": [{"author": "Randell Jesup \u003crjesup@mozilla.com\u003e", "branch": "default", "desc": "Bug 2029707: add a length check  a=diannaS DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D293166\n\nDifferential Revision: https://phabricator.services.mozilla.com/D293897\n", "files": ["netwerk/streamconv/converters/mozTXTToHTMLConv.cpp"], "git_node": "c1448acaddaf590e86d1c6fdba4fb8f269943573", "git_parents": ["b4d1868a0f71d3e0e628fa1388d99ab110d7eb25"], "node": "e6bef6461e65aaacede2d4629ef749740cffef7b", "parents": ["a0f271a60b901334c012c38f0ec5a367aae04871"], "tags": []}], "date": 1776165525, "git_changesets": ["c1448acaddaf590e86d1c6fdba4fb8f269943573"], "user": "dsmith@mozilla.com"}, "25780": {"changesets": [{"author": "Randell Jesup \u003crjesup@mozilla.com\u003e", "branch": "default", "desc": "Bug 2025461: Tweak the GMPUtils, fix LOG  a=diannaS DONTBUILD\n\nDifferential Revision: https://phabricator.services.mozilla.com/D293970\n", "files": ["dom/media/gmp/GMPUtils.cpp", "dom/media/gmp/GMPUtils.h", "dom/media/gmp/GMPVideoEncodedFrameImpl.cpp"], "git_node": "63eeb4a6befebbaf3eb01fbb63bba11a692bb988", "git_parents": ["c1448acaddaf590e86d1c6fdba4fb8f269943573"], "node": "a09fc113a8f0ba71cdd670f7eb5638ec8c4b8f30", "parents": ["e6bef6461e65aaacede2d4629ef749740cffef7b"], "tags": []}], "date": 1776166363, "git_changesets": ["63eeb4a6befebbaf3eb01fbb63bba11a692bb988"], "user": "dsmith@mozilla.com"}, "25781": {"changesets": [{"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 2029776 - Cherry-pick upstream libwebrtc commit 77d265670f  a=diannaS\n\nUpstream commit: https://webrtc.googlesource.com/src/+/77d265670fa7d7f358c86c54704a6e97c27a6005\n       Fix TOCTOU race in RtpVideoSender::OnVideoLayersAllocationUpdated\n\n       RtpVideoSender::OnVideoLayersAllocationUpdated runs on the encoder thread,\n       checks if it's active, and then posts a task to the transport queue to\n       update module status.\n\n       If SetSending(false) is called on the transport queue before the posted\n       task runs, the task would previously re-register modules in PacketRouter\n       even though active_ was false. This lead to dangling pointers in\n       PacketRouter when the RtpVideoSender was destroyed.\n\n       This CL adds an IsActive() check inside the posted task to ensure we don't\n       re-register modules if the sender has been deactivated.\n\n       Bug: chromium:500767595\n       Test: RtpVideoSenderTest.PostTaskRaceDoesNotLeadToDanglingPointer\n       Change-Id: I18827c34bece7f5ebc41d159d9e19e356afbc404\n       Reviewed-on: https://webrtc-review.googlesource.com/c/src/+/462880\n       Commit-Queue: Harald Alvestrand \u003chta@webrtc.org\u003e\n       Reviewed-by: Erik Spr\u00e5ng \u003csprang@webrtc.org\u003e\n       Cr-Commit-Position: refs/heads/main@{#47384}\n\nOriginal Revision: https://phabricator.services.mozilla.com/D293064\n\nDifferential Revision: https://phabricator.services.mozilla.com/D293800\n", "files": ["third_party/libwebrtc/call/BUILD.gn", "third_party/libwebrtc/call/rtp_video_sender.cc", "third_party/libwebrtc/call/rtp_video_sender_unittest.cc", "third_party/libwebrtc/moz-patch-stack/77d265670f.no-op-cherry-pick-msg"], "git_node": "a8d1d07f1b4a7915e5a615c390e755bd6050fbe0", "git_parents": ["63eeb4a6befebbaf3eb01fbb63bba11a692bb988"], "node": "40f7c575cab0d52276fda69eee590d7b046d4acf", "parents": ["a09fc113a8f0ba71cdd670f7eb5638ec8c4b8f30"], "tags": []}], "date": 1776166776, "git_changesets": ["a8d1d07f1b4a7915e5a615c390e755bd6050fbe0"], "user": "dsmith@mozilla.com"}, "25782": {"changesets": [{"author": "Jonathan Kew \u003cjkew@mozilla.com\u003e", "branch": "default", "desc": "Bug 2028627 - [beta] Cache generation in gfxPlatformFontList.  a=diannaS DONTBUILD\n\nAnd make mSharedFontList an atomic ptr, and other fixes.\n\n(Adapted from AI-suggested fixes, see comments 3 & 8.)\n\nDifferential Revision: https://phabricator.services.mozilla.com/D294133\n", "files": ["gfx/thebes/gfxDWriteFontList.cpp", "gfx/thebes/gfxFontEntry.cpp", "gfx/thebes/gf