s from main\n", "files": ["mobile/android/android-components/components/browser/errorpages/src/main/res/values-sr/strings.xml", "mobile/android/android-components/components/compose/awesomebar/src/main/res/values-sr/strings.xml", "mobile/android/android-components/components/compose/base/src/main/res/values-sr/strings.xml", "mobile/android/android-components/components/compose/browser-toolbar/src/main/res/values-sr/strings.xml", "mobile/android/android-components/components/feature/addons/src/main/res/values-sr/strings.xml", "mobile/android/android-components/components/feature/app-links/src/main/res/values-eo/strings.xml", "mobile/android/android-components/components/feature/app-links/src/main/res/values-es/strings.xml", "mobile/android/android-components/components/feature/app-links/src/main/res/values-fr/strings.xml", "mobile/android/android-components/components/feature/app-links/src/main/res/values-gn/strings.xml", "mobile/android/android-components/components/feature/app-links/src/main/res/values-iw/strings.xml", "mobile/android/android-components/components/feature/app-links/src/main/res/values-nb-rNO/strings.xml", "mobile/android/android-components/components/feature/app-links/src/main/res/values-sl/strings.xml", "mobile/android/android-components/components/feature/app-links/src/main/res/values-sr/strings.xml", "mobile/android/android-components/components/feature/contextmenu/src/main/res/values-sr/strings.xml", "mobile/android/android-components/components/feature/downloads/src/main/res/values-om/strings.xml", "mobile/android/android-components/components/feature/downloads/src/main/res/values-sr/strings.xml", "mobile/android/android-components/components/feature/media/src/main/res/values-sr/strings.xml", "mobile/android/android-components/components/feature/prompts/src/main/res/values-om/strings.xml", "mobile/android/android-components/components/feature/prompts/src/main/res/values-sl/strings.xml", "mobile/android/android-components/components/feature/pro