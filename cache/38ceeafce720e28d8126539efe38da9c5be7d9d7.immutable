mozilla.com\u003e", "branch": "default", "desc": "Bug 2028038 - Trigger enableTheme after recovering a legacy backup into a profile group.  a=diannaS DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D293598\n\nDifferential Revision: https://phabricator.services.mozilla.com/D294147\n", "files": ["browser/components/backup/BackupService.sys.mjs", "browser/components/backup/tests/xpcshell/test_BackupService_crossProfileTypeRecovery.js", "browser/components/profiles/ProfilesParent.sys.mjs", "browser/components/profiles/SelectableProfileService.sys.mjs"], "git_node": "82e7ad45362a27775735b4885c7a96f2ce049dc8", "git_parents": ["bcd4f4a366302b4f3e9171121087592592237c34"], "node": "b87a2f07bcee762a8c1e8e2f0d2e57758a386bee", "parents": ["ec9ec2631f3dbb0ee6374f8b845d2b33fb7a11c0"], "tags": []}], "date": 1776177254, "git_changesets": ["82e7ad45362a27775735b4885c7a96f2ce049dc8"], "user": "dsmith@mozilla.com"}, "25786": {"changesets": [{"author": "Alex Franchuk \u003cafranchuk@mozilla.com\u003e", "branch": "default", "desc": "Bug 2026650 p1 - Use the prefs file from the crashreport to disable telemetry  a=diannaS\n\nOriginal Revision: https://phabricator.services.mozilla.com/D290266\n\nDifferential Revision: https://phabricator.services.mozilla.com/D294166\n", "files": ["toolkit/components/crashes/CrashManager.in.sys.mjs", "toolkit/components/crashes/tests/xpcshell/test_crash_manager.js", "toolkit/crashreporter/client/app/src/glean.rs", "toolkit/crashreporter/client/app/src/lang/langpack.rs", "toolkit/crashreporter/client/app/src/main.rs", "toolkit/crashreporter/client/app/src/prefs_parser.rs", "toolkit/crashreporter/client/app/src/send_ping.rs", "toolkit/crashreporter/client/app/src/std/fs.rs", "toolkit/crashreporter/client/app/src/test.rs"], "git_node": "19687c486471f59b81e9e98cf704d3ec94923eb7", "git_parents": ["82e7ad45362a27775735b4885c7a96f2ce049dc8"], "node": "ecc74ef1d608579d9e7f60faeeb65e3381c81502", "parents": ["b87a2f07bcee762a8c1e8e2f0d2e57758a386bee"], "tags": []}, {"author": "Alex Franchuk \u003cafranchuk@mozilla.com\u003e", "branch": "default", "desc": "Bug 2026650 p2 - Use app telemetry upload settings in GleanCrashReporterService  a=diannaS\n\nThere's no reliable way to test these changes end-to-end because we'd\nneed to check the outgoing network traffic from Glean, but that relies\non Glean's scheduling of sending the pings.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D290267\n\nDifferential Revision: https://phabricator.services.mozilla.com/D294167\n", "files": ["mobile/android/android-components/components/lib/crash/src/androidTest/java/mozilla/components/lib/crash/service/GleanCrashReporterServiceTest.kt", "mobile/android/android-components/components/lib/crash/src/main/java/mozilla/components/lib/crash/CrashReporter.kt", "mobile/android/android-components/components/lib/crash/src/main/java/mozilla/components/lib/crash/NativeCrashTools.kt", "mobile/android/android-components/components/lib/crash/src/main/java/mozilla/components/lib/crash/service/CrashTelemetryService.kt", "mobile/android/android-components/components/lib/crash/src/main/java/mozilla/components/lib/crash/service/GleanCrashReporterService.kt", "mobile/android/android-components/components/lib/crash/src/test/java/mozilla/components/lib/crash/CrashReporterTest.kt", "mobile/android/android-components/components/lib/crash/src/test/java/mozilla/components/lib/crash/service/SendCrashTelemetryServiceTest.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/components/Analytics.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/settings/datachoices/DataChoicesFragment.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/fenix/settings/datachoices/DataChoicesMiddleware.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/dataChoicesStore/DataChoicesMiddlewareTest.kt", "mobile/android/focus-android/app/src/main/java/org/mozilla/focus/Components.kt", "toolkit/crashreporter/android/export/lib.rs", "toolkit/crashreporter/android/lib.cpp", "toolkit/crashreporter/crashping/src/lib.rs"], "git_node": "d7037ce421292366d92865611bd5213d5e365c7b", "git_parents": ["19687c486471f59b81e9e98cf704d3ec94923eb7"], "node": "160000ae6c2d751fe6c2e61bf88db6fe3a154767", "parents": ["ecc74ef1d608579d9e7f60faeeb65e3381c81502"], "tags": []}, {"author": "Alex Franchuk \u003cafranchuk@mozilla.com\u003e", "branch": "default", "desc": "Bug 2026650 p3 - Perform crash ping maintenance after startup  a=diannaS\n\nThis ensures any pending pings are sent if they previously failed to\nsend, and that telemetry settings are registered deterministically\nrather than when a crash occurs.\n\nThere's no good way to test this, since we can't mock the glean\npersistence store and a test checking that the process was launched\nwould more-or-less be checking that Subprocess works.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D290989\n\nDifferential Revision: https://phabricator.services.mozilla.com/D294168\n", "files": ["toolkit/components/crashes/CrashManager.in.sys.mjs", "toolkit/components/crashes/tests/xpcshell/test_crash_manager.js", "toolkit/crashreporter/client/app/src/main.rs", "toolkit/crashreporter/client/app/src/send_ping.rs"], "git_node": "8a652ac22c7938eb00900f939e50459d8b1e2fc2", "git_parents": ["d7037ce421292366d92865611bd5213d5e365c7b"], "node": "716766e26730fe9fd5681e4322ff80b940411abe", "parents": ["160000ae6c2d751fe6c2e61bf88db6fe3a154767"], "tags": []}], "date": 1776178971, "git_changesets": ["19687c486471f59b81e9e98cf704d3ec94923eb7", "d7037ce421292366d92865611bd5213d5e365c7b", "8a652ac22c7938eb00900f939e50459d8b1e2fc2"], "user": "dsmith@mozilla.com"}, "25787": {"changesets": [{"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 2027293 - Retrieve and hold editor before calling SetSelectionBoundsAt.  a=diannaS DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D292197\n\nDifferential Revision: https://phabricator.services.mozilla.com/D294206\n", "files": ["accessible/generic/HyperTextAccessible.cpp"], "git_node": "db8a3683b1b1eaf5b4a1bf46e67444298335ff4f", "git_parents": ["8a652ac22c7938eb00900f939e50459d8b1e2fc2"], "node": "9ea35fd20ed3cbbfdb06272acf21ac4b6c7b607c", "parents": ["716766e26730fe9fd5681e4322ff80b940411abe"], "tags": []}], "date": 1776183979, "git_changesets": ["db8a3683b1b1eaf5b4a1bf46e67444298335ff4f"], "user": "dsmith@mozilla.com"}, "25788": {"changesets": [{"author": "Eitan Isaacson \u003ceitan@monotonous.org\u003e", "branch": "default", "desc": "Bug 2029743 - Return strong references to content from ToDOMPoint.  a=diannaS DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D293153\n\nDifferential Revision: https://phabricator.services.mozilla.com/D294200\n", "files": ["accessible/base/TextLeafRange.cpp", "accessible/base/TextLeafRange.h"], "git_node": "2b907d3f27ab1af6c87b5a1582c5612582eeed95", "git_parents": ["db8a3683b1b1eaf5b4a1bf46e67444298335ff4f"], "node": "64b85af3dfa38670b5f8deab4d0f7ba436a6a557", "parents": ["9ea35fd20ed3cbbfdb06272acf21ac4b6c7b607c"], "tags": []}], "date": 1776184329, "git_changesets": ["2b907d3f27ab1af6c87b5a1582c5612582eeed95"], "user": "dsmith@mozilla.com"}, "25789": {"changesets": [{"author": "az \u003cazebrowski@mozilla.com\u003e", "branch": "default", "desc": "Bug 2025511 -  a=diannaS\n\nOriginal Revision: https://phabricator.services.mozilla.com/D291541\n\nDifferential Revision: https://phabricator.services.mozilla.com/D294197\n", "files": ["dom/media/AsyncLogger.h"], "git_node": "bd071ff0eb8b9056b0ef9fc47153c366bae0a607", "git_parents": ["2b907d3f27ab1af6c87b5a1582c5612582eeed95"], "node": "bf9bee3f7d05167f0f75d7a3aafd52c5674e5874", "parents": ["64b85af3dfa38670b5f8deab4d0f7ba436a6a557"], "tags": []}], "date": 1776184870, "git_changesets": ["bd071ff0eb8b9056b0ef9fc47153c366bae0a607"], "user": "dsmith@mozilla.com"}, "25790": {"changesets": [{"author": "Eitan Isaacson \u003ceitan