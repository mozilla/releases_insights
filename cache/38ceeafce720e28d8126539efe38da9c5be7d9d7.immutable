3989f55c3256acea1da3e626f1f2d9627da4c"], "node": "15f8d59c18ae5af607b1834dfad94ddf6cc81280", "parents": ["b3ba33a968485fe449281d83916a5ebadbc3eb64"], "tags": []}], "date": 1775438410, "git_changesets": ["93946e7618470314290d46eb7491b5f815fd9946"], "user": "dsmith@mozilla.com"}, "25517": {"changesets": [{"author": "az \u003cazebrowski@mozilla.com\u003e", "branch": "default", "desc": "Bug 2028551  a=diannaS DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D291535\n\nDifferential Revision: https://phabricator.services.mozilla.com/D291963\n", "files": ["dom/media/platforms/ffmpeg/FFmpegAudioDecoder.cpp"], "git_node": "410a9f9dd24a0fb72d73860a259820e9bfa3b4d6", "git_parents": ["93946e7618470314290d46eb7491b5f815fd9946"], "node": "8b4067e36d57cf992fc58f06988720c98858b669", "parents": ["15f8d59c18ae5af607b1834dfad94ddf6cc81280"], "tags": []}], "date": 1775438480, "git_changesets": ["410a9f9dd24a0fb72d73860a259820e9bfa3b4d6"], "user": "dsmith@mozilla.com"}, "25518": {"changesets": [{"author": "Timothy Nikkel \u003ctnikkel@gmail.com\u003e", "branch": "default", "desc": "Bug 2027975.  a=diannaS DONTBUILD\n\nDifferential Revision: https://phabricator.services.mozilla.com/D291947\n", "files": ["gfx/layers/SourceSurfaceSharedData.cpp"], "git_node": "ae48fa6ce59a1f0e261a9bbbfecfee20be983be5", "git_parents": ["410a9f9dd24a0fb72d73860a259820e9bfa3b4d6"], "node": "7fafb8c3d94aeb8faa4bbb7fa0c92fec38ddb96b", "parents": ["8b4067e36d57cf992fc58f06988720c98858b669"], "tags": []}], "date": 1775438518, "git_changesets": ["ae48fa6ce59a1f0e261a9bbbfecfee20be983be5"], "user": "dsmith@mozilla.com"}, "25519": {"changesets": [{"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 2023670 - Part 1: Only allow sending nsIInputStream for transferrable StruturedCloneHolders,  a=diannaS DONTBUILD\n\nA nsIInputStream is generally only intended to be consumed in one place, so it\nis generally incompatible with being sent in a multi-receiver situation.\n\nThis doesn't make nsIInputStream require an explicit entry in the transferrable\narray for compatibility with existing callers.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D289863\n\nDifferential Revision: https://phabricator.services.mozilla.com/D291879\n", "files": ["dom/base/StructuredCloneHolder.cpp", "dom/base/StructuredCloneHolder.h", "dom/base/test/browser_inputStream_structuredClone.js", "dom/ipc/StructuredCloneData.h"], "git_node": "4bb45c20b2424c7eac6371ee65e61026e1190b89", "git_parents": ["ae48fa6ce59a1f0e261a9bbbfecfee20be983be5"], "node": "8c6985ee3a63e66c41056da876a537f5c746702d", "parents": ["7fafb8c3d94aeb8faa4bbb7fa0c92fec38ddb96b"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 2023670 - Part 2: Clear transferred state in WriteIPCParams,  a=diannaS DONTBUILD\n\nThis adds more checks like the ones which exist due to Read to prevent misuse\nof the StructuredCloneHolder state and multi-use of transferred types. This\nshould give us earlier errors in cases where we may try to use a transferred\nstate multiple times.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D289864\n\nDifferential Revision: https://phabricator.services.mozilla.com/D291880\n", "files": ["dom/base/StructuredCloneHolder.cpp", "dom/base/StructuredCloneHolder.h", "dom/ipc/StructuredCloneData.cpp"], "git_node": "21ec4c9b2f22e45f7bf3ae194f99ac5d1c08ba1e", "git_parents": ["4bb45c20b2424c7eac6371ee65e61026e1190b89"], "node": "af57d5372d71ad848cd2bd60052cc77f49150871", "parents": ["8c6985ee3a63e66c41056da876a537f5c746702d"], "tags": []}], "date": 1775438576, "git_changesets": ["4bb45c20b2424c7eac6371ee65e61026e1190b89", "21ec4c9b2f22e45f7bf3ae194f99ac5d1c08ba1e"], "user": "dsmith@mozilla.com"}, "25520": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Import translations from main\n", "f