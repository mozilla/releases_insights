, "user": "dsmith@mozilla.com"}, "25317": {"changesets": [{"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 2024664 - Prevent ObliviousHttpChannel::mStreamListener replacement  a=diannaS\n\nOriginal Revision: https://phabricator.services.mozilla.com/D289166\n\nDifferential Revision: https://phabricator.services.mozilla.com/D290858\n", "files": ["netwerk/protocol/http/ObliviousHttpChannel.cpp", "netwerk/protocol/http/ObliviousHttpChannel.h"], "git_node": "4441226bdab68fcab384c9fd65c97a858272547d", "git_parents": ["442d337c293cb07c2b693dd2afb0984e4eb3a790"], "node": "07aa7019abdcfdd358d3f1743552eb0ec52d8f10", "parents": ["d38ad659f2eedc6aa074dcb3d00813eff62e8b33"], "tags": []}], "date": 1774892682, "git_changesets": ["4441226bdab68fcab384c9fd65c97a858272547d"], "user": "dsmith@mozilla.com"}, "25318": {"changesets": [{"author": "Malte J\u00fcrgens \u003cmaltejur@mozilla.com\u003e", "branch": "default", "desc": "Bug 2023019 - Handle race in wptrunner switch_to_window  a=diannaS\n\nIn case any of the windows retrieved from self.parent.base.window_handles() are\nclosed before self.parent.base.set_window() is called for them, that call will\ncause an error, which we can just ignore.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D290252\n\nDifferential Revision: https://phabricator.services.mozilla.com/D290839\n", "files": ["testing/web-platform/tests/tools/wptrunner/wptrunner/executors/protocol.py"], "git_node": "85242494ffd4aa5c75adf785f3a038f66843b4f6", "git_parents": ["4441226bdab68fcab384c9fd65c97a858272547d"], "node": "68bd514ceb4c05eb23b7928500367d59acf694d6", "parents": ["07aa7019abdcfdd358d3f1743552eb0ec52d8f10"], "tags": []}], "date": 1774893617, "git_changesets": ["85242494ffd4aa5c75adf785f3a038f66843b4f6"], "user": "dsmith@mozilla.com"}, "25319": {"changesets": [{"author": "Bob Owen \u003cbobowencode@gmail.com\u003e", "branch": "default", "desc": "Bug 2026959 - Fix Trellix exclusion check for closing KsecDD.  a=diannaS\n\nOriginal Revision: https://phabricator.services.mozilla.com/D290458\n\nDifferential Revision: https://phabricator.services.mozilla.com/D290803\n", "files": ["security/sandbox/win/src/sandboxbroker/sandboxBroker.cpp"], "git_node": "e39358a84208df5d76134953bd90e3ac63e54ef5", "git_parents": ["85242494ffd4aa5c75adf785f3a038f66843b4f6"], "node": "92ff60f8afea74c97fb8a1997c65fa1b9b70ae21", "parents": ["68bd514ceb4c05eb23b7928500367d59acf694d6"], "tags": []}], "date": 1774893657, "git_changesets": ["e39358a84208df5d76134953bd90e3ac63e54ef5"], "user": "dsmith@mozilla.com"}, "25320": {"changesets": [{"author": "iain holmes \u003ciholmes@mozilla.com\u003e", "branch": "default", "desc": "[Bug 2025291] Add the ability for to configure Firefox to launch on login for new Windows users.  ,mconley  a=diannaS\n\nHook into first-startup-new-profile to remotely enable launch at login for Windows users via Nimbus.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D289266\n\nDifferential Revision: https://phabricator.services.mozilla.com/D290820\n", "files": ["browser/components/BrowserComponents.manifest", "browser/components/defaultwindowslaunchonlogin/DefaultWindowsLaunchOnLogin.sys.mjs", "browser/components/defaultwindowslaunchonlogin/moz.build", "browser/components/defaultwindowslaunchonlogin/tests/test_nimbus_defaultWindowsLaunchOnLogin_firstStartup.js", "browser/components/defaultwindowslaunchonlogin/tests/xpcshell.toml", "browser/components/moz.build", "toolkit/components/nimbus/FeatureManifest.yaml"], "git_node": "3c896c2268337448dc67c2d230adcae99abf72f6", "git_parents": ["e39358a84208df5d76134953bd90e3ac63e54ef5"], "node": "9b91a00f3623cecbdda940904292e78640311719", "parents": ["92ff60f8afea74c97fb8a1997c65fa1b9b70ae21"], "tags": []}], "date": 1774895302, "git_changesets": ["3c896c2268337448dc67c2d230adcae99abf72f6"], "user": "dsmith@mozilla.com"}, "25321": {"changesets": [{"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 2025387.  a=diannaS DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D290278\n\nDifferential Revision: https://phabricator.services.mozilla.com/D290518\n", "files": ["dom/canvas/DrawTargetWebgl.cpp"], "git_node": "cdec4de2e43395abfad3c28d1fe5e5dcf68fadc5", "git_parents": ["3c896c2268337448dc67c2d230adcae99abf72f6"], "node": "1cfbed3af43f60c486d8e3742461cc2208af63da", "parents": ["9b91a00f3623cecbdda940904292e78640311719"], "tags": []}], "date": 1774897010, "git_changesets": ["cdec4de2e43395abfad3c28d1fe5e5dcf68fadc5"], "user": "dsmith@mozilla.com"}, "25322": {"changesets": [{"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 2026601.  a=diannaS DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D290285\n\nDifferential Revision: https://phabricator.services.mozilla.com/D290952\n", "files": ["gfx/2d/RecordedEventImpl.h"], "git_node": "b5eb680656c8c634ef2e9ce90dd5364fbaf6140b", "git_parents": ["cdec4de2e43395abfad3c28d1fe5e5dcf68fadc5"], "node": "7cfce37f2fa04d3967f102a8f368b647d076d5fd", "parents": ["1cfbed3af43f60c486d8e3742461cc2208af63da"], "tags": []}], "date": 1774897327, "git_changesets": ["b5eb680656c8c634ef2e9ce90dd5364fbaf6140b"], "user": "dsmith@mozilla.com"}, "25323": {"changesets": [{"author": "Tim Giles \u003ctgiles@mozilla.com\u003e", "branch": "default", "desc": "Bug 2018967 - Fix RTL positioning of panel-list popover  a=diannaS\n\nIn RTL layouts, panel-lists were positioning against the viewport edge\ninstead of being anchored to the panel-list trigger button. This was\ncaused by the UA [popover] rule setting `inset: 0`, which overrides\nsetAlign()'s inline-style `left` value through the CSS over-constrained\nresolution. (See CSS Position 3 \u00a76.1\nhttps://www.w3.org/TR/css-position-3/#abs-non-replaced-width)\n\nWe reset `inset` and `padding-inline` on `:host([popover])` so the\npositioning math in setAlign() isn't fighting the UA stylesheet. We also\nround final position values and vertical comparison inputs to prevent\nsubpixel drift, and use the effective panel width, which includes\n`min-width-from-anchor`, when calculating alignment so the overflow\nchecks are accurate.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D289939\n\nDifferential Revision: https://phabricator.services.mozilla.com/D290864\n", "files": ["toolkit/content/tests/widgets/test_panel_list_min_width_from_anchor.html", "toolkit/content/tests/widgets/test_panel_list_shadow_node_anchor.html", "toolkit/content/widgets/panel-list/panel-list.css", "toolkit/content/widgets/panel-list/panel-list.js"], "git_node": "8ca38ad88f6cd19b966b90cebc523ab73525fc8d", "git_parents": ["b5eb680656c8c634ef2e9ce90dd5364fbaf6140b"], "node": "70cfc76fa04ec22208bcca1d4f2b59e633749c89", "parents": ["7cfce37f2fa04d3967f102a8f368b647d076d5fd"], "tags": []}, {"author": "Tim Giles \u003ctgiles@mozilla.com\u003e", "branch": "default", "desc": "Bug 2018967 - Add RTL alignment tests for panel-list popover  a=diannaS\n\nThe previous patch adds RTL layout support to setAlign() but without\ntest coverage to guard it. We add checkRTLAlignment to cover the four\nalignment scenarios: normal right-alignment to the trigger button,\nleft-align fallback when right-alignment overflows the left viewport\nedge, and two cases where the anchor straddles or exceeds the right\nviewport edge.\n\ncheckAlignment also gets a LTR right-edge overflow case to directly\nexercise the new leftOffset clamp. We hoisted getBounds, showPanel, and\nhidePanel to file scope so both tasks can reuse them.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D289941\n\nDifferential Revision: https://phabricator.services.mozilla.com/D290865\n", "files": ["toolkit/content/tests/widgets/test_panel_list_anchoring.html"], "git_node": "61a64e3a2c98aa9e64e55118146d93c3f3fe0a83", "git_parents": ["8ca38ad88f6cd19b966b90cebc523ab73525fc8d"], "node": "4d0dfe6e66d346df5232de7a92fd70abd15ade0c", "parents": ["70cfc76fa04ec22208bcca1d4f2b59e633749c89"], "tags": []}], "date": 1774897587, "git_changesets": ["8ca38ad88f6cd19b966b90cebc523ab73525fc8d", "61a64e3a2c98aa9e64e55118146d93c3f3fe0a83"], "user": "dsmith@mozilla.com"}, "25324": {"changesets": [{"author": "Simon Friedberger \u003csimon@mozilla.com\u003e", "branch": "default", "desc": "Bug 2018787: Init security flags on conversation start  a=diannaS\n\nOriginal Revision: https://phabricator.services.mozilla.com/D288663\n\nDifferential Revision: https://phabricator.services.mozilla.com/D290933\n", "files": ["browser/components/aiwindow/ui/modules/ChatConversation.sys.mjs", "browser/components/aiwindow/ui/test/xpcshell/test_ChatConversation.js"], "git_node": "e6d26d56ebb2995a385906ba00a49b5351624f8a", "git_parents": ["61a64e3a2c98aa9e64e55118146d93c3f3fe0a83"], "node": "cf40e10610455f6cfd3507b28c22c3e9263298b9", "parents": ["4d0dfe6e66d346df5232de7a92fd70abd15ade0c"], "tags": []}, {"author": "Simon Friedberger \u003csimon@mozilla.com\u003e", "branch": "default", "desc": "Bug 2018787: Make getRealTimeInfo static  a=diannaS\n\nOriginal Revision: https://phabricator.services.mozilla.com/D288860\n\nDifferential Revision: https://phabricator.services.mozilla.com/D290934\n", "files": ["browser/components/aiwindow/ui/modules/ChatConversation.sys.mjs", "browser/components/aiwindow/ui/test/xpcshell/test_ChatConversation.js"], "git_node": "22426fdcac0554c0bab2cd5a98e2749e4d1a130e", "git_parents": ["e6d26d56ebb2995a385906ba00a49b5351624f8a"], "node": "fbbb3fa552098f42589f7ad2666f0863f7a68491", "parents": ["cf40e10610455f6cfd3507b28c22c3e9263298b9"], "tags": []}], "date": 1774899977, "git_changesets": ["e6d26d56ebb2995a385906ba00a49b5351624f8a", "22426fdcac0554c0bab2cd5a98e2749e4d1a130e"], "user": "dsmith@mozilla.com"}, "25325": {"changesets": [{"author": "Michael Kaply \u003c345868+mkaply@users.noreply.github.com\u003e", "branch": "default", "desc": "Bug 2019983 - Add a new enterprise policy for AI Controls