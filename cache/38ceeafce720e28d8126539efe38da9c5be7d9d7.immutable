tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging b31970e45f0e483c9de1515dbe0fee2f86c89a44 with DEVEDITION_150_0b1_RELEASE a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "b823e3bca1c74928de13424a34aa8bf3965442fb", "git_parents": ["3b79f6ee87f5bae0aa2c9c74b0a6cacfea889fb2"], "node": "8f8be99cc0f07f41d0968ed74097a4c72be5dd11", "parents": ["641510a19649f453946bb6c673a250eb8969505d"], "tags": []}], "date": 1774455319, "git_changesets": ["b823e3bca1c74928de13424a34aa8bf3965442fb"], "user": "ffxbld@lando.moz.tools"}, "25176": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging b31970e45f0e483c9de1515dbe0fee2f86c89a44 with FIREFOX_150_0b1_RELEASE a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "df965d93774e8e27800f3cd693982bceead07bc7", "git_parents": ["b823e3bca1c74928de13424a34aa8bf3965442fb"], "node": "164a0816ffb02f96205f392f7b061b54ab23d658", "parents": ["8f8be99cc0f07f41d0968ed74097a4c72be5dd11"], "tags": []}], "date": 1774455372, "git_changesets": ["df965d93774e8e27800f3cd693982bceead07bc7"], "user": "ffxbld@lando.moz.tools"}, "25177": {"changesets": [{"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 2024666 - Make TLSTransportLayer::Close dispatch to socket thread  a=diannaS\n\nOriginal Revision: https://phabricator.services.mozilla.com/D288838\n\nDifferential Revision: https://phabricator.services.mozilla.com/D289487\n", "files": ["netwerk/protocol/http/TLSTransportLayer.cpp"], "git_node": "baf048a9cbefdd58aae66fbdb117dc7b0a7ecc7a", "git_parents": ["56897048d126b133d74794365b63442e096eb1d3"], "node": "529019dc3d40d9813d9db7424832223a7f0ed9f9", "parents": ["cffc79147db226deff590c7d7c22b7b99e03a3d1"], "tags": []}], "date": 1774457565, "git_changesets": ["baf048a9cbefdd58aae66fbdb117dc7b0a7ecc7a"], "user": "dsmith@mozilla.com"}, "25178": {"changesets": [{"author": "Cathy Lu \u003ccalu@mozilla.com\u003e", "branch": "default", "desc": "Bug 2025070 - Fix unused string resource in Create Tab Group r=android-reviewers,jdelorenzo, a=dsmith\n\nDifferential Revision: https://phabricator.services.mozilla.com/D289077\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/tabgroups/EditTabGroupBottomSheet.kt"], "git_node": "a4b02e064a398cbd0632ce9c8f60f6cefbbd1130", "git_parents": ["baf048a9cbefdd58aae66fbdb117dc7b0a7ecc7a"], "node": "329989752d069f7a35e16828dea4cc1970a46ed7", "parents": ["529019dc3d40d9813d9db7424832223a7f0ed9f9"], "tags": []}], "date": 1774459191, "git_changesets": ["a4b02e064a398cbd0632ce9c8f60f6cefbbd1130"], "user": "dsmith@mozilla.com"}, "25179": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2024420.  a=diannaS\n\nOriginal Revision: https://phabricator.services.mozilla.com/D288649\n\nDifferential Revision: https://phabricator.services.mozilla.com/D289491\n", "files": ["servo/components/style/values/specified/calc.rs"], "git_node": "9d2b1f5b6757c85c09d55a095fad4f93f07c11fc", "git_parents": ["a4b02e064a398cbd0632ce9c8f60f6cefbbd1130"], "node": "28d0ef3a1a12c8e2dbfb3c5632c9ff719e4eef9a", "parents": ["329989752d069f7a35e16828dea4cc1970a46ed7"], "tags": []}], "date": 1774460933, "git_changesets": ["9d2b1f5b6757c85c09d55a095fad4f93f07c11fc"], "user": "dsmith@mozilla.com"}, "25180": {"changesets": [{"author": "Marcin Kozi\u0144ski \u003cmkozinski@mozilla.com\u003e", "branch": "default", "desc": "Bug 2014124 - Don't show onboarding cards or pagination dots under status or navigation bar  a=diannaS\n\nOriginal Revision: https://phabricator.services.mozilla.com/D289194\n\nDifferential Revision: https://phabricator.services.mozilla.com/D289847\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/onboarding/redesign/view/OnboardingScreenRedesign.kt"], "git_node": "cdba8e3e2bae61f7a31e422343594dae21dd7c47", "git_parents": ["9d2b1f5b6757c85c09d55a095fad4f93f07c11fc"], "node": "c416a9475c752587ffa5714bfa5060eb365a821c", "parents": ["28d0ef3a1a12c8e2dbfb3c5632c9ff719e4eef9a"], "tags": []}], "date": 1774461674, "git_changesets": ["cdba8e3e2bae61f7a31e422343594dae21dd7c47"], "user": "dsmith@mozilla.com"}, "25181": {"changesets": [{"author": "alastor0325 \u003calastor0325@gmail.com\u003e", "branch": "default", "desc": "Bug 2024790 - Use LUID-matched adapter in CreateMediaEngineDevice.  a=diannaS\n\nThe media engine device was created with nullptr + D3D_DRIVER_TYPE_HARDWARE,\nwhich always picks adapter 0 by index and bypasses LUID matching. If adapter\nenumeration order changes (GPU hotplug, driver update), the media engine\ncould land on a different physical GPU than the compositor and decoder,\ncausing rendering or decode failures. Use GetDXGIAdapterLocked() with\nD3D_DRIVER_TYPE_UNKNOWN instead, consistent with every other device creation\nmethod in DeviceManagerDx. D3D11CreateDevice returns E_INVALIDARG when\nD3D_DRIVER_TYPE_HARDWARE is combined with a non-null adapter [1].\n\nAlso drop D3D11_CREATE_DEVICE_VIDEO_SUPPORT. With an explicit adapter,\nD3D11CreateDevice strictly enforces the flag and fails on adapters that do\nnot support it (e.g. the Microsoft Basic Render Driver in CI), causing\nEnableWindowlessSwapchainMode to return E_UNEXPECTED because no\nIMFDXGIDeviceManager could be set up. The flag is safe to drop because\nFirefox code never calls ID3D11VideoDevice/ID3D11VideoContext on this device;\nthe device is only used to call IMFDXGIDeviceManager::ResetDevice once, then\npassed to the MF Media Engine as MF_MEDIA_ENGINE_DXGI_MANAGER for surface\nsharing and frame output.\n\n[1] https://learn.microsoft.com/en-us/windows/win32/api/d3d11/nf-d3d11-d3d11createdevice\n\nOriginal Revision: https://phabricator.services.mozilla.com/D288802\n\nDifferential Revision: https://phabricator.services.mozilla.com/D289682\n", "files": ["gfx/thebes/DeviceManagerDx.cpp"], "git_node": "10314414f6b9fb5e9eb2245f4a04b0650678aabe", "git_parents": ["cdba8e3e2bae61f7a31e422343594dae21dd7c47"], "node": "2308933e7accb7f283279966b28a2c97f00dcb21", "parents": ["c416a9475c752587ffa5714bfa5060eb365a821c"], "tags": []}], "date": 1774476291, "git_changesets": ["10314414f6b9fb5e9eb2245f4a04b0650678aabe"], "user": "dsmith@mozilla.com"}, "25182": {"changesets": [{"author": "Moyin \u003cmadeyemi@mozilla.com\u003e", "branch": "default", "desc": "Bug 2024610 - Replace final overtime and final shootout text with final  a=diannaS\n\nAfter a [conversation on Slack](https://bugzilla.mozilla.org/%5Burl%5D(https://mozilla.slack.com/archives/C0A1YD5DYUU/p1773399592587109)), we've decided to update the strings in the Sports Suggestion cards to match the behavior on Desktop.\n\n**This patch**\nReplace Final Overtime and Final Shootout text with Final in the Sports Card - these strings are still in quarantine and haven't been translated yet, so we'll move them to the static_strings.xml file to leave them untranslated and add the moz:removedIn tag so they can be deleted.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D288646\n\nDifferential Revision: https://phabricator.services.mozilla.com/D289602\n", "files": ["mobile/android/android-components/components/compose/awesomebar/src/main/java/mozilla/components/compose/browser/awesomebar/internal/utils/SportSuggestionDataProvider.kt", "mobile/android/android-components/components/compose/awesomebar/src/main/java/mozilla/components/compose/browser/awesomebar/internal/utils/SuggestionUtils.kt", "mobile/android/android-components/components/compose/awesomebar/src/main/res/values/static_strings.xml", "mobile/android/android-components/components/compose/awesomebar/src/main/res/values/strings.xml", "mobile/android/android-components/components/concept/awesomebar/src/main/java/mozilla/components/concept/awesomebar/optimizedsuggestions/SportSuggestionModel.kt", "mobile/android/android-components/components/feature/awesomebar/src/main/java/mozilla/components/feature/awesomebar/provider/SportsOnlineSuggestionProvider.kt", "mobile/android/android-components/components/feature/awesomebar/src/test/java/mozilla/components/feature/awesomebar/provider/SportsOnlineSuggestionProviderTest.kt"], "git_node": "75ab74e22f2881545bdc1abcc6cf09d794c24ed6", "git_parents": ["10314414f6b9fb5e9eb2245f4a04b0650678aabe"], "node": "568a52d4429a4ed78380be1995d048e443084973", "parents": ["2308933e7accb7f283279966b28a2c97f00dcb21"], "tags": []}, {"author": "Moyin \u003cmadeyemi@mozilla.com\u003e", "branch": "default", "desc": "Bug 2024610: Part 2 - Move the Sports suggestion strings to static_strings.xml  a=diannaS\n\nAfter a [conversation on Slack](https://bugzilla.mozilla.org/%5Burl%5D(https://mozilla.slack.com/archives/C0A1YD5DYUU/p1773399592587109)), we've decided to update the strings in the Sports Suggestion cards to match the behavior on Desktop.\n\n**This patch**\nMove all the other sports strings to the static_strings.xml\n\nOriginal Revision: https://phabricator.services.mozilla.com/D288858\n\nDifferential Revision: https://phabricator.services.mozilla.com/D289603\n", "files": ["mobile/android/android-components/components/compose/awesomebar/src/main/res/values/static_strings.xml", "mobile/android/android-components/components/compose/awesomebar/src/main/res/values/strings.xml"], "git_node": "07932563d19dfb5f3854f0174e50dec47a340585", "git_parents": ["75ab74e22f2881545bdc1abcc6cf09d794c24ed6"], "node": "6c0417d1fbda3b1e7d14a05e80535e3da24b412d", "parents": ["568a52d4429a4ed78380be1995d048e443084973"], "tags": []}], "date": 1774476489, "git_changesets": ["75ab74e22f2881545bdc1abcc6cf09d794c24ed6", "07932563d19dfb5f3854f0174e50dec47a340585"], "user": "dsmith@mozilla.com"}, "25183": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2024654 - Simplify ShadowRoot::InvalidateStyleAndLayoutOnSubtree.  a=diannaS\n\nOriginal Revision: https://phabricator.services.mozilla.com/D288958\n\nDifferential Revision: https://phabricator.services.mozilla.com/D289460\n", "files": ["dom/base/ShadowRoot.cpp", "dom/base/ShadowRoot.h", "dom/html/HTMLSlotElement.cpp"], "git_node": "1895476f7d74730291b0435d729c16b78700b1d6", "git_parents": ["07932563d19dfb5f3854f0174e50dec47a340585"], "node": "c8efcef4e8a8ac029b7636f6357572403cc8a949", "parents": ["6c0417d1fbda3b1e7d14a05e80535e3da24b412d"], "tags": []}], "date": 1774480746, "git_changesets": ["1895476f7d74730291b0435d729c16b78700b1d6"], "user": "dsmith@mozilla.com"}, "25184": {"changesets": [{"author": "Harshit Sohaney \u003chsohaney@mozilla.com\u003e", "branch": "default", "desc": "Bug 2022813 - Fetch and enable theme when replacing a selectable profile with a legacy backup.  a=diannaS\n\nOriginal Revision: https://phabricator.services.mozilla.com/D288072\n\nDifferential Revision: https://phabricator.services.mozilla.com/D289696\n", "files": ["browser/components/backup/BackupService.sys.mjs", "browser/components/backup/resources/SelectableProfileBackupResource.sys.mjs", "browser/components/backup/tests/xpcshell/test_SelectableProfileBackupResource.js", "browser/components/profiles/ProfilesParent.sys.mjs", "browser/components/profiles/SelectableProfileService.sys.mjs"], "git_node": "86defda6de858c6331efa9c19cd6954257df1b68", "git_parents": ["1895476f7d74730291b0435d729c16b78700b1d6"], "node": "3d37e8017e419e835513428fda36fb7ab1bb6da8", "parents": ["c8efcef4e8a8ac029b7636f6357572403cc8a949"], "tags": []}, {"author": "Harshit Sohaney \u003chsohaney@mozilla.com\u003e", "branch": "default", "desc": "Bug 2022813 - (Part 2) Test updates to ensure theme persists when recovering a legacy backup.  a=diannaS\n\nOriginal Revision: https://phabricator.services.mozilla.com/D288201\n\nDifferential Revision: https://phabricator.services.mozilla.com/D289697\n", "files": ["browser/components/backup/tests/marionette/test_backup_replace_current_profile.py", "browser/components/backup/tests/xpcshell/test_BackupService.js", "browser/components/backup/tests/xpcshell/test_BackupService_crossProfileTypeRecovery.js", "browser/components/backup/tests/xpcshell/test_SelectableProfileBackupResource.js"], "git_node": "080870c7a1f8ecda70eb403dac125b929e3b22c9", "git_parents": ["86defda6de858c6331efa9c19cd6954257df1b68"], "node": "44d8730ff7f469396c0eb20f10046cbc82ea5a22", "parents": ["3d37e8017e419e835513428fda36fb7ab1bb6da8"], "tags": []}], "date": 1774481167, "git_changesets": ["86defda6de858c6331efa9c19cd6954257df1b68", "080870c7a1f8ecda70eb403dac125b929e3b22c9"], "user": "dsmith@mozilla.com"}, "25185": {"changesets": [{"author": "Kershaw Chang \u003ckershaw@mozilla.com\u003e", "branch": "default", "desc": "Bug 2024951 - WindowsInternetFunctionsWrapper cleanup,  a=diannaS\n\nOriginal Revision: https://phabricator.services.mozilla.com/D289173\n\nDifferential Revision: https://phabricator.services.mozilla.com/D289750\n", "files": ["toolkit/system/windowsproxy/WindowsInternetFunctionsWrapper.cpp", "toolkit/system/windowsproxy/WindowsInternetFunctionsWrapper.h"], "git_node": "348390dc996b4ffbb33ac86f3de7a038470aeaf3", "git_parents": ["080870c7a1f8ecda70eb403dac125b929e3b22c9"], "node": "006c4e9e32605226c6c09ab13e49446562834db2", "parents": ["44d8730ff7f469396c0eb20f10046cbc82ea5a22"], "tags": []}], "date": 1774481588, "git_changesets": ["348390dc996b4ffbb33ac86f3de7a038470aeaf3"], "user": "dsmith@mozilla.com"}, "25186": {"changesets": [{"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 2024396 - Make CheckedInt::value() check use a release assert. r=sergesanspaille a=diannaS\n\nThis has been a diagnostic assert for many years now without causing\nstability problems on Nightly or early Beta, so let's finish shipping\nit to paper over potential security issues.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D289308\n\nDifferential Revision: https://phabricator.services.mozilla.com/D289793\n", "files": ["mfbt/CheckedInt.h"], "git_node": "2edfe977c2e2af62ed21b838898b9ddba6ccdf18", "git_parents": ["348390dc996b4ffbb33ac86f3de7a038470aeaf3"], "node": "fc663abe960f02fcfab3f23d4ce9d77c000f4e22", "parents": ["006c4e9e32605226c6c09ab13e49446562834db2"], "tags": []}], "date": 1774485626, "git_changesets": ["2edfe977c2e2af62ed21b838898b9ddba6ccdf18"], "user": "dsmith@mozilla.com"}, "25187": {"changesets": [{"author": "Daniel Holbert \u003cdholbert@cs.stanford.edu\u003e", "branch": "default", "desc": "Bug 2026051: Turn off prefs for the GeometryUtils APIs getBoxQuads and convert*FromNode.  a=diannaS\n\nAs noted in the bug, these prefs have never been enabled in release, and\nthere's little value in keeping them enabled in Nightly at this point, given\nthat we're the only engine to support these APIs.  So: let's turn them off\nentirely.\n\nIf other engines gain interest in supporting these, or we prioritize getting\nthem into a shippable state, we can always reenable the prefs.\n\n(Note that getBoxQuads has some internal usage inside the Firefox frontend;\nthat's still allowed using a separate mechanism outside of this about:config\npref -- see nsINode::HasBoxQuadsSupport.)\n\nOriginal Revision: https://phabricator.services.mozilla.com/D289694\n\nDifferential Revision: https://phabricator.services.mozilla.com/D289858\n", "files": ["modules/libpref/init/StaticPrefList.yaml"], "git_node": "a083f4d4ac7f10b28041cd5874fc0dda0a272af9", "git_parents": ["2edfe977c2e2af62ed21b838898b9ddba6ccdf18"], "node": "a1d166d7a7fde7a4dee2240a2a2448750cc1b224", "parents": ["fc663abe960f02fcfab3f23d4ce9d77c000f4e22"], "tags": []}], "date": 1774487203, "git_changesets": ["a083f4d4ac7f10b28041cd5874fc0dda0a272af9"], "user": "dsmith@mozilla.com"}, "25188": {"changesets": [{"author": "Jan-Niklas Jaeschke \u003cjjaschke@mozilla.com\u003e", "branch": "default", "desc": "Bug 2024656 - Keep strong PresShell reference.  a=diannaS\n\nOriginal Revision: https://phabricator.services.mozilla.com/D288853\n\nDifferential Revision: https://phabri