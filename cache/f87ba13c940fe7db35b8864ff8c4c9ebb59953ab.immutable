ifferential Revision: https://phabricator.services.mozilla.com/D53667", "files": ["toolkit/components/passwordmgr/LoginManagerParent.jsm", "toolkit/components/passwordmgr/test/mochitest/test_autofill_https_upgrade.html", "toolkit/components/passwordmgr/test/unit/test_LoginManagerParent_searchAndDedupeLogins.js", "toolkit/components/passwordmgr/test/unit/test_dedupeLogins.js"], "git_node": null, "git_parents": [null], "node": "d78bdcc055db63879bce751e29b0cf7486986dd5", "parents": ["e09e60002be98e2c8e553c29e6928adc5ff341a0"], "tags": []}], "date": 1574119979, "git_changesets": [null, null], "user": "archaeopteryx@coole-files.de"}, "12328": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nde -\u003e 64a6464a9310\neo -\u003e a353b9837bf7\nhe -\u003e 616446418b87\nit -\u003e 8c618363cbc0\npt-PT -\u003e 00e6f6b41df4\nrm -\u003e 90cd4fe11a56", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "45456a65c9595f96aa3e5c3cad9ee876ba75737e", "parents": ["d78bdcc055db63879bce751e29b0cf7486986dd5"], "tags": []}], "date": 1574146839, "git_changesets": [null], "user": "ffxbld"}, "12329": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nde -\u003e 64a6464a9310\neo -\u003e a353b9837bf7\nhe -\u003e 616446418b87\nit -\u003e 8c618363cbc0\npt-PT -\u003e 00e6f6b41df4\nrm -\u003e 90cd4fe11a56", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "5d6dc1652ebc2d3d29f252b1c3910b857f0f6065", "parents": ["45456a65c9595f96aa3e5c3cad9ee876ba75737e"], "tags": []}], "date": 1574150429, "git_changesets": [null], "user": "ffxbld"}, "12330": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com