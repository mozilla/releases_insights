, "devtools/server/tests/browser/browser.ini", "devtools/server/tests/browser/browser_dbg_promises-allocation-stack.js", "devtools/server/tests/browser/browser_dbg_promises-chrome-allocation-stack.js", "devtools/server/tests/browser/browser_dbg_promises-fulfillment-stack.js", "devtools/server/tests/browser/browser_dbg_promises-rejection-stack.js", "devtools/server/tests/browser/doc_promise-get-allocation-stack.html", "devtools/server/tests/browser/doc_promise-get-fulfillment-stack.html", "devtools/server/tests/browser/doc_promise-get-rejection-stack.html", "devtools/server/tests/unit/head_dbg.js", "devtools/server/tests/unit/test_promises_actor_attach.js", "devtools/server/tests/unit/test_promises_actor_list_promises.js", "devtools/server/tests/unit/test_promises_actor_onnewpromise.js", "devtools/server/tests/unit/test_promises_actor_onpromisesettled.js", "devtools/server/tests/unit/test_promises_client_getdependentpromises.js", "devtools/server/tests/unit/test_promises_object_creationtimestamp.js", "devtools/server/tests/unit/test_promises_object_timetosettle-01.js", "devtools/server/tests/unit/test_promises_object_timetosettle-02.js", "devtools/server/tests/unit/xpcshell.ini", "devtools/shared/fronts/moz.build", "devtools/shared/fronts/promises.js", "devtools/shared/specs/index.js", "devtools/shared/specs/moz.build", "devtools/shared/specs/promises.js"], "git_node": null, "git_parents": [null], "node": "b838594432f85707da6be9bfb19521b2175fd199", "parents": ["68614fa56268acc40895f27b0b3cb2750f7248ae"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1496025 - Remove unused methods on ObjectClient related to promises r=ochameau\n\nDepends on D49636\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49638", "files": ["devtools/server/actors/object.js", "devtools/shared/client/object-client.js"], "git_node": null, "git_parents": [null], "node": "6acfae11770ce3a6a0c0f5ebdbe5ebe874c882bb", "parents": ["b838594432f85707da6be9bfb19521b2175fd199"], "tags": []}, {"author": "Sean Feng \u003csefeng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1580315 - Use cert array to do certList serialization r=keeler\n\nThe internal representation of certList has been converted to\ncert array, and this patch does it for the serialization.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49347", "files": ["security/manager/ssl/TransportSecurityInfo.cpp", "security/manager/ssl/TransportSecurityInfo.h", "security/manager/ssl/tests/unit/test_cert_chains.js"], "git_node": null, "git_parents": [null], "node": "d3482abe1fc9117fa433abcf693558ad4ee2bb40", "parents": ["6acfae11770ce3a6a0c0f5ebdbe5ebe874c882bb"], "tags": []}, {"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1589324 - Restore max-width on .container. r=jaws\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49654", "files": ["browser/components/aboutlogins/content/components/login-item.css"], "git_node": null, "git_parents": [null], "node": "bac89dc0731ac6ef5d4643b57cda37817fde4833", "parents": ["d3482abe1fc9117fa433abcf693558ad4ee2bb40"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1589204 - Fix a bug in Matrix4x4Flagged::operator*. r=mstange\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49486", "files": ["gfx/2d/Matrix.h", "gfx/tests/gtest/TestMatrix.cpp"], "git_node": null, "git_parents": [null], "node": "41a1dfdfea9f1ead14119aeaa0513678bddded50", "parents": ["bac89dc0731ac6ef5d4643b57cda37817fde4833"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1587164 - Avoid left shift of negative value in TimestampWrapAroundHandler; r=bwc\n\nThe code for handling backwards wraps left shifts num_wrap_ - 1. If\nnum_wrap_ is zero, this results in a left shift of a negative value which\nis undefined behaviour. This modifies the code to avoid the shift at the cost\nof an extra multiplication.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49609", "files": ["media/webrtc/trunk/webrtc/rtc_base/timeutils.cc"], "git_node": null, "git_parents": [null], "node": "b37d1c262965893df0d27fa9300e6cf6af337a99", "parents": ["41a1dfdfea9f1ead14119aeaa0513678bddded50"], "tags": []}, {"author": "Shane Caraveo \u003cscaraveo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1558326 re-enable test browser_block_fullscreen_prompt.js r=robwu\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49661", "files": ["toolkit/mozapps/extensions/test/xpinstall/browser.ini"], "git_node": null, "git_parents": [null], "node": "c11aa23a063905003bdf0ebc16f78a36474f4b26", "parents": ["b37d1c262965893df0d27fa9300e6cf6af337a99"], "tags": []}, {"author": "J.C. Jones \u003cjc@mozilla.com\u003e", "branch": "default", "desc": "Bug 1577822 - land NSS NSS_3_47_BETA4 UPGRADE_NSS_RELEASE, r=kjacobs\n\n2019-10-18  Deian Stefan  \u003cdeian@cs.ucsd.edu\u003e\n\n\t* lib/softoken/pkcs11c.c:\n\tBug 1459141 - Rewrite softoken CBC pad check to be constant\n\tr=jcj,kjacobs\n\n\t[d3c8638f85cd] [NSS_3_47_BETA4]\n\n2019-10-17  Kevin Jacobs  \u003ckjacobs@mozilla.com\u003e\n\n\t* gtests/pk11_gtest/pk11_cbc_unittest.cc:\n\tBug 1589120 - Additional test vectors for CBC padding. r=jcj\n\n\tThis patch adds more test vectors for AES-CBC and 3DES-CBC padding.\n\n\t[7f17b911ac99]\n\n\t* gtests/pk11_gtest/manifest.mn,\n\tgtests/pk11_gtest/pk11_aeskeywrappad_unittest.cc,\n\tgtests/pk11_gtest/pk11_gtest.gyp:\n\tBug 1589120 - Tests for padded AES key wrap r=jcj\n\n\tThis patch adds test vectors for padded AES Key Wrap. AES-CBC and\n\t3DES-CBC ports of the same vectors will be included in a separate\n\trevision.\n\n\t[fb4d9b6ea2c4]\n\n2019-10-16  Kevin Jacobs  \u003ckjacobs@mozilla.com\u003e\n\n\t* gtests/ssl_gtest/tls_agent.cc, gtests/ssl_gtest/tls_agent.h,\n\tgtests/ssl_gtest/tls_subcerts_unittest.cc, lib/ssl/ssl3con.c,\n\tlib/ssl/sslimpl.h, lib/ssl/tls13subcerts.c,\n\ttests/common/certsetup.sh, tests/ssl_gtests/ssl_gtests.sh:\n\tBug 1588244 - SSLExp_DelegateCredential to support 'rsaEncryption'\n\tend-entity certs with default scheme override r=mt\n\n\tIf an end-entity cert has an SPKI type of 'rsaEncryption', override\n\tthe DC alg to be `ssl_sig_rsa_pss_rsae_sha256`.\n\n\t[93383e0fb833]\n\n2019-10-16  J.C. Jones  \u003cjjones@mozilla.com\u003e\n\n\t* .hgtags:\n\tAdded tag NSS_3_47_BETA3 for changeset f10c3e0757b7\n\t[fa8a67bee2dc]\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49774", "files": ["security/nss/TAG-INFO", "security/nss/coreconf/coreconf.dep", "security/nss/gtests/pk11_gtest/manifest.mn", "security/nss/gtests/pk11_gtest/pk11_aeskeywrappad_unittest.cc", "security/nss/gtests/pk11_gtest/pk11_cbc_unittest.cc", "security/nss/gtests/pk11_gtest/pk11_gtest.gyp", "security/nss/gtests/ssl_gtest/tls_agent.cc", "security/nss/gtests/ssl_gtest/tls_agent.h", "security/nss/gtests/ssl_gtest/tls_subcerts_unittest.cc", "security/nss/lib/softoken/pkcs11c.c", "security/nss/lib/ssl/ssl3con.c", "security/nss/lib/ssl/sslimpl.h", "security/nss/lib/ssl/tls13subcerts.c", "security/nss/tests/common/certsetup.sh", "security/nss/tests/ssl_gtests/ssl_gtests.sh"], "git_node": null, "git_parents": [null], "node": "27bbc1fba01518ef3f0ef836fb4a0473d8f71915", "parents": ["c11aa23a063905003bdf0ebc16f78a36474f4b26"], "tags": []}, {"author": "Nour \u003cnsaffour@gmail.com\u003e", "branch": "default", "desc": "Bug 584141 Added WBR frame class implementing nsFrame and overriding thepeekOffset* methods. r=dbaron,Ehsan\n\nThe wbr element represents a line break opportunity. Before the change double clicking on a text that contains a wbr element did not select the whole sentence.\nAfter the change, the presence of a wbr element in the selection does not affect the selection functionality.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47558", "files": ["layout/generic/FrameClasses.py", "layout/generic/WBRFrame.cpp", "layout/generic/moz.build", "layout/generic/nsHTMLParts.h"], "git_node": null, "git_parents": [null], "node": "80ffb5ef8efb71442034e56a093a4367ac06cdf6", "parents": ["27bbc1fba01518ef3f0ef836fb4a0473d8f71915"], "tags": []}, {"author": "Nour \u003cnsaffour@gmail.com\u003e", "branch": "default", "desc": "Tests for wbr element Bug 584141 r=Ehsan\n\nadded tests for Bug 584141 selection across wbr elements\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49193", "files": ["layout/generic/test/mochitest.ini", "layout/generic/test/test_selection_doubleclick.html"], "git_node": null, "git_parents": [null], "node": "ab0ed4869416de1b5bc777d97949351c48b61913", "parents": ["80ffb5ef8efb71442034e56a093a4367ac06cdf6"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "No bug: [taskgraph] Simplify release_notifications transform slightly; r=aki\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49770", "files": ["taskcluster/taskgraph/transforms/release_notifications.py"], "git_node": null, "git_parents": [null], "node": "5e06a02cad6be0dd6c4c79b916076e50e01ae391", "parents": ["ab0ed4869416de1b5bc777d97949351c48b61913"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1589706: Remove unused b-android worker type; r=Callek\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49762", "files": ["taskcluster/ci/config.yml"], "git_node": null, "git_parents": [null], "node": "71f00b917fb953b82a4c2e85091325fd31338a20", "parents": ["5e06a02cad6be0dd6c4c79b916076e50e01ae391"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1589706: Add support worker worker-manager pool aliases; r=Callek\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49763", "files": ["taskcluster/taskgraph/config.py", "taskcluster/taskgraph/util/workertypes.py"], "git_node": null, "git_parents": [null], "node": "c3f3c9dd353724c0e16cab127bd04ce3afc59537", "parents": ["71f00b917fb953b82a4c2e85091325fd31338a20"], "tags": []}, {"author": "Andrei Oprea \u003candrei.br92@gmail.com\u003e", "branch": "default", "desc": "Bug 1589678 - CFR Pin tab message text gets cut off r=Mardak\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49760", "files": ["browser/themes/shared/browser.inc.css"], "git_node": null, "git_parents": [null], "node": "b5f7dccff453e27c686b89f4d94852d6ec37d1fa", "parents": ["c3f3c9dd353724c0e16cab127bd04ce3afc59537"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1589561.  Factor out idle handling from PrioritizedEventQueue.  r=smaug\n\nWe could try to move the EnforcePendingTaskGuarantee() bit into PeekIdleDeadline, but\nthen we'd need to check HasReadyEvent() on mDeferredTimersQueue and mIdleQueue\nbefore we unlock the mutex and PeekIdleDeadline, and it's not clear that that\nstate cannot change once the mutex is unlocked...\n\nThe EnsureIsActive() call at the end of GetIdleDeadlineInternal in the !aIsPeek\ncase only makes sense if there are in fact idle tasks available to run when\nGetDeadlineForIdleTask is called, because otherwise it would incorrectly set us\nactive when we are not running any tasks.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49696", "files": ["ipc/glue/IdleSchedulerChild.cpp", "ipc/glue/IdleSchedulerChild.h", "xpcom/threads/IdlePeriodState.cpp", "xpcom/threads/IdlePeriodState.h", "xpcom/threads/PrioritizedEventQueue.cpp", "xpcom/threads/PrioritizedEventQueue.h", "xpcom/threads/moz.build"], "git_node": null, "git_parents": [null], "node": "798bab343a0aa9e7940e5a449e6555096ecdc4ac", "parents": ["b5f7dccff453e27c686b89f4d94852d6ec37d1fa"], "tags": []}, {"author": "Jorg K \u003cjorgk@jorgk.com\u003e", "branch": "default", "desc": "Bug 1587067 - Don't distinguish between 32bit and 64bit install location in IsProfileForCurrentInstall(). r=mossop\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49466", "files": ["toolkit/profile/nsToolkitProfileService.cpp"], "git_node": null, "git_parents": [null], "node": "7c59ec30b84c4f66c50a82613295c60e92a4fb0c", "parents": ["798bab343a0aa9e7940e5a449e6555096ecdc4ac"], "tags": []}, {"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 1583654 - Use the subgridToParentMap to check that the node was previously a subgrid. r=pbro\n\nThe previous condition didn't fully check that the grid node was previously a subgrid.\nSo, we run into a scenario where we refresh the page and a \"display-change\" event is hit\nafter a new root is loaded, and the grid highlighter is restored and hidden because\nthe check will pass as long as the node is a grid container.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49659", "files": ["devtools/client/inspector/shared/highlighters-overlay.js"], "git_node": null, "git_parents": [null], "node": "abfee71f01b0122064a93c0f3c8cf56b887573fd", "parents": ["7c59ec30b84c4f66c50a82613295c60e92a4fb0c"], "tags": []}, {"author": "Kristen Wright \u003ckwright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588650 - Remove duplicate prefs from mobile.js r=njn\n\nRemoves all of the duplicate prefs from mobile.js and StaticPrefList.yaml where the `value` field is the same. Carries over comments from mobile.js where needed.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49357", "files": ["mobile/android/app/mobile.js", "modules/libpref/init/StaticPrefList.yaml", "tools/lint/libpref/__init__.py"], "git_node": null, "git_parents": [null], "node": "28c678b3bf057c25bd24797efdb3960114cedbb8", "parents": ["abfee71f01b0122064a93c0f3c8cf56b887573fd"], "tags": []}, {"author": "Kristen Wright \u003ckwright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588650 - Remove duplicate prefs from firefox.js r=njn\n\nRemoves the three duplicate prefs from firefox.js where the `value` field matches with StaticPrefList.yaml. Imports any additional comments from firefox.js to their accompanying static pref.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49356", "files": ["browser/app/profile/firefox.js", "modules/libpref/init/StaticPrefList.yaml"], "git_node": null, "git_parents": [null], "node": "5812f2d6c02fcb5dce7a722f94546a726b09c547", "parents": ["28c678b3bf057c25bd24797efdb3960114cedbb8"], "tags": []}, {"author": "Tomislav Jovanovic \u003ctomica@gmail.com\u003e", "branch": "default", "desc": "Bug 1589481 - Enable four extensions mochitests with fission+debug r=robwu\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49653", "files": ["toolkit/components/extensions/test/mochitest/mochitest-common.ini"], "git_node": null, "git_parents": [null], "node": "7635e8cad2c017331601d294acce20b1105e9cd4", "parents": ["5812f2d6c02fcb5dce7a722f94546a726b09c547"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset ab0ed4869416 (bug 584141) for mochitest failures on test_selection_doubleclick.html. CLOSED TREE", "files": ["layout/generic/test/mochitest.ini", "layout/generic/test/test_selection_doubleclick.html"], "git_node": null, "git_parents": [null], "node": "256c7cd198a50aaaeeae2889cdbbc5c8eab2789a", "parents": ["7635e8cad2c017331601d294acce20b1105e9cd4"], "tags": []}, {"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 1588728 - Add a check for this._highlightedNodeFront in _hideBoxModel. r=pbro\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49632", "files": ["devtools/client/inspector/markup/markup.js"], "git_node": null, "git_parents": [null], "node": "30190859b9f5abafad52151a7bae926a5d988b4b", "parents": ["256c7cd198a50aaaeeae2889cdbbc5c8eab2789a"], "tags": []}, {"aut