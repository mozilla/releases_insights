g-tidy/test/performance-move-const-arg.cpp", "tools/clang-tidy/test/performance-move-const-arg.json"], "git_node": null, "git_parents": [null], "node": "4ff3f106ce2f0c95f579827a799fb34d2935f658", "parents": ["75773bf8c23c778943f0132d6d1ca83ea16c45ff"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588935 - Improve efficiency of 'mach test-info report'; r=bc\n\nPull calls to mozbuild_reader().files_info() out of loops, instead passing\nall the paths of interest at once.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49358", "files": ["testing/mach_commands.py"], "git_node": null, "git_parents": [null], "node": "67006875213e30bb5d86cb963383664cca6bfdaa", "parents": ["4ff3f106ce2f0c95f579827a799fb34d2935f658"], "tags": []}, {"author": "James Graham \u003cjames@hoppipolla.co.uk\u003e", "branch": "default", "desc": "Bug 1583012 - Ensure removing a node from a manifest removes the underlying tree node, r=dheiberg\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48893", "files": ["testing/web-platform/tests/tools/wptrunner/wptrunner/wptmanifest/backends/conditional.py"], "git_node": null, "git_parents": [null], "node": "2b068107c651de810be99e8afc513150c23de758", "parents": ["67006875213e30bb5d86cb963383664cca6bfdaa"], "tags": []}, {"author": "James Graham \u003cjames@hoppipolla.co.uk\u003e", "branch": "default", "desc": "Bug 1583012 - Remove subsubtest junk when doing a full metadata update, r=dheiberg\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48894", "files": ["testing/web-platform/tests/tools/wptrunner/wptrunner/metadata.py", "testing/web-platform/tests/tools/wptrunner/wptrunner/tests/test_update.py"], "git_node": null, "git_parents": [null], "node": "06b945715ba36d49882f45362533007f49465c76", "parents": ["2b068107c651de810be99e8afc513150c23de758"], "tags": []}, {"author": "Julian Seward \u003cjseward@acm.org\u003e", "branch": "default", "desc": "Bug 1586791 - [Cranelift] BatchCompiler::new called too often?  r=bbouvier.\n\nWhilst trying to track down why Cranelift has high heap turnover (not\nresidency) compared to Ion, I have come to wonder if we are creating and\ndestroying the basic compiler structure, BatchCompiler, too often.\n\nThis patch reduces the overall Cranelift heap overhead by increasing the\nbatching threshold from 1100 wasm stream bytes to 5000.  This is a compromise\nbetween reducing overhead and potential loss of parallelism.  The effect is,\nfor wasm_lua_binarytrees: a 1.3% reduction in instruction count, 26.5% fewer\nblocks allocated and 22.1% fewer bytes allocated.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49156", "files": ["js/src/jit/JitOptions.cpp", "js/src/jit/JitOptions.h", "js/src/wasm/WasmGenerator.cpp"], "git_node": null, "git_parents": [null], "node": "374f3ab2e4616b39268cb1134efe280b588f817f", "parents": ["06b945715ba36d49882f45362533007f49465c76"], "tags": []}, {"author": "Andrew Halberstadt \u003cahalberstadt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1587826 - [ci] Create a separate transform file for 'raptor' transforms r=tomprince\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48978", "files": ["taskcluster/taskgraph/transforms/raptor.py", "taskcluster/taskgraph/transforms/tests.py"], "git_node": null, "git_parents": [null], "node": "a6848e0fe8aa8dd35e878ae0fabbc95c89c584c5", "parents": ["374f3ab2e4616b39268cb1134efe280b588f817f"], "tags": []}, {"author": "Andrew Halberstadt \u003cahalberstadt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1587826 - [ci] Use a transform to split raptor apps r=tomprince,perftest-reviewers,rwood\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48979", "files": ["taskcluster/ci/test/browsertime-fenix.yml", "taskcluster/ci/test/browsertime-gve.yml", "taskcluster/ci/test/browsertime-mobile.yml", "taskcluster/ci/test/browsertime-refbrow.yml", "taskcluster/ci/test