y-objectstores.html", "devtools/client/storage/test/storage-file-url.html", "devtools/client/storage/test/storage-idb-delete-blocked.html", "devtools/client/storage/test/storage-indexeddb-duplicate-names.html", "devtools/client/storage/test/storage-listings-usercontextid.html", "devtools/client/storage/test/storage-listings-with-fragment.html", "devtools/client/storage/test/storage-listings.html", "devtools/client/storage/test/storage-localstorage.html", "devtools/client/storage/test/storage-secured-iframe-usercontextid.html", "devtools/client/storage/test/storage-secured-iframe.html", "devtools/client/storage/test/storage-sessionstorage.html", "devtools/client/storage/test/storage-sidebar-parsetree.html", "devtools/client/storage/test/storage-updates.html"], "git_node": null, "git_parents": [null], "node": "7ac0a413ce8e0bab1d5bd4aff3fe64dca77fa983", "parents": ["41bf040c31a24948261f42e87efde572f0665393"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1508567 - Move call to run_function_deprecated_ to outside of message loop; r=pehrsons\n\nThis moves the call to run_function_deprecated_, which ensures it is called at\nleast once prior to the thread exiting, to outside of the do/while loop. As\nwritten, it is being called every time a message is received, causing desktop\ncapture frame rates on Windows to be higher than expected.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49412", "files": ["dom/media/systemservices/video_engine/platform_uithread.cc"], "git_node": null, "git_parents": [null], "node": "fd81bc5ca14623a917cc213b4ae06cd3eb6d4be5", "parents": ["7ac0a413ce8e0bab1d5bd4aff3fe64dca77fa983"], "tags": []}, {"author": "Edgar Chen \u003cechen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1421539 - Remove todo comment for shadow dom; r=smaug\n\nGiven that test_bug522601-shadow.xhtml already has pretty nice test cases for shadow dom;\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49395", "files": ["layout/inspector/tests/test_bug522601-shadow.xhtml", "layout/inspector/tests/test_bug522601.xhtml"], "git_node": null, "git_parents": [null], "node": "e4e44d970cbcb3b2e4f57dd255d8b309ef5b9c55", "parents": ["fd81bc5ca14623a917cc213b4ae06cd3eb6d4be5"], "tags": []}, {"author": "Dzmitry Malyshau \u003cdmalyshau@mozilla.com\u003e", "branch": "default", "desc": "Bug 1586396 - Formatting fixes in WebGPUThreading\n\nfollow-up to D48229\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49367", "files": ["dom/webgpu/thread/WebGPUThreading.cpp", "dom/webgpu/thread/WebGPUThreading.h"], "git_node": null, "git_parents": [null], "node": "ab675f6a7e263a8dd3003056eb7b1eb681951d3d", "parents": ["e4e44d970cbcb3b2e4f57dd255d8b309ef5b9c55"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1587139 - Improve mozharness search for test failure patterns; r=bc\n\nWhen searching for \"harness errors\" as defined by the regexes at\nhttps://searchfox.org/mozilla-central/rev/5cb522c7baba24e55874809e0e206b001494c1e9/testing/mozharness/mozharness/mozilla/testing/errors.py#112\nuse re.search rather than re.match so that any logging prefixes do not defeat the match.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48598", "files": ["testing/mozharness/mozharness/mozilla/testing/unittest.py"], "git_node": null, "git_parents": [null], "node": "c5f0a88c97f81eb55b14d8bb445c108a468716a2", "parents": ["ab675f6a7e263a8dd3003056eb7b1eb681951d3d"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Bug 1448915 - Disable browser_bug579872.js on mac and linux !debug for frequent failures. r=gbrown\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49403", "files": ["browser/base/content/test/general/browser.ini"], "git_node": null, "git_parents": [null], "node": "a13a70f7bb6e5618724dd3baff03b8166d73d249", "parents": ["c5f0a88c97f81eb55b14d8bb445c108a468716a2"], "tags": []}, {"author": "Nihanth Subramanya \u003cnhnt11@gmail.com\u003e", "branch": "default", "desc": "Bug 1584312 - Implement blocked tracker count milestones UI. r=johannh,flod\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47799", "files": ["browser/base/content/browser-siteProtections.js", "browser/base/content/test/siteProtections/browser.ini", "browser/base/content/test/siteProtections/browser_protections_UI.js", "browser/base/content/test/siteProtections/browser_protections_UI_milestones.js", "browser/base/content/test/siteProtections/head.js", "browser/components/controlcenter/content/protectionsPanel.inc.xul", "browser/locales/en-US/chrome/browser/browser.properties", "browser/themes/shared/controlcenter/etp-milestone.svg", "browser/themes/shared/controlcenter/panel.inc.css", "browser/themes/shared/jar.inc.mn"], "git_node": null, "git_parents": [null], "node": "b649a4a3bb7e1f7ed173fd1f0237c0d896e84432", "parents": ["a13a70f7bb6e5618724dd3baff03b8166d73d249"], "tags": []}, {"author": "Frederic Wang \u003cfred.wang@free.fr\u003e", "branch": "default", "desc": "Bug 1587570 - Remove support for the subscriptshift and superscriptshift attributes. r=emilio\n\nSee https://groups.google.com/forum/#!topic/mozilla.dev.platform/CAqw0Nxw6Pg\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48766", "files": ["dom/base/nsDeprecatedOperationList.h", "dom/locales/en-US/chrome/dom/dom.properties", "layout/mathml/nsMathMLmmultiscriptsFrame.cpp", "layout/mathml/tests/test_bug827713.html", "modules/libpref/init/StaticPrefList.yaml", "testing/web-platform/meta/mathml/__dir__.ini", "testing/web-platform/meta/mathml/presentation-markup/scripts/subsup-legacy-scriptshift-attributes-001.tentative.html.ini"], "git_node": null, "git_parents": [null], "node": "fe2312ad6c4fd03510106cfdbe51480ffcff031d", "parents": ["b649a4a3bb7e1f7ed173fd1f0237c0d896e84432"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 998590 - Cleanup HTMLHeadingElement, and add HTMLHeadingElement::FromNode. r=bzbarsky\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49406", "files": ["dom/base/nsINode.h", "dom/html/HTMLHeadingElement.h"], "git_node": null, "git_parents": [null], "node": "0e06e454c8c8a9286e1416c664dd250704ac81c2", "parents": ["fe2312ad6c4fd03510106cfdbe51480ffcff031d"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 998590 - Factor out heading accessibility level into HTMLHeadingElement. r=MarcoZ\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49407", "files": ["accessible/generic/HyperTextAccessible.cpp", "dom/html/HTMLHeadingElement.h"], "git_node": null, "git_parents": [null], "node": "e46f94e125546017360f0a4c1e2f03632f2156af", "parents": ["0e06e454c8c8a9286e1416c664dd250704ac81c2"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 998590 - Prototype accessibility level changes for headings behind a pref. r=MarcoZ\n\nI don't think these need invalidation of any sort since they only depend on\nancestors, and we recreate accessibles when the element's ancestor chain changes.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49408", "files": ["accessible/tests/mochitest/elm/test_HTMLSpec.html", "dom/html/HTMLHeadingElement.cpp", "dom/html/HTMLHeadingElement.h", "modules/libpref/init/StaticPrefList.yaml"], "git_node": null, "git_parents": [null], "node": "41b4f84dd944ce516573deaea313d8a533fef3e7", "parents": ["e46f94e125546017360f0a4c1e2f03632f2156af"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 1: Change Intl.Collator to use ClassSpec. r=mgaudet\n\n- `JSProto_Collator` has to be added to the end until part 9.\n- `js::CreateCollatorPrototype` was renamed to `js::CreateCollator` because it\n  no longer returns the prototype object. Part 7 will change this again.\n- `CollatorObject::protoClass_` uses `PlainObject::class_`, which works because\n  CollatorObject isn't xrayable.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42870", "files": ["js/public/Class.h", "js/public/ProtoKey.h", "js/src/builtin/intl/Collator.cpp", "js/src/builtin/intl/Collator.h", "js/src/builtin/intl/IntlObject.cpp", "js/src/vm/CommonPropertyNames.h", "js/src/vm/GlobalObject.cpp", "js/src/vm/GlobalObject.h"], "git_node": null, "git_parents": [null], "node": "0e2bd4be3e42ce84a65418fb0af72a61ae1efadd", "parents": ["41b4f84dd944ce516573deaea313d8a533fef3e7"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 2: Change Intl.DateTimeFormat to use ClassSpec. r=mgaudet\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42871", "files": ["js/public/Class.h", "js/public/ProtoKey.h", "js/src/builtin/intl/DateTimeFormat.cpp", "js/src/builtin/intl/DateTimeFormat.h", "js/src/builtin/intl/IntlObject.cpp", "js/src/vm/CommonPropertyNames.h", "js/src/vm/GlobalObject.cpp", "js/src/vm/GlobalObject.h"], "git_node": null, "git_parents": [null], "node": "aebd85991cc4c28c4657e156b718534a0454cea8", "parents": ["0e2bd4be3e42ce84a65418fb0af72a61ae1efadd"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 3: Change Intl.Locale to use ClassSpec. r=mgaudet\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42872", "files": ["js/public/Class.h", "js/public/ProtoKey.h", "js/src/builtin/intl/Locale.cpp", "js/src/builtin/intl/Locale.h", "js/src/jsfriendapi.h", "js/src/vm/CommonPropertyNames.h", "js/src/vm/GlobalObject.cpp", "js/src/vm/GlobalObject.h"], "git_node": null, "git_parents": [null], "node": "89d7388251d19dd0a339b9476def7e1c79287037", "parents": ["aebd85991cc4c28c4657e156b718534a0454cea8"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 4: Change Intl.NumberFormat to use ClassSpec. r=mgaudet\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42873", "files": ["js/public/Class.h", "js/public/ProtoKey.h", "js/src/builtin/intl/IntlObject.cpp", "js/src/builtin/intl/NumberFormat.cpp", "js/src/builtin/intl/NumberFormat.h", "js/src/vm/CommonPropertyNames.h", "js/src/vm/GlobalObject.cpp", "js/src/vm/GlobalObject.h"], "git_node": null, "git_parents": [null], "node": "f464ebe632fd7d28ab0ee09461afe4c114235467", "parents": ["89d7388251d19dd0a339b9476def7e1c79287037"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 5: Change Intl.PluralRules to use ClassSpec. r=mgaudet\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42874", "files": ["js/public/Class.h", "js/public/ProtoKey.h", "js/src/builtin/intl/IntlObject.cpp", "js/src/builtin/intl/PluralRules.cpp", "js/src/builtin/intl/PluralRules.h", "js/src/vm/CommonPropertyNames.h", "js/src/vm/GlobalObject.cpp", "js/src/vm/GlobalObject.h"], "git_node": null, "git_parents": [null], "node": "6d262e7942beae4bfa890cefaedea1b8546a0254", "parents": ["f464ebe632fd7d28ab0ee09461afe4c114235467"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 6: Change Intl.RelativeTimeFormat to use ClassSpec. r=mgaudet\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42875", "files": ["js/public/Class.h", "js/public/ProtoKey.h", "js/src/builtin/intl/IntlObject.cpp", "js/src/builtin/intl/RelativeTimeFormat.cpp", "js/src/builtin/intl/RelativeTimeFormat.h", "js/src/vm/CommonPropertyNames.h", "js/src/vm/GlobalObject.cpp", "js/src/vm/GlobalObject.h"], "git_node": null, "git_parents": [null], "node": "4c8e2c07fa6398e1cc9c332b1b51d47398b522b0", "parents": ["6d262e7942beae4bfa890cefaedea1b8546a0254"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 7: Remove boilerplate to create Intl constructors. r=mgaudet\n\n- Remove the various `js::CreateXYZ` functions be directly iterating over the\n  JSProtoKeys in `js::InitIntlClass`.\n- Also remove the unused `GlobalObject::getOrCreateIntlObject` method and then\n  merge `GlobalObject::initIntlObject` with `js::InitIntlClass`.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42876", "files": ["js/src/builtin/intl/Collator.cpp", "js/src/builtin/intl/Collator.h", "js/src/builtin/intl/DateTimeFormat.cpp", "js/src/builtin/intl/DateTimeFormat.h", "js/src/builtin/intl/IntlObject.cpp", "js/src/builtin/intl/Locale.cpp", "js/src/builtin/intl/Locale.h", "js/src/builtin/intl/NumberFormat.cpp", "js/src/builtin/intl/NumberFormat.h", "js/src/builtin/intl/PluralRules.cpp", "js/src/builtin/intl/PluralRules.h", "js/src/builtin/intl/RelativeTimeFormat.cpp", "js/src/builtin/intl/RelativeTimeFormat.h", "js/src/vm/GlobalObject.h"], "git_node": null, "git_parents": [null], "node": "e3e22cb993b378664bc453a473f805127768e8d4", "parents": ["4c8e2c07fa6398e1cc9c332b1b51d47398b522b0"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 8: Use constexpr instead of #defines in js/Class. r=mgaudet\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42877", "files": ["js/public/Class.h"], "git_node": null, "git_parents": [null], "node": "673dac1119b6428329be9627ff3ad69019d92a70", "parents": ["e3e22cb993b378664bc453a473f805127768e8d4"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 9: Assign an additional bit for CACHED_PROTO_KEY. r=mgaudet\n\nIncrease the CACHED_PROTO_KEY limit from 2\u2076 to 2\u2077 to allow that all current\nJSProto classes can use JSCLASS_HAS_CACHED_PROTO.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42878", "files": ["js/public/Class.h", "js/public/ProtoKey.h"], "git_node": null, "git_parents": [null], "node": "779a0df28f3d747cd8dff57d0baeedcf1a0a2377", "parents": ["673dac1119b6428329be9627ff3ad69019d92a70"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 10: Use cached proto mechanism for Intl classes. r=mgaudet\n\nThis allows to replace `NewObjectWithGivenProto` with `NewObjectWithClassProto`, which\naligns Intl code with the rest of the non-Intl built-ins.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42880", "files": ["js/src/builtin/intl/Collator.cpp", "js/src/builtin/intl/DateTimeFormat.cpp", "js/src/builtin/intl/Locale.cpp", "js/src/builtin/intl/NumberFormat.cpp", "js/src/builtin/intl/PluralRules.cpp", "js/src/builtin/intl/RelativeTimeFormat.cpp"], "git_node": null, "git_parents": [null], "node": "8e5db7a22bc7ec757a31980fbc63b665aa8e7afe", "parents": ["779a0df28f3d747cd8dff57d0baeedcf1a0a2377"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 11: Replace Get{DateTime,Number}FormatConstructor with GetBuiltinConstructor. r=mgaudet\n\nNow that Intl.DateTimeFormat and Intl.NumberFormat both use JSProtoKey, we can\nuse the normal `GetBuiltinConstructor` self-hosting function to retrieve the\nbuilt-in constructor function.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42881", "files": ["js/src/builtin/intl/DateTimeFormat.js", "js/src/builtin/intl/NumberFormat.js", "js/src/vm/SelfHosting.cpp"], "git_node": null, "git_parents": [null], "node": "cf4491c7b279217cf47577b776ed5f207d8ef833", "parents": ["8e5db7a22bc7ec757a31980fbc63b665aa8e7afe"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 12: Remove no longer used getOrCreate functions for Intl object from GlobalObject. r=mgaudet\n\nThese methods are no longer needed after part 10 and part 11.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42882", "files": ["js/src/vm/GlobalObject.h"], "git_node": null, "git_parents": [null], "node": "db8c74ffdbf066065557f5b84443a423f2f6ade7", "parents": ["cf4491c7b279217cf47577b776ed5f207d8ef833"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 13: Add JSProtoKey for AsyncFunction. r=mgaudet\n\nIn a follow-up bug this will be changed to use `ClassSpec`, along with the rest\nof the JSProtoKey classes still using non-ClassSpec initialisation.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42883", "files": ["js/public/Class.h", "js/public/ProtoKey.h", "js/src/jsapi.cpp", "js/src/vm/AsyncFunction.cpp", "js/src/vm/AsyncFunction.h", "js/src/vm/CommonPropertyNames.h", "js/src/vm/GlobalObject.cpp", "js/src/vm/GlobalObject.h", "js/src/vm/HelperThreads.cpp", "js/src/vm/JSFunction.cpp"], "git_node": null, "git_parents": [null], "node": "2b3fe913292a06469799979c912be5109dfda27f", "parents": ["db8c74ffdbf066065557f5b84443a423f2f6ade7"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 14: Add JSProtoKey for GeneratorFunction. r=mgaudet\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42884", "files": ["js/public/Class.h", "js/public/ProtoKey.h", "js/src/jsapi.cpp", "js/src/vm/CommonPropertyNames.h", "js/src/vm/GeneratorObject.cpp", "js/src/vm/GeneratorObject.h", "js/src/vm/GlobalObject.cpp", "js/src/vm/GlobalObject.h", "js/src/vm/HelperThreads.cpp", "js/src/vm/JSFunction.cpp"], "git_node": null, "git_parents": [null], "node": "e6325a3232790e98eaed09565fcab43506623359", "parents": ["2b3fe913292a06469799979c912be5109dfda27f"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 15: Add JSProtoKey for AsyncGeneratorFunction. r=mgaudet\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42885", "files": ["js/public/Class.h", "js/public/ProtoKey.h", "js/src/jsapi.cpp", "js/src/vm/AsyncIteration.cpp", "js/src/vm/AsyncIteration.h", "js/src/vm/CommonPropertyNames.h", "js/src/vm/GlobalObject.cpp", "js/src/vm/GlobalObject.h", "js/src/vm/HelperThreads.cpp", "js/src/vm/JSFunction.cpp"], "git_node": null, "git_parents": [null], "node": "000d2a8cc400889945e93e8aa6c4a78c0e4bbe6c", "parents": ["e6325a3232790e98eaed09565fcab43506623359"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 16: Decouple Async(FromSync)IteratorPrototype initialisation from AsyncGeneneratorFunction. r=mgaudet\n\nAsyncGenerator initialisation isn't required to also always initialise AsyncFromSyncIteratorPrototype,\nso split AsyncFromSyncIteratorPrototype, and its prototype, AsyncFromIteratorPrototype, from the async\ngenerator initialisation.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42886", "files": ["js/src/vm/AsyncIteration.cpp", "js/src/vm/GlobalObject.h"], "git_node": null, "git_parents": [null], "node": "fb1e8f3ad7cc0c4c2e81294228fdb5206b1e2361", "parents": ["000d2a8cc400889945e93e8aa6c4a78c0e4bbe6c"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 17: Remove unnecessary NativeObject downcasts in GlobalObject methods. r=mgaudet\n\nMany `GlobalObject::getOrCreateXYZ()` methods explicitly perform casts to `NativeObject*`\neven though the callers directly assign to `JSObject*`. So remove all explicit casts to\n`NativeObject` which aren't needed in any callers to reduce unnecessary code and to make\nthe code a bit leaner.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42887", "files": ["js/src/vm/GlobalObject.h", "js/src/vm/Interpreter.cpp", "js/src/vm/SavedStacks.cpp"], "git_node": null, "git_parents": [null], "node": "819e1f01708f5fcba61e57c6811e852541f21f67", "parents": ["fb1e8f3ad7cc0c4c2e81294228fdb5206b1e2361"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 18: Remove unnecessary JSFunction downcasts in GlobalObject methods. r=mgaudet\n\nSimilar to part 17, we can also remove unused casts to `JSFunction*`.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42888", "files": ["js/src/builtin/Promise.cpp", "js/src/vm/GlobalObject.h", "js/src/vm/TypedArrayObject.cpp"], "git_node": null, "git_parents": [null], "node": "0d841449ae0bdf6544d9ccc62d1473e8226ca015", "parents": ["819e1f01708f5fcba61e57c6811e852541f21f67"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 19: Add test case. r=mgaudet\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42889", "files": ["js/src/tests/non262/Proxy/revoked-get-function-realm-typeerror.js"], "git_node": null, "git_parents": [null], "node": "1501701f252e26578df9bfa37ffb22d7a5f5e825", "parents": ["0d841449ae0bdf6544d9ccc62d1473e8226ca015"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588551 - Fix Vector::erase documentation comment r=jwalden\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49321", "files": ["mfbt/Vector.h"], "git_node": null, "git_parents": [null], "node": "916eaf6f094e1ad86b28cd17b1cec49dcfa4b7ca", "parents": ["1501701f252e26578df9bfa37ffb22d7a5f5e825"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1572695 - Select the newly 