h": "default", "desc": "Bug 1590461 - Add browser.urlbar.search() to the webextensions API r=mak,mixedpuppy a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52127", "files": ["browser/components/extensions/parent/ext-urlbar.js", "browser/components/extensions/schemas/urlbar.json", "browser/components/extensions/test/browser/browser_ext_urlbar.js"], "git_node": null, "git_parents": [null], "node": "59d3f5ffaf6a3e73c97b04bcf8eda7d239b528d4", "parents": ["f0bc4fd31372562e78047cd364b8fd6aa37ed4df"], "tags": []}, {"author": "Alexander Surkov \u003csurkov.alexander@gmail.com\u003e", "branch": "default", "desc": "Bug 1576363 - Unset active styling for the default dialog button when another button inside the dialog gets focused r=bgrins a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49952", "files": ["toolkit/content/widgets/dialog.js"], "git_node": null, "git_parents": [null], "node": "6ef29e4dcdf567ea90ebb1f6d3f636a42d7ba448", "parents": ["59d3f5ffaf6a3e73c97b04bcf8eda7d239b528d4"], "tags": []}, {"author": "Paul Zuehlcke \u003cpzuhlcke@mozilla.com\u003e", "branch": "default", "desc": "Bug 1571003 - Added pref to disable warning prompts for SuperfluousAuth and AutomaticAuth. r=Gijs a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D51989", "files": ["modules/libpref/init/StaticPrefList.yaml", "netwerk/protocol/http/nsHttpChannelAuthProvider.cpp"], "git_node": null, "git_parents": [null], "node": "47e8d50748c4b2b5e69145bf3ebdd6c6bd921ff6", "parents": ["6ef29e4dcdf567ea90ebb1f6d3f636a42d7ba448"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1591947 - Fix style changes from list-style-image to -moz-appearance for XUL images. r=TYLin a=pascalc\n\nConsider the following case:\n\n  \u003cimage style=\"list-style-image: url(foo.png)\"\u003e\u003c/image\u003e\n\n  image.style.MozAppearance = \"something\"\n\nThe early return was preventing us from clearing the image.\n\nThis is an ancient bug, but it has started happening in the browser chrome\nbecause the lack of lazy frame construction for XUL elements makes us construct\nelements with an outdated style, which means in this case that they wouldn't\nhave the -moz-appearance rule applied yet.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52112", "files": ["layout/reftests/xul/image-appearance-dynamic-ref.xul", "layout/reftests/xul/image-appearance-dynamic.xul", "layout/reftests/xul/reftest.list", "layout/xul/nsImageBoxFrame.cpp", "layout/xul/nsImageBoxFrame.h"], "git_node": null, "git_parents": [null], "node": "6f67f28b1f0928c31c6366db2f82f11a6f718bae", "parents": ["47e8d50748c4b2b5e69145bf3ebdd6c6bd921ff6"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1590997 - Update tests for new MediaRecorder mimetype-at-start-event behavior. r=jib a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52255", "files": ["dom/media/test/test_mediarecorder_onerror_pause.html", "dom/media/test/test_mediarecorder_record_audionode.html", "dom/media/test/test_mediarecorder_record_gum_video_timeslice.html", "testing/web-platform/tests/mediacapture-record/MediaRecorder-mimetype.html"], "git_node": null, "git_parents": [null], "node": "bc3e7578b5d4a3752cb22a8dafb5567a3f38f8a3", "parents": ["6f67f28b1f0928c31c6366db2f82f11a6f718bae"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1590997 - Defer setting MediaRecorder mimeType attribute until firing start event. r=jib a=pascalc\n\nDepends on D52255\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52256", "files": ["dom/media/MediaRecorder.cpp"], "git_node": null, "git_parents": [null], "node": "b0f372da1c94d7df10d57e60558e1478d5c6ad48", "parents": ["bc3e7578b5d4a3752cb22a8dafb5567a3f38f8a3"], "tags": []}, {"author": "Gi