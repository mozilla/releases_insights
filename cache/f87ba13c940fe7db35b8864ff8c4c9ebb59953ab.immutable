455de49e\nzh-TW -\u003e 53e1b207e308", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "515eee7ede88511c6b0526d6a81b71943188546e", "parents": ["349826f6cee70f978cefac38e10d1a56b132e7a5"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\neo -\u003e 19863f076557\nfr -\u003e 046e3d5ba03f\nhe -\u003e bf57d19e1a8e\nia -\u003e 029e5223ddfc\nko -\u003e 7e491bd663c4\nmr -\u003e 4973455de49e\nzh-TW -\u003e 53e1b207e308", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "809a33dbff6cf469f67a554e1132fda6c7005d4b", "parents": ["515eee7ede88511c6b0526d6a81b71943188546e"], "tags": []}], "date": 1573135247, "git_changesets": [null, null], "user": "ffxbld"}, "12272": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP blocklist remote-settings - a=repo-update r=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52153", "files": ["browser/app/blocklist.xml", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/blocklists/addons.json"], "git_node": null, "git_parents": [null], "node": "899098b8c9fff3f4f7c166868d28eb61c9acd08f", "parents": ["809a33dbff6cf469f67a554e1132fda6c7005d4b"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1584040 - Allow assertions in outline-in-frameset.xhtml crashtest; r=dbaron, a=test-only\n\nAccept assertions to avoid intermittent test failures due to assertion count mismatches.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50660", "files": ["layout/generic/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "bad910a6e11dd3a8de56c4e9b872f943734bcb00", "parents": ["899098b8c9fff3f4f7c166868d28eb61c9acd08f"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1584397 - Make http2 proxy code execute in a separate process. r=mayhemer, a=test-only\n\n* Adds a new moz-http2-child.js file which gets spawned into a new process. When calling NodeServer.execute, the code gets passed to the existing moz-http2.js process which then sends it to be evaluated in the child process. Any crash in the child should not be able to kill the main node process.\n* Moves the proxy creation code into test_http2-proxy.js\n* Adds the new NodeServer.fork() and NodeServer.kill() static methods to spawn a new server\n* Makes it easier to isolate a test's behaviour from another's. It also opens the way to moving some of the logic to individual unit tests, like we do for the proxy creation code, rather than keeping it all in moz-http2.js\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49961", "files": ["netwerk/test/httpserver/httpd.js", "netwerk/test/unit/test_http2-proxy.js", "netwerk/test/unit/test_node_execute.js", "netwerk/test/unit/test_trr.js", "testing/xpcshell/moz-http2/moz-http2-child.js", "testing/xpcshell/moz-http2/moz-http2.js"], "git_node": null, "git_parents": [null], "node": "5712c4e9b5f825c1901ae499af78437a75703df2", "parents": ["bad910a6e11dd3a8de56c4e9b872f943734bcb00"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1584743 - Use data URL for services.settings.server in test_http2-proxy.js. r=mayhemer, a=test-only\n\nUsing a data URL makes the request not use the proxy and so it will not mess up the session count\n\nDifferential Revision: https://phabricator.services.mozilla.com/D51843", "files": ["netwerk/test/unit/test_http2-proxy.js"], "git_node": null, "git_parents": [null], "node": "33a63373f6478eabc67ddde9fc55eff5cd4c055f", "parents": ["5712c4e9b5f825c1901ae499af78437a75703df2"], "tags": []}, {"author": "Dana Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "bug 1544244 - disable test_toolkit_securityreporter.js because TLS error reports are disabled by default and it intermittently fails. r=kjacobs, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D51954", "files": ["security/manager/ssl/tests/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "3672dfac6087655e31a6922f6656e03c707e4db9", "parents": ["33a63373f6478eabc67ddde9fc55eff5cd4c055f"], "tags": []}], "date": 1573141945, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "12273": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nbe -\u003e f805a84fd483\nes-AR -\u003e 4e30292f866f\nfi -\u003e 28cd2dd573eb\nhe -\u003e 1c195ce37c50\nko -\u003e 100bbad93350\nnl -\u003e 3246e6d44166\npt-BR -\u003e 226b3056c3c2\nzh-TW -\u003e 6a85c9348c2a", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "c1ef6099c37d87e5969405d0446cd536926b2c9d", "parents": ["3672dfac6087655e31a6922f6656e03c707e4db9"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nbe -\u003e f805a84fd483\nca-valencia -\u003e 1ac2f504cbc9\nes-AR -\u003e 4e30292f866f\nfi -\u003e 28cd2dd573eb\nhe -\u003e 1c195ce37c50\nia -\u003e d93fc1a817bd\nko -\u003e 100bbad93350\nnl -\u003e 3246e6d44166\npt-BR -\u003e 226b3056c3c2\nzh-TW -\u003e 6a85c9348c2a", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "79fb5c9e665061fddaf369065f08b38aa476c523", "parents": ["c1ef6099c37d87e5969405d0446cd536926b2c9d"], "tags": []}], "date": 1573156843, "git_changesets": [null, 