-searchbar.inc.css"], "git_node": null, "git_parents": [null], "node": "014c61389f0bd8982f45be269a761fb0d027a6d2", "parents": ["530ff0c5938780c0e3a0e62a9d1d5716f2e61f7a"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1586991 part 24 - Don't assume JS atoms are null-terminated in GetArrayIndexFromId. r=bzbarsky\n\nThis also adds a GetLinearStringCharAt helper function to simplify GetArrayIndexFromId.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49723", "files": ["dom/bindings/DOMJSProxyHandler.h", "js/src/jsfriendapi.h"], "git_node": null, "git_parents": [null], "node": "ed4954f05de48a2516dce64a7d0d0a3fcf3b6f9a", "parents": ["014c61389f0bd8982f45be269a761fb0d027a6d2"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1586991 part 25 - Remove PropertyNameToExtraName. r=anba\n\nThis function assumed property names are null-terminated. It's also wrong\nin other ways: it let the string chars escape the AutoCheckCannotGC scope.\n\nThe easiest fix is to remove this unsound debugging function for now.\nThere are a lot of (other) extraName overrides so fixing this isn't\ntrivial.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49749", "files": ["js/src/jit/IonTypes.h", "js/src/jit/shared/LIR-shared.h"], "git_node": null, "git_parents": [null], "node": "cb2ad113fb320af6a76bf756a7fbe77c146377e0", "parents": ["ed4954f05de48a2516dce64a7d0d0a3fcf3b6f9a"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1586991 part 26 - Don't assume null-terminated strings in Middleman_HadRepaint. r=bhackett\n\nDepends on D49749\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49750", "files": ["toolkit/recordreplay/ipc/JSControl.cpp"], "git_node": null, "git_parents": [null], "node": "a6e168c78b26cdf69e7a151948c277b4c9d8fea9", "parents": ["cb2ad113fb320af6a76bf756a7fbe77c146377e0"], "tags": []}, {"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1589352 - Always display preference values in the left-to-right direction. r=Itiel\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49828", "files": ["browser/components/aboutconfig/content/aboutconfig.css"], "git_node": null, "git_parents": [null], "node": "938bf161bec586cc461d32e813f05182e43abe31", "parents": ["a6e168c78b26cdf69e7a151948c277b4c9d8fea9"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1588737 - Hide -moz-touch-enabled media query in Nightly and Early Beta. r=xidorn\n\nThis is effectively superseded by the hover / any-hover media queries, which\nactually are standard, and is also causing trouble in the wild.\n\nNot even the browser fronted uses it, so we should be able to just remove it\neverywhere at once.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49506", "files": ["layout/style/test/chrome/bug418986-2.js", "layout/style/test/chrome/test_chrome_only_media_queries.html", "layout/style/test/test_media_queries.html", "modules/libpref/init/StaticPrefList.yaml", "servo/components/style/gecko/media_features.rs", "servo/components/style/media_queries/media_feature.rs", "servo/components/style/media_queries/media_feature_expression.rs"], "git_node": null, "git_parents": [null], "node": "673c2d3025c58a5307d3ecf2da7d500dbe2b16b2", "parents": ["938bf161bec586cc461d32e813f05182e43abe31"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1588737 - Remove layout.css.prefixes.device-pixel-ratio-webkit. r=dholbert\n\nThere's no effort to disable it any time soon, so I don't think it's useful to\nkeep the pref around.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49507", "files": ["modules/libpref/init/StaticPrefList.yaml", "serv