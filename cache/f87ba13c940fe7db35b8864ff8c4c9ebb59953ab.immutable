ys_preserved.xul", "js/xpconnect/tests/chrome/test_weakmap_keys_preserved2.xhtml", "js/xpconnect/tests/chrome/test_weakmap_keys_preserved2.xul", "js/xpconnect/tests/chrome/test_weakref.xhtml", "js/xpconnect/tests/chrome/test_weakref.xul", "js/xpconnect/tests/chrome/test_wrappers.xhtml", "js/xpconnect/tests/chrome/test_wrappers.xul", "js/xpconnect/tests/chrome/test_xrayToJS.xhtml", "js/xpconnect/tests/chrome/test_xrayToJS.xul", "js/xpconnect/tests/chrome/test_xrayic.xhtml", "js/xpconnect/tests/chrome/test_xrayic.xul"], "git_node": null, "git_parents": [null], "node": "523a65f865b0d57464f3b534a20377f33d7871f3", "parents": ["078a8b5628639322e0d0353435318072c9a64eb4"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588967 - Allow up to 1 assertion in android crashtest encrypted-track-with-sample-missing-cenc-aux.mp4; r=bryce\n\nAvoid intermittent crashtest failures by accepting assertion.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49655", "files": ["dom/media/test/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "4f9c5948b03415734dcded1dfb029482379dfdf0", "parents": ["523a65f865b0d57464f3b534a20377f33d7871f3"], "tags": []}, {"author": "Andrew Erickson \u003caerickson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1573269: make g-w tasks support retry-exit-status r=tomprince\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49220", "files": ["taskcluster/taskgraph/transforms/job/mozharness_test.py", "taskcluster/taskgraph/transforms/task.py"], "git_node": null, "git_parents": [null], "node": "5cef7916b0942202578803f86ffb6e3d7dbdb696", "parents": ["4f9c5948b03415734dcded1dfb029482379dfdf0"], "tags": []}, {"author": "Michal Novotny \u003cmichal.novotny@gmail.com\u003e", "branch": "default", "desc": "Bug 1579507 - Fix non-working FTP telemetry probes, r=valentin\n\nWe don't close the channel cleanly most of the time, so the probes need to be moved to a place where we have positive response from the server and the data transfer is about to start.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49657", "files": ["netwerk/protocol/ftp/nsFtpConnectionThread.cpp"], "git_node": null, "git_parents": [null], "node": "650273d192077a93007e509e7d7ec6690d84ee87", "parents": ["5cef7916b0942202578803f86ffb6e3d7dbdb696"], "tags": []}, {"author": "Alexander Surkov \u003csurkov.alexander@gmail.com\u003e", "branch": "default", "desc": "Bug 1583531 - add in-bookmarks-menu class for arrowscrollboxes to adjust padding in bookmarks submenus r=bgrins\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49633", "files": ["browser/components/places/content/places-menupopup.js", "toolkit/content/widgets/menupopup.js", "toolkit/themes/windows/global/scrollbox.css"], "git_node": null, "git_parents": [null], "node": "1f285b3386fa01b242fc3c9947ac50876973652b", "parents": ["650273d192077a93007e509e7d7ec6690d84ee87"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1587850 - Expand expected assertions range for test_bug437844.xul; r=aosmond\n\nAllow fewer assertions to avoid intermittent test failures.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49664", "files": ["toolkit/content/tests/chrome/test_bug437844.xul"], "git_node": null, "git_parents": [null], "node": "28e214b713438e55208b8f78ca32ea5a21630c4f", "parents": ["1f285b3386fa01b242fc3c9947ac50876973652b"], "tags": []}, {"author": "Tomislav Jovanovic \u003ctomica@gmail.com\u003e", "branch": "default", "desc": "Bug 1589508 - Fix three xpinstall/browser_enabled* tests r=mixedpuppy\n\n[browser_enabled.js]\n[browser_enabled2.js]\n[browser_enabled3.js]\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49663", "files": ["toolkit/mozapps/extensions/test/xpinstall/browser.ini", "toolkit/mozapps/extensions/test/xpinstall/browser_enabled.js", "toolkit/mozapps/extensions/test/xpinstall/browser_enabled2.js", "toolkit/mozapps/extensions/test/xpinstall/browser_enabled3.js"], "git_node": null, "git_parents": [null], "node": "1640f69214512e6ac64b84421d6cac1069639324", "parents": ["28e214b713438e55208b8f78ca32ea5a21630c4f"], "tags": []}, {"author": "Itiel \u003citiel_yn8@walla.com\u003e", "branch": "default", "desc": "Bug 1589129 - Fix about:preferences dialogboxes' close icon margin and focusring r=jaws\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49451", "files": ["browser/themes/shared/incontentprefs/preferences.inc.css"], "git_node": null, "git_parents": [null], "node": "cf90081fc72285e00ea5b71efc7c5d13c34633b3", "parents": ["1640f69214512e6ac64b84421d6cac1069639324"], "tags": []}, {"author": "Bryce Seager van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1587543 - Bump OpenH264 fallback downloader to 1.8.1.1. r=Callek\n\nThis change will cause Firefox to re-download the OpenH264 GMP if it already has\nthe 1.8.1 version. This is being done to mitigate and issue where clients that\nalready downloaded that version on previous versions of Firefox did not clear\nthe mac quarantine attribute that prevents the lib being loaded in MacOS\nCatalina.\n\nNewer versions of Firefox will clear the attribute on download, so we want to\ntrigger a re-download by those clients. We would typically expect this to be\ndone by balrog, but we update these fallback rules to cover the edge case where\nbalrog is not available and in order to keep these rules in step with those on\nbalrog.\n\nThe binaries pointed to by this 1.8.1.1 version are the same as the 1.8.1\nversion. This change is solely to trigger a re-download.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49197", "files": ["toolkit/content/gmp-sources/openh264.json"], "git_node": null, "git_parents": [null], "node": "18add174861ca9e30a174526583ef2a15164e139", "parents": ["cf90081fc72285e00ea5b71efc7c5d13c34633b3"], "tags": []}, {"author": "David Walsh \u003cdwalsh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1589272 - Enforce minimum width for debugger's sidebar panels r=jlast\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49522", "files": ["devtools/client/debugger/src/components/App.css", "devtools/client/debugger/src/components/SecondaryPanes/index.js"], "git_node": null, "git_parents": [null], "node": "d1bc0ae0ad2a9b61e39cdeacaf598cf2709bdc3d", "parents": ["18add174861ca9e30a174526583ef2a15164e139"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1582592.  Improve the default return type for example codegen's GetParentObject.  r=edgar\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49467", "files": ["dom/bindings/Codegen.py"], "git_node": null, "git_parents": [null], "node": "ba6ba8d578c9774ad9138725a326eb4e51cfb1f0", "parents": ["d1bc0ae0ad2a9b61e39cdeacaf598cf2709bdc3d"], "tags": []}, {"author": "Boris Chiou \u003cboris.chiou@gmail.com\u003e", "branch": "default", "desc": "Bug 1588792 - Enable the pref of individual transforms for will-change wpt in vendor-imports. r=hiro\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49334", "files": ["testing/web-platform/meta/css/vendor-imports/mozilla/mozilla-central-reftests/will-change/__dir__.ini"], "git_node": null, "git_parents": [null], "node": "9ca90d25365c88f4afdba98a9feb8160465b12b6", "parents": ["ba6ba8d578c9774ad9138725a326eb4e51cfb1f0"], "tags": []}, {"author": "Andrew Sutherland \u003casutherland@asutherland.org\u003e", "branch": "default", "desc": "Bug 1587794 - Do not assume global exists. r=perry\n\nThis is effectively a reversion of the change made in\nhttps://hg.mozilla.org/mozilla-central/rev/89c938649297#l1.39 when\nDOMMozPromiseRequestHolder was introduced.  I've tried to add some\ncomments to contextualize what's happening there and why it differs\nfrom other similar callsites.\n\nLonger term we might move to just deleting the underlying actor when\nwe are disconnected.  Those actors were written assuming an\nexecution model where letting either end delete the actor would result\nin intentional process crashes when a message was received for a\ndestroyed actor.  That is no longer the case.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49671", "files": ["dom/serviceworkers/ServiceWorkerRegistration.cpp"], "git_node": null, "git_parents": [null], "node": "1ab263e4b763cfd7ffcbfe58ecd7d4f0bf6cd0a5", "parents": ["9ca90d25365c88f4afdba98a9feb8160465b12b6"], "tags": []}, {"author": "Andrew Sutherland \u003casutherland@asutherland.org\u003e", "branch": "default", "desc": "Bug 1587794 - Add a test that verifies we don't crash on a disconnected global. r=perry\n\nBecause this seems fairly Gecko-specific, I've put this in our mozilla-specific\nWPT dir.  This is as opposed to writing this as a mochitest.\n\nIf I run this test without the fix, the browser crashes.  If I run it with the fix, we\npass.\n\nI run the test via\n./mach wpt testing/web-platform/mozilla/tests/service-workers/update_completes_in_disconnected_global.https.html\n\nNote that currently because of https://bugzilla.mozilla.org/show_bug.cgi?id=1587463#c13\nI had to comment out the lsan_dir lines I refer to there locally to get the\ntest to run.\n\nDepends on D49671\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49672", "files": ["testing/web-platform/mozilla/tests/service-workers/resources/blank.html", "testing/web-platform/mozilla/tests/service-workers/resources/empty.js", "testing/web-platform/mozilla/tests/service-workers/update_completes_in_disconnected_global.https.html"], "git_node": null, "git_parents": [null], "node": "9ed7fe36e723e573fec9f7360c53a3a83bab7518", "parents": ["1ab263e4b763cfd7ffcbfe58ecd7d4f0bf6cd0a5"], "tags": []}, {"author": "Jim Porter \u003cjporter@mozilla.com\u003e", "branch": "default", "desc": "Bug 1557447 - Profiler support for IPC information; r=nika\n\nThis adds the ability to add profile markers for both the sender and recipient\nsides of IPC messages. These can then be correlated with one another in the\nprofile visualization. For the UI component of this patch, see\n\u003chttps://github.com/firefox-devtools/profiler/pull/2172\u003e.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42226", "files": ["browser/base/content/test/performance/browser_startup_syncIPC.js", "browser/base/content/test/performance/io/browser.ini", "devtools/client/performance-new/components/Settings.js", "dom/media/mediasink/moz.build", "dom/performance/moz.build", "ipc/glue/MessageChannel.cpp", "ipc/glue/MessageChannel.h", "ipc/glue/ProtocolUtils.h", "ipc/ipdl/ipdl/lower.py", "js/public/ProfilingCategory.h", "toolkit/components/extensions/schemas/geckoProfiler.json", "tools/profiler/core/ProfilerMarkerPayload.cpp", "tools/profiler/public/GeckoProfiler.h", "tools/profiler/public/ProfilerMarkerPayload.h", "tools/profiler/tests/browser/browser.ini", "tools/profiler/tests/browser/browser_test_feature_ipcmessages.js", "tools/profiler/tests/gtest/moz.build"], "git_node": null, "git_parents": [null], "node": "cd4dc0ae3364a2216df8ba7598d8cddcaf4944b1", "parents": ["9ed7fe36e723e573fec9f7360c53a3a83bab7518"], "tags": []}, {"author": "Jim Porter \u003cjporter@mozilla.com\u003e", "branch": "default", "desc": "Bug 1557447 part 2 - Remove unnecessary declarations from bug 1575448; r=gerald\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46389", "files": ["tools/profiler/core/ProfilerMarkerPayload.cpp"], "git_node": null, "git_parents": [null], "node": "debb6f82c687e67f5493ce1db5fcf7b12888d0b8", "parents": ["cd4dc0ae3364a2216df8ba7598d8cddcaf4944b1"], "tags": []}, {"author": "Ian Neal \u003ciann_cvs@blueyonder.co.uk\u003e", "branch": "default", "desc": "Bug 1584809 - PageInfo cookie permissions default to allow r=johannh\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47846", "files": ["browser/base/content/pageinfo/permissions.js"], "git_node": null, "git_parents": [null], "node": "94015d1f76fc5552de98109df70b5f028daf2eab", "parents": ["debb6f82c687e67f5493ce1db5fcf7b12888d0b8"], "tags": []}, {"author": "Chris Muldoon \u003cchris.muldoon90@gmail.com\u003e", "branch": "default", "desc": "Bug 1577673 - Continue to Here does not pause. r=davidwalsh\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48178", "files": ["devtools/client/debugger/packages/devtools-reps/src/object-inspector/utils/node.js", "devtools/client/debugger/src/actions/pause/continueToHere.js", "devtools/client/debugger/src/components/Editor/menus/editor.js", "devtools/client/debugger/src/reducers/sources.js", "devtools/client/debugger/src/selectors/breakpointAtLocation.js", "devtools/client/debugger/src/selectors/index.js", "devtools/client/debugger/test/mochitest/browser.ini", "devtools/client/debugger/test/mochitest/browser_dbg-continue-to-here.js", "devtools/client/debugger/test/mochitest/examples/doc-pause-points.html", "devtools/client/debugger/test/mochitest/helpers.js"], "git_node": null, "git_parents": [null], "node": "bdbe51ab36a1b9fd0b25f80c17e8c7eb89ffe3db", "parents": ["94015d1f76fc5552de98109df70b5f028daf2eab"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1543575 - stop using frame scripts across accessible/ browser chrome tests. r=Jamie\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47386", "files": ["accessible/tests/browser/Common.jsm", "accessible/tests/browser/Layout.jsm", "accessible/tests/browser/bounds/browser.ini", "accessible/tests/browser/bounds/browser_test_resolution.js", "accessible/tests/browser/bounds/browser_test_zoom.js", "accessible/tests/browser/bounds/browser_test_zoom_text.js", "accessible/tests/browser/browser.ini", "accessible/tests/browser/browser_shutdown_parent_own_reference.js", "accessible/tests/browser/bro