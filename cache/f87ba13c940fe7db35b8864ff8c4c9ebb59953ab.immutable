: [], "git_node": null, "git_parents": [null, null], "node": "4e1f8ca63a68bd178bc4041ce55dcc18e8a887f0", "parents": ["7b19086f802cc163da1478fcfe9cf35133d95ca7", "d6f9955216483619f8aa7c0be3419dc5c49df369"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1413750 - Handle shift by 32 bits. r=gerald\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49226", "files": ["dom/media/BitReader.cpp"], "git_node": null, "git_parents": [null], "node": "e620adbcbb8e04e77c40973cc30021b4f6d6ff85", "parents": ["213b74bb0fa9d04dc84c36e834170dfde67f3d1f"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1577381: Correct accessibility exposure for optgroups in content select dropdowns. r=eeejay,NeilDeakin\n\nFor remote content documents, select dropdowns (for \u003cselect size=\"1\"\u003e) are rendered in the parent process using a XUL menupopup.\nThis means that the accessibility code for HTML selects doesn't apply.\n\nIn the menupopup, the optgroup is a sibling of its contained options.\nFor accessibility, we want to preserve the hierarchy such that the options are inside the optgroup.\nWe do this using aria-owns on the optgroup item.\n\nThis required some tweaks to XULMenuitemAccessible, as it couldn't previously handle grouping Accessibles between the menupopup and its items.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D43901", "files": ["accessible/tests/browser/e10s/browser.ini", "accessible/tests/browser/e10s/browser_contentSelectDropdown.js", "accessible/xul/XULMenuAccessible.cpp", "toolkit/actors/SelectParent.jsm"], "git_node": null, "git_parents": [null], "node": "b1afc99c9bfb722ef9b12ba1eb2a92268e694e16", "parents": ["e620adbcbb8e04e77c40973cc30021b4f6d6ff85"], "tags": []}, {"author": "Brad Werth \u003cbwerth@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588167: Make UrlbarView._getFirstSelectableElement handle having no children at time of call. r=adw\n\nThis avoids a JS error when the tab has been removed before this function\nhas a chance to run.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48993", "files": ["browser/components/urlbar/UrlbarView.jsm"], "git_node": null, "git_parents": [null], "node": "14c2d187479c756770a918e58ef313c8737414e4", "parents": ["b1afc99c9bfb722ef9b12ba1eb2a92268e694e16"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1587839 - Pass the sourceId to sourcemap service subscribe callback. r=loganfsmyth.\n\nThe sourceId is then used in the various places where we call the sourcemap service.\nA test is added in the console to make sure that we do navigate to the mapped\nlocation in the debugger.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49103", "files": ["devtools/client/framework/source-map-url-service.js", "devtools/client/framework/test/browser_source_map-pub-sub.js", "devtools/client/inspector/computed/computed.js", "devtools/client/inspector/rules/models/rule.js", "devtools/client/inspector/rules/views/rule-editor.js", "devtools/client/shared/components/Frame.js", "devtools/client/shared/components/SmartTrace.js", "devtools/client/shared/widgets/tooltip/EventTooltipHelper.js", "devtools/client/webconsole/test/browser/browser.ini", "devtools/client/webconsole/test/browser/browser_webconsole_stacktrace_mapped_location_debugger_link.js", "devtools/client/webconsole/test/browser/test-console-stacktrace-mapped.html", "devtools/client/webconsole/test/browser/test-sourcemap-original.js", "devtools/client/webconsole/test/browser/test-sourcemap.min.js", "devtools/client/webconsole/test/browser/test-sourcemap.min.js.map"], "git_node": null, "git_parents": [null], "node": "76a5311b64454719a48d71e9dee0669af33de08a", "parents": ["14c2d187479c756770a918e58ef313c8737414e4"], "tags": []}, {"author": "arthur.iakab \u003caiakab@mozilla.com\u003e",