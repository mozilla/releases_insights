ts": ["dcedbb1d3fd9d1b85e90c359d569daca6bc5beb7"], "tags": []}, {"author": "Daniel Varga \u003cdvarga@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland - fix wpt failures. On a CLOSED TREE", "files": [], "git_node": null, "git_parents": [null, null], "node": "5392bdcd9d7d66bddc8b0ce43ab084e64a5c49d5", "parents": ["3b0c05f4e7c786618a8ba7b138dfedc73e27a4b0", "8aa8bbbf0bee82ac6dfeac05da5ee15a1e497d07"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1588743 - Update property database.\n\nMANUAL PUSH: Left this hanging around due to phlay's confirmation dialog.\n\nCLOSED TREE\n", "files": ["devtools/shared/css/generated/properties-db.js"], "git_node": null, "git_parents": [null], "node": "f757f271b3ee5b188e88aa573d9a47f0d9215141", "parents": ["5392bdcd9d7d66bddc8b0ce43ab084e64a5c49d5"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1583967 - Fix pointer overflow errors in webrtc signal processing; r=ng\n\nThese have already been fixed upstream. The upstream comment was: \"Negative\noverflow is permitted here, because this is auto-regressive filters, and the\nstate for each batch run is stored in the \"negative\" positions of the output\nvector.\"\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48884", "files": ["media/webrtc/trunk/webrtc/common_audio/signal_processing/downsample_fast.c", "media/webrtc/trunk/webrtc/common_audio/signal_processing/filter_ar_fast_q12.c", "media/webrtc/trunk/webrtc/common_audio/signal_processing/filter_ma_fast_q12.c"], "git_node": null, "git_parents": [null], "node": "1b3998d69371a2f9428f45551988580b5e00d348", "parents": ["f757f271b3ee5b188e88aa573d9a47f0d9215141"], "tags": []}, {"author": "David Teller \u003cdteller@mozilla.com\u003e", "branch": "default", "desc": "Bug 1587738 - Adding a fastpath for the most common prefixes of a `MultiLookupHuffmanTable`;r=arai\n\nBy definition of Huffman encoding, the shortest keys are reserved for the most common values.\nThis patch changes how we store these shortest keys in a `MultiLookupHuffmanTable` to\nimprove lookup speed: instead of storing short keys in a subtable by extending them,\nwe store them in a `SingleLookupHuffmanTable`.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48968", "files": ["js/src/frontend/BinASTTokenReaderContext.cpp", "js/src/frontend/BinASTTokenReaderContext.h"], "git_node": null, "git_parents": [null], "node": "ded00ff914290d88c44696d0582ab57f0af94531", "parents": ["1b3998d69371a2f9428f45551988580b5e00d348"], "tags": []}, {"author": "David Teller \u003cdteller@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588051 - Tests with many strings;r=arai\n\nDepends on D48968\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49115", "files": ["js/src/jsapi-tests/binast/parser/context/unit/large_array_of_random_strings.binjs", "js/src/jsapi-tests/binast/parser/context/unit/large_array_of_random_strings.js", "js/src/jsapi-tests/binast/parser/context/unit/large_array_of_strings.binjs", "js/src/jsapi-tests/binast/parser/context/unit/large_array_of_strings.js"], "git_node": null, "git_parents": [null], "node": "0c632655907932ee1559cd09aa2b264c461e2b3b", "parents": ["ded00ff914290d88c44696d0582ab57f0af94531"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588164 - Remove an unused declaration for nsPermissionManager::GetPermissionHashKey; r=pbz\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48991", "files": ["extensions/permissions/nsPermissionManager.h"], "git_node": null, "git_parents": [null], "node": "340eefa05fc271fc88f785af9bfe6d20e8165642", "parents": ["0c632655907932ee1559cd09aa2b264c461e2b3b"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1582472 - Exclude DHCP Search Suffi