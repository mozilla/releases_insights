5b3c\nit -\u003e 0bdb90fcaeae\noc -\u003e 03ada2ae0cef\npt-BR -\u003e 85e7ff1bcc09\npt-PT -\u003e 161922a9c36d", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "2ba4ef6fae397a7a9f197a661a6a27299cf9ea81", "parents": ["0f14260c1599baa25d26cfa5c459caa58a3dd267"], "tags": []}], "date": 1573635643, "git_changesets": [null, null], "user": "ffxbld"}, "12297": {"changesets": [{"author": "Nihanth Subramanya \u003cnhnt11@gmail.com\u003e", "branch": "default", "desc": "Bug 1593984 - Set -moz-appearance: none on the milestone toolbarbutton. r=timhuang a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D51886", "files": ["browser/themes/shared/controlcenter/panel.inc.css"], "git_node": null, "git_parents": [null], "node": "6dcd2b5414fe57154de7152e455f41af8720df94", "parents": ["2ba4ef6fae397a7a9f197a661a6a27299cf9ea81"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1594466 - Add crashtest. r=bryce a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52519", "files": ["dom/media/test/crashtests/1594466.html", "dom/media/test/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "4428ee2cbd46c129ea78980fcb3811e887e12ff1", "parents": ["6dcd2b5414fe57154de7152e455f41af8720df94"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1594466 - Don't rewrite mimeType if fully defined. r=bryce a=pascalc\n\nPrior to this patch the mimetype was rewritten per the printf format\n\"%s; codecs=%s\" also when codecs were defined in the constrained mime type.\n\nThe latter '%s' would be the codecs string from the mime type parser, which\nwould have dropped any quotation marks surrounding the string.\nHence 'codecs=\"vp8, opus\"' would be considered supported (quotation marks\nincluded), but when selecting mime type in start(), it would be rewritten\nwith quotation marks dropped. Thus looking like 'codecs=vp8,' which is not\nsupported.\n\nThis patch removes the rewrite step when the mime type is fully defined with\ncodecs, so that the quotation marks are left in place as given to the\nconstructor.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52520", "files": ["dom/media/MediaRecorder.cpp"], "git_node": null, "git_parents": [null], "node": "02d59bed4770232c0b58e24fb80f844f3a5a6fe9", "parents": ["4428ee2cbd46c129ea78980fcb3811e887e12ff1"], "tags": []}, {"author": "Neil Deakin \u003cneil@mozilla.com\u003e", "branch": "default", "desc": "Bug 1590445, only adjust zoom level for FullZoomChange and TextZoomChange events for top-level frames, r=mconley a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D51617", "files": ["toolkit/actors/ZoomChild.jsm"], "git_node": null, "git_parents": [null], "node": "1c239d21550f01aee2c1df27b0317dae50a30b60", "parents": ["02d59bed4770232c0b58e24fb80f844f3a5a6fe9"], "tags": []}, {"author": "Daosheng Mu \u003cdaoshengmu@gmail.com\u003e", "branch": "default", "desc": "Bug 1562825 - Checking if puppet is active before initializing VR puppet command buffers. r=kip a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52116", "files": ["gfx/vr/VRServiceHost.cpp"], "git_node": null, "git_parents": [null], "node": "a207a5eba543d72e292912cd7b114883bfa8ad23", "parents": ["1c239d21550f01aee2c1df27b0317dae50a30b60"], "tags": []}, {"author": "Dave Townsend \u003cdtownsend@oxymoronical.com\u003e", "branch": "default", "desc": "Bug 1513855: Make sure that quit-application-granted and quit-application notifications are always sent. r=froydnj a=pascalc\n\nWe only run the main event loop if at least one window is open. There are various\ncases where this doesn't happen, such as -silent. By the time we get there though\nsome components have started and require appropriate notifications to tell them\nto shutdown safely. This patch sends the quit-application-granted and\nquit-application notifications in the case that there were no windows open\nand nsAppStartup::Quit hasn't already been called when we come to run the\nevent loop.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D51736", "files": ["browser/components/BrowserContentHandler.jsm", "toolkit/components/startup/nsAppStartup.cpp"], "git_node": null, "git_parents": [null], "node": "551870e334f99151d93be5ee0a605a3204f029bc", "parents": ["a207a5eba543d72e292912cd7b114883bfa8ad23"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1444631 - fix browser_utilityOverlay.js to not trip over about:blank loads, r=nhnt11 a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52174", "files": ["browser/base/content/test/contextMenu/browser.ini", "browser/base/content/test/contextMenu/browser_utilityOverlay.js"], "git_node": null, "git_parents": [null], "node": "27bfd98ae6badc6dc8a338021d4ee5f157887151", "parents": ["551870e334f99151d93be5ee0a605a3204f029bc"], "tags": []}, {"author": "Erica Wright \u003cewright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588645 - Ensure data is saved correctly before database closes on shutdown. r=nhnt11,robwu a=pascalc\n\nThis should also fix Bug 1589130\n\nDifferential Revision: https://phabricator.services.mozilla.com/D51908", "files": ["toolkit/components/antitracking/TrackingDBService.jsm"], "git_node": null, "git_parents": [null], "node": "51b1658d803d239e7f6d750d6d678a3e2db2ecf8", "parents": ["27bfd98ae6badc6dc8a338021d4ee5f157887151"], "tags": []}, {"author": "Erica Wright \u003cewright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1594340 - Celebration message is highlighted when selected with keyboard. r=nhnt11 a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52208", "files": ["browser/themes/shared/controlcenter/panel.inc.css"], "git_node": null, "git_parents": [null], "node": "2804297d7ed6707f421553a922fd41a7e4b40e39", "parents": ["51b1658d803d239e7f6d750d6d678a3e2db2ecf8"], "tags": []}, {"author": "Erica Wright \u003cewright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1593974 - remove top border from celebration button r=nhnt11 a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D51887", "files": ["browser/themes/shared/browser.inc.css"], "git_node": null, "git_parents": [null], "node": "87cc76d88859c3a7f73089c551f08abc85a460e8", "parents": ["2804297d7ed6707f421553a922fd41a7e4b40e39"], "tags": []}], "date": 1573656453, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "nbeleuzu@mozilla.com"}, "12298": {"changesets": [{"author": "Nihanth Subramanya \u003cnhnt11@gmail.com\u003e", "branch": "default", "desc": "Bug 1587042 - Don't use --panel-separator-color for TP switch border. r=timhuang a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52330", "files": ["browser/themes/shared/controlcenter/panel.inc.css"], "git_node": null, "git_parents": [null], "node": "61d6918ee072de25818d1011b11bcbd8b3883ea1", "parents": ["87cc76d88859c3a7f73089c551f08abc85a460e8"], "tags": []}, {"author": "Punam Dahiya \u003cpunamdahiya@yahoo.com\u003e", "branch": "default", "desc": "Bug 1593652 - Set default triplet to fix extended triplet on first opened new tab r=Mardak a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D51731", "files": ["browser/components/newtab/lib/ASRouter.jsm", "browser/components/newtab/test/unit/asrouter/ASRouter.test.js"], "git_node": null, "git_parents": [null], "node": "d385c34efc5068f161f02d72fa24a69112339bb0", "parents": ["61d6918ee072de25818d1011b11bcbd8b3883ea1"], "tags": []}, {"author": "Harshil Agrawal \u003cghagrawal17@gmail.com\u003e", "branch": "default", "desc": "Bug 1594359 - Fix DevTools shrink height r=jdescottes a=pascalc\n\nIn the devtools-browser.css file the min-height is set to 29px to the class .devtools-toolboc-bottom-iframe\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52115", "files": ["devtools/client/themes/devtools-browser.css"], "git_node": null, "git_parents": [null], "node": "b0db88caff8ece76977548b08371752c845da089", "parents": ["d385c34efc5068f161f02d72fa24a69112339bb0"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1580695 - Revert bug 1533129. r=alwu,bryce a=pascalc\n\nThis  change was a workaround a Youtube bug that expected a particular behaviour from old TV and that we were exploiting. It was adding support for unsupported, unofficial code.\n\nMediaCapabilities is how things should be done.\n\nMaking this code to work conditionally is too much effort. Reverting it entirely is easier.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49515", "files": ["dom/media/MediaMIMETypes.cpp", "dom/media/MediaMIMETypes.h", "dom/media/mediasource/MediaSource.cpp", "dom/media/mediasource/test/file_isTypeSupported.html", "dom/media/mediasource/test/mochitest.ini", "dom/media/mediasource/test/test_isTypeSupportedExtensions.html"], "git_node": null, "git_parents": [null], "node": "d13878b3967aa3dd0e0ece9ad5cf53ef8191836e", "parents": ["b0db88caff8ece76977548b08371752c845da089"], "tags": []}, {"author": "James Teh \u003cjteh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1590929: a11y::TraversalRule::Match: Don't assume that all Accessibles have a frame. r=MarcoZ a=pascalc\n\nI don't have a test case for this crash, but the stack suggests the frame is null.\nThis can certainly happen for display: contents.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D51560", "files": ["accessible/android/TraversalRule.cpp"], "git_node": null, "git_parents": [null], "node": "4bc5fce6cfca890addd354ff60f373bd395d0501", "parents": ["d13878b3967aa3dd0e0ece9ad5cf53ef8191836e"], "tags": []}, {"author": "Thom Chiovo