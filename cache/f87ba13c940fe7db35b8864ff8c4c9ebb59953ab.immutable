tial Revision: https://phabricator.services.mozilla.com/D48549", "files": ["accessible/tests/browser/browser.ini", "accessible/tests/browser/events/browser_test_focus_browserui.js", "accessible/tests/browser/events/browser_test_focus_dialog.js", "accessible/tests/browser/fission_document_builder.sjs", "accessible/tests/browser/shared-head.js"], "git_node": null, "git_parents": [null], "node": "8f82c25fa54aaadfb787773a4a143f7c0f3bd4eb", "parents": ["af6f7a56fac295160aa8f8fa4d38ea4ae7285069"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1543575 - add fission coverage for accessibility b-c e10s event tests. r=Jamie\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48550", "files": ["accessible/tests/browser/e10s/browser.ini", "accessible/tests/browser/e10s/browser_events_announcement.js", "accessible/tests/browser/e10s/browser_events_caretmove.js", "accessible/tests/browser/e10s/browser_events_hide.js", "accessible/tests/browser/e10s/browser_events_show.js", "accessible/tests/browser/e10s/browser_events_statechange.js", "accessible/tests/browser/e10s/browser_events_textchange.js", "accessible/tests/browser/e10s/browser_events_vcchange.js"], "git_node": null, "git_parents": [null], "node": "5768872b10a05da6518a157dda79e51c2f6e3c4e", "parents": ["8f82c25fa54aaadfb787773a4a143f7c0f3bd4eb"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1543575 - add fission coverage for accessibility b-c e10s caching tests. r=Jamie\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48551", "files": ["accessible/tests/browser/e10s/browser.ini", "accessible/tests/browser/e10s/browser_caching_attributes.js", "accessible/tests/browser/e10s/browser_caching_description.js", "accessible/tests/browser/e10s/browser_caching_name.js", "accessible/tests/browser/e10s/browser_caching_relations.js", "accessible/tests/browser/e10s/browser_caching_states.js", "accessible/tests/browser/e10s/browser_caching_value.js"], "git_node": null, "git_parents": [null], "node": "b698e86b632adf0e7dc561bfef81aab128ef3015", "parents": ["5768872b10a05da6518a157dda79e51c2f6e3c4e"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1543575 - add fission coverage for accessibility b-c e10s tree update tests. r=Jamie\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48552", "files": ["accessible/tests/browser/e10s/browser.ini", "accessible/tests/browser/e10s/browser_contentSelectDropdown.js", "accessible/tests/browser/e10s/browser_treeupdate_ariadialog.js", "accessible/tests/browser/e10s/browser_treeupdate_ariaowns.js", "accessible/tests/browser/e10s/browser_treeupdate_canvas.js", "accessible/tests/browser/e10s/browser_treeupdate_cssoverflow.js", "accessible/tests/browser/e10s/browser_treeupdate_doc.js", "accessible/tests/browser/e10s/browser_treeupdate_gencontent.js", "accessible/tests/browser/e10s/browser_treeupdate_hidden.js", "accessible/tests/browser/e10s/browser_treeupdate_imagemap.js", "accessible/tests/browser/e10s/browser_treeupdate_list.js", "accessible/tests/browser/e10s/browser_treeupdate_list_editabledoc.js", "accessible/tests/browser/e10s/browser_treeupdate_listener.js", "accessible/tests/browser/e10s/browser_treeupdate_optgroup.js", "accessible/tests/browser/e10s/browser_treeupdate_removal.js", "accessible/tests/browser/e10s/browser_treeupdate_select_dropdown.js", "accessible/tests/browser/e10s/browser_treeupdate_table.js", "accessible/tests/browser/e10s/browser_treeupdate_textleaf.js", "accessible/tests/browser/e10s/browser_treeupdate_visibility.js", "accessible/tests/browser/e10s/browser_treeupdate_whitespace.js"], "git_node": null, "git_parents": [null], "node": "f688dcef278a4dad702ec8aef4c611346f152b88", "parents": ["b698e86b632adf0e7dc561bfef81aab128ef3015"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset cd4dc0ae3364 (bug 1557447) for Browser-chrome failures in build/src/obj-firefox/dist/include/mozilla/BlocksRingBuffer.h", "files": ["browser/base/content/test/performance/browser_startup_syncIPC.js", "browser/base/content/test/performance/io/browser.ini", "devtools/client/performance-new/components/Settings.js", "dom/media/mediasink/moz.build", "dom/performance/moz.build", "ipc/glue/MessageChannel.cpp", "ipc/glue/MessageChannel.h", "ipc/glue/ProtocolUtils.h", "ipc/ipdl/ipdl/lower.py", "js/public/ProfilingCategory.h", "toolkit/components/extensions/schemas/geckoProfiler.json", "tools/profiler/core/ProfilerMarkerPayload.cpp", "tools/profiler/public/GeckoProfiler.h", "tools/profiler/public/ProfilerMarkerPayload.h", "tools/profiler/tests/browser/browser.ini", "tools/profiler/tests/browser/browser_test_feature_ipcmessages.js", "tools/profiler/tests/gtest/moz.build"], "git_node": null, "git_parents": [null], "node": "51d3d7b08ee84bf510ffbfaf9f4261d35ab77396", "parents": ["f688dcef278a4dad702ec8aef4c611346f152b88"], "tags": []}, {"author": "thomasmo \u003cthomasmo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1587521 - Enable FullScreen in FxR for Desktop r=mconley,Gijs\n\nBug 1587521 - Enable FullScreen in FxR for Desktop\n\nThis change enables Fullscreen functionality in the UI for Firefox Reality for Desktop. On Fullscreen, the window (rather than the desktop) is taken over, and it is up to the host to render the contents as fullscreen.\n\nTo mitigate the impact on Desktop's implementation, browser-fullScreenAndPointerLock.js is forked and removes the dependencies on browser.js. These two files will be rationalized at a later time.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48913", "files": ["browser/actors/DOMFullscreenParent.jsm", "browser/fxr/content/fxr-fullScreen.js", "browser/fxr/content/fxrui.css", "browser/fxr/content/fxrui.js", "browser/fxr/jar.mn", "dom/base/nsGlobalWindowOuter.cpp", "dom/base/nsGlobalWindowOuter.h", "dom/base/nsPIDOMWindow.h", "gfx/vr/nsFxrCommandLineHandler.cpp"], "git_node": null, "git_parents": [null], "node": "5c70bc0aeda71a69bd145fa5c0d5f00b9bef1ebe", "parents": ["51d3d7b08ee84bf510ffbfaf9f4261d35ab77396"], "tags": []}, {"author": "Daisuke Akatsuka \u003cdaisuke@birchill.co.jp\u003e", "branch": "default", "desc": "Bug 1588962: Reflect the changes on the rule view. r=rcaliman\n\nDepends on D49520\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49534", "files": ["devtools/client/inspector/compatibility/CompatibilityView.js"], "git_node": null, "git_parents": [null], "node": "8d65bb2e23a2658af8b016be54f3c0b0d0083da1", "parents": ["5c70bc0aeda71a69bd145fa5c0d5f00b9bef1ebe"], "tags": []}, {"author": "Daisuke Akatsuka \u003cdaisuke@birchill.co.jp\u003e", "branch": "default", "desc": "Bug 1588962: Add a test whether reflect the rule change. r=rcaliman\n\nDepends on D49534\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49535", "files": ["devtools/client/inspector/compatibility/test/browser/browser.ini", "devtools/client/inspector/compatibility/test/browser/browser_compatibility_event_rule-change.js"], "git_node": null, "git_parents": [null], "node": "382cd1dcf838c2cefe523daf61d817ac9bb5cf9e", "parents": ["8d65bb2e23a2658af8b016be54f3c0b0d0083da1"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1585776 - Fix XPInstall content handler under Fission. r=nika\n\nThe XPInstall content handlers currently make all sorts of assumptions about\nthe process they're being run in and the docShell their request is tied to.\nThese assumptions don't hold under Fission, either now, when they may be\ncalled just after a process switch, or in the future, when they'll be called\nin the parent process.\n\nThis patch updates them to operate on the BrowsingContext of the request, and\nto do their messaging via the process message manager, rather than via frame\nmessage managers. As a bonus, it also removes the existing hacks they had in\nplace to handle the cases where frame message managers didn't work.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48224", "files": ["browser/components/enterprisepolicies/tests/browser/browser.ini", "toolkit/mozapps/extensions/AddonManager.jsm", "toolkit/mozapps/extensions/addonManager.js", "toolkit/mozapps/extensions/amContentHandler.jsm", "toolkit/mozapps/extensions/amInstallTrigger.jsm"], "git_node": null, "git_parents": [null], "node": "93c2588d2799d630caeb38f1c834267e278972a9", "parents": ["382cd1dcf838c2cefe523daf61d817ac9bb5cf9e"], "tags": []}, {"author": "Daosheng Mu \u003cdaoshengmu@gmail.com\u003e", "branch": "default", "desc": "Bug 1587942 - Forwarding keyboard show/hide events to VR host API. r=thomasmo,PhilipLamb,masayuki,imanol\n\nForwarding keyboard focus/blur events to VR browser that runs at another process. We will need to set these events in VR shmem, then VR host can receive these states from other process.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48903", "files": ["gfx/vr/FxRWindowManager.cpp", "gfx/vr/FxRWindowManager.h", "gfx/vr/VRShMem.cpp", "gfx/vr/VRShMem.h", "gfx/vr/external_api/moz_external_vr.h", "gfx/vr/moz.build", "gfx/vr/vrhost/vrhost.def", "gfx/vr/vrhost/vrhostapi.cpp", "gfx/vr/vrhost/vrhostex.h", "gfx/vr/vrhost/vrhostnightly.def", "gfx/vr/vrhost/vrhosttest.cpp", "widget/windows/WinIMEHandler.cpp"], "git_node": null, "git_parents": [null], "node": "4dbfb65c5991c35b9539b3e121a91e69657a4f05", "parents": ["93c2588d2799d630caeb38f1c834267e278972a9"], "tags": []}, {"author": "skierpage \u003cinfo@skierpage.com\u003e", "branch": "default", "desc": "Bug 1587650 - Update README.md with more informative intro r=gw\n\nAddresses issues with the README in [mozilla bug 1587650](https://bugzilla.mozilla.org/show_bug.cgi?id=1587650).\n[import_pr] From https://github.com/servo/webrender/pull/3772\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49501", "files": ["gfx/wr/README.md"], "git_node": null, "git_parents": [null], "node": "fc99c73779480bdc4f82b2cb6e91530cddd48f40", "parents": ["4dbfb65c5991c35b9539b3e121a91e69657a4f05"], "tags": []}, {"author": "Jim Porter \u003cjporter@mozilla.com\u003e", "branch": "default", "desc": "Bug 1557447 - Profiler support for IPC information; r=nika\n\nThis adds the ability to add profile markers for both the sender and recipient\nsides of IPC messages. These can then be correlated with one another in the\nprofile visualization. For the UI component of this patch, see\n\u003chttps://github.com/firefox-devtools/profiler/pull/2172\u003e.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42226", "files": ["browser/base/content/test/performance/browser_startup_syncIPC.js", "browser/base/content/test/performance/io/browser.ini", "devtools/client/performance-new/components/Settings.js", "dom/media/mediasink/moz.build", "dom/performance/moz.build", "ipc/glue/MessageChannel.cpp", "ipc/glue/MessageChannel.h", "ipc/glue/ProtocolUtils.h", "ipc/ipdl/ipdl/lower.py", "js/public/ProfilingCategory.h", "toolkit/components/extensions/schemas/geckoProfiler.json", "tools/profiler/core/ProfilerMarkerPayload.cpp", "tools/profiler/public/GeckoProfiler.h", "tools/profiler/public/ProfilerMarkerPayload.h", "tools/profiler/tests/browser/browser.ini", "tools/profiler/tests/browser/browser_test_feature_ipcmessages.js", "tools/profiler/tests/gtest/moz.build"], "git_node": null, "git_parents": [null], "node": "2923afce519ae4339e8fb7d29dfba065717eff83", "parents": ["fc99c73779480bdc4f82b2cb6e91530cddd48f40"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1589309.  Pass XPCOM strings, not buffer pointers, to notifyJSRunToCompletionStart.  r=smaug\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49650", "files": ["docshell/base/nsDocShell.cpp", "docshell/base/nsIDocShell.idl", "docshell/base/timeline/JavascriptTimelineMarker.h", "dom/script/ScriptSettings.cpp"], "git_node": null, "git_parents": [null], "node": "f0138a399f7c4e3988711293ff595df3e67e60d1", "parents": ["2923afce519ae4339e8fb7d29dfba065717eff83"], "tags": []}, {"author": "Abimbola Olaitan \u003ccraftwordltd@gmail.com\u003e", "branch": "default", "desc": "Bug 1589564 - Refactor ManifestIcons's fetchIcon() function to use await r=marcosc\n\nThe fetchIcon() bug is labelled as async, but doesn't use await. Refactoring it to use await cleans up the function a bit.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49581", "files": ["dom/manifest/ManifestIcons.jsm"], "git_node": null, "git_parents": [null], "node": "77f284223290667b57b3fa70bf147817f974a6d7", "parents": ["f0138a399f7c4e3988711293ff595df3e67e60d1"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1565634 - mach install should install GVE as default. r=nalexander\n\nFennec is removed, but mach install still tries to install Fennec. It should\ninstall GVE instead.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48811", "files": ["mobile/android/build.mk", "python/mozbuild/mozbuild/mach_commands.py"], "git_node": null, "git_parents": [null], "node": "e527a2e55bade3f6c92e19b00340897f546beec3", "parents": ["77f284223290667b57b3fa70bf147817f974a6d7"], "tags": []}, {"author": "Daniel Varga \u003cdvarga@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 2923afce519a (bug 1557447) for browser chrome failure at tools/profiler/tests/browser/browser_test_feature_preferencereads.js. On a CLOSED TREE", "files": ["browser/base/content/test/performance/browser_startup_syncIPC.js", "browser/base/content/test/performance/io/browser.ini", "devtools/client/performance-new/components/Settings.js", "dom/media/mediasink/moz.build", "dom/performance/moz.build", "ipc/glue/MessageChannel.cpp", "ipc/glue/MessageChannel.h", "ipc/glue/ProtocolUtils.h", "ipc/ipdl/ipdl/lower.py", "js/public/ProfilingCategory.h", "toolkit/components/extensions/schemas/geckoProfiler.json", "tools/profiler/core/ProfilerMarkerPayload.cpp", "tools/profiler/public/GeckoProfiler.h", "tools/profiler/public/ProfilerMarkerPayload.h", "tools/profiler/tests/browser/browser.ini", "tools/profiler/tests/browser/browser_test_feature_ipcmessages.js", "tools/profiler/tests/gtest/moz.build"], "git_node": null, "git_parents": [null], "node": "70426e17c6445e928a200123d6a65859870859ff", "parents": ["e527a2e55bade3f6c92e19b00340897f546beec3"], "tags": []}, {"author": "jaril \u003cjarilvalenciano@gmail.com\u003e", "branch": "default", "desc": "Bug 1588997 - Convert ObjectClient to protocol.js front. r=nchevobbe.\n\n- Converted the ObjectClient into an protocoljs Front\n- Converted the SymbolIteratorClient into a protocoljs Front and moved it to devtools/shared/fronts\n- Converted the PropertyIteratorClient into a protocoljs Front and moved it to devtools/shared/fronts\n- Converted the EnvironmentClient into a protocoljs Front and moved it to devtools/shared/fronts\n- Modified calls to `DebuggerClient.release()` so that it tries to call the ObjectFront's release method first, and falls back on `DebuggerClient.release()` if there's no object front\n- Changed reps so that it instantiates only one ObjectClient per grip\n- Changed tests so that they expect what the Front's request method resolves to where applicable (i.e. ObjectFront.allocationStack resolves to allocationStack, not a packet object with an allocationStack property)\n- Changed callbacks provided to ObjectClient methods to be chained to the ObjectFront methods (e.g. ObjectClient.getScope(callback) changed to ObjectFront.getScope().callback())\n- Changed tests to use async/await (test_framebindings-x.js, test_functiongrips-x.js, test_objectgrips-x.js)\n- Changed tests to expect protocoljs to throw an error string instead of an error object (test_objectgrips-fn-apply-03.js, test_threadlifetime-02.js, test_pauselifetime-03.js)\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48182", "files": ["browser/components/extensions/parent/ext-devtools-panels.js", "devtools/client/debugger/packages/devtools-reps/src/launchpad/index.js", "devtools/client/debugger/src/client/firefox/commands.js", "devtools/client/debugger/src/client/firefox/types.js", "devtools/client/debugger/test/mochitest/browser_dbg-scopes-mutations.js", "devtools/client/debugger/test/mochitest/browser_dbg-sourcemaps-reloading.js", "devtools/client/inspector/inspector.js", "devtools/client/scratchpad/scratchpad.js", "devtools/client/shared/components/reps/reps.js", "devtools/client/shared/widgets/VariablesViewController.jsm", "devtools/client/webconsole/commands.js", "devtools/client/webconsole/test/browser/browser_console_cpow.js", "devtools/client/webconsole/test/browser/browser_console_webconsole_console_api_calls.js", "devtools/client/webconsole/webconsole-connection-proxy.js", "devtools/server/tests/browser/browser_dbg_promises-allocation-stack.js", "devtools/server/tests/browser/browser_dbg_promises-chrome-allocation-stack.js", "devtools/server/tests/browser/browser_dbg_promises-fulfillment-stack.js", "devtools/server/tests/browser/browser_dbg_promises-rejection-stack.js", "devtools/server/tests/unit/head_dbg.js", "devtools/server/tests/unit/test_framebindings-01.js", "devtools/server/tests/unit/test_framebindings-02.js", "devtools/server/tests/unit/test_framebindings-03.js", "devtools/server/tests/unit/test_framebindings-04.js", "devtools/server/tests/unit/test_framebindings-05.js", "devtools/server/tests/unit/test_framebindings-06.js", "devtools/server/tests/unit/test_framebindings-07.js", "devtools/server/tests/unit/test_functiongrips-01.js", "devtools/server/tests/unit/test_objectgrips-01.js", "devtools/server/tests/unit/test_objectgrips-02.js", "devtools/server/tests/unit/test_objectgrips-03.js", "devtools/server/tests/unit/test_objectgrips-04.js", "devtools/server/tests/unit/test_objectgrips-05.js", "devtools/server/tests/unit/test_objectgrips-06.js", "devtools/server/tests/unit/test_objectgrips-07.js", "devtools/server/tests/unit/test_objectgrips-08.js", "devtools/server/tests/unit/test_objectgrips-10.js", "devtools/server/tests/unit/test_objectgrips-11.js", "devtools/server/tests/unit/test_objectgrips-12.js", "devtools/server/tests/unit/test_objectgrips-13.js", "devtools/server/tests/unit/test_objectgrips-17.js", "devtools/server/tests/unit/test_objectgrips-18.js", "devtools/server/tests/unit/test_objectgrips-20.js", "devtools/server/tests/unit/test_objectgrips-21.js", "devtools/server/tests/unit/test_objectgrips-22.js", "devtools/server/tests/unit/test_objectgrips-fn-apply-03.js", "devtools/server/tests/unit/test_pauselifetime-03.js", "devtools/server/tests/unit/test_promises_client_getdependentpromises.js", "devtools/server/tests/unit/test_threadlifetime-02.js", "devtools/shared/client/environment-client.js", "devtools/shared/client/moz.build", "devtools/shared/client/object-client.js", "devtools/shared/client/property-iterator-client.js", "devtools/shared/client/symbol-iterator-client.js", "devtools/shared/fronts/environment.js", "devtools/shared/fronts/moz.build", "devtools/shared/fronts/property-iterator.js", "devtools/shared/fronts/symbol-iterator.js", "devtools/shared/specs/index.js", "devtools/shared/webconsole/test/test_bug819670_getter_throws.html", "devtools/shared/webconsole/test/test_object_actor.html", "devtools/shared/webconsole/test/test_object_actor_native_getters.html", "devtools/shared/webconsole/test/test_object_actor_native_getters_lenient_this.html"], "git_node": null, "git_parents": [null], "node": "a15ba287ac6fd84643d248ace00bf18c18382ada", "parents": ["70426e17c6445e928a200123d6a65859870859ff"], "tags": []}, {"author": "Eden Chuang \u003cechuang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1561706 - Update the controlled client in ServiceWorkerManager after process switching r=asuth,valentin,perry\n\nWhen Fission is on, loading a cross-origin iframe triggers process switching when calling the channel::OnStartReqeust.\nIf a ServiceWorker should intercept the loading, the interception setting is completed while opening the channel.\nThat means the service worker controls the ClientSource created by the old process.\nAfter process switching completed, the new ClientSource will be created and resume the loading from the opened channel.\nHowever, in the original code, we did not update the controlled Client in the ServiceWorkerManager.\nAnd when loading the same origin subresource in the new process, it makes ServiceWorkerManager cannot find the correct ServiceWorker to perform the interception.\n\nSince we are going to release sw-e10s, this patch is only for both Fission and sw-e10s are on.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49284", "files": ["dom/serviceworkers/ServiceWorkerManager.cpp", "dom/serviceworkers/ServiceWorkerManager.h", "dom/serviceworkers/test/mochitest.ini", "netwerk/ipc/DocumentChannelParent.cpp"], "git_node": null, "git_parents": [null], "node": "4946569ae95bbf189dea8bc8dfff8d839b496f4b", "parents": ["a15ba287ac6fd84643d248ace00bf18c18382ada"], "tags": []}, {"author": "Alex Chronopoulos \u003cachronop@gmail.com\u003e", "branch": "default", "desc": "Bug 1572884 - Upmix mono webaudio channels to stereo when the output configuration is 3 and 5 channels. r=padenot\n\nWebAudio upmix layout is defined in the spec for the channel configurations mono, stereo, quad and 5.1. Layouts with 3 and 5 channels are not defined yet. For those undefined layouts firefox provided upmix to a single channel (left). This has been updated to upmix to the two stereo channels (left, right).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49610", "files": ["dom/media/AudioChannelFormat.h", "dom/media/webaudio/test/test_mixingRules.html"], "git_node": null, "git_parents": [null], "node": "239ff6e79980e9b8c96a5f46a9555066fd899aed", "parents": ["4946569ae95bbf189dea8bc8dfff8d839b496f4b"], "tags": []}, {"author": "Nihanth Subramanya \u003cnhnt11@gmail.com\u003e", "branch": "default", "desc": "Bug 1589015 - Stop using two label elements in the cookies category item. r=johannh\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49599", "files": ["browser/base/content/browser-siteProtections.js", "browser/components/controlcenter/content/protectionsPanel.inc.xul", "browser/locales/en-US/chrome/browser/browser.dtd"], "git_node": null, "git_parents": [null], "node": "66b01a30ed12782ead9f0d2af4703d51c4fd4f48", "parents": ["239ff6e79980e9b8c96a5f46a9555066fd899aed"], "tags": []}, {"author": "Carolina \u003ccarolina.jimenez.g@gmail.com\u003e", "branch": "default", "desc": "Bug 1582225 - Fixes overflow in \"Public Value\" fields.r=johannh\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49500", "files": ["toolkit/components/certviewer/content/components/info-item.js", "toolkit/components/certviewer/tests/browser/browser_checkLongHex.js"], "git_node": null, "git_parents": [null], "node": "2cd0249984214c8898195de11a61d0724ea99179", "parents": ["66b01a30ed12782ead9f0d2af4703d51c4fd4f48"], "tags": []}, {"author": "Edgar Chen \u003cechen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588720 - Part 1: Convert dom.popup_maximum to a static pref; r=smaug\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49275", "files": ["dom/base/nsGlobalWindowOuter.cpp", "modules/libpref/init/StaticPrefList.yaml", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "729a6c2005ad46a6009e45e7e14db4a38ed338c8", "parents": ["2cd0249984214c8898195de11a61d0724ea99179"], "tags": []}, {"author": "Edgar Chen \u003cechen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588720 - Part 2: Track number of popup spam through BrowsingContext; r=smaug\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49276", "files": ["docshell/base/BrowsingContext.cpp", "docshell/base/BrowsingContext.h", "docshell/base/BrowsingContextFieldList.h", "dom/base/PopupBlocker.cpp", "dom/base/PopupBlocker.h", "dom/base/nsGlobalWindowOuter.cpp", "toolkit/components/windowwatcher/nsWindowWatcher.cpp"], "git_node": null, "git_parents": [null], "node": "996e48d8e990d0dd2cf08492c946a08d0b2dc246", "parents": ["729a6c2005ad46a6009e45e7e14db4a38ed338c8"], "tags": []}, {"author": "Edgar Chen \u003cechen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588720 - Part 3: Remove nsGlobalWindowOuter::gOpenPopupSpamCount; r=smaug\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49277", "files": ["dom/base/nsGlobalWindowOuter.cpp", "dom/base/nsGlobalWindowOuter.h"], "git_node": null, "git_parents": [null], "node": "19a2899c8f21a0b0062b4bc203533669ac6d2d22", "parents": ["996e48d8e990d0dd2cf08492c946a08d0b2dc246"], "tags": []}, {"author": "Nicolas Silva \u003cnsilva@mozilla.com\u003e", "branch": "default", "desc": "Bug 1589119 - Add profile counters for rendered and total number of picture cache tiles. r=gw\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49438", "files": ["gfx/wr/webrender/src/profiler.rs", "gfx/wr/webrender/src/renderer.rs"], "git_node": null, "git_parents": [null], "node": "8f6ab1486f9fe658ad688fea54f6779c43063a11", "parents": ["19a2899c8f21a0b0062b4bc203533669ac6d2d22"], "tags": []}, {"author": "Nicolas Silva \u003cnsilva@mozilla.com\u003e", "branch": "default", "desc": "Bug 1583841 - Add an expected range in ResourceProfileCounter. r=gw\n\nDepends on D49438\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49617", "files": ["gfx/wr/webrender/src/profiler.rs"], "git_node": null, "git_parents": [null], "node": "5979a213200682d5eef021820f88cd3a2ef2f936", "parents": ["8f6ab1486f9fe658ad688fea54f6779c43063a11"], "tags": []}, {"author": "Nicolas Silva \u003cnsilva@mozilla.com\u003e", "branch": "default", "desc": "Bug 1583841 - Include some ResourceProfileCounters in the smart profiler. r=gw\n\nDepends on D49617\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49618", "files": ["gfx/wr/webrender/src/profiler.rs"], "git_node": null, "git_parents": [null], "node": "8cc42e92e6ef2b11d818b056aa6f67cd800844db", "parents": ["5979a213200682d5eef021820f88cd3a2ef2f936"], "tags": []}, {"author": "Nicolas Silva \u003cnsilva@mozilla.com\u003e", "branch": "default", "desc": "Bug 1583841 - Highlight values in red in the full and compact profilers when values are outside their expected range. r=gw\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49619", "files": ["gfx/wr/webrender/src/profiler.rs"], "git_node": null, "git_parents": [null], "node": "16bed925e3ac7bf500d924d5441085f87de07e3d", "parents": ["8cc42e92e6ef2b11d818b056aa6f67cd800844db"], "tags": []}, {"author": "Nicolas Silva \u003cnsilva@mozilla.com\u003e", "branch": "default", "desc": "Bug 1583841 - Don't set an expected range for the FPS counter. r=gw\n\nWhen we are not scrolling or animating it can be normal for there to be a long pause between frames, in which case highlighting the FPS counter in the profiler is distracting.\n\nDepends on D49619\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49620", "files": ["gfx/wr/webrender/src/profiler.rs"], "git_node": null, "git_parents": [null], "node": "1ad5346d3fa4222b2252e756e4c57f62a6292667", "parents": ["16bed925e3ac7bf500d924d5441085f87de07e3d"], "tags": []}, {"author": "Nicolas Silva \u003cnsilva@mozilla.com\u003e", "branch": "default", "desc": "Bug 1589319 - Add some picture caching documentation. r=gw\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49566", "files": ["gfx/wr/webrender/src/picture.rs"], "git_node": null, "git_parents": [null], "node": "eb3e6a48f9b1072e93e0c25627d9207d6cc6d0f7", "parents": ["1ad5346d3fa4222b2252e756e4c57f62a6292667"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1587248 - Add crashtest. r=bryce\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49572", "files": ["dom/media/test/crashtests/1587248.html", "dom/media/test/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "643c477a36c05aa4aedf3f55d67784c57d0adf18", "parents": ["eb3e6a48f9b1072e93e0c25627d9207d6cc6d0f7"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1587248 - Remove unnecessary legacy window guard. r=bryce\n\nDepends on D49572\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49573", "files": ["dom/html/HTMLMediaElement.cpp"], "git_node": null, "git_parents": [null], "node": "131a93988dcd996ac62a18ebe88719d7e30b4e3e", "parents": ["643c477a36c05aa4aedf3f55d67784c57d0adf18"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1587248 - Adequately guard mMediaStreamRenderer usage. r=bryce\n\nIt can be unset by NotifyShutdown, to release the VideoFrameContainer in time.\nThis is unexpected for all paths assuming it will be unset by\nEndSrcMediaStreamPlayback().\n\nDepends on D49573\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49574", "files": ["dom/html/HTMLMediaElement.cpp"], "git_node": null, "git_parents": [null], "node": "721bbb99b98dbeacde74e75afb55314a3b78e539", "parents": ["131a93988dcd996ac62a18ebe88719d7e30b4e3e"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1586201 - Refactor of ObjectActor form function. r=ochameau.\n\nThe function was close to hit the complexity limit set by eslint,\nso we break it up into smaller functions.\nWe also group assignments where we can.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48806", "files": ["devtools/server/actors/object.js", "devtools/server/tests/browser/browser_dbg_promises-chrome-allocation-stack.js", "devtools/server/tests/unit/test_objectgrips-17.js", "devtools/server/tests/unit/test_objectgrips-21.js"], "git_node": null, "git_parents": [null], "node": "e9dada6878890675b3bcb6decbf65a1d7e2b3fae", "parents": ["721bbb99b98dbeacde74e75afb55314a3b78e539"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1586201 - Include ContentDomReference in Node grips. r=pbro.\n\nThis will allow us to retrieve the appropriate inspector\n(and thus walker, highlighter, ...) for a given element\nlater, potentially from a different DebuggerServer.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48807", "files": ["devtools/server/actors/object.js", "devtools/server/tests/browser/browser.ini"], "git_node": null, "git_parents": [null], "node": "1177ff81eab7605c5aba6af677257e4705b2e6f4", "parents": ["e9dada6878890675b3bcb6decbf65a1d7e2b3fae"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1586201 - Add a function to get a nodeFront from a ContentDomReference. r=pbro,jdescottes.\n\nA function is added on the walker actor that creates a NodeFront\nfrom a ContentDomReference, e.g. an object containing a browsingContextId\nand a unique DOM element identifier.\nA trait is added on the walker actor since the ContentDomReference API was\nonly added in Firefox 69.\nWe then add a function on the toolbox that can return a NodeFront from a\nelement grip.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48808", "files": ["devtools/server/actors/inspector/walker.js", "devtools/shared/fronts/inspector.js", "devtools/shared/specs/inspector.js"], "git_node": null, "git_parents": [null], "node": "ba7304bbc693865f655b9fb4c4196fdda44192b9", "parents": ["1177ff81eab7605c5aba6af677257e4705b2e6f4"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1587701 - Use toolbox's getNodeFrontFromNodeGrip in highlight method. r=pbro.\n\nThis allow us to retrieve the appropriate nodeFront from a grip,\nand thus the right highlighterFront to highlight a given element.\nWe also need to cache the highlighter front used for the current\nhighlight, as we need to use the same front for unhighlighting,\nand this saves us a few server round-trip to get the right front.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48809", "files": ["devtools/client/framework/toolbox.js"], "git_node": null, "git_parents": [null], "node": "045d50e021e41f102b08eef67ab1352db67ff027", "parents": ["ba7304bbc693865f655b9fb4c4196fdda44192b9"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1577783 - Use inspectorFront's getNodeFrontFromNodeGrip function in WebConsole's openNodeInInspector. r=pbro,rcaliman.\n\nWe retrieve the right NodeFront from a given grip, which we\ncan then tell the inspector panel to select.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48810", "files": ["devtools/client/webconsole/webconsole.js"], "git_node": null, "git_parents": [null], "node": "3eec673dbb60bff7fd8f4877103d953963317fe5", "parents": ["045d50e021e41f102b08eef67ab1352db67ff027"], "tags": []}, {"author": "Razvan Maries \u003crmaries@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 66b01a30ed12 (bug 1589015) for causing perma fails on browser_trackingUI_categories.js. CLOSED TREE", "files": ["browser/base/content/browser-siteProtections.js", "browser/components/controlcenter/content/protectionsPanel.inc.xul", "browser/locales/en-US/chrome/browser/browser.dtd"], "git_node": null, "git_parents": [null], "node": "c3e12bc6ff0a94c7885c943f9085b7b1b7872f16", "parents": ["3eec673dbb60bff7fd8f4877103d953963317fe5"], "tags": []}, {"author": "Razvan Maries \u003crmaries@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 239ff6e79980 (bug 1572884) for causing perma fails on audionode-channel-rules.html. CLOSED TREE", "files": ["dom/media/AudioChannelFormat.h", "dom/media/webaudio/test/test_mixingRules.html"], "git_node": null, "git_parents": [null], "node": "76b61767def8d6a0458a36d88230a57741568d83", "parents": ["c3e12bc6ff0a94c7885c943f9085b7b1b7872f16"], "tags": []}, {"author": "Benjamin Forehand Jr \u003cbforehand@mozilla.com\u003e", "branch": "default", "desc": "Bug 1586376  - Update ping server URL in telemetry-tests-client; r=raphael\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49452", "files": ["toolkit/components/telemetry/tests/marionette/harness/telemetry_harness/runner.py"], "git_node": null, "git_parents": [null], "node": "1717f4252ed3c0751aec1a6c898e757221167c0e", "parents": ["76b61767def8d6a0458a36d88230a57741568d83"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1413203 - The css for about:networking is not loading in Android r=Gijs\n\n* Make about:networking work on mobile\n* I used the aboutMemory.css file as a guide for doing this\n* The mobile CSS does not include the common.css, since that doesn't seem to work. But at least now the interfaces is functional. We should make it look nice in a follow-up.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49582", "files": ["toolkit/content/aboutNetworking.xhtml", "toolkit/themes/mobile/global/aboutNetworking.css", "toolkit/themes/mobile/jar.mn", "toolkit/themes/shared/jar.inc.mn", "toolkit/themes/shared/mozapps.inc.mn"], "git_node": null, "git_parents": [null], "node": "1e81cd6ced8435144b4daebea285d0e27ca4b0c9", "parents": ["1717f4252ed3c0751aec1a6c898e757221167c0e"], "tags": []}, {"author": "Christian Holler \u003ccholler@mozilla.com\u003e", "branch": "default", "desc": "Bug 1589612 - Remove remaining lsan_dir from WPT mach command. r=jgraham\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49721", "files": ["testing/web-platform/mach_commands.py"], "git_node": null, "git_parents": [null], "node": "0fe30da27a7879eee974e06166147e55e817130a", "parents": ["1e81cd6ced8435144b4daebea285d0e27ca4b0c9"], "tags": []}, {"author": "Ayrton Munoz \u003ca.munoz3327@gmail.com\u003e", "branch": "default", "desc": "Bug 1581777 - IterateCellCallback passes cell as separate void* pointer and trace kind r=jonco\n\npassing cell to IterateCellCallback as GCCellPtr instead of separate void*\npointer and trace kind\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46303", "files": ["js/src/gc/GC.h", "js/src/gc/PublicIterators.cpp", "js/src/jsfriendapi.cpp", "js/src/vm/MemoryMetrics.cpp"], "git_node": null, "git_parents": [null], "node": "f3dc2fd05ffe20684f9f5ba1c1e2341b9ac86b36", "parents": ["0fe30da27a7879eee974e06166147e55e817130a"], "tags": []}, {"author": "Petr Sumbera \u003cpetr.sumbera@oracle.com\u003e", "branch": "default", "desc": "Bug 1527597 - ReserveProcessExecutableMemory should use MAP_NORESERVE r=jandem\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49612", "files": ["js/src/jit/ProcessExecutableMemory.cpp"], "git_node": null, "git_parents": [null], "node": "8cc5f974bbd0b29acccbdd54431d0a64d8fd70c1", "parents": ["f3dc2fd05ffe20684f9f5ba1c1e2341b9ac86b36"], "tags": []}, {"author": "Razvan Maries \u003crmaries@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 1e81cd6ced84 (bug 1413203) for causing perma fails on test_css_chrome_load_access.html. CLOSED TREE", "files": ["toolkit/content/aboutNetworking.xhtml", "toolkit/themes/mobile/global/aboutNetworking.css", "toolkit/themes/mobile/jar.mn", "toolkit/themes/shared/jar.inc.mn", "toolkit/themes/shared/mozapps.inc.mn"], "git_node": null, "git_parents": [null], "node": "b37f26560af018441cba447894ef75a7e8bccfcf", "parents": ["8cc5f974bbd0b29acccbdd54431d0a64d8fd70c1"], "tags": []}, {"author": "Sebastian Streich \u003csstreich@mozilla.com\u003e", "branch": "default", "desc": "Bug 1584204 Remove requestingLocation from nsContentPolicy.cpp r=ckerschb\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47255", "files": ["dom/base/nsContentPolicy.cpp"], "git_node": null, "git_parents": [null], "node": "6e923be2cf6ac05eb6fcc38cd7dfe1fbb2948b30", "parents": ["b37f26560af018441cba447894ef75a7e8bccfcf"], "tags": []}, {"author": "Jonathan Kingston \u003cjkt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1585582 - Don't parse manifest when storage is disabled r=baku\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47958", "files": ["dom/base/nsContentSink.cpp"], "git_node": null, "git_parents": [null], "node": "d30cbc91bfdabd171df3845c2fbd6fda683acace", "parents": ["6e923be2cf6ac05eb6fcc38cd7dfe1fbb2948b30"], "tags": []}, {"author": "Christoph Kerschbaumer \u003cckerschb@christophkerschbaumer.com\u003e", "branch": "default", "desc": "Bug 1583044: Make nsMozIconURI serializeable. r=valentin\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49442", "files": ["dom/security/test/crashtests/1583044.html", "dom/security/test/crashtests/crashtests.list", "image/decoders/icon/nsIconURI.cpp", "image/decoders/icon/nsIconURI.h", "netwerk/build/nsNetCID.h", "testing/crashtest/crashtests.list"], "git_node": null, "git_parents": [null], "node": "fb8fb91d2a9685c841bfdf16c2060fd1c455eff1", "parents": ["d30cbc91bfdabd171df3845c2fbd6fda683acace"], "tags": []}, {"author": "Carolina \u003ccarolina.jimenez.g@gmail.com\u003e", "branch": "default", "desc": "Bug 1588531 - Fixes elements with array sizes equals 0 being rendered and updates test to check non-empty fields being rendered.r=johannh,fluent-reviewers,flod\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49675", "files": ["toolkit/components/certviewer/content/certviewer.js", "toolkit/components/certviewer/tests/browser/browser_checkNonEmptyFields.js", "toolkit/locales/en-US/toolkit/about/certviewer.ftl"], "git_node": null, "git_parents": [null], "node": "2d7f0b8a65ddffaf5c89af31eb68eb777b921123", "parents": ["fb8fb91d2a9685c841bfdf16c2060fd1c455eff1"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1587803 - Check BrowserContentHandler.jsm::doSearch() uses the private engine when appropriate. r=Standard8\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49446", "files": ["browser/base/content/browser.js", "browser/components/BrowserContentHandler.jsm", "browser/components/search/test/browser/browser_contextSearchTabPosition.js", "browser/components/search/test/browser/browser_contextmenu.js", "browser/modules/BrowserUsageTelemetry.jsm", "browser/modules/test/browser/browser_UsageTelemetry_content.js"], "git_node": null, "git_parents": [null], "node": "06644c68c7e7125504d2f78565a906cf445a3e98", "parents": ["2d7f0b8a65ddffaf5c89af31eb68eb777b921123"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1413203 - The css for about:networking is not loading in Android r=Gijs\n\n* Make about:networking work on mobile\n* I used the aboutMemory.css file as a guide for doing this\n* The mobile CSS does not include the common.css, since that doesn't seem to work. But at least now the interfaces is functional. We should make it look nice in a follow-up.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49582", "files": ["editor/libeditor/tests/test_css_chrome_load_access.html", "toolkit/content/aboutNetworking.xhtml", "toolkit/themes/mobile/global/aboutNetworking.css", "toolkit/themes/mobile/jar.mn", "toolkit/themes/shared/jar.inc.mn", "toolkit/themes/shared/mozapps.inc.mn"], "git_node": null, "git_parents": [null], "node": "d7ca36975685a0fe2de39aef067bf3276aead630", "parents": ["06644c68c7e7125504d2f78565a906cf445a3e98"], "tags": []}, {"author": "Razvan Maries \u003crmaries@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset fb8fb91d2a96 (bug 1583044) for causing perma fails on test_DownloadUtils.js and reftests. CLOSED TREE", "files": ["dom/security/test/crashtests/1583044.html", "dom/security/test/crashtests/crashtests.list", "image/decoders/icon/nsIconURI.cpp", "image/decoders/icon/nsIconURI.h", "netwerk/build/nsNetCID.h", "testing/crashtest/crashtests.list"], "git_node": null, "git_parents": [null], "node": "1d5595ad79ead8bf61b5331e2f88bbbdad1cbf18", "parents": ["d7ca36975685a0fe2de39aef067bf3276aead630"], "tags": []}, {"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Bug 1587622 - Use MOZ_ASSERT_UNREACHABLE() instead of double-conversion's UNREACHABLE() in DOM media code. r=karlt\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48880", "files": ["dom/html/HTMLMediaElement.cpp", "dom/media/MediaDecoder.cpp"], "git_node": null, "git_parents": [null], "node": "bd3e04ade52aa7a1cd9847672cc91633154f3961", "parents": ["1d5595ad79ead8bf61b5331e2f88bbbdad1cbf18"], "tags": []}, {"author": "Paul Adenot \u003cpaul@paul.cx\u003e", "branch": "default", "desc": "Bug 1499597 - Don't clamp the Q of a BiquadFilterNode when in low-pass and high-pass mode. r=karlt\n\nBug 1265395 implemented the new filter equations from\nhttps://github.com/webaudio/web-audio-api/commit/a6842f2f733911a8ac6b330a405eac19878adc15,\nbut missed removing the clamping.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49600", "files": ["dom/media/webaudio/blink/Biquad.cpp"], "git_node": null, "git_parents": [null], "node": "6ecf31593df4637e62d0e053fe9ce1d8885258b2", "parents": ["bd3e04ade52aa7a1cd9847672cc91633154f3961"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1584963 - Make `nsTextEditorState` not manage `TextInputListener` by itself when chrome script emulates user input r=m_kato\n\nWhen `nsTextEditorState::SetValue()` is called with `eSetValue_BySetUserInput`,\nwe emulate user input.  I.e., keep using transaction manager of the editor,\nevents fired while handling user input should be fired.\n\nCurrently, `nsTextEditorState::SetValue()` suppresses multiple state handling\nwhile setting value with calling `mTextListener-\u003eSettingValue(true)`.  This\nis why `\"input\"` event listeners cannot retrieve the latest state of validation\nif `inputType` is `\"insertReplacementText\"`.\n\nThis patch makes it keep managing `mTextListener` when setting the value\nprogramatically.   Otherwise, i.e., it emulates user input, editor should\nmanage it from `EditorBase::NotifyEditorObservers()` instead so that this\npatch makes it not managing `mTextListener` in such case.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49571", "files": ["dom/html/nsTextEditorState.cpp", "toolkit/components/satchel/test/mochitest.ini", "toolkit/components/satchel/test/test_form_autocomplete_validation_at_input_event.html"], "git_node": null, "git_parents": [null], "node": "f809ef4ac99402dbd3a4128687abe2cd5b18cf28", "parents": ["6ecf31593df4637e62d0e053fe9ce1d8885258b2"], "tags": []}, {"author": "Kris Taeleman \u003cktaeleman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1589218 - Add Pixel 2 XL to webrender allowed devices. r=jnicol\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49495", "files": ["widget/android/GfxInfo.cpp"], "git_node": null, "git_parents": [null], "node": "4f1b96bc6b9a175b2b0329ffcc763fb84707eaee", "parents": ["f809ef4ac99402dbd3a4128687abe2cd5b18cf28"], "tags": []}, {"author": "Kershaw Chang \u003ckershaw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1584165 - Calaulate network id with delay after network changed r=michal\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48446", "files": ["netwerk/system/mac/nsNetworkLinkService.h", "netwerk/system/mac/nsNetworkLinkService.mm"], "git_node": null, "git_parents": [null], "node": "c90d49953a5329e6fb4a5b13a650607187ea3ee9", "parents": ["4f1b96bc6b9a175b2b0329ffcc763fb84707eaee"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1577896 - Fix GridElementResizer on overflowing container. r=fvsch.\n\nWe remove the pseudo elements we were using to draw the borders and\nput them on the grid elements instead.\nWe make the GridElementResizer 6px and translate it so there's\nhandle on \"both sides\" of the splitter.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D45302", "files": ["devtools/client/shared/components/splitter/GridElementResizer.css", "devtools/client/themes/webconsole.css", "devtools/client/webconsole/components/App.css"], "git_node": null, "git_parents": [null], "node": "8ddcca74cb17d67e1ac21a5198b3665de82d0db9", "parents": ["c90d49953a5329e6fb4a5b13a650607187ea3ee9"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1589592 - Fix Console Editor styling in RTL languages. r=Honza.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49717", "files": ["devtools/client/webconsole/components/Input/JSTerm.js"], "git_node": null, "git_parents": [null], "node": "e87688a24f47a4c00aebefeeca2082f4d36d6700", "parents": ["8ddcca74cb17d67e1ac21a5198b3665de82d0db9"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1589592 - Fix console editor Run button icon in RTL. r=Honza.\n\nSince we want the button to be placed on the right side\nin RTL languages and we don't have logical properties\non background-position yet, we display the icon in\na :before pseudo element which will adapt for both LTR\nand RTL languages. The icon is then mirrored in RTL.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49718", "files": ["devtools/client/webconsole/components/App.css"], "git_node": null, "git_parents": [null], "node": "81c1d93d635a60de2d66e0958713fdc19fd1437d", "parents": ["e87688a24f47a4c00aebefeeca2082f4d36d6700"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1589592 - Fix GridElementWidthResizer in RTL languages. r=Honza.\n\nWhen starting to resize, we store the direction of the\ncontrolled element in the state.\nWhen resizing, we check the current element direction\nto set the appropriate width to the controlled element.\nA test is added to ensure the resizer works as expected\nin RTL languages elements.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49719", "files": ["devtools/client/shared/components/splitter/GridElementWidthResizer.js", "devtools/client/shared/components/test/mochitest/chrome.ini", "devtools/client/shared/components/test/mochitest/test_GridElementWidthResizer_RTL.html"], "git_node": null, "git_parents": [null], "node": "3517b23f7cc488f367d7aa126938b257b7416184", "parents": ["81c1d93d635a60de2d66e0958713fdc19fd1437d"], "tags": []}, {"author": "Liang-Heng Chen \u003cxeonchen@gmail.com\u003e", "branch": "default", "desc": "Bug 1585615 - check content blocking event parameter bitwisely; r=johannh\n\ncontent blocking event should be checked bitwisely to see if targeted bits are all matched.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48170", "files": ["browser/components/newtab/lib/ASRouterTriggerListeners.jsm", "browser/components/newtab/lib/CFRMessageProvider.jsm", "browser/components/newtab/test/browser/browser_asrouter_trigger_listeners.js"], "git_node": null, "git_parents": [null], "node": "747c5f90f2c3916f6d7bc537bd25deac589ae3b9", "parents": ["3517b23f7cc488f367d7aa126938b257b7416184"], "tags": []}, {"author": "Olli Pettay \u003cOlli.Pettay@helsinki.fi\u003e", "branch": "default", "desc": "Bug 1589345 - Fix a leftover comment to tell what PrioritizedEventQueue::mActive actually does, r=farre\n\nEnsureIsActive is called in two places, one is for non-idle tasks, the other for idle tasks\nhttps://searchfox.org/mozilla-central/rev/97976753a21c1731e18177de9e5ce78ea3b3da2d/xpcom/threads/PrioritizedEventQueue.cpp#212-214,286,288,303\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49592", "files": ["xpcom/threads/PrioritizedEventQueue.h"], "git_node": null, "git_parents": [null], "node": "c1b0190a53476e04a3f79d056d177af0c30adfa0", "parents": ["747c5f90f2c3916f6d7bc537bd25deac589ae3b9"], "tags": []}, {"author": "Harry Twyford \u003chtwyford@mozilla.com\u003e", "branch": "default", "desc": "Bug 1578445 - Add roles and aria attributes to tip elements. r=dao,fluent-reviewers,Gijs,Jamie\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47980", "files": ["accessible/tests/browser/events/browser_test_focus_urlbar.js", "browser/components/urlbar/UrlbarView.jsm", "browser/locales/en-US/browser/browser.ftl"], "git_node": null, "git_parents": [null], "node": "7f379c7775ca17056153d034647146b383bb6912", "parents": ["c1b0190a53476e04a3f79d056d177af0c30adfa0"], "tags": []}, {"author": "Alexis Beingessner \u003ca.beingessner@gmail.com\u003e", "branch": "default", "desc": "Bug 1573710 - make window resizing more robust to races. r=sotaro\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49634", "files": ["widget/windows/WinCompositorWidget.cpp"], "git_node": null, "git_parents": [null], "node": "f6ca531ca5b2f282573ba0e1a9ca0e9f06046ac1", "parents": ["7f379c7775ca17056153d034647146b383bb6912"], "tags": []}, {"author": "Christian Holler \u003ccholler@mozilla.com\u003e", "branch": "default", "desc": "Bug 1589207 - Suppress two leaks in WebPlatform tests. r=mccr8\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49640", "files": ["testing/web-platform/meta/pointerevents/__dir__.ini"], "git_node": null, "git_parents": [null], "node": "6a3fa624359372522de13d26c05f4884f3f89ce0", "parents": ["f6ca531ca5b2f282573ba0e1a9ca0e9f06046ac1"], "tags": []}, {"author": "Tom Tung \u003cttung@mozilla.com\u003e", "branch": "default", "desc": "Bug 1583251 - P1 - Propagate the targetAgentClusterId to PostMessageEvent::Run(); r=nika\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48347", "files": ["docshell/base/BrowsingContext.cpp", "dom/base/PostMessageEvent.cpp", "dom/base/PostMessageEvent.h", "dom/base/nsGlobalWindowOuter.cpp", "dom/base/nsGlobalWindowOuter.h"], "git_node": null, "git_parents": [null], "node": "9e9eaa78c43664445e620c82217f4aa6224f82ab", "parents": ["6a3fa624359372522de13d26c05f4884f3f89ce0"], "tags": []}, {"author": "Tom Tung \u003cttung@mozilla.com\u003e", "branch": "default", "desc": "Bug 1583251 - P2 - Fix some format nits or naming nits for StructuredClone::Write; r=nika,lth\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48348", "files": ["dom/base/StructuredCloneHolder.cpp", "dom/base/StructuredCloneHolder.h", "js/public/StructuredClone.h"], "git_node": null, "git_parents": [null], "node": "5d5e3dc1711872b853b30dd061b6bd9030df4f45", "parents": ["9e9eaa78c43664445e620c82217f4aa6224f82ab"], "tags": []}, {"author": "Tom Tung \u003cttung@mozilla.com\u003e", "branch": "default", "desc": "Bug 1583251 - P3 - Check if it is okay to allow shared memory while deserializing; r=nika,lth\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48349", "files": ["dom/base/PostMessageEvent.cpp", "dom/base/StructuredCloneHolder.cpp", "dom/base/StructuredCloneHolder.h", "dom/indexedDB/IDBObjectStore.cpp", "js/public/StructuredClone.h", "js/src/builtin/TestingFunctions.cpp", "js/src/fuzz-tests/testStructuredCloneReader.cpp", "js/src/jsapi-tests/testMappedArrayBuffer.cpp", "js/src/vm/StructuredClone.cpp"], "git_node": null, "git_parents": [null], "node": "248ad59168dd79138efdf8bed3d5863473142b75", "parents": ["5d5e3dc1711872b853b30dd061b6bd9030df4f45"], "tags": []}, {"author": "Tom Tung \u003cttung@mozilla.com\u003e", "branch": "default", "desc": "Bug 1583251 - P4 - Allow deserialize shared memory for Workers; r=nika,perry\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48560", "files": ["dom/workers/MessageEventRunnable.cpp"], "git_node": null, "git_parents": [null], "node": "0113c698b44d431fe02d3f73bea90d65e69df76b", "parents": ["248ad59168dd79138efdf8bed3d5863473142b75"], "tags": []}, {"author": "Tom Tung \u003cttung@mozilla.com\u003e", "branch": "default", "desc": "Bug 1583251 - P5 - Having some js tests to verify the deserialize function; r=nika,lth\n\nDepends on D48560\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48561", "files": ["js/src/builtin/TestingFunctions.cpp", "js/src/jit-test/tests/wasm/memory-cloning.js", "js/src/tests/non262/extensions/clone-sab.js", "js/src/tests/non262/extensions/sharedtypedarray.js"], "git_node": null, "git_parents": [null], "node": "bfe390ad771b5bbaa5515e376dac91373c7837bd", "parents": ["0113c698b44d431fe02d3f73bea90d65e69df76b"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1586991 part 23 - Use mozilla::Range\u003c\u003e in IsTypedArrayIndex, stop assuming null-terminated atoms. r=anba\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49607", "files": ["js/src/vm/TypedArrayObject.cpp", "js/src/vm/TypedArrayObject.h"], "git_node": null, "git_parents": [null], "node": "4c43b1c81af598a2dc2a11abf91214360d03c300", "parents": ["bfe390ad771b5bbaa5515e376dac91373c7837bd"], "tags": []}, {"author": "Andrew Halberstadt \u003cahalberstadt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1583360 - [mozbuild] Make reader.find_sphinx_variables a little more generic, r=nalexander\n\nThe BuildReader's 'find_sphinx_variables' function is hardcoded to look for the\nSPHINX_TREES and SPHINX_PYTHON_PACKAGE_DIRS variables. But it's otherwise\nimplemented to find any arbitrary variable (as long as they are a simple list\nor dict).\n\nThis change simply moves the variable name(s) to the function call. The comment\nabout possibly wanted to use a higher level AST library to parse other kinds of\nvariables still applies, but for now this change is good enough to suit my\nneeds.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48424", "files": ["python/mozbuild/mozbuild/frontend/reader.py", "tools/docs/moztreedocs/__init__.py"], "git_node": null, "git_parents": [null], "node": "3cb0c1d7e71689d1f0198855b5b6064203aba8fc", "parents": ["4c43b1c81af598a2dc2a11abf91214360d03c300"], "tags": []}, {"author": "Andrew Halberstadt \u003cahalberstadt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1583353 - [taskgraph] Remove 'mozharness.chunking-args' key from the test_description_schema, r=gbrown\n\nThis key doesn't appear to be used by anything. Let's get rid of it to remove\nsome of the complexity around chunking.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48422", "files": ["taskcluster/taskgraph/transforms/job/mozharness_test.py", "taskcluster/taskgraph/transforms/tests.py"], "git_node": null, "git_parents": [null], "node": "78cc1e5a395fec57908dd3ac11431c317690f208", "parents": ["3cb0c1d7e71689d1f0198855b5b6064203aba8fc"], "tags": []}, {"author": "Tomislav Jovanovic \u003ctomica@gmail.com\u003e", "branch": "default", "desc": "Bug 1589266 - Fix test_ext_new_tab_processType.html with fission r=rpl\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49504", "files": ["toolkit/components/extensions/test/mochitest/mochitest-common.ini", "toolkit/components/extensions/test/mochitest/test_ext_new_tab_processType.html"], "git_node": null, "git_parents": [null], "node": "fcf2e9fabd1bdeca4b32433d2ec94145c197a29f", "parents": ["78cc1e5a395fec57908dd3ac11431c317690f208"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1580750 - Enable browser_serviceWorker.js in fission-debug r=kershaw\n\nIt was previously causing debug leaks in fission, but those appear to have been fixed.\n\nDifferen