ts r=release a=l10n-bump DONTBUILD\n\neo -\u003e 4b561b1491e1\nit -\u003e 9e6a5cb3c8fd", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "e8d0a3cd4d67bea7d0618da4f66587c007455fd8", "parents": ["f0ea8693c655a3884f112be545c024dbc7ca43e6"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\neo -\u003e 4b561b1491e1\nit -\u003e 9e6a5cb3c8fd", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "83216972660f73657ec5806dd71a6eafb2a4c553", "parents": ["e8d0a3cd4d67bea7d0618da4f66587c007455fd8"], "tags": []}], "date": 1574067645, "git_changesets": [null, null], "user": "ffxbld"}, "12318": {"changesets": [{"author": "Alex Chronopoulos \u003cachronop@gmail.com\u003e", "branch": "default", "desc": "Bug 1596064 - Only enable MediaCapabilities performance benchmarks on Nightly. r=jya a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52834", "files": ["modules/libpref/init/StaticPrefList.yaml"], "git_node": null, "git_parents": [null], "node": "b1c5eb22db7f6649faf938768d956f3d2cda5d54", "parents": ["83216972660f73657ec5806dd71a6eafb2a4c553"], "tags": []}, {"author": "Alex Chronopoulos \u003cachronop@gmail.com\u003e", "branch": "default", "desc": "Bug 1596064 - Remove any access on the database when pref is off. r=jya a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52984", "files": ["dom/media/MediaFormatReader.cpp", "dom/media/mediacapabilities/DecoderBenchmark.cpp"], "git_node": null, "git_parents": [null], "node": "437e904693bcffba0a72c5a7191f1e7ba9490be4", "parents": ["b1c5eb22db7f6649faf938768d956f3d2cda5d54"], "tags": []}, {"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 1578745 - Introduce a preference to enable fission frame inspection in DevTools. r=nchevobbe a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50666", "files": ["browser/app/profile/firefox.js", "devtools/shared/fronts/inspector.js"], "git_node": null, "git_parents": [null], "node": "b92fd849eadcf579743bb5b2c4502bc2e4dd8f0f", "parents": ["437e904693bcffba0a72c5a7191f1e7ba9490be4"], "tags": []}, {"author": "harry \u003chtwyford@mozilla.com\u003e", "branch": "default", "desc": "Bug 1591839 - Close Touch Bar race condition. r=spohl a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52361", "files": ["widget/cocoa/nsTouchBar.h", "widget/cocoa/nsTouchBar.mm", "widget/cocoa/nsTouchBarUpdater.mm"], "git_node": null, "git_parents": [null], "node": "152811e4837c6198b12a9fcd6fe6d86034d26b0f", "parents": ["b92fd849eadcf579743bb5b2c4502bc2e4dd8f0f"], "tags": []}, {"author": "Mark Hammond \u003cmhammond@skippinet.com.au\u003e", "branch": "default", "desc": "Bug 1594704 - ensure sync data choices made before connecting sync are honored. r=eoger a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D53138", "files": ["services/sync/modules/service.js", "services/sync/tests/unit/test_service_sync_updateEnabledEngines.js"], "git_node": null, "git_parents": [null], "node": "c3c19a5d9e0859211627f8889fbd830709d8df32", "parents": ["152811e4837c6198b12a9fcd6fe6d86034d26b0f"], "tags": []}, {"author": "Jan Odvarko \u003codvarko@gmail.com\u003e", "branch": "default", "desc": "Bug 1573805 - Enable WS Monitor in all channels r=Harald a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52333", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "675029eeb048dfe28c948ff750fc1d3df1d5a758", "parents": ["c3c19a5d9e0859211627f8889fbd830709d8df32"], "tags": []}, {"author": "Jan Odvarko \u003codvarko@gmail.com\u003e", "branch": "default", "desc": "Bug 1583446 - Enabling Search in all channels r=Harald a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52334", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "c91f90179bb4ef0606763349296898b71dcbb905", "parents": ["675029eeb048dfe28c948ff750fc1d3df1d5a758"], "tags": []}, {"author": "Toshihito Kikuchi \u003ctkikuchi@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588975 - Replace ShellExecuteExW with mozilla::ShellExecuteByExplorer. r=aklotz,asuth a=pascalc\n\nThe launcher process turns on the `PreferSystem32Images` mitigation policy for\nthe browser process.  Since the mitigation policy is inherited, a process launched\nby the browser process also has `PreferSystem32Images`.  If an application which\ndoes not support `PreferSystem32Images`, such as Skype for Business, is launched\nvia a hyperlink, a custom uri, or a downloaded file, it would fail to launch.\n\nBug 1567614 fixed this issue by introducing `mozilla::ShellExecuteByExplorer` to\n`nsMIMEInfoWin::LoadUriInternal`.  This patch introduces\n`mozilla::ShellExecuteByExplorer` to two more places.\n\n1. xul!nsLocalFile::Launch\nThis is invoked when a user opens a file from the Download Library, or a user\nopens a downloaded file with the default application without saving it.\n\n2. xul!nsMIMEInfoWin::LaunchWithFile\nThis is invoked when a user opens a downloaded file with a custom application\n(configured in about:preference) without saving it.\n\n*Why does this patch change worker.js?*\n\nThe mochitest dom/tests/browser/browser_test_new_window_from_content.js failed\nif it was executed after dom/serviceworkers/test/browser_download.js in the\nsame batch.  This was because browser_download.js launched Notepad to open\nfake_download.bin.txt, preventing a new window from being opened in the\nforeground in browser_test_new_window_from_content.js.\n\nThe test browser_download.js can verify downloaded data without opening an\nassociated application.  So this patch adds the content-type to the response\nheader in order not to open Notepad on Windows.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52567", "files": ["dom/serviceworkers/test/download/worker.js", "uriloader/exthandler/win/nsMIMEInfoWin.cpp", "widget/windows/ShellHeaderOnlyUtils.h", "xpcom/io/nsLocalFileWin.cpp"], "git_node": null, "git_parents": [null], "node": "61750ab393d0977b404defb8af9647386ff5bffc", "parents": ["c91f90179bb4ef0606763349296898b71dcbb905"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1594136 - Add crashtest. r=padenot a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52521", "files": ["dom/media/tests/crashtests/1594136.html", "dom/media/tests/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "ff1db771cc637f454efb7ad42e4bd7f1b840f6d3", "parents": ["61750ab393d0977b404defb8af9647386ff5bffc"], "tags": []}, {"author": "Andreas Pehrson \u003capehrson@mozilla.com\u003e", "branch": "default", "desc": "Bug 1594136 - Check for ended track in MediaStreamTrackAudioSourceNode. r=padenot a=pascalc\n\nDepends on D52521\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52522", "files": ["dom/media/webaudio/MediaStreamTrackAudioSourceNode.cpp"], "git_node": null, "git_parents": [null], "node": "c61bae31a7293fd3df770ada76e310df57a15118", "parents": ["ff1db771cc637f454efb7ad42e4bd7f1b840f6d3"], "tags": []}, {"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1596193 - Replace outdated references to XUL textbox. r=dao a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D53177", "files": ["accessible/html/HTMLFormControlAccessible.h", "browser/base/content/contentSearchUI.js", "browser/components/places/content/bookmarkProperties.js", "browser/components/places/content/places.js", "browser/components/preferences/connection.js", "security/manager/pki/resources/content/certViewer.xul", "toolkit/content/xul.css"], "git_node": null, "git_parents": [null], "node": "01c5734e16abbb9d1cef24f2f08bdfb00af26e5d", "parents": ["c61bae31a7293fd3df770ada76e310df57a15118"], "tags": []}], "date": 1574076214, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null], "user": "cbrindusan@mozilla.com"}, "12319": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nast -\u003e 30bd68198146\nit -\u003e 1878af47a45c\npt-PT -\u003e e59c2f9816ee", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "e67642bcd494a3641bbe65bba83f02e04c74468b", "parents": ["01c5734e16abbb9d1cef24f2f08bdfb00af26e5d"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nast -\u003e 30bd68198146\nit -\u003e 1878af47a45c\npt-PT -\u003e e59c2f9816ee", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "d3c5dbe0e0b781940502f55fff818d9cfa6bc706", "parents": ["e67642bcd494a3641bbe65bba83f02e04c74468b"], "tags": []}], "date": 1574082043, "git_changesets": [null, null], "user": "ffxbld"}, "12320": {"changesets": [{"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1592321 - Collect a sanitized path for files doing eval() on Windows in the same manner as untrusted modules r=aklotz a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50957", "files": ["dom/security/nsContentSecurityUtils.cpp", "dom/security/test/gtest/TestFilenameEvalParser.cpp", "toolkit/components/telemetry/Events.yaml", "widget/windows/WinUtils.cpp", "widget/windows/WinUtils.h"], "git_node": null, "git_parents": [null], "node": "89525246903ffa571321e2621765be11e34446df", "parents": ["d3c5dbe0e0b781940502f55fff818d9cfa6bc706"], "tags": []}, {"author": "Matthew Noorenberghe \u003cmozilla@noorenberghe.ca\u003e", "branch": "default", "desc": "Bug 1590622 - Prefer a domain match over a scheme match when deduping logins. r=sfoster a=pascalc\n\nOn an https: page it's more important to use the login was from the same hostPort than to use an https: login from a different subdomain.\n\nThis fixes autocomplete to show \"From this website\" and also fixes autofill in the event that there was a duplicate username+password combo saved on an different https: subdomain while previously saving that combo on the http: version of the same hostPort.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52802", "files": ["toolkit/components/passwordmgr/LoginManagerParent.jsm", "toolkit/components/passwordmgr/test/mochitest/test_autofill_https_upgrade.html", "toolkit/components/passwordmgr/test/unit/test_LoginManagerParent_searchAndDedupeLogins.js", "toolkit/components/passwordmgr/test/unit/test_dedupeLogins.js"], "git_node": null, "git_parents": [null], "node": "74f713d368c1f05a78647d30ea4652d89c70cc8a", "parents": ["89525246903ffa571321e2621765be11e34446df"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1591409 - improve keyboard a11y checks by avoiding false positive for interactive elements when they are focusable. r=nchevobbe a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52201", "files": ["devtools/server/actors/accessibility/audit/keyboard.js", "devtools/server/tests/browser/browser_accessibility_keyboard_audit.js", "devtools/server/tests/browser/doc_accessibility_keyboard_audit.html"], "git_node": null, "git_parents": [null], "node": "8b6aaf2ebd6b880be242aa34b9c7ea2441c7a3d7", "parents": ["74f713d368c1f05a78647d30ea4652d89c70cc8a"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1594885 - Basic scaffolding for whatsnew panel in DevTools r=jlast,nchevobbe a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52733", "files": ["browser/app/profile/firefox.js", "devtools/client/definitions.js", "devtools/client/framework/test/browser_toolbox_toolbar_reorder_by_dnd.js", "devtools/client/framework/test/browser_toolbox_toolbar_reorder_with_extension.js", "devtools/client/framework/test/browser_toolbox_toolbar_reorder_with_hidden_extension.js", "devtools/client/framework/test/browser_toolbox_tools_per_toolbox_registration.js", "devtools/client/jar.mn", "devtools/client/moz.build", "devtools/client/whats-new/index.html", "devtools/client/whats-new/moz.build", "devtools/client/whats-new/panel.js", "devtools/client/whats-new/src/base.css", "devtools/client/whats-new/src/main.js", "devtools/client/whats-new/src/moz.build", "devtools/client/whats-new/src/whats-new.css", "toolkit/components/telemetry/Events.yaml"], "git_node": null, "git_parents": [null], "node": "eff56012230f4e3889a606402dfbe3f3b3adbd91", "parents": ["8b6aaf2ebd6b880be242aa34b9c7ea2441c7a3d7"], "tags": []}, {"author": "Jason Laster \u003cjlaster@mozilla.com\u003e", "branch": "default", "desc": "Bug 1594885 - What's New in DevTools Panel in Firefox 71. r=jdescottes,victoria a=pascalc\n\nDepends on D52733\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52429", "files": ["devtools/client/whats-new/src/base.css", "devtools/client/whats-new/src/main.js", "devtools/client/whats-new/src/moz.build", "devtools/client/whats-new/src/whats-new.css"], "git_node": null, "git_parents": [null], "node": "fd6da23163020fc2f1046a72343e0d9c289cd0c3", "parents": ["eff56012230f4e3889a606402dfbe3f3b3adbd91"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1596133 - AbuseReporter.queryAMOAddonDetails should normalize type 'statictheme' into type 'theme'. r=mixedpuppy a=pascalc\n\nThe addon details returned from the AMO API endpoint for webextensions static themes is type \"statictheme\",\nbut for an installed WebExtension static theme we expect addon.type to be \"theme\", and so\nAbuseReporter.queryAMOAddonDetails should normalize the type received to ensure it matches what\nFirefox expects.\n\nThis fix is needed to ensure that reporting a \"not installed\" theme from AMO works as expected\n(see https://github.com/mozilla/addons-frontend/issues/8762#issuecomment-553430081).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52853", "files": ["toolkit/mozapps/extensions/AbuseReporter.jsm", "toolkit/mozapps/extensions/test/xpcshell/test_AbuseReporter.js"], "git_node": null, "git_parents": [null], "node": "b6d13adc8be1ae29bf821bd0d1328d51d526efd5", "parents": ["fd6da23163020fc2f1046a72343e0d9c289cd0c3"], "tags": []}, {"author": "Yura Zenevich \u003cyura.zenevich@gmail.com\u003e", "branch": "default", "desc": "Bug 1594743 - ensure that the keyboard audit does not interfere with other audit types. r=nchevobbe a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52378", "files": ["devtools/server/actors/accessibility/accessible.js"], "git_node": null, "git_parents": [null], "node": "73a6d9d8995febd9286859b6cc80979fa2455cc3", "parents": ["b6d13adc8be1ae29bf821bd0d1328d51d526efd5"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1595091 - Remove alwaysOnTop from the window features used by the abuse report dialog. r=mstriemer a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52896", "files": ["toolkit/mozapps/extensions/AbuseReporter.jsm"], "git_node": null, "git_parents": [null], "node": "9ab34f36f0174f5b475517d155357ec7a84cfdbc", "parents": ["73a6d9d8995febd9286859b6cc80979fa2455cc3"], "tags": []}, {"author": "Patrick Brosset \u003cpbrosset@mozilla.com\u003e", "branch": "default", "desc": "Bug 1596673 - Fixing the position of anchors in a few urls, and replacing one with hacks.m.o r=jlast a=pascalc\n\nSome anchors were appearing before the url params part, which prevented them from\nactually being recognized and the page being scrolled to the right position.\n\nAlso the inactive CSS link went to mdn, but we don't have docs there yet for it. So I\nchanged it to go to hacks.m.o instead.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D53153", "files": ["devtools/client/whats-new/src/main.js"], "git_node": null, "git_parents": [null], "node": "43c1897425fdb073755f005302ec63116e09b8f4", "parents": ["9ab34f36f0174f5b475517d155357ec7a84cfdbc"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1594663 - ensure first plural form for blocked tracker count in English includes a plural form reference so its contents provide value when used as a fallback in other locales, r=ewright a=pascalc l10n=Pike\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52855", "files": ["browser/locales/en-US/chrome/browser/browser.properties"], "git_node": null, "git_parents": [null], "node": "a25e8472d4ff130f59792b0ac11a133b0514aca0", "parents": ["43c1897425fdb073755f005302ec63116e09b8f4"], "tags": []}], "date": 1574088650, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "opoprus@mozilla.com"}, "12321": {"changesets": [{"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Backed out changeset 74f713d368c1 (bug 1590622) for eslint and likely browser-chrome failures in test_autofill_https_upgrade.html a=backout", "files": ["toolkit/components/passwordmgr/LoginManagerParent.jsm", "toolkit/components/passwordmgr/test/mochitest/test_autofill_https_upgrade.html", "toolkit/components/passwordmgr/test/unit/test_LoginManagerParent_searchAndDedupeLogins.js", "toolkit/components/passwordmgr/test/unit/test_dedupeLogins.js"], "git_node": null, "git_parents": [null], "n