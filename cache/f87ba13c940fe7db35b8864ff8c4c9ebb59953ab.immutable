nt/inspector/markup/test/browser_markup_events_react_production_16.2.0_jsx.js", "devtools/client/shared/widgets/tooltip/EventTooltipHelper.js", "devtools/server/actors/inspector/event-collector.js"], "git_node": null, "git_parents": [null], "node": "0762a641fec70adb98249fdcf11b879d9506f118", "parents": ["2671cfed404244eceaca6d6f4c7aae9a4e4c945a"], "tags": []}, {"author": "Logan Smyth \u003cloganfsmyth@gmail.com\u003e", "branch": "default", "desc": "Bug 1581530 - Re-apply usage of .enable/.disable accidentally reverted in Bug 997119. r=jlast\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49382", "files": ["devtools/client/debugger/test/mochitest/browser.ini", "devtools/client/debugger/test/mochitest/browser_dbg-navigation-when-paused.js", "devtools/client/debugger/test/mochitest/examples/doc-navigation-when-paused.html", "devtools/server/actors/thread.js"], "git_node": null, "git_parents": [null], "node": "c29ec6e0195d4af8b30a33e0a72fc70697a018fe", "parents": ["0762a641fec70adb98249fdcf11b879d9506f118"], "tags": []}, {"author": "Daosheng Mu \u003cdaoshengmu@gmail.com\u003e", "branch": "default", "desc": "Bug 1589257 - Update Vive Cosmos controller binding file. r=kip\n\nCosmos changes their controller binding of grip/x/y buttons, so we need to give an update.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49502", "files": ["gfx/vr/service/binding/OpenVRCosmosBinding.h"], "git_node": null, "git_parents": [null], "node": "3c76c7680baaa5c0927a9e0fcdcf91f2ce614dfa", "parents": ["c29ec6e0195d4af8b30a33e0a72fc70697a018fe"], "tags": []}, {"author": "Srujana Peddinti \u003csrujana.htt121@gmail.com\u003e", "branch": "default", "desc": "Bug 1570009 - Part 1: Create a top-level actor in child processes capable of testing the sandbox. r=bobowen,dmajor\n\nThis patch includes a new browser chrome mochitest that uses a new XPCOM service (moxISandboxTest) to create a new top-level actor (PSandboxTesting) between the chrome process and any supported child processes (in later parts of this patch set). The framework is makes it easy to add new C/C++ instructions to be tested for permission under real sandbox conditions. Test results can be conditioned on the type of OS, process, sandbox level, etc.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37706", "files": ["security/sandbox/common/components.conf", "security/sandbox/common/moz.build", "security/sandbox/common/test/PSandboxTesting.ipdl", "security/sandbox/common/test/SandboxTest.cpp", "security/sandbox/common/test/SandboxTest.h", "security/sandbox/common/test/SandboxTestingChild.cpp", "security/sandbox/common/test/SandboxTestingChild.h", "security/sandbox/common/test/SandboxTestingParent.cpp", "security/sandbox/common/test/SandboxTestingParent.h", "security/sandbox/common/test/SandboxTestingThread.h", "security/sandbox/common/test/mozISandboxTest.idl", "security/sandbox/test/browser.ini", "security/sandbox/test/browser_sandbox_test.js"], "git_node": null, "git_parents": [null], "node": "cfc5fac4fbb6db8ff17b3d441723515fc4af3fd9", "parents": ["3c76c7680baaa5c0927a9e0fcdcf91f2ce614dfa"], "tags": []}, {"author": "Srujana Peddinti \u003csrujana.htt121@gmail.com\u003e", "branch": "default", "desc": "Bug 1570009 - Part 2 : Added Content Process testing to the framework. r=bobowen\n\nAdds the ability to create and run sandbox tests in a content process.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D37913", "files": ["dom/ipc/ContentChild.cpp", "dom/ipc/ContentChild.h", "dom/ipc/PContent.ipdl", "dom/ipc/moz.build", "security/sandbox/common/test/SandboxTest.cpp", "security/sandbox/test/browser_sandbox_test.js"], "git_node": null, "git_parents": [null], "node": "191da9c843802b9f416b76b03bb5e6666c09cc27", "parents": ["cfc5fac4fbb6db8ff17b3d441723515fc4af3fd9"], "tags": []}, {"author": "Srujana Peddinti \u003csrujana.htt121@gmail.com\u003e", "branch": "default", "desc": "Bug 1570009 - Part 3 : Added GPU Process testing t