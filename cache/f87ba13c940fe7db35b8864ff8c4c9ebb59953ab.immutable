ets r=release a=l10n-bump DONTBUILD\n\nar -\u003e d0bb3fcf96aa\nbe -\u003e 01434a3c9b57\ncs -\u003e 4c628f4d2429\nes-MX -\u003e cf90a59f5ac2\nfr -\u003e b15d61525b94\ngn -\u003e 10d9b95450de\nhy-AM -\u003e c349919dd54d\nit -\u003e 3a1565ec1dcb\nmr -\u003e 82c24b430d2b\nth -\u003e c75e2dc8ab70\nvi -\u003e 71d9bd2ffa76", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "c0412cf53b826f899cbce15d142a0610eb1ff5e3", "parents": ["8b748799d500b1573dddf917e99638df0b8a95c4"], "tags": []}], "date": 1572087647, "git_changesets": [null, null], "user": "ffxbld"}, "12210": {"changesets": [{"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1579761 - Add missing dependencies on .cargo/config. r=mshal a=pascalc\n\n.cargo/config is necessary for all invocations of cargo, which, apart\nfrom normal rust targets, actually also happens indirectly when we\ninvoke cbindgen.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50550", "files": ["config/recurse.mk"], "git_node": null, "git_parents": [null], "node": "d049a5699739b68eb9dda9329a6a0262d0218e28", "parents": ["c0412cf53b826f899cbce15d142a0610eb1ff5e3"], "tags": []}, {"author": "lougenia \u003clougenia@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588948 - Check passwords engine handles incoming records with null or missing username fields r=lina a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49805", "files": ["services/sync/modules/engines/passwords.js", "services/sync/tests/unit/test_password_engine.js"], "git_node": null, "git_parents": [null], "node": "a4f6c62364b01746a678ae75297a82b3f0825c17", "parents": ["d049a5699739b68eb9dda9329a6a0262d0218e28"], "tags": []}, {"author": "L. David Baron \u003cdbaron@dbaron.org\u003e", "branch": "default", "desc": "Bug 1584018 - Add reftest. r=dholbert a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50510", "files": ["testing/web-platform/meta/css/css-flexbox/flex-child-percent-basis-resize-1.html.ini", "testing/web-platform/meta/css/css-grid/grid-child-percent-basis-resize-1.html.ini", "testing/web-platform/tests/css/css-flexbox/flex-child-percent-basis-resize-1-ref.html", "testing/web-platform/tests/css/css-flexbox/flex-child-percent-basis-resize-1.html", "testing/web-platform/tests/css/css-grid/grid-child-percent-basis-resize-1-ref.html", "testing/web-platform/tests/css/css-grid/grid-child-percent-basis-resize-1.html"], "git_node": null, "git_parents": [null], "node": "ed1c6a03a8107db8d0d84d1d197307d3d4977bf1", "parents": ["a4f6c62364b01746a678ae75297a82b3f0825c17"], "tags": []}, {"author": "L. David Baron \u003cdbaron@dbaron.org\u003e", "branch": "default", "desc": "Bug 1584018 - Make flex and grid code indicate that its block resizes can affect basis for percentages. r=dholbert,mats a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50511", "files": ["layout/generic/nsFlexContainerFrame.cpp", "layout/generic/nsGridContainerFrame.cpp", "testing/web-platform/meta/css/css-flexbox/flex-child-percent-basis-resize-1.html.ini", "testing/web-platform/meta/css/css-grid/grid-child-percent-basis-resize-1.html.ini"], "git_node": null, "git_parents": [null], "node": "6e24f27cc398f16f4ad43608e704083f798256d6", "parents": ["ed1c6a03a8107db8d0d84d1d197307d3d4977bf1"], "tags": []}, {"author": "Sean Feng \u003csefeng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1590526 - Temporarily allow node adoption across different docGroups for the content/content case r=smaug,zombie a=pascalc\n\nAs web extensions rely on this node adoption between content to content\ndocuments, we want to continue allowing this capability to work for now.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50348", "files": ["browser/components/extensions/test/browser/browser.ini", "browser/components/extensions/test/browser/browser_ext_contentscript_cross_docGroup_adoption.js", "browser/components/extensions/test/browser/browser_ext_contentscript_cross_docGroup_adoption_xhr.js", "dom/base/nsNodeUtils.h", "dom/tests/mochitest/general/chrome.ini", "dom/tests/mochitest/general/test_nodeAdoption_chrome_boundary.xul"], "git_node": null, "git_parents": [null], "node": "1542e80327c2f1fe04d399f3da7c6b4948bd283a", "parents": ["6e24f27cc398f16f4ad43608e704083f798256d6"], "tags": []}, {"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1587867 - Change regexp in looksLikeURL to avoid bad performance for long strings. r=mak a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49821", "files": ["toolkit/components/places/UnifiedComplete.jsm"], "git_node": null, "git_parents": [null], "node": "8960870ce87122be50ded0dd8a964440a775309a", "parents": ["1542e80327c2f1fe04d399f3da7c6b4948bd283a"], "tags": []}, {"author": "Paul Adenot \u003cpaul@paul.cx\u003e", "branch": "default", "desc": "Bug 1590652 - Temporarily revert to using IAudioClient on Windows 10. r=kinetik a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50242", "files": ["media/libcubeb/disable-iaudioclient3.patch", "media/libcubeb/src/cubeb_wasapi.cpp", "media/libcubeb/update.sh"], "git_node": null, "git_parents": [null], "node": "e47669c4dd1b9a6d87cf2fb28990e08c78c1f7af", "parents": ["8960870ce87122be50ded0dd8a964440a775309a"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1584685 - Don't use try..catch to check for non-existent error strings in aboutNetError.js. r=nhnt11 a=pascalc\n\ndocument.l10n.formatValues seems to have changed and now not throw an error but instead\nreturn `undefined` when no string was found. This broke the implementation which relied\non try..catch to detect non-existent error strings.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49873", "files": ["browser/base/content/aboutNetError.js"], "git_node": null, "git_parents": [null], "node": "b19acb55364c415443935d7cf2979ebf7fd6318f", "parents": ["e47669c4dd1b9a6d87cf2fb28990e08c78c1f7af"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1590749 - Make the update interval for the milestone doorhanger configurable. r=ewright a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50218", "files": ["toolkit/components/antitracking/TrackingDBService.jsm"], "git_node": null, "git_parents": [null], "node": "f2bbdda539c16483a61a67537949ba74eb891f00", "parents": ["b19acb55364c415443935d7cf2979ebf7fd6318f"], "tags": []}, {"author": "Daisuke Akatsuka \u003cdaisuke@birchill.co.jp\u003e", "branch": "default", "desc": "Bug 1590003: Lazily load the compatibility lib and the dataset. r=jdescottes a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50159", "files": ["devtools/client/inspector/compatibility/reducers/compatibility.js"], "git_node": null, "git_parents": [null], "node": "dabd951da5274b57cb821004dacd158e7269b4a7", "parents": ["f2bbdda539c16483a61a67537949ba74eb891f00"], "tags": []}, {"author": "Daisuke Akatsuka \u003cdaisuke@birchill.co.jp\u003e", "branch": "default", "desc": "Bug 1589858: Guard from passing media rules to InspectorUtils.getSelectorCount(). r=pbro a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50155", "files": ["devtools/server/actors/inspector/css-logic.js"], "git_node": null, "git_parents": [null], "node": "564accafca261041dee4339e7bcd4ac017a58df9", "parents": ["dabd951da5274b57cb821004dacd158e7269b4a7"], "tags": []}, {"author": "Daisuke Akatsuka \u003cdaisuke@birchill.co.jp\u003e", "branch": "default", "desc": "Bug 1589858: Add a test whether the rule view is available or not when plural styles which are defined in media query block are set for visited link. r=pbro a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50156", "files": ["devtools/client/inspector/rules/test/browser.ini", "devtools/client/inspector/rules/test/browser_rules_pseudo-visited_in_media-query.js", "devtools/client/inspector/rules/test/doc_visited_in_media_query.html"], "git_node": null, "git_parents": [null], "node": "c65ad7a3cbf9124f880050a569d74f7d42ed972c", "parents": ["564accafca261041dee4339e7bcd4ac017a58df9"], "tags": []}, {"author": "Julian Seward \u003cjseward@acm.org\u003e", "branch": "default", "desc": "Bug 1584976 - LUL on x86_64-{android, linux}: accept .eh_frame with type as either SHT_PROGBITS or SHT_X86_64_UNWIND.  r=mstange. a=pascalc\n\nThe LUL unwinder on x86_64-android and x86_64-linux tries to read Dwarf unwind\ninformation from the ELF section named \".eh_frame\", and expects the section to\nhave type SHT_PROGBITS.  It appears that that section might instead have the\ntype SHT_X86_64_UNWIND, possibly as a result of recent toolchain (linker?)\nchanges.  This patch tracks that change.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50474", "files": ["tools/profiler/lul/LulElf.cpp"], "git_node": null, "git_parents": [null], "node": "0638fe37a75882e83e112ab939b7aed61c09880c", "parents": ["c65ad7a3cbf9124f880050a569d74f7d42ed972c"], "tags": []}, {"author": "Marco Perez Kistler \u003cbugmail@millibyte.net\u003e", "branch": "default", "desc": "Bug 1589975 - Unbreak build on platforms not supporting the mmap flag MAP_NORESERVE. r=jandem a=pascalc\n\nuser: Marco Perez Kistler \u003cbugmail@millibyte.net\u003e\nbranch 'default'\nchanged js/src/jit/ProcessExecutableMemory.cpp\n\nUnbreak builds on (non-Windows) platforms where mmap doesn't support the MAP_NORESERVE flag.\nWe know for sure that at least FreeBSD has been affected since the fix for bug #1527597 landed.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50458", "files": ["js/src/jit/ProcessExecutableMemory.cpp"], "git_node": null, "git_parents": [null], "node": "f9408680c70379b11ebc145cfb67a3de3a212ac6", "parents": ["0638fe37a75882e83e112ab939b7aed61c09880c"], "tags": []}, {"author": "Matthew Noorenberghe \u003cmozilla@noorenberghe.ca\u003e", "branch": "default", "desc": "Bug 1583957 - Indicate support for autocomplete=(username|new-password|current-password). r=farre a=pascalc\n\nBug 917325 started using the `username` token.\nBug 1119063 started using the `new-password` token. This patch also adds support for `current-password` since it's the counterpart to `new-password` and we plan to use it as a signal eventually so want to encourage its use.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50351", "files": ["dom/base/AutocompleteFieldList.h", "dom/html/test/forms/test_autocomplete.html", "dom/html/test/forms/test_autocompleteinfo.html", "testing/web-platform/meta/html/semantics/forms/the-form-element/form-autocomplete.html.ini"], "git_node": null, "git_parents": [null], "node": "3f91bfc4b026c6c7f77c336ee7ec363f38e20d7f", "parents": ["f9408680c70379b11ebc145cfb67a3de3a212ac6"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1590823 - Fix scrollbars in accessibility panel by using --devtools-toolbar-height instead of --accessibility-toolbar-height r=fvsch a=pascalc\n\nThe accessibility panel is calculating the height of some of its containers by doing 100vh - toolbar height.\nBut the accessibility panel was relying on a local variable --accessibility-toolbar-height which was actually not used to set the height of the toolbar.\nSo when the toolbar height increased of 1px, all those calculations became wrong.\n\nThe --accessibility-toolbar-height is now the same as --theme-toolbar-height so I propose to remove the local variable and only use the devtools one.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50291", "files": ["devtools/client/accessibility/accessibility.css"], "git_node": null, "git_parents": [null], "node": "b75400fe3810849b423443986f20043a4482e81c", "parents": ["3f91bfc4b026c6c7f77c336ee7ec363f38e20d7f"], "tags": []}, {"author": "Cameron McCormack \u003ccam@mcc.id.au\u003e", "branch": "default", "desc": "Bug 1585880 - Ensure pointer-events inherits into scrollbar parts. r=emilio a=pascalc\n\nLike visibility, we rely on pointer-events values inheriting down into\nscrollbar part elements.  So don't cached NAC styles for scrollbar parts\nif we have a non-initial value for pointer-events, and adjust the UA\nstyle sheet rules to ensure it is always inherited.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49359", "files": ["layout/base/nsCSSFrameConstructor.cpp", "toolkit/content/minimal-xul.css"], "git_node": null, "git_parents": [null], "node": "5d1f5ff5c72983ae1f1af3da1c6b6f1c96a5dc3f", "parents": ["b75400fe3810849b423443986f20043a4482e81c"], "tags": []}, {"author": "Andrew Sutherland \u003casutherland@asutherland.org\u003e", "branch": "default", "desc": "Bug 1583859 - ExecutionReadyPromise should not be exclusive. r=perry a=pascalc\n\nAlthough many Clients API usages are inherently exclusive (a specific claim\nor control request), the execution-ready promise is shared by all requests\nto get the state of a client that is not yet execution ready.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49976", "files": ["dom/clients/manager/ClientSourceParent.cpp", "dom/clients/manager/ClientSourceParent.h"], "git_node": null, "git_parents": [null], "node": "80b49821b35475d09409ad8c54f51dcd9ad03c99", "parents": ["5d1f5ff5c72983ae1f1af3da1c6b6f1c96a5dc3f"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1589865 - Search in a Private Window appears for the search restriction token. r=Standard8 a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49888", "files": ["browser/components/urlbar/UrlbarProviderPrivateSearch.jsm", "browser/components/urlbar/tests/browser/browser_urlbar_separatePrivateDefault.js"], "git_node": null, "git_parents": [null], "node": "0dfa20097d27d51b6748eb04467a0d6a98764899", "parents": ["80b49821b35475d09409ad8c54f51dcd9ad03c99"], "tags": []}], "date": 1572180790, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "rgurzau@mozilla.com"}, "12211": {"changesets": [{"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1582234 - Change the meaning of browser.urlbar.suggest.bookmark = false so that visited bookmarks are autofilled but unvisited bookmarks still are not. r=mak a=pascalc\n\nWhen suggest.history = true and suggest.bookmark = false, change the inclusion logic from `NOT bookmarked` to `visited OR NOT bookmarked`. That will include visited bookmarks above the autofill threshold but still exclude unvisited bookmarks.\n\nThis also renames the various SQL query consts to better reflect when they are used: `HISTORY_BOOKMARK` for when both suggest.history and suggest.bookmark = true, `HISTORY` for when only suggest.history = true, and `BOOKMARK` for when only suggest.bookmark = true.\n\nFinally, it adds a bunch of test tasks consistent with the other existing autofill test tasks.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50146", "files": ["toolkit/components/places/UnifiedComplete.jsm", "toolkit/components/places/tests/unifiedcomplete/autofill_tasks.js"], "git_node": null, "git_parents": [null], "node": "e5f81abd3ffba1f55ee5ba4f4f382065320bc0b1", "parents": ["0dfa20097d27d51b6748eb04467a0d6a98764899"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1590479 - Reset notification UI state for PopupNotifications doorhangers without checkbox. r=nhnt11 a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50572", "files": ["browser/base/content/test/webrtc/browser_devices_get_user_media_in_xorigin_frame.js", "browser/base/content/test/webrtc/get_user_media_in_xorigin_frame.html", "toolkit/modules/PopupNotifications.jsm"], "git_node": null, "git_parents": [null], "node": "469d2fd39bd0f7032ee04f9c96d062ba3b1c8c5c", "parents": ["e5f81abd3ffba1f55ee5ba4f4f382065320bc0b1"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1590755 - Enable the new certificate viewer everywhere. r=carolina.jimenez.g a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50575", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "105200ed1cf6753d13dbeecc4bbb9e4837b7711d", "parents": ["469d2fd39bd0f7032ee04f9c96d062ba3b1c8c5c"], "tags": ["DEVEDITION_71_0b5_BUILD1", "DEVEDITION_71_0b5_RELEASE", "FIREFOX_71_0b5_BUILD1", "FIREFOX_71_0b5_RELEASE"]}], "date": 1572260405, "git_changesets": [null, null, null], "user": "apavel@mozilla.com"}, "12212": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP remote-settings tld-suffixes - a=repo-update r=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50807", "files": ["netwerk/dns/effective_tld_names.dat", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/main/url-classifier-skip-urls.json"], "git_node": null, "git_parents": [null], "node": "af61be9c974af0eae89a384776dc897127d14d64", "parents": ["105200ed1cf6753d13dbeecc4bbb9e4837b7711d"], "tags": []}, {"author": "Geoff Brown \u003cgbrown@mozilla.com\u003e", "branch": "default", "desc": "Bug 1516298 - Disable test_group_touchevents.html on android for frequent intermittent failures; r=egao, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50481", "files": ["gfx/layers/apz/test/mochitest/mochitest.ini"], "git_node": null, "git_parents": [null], "node": "1d82f36f19305ed6