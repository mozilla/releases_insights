gesets r=release a=l10n-bump DONTBUILD\n\nbn -\u003e b2158cb79fa2\nel -\u003e 9d05598c58eb\nes-MX -\u003e 0516b478e348\npl -\u003e 4604e009924e\nsq -\u003e 844cb5ff1bb5\nsv-SE -\u003e 485c25be8e78", "files": ["mobile/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "894079a4ad7575ca3b771969275b3f6f7cd6fcbf", "parents": ["7610ca22d7c6e97e128d26052b7a501d439d4ef2"], "tags": []}, {"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Firefox l10n changesets r=release a=l10n-bump DONTBUILD\n\nbn -\u003e b2158cb79fa2\nel -\u003e 9d05598c58eb\nes-MX -\u003e 0516b478e348\nia -\u003e 7b48c26a9f49\npl -\u003e 4604e009924e\nsq -\u003e 844cb5ff1bb5\nsv-SE -\u003e 485c25be8e78\ntl -\u003e 33320025f906", "files": ["browser/locales/l10n-changesets.json"], "git_node": null, "git_parents": [null], "node": "336974ba64ff2ff0c661967f87d32b6c85d21e99", "parents": ["894079a4ad7575ca3b771969275b3f6f7cd6fcbf"], "tags": []}], "date": 1573297241, "git_changesets": [null, null], "user": "ffxbld"}, "12285": {"changesets": [{"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1546801: [firefox-ci] Update default taskcluster; r=Callek a=taskcluster-migration\n\nMANUAL PUSH: Initial push to test new firefox-ci taskcluster cluster.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52453", "files": ["taskcluster/taskgraph/util/taskcluster.py"], "git_node": null, "git_parents": [null], "node": "306665629da0896035216dfd44735558cb5e8275", "parents": ["336974ba64ff2ff0c661967f87d32b6c85d21e99"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1546801: [firefox-ci] Use taskcluster-proxy for windows builds' tooltool access; r=Callek a=taskcluster-migration\n\nMANUAL PUSH: Fix windows tooltool failures in firefox-ci cluster.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52456", "files": ["taskcluster/ci/build/windows.yml", "taskcluster/ci/instrumented-build/kind.yml", "taskcluster/ci/toolchain/cbindgen.yml", "taskcluster/ci/toolchain/cctools-port.yml", "taskcluster/ci/toolchain/clang-tidy.yml", "taskcluster/ci/toolchain/clang.yml", "taskcluster/ci/toolchain/gn.yml", "taskcluster/ci/toolchain/grcov.yml", "taskcluster/ci/toolchain/rust-size.yml", "taskcluster/ci/toolchain/sccache.yml", "taskcluster/ci/webrender/kind.yml", "taskcluster/taskgraph/transforms/job/common.py", "taskcluster/taskgraph/transforms/job/hazard.py", "taskcluster/taskgraph/transforms/job/mozharness.py", "taskcluster/taskgraph/transforms/job/run_task.py", "taskcluster/taskgraph/transforms/job/spidermonkey.py"], "git_node": null, "git_parents": [null], "node": "7cbbfeb9b66d6c8875e1b1431e8e9b9edf0e1ca7", "parents": ["306665629da0896035216dfd44735558cb5e8275"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1546801: [firefox-ci] Use taskcluster-proxy for windows builds' tooltool access; r=Callek a=taskcluster-migration\n\nDifferential Revision: https://phabricator.services.mozilla.com//D52471", "files": ["taskcluster/ci/instrumented-build/kind.yml", "taskcluster/ci/searchfox/kind.yml", "taskcluster/ci/static-analysis-autotest/kind.yml"], "git_node": null, "git_parents": [null], "node": "0ee84ffcd9ce27a9a40dacd6c43345b266f3e8c5", "parents": ["7cbbfeb9b66d6c8875e1b1431e8e9b9edf0e1ca7"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1546801: [firefox-ci] Do not enable taskcluster proxy on g-w for non-internal tooltool downloads; r=dustin a=taskcluster-migration\n\ngeneric-worker uses localhost:8080 for the taskcluster proxy. Many jobs,\nincluding raptor also try to use that port. Disable using the proxy\nwhen only public tooltool downloads were requested, since this\nwas how thing were configured before.\n\nDifferential Revision: https://phabricator.services.mozilla.com//D52478", "files": ["taskcluster/taskgraph/transforms/job/common.py"], "git_node": null, "git_parents": [null], "node": "f48c43bce966d55ff8f9ac11e2e836a6ae43d6e9", "parents": ["0ee84ffcd9ce27a9a40dacd6c43345b266f3e8c5"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1546801: [firefox-ci] Do not enable taskcluster proxy on android bitbar workers; r=dustin a=taskcluster-migration\n\nThe bitbar workers do not support taskcluster-proxy, and so tooltool internal downloads\ndon't work, even though they had been requested.\n\nDifferential Revision: https://phabricator.services.mozilla.com//D52480", "files": ["taskcluster/taskgraph/transforms/job/mozharness_test.py"], "git_node": null, "git_parents": [null], "node": "4d2f8fb512e3fa031cf8ecf2f8761da3d02380fa", "parents": ["f48c43bce966d55ff8f9ac11e2e836a6ae43d6e9"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1595368: [firefox-ci] Use internal tooltool downloads for windows spidermonkey tasks; r=garbas a=task-fix\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52497", "files": ["taskcluster/ci/spidermonkey/linux.yml", "taskcluster/ci/spidermonkey/windows.yml", "taskcluster/taskgraph/transforms/job/spidermonkey.py"], "git_node": null, "git_parents": [null], "node": "5c32aad89c8cf0b50d444e19b3763b8421b8ec2d", "parents": ["4d2f8fb512e3fa031cf8ecf2f8761da3d02380fa"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1595368: [firefox-ci] Use consitent logic to determine tooltool url; r=sfraser a=task-fix\n\nDifferential Revision: https://phabricator.services.mozilla.com/D52498\n\nDepends on D52497", "files": ["js/src/devtools/automation/winbuildenv.sh", "python/mozbuild/mozbuild/action/tooltool.py", "python/mozbuild/mozbuild/artifact_commands.py", "taskcluster/ci/build/windows.yml", "taskcluster/ci/instrumented-build/kind.yml", "taskcluster/ci/searchfox/k