nt/webconsole/test/browser/browser_webconsole_telemetry_persist_toggle_changed.js", "devtools/client/webconsole/test/browser/browser_webconsole_timestamps.js", "devtools/client/webconsole/test/browser/browser_webconsole_warning_groups_toggle.js", "devtools/client/webconsole/test/browser/head.js", "devtools/client/webconsole/test/node/components/filter-bar.test.js", "devtools/client/webconsole/test/node/fixtures/DevToolsUtils.js", "devtools/client/webconsole/test/node/mocha-test-setup.js", "devtools/client/webconsole/test/node/package.json", "devtools/client/webconsole/webconsole-ui.js", "devtools/client/webconsole/webconsole-wrapper.js"], "git_node": null, "git_parents": [null], "node": "4919d1f95752be8626b55eeab03c90193fb354f6", "parents": ["e7bd0696e0c8c7b1ead41dca8df43e374f1e18f6"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 7f353853da83 (bug 1588793) as requsted by the dev. CLOSED TREE", "files": ["browser/components/customizableui/content/panelUI.inc.xul", "browser/locales/en-US/browser/appmenu.ftl", "browser/locales/en-US/browser/sync.ftl", "python/l10n/fluent_migrations/bug_1588793_syncnow_label.py"], "git_node": null, "git_parents": [null], "node": "c991f3b3466e8cedfcdcbd9f1a24c6d8d3c30c0b", "parents": ["4919d1f95752be8626b55eeab03c90193fb354f6"], "tags": []}, {"author": "Sylvestre Ledru \u003csledru@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588458 - Replace dxr by searchfox in the doc r=ahal\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49140", "files": ["browser/components/payments/docs/index.rst", "browser/components/urlbar/docs/index.rst", "browser/components/urlbar/docs/overview.rst", "browser/components/urlbar/docs/utilities.rst", "browser/docs/BrowserUsageTelemetry.rst", "build/docs/rust.rst", "services/common/docs/RemoteSettings.rst", "taskcluster/docs/partner-repacks.rst", "taskcluster/docs/release-promotion-action.rst", "taskcluster/docs/taskgraph.rst", "taskcluster/docs/try.rst", "toolkit/components/telemetry/docs/collection/events.rst", "toolkit/components/telemetry/docs/collection/histograms.rst", "toolkit/components/telemetry/docs/collection/hybrid-content.rst", "toolkit/components/telemetry/docs/collection/scalars.rst", "toolkit/components/telemetry/docs/collection/stack-capture.rst", "toolkit/components/telemetry/docs/collection/use-counters.rst", "toolkit/components/telemetry/docs/data/main-ping.rst", "toolkit/components/telemetry/docs/data/new-profile-ping.rst", "toolkit/components/telemetry/docs/data/sync-ping.rst", "toolkit/components/telemetry/docs/internals/geckoview.rst", "toolkit/components/telemetry/docs/start/adding-a-new-probe.rst", "tools/compare-locales/docs/index.rst"], "git_node": null, "git_parents": [null], "node": "35d4451f348d39c86e24acf45fed1ac61a07df91", "parents": ["c991f3b3466e8cedfcdcbd9f1a24c6d8d3c30c0b"], "tags": []}, {"author": "Alexandre Poirot \u003cpoirot.alex@gmail.com\u003e", "branch": "default", "desc": "Bug 1588730 - Convert test_protocol_simple to async/await. r=jdescottes\n\nI thought I would contribute to this test.\nAs it doesn't involve any child actor, I'm not, but this cleanup is still valuable.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49260", "files": ["devtools/server/tests/unit/test_protocol_simple.js"], "git_node": null, "git_parents": [null], "node": "ad24c0afefd4b8dba70c2bdae593d622c5ad8f49", "parents": ["35d4451f348d39c86e24acf45fed1ac61a07df91"], "tags": []}, {"author": "Alexandre Poirot \u003cpoirot.alex@gmail.com\u003e", "branch": "default", "desc": "Bug 1588730 - Ensure calling form() before calling notifying onFront listeners. r=jdescottes\n\nYou can listen for fronts creation via `parentFront.onFront(typeName, callback)`.\nFor now, we were calling `callback` before we pass the `form` to Front.\nThis leads to empty attributes as the Front doesn't have access to any data.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49261", "files": ["devtools/server/tests/unit/test_protocol_onFront.js", "devtools/shared/protocol/Front.js", "devtools/shared/protocol/types.js"], "git_node": null, "git_parents": [null], "node": "b2a798629bd60d066849d08a1315f4e74d3a9393", "parents": ["ad24c0afefd4b8dba70c2bdae593d622c5ad8f49"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1517369 - Check for invalid rtp extension ids; r=bwc\n\nThis adds checks for invalid and duplicated rtp extension ids to\nJsepSessionImpl. Since the version of webrtc.org we're using does not support\ntwo byte extension ids, ids must be between 1 and 14 inclusive. Duplicated\nextension ids are also disallowed by RFC 8285. Passing an invalid extension id\ninto the webrtc.org code will trigger a release assertion and a browser crash.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48689", "files": ["media/webrtc/signaling/gtest/jsep_session_unittest.cpp", "media/webrtc/signaling/src/jsep/JsepSessionImpl.cpp"], "git_node": null, "git_parents": [null], "node": "98c7a85974c5a1ae7ea166bea9b01a2b2adbc979", "parents": ["b2a798629bd60d066849d08a1315f4e74d3a9393"], "tags": []}, {"author": "Morgan Reschenberg \u003cmreschenberg@mozilla.com\u003e", "branch": "default", "desc": "Bug 822988: Create HyperTextAccessibleWrap for SVG text objects for correct role assignment. r=Jamie\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49202", "files": ["accessible/base/nsAccessibilityService.cpp", "accessible/tests/mochitest/tree/a11y.ini", "accessible/tests/mochitest/tree/test_svg.html"], "git_node": null, "git_parents": [null], "node": "3025b00645faf2fd80a87e0b62f95caf79fb5bef", "parents": ["98c7a85974c5a1ae7ea166bea9b01a2b2adbc979"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1587008 - [Wayland] Set EGL window size at CompositorOGL::BeginFrame, r=sotaro\n\nwl_egl_window size must exactly march GL rendering pipeline setting.\n\nCompositor and widget can have different window sizes during window resize when widget\nis resized faster than layout can render. Firefox window is rendered misplaced then\nand it's \"jumping\" as layout size is behind toolkit size.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49136", "files": ["gfx/layers/opengl/CompositorOGL.cpp", "widget/gtk/GtkCompositorWidget.cpp", "widget/gtk/GtkCompositorWidget.h"], "git_node": null, "git_parents": [null], "node": "afc6499c8f1f15247076e320e9410457c4c15ab5", "parents": ["3025b00645faf2fd80a87e0b62f95caf79fb5bef"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1587008 - [Wayland] Get wl_egl_window size from compositor by nsWindow::SetEGLNativeWindowSize, r=jhorak\n\nWe can't set wl_egl_window from widget code as it must match GL rendering pipeline,\nso let compositor to set the egl window size.\n\nDepends on D49136\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49137", "files": ["widget/gtk/mozcontainer.cpp", "widget/gtk/mozcontainer.h", "widget/gtk/nsWindow.cpp", "widget/gtk/nsWindow.h"], "git_node": null, "git_parents": [null], "node": "9e610c4628e11d5374d2adae34d26a028b30bae3", "parents": ["afc6499c8f1f15247076e320e9410457c4c15ab5"], "tags": []}, {"author": "Stephen Horlander \u003cshorlander@mozilla.com\u003e", "branch": "default", "desc": "Bug 1582879 - Update unofficial branding r=dao\n\nUpdate unofficial build branding with new visuals and assets\n\nDifferential Revision: https://phabricator.services.mozilla.com/D46677", "files": ["browser/branding/unofficial/VisualElements_150.png", "browser/branding/unofficial/VisualElements_70.png", "browser/branding/unofficial/background.png", "browser/branding/unofficial/bgstub.jpg", "browser/branding/unofficial/bgstub_2x.jpg", "browser/branding/unofficial/content/about-background.png", "browser/branding/unofficial/content/about-logo.png", "browser/branding/unofficial/content/about-logo@2x.png", "browser/branding/unofficial/content/about-wordmark.svg", "browser/branding/unofficial/content/about.png", "browser/branding/unofficial/content/aboutDialog.css", "browser/branding/unofficial/content/horizontal-lockup.svg", "browser/branding/unofficial/content/identity-icons-brand.svg", "browser/branding/unofficial/content/jar.mn", "browser/branding/unofficial/default128.png", "browser/branding/unofficial/default16.png", "browser/branding/unofficial/default22.png", "browser/branding/unofficial/default24.png", "browser/branding/unofficial/default256.png", "browser/branding/unofficial/default32.png", "browser/branding/unofficial/default48.png", "browser/branding/unofficial/default64.png", "browser/branding/unofficial/disk.icns", "browser/branding/unofficial/document.icns", "browser/branding/unofficial/document.ico", "browser/branding/unofficial/firefox.icns", "browser/branding/unofficial/firefox.ico", "browser/branding/unofficial/firefox64.ico", "browser/branding/unofficial/wizHeader.bmp", "browser/branding/unofficial/wizHeaderRTL.bmp", "browser/branding/unofficial/wizWatermark.bmp"], "git_node": null, "git_parents": [null], "node": "6e8f6ab1724a37e31c8e5247bd097e81e5395a97", "parents": ["9e610c4628e11d5374d2adae34d26a028b30bae3"], "tags": []}, {"author": "Morgan Reschenberg \u003cmreschenberg@mozilla.com\u003e", "branch": "default", "desc": "Bug 1579750: Consider aria role before landmark role for xlm-roles attribute. r=Jamie\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49178", "files": ["accessible/generic/Accessible.cpp", "accessible/tests/mochitest/attributes/test_obj.html"], "git_node": null, "git_parents": [null], "node": "d44a3247d4faaaf3e6d2f409f34e08ff005d5190", "parents": ["6e8f6ab1724a37e31c8e5247bd097e81e5395a97"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 35d4451f348d (bug 1588458) as requested by the dev", "files": ["browser/components/payments/docs/index.rst", "browser/components/urlbar/docs/index.rst", "browser/components/urlbar/docs/overview.rst", "browser/components/urlbar/docs/utilities.rst", "browser/docs/BrowserUsageTelemetry.rst", "build/docs/rust.rst", "services/common/docs/RemoteSettings.rst", "taskcluster/docs/partner-repacks.rst", "taskcluster/docs/release-promotion-action.rst", "taskcluster/docs/taskgraph.rst", "taskcluster/docs/try.rst", "toolkit/components/telemetry/docs/collection/events.rst", "toolkit/components/telemetry/docs/collection/histograms.rst", "toolkit/components/telemetry/docs/collection/hybrid-content.rst", "toolkit/components/telemetry/docs/collection/scalars.rst", "toolkit/components/telemetry/docs/collection/stack-capture.rst", "toolkit/components/telemetry/docs/collection/use-counters.rst", "toolkit/components/telemetry/docs/data/main-ping.rst", "toolkit/components/telemetry/docs/data/new-profile-ping.rst", "toolkit/components/telemetry/docs/data/sync-ping.rst", "toolkit/components/telemetry/docs/internals/geckoview.rst", "toolkit/components/telemetry/docs/start/adding-a-new-probe.rst", "tools/compare-locales/docs/index.rst"], "git_node": null, "git_parents": [null], "node": "206c6ca088cbf938042044250682cf0eff47f0eb", "parents": ["d44a3247d4faaaf3e6d2f409f34e08ff005d5190"], "tags": []}, {"author": "Junior Hsu \u003cjuhsu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1566868 - network error for non empty sandboxing flag and non-null COOP r=valentin\n\nAdjust for new spec change (comment 23)\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49222", "files": ["docshell/base/nsDocShell.cpp", "netwerk/ipc/NeckoChannelParams.ipdlh", "netwerk/protocol/http/ClassifierDummyChannel.cpp", "netwerk/protocol/http/HttpBaseChannel.cpp", "netwerk/protocol/http/HttpBaseChannel.h", "netwerk/protocol/http/HttpChannelChild.cpp", "netwerk/protocol/http/HttpChannelParent.cpp", "netwerk/protocol/http/HttpChannelParent.h", "netwerk/protocol/http/nsHttpChannel.cpp", "netwerk/protocol/http/nsIHttpChannelInternal.idl", "netwerk/protocol/viewsource/nsViewSourceChannel.cpp", "testing/web-platform/meta/html/cross-origin-opener-policy/coop-sandbox.https.html.ini"], "git_node": null, "git_parents": [null], "node": "906731e277bb028740afddd905c2309c00e55044", "parents": ["206c6ca088cbf938042044250682cf0eff47f0eb"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1576714 - Part 1: Move BBC initialization into BrowserBridgeChild, r=kmag\n\nThis is useful in part 3, where the initialization will need to be called from\nmultiple places.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47308", "files": ["dom/ipc/BrowserBridgeChild.cpp", "dom/ipc/BrowserBridgeChild.h", "dom/ipc/ContentChild.cpp"], "git_node": null, "git_parents": [null], "node": "21053f81f2cf0f538529a48ce06af3e322aa304c", "parents": ["906731e277bb028740afddd905c2309c00e55044"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1576714 - Part 2: Remove mIPCOpen from PBrowserBridge actors, r=kmag\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47309", "files": ["dom/ipc/BrowserBridgeChild.cpp", "dom/ipc/BrowserBridgeChild.h", "dom/ipc/BrowserBridgeParent.cpp", "dom/ipc/BrowserBridgeParent.h"], "git_node": null, "git_parents": [null], "node": "7a8d759536e0fd50141ef7d3c4cf9271d6eb3ecd", "parents": ["21053f81f2cf0f538529a48ce06af3e322aa304c"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1576714 - Part 3: Initiate subframe process switches from the parent, r=kmag\n\nThis flips the direction in which the BrowserBridge actor is generally created\nsuch that it is generally created in the parent and sent down to a child\nprocess.\n\nThis is done by making the decision about what kind of switch to perform in the\nparent, and sending messages down to child processes async to orchestrate these\nprocess changes.\n\nProcess launching is changed to use an async `MozPromise`-returning API in this\npatch, though the actual process launching still occurs synchronously. A future\npatch will enable performing async process launching through the\nNewOrUsedBrowserProcess mechanism.\n\nI know of at least a few timing issues which exist with the new logic,\nespecially around the state of the BrowsingContext during the process\ntransition. I decided to not try to fix all of these issues in this patch, as\nmany are complex and will require changing how we manage the lifecycle of\nBrowsingContext substantially. I do, however, think that the new logic is more\nreliable and has fewer timing issues than the previous logic.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47310", "files": ["browser/components/sessionstore/SessionStore.jsm", "docshell/base/CanonicalBrowsingContext.cpp", "docshell/base/CanonicalBrowsingContext.h", "docshell/base/nsDocShell.cpp", "dom/base/nsFrameLoader.h", "dom/base/nsFrameLoaderOwner.cpp", "dom/base/nsFrameLoaderOwner.h", "dom/chrome-webidl/BrowsingContext.webidl", "dom/chrome-webidl/WindowGlobalActors.webidl", "dom/ipc/BrowserBridgeChild.h", "dom/ipc/BrowserBridgeParent.cpp", "dom/ipc/BrowserBridgeParent.h", "dom/ipc/PWindowGlobal.ipdl", "dom/ipc/WindowGlobalChild.cpp", "dom/ipc/WindowGlobalChild.h", "dom/ipc/WindowGlobalParent.cpp", "dom/ipc/WindowGlobalParent.h"], "git_node": null, "git_parents": [null], "node": "7935fa1ac77479636596be9a213652e6932ca8ab", "parents": ["7a8d759536e0fd50141ef7d3c4cf9271d6eb3ecd"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1576714 - Part 4: Delay canceling original http channel during process switch, r=mattwoodrow\n\nThis patch changes when the original HttpChannelChild gets canceled during a\nprocess switch to be after when the process switch is completed. This is needed\nto prevent the load event firing too early in the original content process.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47311", "files": ["netwerk/protocol/http/HttpChannelParent.cpp", "netwerk/protocol/http/HttpChannelParent.h"], "git_node": null, "git_parents": [null], "node": "c5f3fab8d36d0b0b2fa0f1a696707c9e5a41f3af", "parents": ["7935fa1ac77479636596be9a213652e6932ca8ab"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1576714 - Part 5: Delay canceling original document channel during process switch, r=mattwoodrow\n\nThis delays when the DocumentChannelChild is canceled during a process switch to\nbe after the switch has been completed, to prevent the load event firing too\nearly in the original content process.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47312", "files": ["netwerk/ipc/DocumentChannelParent.cpp", "netwerk/ipc/DocumentChannelParent.h"], "git_node": null, "git_parents": [null], "node": "6e6f09db875562747fde0354830f5f605c7ee374", "parents": ["c5f3fab8d36d0b0b2fa0f1a696707c9e5a41f3af"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 1576714 - Part 6: Remove now-passing fail-if, r=kmag\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48129", "files": ["browser/components/sessionstore/test/browser.ini"], "git_node": null, "git_parents": [null], "node": "0594b5176839ab553e0c2d745b569f7848f0ba61", "parents": ["6e6f09db875562747fde0354830f5f605c7ee374"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Backed out 2 changesets (bug 1587008) for build bustage on src/widget/gtk/GtkCompositorWidget.cpp. CLOSED TREE\n\nBacked out changeset 9e610c4628e1 (bug 1587008)\nBacked out changeset afc6499c8f1f (bug 1587008)", "files": ["gfx/layers/opengl/CompositorOGL.cpp", "widget/gtk/GtkCompositorWidget.c