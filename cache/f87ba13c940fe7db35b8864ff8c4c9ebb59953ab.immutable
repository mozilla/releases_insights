85582)", "files": ["browser/base/content/test/sanitize/browser.ini", "browser/base/content/test/sanitize/browser_sanitizeDialog.js", "dom/base/nsGlobalWindowInner.cpp", "dom/base/nsGlobalWindowInner.h", "dom/webidl/OfflineResourceList.webidl", "dom/webidl/Window.webidl", "netwerk/cache/nsCacheService.cpp", "testing/profiles/web-platform/user.js", "toolkit/forgetaboutsite/test/unit/test_removeDataFromDomain.js", "toolkit/forgetaboutsite/test/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "2b0f526cdab1f1a6f93a86ed51a961f40bb98641", "parents": ["a55fbe37780387823c0013f11a5e90ea4ee7ed76"], "tags": []}, {"author": "Mats Palmgren \u003cmats@mozilla.com\u003e", "branch": "default", "desc": "Bug 1587141 part 1 - Share some common code between Handle[CSS|HTML]IndentAtSelectionInternal (idempotent patch).  r=masayuki\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48586", "files": ["editor/libeditor/HTMLEditSubActionHandler.cpp", "editor/libeditor/HTMLEditor.h"], "git_node": null, "git_parents": [null], "node": "47b2e27b46b7577dad33c4172019dc5236754747", "parents": ["2b0f526cdab1f1a6f93a86ed51a961f40bb98641"], "tags": []}, {"author": "Mats Palmgren \u003cmats@mozilla.com\u003e", "branch": "default", "desc": "Bug 1587141 part 2 - Make execCommand(\"indent\") ignore whitespace when looking for sibling list element.  r=masayuki\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48587", "files": ["editor/libeditor/HTMLEditSubActionHandler.cpp", "editor/libeditor/HTMLEditor.cpp", "editor/libeditor/HTMLEditor.h", "editor/reftests/exec-command-indent-ws-ref.html", "editor/reftests/exec-command-indent-ws.html", "editor/reftests/reftest.list"], "git_node": null, "git_parents": [null], "node": "973eac50bb33fc630b9d7a49556a9c9c26ff465c", "parents": ["47b2e27b46b7577dad33c4172019dc5236754747"], "tags": []}, {"author": "Logan Smyth \u003cloganfsmyth@gmail.com\u003e", "branch": "default", "desc": "Bug 1564177 - Part 1: Clean up unused type declaration on Zone. r=jimb\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49705", "files": ["js/src/gc/Zone.h"], "git_node": null, "git_parents": [null], "node": "1d502a2613701b10ef2d8b37d54119992c2b48b1", "parents": ["973eac50bb33fc630b9d7a49556a9c9c26ff465c"], "tags": []}, {"author": "Logan Smyth \u003cloganfsmyth@gmail.com\u003e", "branch": "default", "desc": "Bug 1564177 - Part 2: Move the DebuggerVector from GlobalObject to the Realm. r=jimb\n\nThe DebuggerVector has been associated with the GlobalObject via a private slot\nreferencing a wrapper JS object (DebugggerVectorHolder). Moving this data into\nthe JS::Realm instance removes complexity and avoids needing the holder.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49570", "files": ["js/public/Class.h", "js/src/debugger/DebugAPI-inl.h", "js/src/debugger/DebugAPI.h", "js/src/debugger/Debugger.cpp", "js/src/gc/GCEnum.h", "js/src/vm/GlobalObject.cpp", "js/src/vm/GlobalObject.h", "js/src/vm/Realm.cpp", "js/src/vm/Realm.h"], "git_node": null, "git_parents": [null], "node": "096bd2773fc164fbfb6866fc2bdade407e77b286", "parents": ["1d502a2613701b10ef2d8b37d54119992c2b48b1"], "tags": []}, {"author": "harry \u003chtwyford@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588921 - Fix nsTouchBar build errors. r=spohl\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49434", "files": ["widget/cocoa/nsTouchBar.mm"], "git_node": null, "git_parents": [null], "node": "a7afcafc710a53c83cdb2ea15317512c7cf996cf", "parents": ["096bd2773fc164fbfb6866fc2bdade407e77b286"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1589561.  Factor out idle handling from PrioritizedEventQueue.  r=smaug\n\nWe could try to move the EnforcePendingTaskGuarantee() bit into\nPeekIdleDeadline, but then we'd need to check HasReadyEvent() on\nmDeferredTimersQueue and mIdleQueue before we possibly unlock the mutex under\nPeekIdleDeadline, and it's not clear that that state cannot change once the\nmutex is unlocked...\n\nThe EnsureIsActive() call at the end of GetIdleDeadlineInternal in the !aIsPeek\ncase only makes sense if there are in fact idle tasks available to run when\nGetDeadlineForIdleTask is called, because otherwise it would incorrectly set us\nactive when we are not running any tasks.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49696", "files": ["ipc/glue/IdleSchedulerChild.cpp", "ipc/glue/IdleSchedulerChild.h", "xpcom/threads/IdlePeriodState.cpp", "xpcom/threads/IdlePeriodState.h", "xpcom/threads/PrioritizedEventQueue.cpp", "xpcom/threads/PrioritizedEventQueue.h", "xpcom/threads/moz.build"], "git_node": null, "git_parents": [null], "node": "a05bb855056d483927dc433cc55a31f09bf37213", "parents": ["a7afcafc710a53c83cdb2ea15317512c7cf996cf"], "tags": []}, {"author": "Gurzau Raul \u003crgurzau@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset f6ca531ca5b2 (bug 1573710) requested by alice0775. a=backout", "files": ["widget/windows/WinCompositorWidget.cpp"], "git_node": null, "git_parents": [null], "node": "11d13005c8767500d6a20858e9db82603e8fb808", "parents": ["014c61389f0bd8982f45be269a761fb0d027a6d2"], "tags": []}, {"author": "Gurzau Raul \u003crgurzau@mozilla.com\u003e", "branch": "default", "desc": "Merge autoland to mozilla-central. a=merge", "files": [], "git_node": null, "git_parents": [null, null], "node": "4b332005f92551e4c96e74a150a601764f76aa02", "parents": ["11d13005c8767500d6a20858e9db82603e8fb808", "a6e168c78b26cdf69e7a151948c277b4c9d8fea9"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Merge autoland to mozilla-central. a=merge", "files": [], "git_node": null, "git_parents": [null, null], "node": "b34beb21e1cf9d283ef0d855f68f63bcc15e40fb", "parents": ["4b332005f92551e4c96e74a150a601764f76aa02", "2b0f526cdab1f1a6f93a86ed51a961f40bb98641"], "tags": []}, {"author": "A