 [null], "node": "06e6c1909fe14af67ef89a6ecf7f8c1fe572e2e4", "parents": ["91e184a01fa74c39d7be931700d3a932f63288a2"], "tags": []}, {"author": "Ting-Yu Lin \u003ctlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 992384 - Make sure we always propagate root element's mWritingMode. r=emilio\n\nBug 1102175 Part 1 only handles HTML documents correctly because they\nalways have a body element (even if the \u003cbody\u003e tag is not written\nexplicitly in the document). For SVG documents and all other documents\nlacking \u003cbody\u003e element, we always want to propagate mWritingMode from\nthe root element, which is our old behavior prior to Bug 1102175.\n\nNote that mDocElementContainingBlock (i.e. nsCanvasFrame) is using\nviewport's style, so we need to use the root element's computed style to\ncompute WritingMode for propagating.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49695", "files": ["layout/base/nsCSSFrameConstructor.cpp", "testing/web-platform/tests/css/css-writing-modes/wm-propagation-svg-root-scrollbar.svg"], "git_node": null, "git_parents": [null], "node": "98575a5ca794cb67b8d569e8a95188a30532e336", "parents": ["06e6c1909fe14af67ef89a6ecf7f8c1fe572e2e4"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1587840 - Update the copy for the separate default search engine. r=mikedeboer,fluent-reviewers\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49591", "files": ["browser/components/preferences/in-content/search.inc.xul", "browser/locales/en-US/browser/preferences/preferences.ftl"], "git_node": null, "git_parents": [null], "node": "4a95ac39f66b1ca32102cb562f96f8fb8129ea28", "parents": ["98575a5ca794cb67b8d569e8a95188a30532e336"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1589410 - fix how remote-settings blocklist handles the absence of a `blockID` property in the blocklist ent