boardingMessageProvider.jsm", "browser/components/newtab/test/browser/browser_aboutwelcome.js"], "git_node": null, "git_parents": [null], "node": "1c04ad803c6284fd1196b7fc1ce8171c42bc5752", "parents": ["ef43ee07acdaaa8a86d6ab12fccc5a3e27f44656"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1571219 - Refactor PerformanceMeasure to avoid double-reducing timestamps r=baku a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50127", "files": ["dom/performance/Performance.cpp", "dom/performance/PerformanceMainThread.cpp"], "git_node": null, "git_parents": [null], "node": "2095702e4783e12b73bc0c9adf466e2346e04dad", "parents": ["1c04ad803c6284fd1196b7fc1ce8171c42bc5752"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1586918 - Separate the add row from last pref in about:config r=Gijs a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49474", "files": ["browser/components/aboutconfig/content/aboutconfig.css"], "git_node": null, "git_parents": [null], "node": "b625b846f88c50aad3a576a40788bb5fef5ff6c3", "parents": ["2095702e4783e12b73bc0c9adf466e2346e04dad"], "tags": []}, {"author": "Jeff Gilbert \u003cjgilbert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1583970 - Cast sizeof to ptrdiff_t to avoid `-16 / 4 = big`. r=tsmith a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50149", "files": ["dom/canvas/WebGLTexelConversions.cpp"], "git_node": null, "git_parents": [null], "node": "98e2a38a4d7822f110ff4100872770a7c9e833a1", "parents": ["b625b846f88c50aad3a576a40788bb5fef5ff6c3"], "tags": []}, {"author": "Haik Aftandilian \u003chaftandilian@mozilla.com\u003e", "branch": "default", "desc": "Bug 1587962 - [10.15] \"Use keyboard navigation\" and \"jump to spot\" scrolling preferences do not work r=spohl a=lizzard\n\nUpdate sandbox rules to allow services and files needed for global UI system preferences.\n\nUpdate tests now that stat() calls on the filesystem are permitted.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50298", "files": ["security/sandbox/mac/SandboxPolicyContent.h", "security/sandbox/test/browser_content_sandbox_fs.js"], "git_node": null, "git_parents": [null], "node": "dfe0211b28126996fed51ef6bd965ecefa986a42", "parents": ["98e2a38a4d7822f110ff4100872770a7c9e833a1"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1590582 - Don't leave HitTestResult::mFixedPosSides uninitialized. r=tnikkel a=pascalc\n\nLikewise for APZCTreeManager::mFixedPosSidesForInputBlock.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50360", "files": ["gfx/layers/apz/src/APZCTreeManager.h"], "git_node": null, "git_parents": [null], "node": "5f2b98bde7590176bb780147c6ba29f825fed4d5", "parents": ["dfe0211b28126996fed51ef6bd965ecefa986a42"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1590582 - Subtract the fixed margins offset when adjusting event coordinates during hit testing, rather than adding it. r=tnikkel a=pascalc\n\nThe offset is applied (added) during rendering; it needs to be un-applied\n(subtracted) during hit testing.\n\nDepends on D50360\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50361", "files": ["gfx/layers/apz/src/APZCTreeManager.cpp"], "git_node": null, "git_parents": [null], "node": "59533843b4dafb79848dea7a214e610e04ba4ca3", "parents": ["5f2b98bde7590176bb780147c6ba29f825fed4d5"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1590582 - Un-apply the fixed margins offset in ConvertToGecko as well. r=tnikkel a=pascalc\n\nThis ensures the coordinates of tap events are adjusted as well.\n\nDepends on D50361\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50362", "files": ["gfx/layers/apz/src/APZCTreeManager.cpp", "gfx/layers/apz/src/APZCTreeManager.h", "gfx/layers/apz/src/AsyncPanZoomController.cpp"], "git_node": null, "git_parents": [null], "node": "c59bc98634287e2c76f35a59bdd97c21f93fb8a9", "parents": ["59533843b4dafb79848dea7a214e610e04ba4ca3"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1590582 - Have AsyncPanZoomController::ConvertToGecko return a Maybe rather than using a bool + outparam. r=tnikkel a=pascalc\n\nDepends on D50362\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50363", "files": ["gfx/layers/apz/src/AsyncPanZoomController.cpp", "gfx/layers/apz/src/AsyncPanZoomController.h"], "git_node": null, "git_parents": [null], "node": "661f1e5306895da7655dc9ed1f43b8d8bd54491f", "parents": ["c59bc98634287e2c76f35a59bdd97c21f93fb8a9"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588563 - Reduce background image size in about:config r=jaws a=pascalc l10n=flod\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49463", "files": ["browser/components/aboutconfig/content/aboutconfig.css", "browser/components/aboutconfig/content/background.svg"], "git_node": null, "git_parents": [null], "node": "fb78ad450cc49668b407dd6f68d086fa10d73520", "parents": ["661f1e5306895da7655dc9ed1f43b8d8bd54491f"], "tags": []}], "date": 1572435059, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "dluca@mozilla.com"}, "12224": {"changesets": [{"author": "Greg Tatum \u003cgtatum@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588295 - Change popup test to use the js feature rather than stackwalk; r=gerald a=pascalc\n\nThis test is relying on a profiler feature that is not available in every\nplatform. This patch changes it to use the \"js\" feature, which should be\nsupported everywhere.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49948", "files": ["devtools/client/performance-new/test/xpcshell/test_popup_initial_state.js"], "git_node": null, "git_parents": [null], "node": "9b156fd52465e79950f3f153380e938188b0d00f", "parents": ["fb78ad450cc49668b407dd6f68d086fa10d73520"], "tags": []}, {"author": "Itiel \u003citiel_yn8@walla.com\u003e", "branch": "default", "desc": "Bug 1589899 - Always display preference values on the search bar in the left-to-right direction. r=Itiel a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49835", "files": ["browser/components/aboutconfig/content/aboutconfig.css"], "git_node": null, "git_parents": [null], "node": "9a6ed73c61c31021d38c20361a6e91221b10eb3d", "parents": ["9b156fd52465e79950f3f153380e938188b0d00f"], "tags": []}, {"author": "Brian Grinstead \u003cbgrinstead@mozilla.com\u003e", "branch": "default", "desc": "Bug 1589595 - Replace cmd_copy with cmd_copy_tree in page info so the tree copy handler doesn't override the input field copy handler r=Gijs a=pascalc\n\nPreviously when uing \u003cxul:textbox\u003e the context menu was handled by the moz-input-box and not cmd_copy.\nNow that these are \u003chtml:input\u003e they rely on the cmd_copy by name through a menuitem created in editmenuoverlay\nat https://searchfox.org/mozilla-central/rev/088e2cf29c59d733d57af43903eb0267dbf72e2a/toolkit/content/editMenuOverlay.js#119.\n\nThis also changes cmd_selectall with cmd_selectall_tree for consistency, but since the casing was different\nbetween that and the edit menu (cmd_selectAll), this issue didn't come up.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50390", "files": ["browser/base/content/pageinfo/pageInfo.xul"], "git_node": null, "git_parents": [null], "node": "3cf69f0f8361611248fcf2c6a1838c6a881b5392", "parents": ["9a6ed73c61c31021d38c20361a6e91221b10eb3d"], "tags": []}, {"author": "Mustafa \u003cmustafa.abdelmogoud@gmail.com\u003e", "branch": "default", "desc": "Bug 1587750 - fix isJSON healper function. r=Honza a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49294", "files": ["devtools/client/netmonitor/src/utils/request-utils.js"], "git_node": null, "git_parents": [null], "node": "482ca58d538256acf92e1b796092502f3c406e79", "parents": ["3cf69f0f8361611248fcf2c6a1838c6a881b5392"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1589346 - Fix navigation to debugger from console on prettified sources. r=loganfsmyth a=pascalc\n\nThis revert the changes made in Bug 1587839, except the added test.\nThe safer fix to be uplifted is to only fix the original issue\nin the SmartTrace component, where we remove any sourceId we might\nhave when creating the new mapped frame.\n\nWe also modify the browser_dbg-pretty-print-console test to ensure\nclicking on a prettified location in the console does open the\ndebugger with the expected location.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50173", "files": ["devtools/client/debugger/test/mochitest/browser_dbg-pretty-print-console.js", "devtools/client/framework/source-map-url-service.js", "devtools/client/framework/test/browser_source_map-pub-sub.js", "devtools/client/inspector/computed/computed.js", "devtools/client/inspector/rules/models/rule.js", "devtools/client/inspector/rules/views/rule-editor.js", "devtools/client/shared/components/Frame.js", "devtools/client/shared/components/SmartTrace.js", "devtools/client/shared/widgets/tooltip/EventTooltipHelper.js"], "git_node": null, "git_parents": [null], "node": "78005895ad96a32ff91915423cdb3006d250d9d6", "parents": ["482ca58d538256acf92e1b796092502f3c406e79"], "tags": []}, {"author": "Mark Hammond \u003cmhammond@skippinet.com.au\u003e", "branch": "default", "desc": "Bug 1589652 - better handling of long sync engine names in the preferences UI. r=Gijs a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50414", "files": ["browser/themes/shared/incontentprefs/preferences.inc.css"], "git_node": null, "git_parents": [null], "node": "cecf35abeef6a60d37c58088914eaafb8dc75ccf", "parents": ["78005895ad96a32ff91915423cdb3006d250d9d6"], "tags": []}, {"author": "Thom Chiovoloni \u003ctchiovoloni@mozilla.com\u003e", "branch": "default", "desc": "Bug 1238810 - Replace {FXA,WEAVE}_CONFIGURED with entries in the telemetry environment. r=chutten,markh,loines a=pascalc\n\nReplace {FXA,WEAVE}_CONFIGURED with entries in the telemetry environment\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49166", "files": ["services/fxaccounts/FxAccounts.jsm", "services/fxaccounts/tests/xpcshell/test_accounts.js", "services/sync/Weave.jsm", "toolkit/components/telemetry/Histograms.json", "toolkit/components/telemetry/app/TelemetryEnvironment.jsm", "toolkit/components/telemetry/docs/data/environment.rst", "toolkit/components/telemetry/histogram-allowlists.json", "toolkit/components/telemetry/tests/unit/test_TelemetryEnvironment.js"], "git_node": null, "git_parents": [null], "node": "68b750271d3a067e3c9e6c65baf3ca835489f168", "parents": ["cecf35abeef6a60d37c58088914eaafb8dc75ccf"], "tags": []}, {"author": "Brendan Dahl \u003cbdahl@mozilla.com\u003e", "branch": "default", "desc": "Bug 1590044 - Fix root HTML element attribute persistence. r=smaug a=pascalc\n\nAttribute persistence for root elements should be handled by nsXULWindow,\nnot XULPersist. This was causing browser.xhtml with an \u003chtml\u003e root to be\nslightly smaller on each new window during the test\n\"open-features-non-integer-height.html.\"\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50622", "files": ["dom/xul/XULPersist.cpp"], "git_node": null, "git_parents": [null], "node": "d90a0f0c5ba9f96ae4e8bc8beb9cf7af5c326f14", "parents": ["68b750271d3a067e3c9e6c65baf3ca835489f168"], "tags": []}, {"author": "Sam Foster \u003csfoster@mozilla.com\u003e", "branch": "default", "desc": "Bug 1590362 - Prefer matched origin logins when deduping. r=MattN a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50542", "files": ["toolkit/components/passwordmgr/LoginHelper.jsm", "toolkit/components/passwordmgr/test/unit/test_dedupeLogins.js"], "git_node": null, "git_parents": [null], "node": "d2aa52c5e5a4ff6f76aca2ec06a26a738fd15505", "parents": ["d90a0f0c5ba9f96ae4e8bc8beb9cf7af5c326f14"], "tags": []}, {"author": "Sean Feng \u003csefeng@mozilla.com\u003e", "branch": "default", "desc": "Bug 1590709 - Fix crash in TransportSecurityInfo::ReadCertList r=keeler a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50557", "files": ["security/manager/ssl/TransportSecurityInfo.cpp", "security/manager/ssl/tests/unit/test_cert_chains.js"], "git_node": null, "git_parents": [null], "node": "36608f8649b254b65a0efa461be675cf610b96e0", "parents": ["d2aa52c5e5a4ff6f76aca2ec06a26a738fd15505"], "tags": []}], "date": 1572439371, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "dvarga@mozilla.com"}, "12225": {"changesets": [{"author": "Dana Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "bug 1590888 - reinstate filtering of client certificate selection during the TLS handshake r=kjacobs a=pascalc\n\nBug 1267643 removed filtering of client certificates based on the\n\"certificate_authorities\" list sent in the client certificate request from the\nserver in TLS handshakes because it is impossible to implement as specified\nwithout false negatives (i.e. excluding certificates that could be usable but\ndon't seem to be according to the certificates the client is aware of). In\npractice, however, it seems enough users rely on this behavior[0] that we\nshould add it back until the platform can save client certificate selections\nacross restarts and the \"select one automatically\" option is removed (see also\nbug 634697).\n\n[0] See e.g. bug 1588703, bug 1590297, bug 1590596, bug 1074195 comment 27,\nand any other duplicates of this bug.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50355", "files": ["browser/components/urlbar/tests/browser/browser_urlbar_speculative_connect_not_with_client_cert.js", "security/manager/ssl/nsNSSIOLayer.cpp", "security/manager/ssl/tests/mochitest/browser/browser_clientAuth_connection.js", "testing/mochitest/ssltunnel/ssltunnel.cpp"], "git_node": null, "git_parents": [null], "node": "ab2f5e065d6f722569d5daba99956f0b6affa527", "parents": ["36608f8649b254b65a0efa461be675cf610b96e0"], "tags": []}, {"author": "Edgar Chen \u003cechen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588356 - Store the underlying sandbox object instead of a wrapper to UAWidgetScopeMap; r=bholley a=pascalc\n\nIf the wrapper is for extension, it could possibly be nuked after extension's\nwindow is destroyed. Then we will end up getting a DeadWrapper for same\nextension next time (if the UAWidgetScopeMap is not yet swept).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50582", "files": ["js/xpconnect/src/XPCJSRuntime.cpp", "js/xpconnect/tests/unit/test_uawidget_scope.js", "js/xpconnect/tests/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "5614af3ece59bee61c6509b9b59aebea0ea952a3", "parents": ["ab2f5e065d6f722569d5daba99956f0b6affa527"], "tags": []}, {"author": "Brian Hackett \u003cbhackett1024@gmail.com\u003e", "branch": "default", "desc": "Bug 1584538 - Allow debug environment proxy to access aliased module variables after the module script executes, r=jonco. a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50747", "files": ["js/src/jit-test/tests/debug/Environment-module-02.js", "js/src/vm/EnvironmentObject.cpp"], "git_node": null, "git_parents": [null], "node": "f12176eee588195f1b080bcc762abca341c3ab74", "parents": ["5614af3ece59bee61c6509b9b59aebea0ea952a3"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1592134 - Turn on the display of default private search engine feature for Nightly users only. r=johannh a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50866", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "aecc033327a33efe501b3a95eabb5bb28945bf38", "parents": ["f12176eee588195f1b080bcc762abca341c3ab74"], "tags": []}, {"author": "Dzmitry Malyshau \u003cdmalyshau@mozilla.com\u003e", "branch": "default", "desc": "Bug 1570736 - Blocklist WR swizzling on HD3000 r=jrmuizel a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50813", "files": ["widget/GfxDriverInfo.cpp", "widget/GfxDriverInfo.h", "widget/cocoa/GfxInfo.mm"], "git_node": null, "git_parents": [null], "node": "7abf70086d8746ae5e29b6cbbf193529980399fb", "parents": ["aecc033327a33efe501b3a95eabb5bb28945bf38"], "tags": []}, {"author": "Tim Huang \u003ctihuang@mozilla.com\u003e", "branch": "default", "desc": "Bug 1591049 - Fix the misplacement issue of the tracking protection icon when setting the system text size to 125% on Windows. r=johannh a=pascalc\n\nThis patch fixes the issue by adding a 'display: block;' rule on the\ntracking protection animatable image. This will override the default\n'display: -moz-box;' rule and fixes the issue.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D50784", "files": ["browser/themes/shared/identity-block/identity-block.inc.css"], "git_node": null, "git_parents": [null], "node": "d6a73719bc8c2c17b60981d526c2c5bfde511788", "parents": ["7abf70086d8746ae5e29b6cbbf193529980399fb"], "tags": []}, {"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1591327 - Quantumbar: Properly limit results to maxResults while taking result spans into account. r=mak a=pascalc\n\nThe muxer shouldn't decrease `maxResults`. The cropping in the providers manager should take result spans into account.\n\nI updated the result-span t