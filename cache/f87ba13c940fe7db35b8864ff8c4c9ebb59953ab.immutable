.services.mozilla.com/D49257", "files": ["js/src/jsapi.cpp"], "git_node": null, "git_parents": [null], "node": "f9bb6a94cf050dfeeecf5b67539e07349f1e9d12", "parents": ["9e4319f02f18707d2b55018179bdf70a92c832ee"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1586991 part 19 - Use linear strings instead of flat strings in CTypes. r=jwalden\n\nAlso simplify the code a bit by using js::CopyChars instead of manual\nchar conversion/copying.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49269", "files": ["js/src/ctypes/CTypes.cpp", "js/src/ctypes/Library.cpp"], "git_node": null, "git_parents": [null], "node": "99503df61d8e9f7b8bcbe5d38b341cd6d4a5c78f", "parents": ["f9bb6a94cf050dfeeecf5b67539e07349f1e9d12"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1586991 part 20 - Don't rely on null-terminated strings in PrintHelpString. r=jwalden\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49271", "files": ["js/src/shell/js.cpp"], "git_node": null, "git_parents": [null], "node": "2252a3f67ea36fa387c20ee38157f39931718764", "parents": ["99503df61d8e9f7b8bcbe5d38b341cd6d4a5c78f"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588810 - Fix ctypes UnicodeToNative callback to not assume null-terminated strings. r=bzbarsky\n\nBug 1586683 replaced the JS_FlattenString in the caller with JS_EnsureLinearString but\nI wasn't aware of the nsDependentString vs nsDependentSubstring distinction.\n\nThis fixes assertion failures when starting the browser with non-null-terminated\nJS strings.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49297", "files": ["dom/workers/ChromeWorkerScope.cpp", "toolkit/components/ctypes/ctypes.cpp"], "git_node": null, "git_parents": [null], "node": "7014c7a657a38ead50d5ce1fb3ba2d5f64b88e23", "parents": ["2252a3f67ea36fa387c20ee38157f39931718764"], "tags": []}, {"author": "Francesco Lodolo (:flod) \u003cflod@lodolo.net\u003e", "branch": "default", "desc": "Bug 1588992 - Remove Fluent migration recipes for Firefox 70 r=Pike\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49383", "files": ["python/l10n/fluent_migrations/bug_1501886_browser-menubar.py", "python/l10n/fluent_migrations/bug_1533863_aboutconfig_button_labels.py"], "git_node": null, "git_parents": [null], "node": "c7e6179969ef8d92caa8ae15479a9a5f6b6e0cba", "parents": ["7014c7a657a38ead50d5ce1fb3ba2d5f64b88e23"], "tags": []}, {"author": "Sylvestre Ledru \u003csledru@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588523 - Improve the mozlint doc (various changes) r=ahal\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49160", "files": ["tools/lint/docs/conf.py", "tools/lint/docs/create.rst", "tools/lint/docs/index.rst", "tools/lint/docs/usage.rst"], "git_node": null, "git_parents": [null], "node": "79009828ca610c54f3277696ba8525056cb38c7f", "parents": ["c7e6179969ef8d92caa8ae15479a9a5f6b6e0cba"], "tags": []}, {"author": "Sylvestre Ledru \u003csledru@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588523 - Provide doc for the codespell, file-perm, file-whitespace, etc linters r=ahal\n\nDepends on D49160\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49161", "files": ["tools/lint/docs/linters/codespell.rst", "tools/lint/docs/linters/cpp-virtual-final.rst", "tools/lint/docs/linters/file-perm.rst", "tools/lint/docs/linters/file-whitespace.rst", "tools/lint/docs/linters/license.rst", "tools/lint/docs/linters/mingw-capitalization.rst"], "git_node": null, "git_parents": [null], "node": "42be3322aeab1bebf0451ea85e0a6439843aa305", "parents": ["79009828ca610c54f3277696ba8525056cb38c7f"], "tags": []}, {"author": "Sylvestre Ledru \u003csledru@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588523 - Document the autofix when existing r=ahal\n\nDepends on D49161\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49162", "files": ["tools/lint/docs/linters/eslint.rst", "tools/lint/docs/linters/flake8.rst"], "git_node": null, "git_parents": [null], "node": "e98baddfa8895c6576dbada22316b30aca28f4a4", "parents": ["42be3322aeab1bebf0451ea85e0a6439843aa305"], "tags": []}, {"author": "Sylvestre Ledru \u003csledru@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588523 - add links to the sources everywhere r=ahal\n\nDepends on D49162\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49163", "files": ["tools/lint/docs/linters/codespell.rst", "tools/lint/docs/linters/cpp-virtual-final.rst", "tools/lint/docs/linters/eslint.rst", "tools/lint/docs/linters/file-perm.rst", "tools/lint/docs/linters/file-whitespace.rst", "tools/lint/docs/linters/flake8.rst", "tools/lint/docs/linters/l10n.rst", "tools/lint/docs/linters/lintpref.rst", "tools/lint/docs/linters/mingw-capitalization.rst", "tools/lint/docs/linters/rstlinter.rst"], "git_node": null, "git_parents": [null], "node": "50cad137801425d40d70b65b43ef573db0e3755e", "parents": ["e98baddfa8895c6576dbada22316b30aca28f4a4"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 1f4132be47b0 (bug 1588429) for failures on test_EcosystemTelemetry.js.", "files": ["toolkit/components/telemetry/Scalars.yaml", "toolkit/components/telemetry/pings/EcosystemTelemetry.jsm", "toolkit/components/telemetry/tests/unit/test_EcosystemTelemetry.js"], "git_node": null, "git_parents": [null], "node": "5e1eb5af5abe61332435e1e3e7ee0fb46b58b9bc", "parents": ["50cad137801425d40d70b65b43ef573db0e3755e"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 1a28547631d7 (bug 1584312) for failures on browser_protections_UI_milestones.js.", "files": ["browser/base/content/browser-siteProtections.js", "browser/base/content/test/siteProtections/browser.ini", "browser/base/content/test/siteProtections/browser_protections_UI.js", "browser/base/content/test/siteProtections/browser_protections_UI_milestones.js", "browser/base/content/test/siteProtections/head.js", "browser/components/controlcenter/content/protectionsPanel.inc.xul", "browser/locales/en-US/chrome/browser/browser.properties", "browser/themes/shared/controlcenter/etp-milestone.svg", "browser/themes/shared/controlcenter/panel.inc.css", "browser/themes/shared/jar.inc.mn"], "git_node": null, "git_parents": [null], "node": "0be15ecc1848aa2d0be438baae6f60989a0f8053", "parents": ["5e1eb5af5abe61332435e1e3e7ee0fb46b58b9bc"], "tags": []}, {"author": "James Graham \u003cjames@hoppipolla.co.uk\u003e", "branch": "default", "desc": "Bug 1588713 - Schedule wpt-fis as Tier-3, r=ahal\n\nThis enables wpt-fis for the same configurations as mochitest-fis,\ninitially as T3 so that any stability issues can be worked out.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49241", "files": ["taskcluster/taskgraph/transforms/tests.py"], "git_node": null, "git_parents": [null], "node": "7962998273b05f0d44a7e85bba072a6a5d35cf0f", "parents": ["0be15ecc1848aa2d0be438baae6f60989a0f8053"], "tags": []}, {"author": "James Graham \u003cjames@hoppipolla.co.uk\u003e", "branch": "default", "desc": "Bug 1584192 - Allow handling multiple reruns in wptreport.json files, r=maja_zf\n\nPreviously when running with --rerun=N we added all the subtest results\nto the previous test results and so got all N iterations of each\nsubtest result, but only one of each test result. Instead ensure that\ntop-level tests are added each time they are run, allowing multiple\ntest results.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47249", "files": ["testing/web-platform/tests/tools/wptrunner/wptrunner/formatters/wptreport.py"], "git_node": null, "git_parents": [null], "node": "325b5278961fb32b8fd6d4dcc481c4dd7890f33c", "parents": ["7962998273b05f0d44a7e85bba072a6a5d35cf0f"], "tags": []}, {"author": "David Teller \u003cdteller@mozilla.com\u003e", "branch": "default", "desc": "Bug 1587738 - Adding a fastpath for the most common prefixes of a `MultiLookupHuffmanTable`;r=arai\n\nBy definition of Huffman encoding, the shortest keys are reserved for the most common values.\nThis patch changes how we store these shortest keys in a `MultiLookupHuffmanTable` to\nimprove lookup speed: instead of storing short keys in a subtable by extending them,\nwe store them in a `SingleLookupHuffmanTable`.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48968", "files": ["js/src/frontend/BinASTTokenReaderContext.cpp", "js/src/frontend/BinASTTokenReaderContext.h"], "git_node": null, "git_parents": [null], "node": "58fc2e7b4956ebc48640d8ef820c75248e1bfdef", "parents": ["325b5278961fb32b8fd6d4dcc481c4dd7890f33c"], "tags": []}, {"author": "Jan-Erik Rediger \u003cjrediger@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588429 - Remove expiring metrics ecosystem_(old|new)_send_time r=chutten\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49104", "files": ["toolkit/components/telemetry/Scalars.yaml", "toolkit/components/telemetry/pings/EcosystemTelemetry.jsm", "toolkit/components/telemetry/tests/unit/test_EcosystemTelemetry.js"], "git_node": null, "git_parents": [null], "node": "4976fa1575dd9635becbd6d642be728fc689e35e", "parents": ["58fc2e7b4956ebc48640d8ef820c75248e1bfdef"], "tags": []}, {"author": "Honza Bambas \u003chonzab.moz@firemni.cz\u003e", "branch": "default", "desc": "Bug 1586195 - Add a non-null check for mChannel in HttpChannelParent::RecvRedirect2Verify as it can already be legally dropped, r=michal\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48841", "files": ["netwerk/protocol/http/HttpChannelParent.cpp"], "git_node": null, "git_parents": [null], "node": "55b215923179e7077b48fd7ee3207f89d778059e", "parents": ["4976fa1575dd9635becbd6d642be728fc689e35e"], "tags": []}, {"author": "Frederic Wang \u003cfred.wang@free.fr\u003e", "branch": "default", "desc": "Bug 1587570 - Remove support for the subscriptshift and superscriptshift attributes. r=emilio\n\nSee https://groups.google.com/forum/#!topic/mozilla.dev.platform/CAqw0Nxw6Pg\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48766", "files": ["dom/base/nsDeprecatedOperationList.h", "dom/locales/en-US/chrome/dom/dom.properties", "layout/mathml/nsMathMLmmultiscriptsFrame.cpp", "layout/mathml/tests/test_bug827713.html", "modules/libpref/init/StaticPrefList.yaml"], "git_node": null, "git_parents": [null], "node": "972db326c3754792b29dfa649d7dc18950431421", "parents": ["55b215923179e7077b48fd7ee3207f89d778059e"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1588835 - fix browser_bug633691.js to pass with fission enabled, r=johannh\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49313", "files": ["browser/base/content/test/about/browser.ini", "browser/base/content/test/about/browser_bug633691.js", "browser/base/content/test/general/browser.ini", "browser/base/content/test/general/browser_bug633691.js"], "git_node": null, "git_parents": [null], "node": "15dcfe42e6d09dfecc8b9ba7116d1eb3e7a7932a", "parents": ["972db326c3754792b29dfa649d7dc18950431421"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1589031 - re-enable browser_bug462673.js in fission debug, r=johannh\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49398", "files": ["browser/base/content/test/general/browser.ini"], "git_node": null, "git_parents": [null], "node": "8348a2e9d746c3f2108c1f0e496770658376f7ac", "parents": ["15dcfe42e6d09dfecc8b9ba7116d1eb3e7a7932a"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 1: Change Intl.Collator to use ClassSpec. r=mgaudet\n\n- `JSProto_Collator` has to be added to the end until part 9.\n- `js::CreateCollatorPrototype` was renamed to `js::CreateCollator` because it\n  no longer returns the prototype object. Part 7 will change this again.\n- `CollatorObject::protoClass_` uses `PlainObject::class_`, which works because\n  CollatorObject isn't xrayable.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42870", "files": ["js/public/Class.h", "js/public/ProtoKey.h", "js/src/builtin/intl/Collator.cpp", "js/src/builtin/intl/Collator.h", "js/src/builtin/intl/IntlObject.cpp", "js/src/vm/CommonPropertyNames.h", "js/src/vm/GlobalObject.cpp", "js/src/vm/GlobalObject.h"], "git_node": null, "git_parents": [null], "node": "cb587dae40808c1f6f520b16f8bf95d003ad99cc", "parents": ["8348a2e9d746c3f2108c1f0e496770658376f7ac"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 2: Change Intl.DateTimeFormat to use ClassSpec. r=mgaudet\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42871", "files": ["js/public/Class.h", "js/public/ProtoKey.h", "js/src/builtin/intl/DateTimeFormat.cpp", "js/src/builtin/intl/DateTimeFormat.h", "js/src/builtin/intl/IntlObject.cpp", "js/src/vm/CommonPropertyNames.h", "js/src/vm/GlobalObject.cpp", "js/src/vm/GlobalObject.h"], "git_node": null, "git_parents": [null], "node": "d8b0d1db18b8ce1b45243f27633b118d4210cd69", "parents": ["cb587dae40808c1f6f520b16f8bf95d003ad99cc"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 3: Change Intl.Locale to use ClassSpec. r=mgaudet\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42872", "files": ["js/public/Class.h", "js/public/ProtoKey.h", "js/src/builtin/intl/Locale.cpp", "js/src/builtin/intl/Locale.h", "js/src/jsfriendapi.h", "js/src/vm/CommonPropertyNames.h", "js/src/vm/GlobalObject.cpp", "js/src/vm/GlobalObjec