.xhtml", "browser/components/places/tests/chrome/test_bug549192.xul", "browser/components/places/tests/chrome/test_bug549491.xhtml", "browser/components/places/tests/chrome/test_bug549491.xul", "browser/components/places/tests/chrome/test_selectItems_on_nested_tree.xhtml", "browser/components/places/tests/chrome/test_selectItems_on_nested_tree.xul", "browser/components/places/tests/chrome/test_treeview_date.xhtml", "browser/components/places/tests/chrome/test_treeview_date.xul", "browser/components/preferences/in-content/tests/browser.ini", "browser/components/preferences/in-content/tests/browser_bug1184989_prevent_scrolling_when_preferences_flipped.js", "browser/components/preferences/in-content/tests/browser_bug1184989_prevent_scrolling_when_preferences_flipped.xhtml", "browser/components/preferences/in-content/tests/browser_bug1184989_prevent_scrolling_when_preferences_flipped.xul", "browser/components/preferences/in-content/tests/browser_subdialogs.js", "browser/components/preferences/in-content/tests/subdialog.xhtml", "browser/components/preferences/in-content/tests/subdialog.xul", "browser/components/preferences/in-content/tests/subdialog2.xhtml", "browser/components/preferences/in-content/tests/subdialog2.xul", "browser/extensions/formautofill/test/browser/focus-leak/browser.ini", "browser/extensions/formautofill/test/browser/focus-leak/browser_iframe_typecontent_input_focus.js", "browser/extensions/formautofill/test/browser/focus-leak/doc_iframe_typecontent_input_focus.xhtml", "browser/extensions/formautofill/test/browser/focus-leak/doc_iframe_typecontent_input_focus.xul"], "git_node": null, "git_parents": [null], "node": "a37b3531c1d18962ed04ac83c7d326d40e969454", "parents": ["bbe70f8da3f8643b7c546791bd92eaccc1b703f0"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 2947c5ae2f8b (bug 1586600) for mochitest failures on test_group_wheelevents.html.", "files": ["gfx/layers/apz/test/mochitest/helper_overscroll_behavior_bug1494440.html", "layout/base/crashtests/1586600.html", "layout/base/crashtests/crashtests.list", "layout/base/nsPresContext.cpp", "testing/web-platform/tests/css/css-overflow/overflow-body-propagation-005.html", "testing/web-platform/tests/css/css-overflow/overflow-body-propagation-006.html"], "git_node": null, "git_parents": [null], "node": "b5e165dc362a4afce1baa76b407737284b2dd059", "parents": ["a37b3531c1d18962ed04ac83c7d326d40e969454"], "tags": []}, {"author": "Ting-Yu Lin \u003ctlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1582019 Part 1 - Move the comments to make them easier to read. r=dholbert\n\nBy looking at the original diff, the comments were placed after the conditions.\nhttps://hg.mozilla.org/mozilla-central/diff/854d0d4791411c4733946d366a3824509451ed4f/layout/generic/nsAbsoluteContainingBlock.cpp\n\nI place the comments before the conditions, and add blank lines to\nseparate them. This is a preparation because Part 2 is going to add a\nnew condition.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49209", "files": ["layout/generic/nsAbsoluteContainingBlock.cpp"], "git_node": null, "git_parents": [null], "node": "759577f1a373d0c14ad7234aad89208b4e135a91", "parents": ["b5e165dc362a4afce1baa76b407737284b2dd059"], "tags": []}, {"author": "Ting-Yu Lin \u003ctlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1582019 Part 2 - Disable splitting absolute positioned multicol containers. r=dholbert\n\nThe crashtest contains an absolute positioning \u003cdialog\u003e multicol\ncontainer. If it is fragmented, we end up having a very wrong frame\ntree.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49210", "files": ["layout/generic/crashtests/1582019.html", "layout/generic/crashtests/crashtests.list", "layout/generic/nsAbsoluteContainingBlock.cpp"], "git_node": null, "git_parents": [null], "node": "7315890d3351b074a547db55de7417894ed3af74", "parents": ["759577f1a373d0c14ad7234aad89208b4e135a91"], "tags": []}, {"author": "Markus Stange \u003cmstange@themasta.com\u003e", "branch": "default", "desc": "Bug 1586627 - Work around a bug in AppleIntelHD3000GraphicsGLDriver in CompositorOGL. r=jrmuizel\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49050", "files": ["gfx/layers/opengl/CompositorOGL.cpp"], "git_node": null, "git_parents": [null], "node": "eea4ecbe16b6f02e1ce8754f90996c2264cbbf0b", "parents": ["7315890d3351b074a547db55de7417894ed3af74"], "tags": []}, {"author": "jaril \u003cjarilvalenciano@gmail.com\u003e", "branch": "default", "desc": "Bug 1587170 - Fixed tick highlighting when hovered on a message r=jlast\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49173", "files": ["devtools/client/themes/toolbox.css", "devtools/client/webreplay/components/WebReplayPlayer.js"], "git_node": null, "git_parents": [null], "node": "d1168081c8df595ac7d008eaa1799cc851eccf26", "parents": ["eea4ecbe16b6f02e1ce8754f90996c2264cbbf0b"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1581506 - Hide the extra text for the Firefox Accounts button if the text wrapping stretches across more than three lines. r=sfoster\n\nI used three lines instead of two because in my testing the space above and below the Sign In button allowed for some extra text to be shown without strecthing out of the container. I would prefer to err on the side of showing the full text instead of just the elided text since we cannot add a tooltip (title attribute) without changing the FTL key.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49014", "files": ["browser/components/aboutlogins/content/components/fxaccounts-button.css"], "git_node": null, "git_parents": [null], "node": "be74a47ce6693bd0f72733265a3b185a0e470a84", "parents": ["d1168081c8df595ac7d008eaa1799cc851eccf26"], "tags": []}, {"author": "Mihai Tabara \u003cmtabara@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588577 - switch to new GCP pushsnapworkers. r=nthomas a=release\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49183", "files": ["taskcluster/ci/release-secondary-snap-push/kind.yml", "taskcluster/ci/release-snap-push/kind.yml"], "git_node": null, "git_parents": [null], "node": "fb989789fedb70bf9c5bf0b51efd3261fbefba89", "parents": ["be74a47ce6693bd0f72733265a3b185a0e470a84"], "tags": []}, {"author": "Coroiu Cristina \u003cccoroiu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1530566 - Disable browser_passwordmgr_switchtab.js on mac debug for frequent failures r=gbrown\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49066", "files": ["toolkit/components/passwordmgr/test/browser/browser.ini"], "git_node": null, "git_parents": [null], "node": "cbdd47de480a9b49509fa1f0fdac2458727132a4", "parents": ["fb989789fedb70bf9c5bf0b51efd3261fbefba89"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1586991 part 9 - Change NativeIterator properties array from GCPtrFlatString to GCPtrLinearString. r=jwalden\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48494", "files": ["js/src/gc/Barrier.h", "js/src/jit/MacroAssembler.cpp", "js/src/vm/Iteration.cpp", "js/src/vm/Iteration.h"], "git_node": null, "git_parents": [null], "node": "209baba7ed0cf16e4aabd8634f15965df3d6c8ad", "parents": ["cbdd47de480a9b49509fa1f0fdac2458727132a4"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1586991 part 10 - Use JSLinearString instead of JSFlatString in number/string conversion code. r=jwalden\n\nThe isIndex method can no longer rely on null-termination so isIndex now\nchecks for the |length == 0| case before dereferencing and in isIndexSlow\nwe now do a |cp \u003c end| bounds check in the loop.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D48495", "files": ["js/src/jit/Co