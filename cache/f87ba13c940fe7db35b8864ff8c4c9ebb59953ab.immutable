t_setrequestheader-invalid-arguments.htm", "dom/imptests/webapps/mochitest.ini", "dom/imptests/writeBuildFiles.py", "dom/moz.build", "python/mozbuild/TODO", "testing/mochitest/runtests.py"], "git_node": null, "git_parents": [null], "node": "73cbc0f610531ae44b01f0e6ca41bf6a6b8e636d", "parents": ["54b7889d4457f4e94ba2dceb0de8f1a0e4fbfb41"], "tags": []}, {"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-central repo-update HSTS HPKP blocklist remote-settings tld-suffixes - a=repo-update r=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49151", "files": ["browser/app/blocklist.xml", "netwerk/dns/effective_tld_names.dat", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/blocklists/addons.json"], "git_node": null, "git_parents": [null], "node": "ebbbf2c970bdb0040bedfb8ea5da575ca46333f8", "parents": ["73cbc0f610531ae44b01f0e6ca41bf6a6b8e636d"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1576472 - Fix browser_about_debugging_link.js intermittent failure due to RDP requests pending while closing the tab. r=jdescottes\n\nbrowser_about_debugging_link.js is testing the page options that open (or switch) to about:debugging\nfrom about:addons.\n\nThis test seems to be failing intermittently because there are pending RDP requests when the about:debugging\ntab is being closed once the test is completed.\n\nWe already had a similar issue before and at the time daisuke provided us the test helpers currently used\nin the test to wait for the tabs, workers and extensions to be populated in the store.\n\nUnfortunately this doesn't seem enough anymore, especially with fission enabled the test is keep\nfailing because it seems that some new RDP requests are pending when we are closing the tab\n(from the stacktrace it seems that the pending requests are triggered by the \"processes updates listener\").\n\nThe waitForRequestsToSettle test helper used in some other about:debugging tests seems to be able to fix\nthe intermittent failure (trying on linux64 debug locally it passed test-verify multiple times).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49015", "files": ["toolkit/mozapps/extensions/test/browser/browser_about_debugging_link.js"], "git_node": null, "git_parents": [null], "node": "c157c41fcb26f251d7d9637d81717bd310f0a564", "parents": ["ebbbf2c970bdb0040bedfb8ea5da575ca46333f8"], "tags": []}, {"author": "Andi-Bogdan Postelnicu \u003cbpostelnicu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1588482 - For Coverity analysis add a modeling file when dealing with json_cpp. r=sylvestre\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49133", "files": ["tools/coverity/model.cpp"], "git_node": null, "git_parents": [null], "node": "4ca3dde6501c0943b3d49e5604afc68feb47bb08", "parents": ["c157c41fcb26f251d7d9637d81717bd310f0a564"], "tags": []}, {"author": "alexandru.ionescu \u003calexandru.ionescu@softvision.ro\u003e", "branch": "default", "desc": "Bug 1580141 Stop raptor tests execution and fail with propper message if mozproxy has issues initiating and starting the proxy r=tarek\n\nDifferential Revision: https://phabricator.services.mozilla.com/D47781", "files": ["testing/mozbase/mozproxy/mozproxy/utils.py"], "git_node": null, "git_parents": [null], "node": "5ccc65a83db3ce81a0a76e22f3d674d11a96a668", "parents": ["4ca3dde6501c0943b3d49e5604afc68feb47bb08"], "tags": []}, {"author": "shindli \u003cshindli@mozilla.com\u003e", "branch": "default", "desc": "Bug 1580141 - fix linting opt CLOSED TREE", "files": ["testing/mozbase/mozproxy/mozproxy/utils.py"], "git_node": null, "git_parents": [null], "node": "6d59c36d8aca9a176e3e405f2a806ac3af47c7c4", "parents": ["5ccc65a83db3ce81a0a76e22f3d674d11a96a668"], "tags": []}, {"author": "shindli \u003cshindli@mozilla.com\u003e", "branch": "default", "desc": "Backed out change