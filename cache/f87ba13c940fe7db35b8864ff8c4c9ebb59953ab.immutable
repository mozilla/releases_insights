/src/vm/GlobalObject.cpp", "js/src/vm/GlobalObject.h"], "git_node": null, "git_parents": [null], "node": "79af8c3fa894bda5e02298207327a6cd607f5b48", "parents": ["310181e1596b2477c61711f656928792242c027b"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 7: Remove boilerplate to create Intl constructors. r=mgaudet\n\n- Remove the various `js::CreateXYZ` functions be directly iterating over the\n  JSProtoKeys in `js::InitIntlClass`.\n- Also remove the unused `GlobalObject::getOrCreateIntlObject` method and then\n  merge `GlobalObject::initIntlObject` with `js::InitIntlClass`.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42876", "files": ["js/src/builtin/intl/Collator.cpp", "js/src/builtin/intl/Collator.h", "js/src/builtin/intl/DateTimeFormat.cpp", "js/src/builtin/intl/DateTimeFormat.h", "js/src/builtin/intl/IntlObject.cpp", "js/src/builtin/intl/Locale.cpp", "js/src/builtin/intl/Locale.h", "js/src/builtin/intl/NumberFormat.cpp", "js/src/builtin/intl/NumberFormat.h", "js/src/builtin/intl/PluralRules.cpp", "js/src/builtin/intl/PluralRules.h", "js/src/builtin/intl/RelativeTimeFormat.cpp", "js/src/builtin/intl/RelativeTimeFormat.h", "js/src/vm/GlobalObject.h"], "git_node": null, "git_parents": [null], "node": "fe1512265c0728a5c34c34607751564ec1f4157a", "parents": ["79af8c3fa894bda5e02298207327a6cd607f5b48"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 8: Use constexpr instead of #defines in js/Class. r=mgaudet\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42877", "files": ["js/public/Class.h"], "git_node": null, "git_parents": [null], "node": "e1a4db22bcb9c22fd319ee7a1df48fad2e111acc", "parents": ["fe1512265c0728a5c34c34607751564ec1f4157a"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 9: Assign an additional bit for CACHED_PROTO_KEY. r=mgaudet\n\nIncrease the CACHED_PROTO_KEY limit from 2\u2076 to 2\u2077 to allow that all current\nJSProto classes can use JSCLASS_HAS_CACHED_PROTO.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42878", "files": ["js/public/Class.h", "js/public/ProtoKey.h"], "git_node": null, "git_parents": [null], "node": "13369226eaca4e822f64bf2710f7fa66c42a4178", "parents": ["e1a4db22bcb9c22fd319ee7a1df48fad2e111acc"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 10: Use cached proto mechanism for Intl classes. r=mgaudet\n\nThis allows to replace `NewObjectWithGivenProto` with `NewObjectWithClassProto`, which\naligns Intl code with the rest of the non-Intl built-ins.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42880", "files": ["js/src/builtin/intl/Collator.cpp", "js/src/builtin/intl/DateTimeFormat.cpp", "js/src/builtin/intl/Locale.cpp", "js/src/builtin/intl/NumberFormat.cpp", "js/src/builtin/intl/PluralRules.cpp", "js/src/builtin/intl/RelativeTimeFormat.cpp"], "git_node": null, "git_parents": [null], "node": "c743e9d10ae5029b11404600770a9035d517a458", "parents": ["13369226eaca4e822f64bf2710f7fa66c42a4178"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 11: Replace Get{DateTime,Number}FormatConstructor with GetBuiltinConstructor. r=mgaudet\n\nNow that Intl.DateTimeFormat and Intl.NumberFormat both use JSProtoKey, we can\nuse the normal `GetBuiltinConstructor` self-hosting function to retrieve the\nbuilt-in constructor function.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42881", "files": ["js/src/builtin/intl/DateTimeFormat.js", "js/src/builtin/intl/NumberFormat.js", "js/src/vm/SelfHosting.cpp"], "git_node": null, "git_parents": [null], "node": "19625261f55a278f8d0d36b05f720056f86dbd84", "parents": ["c743e9d10ae5029b11404600770a9035d517a458"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 12: Remove no longer used getOrCreate functions for Intl object from GlobalObject. r=mgaudet\n\nThese methods are no longer needed after part 10 and part 11.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42882", "files": ["js/src/vm/GlobalObject.h"], "git_node": null, "git_parents": [null], "node": "226c1017cdbdfdefe3496c960a962a8796ef7a5f", "parents": ["19625261f55a278f8d0d36b05f720056f86dbd84"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 13: Add JSProtoKey for AsyncFunction. r=mgaudet\n\nIn a follow-up bug this will be changed to use `ClassSpec`, along with the rest\nof the JSProtoKey classes still using non-ClassSpec initialisation.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42883", "files": ["js/public/Class.h", "js/public/ProtoKey.h", "js/src/jsapi.cpp", "js/src/vm/AsyncFunction.cpp", "js/src/vm/AsyncFunction.h", "js/src/vm/CommonPropertyNames.h", "js/src/vm/GlobalObject.cpp", "js/src/vm/GlobalObject.h", "js/src/vm/HelperThreads.cpp", "js/src/vm/JSFunction.cpp"], "git_node": null, "git_parents": [null], "node": "82e03558dc9f5f403f20101dce9c899a34a2942c", "parents": ["226c1017cdbdfdefe3496c960a962a8796ef7a5f"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 14: Add JSProtoKey for GeneratorFunction. r=mgaudet\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42884", "files": ["js/public/Class.h", "js/public/ProtoKey.h", "js/src/jsapi.cpp", "js/src/vm/CommonPropertyNames.h", "js/src/vm/GeneratorObject.cpp", "js/src/vm/GeneratorObject.h", "js/src/vm/GlobalObject.cpp", "js/src/vm/GlobalObject.h", "js/src/vm/HelperThreads.cpp", "js/src/vm/JSFunction.cpp"], "git_node": null, "git_parents": [null], "node": "c13ce7a93ce92bc9952b5db1abfd029c9a892dac", "parents": ["82e03558dc9f5f403f20101dce9c899a34a2942c"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 15: Add JSProtoKey for AsyncGeneratorFunction. r=mgaudet\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42885", "files": ["js/public/Class.h", "js/public/ProtoKey.h", "js/src/jsapi.cpp", "js/src/vm/AsyncIteration.cpp", "js/src/vm/AsyncIteration.h", "js/src/vm/CommonPropertyNames.h", "js/src/vm/GlobalObject.cpp", "js/src/vm/GlobalObject.h", "js/src/vm/HelperThreads.cpp", "js/src/vm/JSFunction.cpp"], "git_node": null, "git_parents": [null], "node": "8f4cb4f8495c7c850f3649ab3d22dcefb0572a83", "parents": ["c13ce7a93ce92bc9952b5db1abfd029c9a892dac"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 16: Decouple Async(FromSync)IteratorPrototype initialisation from AsyncGeneneratorFunction. r=mgaudet\n\nAsyncGenerator initialisation isn't required to also always initialise AsyncFromSyncIteratorPrototype,\nso split AsyncFromSyncIteratorPrototype, and its prototype, AsyncFromIteratorPrototype, from the async\ngenerator initialisation.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42886", "files": ["js/src/vm/AsyncIteration.cpp", "js/src/vm/GlobalObject.h"], "git_node": null, "git_parents": [null], "node": "eafdeb4aaa02b2f4b0b8d7c3664cb8209cc3b534", "parents": ["8f4cb4f8495c7c850f3649ab3d22dcefb0572a83"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 17: Remove unnecessary NativeObject downcasts in GlobalObject methods. r=mgaudet\n\nMany `GlobalObject::getOrCreateXYZ()` methods explicitly perform casts to `NativeObject*`\neven though the callers directly assign to `JSObject*`. So remove all explicit casts to\n`NativeObject` which aren't needed in any callers to reduce unnecessary code and to make\nthe code a bit leaner.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42887", "files": ["js/src/vm/GlobalObject.h", "js/src/vm/Interpreter.cpp", "js/src/vm/SavedStacks.cpp"], "git_node": null, "git_parents": [null], "node": "d8176a4b1984fdf58b86fc77558a94c2ac87eadd", "parents": ["eafdeb4aaa02b2f4b0b8d7c3664cb8209cc3b534"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 18: Remove unnecessary JSFunction downcasts in GlobalObject methods. r=mgaudet\n\nSimilar to part 17, we can also remove unused casts to `JSFunction*`.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42888", "files": ["js/src/builtin/Promise.cpp", "js/src/vm/GlobalObject.h", "js/src/vm/TypedArrayObject.cpp"], "git_node": null, "git_parents": [null], "node": "ee723359cd0a6f39b0e5e1221e72c51417f48b94", "parents": ["d8176a4b1984fdf58b86fc77558a94c2ac87eadd"], "tags": []}, {"author": "Andr\u00e9 Bargull \u003candre.bargull@gmail.com\u003e", "branch": "default", "desc": "Bug 1288457 - Part 19: Add test case. r=mgaudet\n\nDifferential Revision: https://phabricator.services.mozilla.com/D42889", "files": ["js/src/tests/non262/Proxy/revoked-get-function-realm-typeerror.js"], "git_node": null, "git_parents": [null], "node": "e350706464ea616e32b6308559f90cc744223b75", "parents": ["ee723359cd0a6f39b0e5e1221e72c51417f48b94"], "tags": []}, {"author": "sotaro \u003csotaro.ikeda.g@gmail.com\u003e", "branch": "default", "desc": "Bug 1588987 - Do not trigger WR rendering during paused state r=nical\n\nDifferential Revision: https://phabricator.services.mozilla.com/D49379", "files": ["gfx/layers/wr/WebRenderBridgeParent.cpp"], "git_node": null, "git_parents": [null], "node": "3f55a2e620e469a319b079b968382f903170ed30", "parents": ["e350706464ea616e32b6308559f90cc744223b75"], "tags": 