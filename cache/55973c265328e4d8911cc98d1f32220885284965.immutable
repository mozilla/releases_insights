on", "services/settings/dumps/blocklists/addons-bloomfilters.json", "services/settings/dumps/main/devtools-compatibility-browsers.json", "services/settings/dumps/main/search-config-icons.json"], "git_node": "b00fc3695aedf2ba06666e8d912bc05caf711ee8", "git_parents": ["fb8671e172c70535763bb62abd56b858930013c0"], "node": "21618bc078ae968fb96cc0c9fe52eb74e1ceff27", "parents": ["8f4d724104faf532372684a9113de0687858a4f2"], "tags": []}], "date": 1772594321, "git_changesets": ["b00fc3695aedf2ba06666e8d912bc05caf711ee8"], "user": "rvandermeulen@mozilla.com"}, "24874": {"changesets": [{"author": "Nikki Sharpley \u003cnsharpley@mozilla.com\u003e", "branch": "default", "desc": "Bug 2014963 - Fix multiselection range when splitview is included  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D283107\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285850\n", "files": ["browser/base/content/browser-init.js", "browser/components/tabbrowser/content/drag-and-drop.js", "browser/components/tabbrowser/content/tabbrowser.js", "browser/components/tabbrowser/test/browser/tabs/browser_multiselect_tabs_using_Shift.js"], "git_node": "6fdedc77057b63327995461265e8d677db062857", "git_parents": ["b00fc3695aedf2ba06666e8d912bc05caf711ee8"], "node": "d2c188ae60f614b555013eb892d02adc0c447b11", "parents": ["21618bc078ae968fb96cc0c9fe52eb74e1ceff27"], "tags": []}, {"author": "Nikki Sharpley \u003cnsharpley@mozilla.com\u003e", "branch": "default", "desc": "Bug 2014358 - Don't allow pinning when splitview is part of multiselection  a=pascalc\n\n- if trying to pin a selection, pin all except splitviews\n\nOriginal Revision: https://phabricator.services.mozilla.com/D282643\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285851\n", "files": ["browser/components/tabbrowser/content/drag-and-drop.js"], "git_node": "914c3564be2ba7eb27a9311c5589c183e1c113c4", "git_parents": ["6fdedc77057b63327995461265e8d677db062857"], "node": "1bd65456885431b3a0f