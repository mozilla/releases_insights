c": "No Bug - Import translations from main\n", "files": ["mobile/android/android-components/components/browser/toolbar/src/main/res/values-brh/strings.xml", "mobile/android/android-components/components/compose/awesomebar/src/main/res/values-brh/strings.xml", "mobile/android/android-components/components/compose/awesomebar/src/main/res/values-eu/strings.xml", "mobile/android/android-components/components/compose/awesomebar/src/main/res/values-ru/strings.xml", "mobile/android/android-components/components/compose/awesomebar/src/main/res/values-vi/strings.xml", "mobile/android/android-components/components/compose/browser-toolbar/src/main/res/values-brh/strings.xml", "mobile/android/android-components/components/compose/cfr/src/main/res/values-brh/strings.xml", "mobile/android/android-components/components/feature/app-links/src/main/res/values-brh/strings.xml", "mobile/android/android-components/components/feature/autofill/src/main/res/values-brh/strings.xml", "mobile/android/android-components/components/feature/awesomebar/src/main/res/values-brh/strings.xml", "mobile/android/android-components/components/feature/contextmenu/src/main/res/values-brh/strings.xml", "mobile/android/android-components/components/feature/readerview/src/main/res/values-brh/strings.xml", "mobile/android/android-components/components/ui/widgets/src/main/res/values-brh/strings.xml", "mobile/android/fenix/app/src/main/res/values-cs/strings.xml", "mobile/android/fenix/app/src/main/res/values-eu/strings.xml", "mobile/android/fenix/app/src/main/res/values-ru/strings.xml", "mobile/android/fenix/app/src/main/res/values-tr/strings.xml", "mobile/android/fenix/app/src/main/res/values-vi/strings.xml", "mobile/android/focus-android/app/src/main/res/values-cs/strings.xml"], "git_node": "44d8470c2606cceb12b00fc9ecd6dab638ee472a", "git_parents": ["da7231f7a257368b7158b8739606985cd435bcac"], "node": "229f6d02888847ff228e0f3d6a9b686edd9d1a1c", "parents": ["a696c28adc671f2893577258e22154ce8635db2d"], "tags": []}], "date": 1773022835, "git_changesets": ["44d8470c2606cceb12b00fc9ecd6dab638ee472a"], "user": "ffxbld@lando.moz.tools"}, "24948": {"changesets": [{"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 2019372 - Clear native key bindings of the reply event  a=pascalc DONTBUILD\n\nThe parent process should handle only the shortcut key and access key\nwhen it receives a reply key event. Thus, the editor commands are not\nrequired, but the copy cost may not be cheap. Therefore, we should stop\ncopying them and the parent process should check whether the reply event\nhas unexpected edit commands or not.\n\nAnd also this makes `nsGUIEventIPC.h` sanitizes the `KeyNameIndex` and\n`CodeNameIndex`.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D286456\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286585\n", "files": ["dom/events/GlobalKeyListener.cpp", "dom/ipc/BrowserChild.cpp", "dom/ipc/BrowserParent.cpp", "toolkit/components/resistfingerprinting/nsRFPService.cpp", "toolkit/components/resistfingerprinting/nsRFPService.h", "widget/EventForwards.h", "widget/TextEvents.h", "widget/WidgetEventImpl.cpp", "widget/nsGUIEventIPC.h"], "git_node": "f9e8a639d18501a05c6b7a4868cd721a6129b402", "git_parents": ["44d8470c2606cceb12b00fc9ecd6dab638ee472a"], "node": "ffbc5bf1490b6702b7e2ebaac4b8a9f7f5d0da10", "parents": ["229f6d02888847ff228e0f3d6a9b686edd9d1a1c"], "tags": []}], "date": 1773045575, "git_changesets": ["f9e8a639d18501a05c6b7a4868cd721a6129b402"], "user": "pchevrel@mozilla.com"}, "24949": {"changesets": [{"author": "Chun-Min Chang \u003cchun.m.chang@gmail.com\u003e", "branch": "default", "desc": "Bug 2016329 - Rework CheckFrameData  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D283433\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286496\n", "files": ["dom/media/gmp/GMPVideoi420FrameImpl.cpp"], "git_node": "ac891503b35aed628fe0928e537a9f7a584a74e3", "git_parents": ["f9e8a639d18501a05c6b7a4868cd721a6129b402"], "node": "dddab69b256cfd40a9a70678afe711867d03d203", "parents": ["ffbc5bf1490b6702b7e2ebaac4b8a9f7f5d0da10"], "tags": []}], "date": 1773045616, "git_changesets": ["ac891503b35aed628fe0928e537a9f7a584a74e3"], "user": "pchevrel@mozilla.com"}, "24950": {"changesets": [{"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 2016349. r=ahale a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285582\n", "files": ["gfx/2d/FilterNodeSoftware.cpp", "gfx/2d/FilterNodeSoftware.h", "gfx/2d/Rect.h"], "git_node": "c758b4d200828de48798c55c50272f0b55688126", "git_parents": ["ac891503b35aed628fe0928e537a9f7a584a74e3"], "node": "697210be0ae4a4afa4de2b1325bad495c5920d11", "parents": ["dddab69b256cfd40a9a70678afe711867d03d203"], "tags": []}, {"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 2016351. r=ahale a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285584\n", "files": ["gfx/2d/FilterNodeSoftware.cpp", "gfx/2d/FilterNodeSoftware.h"], "git_node": "bfe5c5870fa9a8af278f9077b01020d0e74345af", "git_parents": ["c758b4d200828de48798c55c50272f0b55688126"], "node": "4e7995c89c6622fd7ddb0a538c1e4d9f73a29f5a", "parents": ["697210be0ae4a4afa4de2b1325bad495c5920d11"], "tags": []}], "date": 1773046261, "git_changesets": ["c758b4d200828de48798c55c50272f0b55688126", "bfe5c5870fa9a8af278f9077b01020d0e74345af"], "user": "pchevrel@mozilla.com"}, "24951": {"changesets": [{"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 2020906 - Improve FoldTests pattern matching.  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D286003\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286613\n", "files": ["js/src/jit/IonAnalysis.cpp"], "git_node": "5a98ab913c5a0dbb34bcb9c1b73e4c70052b58ae", "git_parents": ["bfe5c5870fa9a8af278f9077b01020d0e74345af"], "node": "ca1c21cbcbff02beea283817777c0cad68ecbb53", "parents": ["4e7995c89c6622fd7ddb0a538c1e4d9f73a29f5a"], "tags": []}], "date": 1773046577, "git_changesets": ["5a98ab913c5a0dbb34bcb9c1b73e4c70052b58ae"], "user": "pchevrel@mozilla.com"}, "24952": {"changesets": [{"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 2015359 - Use MADV_FREE instead of MADV_FREE_REUSABLE + MADV_FREE_REUSE on MacOS.  a=pascalc DONTBUILD\n\nMacOS Tahoe has a bug where (very intermittently) pages can be zeroed by the kernel\nafter going through `madvise` with `MADV_FREE_REUSABLE` and then `MADV_FREE_REUSE`.\n\nThe fuzz bug triggers this issue in the JS shell and we've also seen an increase in crashes\non Mac after the release of Tahoe, with very similar signatures. I've been able to\nreproduce this with a stand-alone C++ test case and the issue has been reported to Apple.\n\nI haven't been able to reproduce this bug with `MADV_FREE` so this patch switches back to\nthat, reverting bug 1567366 and bug 1682947. Unfortunately this means our RSS numbers are\nlikely to increase.\n\nThe JIT code allocator also uses `MADV_FREE_REUSABLE` and `MADV_FREE_REUSE` but it's\nmore complex and it's not clear if it's affected the same way, so let's start with the\nGC memory allocator and see what the effect is on crash rates.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D285226\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286610\n", "files": ["js/src/gc/Memory.cpp"], "git_node": "f40393eba7a05d6d025db35661209beb9316185b", "git_parents": ["5a98ab913c5a0dbb34bcb9c1b73e4c70052b58ae"], "node": "e39020db92289c45b3752155c164141a6f459425", "parents": ["ca1c21cbcbff02beea283817777c0cad68ecbb53"], "tags": []}], "date": 1773046669, "git_changesets": ["f40393eba7a05d6d025db35661209beb9316185b"], "user": "pchevrel@mozilla.com"}, "24953": {"changesets": [{"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 2020553: Update the hash probabilities for collection  a=pascalc DONTBUILD\n\nSome canvas hashes appeared in both HW and SW results.\nhe script used to generate the probabilities used the\nlesser of the numbers when choosing the probability,\nresulting in 7 having a very large difference, and\nmany others having a small difference.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D285662\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286477\n", "files": ["toolkit/components/resistfingerprinting/CanvasHashData.sys.mjs"], "git_node": "f699b8032c33032d3e75d6bb26805d7c3b3064f8", "git_parents": ["f40393eba7a05d6d025db35661209beb9316185b"], "node": "504b5fd9ee617f83d77e7dc3213bc60cadf53f5c", "parents": ["e39020db92289c45b3752155c164141a6f459425"], "tags": []}], "date": 1773046732, "git_changesets": ["f699b8032c33032d3e75d6bb26805d7c3b3064f8"], "user": "pchevrel@mozilla.com"}, "24954": {"changesets": [{"author": "AndiAJ \u003candiaj@users.noreply.github.com\u003e", "branch": "default", "desc": "Bug 2021581 - Disable failing verifyShowSearchSuggestionsToggleTest UI tests  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D286478\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286479\n", "files": ["mobile/android/fenix/app/src/androidTest/java/org/mozilla/fenix/ui/NavigationToolbarTest.kt", "mobile/android/fenix/app/src/androidTest/java/org/mozilla/fenix/ui/SettingsSearchTest.kt"], "git_node": "a1483c1346f6de5f053bb524f43f542fd8d85f19", "git_parents": ["f699b8032c33032d3e75d6bb26805d7c3b3064f8"], "node": "e2a71159bbf98eb22be085a40638f1e72e9799c7", "parents": ["504b5fd9ee617f83d77e7dc3213bc60cadf53f5c"], "tags": []}], "date": 1773046814, "git_changesets": ["a1483c1346f6de5f053bb524f43f542fd8d85f19"], "user": "pchevrel@mozilla.com"}, "24955": {"changesets": [{"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": 