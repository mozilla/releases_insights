arch.js"], "git_node": "ebd5a73105d920035f509a4aab42aebe35467c8d", "git_parents": ["674830de7ced1dbbc9ff103b87b9da8e628657ea"], "node": "b885dcb866618cee5aabd33635953378b26dbc33", "parents": ["05d49568a7988b753c092428da76462cfa5db397"], "tags": []}], "date": 1772895667, "git_changesets": ["ebd5a73105d920035f509a4aab42aebe35467c8d"], "user": "dmeehan@mozilla.com"}, "24940": {"changesets": [{"author": "Sotaro Ikeda \u003csotaro.ikeda.g@gmail.com\u003e", "branch": "default", "desc": "Bug 2019515 - Relax the case that do video scaling at VideoProcessor in DCSurfaceVideo::CalculateSwapChainSize()  a=dmeehan\n\nThe change of  Bug 2007464 was too strict. This change relax the condition a bit to increase a case that do video scaling at VideoProcessor.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D285450\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286203\n", "files": ["gfx/webrender_bindings/DCLayerTree.cpp"], "git_node": "a6d62df1b55d6d398b1c31fa2ffda39c0a04a8fc", "git_parents": ["ebd5a73105d920035f509a4aab42aebe35467c8d"], "node": "bdacaf69c21a1a01a23445769d30fd41c9ad9705", "parents": ["b885dcb866618cee5aabd33635953378b26dbc33"], "tags": []}], "date": 1772895871, "git_changesets": ["a6d62df1b55d6d398b1c31fa2ffda39c0a04a8fc"], "user": "dmeehan@mozilla.com"}, "24941": {"changesets": [{"author": "Vincent Hilla \u003cvhilla@mozilla.com\u003e", "branch": "default", "desc": "Bug 2020300 - Force sync about:blank despite Document::mOnloadBlockCount.  a=dmeehan DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D285563\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286338\n", "files": ["docshell/base/nsDocShell.cpp", "docshell/test/browser/browser_initialDocument_noLoadBlocking.js", "dom/base/Document.cpp", "dom/base/Document.h", "uriloader/base/nsDocLoader.cpp"], "git_node": "70152dec65bdef97d0c85e8a01279ba6b858012e", "git_parents": ["a6d62df1b55d6d398b1c31fa2ffda39c0a04a8fc"], "node": "e0f4cebc4b9108e40b9f529d7062ef06b29628e1", "parents": ["bdacaf69c21a1a01a23445769d30fd41c9ad9705"], "tags": []}], "date": 1772896329, "git_changesets": ["70152dec65bdef97d0c85e8a01279ba6b858012e"], "user": "dmeehan@mozilla.com"}, "24942": {"changesets": [{"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 2017622 - Check incoming symbol edges at the start of gray weak marking  a=dmeehan DONTBUILD\n\nThe problem that bug 2013561 was trying to solve was that if we find a symbol\nkey in a weakmap that we think should be gray, if we are currently marking\nblack then we can't mark it and it won't get marked in time for the weakmap\nentry's value to get marked.\n\nMoving the check to the start of weak marking fixed one problem but caused\nanother, because it only applied to weakmaps that had been discovered to be\nlive at the start of weak marking. So weakmaps discovered after this point were\nnot marked correctly.\n\nIn general I like the original approach of checking for this condition when the\nweakmap is marked. We can fix the gray marking problem by doing a single scan\nat the start of gray weak marking to mark any sybol keys we otherwise missed.\nAny weakmaps discovered after this point will be handled by the original check.\n\nThis patch is a combination of both approaches and adds back the original code.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284285\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286480\n", "files": ["js/src/gc/GCRuntime.h", "js/src/gc/Sweeping.cpp", "js/src/gc/WeakMap-inl.h"], "git_node": "306a582a7f6d166c4d9143e14aaf20acf27b17a1", "git_parents": ["70152dec65bdef97d0c85e8a01279ba6b858012e"], "node": "1be25bd2cf371bb4aa752e4881e1e7c902ac4756", "parents": ["e0f4cebc4b9108e40b9f529d7062ef06b29628e1"], "tags": []}], "date": 1772896378, "git_changesets": ["306a582a7f6d166c4d9143e14aaf20acf27b17a1"], "user": "dmeehan@mozilla.com"}, "24943": {"changesets": [{"author": "John Lin \u003cjolin@mozilla.com\u003e", "branch": "default", "desc": "Bug 2020174 - validate buffer size before allocation.  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D286161\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286452\n", "files": ["dom/media/MediaData.cpp"], "git_node": "7fbb172b886fc56e9e5916c8e0a35c1d8aca4a81", "git_parents": ["306a582a7f6d166c4d9143e14aaf20acf27b17a1"], "node": "98a5f44d584713be0bd5df3e8b6e067402814e2d", "parents": ["1be25bd2cf371bb4aa752e4881e1e7c902ac4756"], "tags": []}, {"author": "Karl Tomlinson \u003ckarlt+@karlt.net\u003e", "branch": "default", "desc": "Bug 2018102 validate chroma plane strides for VideoData::CreateAndCopyData()  a=dmeehan\n\nand assert that plane sizes match subsampling.\n\nDepends on D286452\n\nOriginal Revision: https://phabricator.services.mozilla.com/D285683\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286509\n", "files": ["dom/media/MediaData.cpp", "dom/media/platforms/agnostic/VPXDecoder.cpp"], "git_node": "697a459ae30e05b41baf8fef1ac28f9c44f2040e", "git_parents": ["7fbb172b886fc56e9e5916c8e0a35c1d8aca4a81"], "node": "60136a39180a0ef74d292ede77b8c0de43d812c6", "parents": ["98a5f44d584713be0bd5df3e8b6e067402814e2d"], "tags": []}, {"author": "Karl Tomlinson \u003ckarlt+@karlt.net\u003e", "branch": "default", "desc": "Bug 2018102 validate alpha plane for VideoData::CreateAndCopyData()  a=dmeehan\n\nOriginal Revision: https://phabricator.services.mozilla.com/D285684\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286510\n", "files": ["dom/media/MediaData.cpp"], "git_node": "a3d1f571e36ff7ab7378fd9083b7839b8b852a71", "git_parents": ["697a459ae30e05b41baf8fef1ac28f9c44f2040e"], "node": "869fba2e8d7efcb9d039dad56d3b3f359ccc1cf2", "parents": ["60136a39180a0ef74d292ede77b8c0de43d812c6"], "tags": []}], "date": 1772896928, "git_changesets": ["7fbb172b886fc56e9e5916c8e0a35c1d8aca4a81", "697a459ae30e05b41baf8fef1ac28f9c44f2040e", 