fbae", "parents": ["c794d22e5e014728425fa1adec0416fd9c54cc33"], "tags": []}], "date": 1772096728, "git_changesets": ["f2c53d0995164baa6fb0a9cec4a640179ae13396", "89ce14a4315f7902e231d7375d2fe0e6176df5f0"], "user": "ffxbld@lando.moz.tools"}, "24786": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP remote-settings tld-suffixes mobile-experiments ct-logs -  a=diannaS\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285001\n", "files": ["mobile/android/fenix/app/src/main/res/raw/initial_experiments.json", "netwerk/dns/effective_tld_names.dat", "security/ct/CTKnownLogs.h", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "security/manager/tools/log_list.json", "services/settings/dumps/blocklists/addons-bloomfilters.json", "services/settings/dumps/blocklists/gfx.json", "services/settings/dumps/main/devtools-compatibility-browsers.json", "services/settings/dumps/security-state/intermediates.json"], "git_node": "4b60f1956cad3bccbd00105bd68aa720d98a9a8b", "git_parents": ["89ce14a4315f7902e231d7375d2fe0e6176df5f0"], "node": "18994ea4678ba6dc1eb0a774cbf53989c7fee3e9", "parents": ["6521f536d493b12496cf8f7c08914bad890efbae"], "tags": []}], "date": 1772122910, "git_changesets": ["4b60f1956cad3bccbd00105bd68aa720d98a9a8b"], "user": "dsmith@mozilla.com"}, "24787": {"changesets": [{"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 2018257 - Undo simplification changes in ContentSearchParent that were done in bug 2003294.  a=diannaS\n\nThis will make it easier for the work in bug 2017049.\n\nThis undoes the work in commit aca14b8e67152e57d223b50bdf3dba99f4324d9e, accounting for changes made since.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284294\n\nDifferential Revision: https://phabricator.services.mozilla.com/D284712\n", "files": ["browser/actors/ContentSearchParent.sys.mjs", "browser/components/search/content/contentSearchHandoffUI.mjs", "browser/components/search/test/browser/browser_contentSearch.js"], "git_node": "88d0da2774524865a71bab2030bf686677861082", "git_parents": ["4b60f1956cad3bccbd00105bd68aa720d98a9a8b"], "node": "3b7e5160fb0e89c17c84d79f84bd5a904c8c4a3e", "parents": ["18994ea4678ba6dc1eb0a774cbf53989c7fee3e9"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 2018257 - Restore messages from ContentSearchParent that were removed in bug 2003294 and used for the non-handoff searchbar.  a=diannaS\n\nThis will make it easier for the work in bug 2017049.\n\nThis undoes the work in commit 8943ca67c923f392cbd8321c402ac4f434cd9a62, accounting for\tchanges\tmade since.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284295\n\nDifferential Revision: https://phabricator.services.mozilla.com/D284713\n", "files": ["browser/actors/ContentSearchParent.sys.mjs", "browser/components/search/test/browser/browser.toml", "browser/components/search/test/browser/browser_contentSearch.js", "browser/components/search/test/browser/contentSearchSuggestions.sjs", "browser/components/search/test/browser/contentSearchSuggestions.xml"], "git_node": "65e4e1fd43a57262baa8ad07bf9624ee522bf4ca", "git_parents": ["88d0da2774524865a71bab2030bf686677861082"], "node": "f2c2a4b8f2955b3f2272537e8a2cdeebe9fd5a3f", "parents": ["3b7e5160fb0e89c17c84d79f84bd5a904c8c4a3e"], "tags": []}, {"author": "Mike Conley \u003cmike@conley.io\u003e", "branch": "default", "desc": "Bug 2017049 - Part 1: Revive ContentSearchUIController and put it into contentSearchHandoffUI.mjs.  a=diannaS\n\nThis is an almost verbatim revival of the ContentSearchUIController that used to live inside\nof a script called \"contentSearchUI.js\", which got removed in Bug 1999334. We place this inside\nof contentSearchHandoffUI.mjs so that the search handoff component can use it in a \"non-handoff\"\nmode.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284289\n\nDifferential Revision: https://phabricator.services.mozilla.com/D284714\n", "files": ["browser/components/search/content/contentSearchHandoffUI.mjs"], "git_node": "21e251410bac3a6c3f14981c28b6d1b68f2aeb8d", "git_parents": ["65e4e1fd43a57262baa8ad07bf9624ee522bf4ca"], "node": "9117519681c812b1550f93f6687eff87640f8303", "parents": ["f2c2a4b8f2955b3f2272537e8a2cdeebe9fd5a3f"], "tags": []}, {"author": "Mike Conley \u003cmike@conley.io\u003e", "branch": "default", "desc": "Bug 2017049 - Part 2: Wire up ContentSearchUIController to ContentSearchHandoffUI component and revive handoff pref support.  a=diannaS\n\nAlongside adding the required integration between ContentSearchHandoffUI and\nContentSearchUIController, this also adds a pref-read to SearchUIUtils for the\nexternal widget registrar for newtab to choose whether or not to use handoff\nor non-handoff mode.\n\nProbably the most notable absence in this wiring up is a complete lack of tests.\n\nWe've decided not to revive / modify our automated tests for this mode, mainly\ndue to the challenge of maintaining the test support for both cases while we\nwork on completely replacing this mechanism down the road. So we're relying\nentirely on manual testing here, and the majority of the automated testing\nis really just to ensure that the handoff mode hasn't regressed somehow\nfrom this revival.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284290\n\nDifferential Revision: https://phabricator.services.mozilla.com/D284715\n", "files": ["browser/app/profile/firefox.js", "browser/components/search/SearchUIUtils.sys.mjs", "browser/components/search/content/contentSearchHandoffUI.mjs"], "git_node": "6bfdd4c9c81789bcb00155127dd0fbf9d7df4b1e", "git_parents": ["21e251410bac3a6c3f14981c28b6d1b68f2aeb8d"], "node": "ca03f9e35f19dbe3ceb13c669b67d48c94083d21", "parents": ["9117519681c812b1550f93f6687eff87640f8303"], "tags": []}, {"author": "Mike Conley \u003cmike@conley.io\u003e", "branch": "default", "desc": "Bug 2017049 - Part 3: Revive contentSearchUI styles and inline newtab style modifications.  a=diannaS\n\nThis is pretty ham-fisted, but it's also a temporary kludge until we can get the inline\nsearch mechanism done and we can remove all of this.\n\nEssentially, this revives and inlines the old non-handoff CSS from contentSearchUI.css into\ncontentSearchHandoffUI.css, but only uses it in non-handoff mode. It also includes a bunch\nof additional overrides that newtab had historically been applying to contentSearchUI.css,\nbut those are now inlined directly. This way, we can get the behaviour and appearance that\nwe want without relying on newtab needing to update its sheets / send out a train-hop release\nto support this revived mode.\n\nThe CSS rules have not been de-duplicated / simplified, beyond the inlining of various variables\nthat historically had lived within activity-stream.css. I honestly don't think such a\nsimplification / cleanup is worth the effort since this is so temporary.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284291\n\nDifferential Revision: https://phabricator.services.mozilla.com/D284716\n", "files": ["browser/components/search/content/contentSearchHandoffUI.css"], "git_node": "ae90ce6961040c7d0b84080c0ec52eceef275221", "git_parents": ["6bfdd4c9c81789bcb00155127dd0fbf9d7df4b1e"], "node": "36ec63aa20eb2bcacac19ba947c7be16eb3e065e", "parents": ["ca03f9e35f19dbe3ceb13c669b67d48c94083d21"], "tags": []}], "date": 1772124702, "git_changesets": ["88d0da2774524865a71bab2030bf686677861082", "65e4e1fd43a57262baa8ad07bf9624ee522bf4ca", "21e251410bac3a6c3f14981c28b6d1b68f2aeb8d", "6bfdd4c9c81789bcb00155127dd0fbf9d7df4b1e", "ae90ce6961040c7d0b84080c0ec52eceef275221"], "user": "dsmith@mozilla.com"}, "24788": {"changesets": [{"author": "Keith Cirkel \u003ckeithamus@users.noreply.github.com\u003e", "branch": "default", "desc": "Bug 2017858 - Fix test; CloseWatcher is exposed in all channels r=dom-core,webidl,smaug a=test-only DONTBUILD\n\nDifferential Revision: https://phabricator.services.mozilla.com/D284638\n", "files": ["dom/tests/mochitest/general/test_interfaces.js"], "git_node": "7990ad0c2a7af3b59001623e560e51d2408c7898", "git_parents": ["ae90ce6961040c7d0b84080c0ec52eceef275221"], "node": "5160eecfbf752a2d9122a269d23e12e429e0871e", "parents": ["36ec63aa20eb2bcacac19ba947c7be16eb3e065e"], "tags": []}], "date": 1772124803, "git_changesets": ["7990ad0c2a7af3b59001623e560e51d2408c7898"], "user": "archaeopteryx@coole-files.de"}, "24789": {"changesets": [{"author": "Sarah Chung \u003csachung@mozilla.com\u003e", "branch": "default", "desc": "Bug 2014272 - Add pref flip for Smart Window onboarding screen  a=diannaS DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D283979\n\nDifferential Revision: https://phabricator.services.mozilla.com/D284698\n", "files": ["browser/components/aboutwelcome/modules/AboutWelcomeDefaults.sys.mjs", "browser/components/aboutwelcome/tests/browser/browser_aboutwelcome_attribution.js"], "git_node": "cee8c6c7031b307f8f2927016ff3e2f9c1b2f9e0", "git_parents": ["7990ad0c2a7af3b59001623e560e51d2408c7898"], "node": "6c3434a2b66ddff9109173cec5add98c1c165da7", "parents": ["5160eecfbf752a2d9122a269d23e12e429e0871e"], "tags": []}], "date": 1772124963, "git_changesets": ["cee8c6c7031b307f8f2927016ff3e2f9c1b2f9e0"], "user": "dsmith@mozilla.com"}, "24790": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 2017500 - Null-check host when computing auto directionality.  a=diannaS DONTBUILD\n\nRestores behavior when running this after unlinking.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284686\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285030\n", "files": ["dom/base/DirectionalityUtils.cpp", "testing/web-platform/tests/shadow-dom/directionality-003-crash.html"], "git_node": "a1b67cf98a792d8a46bb24545ee55587366c752f", "git_parents": ["cee8c6c7031b307f8f2927016ff3e2f9c1b2f9e0"], "node": "1d52b7399205f23b517ae0fdc85ca498c0c237fe", "parents": ["6c3434a2b66ddff9109173cec5add98c1c165da7"], "tags": []}], "date": 1772126669, "git_changesets": ["a1b67cf98a792d8a46bb24545ee55587366c752f"], "user": "dsmith@mozilla.com"}, "24791": {"changesets": [{"author": "mike a. \u003cmavduevskiy@mozilla.com\u003e", "branch": "default", "desc": "Bug 2015790 - Fix repeated pin request for PBM  a=diannaS DONTBUILD\n\nChanging the lifecycle state from 'onViewCreated' to 'onResume' for the prompt request while fixing bug2011477 was meant to insure that we always request the prompt, but 'onResume' breaks the authentication flow if the user uses a pin or a pattern instead of biometrics. The pin and pattern screens trigger a separate system activity while the biometrics uses a dialog fragment. Using an activity is essentially leaving the app, and the 'onResume' method is triggered upon returning to the app, which would retrigger the prompt, creating a loop.\n\nThe patch returns the initial flow while keeping the fix for the screensaver bug2011477. It is unfortunate that we will not show the prompt for those who have both a screenlock and a screensaver and activate their phone by touching the screen or the gyro, but keeping track of lifecycle locally is usually a bad idea. User can always request the prompt from the lock fragment.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284558\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285065\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/pbmlock/UnlockPrivateTabsFragment.kt"], "git_node": "2e09d9389654659c5403b3130cf6969c14fa7d82", "git_parents": ["a1b67cf98a792d8a46bb24545ee55587366c752f"], "node": "2e1759f8946fa3e1a24cddedcffa775a0efb7635", "parents": ["1d52b7399205f23b517ae0fdc85ca498c0c237fe"], "tags": []}], "date": 1772126764, "git_changesets": ["2e09d9389654659c5403b3130cf6969c14fa7d82"], "user": "dsmith@mozilla.com"}, "24792": {"changesets": [{"author": "Jamie Nicol \u003cjnicol@mozilla.com\u003e", "branch": "default", "desc": "Bug 2017901 - Ensure screen pixels HardwareBuffer remains alive while in use.  a=diannaS\n\nTo capture screen pixels on Android we create an AHardwareBuffer and\nblit the contents of the framebuffer into it. This then gets sent to\nthe widget side via a unix socket, from which another AHardwareBuffer\ninstance (referring to the same underlying buffer) is obtained.\nFinally we memcpy from the buffer into a Java Bitmap.\n\nOn a handful of Exynos devices we are seeing segfaults when attempting\nto memcpy from the AHardwareBuffer on the widget side. Technically we\nmust ensure that the original AHardwareBuffer remains alive until we\nhave finished deserializing the second AHardwareBuffer from the\nsocket, which we were not doing. However, that alone does not avoid\nthe crash. To avoid the crash on Exynos we must ensure that the\noriginal AHardwareBuffer remains alive until we have completely\nfinished using the buffer (i.e. the memcpy is complete).\n\nPresumably there is an Exynos bug which frees the underyling resource\nwhen the original AHardwareBuffer is released, even if another\nAHardwareBuffer referring to the same resource remains alive. Note\nthis only occurs when the GPU process is disabled, meaning that both\nAHardwareBuffer instances reside in the same process.\n\nThis patch avoids this bug by making\nUiCompositorControllerParent::SendScreenPixels() return asynchronously\nwhen the child side has finished using the hardware buffer. The parent\nside holds a reference to the HardwareBuffer until this returns. In\nUiCompositorControllerChild::RecvScreenPixels() we ensure\nmScreenPixelsPromise is resolved using synchronous dispatch, meaning\nthe memcpy() has completed, prior to calling the resolver to notify\nthe parent side we are done.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284679\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285017\n", "files": ["gfx/layers/ipc/PUiCompositorController.ipdl", "gfx/layers/ipc/UiCompositorControllerChild.cpp", "gfx/layers/ipc/UiCompositorControllerChild.h", "gfx/layers/ipc/UiCompositorControllerParent.cpp"], "git_node": "2f836fb98cd00f3e764aaae583acada6e51a3136", "git_parents": ["2e09d9389654659c5403b3130cf6969c14fa7d82"], "node": "2dc77ea005cde7590b60f6852075c57f91771682", "parents": ["2e1759f8946fa3e1a24cddedcffa775a0efb7635"], "tags": []}], "date": 1772126807, "git_changesets": ["2f836fb98cd00f3e764aaae583acada6e51a3136"], "user": "dsmith@mozilla.com"}, "24793": {"changesets": [{"author": "Michael Hynson \u003cmhynson@mozilla.com\u003e", "branch": "default", "desc": "Bug 2017742 - Remove ipprotection.usage_rx and ipprotection.usage_tx usage metrics.  a=diannaS DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284356\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285116\n", "files": ["browser/components/ipprotection/IPPProxyManager.sys.mjs", "browser/components/ipprotection/IPProtectionUsage.sys.mjs", "browser/components/ipprotection/docs/Components.rst", "browser/components/ipprotection/metrics.yaml", "browser/components/ipprotection/moz.build", "browser/components/ipprotection/tests/browser/browser.toml", "browser/components/ipprotection/tests/browser/browser_ipprotection_usage.js", "browser/components/ipprotection/tests/xpcshell/test_IPProtectionUsage.js", "browser/components/ipprotection/tests/xpcshell/xpcshell.toml"], "git_node": "d0ec602be9e43d6551931996fd3e724c42c7ccfd", "git_parents": ["2f836fb98cd00f3e764aaae583acada6e51a3136"], "node": "5484baf7f53bbad76b63fe23dddda0daca8732a8", "parents": ["2dc77ea005cde7590b60f6852075c57f91771682"], "tags": []}], "date": 1772137168, "git_changesets": ["d0ec602be9e43d6551931996fd3e724c42c7ccfd"], "user": "dsmith@mozilla.com"}, "24794": {"changesets": [{"author": "Kelly Cochrane \u003ckcochrane@mozilla.com\u003e", "branch": "default", "desc": "Bug 1992744 - Add telemetry for split view  a=diannaS\n\nOriginal Revision: https://phabricator.services.mozilla.com/D283760\n\nDifferential Revision: https://phabricator.services.mozilla.com/D284829\n", "files": ["browser/components/tabbrowser/content/tabbrowser.js", "browser/components/tabbrowser/content/tabsplitview.js", "browser/components/tabbrowser/metrics.yaml", "browser/components/tabbrowser/test/browser/tabs/browser_tab_splitview_telemetry.js", "toolkit/content/widgets/tabbox.js"], "git_node": "616122b0fa81e1076e2f09c0fc895514cbf55a77", "git_parents": ["d0ec602be9e43d6551931996fd3e724c42c7ccfd"], "node": "b36a702c76d9eead33a5d11f2b4bcf028f393edf", "parents": ["5484baf7f53bbad76b63fe23dddda0daca8732a8"], "tags": []}], "date": 1772137916, "git_changesets": ["616122b0fa81e1076e2f09c0fc895514cbf55a77"], "user": "dsmith@mozilla.com"}, "24795": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Import translations from main\n", "files": ["mobile/android/android-components/components/browser/errorpages/src/main/res/values-km/strings.xml", "mobile/android/android-components/components/browser/toolbar/src/main/res/values-km/strings.xml", "mobile/android/android-components/components/compose/browser-toolbar/src/main/res/values-km/strings.xml", "mobile/android/android-components/components/feature/addons/src/main/res/values-km/strings.xml", "mobile/android/android-components/components/feature/addons/src/main/res/values-ru/strings.xml", "mobile/android/android-components/components/feature/media/src/main/res/values-trs/strings.xml", "mobile/android/android-components/components/feature/prompts/src/main/res/values-cs/strings.xml", "mobile/android/android-components/components/feature/prompts/src/main/res/values-km/strings.xml", "mobile/android/android-components/components/feature/prompts/src/main/res/values-th/strings.xml", "mobile/android/android-components/components/feature/prompts/src/main/res/values-trs/strings.xml", "mobile/android/fenix/app/src/main/res/values-bqi/strings.xml", "mobile/android/fenix/app/src/main/res/values-cs/strings.xml", "mobile/android/fenix/app/src/main/res/values-gd/strings.xml", "mobile/android/fenix/app/src/main/res/values-km/strings.xml", "mobile/android/fenix/app/src/main/res/values-pt-rBR/strings.xml", "mobile/android/fenix/app/src/main/res/values-ru/strings.xml", "mobile/android/fenix/app/src/main/res/values-th/strings.xml", "mobile/android/fenix/app/src/main/res/values-trs/strings.xml", "mobile/android/focus-android/app/src/main/res/values-cs/strings.xml", "mobile/android/focus-android/app/src/main/res/values-es-rAR/strings.xml", "mobile/android/focus-android/app/src/main/res/values-pt-rBR/strings.xml", "mobile/android/focus-android/app/src/main/res/values-ru/strings.xml"], "git_node": "4cee72246e3701fc7a1f140ec9968a18c3aaba6f", "git_parents": ["616122b0fa81e1076e2f09c0fc895514cbf55a77"], "node": "315e48fadf20d974af4c3bd4ac98711f70aa351e", "parents": ["b36a702c76d9eead33a5d11f2b4bcf028f393edf"], "tags": []}], "date": 1772158524, "git_changesets": ["4cee72246e3701fc7a1f140ec9968a18c3aaba6f"], "user": "ffxbld@lando.moz.tools"}, "24796": {"changesets": [{"author": "unifolia \u003cjlewis@mozilla.com\u003e", "branch": "default", "desc": "Bug 2010728 - 'New AI Window' and 'New Classic Window' items shown in macOS File menu when no Firefox windows are open  a=pascalc\n\nWhen no windows open:\n- Smart Window //File menu// items should not appear if **!**browser.smartwindow.enabled\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284723\n\nDifferential Revision: https://phabricator.services.mozilla.com/D284966\n", "files": ["browser/base/content/browser-sets.js", "browser/base/content/browser.js", "browser/components/aiwindow/ui/modules/AIWindow.sys.mjs", "browser/components/aiwindow/ui/test/browser/browser_open_aiwindow.js"], "git_node": "6f720071cbfcbf609f60019f7630b86db1b92b7c", "git_parents": ["4cee72246e3701fc7a1f140ec9968a18c3aaba6f"], "node": "c9441024d1c973735907cf46889669eb40a098ba", "parents": ["315e48fadf20d974af4c3bd4ac98711f70aa351e"], "tags": []}], "date": 1772180233, "git_changesets": ["6f720071cbfcbf609f60019f7630b86db1b92b7c"], "user": "pchevrel@mozilla.com"}, "24797": {"changesets": [{"author": "apostrophest \u003cstephen@chomadoma.net\u003e", "branch": "default", "desc": "Bug 1996471 - fixes for intermittent browser_tab_splitview_contextmenu.js  a=pascalc DONTBUILD\n\nUpdates MutationObserver arguments to ensure that the observers get called when the mutation condition holds.\n\nThis test was failing intermittently and caused an unrelated patch of mine (bug 2015874) to be backed out. I couldn't figure out why or whether my patch might be causing problems to this test. However, I was able to consistently reproduce this test's timeouts on Windows on firefox-main without any of my patches.\n\nEven with this fix, it seems that bug 1994508 is still present, resulting in intermittent issues on macOS 10.15. I'm keeping this test skipped for that version and keeping that bug open.\n\n1. MutationObserver monitors child elements using `childList`, not `children`\n2. The \"remove split view from group\" menu item is tricky because the l10n engine changes the `label` attribute from \"Remove from Groups\" to \"Remove from Group\" but there are two mutation observers: this test, and the menuitem itself. The menuitem has a mutation observer that reflects `label` attribute changes to its `.menu-text` child's text content, but there is a risk that this test's mutation observer runs before the menuitem. In order to ensure that the test can always see changes to the textContent, it was not enough to just use `characterData` because the text is updated on a child element. Both `characterData` and `subtree` seemed to consistently pick up changes to the menuitem text.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284736\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285068\n", "files": ["browser/components/tabbrowser/test/browser/tabs/browser.toml", "browser/components/tabbrowser/test/browser/tabs/browser_tab_splitview_contextmenu.js"], "git_node": "26de17a1e0f52aaa68ccf3910a62a15747e4a2b2", "git_parents": ["6f720071cbfcbf609f60019f7630b86db1b92b7c"], "node": "db021ad667c2d5407dd7a6726e3d93ee8e3d1600", "parents": ["c9441024d1c973735907cf46889669eb40a098ba"], "tags": []}], "date": 1772180271, "git_changesets": ["26de17a1e0f52aaa68ccf3910a62a15747e4a2b2"], "user": "pchevrel@mozilla.com"}, "24798": {"changesets": [{"author": "Kelly Cochrane \u003ckcochrane@mozilla.com\u003e", "branch": "default", "desc": "Bug 2019680 - Update tabSwitch messaging to only fire after every 3 tab switches  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D285074\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285077\n", "files": ["browser/components/asrouter/tests/browser/browser_trigger_listeners.js", "browser/components/tabbrowser/content/tabbrowser.js"], "git_node": "ed549359360640cc3574e0818b7dabcf59b6a714", "git_parents": ["26de17a1e0f52aaa68ccf3910a62a15747e4a2b2"], "node": "f7b0705a9149df5e16bb20f6987f3c95c6046ca9", "parents": ["db021ad667c2d5407dd7a6726e3d93ee8e3d1600"], "tags": []}], "date": 1772180321, "git_changesets": ["ed549359360640cc3574e0818b7dabcf59b6a714"], "user": "pchevrel@mozilla.com"}, "24799": {"changesets": [{"author": "Nathan Barrett \u003cnbarrett@mozilla.com\u003e", "branch": "default", "desc": "Bug 2016943 - Fix browsertime errors with updated speculative connect api  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D283978\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285118\n", "files": ["testing/raptor/browsertime/speculative-connect.js"], "git_node": "2380d246fabf8b1ae164483109646b7c97281bda", "git_parents": ["ed549359360640cc3574e0818