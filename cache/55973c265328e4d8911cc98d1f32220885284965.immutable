m/D287765\n", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/WebAuthnCredentialManager.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/WebAuthnTokenManager.java"], "git_node": "c0b07997f1948046160ae2efbeffd15e0b56a7fd", "git_parents": ["30f1e62ba6f297b793873f90e832a0a61a55db68"], "node": "7197e078fc2298dad889ed9d2923622d0a666dda", "parents": ["22055051fd2c32781a3f3e78244946f9608cadd1"], "tags": []}], "date": 1773484305, "git_changesets": ["c0b07997f1948046160ae2efbeffd15e0b56a7fd"], "user": "pchevrel@mozilla.com"}, "25071": {"changesets": [{"author": "Greg Stoll \u003cgreg@gregstoll.com\u003e", "branch": "default", "desc": "Bug 2022643 - skip UTF-8 BOM when parsing prefs files  a=pascalc DONTBUILD\n\nOur telemetry data indicates that this is pretty common. (in an admittedly\nsmall sample) I will continue monitoring the failure rate after this goes\nin to see if we get any improvements in Nightly.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D287210\n\nDifferential Revision: https://phabricator.services.mozilla.com/D287562\n", "files": ["modules/libpref/parser/src/lib.rs", "modules/libpref/test/gtest/Parser.cpp"], "git_node": "59799b7b228bcefd39a3a05f951150d3bbe8aa75", "git_parents": ["c0b07997f1948046160ae2efbeffd15e0b56a7fd"], "node": "3fb327191815829546c49d5390aff9b398722e93", "parents": ["7197e078fc2298dad889ed9d2923622d0a666dda"], "tags": []}], "date": 1773484475, "git_changesets": ["59799b7b228bcefd39a3a05f951150d3bbe8aa75"], "user": "pchevrel@mozilla.com"}, "25072": {"changesets": [{"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 2023039 - [devtools] Restore updated devtools-devices.json and fix browser_device_state_restore.js failures. r=jdescottes,devtools-reviewers a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D287621\n", "files": ["devtools/client/responsive/test/browser/browser_device_state_restore.js", "services/s