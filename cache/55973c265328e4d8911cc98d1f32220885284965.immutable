ug 2022281 - Reject openPopup() when other panels are open (149 port)  a=pascalc DONTBUILD\n\nOn top of the original revision, this also includes a hidden pref\n(`extensions.openPopup.undoBug2022281`) to allow users to undo the\nchange if they encounter an issue for any reason.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D286943\n\nDifferential Revision: https://phabricator.services.mozilla.com/D287172\n", "files": ["browser/components/extensions/ExtensionPopups.sys.mjs", "browser/components/extensions/parent/ext-browserAction.js", "browser/components/extensions/parent/ext-pageAction.js", "browser/components/extensions/test/browser/browser.toml", "browser/components/extensions/test/browser/browser_ext_action_openPopup.js"], "git_node": "86b56c25b333a4683f44f44f870d77dcc8f4537c", "git_parents": ["ba923dda4e4ad0ef2a14501942f4d9c66875a864"], "node": "2e395ebf0c6cf6088e7c34121cb76e75e92fd9f7", "parents": ["6e828446915154b4c10630d988439d2dbdebeead"], "tags": []}], "date": 1773249384, "git_changesets": ["86b56c25b333a4683f44f44f870d77dcc8f4537c"], "user": "pchevrel@mozilla.com"}, "25021": {"changesets": [{"author": "Sarah Clements \u003csclements@mozilla.com\u003e", "branch": "default", "desc": "Bug 2007802 - Preserve splitview behavior in All Tabs list  a=pascalc DONTBUILD\n\n* Add support in the TabsList panel but omit styling changes for now; ensures a tab can't be dropped between a splitview, and ensures the splitview state is updated when splitviews move within the tabstrip.\n* Add test cases\n\nOriginal Revision: https://phabricator.services.mozilla.com/D285810\n\nDifferential Revision: https://phabricator.services.mozilla.com/D287139\n", "files": ["browser/components/tabbrowser/TabsList.sys.mjs", "browser/components/tabbrowser/test/browser/tabs/browser_tab_manager_drag.js"], "git_node": "3072ce60dcda0d8b03661baf33f7701fc88b9fbb", "git_parents": ["86b56c25b333a4683f44f44f870d77dcc8f4537c"], "node": "80fb6bc07050f010078bd7cdc329d6dd33431427", "parents": ["2e395ebf0c6cf6088e7c34121cb76e75e92fd9f7"], "tags": []}], "date": 1773249883, "git_changesets": ["3072ce60dcda0d8b03661baf33f7701fc88b9fbb"], "user": "pchevrel@mozilla.com"}, "25022": {"changesets": [{"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 2019309 - Use ContiguousEnumSerializer for necko ipdl params  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D285413\n\nDifferential Revision: https://phabricator.services.mozilla.com/D287075\n", "files": ["netwerk/protocol/http/PHttpChannelParams.h"], "git_node": "d3c9511ace3fda99a8362dd247fa46d807a088cb", "git_parents": ["3072ce60dcda0d8b03661baf33f7701fc88b9fbb"], "node": "d3d9d4925f8c0444b75ec49b0eeb106b6411f008", "parents": ["80fb6bc07050f010078bd7cdc329d6dd33431427"], "tags": []}], "date": 1773249935, "git_changesets": ["d3c9511ace3fda99a8362dd247fa46d807a088cb"], "user": "pchevrel@mozilla.com"}, "25023": {"changesets": [{"author": "mimi \u003cnsauermann@mozilla.com\u003e", "branch": "default", "desc": "Bug 2014417 - Prevent ESC when focus is on frame dismissing Spotlights when 'disableEscClose' is true  a=pascalc DONTBUILD\n\n[try run](https://treeherder.mozilla.org/jobs?repo=try&landoCommitID=184235)\n\nOriginal Revision: https://phabricator.services.mozilla.com/D286696\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286953\n", "files": ["browser/base/content/spotlight.js", "browser/components/asrouter/tests/browser/browser_multistage_spotlight.js"], "git_node": "a546ea25edf1950db58ebc9a7cc21ed576d90f10", "git_parents": ["d3c9511ace3fda99a8362dd247fa46d807a088cb"], "node": "8b7b6b536b1bd863242a0519fd753f0b7addf0e9", "parents": ["d3d9d4925f8c0444b75ec49b0eeb106b6411f008"], "tags": []}], "date": 1773249982, "git_changesets": ["a546ea25edf1950db58ebc9a7cc21ed576d90f10"], "user": "pchevrel@mozilla.com"}, "25024": {"changesets": [{"author": "Yury Delendik \u003cydelendik@mozilla.com\u003e", "branch": "defaul