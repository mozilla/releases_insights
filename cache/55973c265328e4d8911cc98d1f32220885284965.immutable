iveMenuSupport.cpp", "widget/gtk/TaskbarProgress.cpp", "widget/gtk/nsDragService.cpp", "widget/gtk/nsFilePicker.cpp"], "git_node": "540c10c8c805e052d1c90928d4ae7145fa9543b9", "git_parents": ["503da499a75bfd78c0fb853f8ad2199f9c708820"], "node": "803ec9acddbc008d77672cedccdcb01204f1a07d", "parents": ["41d6f23aceac0a10e42fa91c4df684f4f3c9559d"], "tags": []}], "date": 1773088212, "git_changesets": ["fe7f8a23d0ec46f70d4c1e649bd670729d7041b4", "cce9e9705246472c76abba901a338cc1e8528456", "503da499a75bfd78c0fb853f8ad2199f9c708820", "540c10c8c805e052d1c90928d4ae7145fa9543b9"], "user": "pchevrel@mozilla.com"}, "24975": {"changesets": [{"author": "Alexandra Borovova \u003caborovova@mozilla.com\u003e", "branch": "default", "desc": "Bug 2019661 - Initialize \"UserPromptHandlerManager\" only when \"bidi\" flag is set on the session.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D285075\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286618\n", "files": ["remote/webdriver-bidi/WebDriverBiDi.sys.mjs", "testing/web-platform/mozilla/tests/webdriver/interop/user_prompts.py"], "git_node": "8f9e2dd7d58878b06c5013306ed99d22a14a76c0", "git_parents": ["540c10c8c805e052d1c90928d4ae7145fa9543b9"], "node": "e2032bc2d741c01a522ea41738b57b0f661af8f7", "parents": ["803ec9acddbc008d77672cedccdcb01204f1a07d"], "tags": []}], "date": 1773088259, "git_changesets": ["8f9e2dd7d58878b06c5013306ed99d22a14a76c0"], "user": "pchevrel@mozilla.com"}, "24976": {"changesets": [{"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 2017506 - Fix memory reporting to discriminate between malloc memory and GC buffer allocator memory r!#spidermonkey-reviewers  a=pascalc\n\nThis patch aims to bring memory reporting back into line after the JS engine\nwas updated to use the buffer allocator rather than malloc in a bunch of\nplaces.\n\n - JSObject slots and elements were mostly correctly dealt with although they\n   were still misnamed as malloc heap measurements and had the wrong heap type\n   in MemoryMetrics\n\n - objectsMallocHeapElementsArrayBuffer was added to cover array buffers with\n   malloc data\n\n - Reporting for BigInts and Scopes was updated now they use the buffer\n   allocator\n\n - Reporting for JSScripts was updated now they use the buffer allocator for\n   script private data\n\n - The data structures behind nurseryMallocedBlockCache and\n   nurseryTrailerBlockSets have been removed so these measurements were removed\n\n - Small buffer GC things have been removed also\n\nThe patch removes the mozilla::MallocSizeOf argument from reporting methods\nwhere it is not used. This also hints that the method does not report on malloc\nallocated data.\n\nFor Map and Set objects there are now separate methods to report on malloc and\nbuffer allocated data.\n\nThis fixes the negative heap-unclassified reports when running the test case in\nthe bug.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284079\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286619\n", "files": ["js/public/MemoryMetrics.h", "js/src/builtin/MapObject.cpp", "js/src/builtin/MapObject.h", "js/src/builtin/OrderedHashTableObject.h", "js/src/vm/ArgumentsObject.cpp", "js/src/vm/ArgumentsObject.h", "js/src/vm/ArrayBufferObject.cpp", "js/src/vm/BigIntType.cpp", "js/src/vm/BigIntType.h", "js/src/vm/JSObject.cpp", "js/src/vm/JSScript.cpp", "js/src/vm/JSScript.h", "js/src/vm/MemoryMetrics.cpp", "js/xpconnect/src/XPCJSRuntime.cpp"], "git_node": "8970a78cea88f372ccd9f0e5127024e32990fa56", "git_parents": ["8f9e2dd7d58878b06c5013306ed99d22a14a76c0"], "node": "eed2b76e294e6878e9b00d3542093e54c266c15c", "parents": ["e2032bc2d741c01a522ea41738b57b0f661af8f7"], "tags": []}], "date": 1773088303, "git_changesets": ["8970a78cea88f372ccd9f0e5127024e32990fa56"], "user": "pchevrel@mozilla.com"}, "24977": {"changesets": [{"author": "Henri Sivonen \u003chsivonen@hsivonen.fi\u003e", "branch": "default", "desc": "Bug 2020953 - Tolerate %VERSION% as a CKEditor 4 version number in the compatibility hack.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D285982\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286627\n", "files": ["dom/base/nsGlobalWindowInner.cpp", "dom/base/test/test_ckeditor4_compat_hack.html"], "git_node": "7d7ce17707df13585b127fedd5b13339e87e190e", "git_parents": ["8970a78cea88f372ccd9f0e5127024e32990fa56"], "node": "ef3db2ff55e02a79653628064a2020571b746978", "parents": ["eed2b76e294e6878e9b00d3542093e54c266c15c"], "tags": []}, {"author": "Henri Sivonen \u003chsivonen@hsivonen.fi\u003e", "branch": "default", "desc": "Bug 2020927 - Extend the CKEditor 4 compat hack to GWT RichTextArea.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D286099\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286628\n", "files": ["dom/base/nsDeprecatedOperationList.inc", "dom/base/nsGlobalWindowInner.cpp", "dom/base/test/test_ckeditor4_compat_hack.html", "dom/base/use_counter_metrics.yaml", "dom/chrome-webidl/WebCompat.webidl", "dom/locales/en-US/chrome/dom/dom.properties", "modules/libpref/init/StaticPrefList.yaml", "xpcom/ds/StaticAtoms.py"], "git_node": "7ecb95ba4d14897a759bff11e76d6f5d93b900e3", "git_parents": ["7d7ce17707df13585b127fedd5b13339e87e190e"], "node": "6ad658e8f97d45ab9b921c537724917b5ae6adf3", "parents": ["ef3db2ff55e02a79653628064a2020571b746978"], "tags": []}], "date": 1773088380, "git_changesets": ["7d7ce17707df13585b127fedd5b13339e87e190e", "7ecb95ba4d14897a759bff11e76d6f5d93b900e3"], "user": "pchevrel@mozilla.com"}, "24978": {"changesets": [{"author": "Alex Franchuk \u003cafranchuk@mozilla.com\u003e", "branch": "default", "desc": "Bug 2021130 - Do not submit ProcessType for main process crash report submissions  a=pascalc\n\nThere is likely a more elegant solution where we change the crashping\ncrate to interpret a missing ProcessType as the main process (a\ndifferent solution to bug 2014195), however this solution is lower risk\nas it's a more localized change.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D286193\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286679\n", "files": ["toolkit/crashreporter/client/app/src/net/report.rs", "toolkit/crashreporter/client/app/src/test.rs"], "git_node": "645f85eeff4566dc01b76019561c8c757d6a65ac", "git_parents": ["7ecb95ba4d14897a759bff11e76d6f5d93b900e3"], "node": "65b63e1d55fe9459b83b9c5bc24895c363a23819", "parents": ["6ad658e8f97d45ab9b921c537724917b5ae6adf3"], "tags": []}], "date": 1773088426, "git_changesets": ["645f85eeff4566dc01b76019561c8c757d6a65ac"], "user": "pchevrel@mozilla.com"}, "24979": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Import translations from main\n", "files": ["mobile/android/android-components/components/browser/errorpages/src/main/res/values-kmr/strings.xml", "mobile/android/android-components/components/compose/awesomebar/src/main/res/values-es-rES/strings.xml", "mobile/android/android-components/components/compose/awesomebar/src/main/res/values-in/strings.xml", "mobile/android/android-components/components/compose/awesomebar/src/main/res/values-nb-rNO/strings.xml", "mobile/android/android-components/components/compose/awesomebar/src/main/res/values-tr/strings.xml", "mobile/android/android-components/components/compose/browser-toolbar/src/main/res/values-brh/strings.xml", "mobile/android/android-components/components/feature/addons/src/main/res/values-kmr/strings.xml", "mobile/android/android-components/components/feature/app-links/src/main/res/values-brh/strings.xml", "mobile/android/android-components/components/feature/contextmenu/src/main/res/values-brh/strings.xml", "mobile/android/android-components/components/feature/customtabs/src/main/res/values-brh/strings.xml", "mobile/android/android-components/component