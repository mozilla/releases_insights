/org/mozilla/fenix/onboarding/redesign/view/OnboardingScreenRedesign.kt"], "git_node": "d37c15cca7df42d66f5bf6749a28df981b59caec", "git_parents": ["2a7ca480a456b980decfefc15987336476ceebcf"], "node": "8544dcdf74ddd89ad80102273d481f6fc336d48e", "parents": ["1f629a07f994a0e1dd0ce577abe88347f1be657e"], "tags": []}], "date": 1773250352, "git_changesets": ["d37c15cca7df42d66f5bf6749a28df981b59caec"], "user": "pchevrel@mozilla.com"}, "25027": {"changesets": [{"author": "Mugurell \u003cMugurell@users.noreply.github.com\u003e", "branch": "default", "desc": "Bug 2018915 - Record that widget is installed also when it is updated  a=pascalc DONTBUILD\n\nThis ensures that if the search widget was previously added to the homescreen\nand then the application had its data cleared upon the application being\nreopened we'll record again internally that the widget is installed.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D285083\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285935\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/utils/Settings.kt", "mobile/android/fenix/app/src/main/java/org/mozilla/gecko/search/SearchWidgetProvider.kt", "mobile/android/fenix/app/src/test/java/org/mozilla/fenix/widget/SearchWidgetProviderTest.kt"], "git_node": "852bdbc41283e8da874bce7657f52b3164d5e6df", "git_parents": ["d37c15cca7df42d66f5bf6749a28df981b59caec"], "node": "0ad21e0d2aa5ce0d3c5831c3cf3a1924851d5ffc", "parents": ["8544dcdf74ddd89ad80102273d481f6fc336d48e"], "tags": []}], "date": 1773251658, "git_changesets": ["852bdbc41283e8da874bce7657f52b3164d5e6df"], "user": "pchevrel@mozilla.com"}, "25028": {"changesets": [{"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 2019364: Collect WebGL context attributes (antialias, alpha)  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284920\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286253\n", "files": ["toolkit/components/resistfingerprinting/UserCharacteristicsPageService.sys.mjs", "toolkit/components/resistfingerprinting/metrics.yaml", "toolkit/components/resistfingerprinting/nsUserCharacteristics.cpp"], "git_node": "14f9960b19256ff8f156d756533fa6c1a14852e3", "git_parents": ["852bdbc41283e8da874bce7657f52b3164d5e6df"], "node": "8b6657e48e187c744c6828f3ca06fcd69387c7ea", "parents": ["0ad21e0d2aa5ce0d3c5831c3cf3a1924851d5ffc"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 2019364: Collect IMPLEMENTATION_COLOR_READ_FORMAT/TYPE WebGL params  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284921\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286254\n", "files": ["toolkit/components/resistfingerprinting/UserCharacteristicsPageService.sys.mjs", "toolkit/components/resistfingerprinting/metrics.yaml", "toolkit/components/resistfingerprinting/nsUserCharacteristics.cpp"], "git_node": "14f164c57f320e017d583da879025d661ed9d64a", "git_parents": ["14f9960b19256ff8f156d756533fa6c1a14852e3"], "node": "a362ddc7b8388c6c1b8650663cfda425b87952dd", "parents": ["8b6657e48e187c744c6828f3ca06fcd69387c7ea"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 2019364: Collect QUERY_COUNTER_BITS_EXT from EXT_disjoint_timer_query  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284922\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286255\n", "files": ["toolkit/components/resistfingerprinting/UserCharacteristicsPageService.sys.mjs", "toolkit/components/resistfingerprinting/nsUserCharacteristics.cpp"], "git_node": "1d56d021a7dce8cb6da170dc5a32c508626ec3ea", "git_parents": ["14f164c57f320e017d583da879025d661ed9d64a"], "node": "923dce615d6e11fc183bf482cd430c594dbf13d3", "parents": ["a362ddc7b8388c6c1b8650663cfda425b87952dd"], "tags": []}], "date": 1773251715, "git_changesets": ["14f9960b19256ff8f156d756533fa6c1a14852e3", "14f164c57f320e017d583da879025d661ed9d64a", "1d56d021a7dce8cb6da170dc5a32c508626ec3ea"], "user": "pchevrel@mozilla.com"}, "25029": {"changesets": [{"author": "Stephen Thompson \u003csthompson@mozilla.com\u003e", "branch": "default", "desc": "Bug 2020369 - restore `.badge-new` to tab context menu items  a=pascalc DONTBUILD\n\nFixes regression from bug 2000075 that turned tab context menu \"new\" badges gray on Linux and Windows. This patch restores them to green.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D286784\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286791\n", "files": ["browser/components/tabbrowser/content/tabbrowser.js"], "git_node": "06eabcba83a8db41c1be9493d3de52e0d1851cf7", "git_parents": ["1d56d021a7dce8cb6da170dc5a32c508626ec3ea"], "node": "b23f3ef9a38f134490c1c11eb4b20e5ee09661e4", "parents": ["923dce615d6e11fc183bf482cd430c594dbf13d3"], "tags": []}], "date": 1773251762, "git_changesets": ["06eabcba83a8db41c1be9493d3de52e0d1851cf7"], "user": "pchevrel@mozilla.com"}, "25030": {"changesets": [{"author": "Jeremy Swinarton \u003cjswinarton@mozilla.com\u003e", "branch": "default", "desc": "Bug 2014459: Add 'new' badge to tab note in tab hover preview panel  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284848\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286930\n", "files": ["browser/base/content/main-popupset.inc.xhtml", "browser/components/tabbrowser/content/tab-hover-preview.mjs", "browser/components/tabbrowser/test/browser/tabs/browser_tab_preview.js", "browser/locales/en-US/browser/tabbrowser.ftl", "browser/themes/shared/customizableui/panelUI-shared.css", "browser/themes/shared/tabbrowser/tab-hover-preview.css"], "git_node": "56e735f9ca1f5e94043a8128621ec3ddb98dea62", "git_parents": ["06eabcba83a8db41c1be9493d3de52e0d1851cf7"], "node": "3ae62e446c901a8e4bfc5a8d4e7dbd05959f59c0", "parents": ["b23f3ef9a38f134490c1c11eb4b20e5ee09661e4"], "tags": []}], "date": 1773254807, "git_changesets": ["56e735f9ca1f5e94043a8128621ec3ddb98dea62"], "user": "pchevrel@mozilla.com"}, "25031": {"changesets": [{"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 2017243: Only check PDF.js exemption for document/subdocument loads  a=pascalc DONTBUILD\n\nThe original PDF.js RFP exemption patch called GetChannelResultPrincipal()\non all channel types, including internal channels like TRR (DNS over HTTPS).\nThese internal channels use TYPE_OTHER and don't have a fully initialized\nLoadInfo, causing an assertion failure in GetForceInheritPrincipalOverruleOwner().\n\nThis patch restricts the PDF.js check to only TYPE_DOCUMENT and TYPE_SUBDOCUMENT\nchannels, since those are the only contexts where PDF.js can actually be loaded.\nThis prevents the assertion failure while maintaining the correct PDF.js RFP\nexemption behavior.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D283718\n\nDifferential Revision: https://phabricator.services.mozilla.com/D287208\n", "files": ["dom/base/nsContentUtils.cpp"], "git_node": "a05dd296654c15d2a85d3721bb1d548575b7327c", "git_parents": ["56e735f9ca1f5e94043a8128621ec3ddb98dea62"], "node": "16629828d1964c5c0ee94250e58302ba016b6685", "parents": ["3ae62e446c901a8e4bfc5a8d4e7dbd05959f59c0"], "tags": []}], "date": 1773259929, "git_changesets": ["a05dd296654c15d2a85d3721bb1d548575b7327c"], "user": "pchevrel@mozilla.com"}, "25032": {"changesets": [{"author": "Release Engineering Landoscript \u003crelease+landoscript@mozilla.com\u003e", "branch": "default", "desc": "No Bug - Import translations from main\n", "files": ["mobile/android/android-components/components/compose/awesomebar/src/main/res/values-fr/strings.xml", "mobile/android/fenix/app/src/main/res/values-be/strings.xml", "mobile/android/fenix/app/src/main/res/values-brh/strings.xml", "mobile/android/fenix/app/src/main/res/values-cs/strings.xml", "mobile/android/fenix/app/src/main/res/va