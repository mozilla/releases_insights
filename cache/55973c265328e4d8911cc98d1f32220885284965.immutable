tools"}, "24982": {"changesets": [{"author": "Fred Chasen \u003cfchasen@mozilla.com\u003e", "branch": "default", "desc": "Bug 2015553 - Update the IPPProxyManager paused state and usage refresh.  a=pascalc DONTBUILD\n\n- Adds a `pause()` method that clears the pass, stops rotation, and sets the PAUSED state.\n- Proxy remains in the PAUSED state when `stop()` is called while paused if there is no remain bandwidth.\n- Proxy can not be started in the `PAUSE` state.\n- Updates `updateState()` so it can be used instead most direct state transitions.\n- Panel paused state is set from the proxy PAUSED state, showing the paused view when there is no remaining bandwidth.\n- Triggers a usage refresh when the panel is opened by an authenticated user.\n- Remove `no-cache` for `fetchProxyUsage` so it will cache the more frequent checks from panel opens.\n- Adds a stub for `fetchProxyUsage` that can be set by passing `usageInfo` to the test service setup.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D285190\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286747\n", "files": ["browser/components/ipprotection/GuardianClient.sys.mjs", "browser/components/ipprotection/IPPProxyManager.sys.mjs", "browser/components/ipprotection/IPProtectionPanel.sys.mjs", "browser/components/ipprotection/tests/browser/browser_IPPProxyManager.js", "browser/components/ipprotection/tests/browser/browser_ipprotection_bandwidth_precision.js", "browser/components/ipprotection/tests/browser/browser_ipprotection_message_bar.js", "browser/components/ipprotection/tests/browser/browser_ipprotection_status_card.js", "browser/components/ipprotection/tests/browser/head.js", "browser/components/ipprotection/tests/xpcshell/test_IPProxyManager.js"], "git_node": "1795b5c55d13915da49c755c553c7ccf4c320c92", "git_parents": ["1dc0438d8314931918b105fe9e09685198a65215"], "node": "a435d0c4042d6e5e0d7c4581d4efc7a001a10b41", "parents": ["a0832e8f398b74cd0da5e67c09ad77b7eafc3524"], "tags": []}, {"author": "Fred Chasen \u003cfchasen@mozilla.com\u003e", "branch": "default", "desc": "Bug 2021236 - Ensure IPPProxyManager updateState checks connection is not active before moving to READY.  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D286292\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286748\n", "files": ["browser/components/ipprotection/IPPProxyManager.sys.mjs", "browser/components/ipprotection/tests/browser/browser_IPPProxyManager.js", "browser/components/ipprotection/tests/browser/head.js", "browser/components/ipprotection/tests/xpcshell/test_IPProxyManager.js"], "git_node": "1e5f92e993e392dd1b8b7b7fb606b85f91257b35", "git_parents": ["1795b5c55d13915da49c755c553c7ccf4c320c92"], "node": "2ec41dd5d6279e0e5135eb596b65aca9241c5677", "parents": ["a435d0c4042d6e5e0d7c4581d4efc7a001a10b41"], "tags": []}], "date": 1773135845, "git_changesets": ["1795b5c55d13915da49c755c553c7ccf4c320c92", "1e5f92e993e392dd1b8b7b7fb606b85f91257b35"], "user": "pchevrel@mozilla.com"}, "24983": {"changesets": [{"author": "Byron Campen \u003cdocfaraday@gmail.com\u003e", "branch": "default", "desc": "Bug 2020617: Use actual types to serialize/deserialize these.  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D286362\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286753\n", "files": ["dom/media/webrtc/transport/mediapacket.cpp"], "git_node": "752822138dff838fff4c42a8879d075f1a9cfcb6", "git_parents": ["1e5f92e993e392dd1b8b7b7fb606b85f91257b35"], "node": "e08e4c3c28b70c01301ee4cc7d14a7afe4f441b9", "parents": ["2ec41dd5d6279e0e5135eb596b65aca9241c5677"], "tags": []}], "date": 1773136007, "git_changesets": ["752822138dff838fff4c42a8879d075f1a9cfcb6"], "user": "pchevrel@mozilla.com"}, "24984": {"changesets": [{"author": "kpatenio \u003ckpatenio@mozilla.com\u003e", "branch": "default", "desc": "Bug 2020503 \u2014 add metric for button clicked in IPProtectionAlertManager.  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D285872\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286760\n", "files": ["browser/components/ipprotection/IPProtectionAlertManager.sys.mjs", "browser/components/ipprotection/metrics.yaml", "browser/components/ipprotection/tests/browser/browser_ipprotection_alert_manager.js"], "git_node": "54ee84b085a1e3664f31dbea1ec45ace5ca182f6", "git_parents": ["752822138dff838fff4c42a8879d075f1a9cfcb6"], "node": "30c8512d63bd446724753fe2dd83891806176303", "parents": ["e08e4c3c28b70c01301ee4cc7d14a7afe4f441b9"], "tags": []}], "date": 1773136104, "git_changesets": ["54ee84b085a1e3664f31dbea1ec45ace5ca182f6"], "user": "pchevrel@mozilla.com"}, "24985": {"changesets": [{"author": "Rebecca King \u003crking@mozilla.com\u003e", "branch": "default", "desc": "Bug 2020957 - Fix learn more links from about:preferences -  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D286359\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286785\n", "files": ["browser/components/ipprotection/IPProtectionPanel.sys.mjs", "browser/components/ipprotection/content/bandwidth-usage.mjs", "browser/components/ipprotection/content/ipprotection-constants.mjs", "browser/components/preferences/main.js"], "git_node": "30e8796b77c0ac5de60f0514bbcddc1dce69733a", "git_parents": ["54ee84b085a1e3664f31dbea1ec45ace5ca182f6"], "node": "4fe912ecaaf4a7ab210bdbe918314e6b8172cac9", "parents": ["30c8512d63bd446724753fe2dd83891806176303"], "tags": []}], "date": 1773136249, "git_changesets": ["30e8796b77c0ac5de60f0514bbcddc1dce69733a"], "user": "pchevrel@mozilla.com"}, "24986": {"changesets": [{"author": "Fred Chasen \u003cfchasen@mozilla.com\u003e", "branch": "default", "desc": "Bug 2017484 - Add telemetry events for VPN enrollment.  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D285634\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286796\n", "files": ["browser/components/ipprotection/IPProtectionPanel.sys.mjs", "browser/components/ipprotection/metrics.yaml", "browser/components/ipprotection/tests/browser/browser_ipprotection_telemetry.js"], "git_node": "8f61d52eb5cdd5481da467975612bd916b46e67e", "git_parents": ["30e8796b77c0ac5de60f0514bbcddc1dce69733a"], "node": "d2eb97f6068cc72b9d70f2b70c40c78cdf649d1b", "parents": ["4fe912ecaaf4a7ab210bdbe918314e6b8172cac9"], "tags": []}], "date": 1773136920, "git_changesets": ["8f61d52eb5cdd5481da467975612bd916b46e67e"], "user": "pchevrel@mozilla.com"}, "24987": {"changesets": [{"author": "Sebastian Streich \u003csstreich@mozilla.com\u003e", "branch": "default", "desc": "Bug 2014732 - Add an Inclusions-Only mode  a=pascalc\n\nRN we have modes for\n-\u003e ALL\n-\u003e Blockers\n-\u003e PB Mode\n\nThis patch adds a new mode for opt-in. So in this mode no traffic is using the proxy unless it specifically is inside\na matchset. As a rule engine we do use the \"MatchSet\" used in extensions and other places.\n\nThis should make it easy for enterprise customers to tailor this module to their usage patterns.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284649\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286803\n", "files": ["browser/components/ipprotection/IPPChannelFilter.sys.mjs", "browser/components/ipprotection/tests/xpcshell/test_IPPChannelFilter.js"], "git_node": "922a04725defe72ebb7207cade725e559be9626d", "git_parents": ["8f61d52eb5cdd5481da467975612bd916b46e67e"], "node": "8426103583c90d8a8a1608b02eec80cf336b0a89", "parents": ["d2eb97f6068cc72b9d70f2b70c40c78cdf649d1b"], "tags": []}, {"author": "Sebastian Streich \u003csstreich@mozilla.com\u003e", "branch": "default", "desc": "Bug 2016344 - Preamble, use dispose-symbols for browser/head.js:withProxyServer()  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284516\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286804\n", "files": ["browser/components/ipprotection/tests/browser/browser_IPPChannelFilter.js", "browser/components/ipprotection/tests/browser/browser_ipprotection_proxy_errors.js", "browser/components/ipprotection/tests/browser/browser_ipprotection_usage.js", "browser/components/ipprotection/tests/browser/head.js"], "git_node": "8710a54c2b38de2fc8bdac289e6d55af42130d4b", "git_parents": ["922a04725defe72ebb7207cade725e559be9626d"], "node": "d04d1dc336160289f488384bf1703103fc077e76", "parents": ["8426103583c90d8a8a1608b02eec80cf336b0a89"], "tags": []}, {"author": "Sebastian Streich \u003csstreich@mozilla.com\u003e", "branch": "default", "desc": "Bug 2016344 - Pass default proxy info when excluding the proxy  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284517\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286805\n", "files": ["browser/components/ipprotection/IPPChannelFilter.sys.mjs", "browser/components/ipprotection/tests/browser/browser_IPPChannelFilter.js"], "git_node": "223bc21831dc667084c0b60a38829d521fbafbeb", "git_parents": ["8710a54c2b38de2fc8bdac289e6d55af42130d4b"], "node": "592ff98b65e856a7594bc7bab9c446e2d3268254", "parents": ["d04d1dc336160289f488384bf1703103fc077e76"], "tags": []}], "date": 1773137069, "git_changesets": ["922a04725defe72ebb7207cade725e559be9626d", "8710a54c2b38de2fc8bdac289e6d55af42130d4b", "223bc21831dc667084c0b60a38829d521fbafbeb"], "user": "pchevrel@mozilla.com"}, "24988": {"changesets": [{"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 2018848 - Only filter out .hg*/.git*/.mozconfig* files from the top-level directory.  a=pascalc DONTBUILD\n\nAny such file that is not at the top level but still in the repo is\nintended to be there.\n\n(Ideally, we'd use .gitignore, but that's a more involved change)\n\nOriginal Revision: https://phabricator.services.mozilla.com/D285179\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286821\n", "files": ["toolkit/mozapps/installer/upload-files.mk"], "git_node": "3343da238201f0ac4b607074f75c9edc5e4900eb", "git_parents": ["223bc21831dc667084c0b60a38829d521fbafbeb"], "node": "48067f68a85a93bcfe76d5b1c5311d3ff5013c7d", "parents": ["592ff98b65e856a7594bc7bab9c446e2d3268254"], "tags": []}], "date": 1773137319, "git_changesets": ["3343da238201f0ac4b607074f75c9edc5e4900eb"], "user": "pchevrel@mozilla.com"}, "24989": {"changesets": [{"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 2016367. r=aosmond a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286343\n", "files": ["gfx/2d/ScaledFontMac.cpp"], "git_node": "7ad9f316ae2f9966bfb107685b2532966d876226", "git_parents": ["3343da238201f0ac4b607074f75c9edc5e4900eb"], "node": "fd600b8330f261ad6eb3454b78559a504069873d", "parents": ["48067f68a85a93bcfe76d5b1c5311d3ff5013c7d"], "tags": []}], "date": 1773140890, "git_changesets": ["7ad9f316ae2f9966bfb107685b2532966d876226"], "user": "pchevrel@mozilla.com"}, "24990": {"changesets": [{"author": "Simon Farre \u003csimon.farre.cx@gmail.com\u003e", "branch": "default", "desc": "Bug 2016380 - Fix edge case CSP Violation report sending  a=pascalc DONTBUILD\n\nAn edge case amount of CSP reports, are triggered not with the global\npresent, in the parent process.\n\nIn those scenarios it uses listeners and fires events by\ndispatching IPC, FetchChild::RecvOnCSPViolationEvent and\nWindowGlobalChild::RecvDispatchSecurityPolicyViolation to fire an actual\n\"securitypolicyviolation\" event that the webcontent can see.\n\nThis is the same time we should be\nreporting the event to a potential ReportingObserver and also queuing\nthe report to be sent.\n\nThese two methods therefore get a \"violated policy index\" by which it\ncan use to look up the name for the group it should report to.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D283683\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286860\n", "files": ["dom/fetch/FetchChild.cpp", "dom/fetch/FetchChild.h", "dom/fetch/FetchParent.cpp", "dom/fetch/FetchParent.h", "dom/fetch/PFetch.ipdl", "dom/interfaces/security/nsIContentSecurityPolicy.idl", "dom/ipc/PWindowGlobal.ipdl", "dom/ipc/WindowGlobalChild.cpp", "dom/ipc/WindowGlobalChild.h", "dom/reporting/ReportingHeader.cpp", "dom/reporting/ReportingUtils.cpp", "dom/reporting/ReportingUtils.h", "dom/security/nsCSPContext.cpp", "dom/security/nsCSPContext.h", "dom/workers/WorkerCSPEventListener.cpp", "dom/workers/remoteworkers/RemoteWorkerChild.cpp", "dom/workers/remoteworkers/RemoteWorkerChild.h", "testing/web-platform/meta/content-security-policy/reporting-api/dedicated-worker-correct-url-in-report.html.ini", "testing/web-platform/meta/content-security-policy/reporting-api/reporting-api-works-on-frame-src.https.sub.html.ini"], "git_node": "2f074bbed8613e4a939e30885b493dda90e8d284", "git_parents": ["7ad9f316ae2f9966bfb107685b2532966d876226"], "node": "0d7190a212d6807ee4b9b8d6334b7277dcb00352", "parents": ["fd600b8330f261ad6eb3454b78559a504069873d"], "tags": []}], "date": 1773142338, "git_changesets": ["2f074bbed8613e4a939e30885b493dda90e8d284"], "user": "pchevrel@mozilla.com"}, "24991": {"changesets": [{"author": "Pascal Chevrel \u003cpascal@mozilla.com\u003e", "branch": "default", "desc": "Revert \"Bug 2015252 - Use existing 'Reverse Tabs' string for new tab context menu option a=pascalc\" new release target for this bug is 150 a=backout\n\nThis reverts commit 80ac2792aa0ad3b6f65cd229680e9dcd68cd5b6b.\n", "files": ["browser/base/content/main-popupset.inc.xhtml"], "git_node": "64aad8e562840f07969a119733ffd5cc377be78b", "git_parents": ["2f074bbed8613e4a939e30885b493dda90e8d284"], "node": "aca20b0dfc053b207c6dc5243d971fdb30d88f46", "parents": ["0d7190a212d6807ee4b9b8d6334b7277dcb00352"], "tags": []}, {"author": "Pascal Chevrel \u003cpascal@mozilla.com\u003e", "branch": "default", "desc": "Revert \"Bug 2015252 - Add 'Reverse Tabs' option to the tab context menu for split view tabs a=pascalc\" new release target for this bug is 150 a=backout\n\nThis reverts commit 1f917839dba532d490f0e1792524e95a5efe4e76.\n", "files": ["browser/base/content/main-popupset.inc.xhtml", "browser/base/content/main-popupset.js", "browser/components/tabbrowser/content/tabbrowser.js", "browser/components/tabbrowser/test/browser/tabs/browser_tab_splitview_contextmenu.js", "browser/locales/en-US/browser/tabbrowser.ftl"], "git_node": "35178287721c4233fb8e19d407d2ae2429dfeade", "git_parents": ["64aad8e562840f07969a119733ffd5cc377be78b"], "node": "c3124e9df614fd7d6cbf1693f339b18a34f6f98c", "parents": ["aca20b0dfc053b207c6dc5243d971fdb30d88f46"], "tags": []}], "date": 1773153324, "git_changesets": ["64aad8e562840f07969a119733ffd5cc377be78b", "35178287721c4233fb8e19d407d2ae2429dfeade"], "user": "pchevrel@mozilla.com"}, "24992": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging 15542f265e9eb232f80e52c0966300225d0b1cb7 with FIREFOX_148_0_2_RELEASE a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "093c7b60eb54146bf57fc702bf5067865daa7b40", "git_parents": ["bfce575be0efd11a078d48b67fafdbbb6802f220"], "node": "59b097c2ce3900888a4abbae184f139a383869e0", "parents": ["50593c472b7e83d78b043c17675d6bb05c16e914"], "tags": []}], "date": 1773155226, "git_changesets": ["093c7b60eb54146bf57fc702bf5067865daa7b40"], "user": "ffxbld@lando.moz.tools"}, "24993": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging 15542f265e9eb232f80e52c0966300225d0b1cb7 with FIREFOX-ANDROID_148_0_2_RELEASE a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "c68e195cfa19a1cac72084dd4060472cbeb4a113", "git_parents": ["093c7b60eb54146bf57fc702bf5067865daa7b40"], "node": "9e2d3a50cbce08380976df263f3b79f2b7aa2f20", "parents": ["59b097c2ce3900888a4abbae184f139a383869e0"], "tags": []}], "date