97809b8f02d8"], "user": "pchevrel@mozilla.com"}, "24908": {"changesets": [{"author": "Andrew McCreight \u003ccontinuation@gmail.com\u003e", "branch": "default", "desc": "Bug 2019112 - Fold the prompt message into ContentPermissionRequest construction.  a=pascalc\n\nInstead of sending a separate message, immediately do the initialization after the\nactor is created and registered, via a new override of RecvPContentPermissionRequestConstructor.\nI didn't move the initialization inside AllocPContentPermissionRequestParent because\nthe Init() method runs JS so it seems like a bad idea to do when the actor isn't fully set up.\n\naRequests is now set inside the Init() method instead of the constructor, which allows us\nto avoid a copy of this array at the low cost of making the diff gross.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284774\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286016\n", "files": ["dom/base/nsContentPermissionHelper.cpp", "dom/base/nsContentPermissionHelper.h", "dom/ipc/ContentParent.cpp", "dom/ipc/ContentParent.h", "dom/ipc/PContentPermissionRequest.ipdl"], "git_node": "dd03f7d7a35c88ac8d299f64232aa3d324d0fe80", "git_parents": ["6224250b036b1615d71605ae6c2097809b8f02d8"], "node": "7fb61138232ac2cd251b8686561e2ad08ff906d9", "parents": ["bc4c1682bae48d7e0f2e3a0b3c2bdd1dd40ab8f0"], "tags": []}], "date": 1772717955, "git_changesets": ["dd03f7d7a35c88ac8d299f64232aa3d324d0fe80"], "user": "pchevrel@mozilla.com"}, "24909": {"changesets": [{"author": "Yoshi Cheng-Hao Huang \u003callstars.chh@gmail.com\u003e", "branch": "default", "desc": "Bug 2019811 - Part 1: Refactor ModuleResolveExport.  a=pascalc DONTBUILD\n\nRename the Module Records' abstract methods `ResolveExport` to\n`ResolveExportWithResolveSet` and `ModuleResolveExport`.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D285717\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285992\n", "files": ["js/src/vm/Modules.cpp"], "git_node": "6732c6dce31bda78554ccb39c06b9e822070d1b8", "git_parents": ["dd03f7d7a35c88ac8d299f64232aa3d324d0fe80"], "node": "5bec23fd0696e449f02fbc6f3bcac0a1a8a84cbb", "parents": ["7fb61138232ac2cd251b8686561e2ad08ff906d9"], "tags": []}, {"author": "Yoshi Cheng-Hao Huang \u003callstars.chh@gmail.com\u003e", "branch": "default", "desc": "Bug 2019811 - Part 2: Call ModuleResolveExportWithResolveSet instead.  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D285718\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285993\n", "files": ["js/src/vm/Modules.cpp"], "git_node": "1988af71bafda3a2138ab6c7dfce49efb7528d4d", "git_parents": ["6732c6dce31bda78554ccb39c06b9e822070d1b8"], "node": "38f0b4426f9010d8bf239755a6ba544a8d05957d", "parents": ["5bec23fd0696e449f02fbc6f3bcac0a1a8a84cbb"], "tags": []}, {"author": "Yoshi Cheng-Hao Huang \u003callstars.chh@gmail.com\u003e", "branch": "default", "desc": "Bug 2019811 - Part 3: jit-test.  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D285719\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285994\n", "files": ["js/src/jit-test/tests/modules/bug-2019811.js"], "git_node": "10cefed3d9701e0fd43a5335c1644e01e34b1cdd", "git_parents": ["1988af71bafda3a2138ab6c7dfce49efb7528d4d"], "node": "333e59645fdb3ef9a508259e0d332b92281e73ad", "parents": ["38f0b4426f9010d8bf239755a6ba544a8d05957d"], "tags": []}], "date": 1772719229, "git_changesets": ["6732c6dce31bda78554ccb39c06b9e822070d1b8", "1988af71bafda3a2138ab6c7dfce49efb7528d4d", "10cefed3d9701e0fd43a5335c1644e01e34b1cdd"], "user": "pchevrel@mozilla.com"}, "24910": {"changesets": [{"author": "Malte J\u00fcrgens \u003cmaltejur@mozilla.com\u003e", "branch": "default", "desc": "Bug 2020354 - Fix missing subcategories for links in privacy & security settings  a=pascalc DONTBUILD\n\nThese were previously located in\nbrowser/components/preferences/privacy.inc.xhtml and seem to have not been