c7dd99a699fff8ebfff987e61e9cba", "parents": ["3227d90af0df5818372a4eb6eed19af903761ce3"], "tags": []}], "date": 1773219957, "git_changesets": ["761573fe85c68efe85226f014f1a3559fc4f7676"], "user": "pchevrel@mozilla.com"}, "25009": {"changesets": [{"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 2021306 - Translate the IP Protection warning system add-on,  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D286283\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286997\n", "files": ["browser/extensions/ipp-activator/extension/api/parent/ext-ipp.js", "browser/extensions/ipp-activator/extension/api/schemas/ipp.json", "browser/extensions/ipp-activator/extension/bg.js", "browser/extensions/ipp-activator/extension/breakages/tab.json", "browser/extensions/ipp-activator/moz.build", "browser/extensions/ipp-activator/tests/browser/browser.toml", "browser/extensions/ipp-activator/tests/browser/browser_breakages_l10n.js", "browser/locales/en-US/browser/ipProtection.ftl"], "git_node": "158502a97215fb3df502775ae44c451940aa7c3c", "git_parents": ["761573fe85c68efe85226f014f1a3559fc4f7676"], "node": "6cace15370f2bbd216d9b21a64d7dac910b30833", "parents": ["29e16459fac7dd99a699fff8ebfff987e61e9cba"], "tags": []}], "date": 1773220101, "git_changesets": ["158502a97215fb3df502775ae44c451940aa7c3c"], "user": "pchevrel@mozilla.com"}, "25010": {"changesets": [{"author": "Michael Hynson \u003cmhynson@mozilla.com\u003e", "branch": "default", "desc": "Bug 2020913 - Ensure VPN shows \u2018Get started\u2019 after re-adding to toolbar post 2nd CFR dismissal.  a=pascalc DONTBUILD\n\nThis patch updates how the opted out state is handled to ultimately show the \"Get Started\" state of the panel if a user opts out, but then re-adds the button to the toolbar manually.\n\nThere are 2 primary parts to this:\n\n  # Eliminate the IPProtectionState.OPTED_OUT state\n    # Eliminating this state allows the program to naturally flow past this point to check if the user is signed out and ultimately sets the `UNAUTHENTICATED` state. This state shows the user the \"Get Started\" panel after re-adding the toolbar button. from the  Bug 2020913 \u2014 Move widget removal on opt-out from IPProtection.sys.mjs to IPPOptOutHelper.sys.mjs\n  # Update how the `browser.ipProtection.optedOut` pref is read to remove the toolbar button\n    # Now that the OPTED_OUT state is no longer available, the `#handleEvent` method in `IPProtection.sys.mjs` no longer has anything to check against when the updateState is called\n    # So, `IPPOptOutHelper.sys.mjs` has been updated to handle the logic for removing the button from the toolbar if the `browser.ipProtection.optedOut` is set to true (which occurs when a user clicks the \"No Thanks\" button on a discovery CFR callout\n\nOriginal Revision: https://phabricator.services.mozilla.com/D286693\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286903\n", "files": ["browser/components/ipprotection/IPPOptOutHelper.sys.mjs", "browser/components/ipprotection/IPProtection.sys.mjs", "browser/components/ipprotection/IPProtectionService.sys.mjs"], "git_node": "52af89bd70a563faf37a7ea6271ffd110d8abe31", "git_parents": ["158502a97215fb3df502775ae44c451940aa7c3c"], "node": "ac7b7a651ed1a4a269a23278e8ccc85fbe2607f2", "parents": ["6cace15370f2bbd216d9b21a64d7dac910b30833"], "tags": []}], "date": 1773220377, "git_changesets": ["52af89bd70a563faf37a7ea6271ffd110d8abe31"], "user": "pchevrel@mozilla.com"}, "25011": {"changesets": [{"author": "Michael Hynson \u003cmhynson@mozilla.com\u003e", "branch": "default", "desc": "Bug 2020735 - Fix bandwidth warnings UI in the VPN panel.  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D286384\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286906\n", "files": ["browser/components/ipprotection/content/ipprotection-content.css"], "git_node": "a898e882a6c8ff99a27e98220009627a624fb132", "git_parents": ["52af89bd70a563faf37a7ea6271ffd110d8abe31"], "node": "a7621fbb9568c60e31263184f5fc4bb72c60a33e", "parents": ["ac7b7a651ed1a4a269a23278e8ccc85fbe2607f2"], "tags": []}], "date": 1773220541, "git_changesets": ["a898e882a6c8ff99a27e98220009627a624fb132"], "user": "pchevrel@mozilla.com"}, "25012": {"changesets": [{"author": "Alex Franchuk \u003cafranchuk@mozilla.com\u003e", "branch": "default", "desc": "Bug 2019539 - Rewrite the macos application stop logic  a=pascalc\n\nThere was a lot of fragility brought about by relying on the cocoa API\nbehavior, so this tracks the main application manually, and also fixes\nthe application `stop` call by sending a dummy event to ensure the event\nloop witnesses the stop flag.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D285856\n\nDifferential Revision: https://phabricator.services.mozilla.com/D286995\n", "files": ["toolkit/crashreporter/client/app/src/ui/macos/mod.rs"], "git_node": "83a5d2a8cda6706d1765d1eb504567692b904231", "git_parents": ["a898e882a6c8ff99a27e98220009627a624fb132"], "node": "b55b54d7b12c5a3e4ef5f29717b07b5b2e79a561", "parents": ["a7621fbb9568c60e31263184f5fc4bb72c60a33e"], "tags": ["DEVEDITION_149_0b7_BUILD1", "DEVEDITION_149_0b7_RELEASE", "FIREFOX-ANDROID_149_0b7_BUILD1", "FIREFOX-ANDROID_149_0b7_RELEASE", "FIREFOX_149_0b7_BUILD1", "FIREFOX_149_0b7_RELEASE"]}], "date": 1773221052, "git_changesets": ["83a5d2a8cda6706d1765d1eb504567692b904231"], "user": "pchevrel@mozilla.com"}, "25013": {"changesets": [{"author": "ffxbld \u003cffxbld@lando.moz.tools\u003e", "branch": "tags-unified", "desc": "No bug - Tagging b55b54d7b12c5a3e4ef5f29717b07b5b2e79a561 with FIREFOX-ANDROID_149_0b7_BUILD1 a=tagging CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": "dcee60929f138be85598069b77f8112b1d46e401", "git_parents": ["c68e195cfa19a1cac72084dd4060472cbeb4a113"], "node": "1da3b8a48c5344dd90a5c5bdba1f722a38461611", "parents": ["9e2d3a50cbce08380976df263f3b79