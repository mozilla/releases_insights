f4531c5fe55c71b539\nxh -\u003e 858b698d166040e2327f14f4531c5fe55c71b539\nzam -\u003e 858b698d166040e2327f14f4531c5fe55c71b539\nzh-CN -\u003e 858b698d166040e2327f14f4531c5fe55c71b539\nzh-TW -\u003e 858b698d166040e2327f14f4531c5fe55c71b539\n", "files": ["mobile/locales/l10n-changesets.json"], "git_node": "96230649dda4ec7ad9d4bd3399e474a6b3220fc5", "git_parents": ["694628bcdd92dcedbb7a9d8d4a47a2f2c0790c23"], "node": "a84efc23255ecedea57b381ce9e15eabfbf121f8", "parents": ["70b84bd8799f3ba609dbaa6aaad8e6f2205bdef1"], "tags": []}], "date": 1772528755, "git_changesets": ["694628bcdd92dcedbb7a9d8d4a47a2f2c0790c23", "96230649dda4ec7ad9d4bd3399e474a6b3220fc5"], "user": "ffxbld@lando.moz.tools"}, "24863": {"changesets": [{"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 2017797 - Part 1: Allow calls to structuredClone to change globals,  a=pascalc\n\nThis better aligns with the behaviour as defined in the spec, and allows us to\nstart passing some WPTs we were previously failing.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284163\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285609\n", "files": ["dom/base/nsContentUtils.cpp", "testing/web-platform/meta/html/webappapis/structured-clone/structured-clone-cross-realm-method.html.ini"], "git_node": "f843e481a8cbc1c85bc566c6d28b055c2dd9bf82", "git_parents": ["96230649dda4ec7ad9d4bd3399e474a6b3220fc5"], "node": "d0d302b6e7240bde265f83d1e24c4d4b0b428455", "parents": ["a84efc23255ecedea57b381ce9e15eabfbf121f8"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 2017797 - Part 2: Don't require bindings header for IS_INSTANCE_OF,  a=pascalc\n\nThe implementaion of IS_INSTANCE_OF previously specified the true native type T\nto UnwrapObjectInternal. This is unnecessary, as it is not part of the actual\n\"IsInstanceOf\" check, and is only used for a static cast (which is then\ndiscarded).\n\nThis patch changes the passed-in type to be `void`. This change should have no\nruntime effect (the value was assigned into a void* immediately anyways), but\navoids requiring callers which use IS_INSTANCE_OF to import the relevant\nbindings headers.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284522\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285610\n", "files": ["dom/bindings/BindingUtils.h"], "git_node": "46775a04d18b67adb0ce00326fbfbdcec559ab89", "git_parents": ["f843e481a8cbc1c85bc566c6d28b055c2dd9bf82"], "node": "c9560ec7f2cdb7ab172c880375a48e0d35bdcc83", "parents": ["d0d302b6e7240bde265f83d1e24c4d4b0b428455"], "tags": []}, {"author": "Nika Layzell \u003cnika@thelayzells.com\u003e", "branch": "default", "desc": "Bug 2017797 - Part 3: Preserve legacy structuredClone behaviour for WebExtensions,  a=pascalc\n\nThis change attempts to preserve the behaviour from before bug 2013389 for\nWebExtensions, putting the janky type-dependant behaviour behind a pref. This\nis done by making the webextension content script globals shadow\n'structuredClone' with an alternative implementation based in the content\nscript's global.\n\nThis alternative implementation will, when being called from a webextension\ncontent script, only change the global of the cloned object when called on one\nof the set of DOM objects which previously were impacted by the bug.\n\nNote that previously 'structuredClone' would do this odd behaviour even for a\nnested object, but this is very unlikely to happen intentionally (and would be\nmuch more difficult to implement), so that behaviour has not been preserved.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284524\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285611\n", "files": ["js/xpconnect/src/Sandbox.cpp", "modules/libpref/init/StaticPrefList.yaml", "toolkit/components/extensions/ExtensionContent.sys.mjs", "toolkit/components/extensions/ExtensionUserScriptsContent.sys.mjs", "toolkit/components/extensions/test/xpcshell/test_ext_contentscript_structured_clone.js", "toolkit/components/extensions/test/xpcshell/xpcshell-common.toml"], "git_node": "2c5b9cecd0f2816ff7672b87dd3534321581b3fb", "git_parents": ["46775a04d18b67adb0ce00326fbfbdcec559ab89"], "node": "9b37b28682fdfe06a413541fbb5d5ad9fb9bb2bc", "parents": ["c9560ec7f2cdb7ab172c880375a48e0d35bdcc83"], "tags": []}], "date": 1772529297, "git_changesets": ["f843e481a8cbc1c85bc566c6d28b055c2dd9bf82", "46775a04d18b67adb0ce00326fbfbdcec559ab89", "2c5b9cecd0f2816ff7672b87dd3534321581b3fb"], "user": "pchevrel@mozilla.com"}, "24864": {"changesets": [{"author": "Jeff Muizelaar \u003cjmuizelaar@mozilla.com\u003e", "branch": "default", "desc": "Bug 2017547. Add hyattinclusivecollection.com to defer_during_load.force-disable. a=pascalc DONTBUILD\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285178\n", "files": ["modules/libpref/init/StaticPrefList.yaml"], "git_node": "c5ed9763dd86eb1ac372d036660612d85213ec1f", "git_parents": ["2c5b9cecd0f2816ff7672b87dd3534321581b3fb"], "node": "0775bedf0d48d08408715f23894d1cdaa136ed86", "parents": ["9b37b28682fdfe06a413541fbb5d5ad9fb9bb2bc"], "tags": []}], "date": 1772529779, "git_changesets": ["c5ed9763dd86eb1ac372d036660612d85213ec1f"], "user": "pchevrel@mozilla.com"}, "24865": {"changesets": [{"author": "alin lastun \u003calastun@mozilla.com\u003e", "branch": "default", "desc": "Bug 1985031 - Update default prompt tracking logic.  a=pascalc DONTBUILD\n\nUpdated the settings call to use 'setToDefaultPromptRequested' instead of 'lastSetAsDefaultPromptShownTimeInMillis' to correctly track the user request time.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284991\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285686\n", "files": ["mobile/android/fenix/app/src/main/java/org/mozilla/fenix/home/SetToDefaultPromptRequest.kt"], "git_node": "13de40ba5a09f9ef7bc84720213305e0eee3fb50", "git_parents": ["c5ed9763dd86eb1ac372d036660612d85213ec1f"], "node": "cd08d7f7bb8f5ef15d5287cb292cfcadc519fa33", "parents": ["0775bedf0d48d08408715f23894d1cdaa136ed86"], "tags": []}], "date": 1772549389, "git_changesets": ["13de40ba5a09f9ef7bc84720213305e0eee3fb50"], "user": "pchevrel@mozilla.com"}, "24866": {"changesets": [{"author": "Tim Huang \u003ctihuang@mozilla.com\u003e", "branch": "default", "desc": "Bug 2018004 - Part 1: Introduce cookieJarSettings to the requestInit for fetch requests.  a=pascalc\n\nNormally, a fetch request acquires its cookieJarSettings from the global\nthat triggers it (a window or a worker). However, the global may not\nalways have the correct cookieJarSettings. For example, the Reporting API\ndelivers reports using fetch from a global whose cookieJarSettings does\nnot match the originating content. In this case, the fallback creates a\ndefault cookieJarSettings which can cause crashes when processing\nSet-Cookie response headers (e.g. CHIPS cookies with the Partitioned\nattribute).\n\nThis patch adds a ChromeOnly cookieJarSettings field to RequestInit and\na corresponding member on InternalRequest, allowing callers to explicitly\nprovide the correct cookieJarSettings. When set, it takes precedence\nover the cookieJarSettings obtained from the global.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D285021\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285690\n", "files": ["dom/fetch/Fetch.cpp", "dom/fetch/InternalRequest.cpp", "dom/fetch/InternalRequest.h", "dom/fetch/Request.cpp", "dom/webidl/Request.webidl"], "git_node": "2e1c961005e3996a312dd94c780684c6115f7c3a", "git_parents": ["13de40ba5a09f9ef7bc84720213305e0eee3fb50"], "node": "a55422e36f699122f69b41c6f3877006593a14ce", "parents": ["cd08d7f7bb8f5ef15d5287cb292cfcadc519fa33"], "tags": []}, {"author": "Tim Huang \u003ctihuang@mozilla.com\u003e", "branch": "default", "desc": "Bug 2018004 - Part 2: Use the correct cookieJarSettings for requests of Reporting API.  a=pascalc\n\nThe Reporting API sends report delivery requests from a global that may\nnot carry the correct cookieJarSettings for the originating content.\nThis can cause crashes when the reporting endpoint responds with\nSet-Cookie headers that require proper cookie jar context (e.g. CHIPS\ncookies with the Partitioned attribute).\n\nThis patch propagates the cookieJarSettings through the reporting pipeline.\nWe store the cookieJarSettings in the GlobalReportingData when\ninitializing the reporting endpoints, obtained from the document or the\nworker private. Then, we use the stored cookieJarSettings for the fetch\nrequest for the report delivery.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D285022\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285691\n", "files": ["dom/reporting/ReportDeliver.cpp", "dom/reporting/ReportDeliver.h", "dom/workers/WorkerPrivate.cpp"], "git_node": "413aa30ecfd1f81ea98334bbc5bf4a813569470c", "git_parents": ["2e1c961005e3996a312dd94c780684c6115f7c3a"], "node": "9cb4e5b09e43f945fc11a4b43637a00a088e8394", "parents": ["a55422e36f699122f69b41c6f3877006593a14ce"], "tags": []}, {"author": "Tim Huang \u003ctihuang@mozilla.com\u003e", "branch": "default", "desc": "Bug 2018004 - Part 3: Add tests.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D285023\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285692\n", "files": ["dom/reporting/tests/delivering.sjs", "dom/reporting/tests/iframe_delivering_chips.html", "dom/reporting/tests/iframe_delivering_chips_worker.html", "dom/reporting/tests/mochitest.toml", "dom/reporting/tests/test_delivering_chips.html", "dom/reporting/tests/test_delivering_chips_worker.html", "dom/reporting/tests/worker_delivering_chips.js"], "git_node": "88697cb8e4403f4615f227d779d00b8757fe2dc4", "git_parents": ["413aa30ecfd1f81ea98334bbc5bf4a813569470c"], "node": "cacabeeb9cbe715793ed999b35bcd86613840054", "parents": ["9cb4e5b09e43f945fc11a4b43637a00a088e8394"], "tags": []}], "date": 1772549888, "git_changesets": ["2e1c961005e3996a312dd94c780684c6115f7c3a", "413aa30ecfd1f81ea98334bbc5bf4a813569470c", "88697cb8e4403f4615f227d779d00b8757fe2dc4"], "user": "pchevrel@mozilla.com"}, "24867": {"changesets": [{"author": "Jamie Nicol \u003cjnicol@mozilla.com\u003e", "branch": "default", "desc": "Bug 2014925 - Null terminate shader source strings on Adreno 750 GPUs.  a=pascalc DONTBUILD\n\nOn some Lenovo devices with Adreno 750 GPUs we are seeing cases of\nglCompileShader failing, and the subsequent call to glGetShaderInfoLog\nreturning invalid UTF-8, leading to a crash in the gleam bindings when\nconverting to a Rust String.\n\nWe have been unable to reproduce the crash organically. However, by\npassing null as the length argument to glCompileShader (whilst still\npassing non-null-terminated source strings) we can reproduce the exact\nsame behaviour. This perhaps indicates that the lack of null\ntermination could be a factor in the crash, though of course it does\nnot explain why users in the wild are encountering this when we could\nnot ourselves.\n\nThis patch therefore speculatively ensures the shader source strings\nwe pass to the driver are always null terminated on this\nGPU. Hopefully that will prevent the compilation failures and crashes.\n\nOriginal Revision: https://phabricator.services.mozilla.com/D285497\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285693\n", "files": ["gfx/wr/webrender/src/device/gl.rs"], "git_node": "5c525b1c92148ec53d780257ff89b0fcc80076e1", "git_parents": ["88697cb8e4403f4615f227d779d00b8757fe2dc4"], "node": "6facd08f1f359c9a3bff312c94a6af774bac0d78", "parents": ["cacabeeb9cbe715793ed999b35bcd86613840054"], "tags": []}], "date": 1772549941, "git_changesets": ["5c525b1c92148ec53d780257ff89b0fcc80076e1"], "user": "pchevrel@mozilla.com"}, "24868": {"changesets": [{"author": "Titouan Thibaud \u003ctthibaud@mozilla.com\u003e", "branch": "default", "desc": "Bug 2019453 - Fix homeview-startup perf tests after setting Edge2Edge background as default.  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D285043\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285708\n", "files": ["testing/performance/mobile-startup/expected_startup_screenshots/fenix-homeview_startup-a55.png", "testing/performance/mobile-startup/expected_startup_screenshots/fenix-homeview_startup-p6.png", "testing/performance/mobile-startup/expected_startup_screenshots/fenix-homeview_startup-s24.png"], "git_node": "bccfada3eb578b0cafe20989db72e5793388c9ec", "git_parents": ["5c525b1c92148ec53d780257ff89b0fcc80076e1"], "node": "2cd622c92820bd047aac9df3577b99e310d8c5cd", "parents": ["6facd08f1f359c9a3bff312c94a6af774bac0d78"], "tags": []}], "date": 1772549984, "git_changesets": ["bccfada3eb578b0cafe20989db72e5793388c9ec"], "user": "pchevrel@mozilla.com"}, "24869": {"changesets": [{"author": "Artur Iunusov \u003caiunusov@mozilla.com\u003e", "branch": "default", "desc": "Bug 2017785 - Assertion failure: aNewLength \u003c= base_string_type::mLength,  a=pascalc DONTBUILD\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284630\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285714\n", "files": ["dom/indexedDB/Key.h", "dom/indexedDB/test/crashtests/2017785-1.html", "dom/indexedDB/test/crashtests/crashtests.list"], "git_node": "5dfc1f69fbb1f157f94213939410d0846df1ac1d", "git_parents": ["bccfada3eb578b0cafe20989db72e5793388c9ec"], "node": "ffab33b9cc5fc497347baa253e773795921e1fdf", "parents": ["2cd622c92820bd047aac9df3577b99e310d8c5cd"], "tags": []}], "date": 1772550028, "git_changesets": ["5dfc1f69fbb1f157f94213939410d0846df1ac1d"], "user": "pchevrel@mozilla.com"}, "24870": {"changesets": [{"author": "Ben Visness \u003cbvisness@mozilla.com\u003e", "branch": "default", "desc": "Bug 2013762: Make table loads immovable.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D284888\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285780\n", "files": ["js/src/jit/MIR-wasm.h"], "git_node": "a845ded03d9ebadbc84a6fadc2c6d61f66f4ba66", "git_parents": ["5dfc1f69fbb1f157f94213939410d0846df1ac1d"], "node": "444391e9a7efc6caddce0ebe900ac51452b11a9a", "parents": ["ffab33b9cc5fc497347baa253e773795921e1fdf"], "tags": []}], "date": 1772557784, "git_changesets": ["a845ded03d9ebadbc84a6fadc2c6d61f66f4ba66"], "user": "pchevrel@mozilla.com"}, "24871": {"changesets": [{"author": "Jeremy Swinarton \u003cjswinarton@mozilla.com\u003e", "branch": "default", "desc": "Bug 2014299: Improve persistence handling in tab hover preview  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D282225\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285758\n", "files": ["browser/base/content/main-popupset.inc.xhtml", "browser/components/tabbrowser/content/tab-hover-preview.mjs", "browser/components/tabbrowser/test/browser/tabs/browser_tab_preview.js", "browser/themes/shared/tabbrowser/tab-hover-preview.css"], "git_node": "831aea6b09b1dc7e86b8a65fb8c4d684d0783f93", "git_parents": ["a845ded03d9ebadbc84a6fadc2c6d61f66f4ba66"], "node": "42af021d17b2045057508f275f5f67d3b32ab13c", "parents": ["444391e9a7efc6caddce0ebe900ac51452b11a9a"], "tags": []}, {"author": "DJ \u003cdj@walker.dev\u003e", "branch": "default", "desc": "Bug 2014295 - move tab note section to new preview panel.  a=pascalc\n\nOriginal Revision: https://phabricator.services.mozilla.com/D282227\n\nDifferential Revision: https://phabricator.services.mozilla.com/D285759\n", "files": ["browser/base/content/main-popupset.inc.xhtml", "browser/components/tabbrowser/content/tab-hover-preview.mjs", "browser/components/tabbrowser/content/tab.js", "browser/components/tabbrowser/content/tabs.js", "browser/components/tabbrowser/test/browser/tabs/browser.toml", "browser/components/tabbrowser/test/browser/tabs/browser_tab_note_preview.js", "browser/components/tabbrowser/