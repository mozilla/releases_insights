6189"], "tags": []}], "date": 1537542035, "git_changesets": [null, null], "user": "ffxbld"}, "9857": {"changesets": [{"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1488296 - Race condition when setting favicons for a browser with a changed currentURI. r=mossop a=pascalc\n\nThere is a race condition between the time we decide to fetch an icon and the time we actually store that icon, where the original browser currentURI may have changed.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5685", "files": ["browser/actors/LinkHandlerChild.jsm", "browser/base/content/browser.js", "browser/components/originattributes/test/browser/browser_favicon_userContextId.js", "browser/components/places/PlacesUIUtils.jsm", "browser/modules/FaviconLoader.jsm"], "git_node": null, "git_parents": [null], "node": "df9eabc4e3e1f12b4d42c6f09fdf28857e685f6c", "parents": ["4012293f8bbcbfa34b5fb7af5b420f547725d0b3"], "tags": []}], "date": 1537545596, "git_changesets": [null], "user": "nerli@mozilla.com"}, "9858": {"changesets": [{"author": "Tom Glowka \u003cglowka.tom@gmail.com\u003e", "branch": "default", "desc": "Bug 1478361 - Simplify custom headers editing to prevent caret reset; r=Honza a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5410", "files": ["devtools/client/netmonitor/src/components/CustomRequestPanel.js", "devtools/client/netmonitor/test/browser.ini", "devtools/client/netmonitor/test/browser_net_edit_resend_caret.js"], "git_node": null, "git_parents": [null], "node": "b8b8642597be9d74ff5617ad769166664061c1d5", "parents": ["df9eabc4e3e1f12b4d42c6f09fdf28857e685f6c"], "tags": []}], "date": 1537545757, "git_changesets": [null], "user": "nerli@mozilla.com"}, "9859": {"changesets": [{"author": "Alessio Placitelli \u003calessio.placitelli@gmail.com\u003e", "branch": "default", "desc": "Bug 1491888 - Bump the version of the HCT npm package. r=chutten a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6056", "files": ["toolkit/components/telemetry/hybrid-content/package.json"], "git_node": null, "git_parents": [null], "node": "ec9bd79846dbaa3fec98cac6681892ca5073f508", "parents": ["b8b8642597be9d74ff5617ad769166664061c1d5"], "tags": []}], "date": 1537547471, "git_changesets": [null], "user": "nerli@mozilla.com"}, "9860": {"changesets": [{"author": "Alessio Placitelli \u003calessio.placitelli@gmail.com\u003e", "branch": "default", "desc": "Bug 1490284 - Make Mozilla.ContentTelemetry.initPromise reject. r=chutten a=pascalc\n\nThis patch enables Hybrid Content Telemetry's |initPromise| to reject\nif it is disabled or if the host requesting the API doesn't have\nenough privileges. This also updates the documentation to mention\nthe change in behaviour.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5849", "files": ["toolkit/components/telemetry/docs/collection/hybrid-content.rst", "toolkit/components/telemetry/hybrid-content/HybridContentTelemetry-lib.js", "toolkit/components/telemetry/hybrid-content/content-HybridContentTelemetry.js", "toolkit/components/telemetry/tests/browser/browser_HybridContentTelemetry.js"], "git_node": null, "git_parents": [null], "node": "f5b8fa65dbdf55a44778f0b6daba6765dd9d4226", "parents": ["ec9bd79846dbaa3fec98cac6681892ca5073f508"], "tags": []}], "date": 1537547904, "git_changesets": [null], "user": "nerli@mozilla.com"}, "9861": {"changesets": [{"author": "alwu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1477767 - disconnect request when XPCOM is going to shutdown. r=cpearce a=pascalc\n\nThe reason we hit this assertion is that we still connected to Then() and waited for its result when the resolve or reject\nrunnable which dispatched by ThenValue can't be executed because the target thread had been shutdown.\n\nTherefore, when XPCOM is going to shutdown, we should disconnect the Then() because it might not have a chance to execute\nits resolve/reject method.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5893", "files": ["dom/html/HTMLMediaElement.cpp"], "git_node": null, "git_parents": [null], "node": "9f7aaef8e942aa7707b352168bb45a9a2a35f3bd", "parents": ["f5b8fa65dbdf55a44778f0b6daba6765dd9d4226"], "tags": []}, {"author": "alwu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1479218 - deny request when inner window is destroyed. r=cpearce a=pascalc\n\nThe AutoplayPermissionManager might be destroyed before the AutoplayPermissionRequest, so we can't\nget the response from request before AutoplayPermissionManager is destroyed.\n\nTherefore, we should manually reject the promise when the inner window is going to be destroyed.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5906", "files": ["dom/base/nsGlobalWindowInner.cpp", "dom/html/AutoplayPermissionManager.cpp", "dom/html/AutoplayPermissionManager.h", "dom/html/AutoplayPermissionRequest.cpp"], "git_node": null, "git_parents": [null], "node": "d0e8aadd83231090f63d8823089d23edb5bf8b41", "parents": ["9f7aaef8e942aa7707b352168bb45a9a2a35f3bd"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1489007 - Turn the colour of the 'Disabled' warning when Content Blocking UI is turned off and tracking protection is off to grey; r=johannh a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5940", "files": ["browser/themes/shared/controlcenter/panel.inc.css"], "git_node": null, "git_parents": [null], "node": "79c5606108ecb4308e00b14be1d7ccfbeacf908d", "parents": ["d0e8aadd83231090f63d8823089d23edb5bf8b41"], "tags": []}], "date": 1537548145, "git_changesets": [null, null, null], "user": "nerli@mozilla.com"}, "9862": {"changesets": [{"author": "L10n Bumper Bot \u003crelease+l10nbumper@mozilla.com\u003e", "branch": "default", "desc": "no bug - Bumping Fennec l10n changesets r=release a=l10n-bump DONTBUILD\n\nan -\u003e 188db2a0a2e2\nar -\u003e