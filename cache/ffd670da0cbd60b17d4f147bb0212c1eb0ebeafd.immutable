397 - Part 3: Return the computed style properties and flex item sizing information from the FlexItemActor. r=rcaliman", "files": ["devtools/client/inspector/flexbox/flexbox.js", "devtools/client/inspector/flexbox/types.js", "devtools/server/actors/layout.js", "devtools/shared/fronts/layout.js"], "git_node": null, "git_parents": [null], "node": "4a5c07069012762e90459ed1f81c48e0a53f3cd1", "parents": ["58fb697a29d3e0f0411cfe26c1a5af83f233bb93"], "tags": []}, {"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 1478397 - Part 4: Implement the methods to show the flex item highlighter from HighlightersOverlay. r=rcaliman", "files": ["devtools/client/inspector/shared/highlighters-overlay.js"], "git_node": null, "git_parents": [null], "node": "920027e02ee128e0bbe86e824395f006045c1cbc", "parents": ["4a5c07069012762e90459ed1f81c48e0a53f3cd1"], "tags": []}, {"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 1486797 - flex display badge is not active when the flexbox highlighter is shown. r=miker", "files": ["devtools/client/themes/markup.css"], "git_node": null, "git_parents": [null], "node": "2ab1eb37def4c617e420cb30d5d6e7789e80ca01", "parents": ["920027e02ee128e0bbe86e824395f006045c1cbc"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1480366 - Traverse/Unlink mAbortFollowing in any object exposed to content, r=smaug", "files": ["dom/fetch/FetchObserver.cpp", "dom/fetch/Request.cpp"], "git_node": null, "git_parents": [null], "node": "44e3fc29c49f0af6823790b74f051f62f8340ecc", "parents": ["2ab1eb37def4c617e420cb30d5d6e7789e80ca01"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486429 - AbortSignal must use nsTObserverArray for AbortFollower objects, r=smaug", "files": ["dom/abort/AbortSignal.cpp", "dom/abort/AbortSignal.h"], "git_node": null, "git_parents": [null], "node": "7318404ba4f875eb47ed568fa31572567885b47e", "parents": ["44e3fc29c49f0af6823790b74f051f62f8340ecc"], "tags": []}, {"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 1470380 - Enable the first simple version of the flexbox highlighter (M0) in nightly only. r=pbro", "files": ["devtools/client/preferences/devtools-client.js"], "git_node": null, "git_parents": [null], "node": "4379708ccd033804982e79c50631aca905289949", "parents": ["7318404ba4f875eb47ed568fa31572567885b47e"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1480587 - add support for atomic operations on AArch64 Windows; r=lth", "files": ["js/src/jit/AtomicOperations.h", "js/src/jit/arm64/AtomicOperations-arm64-gcc.h", "js/src/jit/arm64/AtomicOperations-arm64-msvc.h", "js/src/jit/arm64/AtomicOperations-arm64.h"], "git_node": null, "git_parents": [null], "node": "796f67446c435f7549d83df018fde1bb854eaa04", "parents": ["4379708ccd033804982e79c50631aca905289949"], "tags": []}, {"author": "Gurzau Raul \u003crgurzau@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset a47f6d2d38a4 (bug 1486536) for failing at tests/layout/style/crashtests/1486536.html", "files": ["layout/style/crashtests/1486536.html", "layout/style/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "0e03f055808cb2ed38381c1c1f7f1b2756a7c8a4", "parents": ["796f67446c435f7549d83df018fde1bb854eaa04"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1486480.  Add memory reporting for custom element data.  r=smaug\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4350", "files": ["dom/base/CustomElementRegistry.cpp", "dom/base/CustomElementRegistry.h", "dom/base/FragmentOrElement.cpp", "dom/base/FragmentOrElement.h", "dom/base/nsIContent.h"], "git_node": null, "git_parents": [null], "node": "4292aeb328da7fa052bec34a635248e849400a58", "parents": ["0e03f055808cb2ed38381c1c1f7f1b2756a7c8a4"], "tags": []}, {"author": "Bas Schouten \u003cbschouten@mozilla.com\u003e", "branch": "default", "desc": "Bug 1485485 - Followup: Fix which function definition in derrived classes. r=froydnj", "files": ["python/mozboot/mozboot/mozillabuild.py", "python/mozboot/mozboot/windows.py"], "git_node": null, "git_parents": [null], "node": "7eb7606a2b12990e8ef5e470db27838d5f5af612", "parents": ["4292aeb328da7fa052bec34a635248e849400a58"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1486057: Skip uninitialized windows when injecting content scripts. r=mixedpuppy\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4286", "files": ["toolkit/components/extensions/ExtensionPolicyService.cpp"], "git_node": null, "git_parents": [null], "node": "292e35a4377f5f6c5534dad4f4df349010de41b9", "parents": ["7eb7606a2b12990e8ef5e470db27838d5f5af612"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1486199: Ignore null promises when injecting content scripts. r=mixedpuppy\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4287", "files": ["toolkit/components/extensions/ExtensionPolicyService.cpp"], "git_node": null, "git_parents": [null], "node": "24a110d82c0f52e757878dbfa7b0c62f2bd0b2fa", "parents": ["292e35a4377f5f6c5534dad4f4df349010de41b9"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1486130: Fix reporting of unhandled DOMException rejection values. r=smaug\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4264", "files": ["browser/components/payments/test/browser/head.js", "dom/promise/Promise.cpp", "dom/promise/tests/unit/.eslintrc.js", "dom/promise/tests/unit/test_promise_unhandled_rejection.js", "dom/promise/tests/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "7ccc1c8a7abeefd54bc4cf9a5d0eef23681c924a", "parents": ["24a110d82c0f52e757878dbfa7b0c62f2bd0b2fa"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1485209 - Make the JIT check that an object/string is non-null and aligned (mainly to catch poison patterns) before storing, r=tcampbell", "files": ["js/src/jit/x64/MacroAssembler-x64.h", "js/src/jit/x86/MacroAssembler-x86.h"], "git_node": null, "git_parents": [null], "node": "275602e7cfcdd2e9c7326bbd190525cd92f21832", "parents": ["7ccc1c8a7abeefd54bc4cf9a5d0eef23681c924a"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1481776 - [geckodriver] Move WebDriver related code into the command module. r=ato", "files": ["testing/geckodriver/src/capabilities.rs", "testing/geckodriver/src/command.rs", "testing/geckodriver/src/main.rs", "testing/geckodriver/src/marionette.rs"], "git_node": null, "git_parents": [null], "node": "fb80a4f44ac2a1ea9007d72593521dde33e4d2bc", "parents": ["275602e7cfcdd2e9c7326bbd190525cd92f21832"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1481513 - disable ffvpx on aarch64 windows; r=gps\n\nThere's no support for it in our local tree.", "files": ["old-configure.in"], "git_node": null, "git_parents": [null], "node": "64213b300680bd87b79990b63a9304f80034a664", "parents": ["fb80a4f44ac2a1ea9007d72593521dde33e4d2bc"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1486512: Fix compiling Promise-inl.h on MSVC. r=froydnj\n\nFor reasions which are unclear, MSVC does not recognize the declaration and\ndefinition of ThenWithCycleCollectedArts as matching in their previous form.\nChanging both to use the same template `using` declaration for the entire\nreturn type fixes this.\n\nMSVC also has problems with the previous use of std::forward, which is fixed\nby explicitly coercing smart pointers to their equivalent pointer types, and\nmoving any other type.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4397", "files": ["dom/promise/Promise-inl.h", "dom/promise/Promise.h"], "git_node": null, "git_parents": [null], "node": "23e112bfaf97817122b1f3bae3e9ecf4ff9d63ef", "parents": ["64213b300680bd87b79990b63a9304f80034a664"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1486130: Follow-up: Ignore extra console message on OS-X. r=bustage,test-only", "files": ["dom/promise/tests/unit/test_promise_unhandled_rejection.js"], "git_node": null, "git_parents": [null], "node": "ee4af6d31e69542f53aee91cb126e3d2a85691de", "parents": ["23e112bfaf97817122b1f3bae3e9ecf4ff9d63ef"], "tags": []}, {"author": "Narcis Beleuzu \u003cnbeleuzu\u003e", "branch": "default", "desc": "Bug 1366137 - Disable browser_new_web_tab_in_file_process_pref.js on OSX-debug for frequent failures. r=jmaher", "files": ["browser/base/content/test/tabs/browser.ini"], "git_node": null, "git_parents": [null], "node": "b6d7a77d510952174e4668364fca3f0c441e328e", "parents": ["ee4af6d31e69542f53aee91cb126e3d2a85691de"], "tags": []}, {"author": "omersid", "branch": "default", "desc": "Bug 1472170- Added description as a property for Symbol and updated tests262. r=anba", "files": ["js/src/builtin/Symbol.cpp", "js/src/builtin/Symbol.h", "js/src/tests/test262-update.py", "js/src/tests/test262/built-ins/Symbol/prototype/description/description-symboldescriptivestring.js", "js/src/tests/test262/built-ins/Symbol/prototype/description/descriptor.js", "js/src/tests/test262/built-ins/Symbol/prototype/description/get.js", "js/src/tests/test262/built-ins/Symbol/prototype/description/is-not-own-property.js", "js/src/tests/test262/built-ins/Symbol/prototype/description/this-val-non-symbol.js", "js/src/tests/test262/built-ins/Symbol/prototype/description/this-val-symbol.js", "js/src/tests/test262/built-ins/Symbol/prototype/description/wrapper.js"], "git_node": null, "git_parents": [null], "node": "709590a1a24fc8d55f891204dd1e105eaf787177", "parents": ["b6d7a77d510952174e4668364fca3f0c441e328e"], "tags": []}, {"author": "Ashley Hauck \u003ckhyperia@mozilla.com\u003e", "branch": "default", "desc": "Bug 1476921 - Don't throw an error in GetModuleNamespace for errored modules. r=jonco", "files": ["js/src/builtin/Module.js"], "git_node": null, "git_parents": [null], "node": "873cd2e119b3296e3407969f1f7459726f5d2a17", "parents": ["709590a1a24fc8d55f891204dd1e105eaf787177"], "tags": []}, {"author": "Ashley Hauck \u003ckhyperia@mozilla.com\u003e", "branch": "default", "desc": "Bug 1476921 - Add tests to make sure GetModuleNamespace errors are correctly handled. r=jonco", "files": ["js/src/jit-test/tests/modules/bug-1476921.js"], "git_node": null, "git_parents": [null], "node": "25af0b19ec39666d33efe54a7feca0e7cb35fb6c", "parents": ["873cd2e119b3296e3407969f1f7459726f5d2a17"], "tags": []}, {"author": "Jorg K \u003cjorgk@jorgk.com\u003e", "branch": "default", "desc": "Bug 1486178 - fix mouse-up and mouse-move handling in auto-complete if widget embedded in richlistbox. r=Gijs", "files": ["toolkit/content/widgets/autocomplete.xml"], "git_node": null, "git_parents": [null], "node": "f6d7cbceaa1ae13625587c887c6d5e720ccd3399", "parents": ["25af0b19ec39666d33efe54a7feca0e7cb35fb6c"], "tags": []}, {"author": "Jan Beich \u003cjbeich@FreeBSD.org\u003e", "branch": "default", "desc": "Bug 1486281 - Implement js::ThisThread::GetName() on FreeBSD 11.3/12.0. r=sfink r=Build", "files": ["js/src/old-configure.in", "js/src/threading/posix/Thread.cpp"], "git_node": null, "git_parents": [null], "node": "744b6786f4d2c5f65cac6475b18d6a113ab1ac72", "parents": ["f6d7cbceaa1ae13625587c887c6d5e720ccd3399"], "tags": []}, {"author": "Ekanan Ketunuti \u003cananuti@gmail.com\u003e", "branch": "default", "desc": "Bug 1486338 - Add words to en-US dictionary. r=ehsan", "files": ["extensions/spellcheck/locales/en-US/hunspell/en-US.dic"], "git_node": null, "git_parents": [null], "node": "72614ed1b56fc7afcd3844557b08fd20a9aa3b89", "parents": ["744b6786f4d2c5f65cac6475b18d6a113ab1ac72"], "tags": []}, {"author": "Ashley Hauck \u003ckhyperia@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486584 - Update test262 sort-tonumber.js. r=jorendorff", "files": ["js/src/tests/non262/TypedArray/sort-tonumber.js", "js/src/tests/test262/built-ins/TypedArray/prototype/sort/sort-tonumber.js"], "git_node": null, "git_parents": [null], "node": "28b6adbb3b4c9d076a1b93590cf12ffe22795ecc", "parents": ["72614ed1b56fc7afcd3844557b08fd20a9aa3b89"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Backed out 2 changesets (bug 1476921) for build bustage. CLOSED TREE\n\nBacked out changeset 25af0b19ec39 (bug 1476921)\nBacked out changeset 873cd2e119b3 (bug 1476921)", "files": ["js/src/builtin/Module.js", "js/src/jit-test/tests/modules/bug-1476921.js"], "git_node": null, "git_parents": [null], "node": "211b070bac735ff9301f80af489a045a7f644b60", "parents": ["28b6adbb3b4c9d076a1b93590cf12ffe22795ecc"], "tags": []}, {"author": "Ciure Andrei \u003caciure@mozilla.com\u003e", "branch": "default", "desc": "Merge inbound to mozilla-central. a=merge", "files": ["browser/app/profile/firefox.js", "devtools/client/inspector/flexbox/components/FlexContainerItem.js", "devtools/client/inspector/flexbox/components/FlexContainerList.js", "devtools/client/preferences/devtools-client.js", "dom/base/CustomElementRegistry.cpp", "dom/base/CustomElementRegistry.h", "dom/base/FragmentOrElement.cpp", "dom/base/FragmentOrElement.h", "dom/base/nsDocument.cpp", "dom/base/nsIContent.h", "gfx/src/nsIScriptableRegion.idl", "gfx/src/nsScriptableRegion.cpp", "gfx/src/nsScriptableRegion.h", "gfx/tests/unit/.eslintrc.js", "gfx/tests/unit/test_nsIScriptableRegion.js", "gfx/tests/unit/xpcshell.ini", "js/src/jit/arm64/AtomicOperations-arm64.h", "modules/libpref/init/StaticPrefList.h", "testing/web-platform/meta/MANIFEST.json", "testing/web-platform/meta/webdriver/tests/element_send_keys/user_prompts.py.ini", "toolkit/components/antitracking/test/browser/browser_imageCache.js"], "git_node": null, "git_parents": [null, null], "node": "3205543f957cd2a6905486d73aa897535fdd9825", "parents": ["9494c03553b9b968194c78602fb75273d39d9ede", "211b070bac735ff9301f80af489a045a7f644b60"], "tags": []}, {"author": "Ciure Andrei \u003caciure@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland.  a=merge CLOSED TREE", "files": ["devtools/client/inspector/flexbox/components/FlexContainerItem.js", "devtools/client/inspector/flexbox/components/FlexContainerList.js", "gfx/src/nsIScriptableRegion.idl", "gfx/src/nsScriptableRegion.cpp", "gfx/src/nsScriptableRegion.h", "gfx/tests/unit/.eslintrc.js", "gfx/tests/unit/test_nsIScriptableRegion.js", "gfx/tests/unit/xpcshell.ini", "js/src/jit/arm64/AtomicOperations-arm64.h", "testing/web-platform/meta/MANIFEST.json", "testing/web-platform/meta/webdriver/tests/element_send_keys/user_prompts.py.ini", "toolkit/components/antitracking/test/browser/browser_imageCache.js"], "git_node": null, "git_parents": [null, null], "node": "644e800d1d8aa4bf2a4cc560132fc290539c5bea", "parents": ["8a25fc40764a60d9dd5a72b710955bf45220f94d", "3205543f957cd2a6905486d73aa897535fdd9825"], "tags": []}, {"author": "Gerald Squelart \u003cgsquelart@mozilla.com\u003e", "branch": "default", "desc": "Bug 1479996 - Combine nsTArray::IndexOf and element access into lambda-friendly functions - r=froydnj\n\nIn many places, nsTArray::IndexOf is followed by accessing that element\n(hopefully with `Elements() + index`, which skips unnecessary bounds checks.)\nBut this pattern introduces operations that could be avoided:\n- IndexOf converts the address of the found element into an index,\n- The caller must test for a special `NoIndex` value,\n- On success, accesses convert that index back into the original address.\n\nThis patch introduces new 'ApplyIf...' functions that combine all these\noperations in a more efficient ensemble: If the sought element is found, it is\npassed by reference to a given callable object (usually a lambda); if not\nfound, another callable is invoked.\nDepending on what they need, the first callable may take one of these parameter\nlists: (), (size_t), (maybe-const elem_type&), (size_t, maybe-const elem_type&).\nOn top of removing the pointer-\u003eindex-\u003epointer operations in most cases,\ninvoking callables directly from ApplyIf is safer, as the array is guaranteed to\nbe untouched at this time.\nAlso, being templates taking function objects, in most cases the compiler should\nbe able to inline and optimize the search and its callables' code.\n\nThis patch gives example uses in nsTArray::Contains, and in\nFrameProperties::GetInternal, SetInternal.\nAnd FrameProperties::Has now calls Contains, which is more efficient because\nthe former code would compute an index (or NoIndex), and then convert that index\nto a bool; whereas the new code directly produces a bool from within the search\nalgorithm.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D2758", "files": ["layout/base/FrameProperties.h", "xpcom/ds/nsTArray.h", "xpcom/tests/gtest/TestTArray2.cpp"], "git_node": null, "git_parents": [null], "node": "9fa92a1d961da1538f6af39d9401bc2793deea89", "parents": ["644e800d1d8aa4bf2a4cc560132fc290539c5bea"], "tags": []}, {"author": "Imanol Fernandez \u003cimanol@mozilla.com\u003e", "branch": "default", "desc": "Bug 1483397 - Add media control API so apps can control when media is paused r=snorp,rbarker,jchen\n\nAdd a GeckoSession property too specify if media should be suspended when the session is inactive.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4472", "files": ["mobile/android/chrome/geckoview/GeckoViewContent.js", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSessionSettings.java", "mobile/android/modules/geckoview/GeckoViewContent.jsm"], "git_node": null, "git_parents": [null], "node": "33c06c93406863777cedffacc04e78caab6d1e8d", "parents": ["9fa92a1d961da1538f6af39d9401bc2793deea89"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486901: Part 1 - Allow RunAsLauncherProcess to fall back to environment and command line if the parent process check does not return true; r=mhowell!\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4496", "files": ["browser/app/winlauncher/LauncherProcessWin.cpp"], "git_node": null, "git_parents": [null], "node": "6f6c28eb6041a8d18caf5cead0562c271449b75f", "parents": ["33c06c93406863777cedffacc04e78caab6d1e8d"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486901: Part 2 - Set MOZ_LAUNCHER_PROCESS when the launcher process is enabled by default and restarting via LaunchChild; r=mhowell!\n\nThis patch causes Firefox processes created via LaunchChild to start via the\nlauncher process.\n\nWhile this extra hop through the launcher process takes longer than if we were\nto simply make LaunchChild use the same code as the launcher process itself,\nI do not want to simply export LauncherProcessMain from firefox.exe, as that\nwould be too easy to hook into and mess with.\n\nAnother option would be to host a second copy of the launcher code inside\nxul.dll, but that's less than ideal.\n\nAnyway, until we get that figured out, I don't think it's too big a deal to\nhave this extra hop in place. I don't think anybody has been clamoring for\nfaster restarts from the updater or the profile manager.\n\nDepends on D4496\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4497", "files": ["toolkit/xre/nsAppRunner.cpp"], "git_node": null, "git_parents": [null], "node": "511ad3e51be353f40f5f0a56ac953f39e7beba32", "parents": ["6f6c28eb6041a8d18caf5cead0562c271449b75f"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1486228 - Grab mutex when accessing nsDNSService::mLocalDomains r=mayhemer!\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4452", "files": ["netwerk/dns/nsDNSService2.cpp", "netwerk/dns/nsDNSService2.h"], "git_node": null, "git_parents": [null], "node": "19caa87ed595777c72d563471eb04135712155ff", "parents": ["511ad3e51be353f40f5f0a56ac953f39e7beba32"], "tags": []}, {"author": "Ciure Andrei \u003caciure@mozilla.com\u003e", "branch": "default", "desc": "Backed out 2 changesets (bug 1486931, bug 1486631) for browser_onboarding_accessibility.js failures CLOSED TREE\n\nBacked out changeset 8a25fc40764a (bug 1486931)\nBacked out changeset a89328c87888 (bug 1486631)", "files": ["browser/components/newtab/common/Actions.jsm", "browser/components/newtab/common/Reducers.jsm", "browser/components/newtab/content-src/activity-stream.jsx", "browser/components/newtab/content-src/asrouter/README.md", "browser/components/newtab/content-src/asrouter/asrouter-content.jsx", "browser/components/newtab/content-src/asrouter/schemas/message-format.md", "browser/components/newtab/content-src/asrouter/templates/CFR/templates/ExtensionDoorhanger.schema.json", "browser/components/newtab/content-src/asrouter/templates/OnboardingMessage/OnboardingMessage.jsx", "browser/components/newtab/content-src/components/ASRouterAdmin/ASRouterAdmin.jsx", "browser/components/newtab/content-src/components/Base/Base.jsx", "browser/components/newtab/content-src/components/Sections/Sections.jsx", "browser/components/newtab/content-src/components/StartupOverlay/StartupOverlay.jsx", "browser/components/newtab/content-src/components/TopSites/_TopSites.scss", "browser/components/newtab/content-src/lib/asroutercontent.js", "browser/components/newtab/content-src/lib/snippets.js", "browser/components/newtab/content-src/styles/_variables.scss", "browser/components/newtab/css/activity-stream-linux.css", "browser/componen