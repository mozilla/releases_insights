emes/shared/incontentprefs/preferences.inc.css"], "git_node": null, "git_parents": [null], "node": "6224d9ad89ba1ad5d3f410aa1cd524c12ebeaee0", "parents": ["af6ef2b9fb77564316c2d8dc793681152d489c62"], "tags": []}, {"author": "Mark Striemer \u003cmstriemer@mozilla.com\u003e", "branch": "default", "desc": "Bug 1488467 - Part 2: Match web languages dialog with browser dialog r=jaws a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5039", "files": ["browser/components/preferences/languages.xul", "browser/themes/shared/incontentprefs/preferences.inc.css"], "git_node": null, "git_parents": [null], "node": "221d11dbdbb6b58749f4448ba85fdafb599b786a", "parents": ["6224d9ad89ba1ad5d3f410aa1cd524c12ebeaee0"], "tags": []}, {"author": "Dave Townsend \u003cdtownsend@oxymoronical.com\u003e", "branch": "default", "desc": "Bug 1488881: Re-enable the NUMBER_OF_PROFILES probe. r=chutten a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5070", "files": ["toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "4b77bd43d1a416ff25ea09b6e47fc7ab92ddbeff", "parents": ["221d11dbdbb6b58749f4448ba85fdafb599b786a"], "tags": []}, {"author": "David Major \u003cdmajor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1489096: Use clang 7.0.0rc3 for Windows builds. r=glandium a=pascalc", "files": ["build/build-clang/clang-win64.json", "build/build-clang/r341035.patch"], "git_node": null, "git_parents": [null], "node": "98ecb26cc87fef0efa20fa04ef4edd389c6c5fb4", "parents": ["4b77bd43d1a416ff25ea09b6e47fc7ab92ddbeff"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1489317: Part 1 - Add forward declaration for mscom::AgileReference to RefPtr; r=froydnj a=pascalc\n\nI'd like to add a constructor and operator= to RefPtr for mscom::AgileReference.\nThis patch is simply the forward declarations to allow for that.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5317", "files": ["mfbt/RefPtr.h"], "git_node": null, "git_parents": [null], "node": "8344af6b480d2033894f903a1d644b66350a54c4", "parents": ["98ecb26cc87fef0efa20fa04ef4edd389c6c5fb4"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1489317: Part 2 - Improvements to mscom::AgileReference; r=froydnj a=pascalc\n\nThis patch adds the definitions of the RefPtr constructor and operator=.\nIt also refactors some stuff in AgileReference to make these objects easier\nto use. Since it's just a bunch of C++ goop, I figured that you'd be fine to\nreview this. Let me know if you want to add a reviewer who is more familiar\nwith the COM nuances.\n\nDepends on D5317\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5318", "files": ["ipc/mscom/AgileReference.cpp", "ipc/mscom/AgileReference.h"], "git_node": null, "git_parents": [null], "node": "d9b447bdf5e9dbc923bc6ce6058d655be9229ab9", "parents": ["8344af6b480d2033894f903a1d644b66350a54c4"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1489317: Part 3 - Use an agile reference for JumpListBuilder::mJumpListMgr to ensure smooth transition between apartments; r=mhowell a=pascalc\n\nDepends on D5318\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5321", "files": ["widget/windows/JumpListBuilder.cpp", "widget/windows/JumpListBuilder.h"], "git_node": null, "git_parents": [null], "node": "e7f051b7650ec194642056daf618fb2905b1a4d3", "parents": ["d9b447bdf5e9dbc923bc6ce6058d655be9229ab9"], "tags": []}, {"author": "Aaron Klotz \u003caklotz@mozilla.com\u003e", "branch": "default", "desc": "Bug 1489317: Part 4 - Add asssertion that COM is initialized on the thread that is resolving an agile reference; r=mhowell a=pascalc\n\nDepends on D5321\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5323", "files": ["ipc/mscom/AgileReference.cpp", "ipc/mscom/Utils.cpp", "ipc/mscom/Utils.h"], "git_node": null, "git_parents": [null], "node": "fe879d96c14becf34012260fc4cc91e03454b163", "parents": ["e7f051b7650ec194642056daf618fb2905b1a4d3"], "tags": []}], "date": 1536953749, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "ncsoregi@mozilla.com"}, "9802": {"changesets": [{"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1489402 - Middle-clicking a link from the address bar dropdown may apply the wrong overflow effect on the URL. r=adw a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5444", "files": ["browser/base/content/urlbarBindings.xml"], "git_node": null, "git_parents": [null], "node": "ec22c88433965e42673cbafd110e9d2776530784", "parents": ["fe879d96c14becf34012260fc4cc91e03454b163"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1490012 - FlushPendingMediaFeatureValuesChanged can kill the PresShell. r=xidorn a=pascalc\n\nIt can flush the parent document from MediaQueryList::RecomputeMatches, which\ncan destroy our pres context.\n\nI think that flush is wrong btw, it should probably either flush layout so the\nviewport size is correct, or just not flush (we should make MediaList::Matches\ntake a document now that we don't need a pres context to match media queries,\nbut that requires a bit more refactoring).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5524", "files": ["layout/base/PresShell.cpp", "layout/style/crashtests/1490012.html", "layout/style/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "f09bf04f488cc97081c848a83202e1ce5f6b8955", "parents": ["ec22c88433965e42673cbafd110e9d2776530784"], "tags": []}, {"author": "Dave Townsend \u003cdtownsend@oxymoronical.com\u003e", "branch": "default", "desc": "Bug 1490342: Make NUMBER_OF_PROFILES opt-out. r=Dexter a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5551", "files": ["toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "808461b7530b46d54b0cd667d9fef70f94f90679", "parents": ["f09bf04f488cc97081c848a83202e1ce5f6b8955"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1490729 - Ensure that we send variation=0 for the TP UI on about:privatebrowsing. r=Gijs a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5680", "files": ["browser/components/privatebrowsing/content/aboutPrivateBrowsing.js", "browser/components/privatebrowsing/test/browser/browser_privatebrowsing_about.js"], "git_node": null, "git_parents": [null], "node": "08ffdcf76ece9bd23e2d0363ddb15004292541be", "parents": ["808461b7530b46d54b0cd667d9fef70f94f90679"], "tags": []}, {"author": "Thomas Daede \u003cdaede003@umn.edu\u003e", "branch": "default", "desc": "Bug 1490877: Make codecs=av01* mimetypes work with MSE. r=jya a=pascalc\n\nWhile the MP4 parser correctly handles the av01* codec string, it\nis then converted to a video/av01* mimetype to search for a PDM.\nThe libaom PDM only accepts video/av1, so always produce a video/av1\nMIME type from a codecs=av01 string.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5744", "files": ["dom/media/mp4/MP4Decoder.cpp"], "git_node": null, "git_parents": [null], "node": "6ad54436118a8c5115f60663a5032fa8a2de2d6f", "parents": ["08ffdcf76ece9bd23e2d0363ddb15004292541be"], "tags": []}, {"author": "Dustin J. Mitchell \u003cdustin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1491307: make retrigger-mochitest its own action r=tomprince a=mochitest-retrigger-fix\n\nEven with no options, this is not a simple retrigger -- it adds voluminous\ndebug output.  So let's keep it as a custom action.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5879", "files": ["taskcluster/taskgraph/actions/ret