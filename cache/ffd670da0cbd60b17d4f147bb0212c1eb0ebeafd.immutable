l], "user": "ffxbld"}, "9885": {"changesets": [{"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1492114 - Really ensure that the Third-Party Cookies description doesn't wrap unnecessarily; r=johannh a=pascalc\n\nThe selector should apply to deck elements that do have a selectedIndex\nattribute but it's not 0.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6567\n", "files": ["browser/themes/shared/incontentprefs/privacy.css"], "git_node": null, "git_parents": [null], "node": "ad1ff0504c04941457c9480760585399dfa80d4f", "parents": ["2231ea6517eb7e2b8fd1f47162ffc9ce5d03340e"], "tags": []}], "date": 1537853192, "git_changesets": [null], "user": "eakhgari@mozilla.com"}, "9886": {"changesets": [{"author": "Jonathan Watt \u003cjwatt@jwatt.org\u003e", "branch": "default", "desc": "Bug 1368555. Let -webkit-appearance ride the trains in v63. r=emilio, a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6765", "files": ["modules/libpref/init/StaticPrefList.h"], "git_node": null, "git_parents": [null], "node": "871364095b279eab4d89411cd5798b0b6f28ef1a", "parents": ["ad1ff0504c04941457c9480760585399dfa80d4f"], "tags": []}], "date": 1537881042, "git_changesets": [null], "user": "jwatt@jwatt.org"}, "9887": {"changesets": [{"author": "Felipe Gomes \u003cfelipc@gmail.com\u003e", "branch": "default", "desc": "Bug 1485109 - Force LTR on code snippets in about:policies. r=zbraniecki a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6677", "files": ["browser/components/enterprisepolicies/content/aboutPolicies.css"], "git_node": null, "git_parents": [null], "node": "757f18f89a54fdd34ac22d8edf678fda687c4103", "parents": ["871364095b279eab4d89411cd5798b0b6f28ef1a"], "tags": []}, {"author": "Timothy Guan-tin Chien \u003ctimdream@gmail.com\u003e", "branch": "default", "desc": "Bug 1487143 - Properly dispatch MozAutoplayMediaBlocked event to content, r=alwu a=pascalc\n\nThe MozAutoplayMediaBlocked event should have its target set to the video\nelement, not the document.\n\nAlso, MozNoControlsBlockedVideo event has to initialized from the CustomEvent\nconstructor of the right window for the XBL binding to access it. I don't know\nwhen it stopped working.\n\nTest is added to ensure the entire UI won't break.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5801", "files": ["dom/html/HTMLMediaElement.cpp", "mobile/android/chrome/content/CastingApps.js", "mobile/android/tests/browser/chrome/media_playback.html", "mobile/android/tests/browser/chrome/test_mozAutoplayMediaBlocked.html"], "git_node": null, "git_parents": [null], "node": "34cfa5617f98a5bdd84ba2a9765fded743c4ac96", "parents": ["757f18f89a54fdd34ac22d8edf678fda687c4103"], "tags": []}, {"author": "Luke Schwalfenberg \u003clschwalfenberg@gmail.com\u003e", "branch": "default", "desc": "Bug 1488241 - Error link from about:support leads to about:policies#active instead of about:policies#errors. r=felipe a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6538", "files": ["toolkit/content/aboutSupport.js"], "git_node": null, "git_parents": [null], "node": "e71d111100026b11b611f304e3cad75dff77a303", "parents": ["34cfa5617f98a5bdd84ba2a9765fded743c4ac96"], "tags": []}, {"author": "Andrew Johnson \u003cajohnson@draster.com\u003e", "branch": "default", "desc": "Bug 1489757 - Bug 1448863 causes video streams to take a very long time to recover from packet loss; r=bwc a=pascalc\n\nThis patch sets mDecoderStatus from the GMPThread so we can eventually report\nan error back to the caller. Since this done during an asynchronous call, there\nis no guarantee that the error will be associated with the correct frame, but\nthis workaround should eventually cause an error to be signalled, so that a\nPLI can be requested and video will not freeze.", "files": ["media/webrtc/signaling/src/media-conduit/WebrtcGmpVideoCodec.cpp", "media/webrtc/signaling/src/media-conduit/WebrtcGmpVideoCodec.h"], "git_node": null, "git_parents": [null], "node": "fc45a1a514bd2c338150d537df8b6f092a8074cb", "parents": ["e71d111100026b11b611f304e3cad75dff77a303"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1490848 - Constraint failed errors when trying to download urls not present in history. r=Standard8 a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6666", "files": ["toolkit/components/places/History.jsm", "toolkit/components/places/tests/history/test_update.js"], "git_node": null, "git_parents": [null], "node": "db44e1bed0c6905c11ef424250d3d0450cd97b81", "parents": ["fc45a1a514bd2c338150d537df8b6f092a8074cb"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1492233 - Add telemetry for search from webextension. r=mikedeboer a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6262", "files": ["browser/components/extensions/parent/ext-search.js", "browser/modules/BrowserUsageTelemetry.jsm", "toolkit/components/telemetry/Events.yaml", "toolkit/components/telemetry/Scalars.yaml"], "git_node": null, "git_parents": [null], "node": "75c5cc385dc7af3fb7b19b0913f58ff35aac4bf9", "parents": ["db44e1bed0c6905c11ef424250d3d0450cd97b81"], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1493590 - Fix crash in GPUVideoImage::GetData. r=mattwoodrow a=pascalc\n\nThe texture client bound in a GPUVideoImage can be destroyed underneath\nit if the GPU process crashed and was restarted. This is because the\nImageBridgeChild singleton will destroy any textures bound to it before\nreinitializing itself. If there is a race to access a now stale\nGPUVideoImage object, we could accidently dereference the underlying\nTextureData which is now null in the TextureClient which was kept alive\nin the GPUVideoImage object. Now we check to make sure the TextureData\nis still there before accessing.", "files": ["gfx/layers/GPUVideoImage.h"], "git_node": null, "git_parents": [null], "node": "0ceb821ece0d820bddbfe9c9b551634c5a81b529", "parents": ["75c5cc385dc7af3fb7b19b0913f58ff35aac4bf9"], "tags": []}, {"author": "Julien Wajsberg \u003cfelash@gmail.com\u003e", "branch": "default", "desc": "Bug 1493680 - use the new getFront API and properly wait for the promise fullfilment r=gregtatum a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6671", "files": ["devtools/client/performance-new/panel.js"], "git_node": null, "git_parents": [null], "node": "9841fa1b5f14754998800b7d34b3b621aa829913", "parents": ["0ceb821ece0d820bddbfe9c9b551634c5a81b529"], "tags": []}], "date": 1537891746, "git_changesets": [null, null, null, null, null, null, null, null], "user": "dluca@mozilla.com"}, "9888": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 946cccc1bb45ab0f7c271b550ed5dc43cbf392f9 with DEVEDITION_63_0b9_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "55a0f1dc9c1e94e4bd25f8139e66e2afb47e263d", "parents": ["9841fa1b5f14754998800b7d34b3b621aa829913"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "0c772a11006f377d07274db17ce44362212085fe", "parents": ["55a0f1dc9c1e94e4bd25f8139e66e2afb47e263d"], "tags": []}], "date": 1537894661, "git_changesets": [null, null], "user": "ffxbld"}, "9889": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 946cccc1bb45ab0f7c271b550ed5dc43cbf392f9 with FENNEC_63_0b9_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "13007085e954b018f5085dacf16aa066a951f79e", "parents": ["0c772a11006f377d07274db17ce44362212085fe"], "tags": []}], "date": 1537894864, "git_changesets": [null], "user": "ffxbld"}, "9890": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 946cccc1bb45ab0f7c271b550ed5dc43cbf392f9 with FIREFOX_63_0b9_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "9029e856e7b0b1a32317b5bd4b8ec9b9407a6ec5", "parents": ["13007085e954b018f5085dacf16aa066a951f79e"], "tags": []}], "date": 1537895048, "git_changesets": [null], "user": "ffxbld"}, "9891": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1493710 - Don't apply containing shadow-host rules to NAC. r=mats a=pascalc\nThis is a regression from bug 1487856.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6700", "files": ["layout/reftests/forms/input/text/reftest.list", "layout/reftests/forms/input/text/shadow-rules-ref.html", "layout/reftests/forms/input/text/shadow-rules.html", "servo/components/style/stylist.rs"], "git_node": null, "git_parents": [null], "node": "7a888f0923ee678ba61f3ffbe5fce672ed0c1322", "parents": ["9029e856e7b0b1a32317b5bd4b8ec9b9407a6ec5"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao+bmo\u003e", "branch": "default", "desc": "Bug 1490937 - \"Tab titles for selected tabs in modal dialogs have too little contrast\" a=pascalc", "files": ["toolkit/themes/osx/global/in-content/common.css", "toolkit/themes/shared/in-content/common.inc.css"], "git_node": null, "git_parents": [null], "node": "b94d1d0eaf9e5b062ee94b62e0456d06aedbd842", "parents": ["7a888f0923ee678ba61f3ffbe5fce672ed0c1322"], "tags": []}], "date": 1537907083, "git_changesets": [null, null], "user": "apavel@mozilla.com"}, "9892": {"changesets": [{"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1481439 - Fix intermittent browser_ext_omnibox.js. r=aswan, a=test-only\n\nThe \"startInputSession\" test helper triggers the autocompletion logic to\nkick off the test. In all cases except for \"testSuggestions\", the search\nsuggestions are set synchronously. Consequently, the\n\"waitForAutocompleteResultAt\" call at the end of starting the input\nsession would find the expected suggestion item at the given index.\n\nHowever, in the case of \"testSuggestions\", the results are generated\nasynchronously. There is no guarantee that the results are set. The test\nhas only been passing so far because the result items from the previous\ntest are still cached, and cleared after a 100ms delay by:\nhttps://searchfox.org/mozilla-central/rev/a41fd8cb947266ea2e3f463fc6e31c88bfab9d41/toolkit/components/places/UnifiedComplete.js#1728\nOn slow test runs, the test fails intermittently when the clean-up logic\nruns before the test checked the suggestion item.\n\nThis patch fixes the issue by splitting \"startInputSession\", and only\nuse \"waitForAutocompleteResultAt\" after having sent the suggestions.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5170", "files": ["browser/components/extensions/test/browser/browser_ext_omnibox.js"], "git_node": null, "git_parents": [null], "node": "020d3140a05545cfe88da2edabe4831c69ce9db0", "parents": ["b94d1d0eaf9e5b062ee94b62e0456d06aedbd842"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1443137 - Attempt to fix intermittent in browser_search_notification.js by relying on a different method for opening the tab and waiting for completion before we start a search. r=adw, a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6620", "files": ["docshell/test/browser/browser_search_notification.js"], "git_node": null, "git_parents": [null], "node": "2989c70614b5459beafdab022c56c25878cfbdb7", "parents": ["020d3140a05545cfe88da2edabe4831c69ce9db0"], "tags": []}, {"author": "Tom Prince \u003cmozilla@hocat.ca\u003e", "branch": "default", "desc": "Bug 1486224: [fetch-content] Retry downloads when fetching content; r=gps, a=release\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6686", "files": ["taskcluster/scripts/misc/fetch-content"], "git_node": null, "git_parents": [null], "node": "a0131a884984956c257876ba26c0a56d7fb10ef1", "parents": ["2989c70614b5459beafdab022c56c25878cfbdb7"], "tags": []}, {"author": "Brad Werth \u003cbwerth@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418470 - Part 1: Provide a specialized parse_method for mask-image to use CORS. r=emilio, a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5714", "files": ["servo/components/style/properties/longhands/svg.mako.rs", "servo/components/style/values/specified/image.rs"], "git_node": null, "git_parents": [null], "node": "6c86260752486daaebbefde95f1bbfe7494aed58", "parents": ["a0131a884984956c257876ba26c0a56d7fb10ef1"], "tags": []}, {"author": "Brad Werth \u003cbwerth@mozilla.com\u003e", "branch": "default", "desc": "Bug 1418470 - Part 2: Add a test confirming that mask-image is blocked cross-origin. r=emilio, a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5910", "files": ["layout/style/test/mochitest.ini", "layout/style/test/support/blue-100x100.png", "layout/style/test/test_mask_image_CORS.html"], "git_node": null, "git_parents": [null], "node": "49d0176204ccc7e0b175b70adfc46a4fc1a01df5", "parents": ["6c86260752486daaebbefde95f1bbfe7494aed58"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1464938 - Add extension lifecycle state information to shutdown blocker for better diagnostics. r=aswan, a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6419", "files": ["toolkit/components/e