s": ["browser/components/nsBrowserGlue.js", "browser/modules/ContentClick.jsm"], "git_node": null, "git_parents": [null], "node": "c271ac97a512247c2b57dbb6ce22d76a305ae7e6", "parents": ["666f2f54111f35a04c6e23372f48555461a05d7a"], "tags": []}, {"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1485830 - Set custom odd tree row colors in common.css on all platforms. r=dao a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5963", "files": ["browser/base/content/test/static/browser_parsable_css.js", "toolkit/themes/linux/global/in-content/common.css", "toolkit/themes/shared/in-content/common.inc.css", "toolkit/themes/windows/global/in-content/common.css"], "git_node": null, "git_parents": [null], "node": "9199694d017c71a4e687f195ba0bfa307770d282", "parents": ["c271ac97a512247c2b57dbb6ce22d76a305ae7e6"], "tags": []}, {"author": "Tim Nguyen \u003cntim.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1487397 - Add hover styling on trees on Windows default theme. r=dao a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5796", "files": ["toolkit/themes/shared/tree.inc.css"], "git_node": null, "git_parents": [null], "node": "10bb8728016ad3426515ecd14a6be4c9c0e3d50b", "parents": ["9199694d017c71a4e687f195ba0bfa307770d282"], "tags": []}], "date": 1537364663, "git_changesets": [null, null, null, null], "user": "nbeleuzu@mozilla.com"}, "9837": {"changesets": [{"author": "philipp \u003cmadperson@gmx.at\u003e", "branch": "default", "desc": "Bug 1465787 - Add old versions of nviewh64.dll to the dll blocklist. r=marco a=pascalc", "files": ["mozglue/build/WindowsDllBlocklistDefs.h"], "git_node": null, "git_parents": [null], "node": "9e7e697907a4e41aea587335d66cee37f4b1dfea", "parents": ["10bb8728016ad3426515ecd14a6be4c9c0e3d50b"], "tags": []}, {"author": "Jason Orendorff \u003cjorendorff@mozilla.com\u003e", "branch": "default", "desc": "Bug 1488163 - Fix an compartment assertion that failed while evaluating another assertion. r=jimb a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5303", "files": ["js/src/jit-test/tests/debug/bug1488163.js", "js/src/vm/Debugger.cpp", "js/src/vm/GeneratorObject.cpp"], "git_node": null, "git_parents": [null], "node": "71b13044d9c4b60e7daac28bd7b9a2dd20cc14a5", "parents": ["9e7e697907a4e41aea587335d66cee37f4b1dfea"], "tags": []}], "date": 1537371230, "git_changesets": [null, null], "user": "nbeleuzu@mozilla.com"}, "9838": {"changesets": [{"author": "Liang-Heng Chen \u003cxeonchen@gmail.com\u003e", "branch": "default", "desc": "Bug 1477046 - Part 1: Add basic FastBlock automation tests. r=mayhemer a=test-only\n\nBasic parts of FastBlock tests, no iframe/xhr tests in this patch.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4655", "files": ["netwerk/protocol/http/nsHttpChannel.cpp", "toolkit/components/url-classifier/tests/mochitest/chrome.ini", "toolkit/components/url-classifier/tests/mochitest/fastblock.html", "toolkit/components/url-classifier/tests/mochitest/test_fastblock_bug1477046.html"], "git_node": null, "git_parents": [null], "node": "bcc215e21646e7452c579dee5b11086f68dadbdf", "parents": ["71b13044d9c4b60e7daac28bd7b9a2dd20cc14a5"], "tags": []}, {"author": "Liang-Heng Chen \u003cxeonchen@gmail.com\u003e", "branch": "default", "desc": "Bug 1477046 - Part 2: Add FastBlock iframe tests. r=mayhemer a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4770", "files": ["toolkit/components/url-classifier/tests/mochitest/chrome.ini", "toolkit/components/url-classifier/tests/mochitest/fastblock.html", "toolkit/components/url-classifier/tests/mochitest/fastblock_iframe.html", "toolkit/components/url-classifier/tests/mochitest/test_fastblock_bug1477046.html"], "git_node": null, "git_parents": [null], "node": "73a1d6086193470df4b3015fab66972aa1d32f05", "parents": ["bcc215e21646e7452c579dee5b11086f68dadbdf"], "tags": []}, {"author": "Liang-Heng Chen \u003cxeonchen@gmail.com\u003e", "branch": "default", "desc": "Bug 1477046 - Part 3: Add FastBlock redirect tests. r=mayhemer a=test-only\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5806", "files": ["toolkit/components/url-classifier/tests/mochitest/chrome.ini", "toolkit/components/url-classifier/tests/mochitest/fastblock.html", "toolkit/components/url-classifier/tests/mochitest/redirect_tracker.sjs", "toolkit/components/url-classifier/tests/mochitest/test_fastblock_bug1477046.html"], "git_node": null, "git_parents": [null], "node": "6dea608bdf6b262cad68f588037d99c4d3f25972", "parents": ["73a1d6086193470df4b3015fab66972aa1d32f05"], "tags": []}, {"author": "Vlad Baicu \u003cvlad.baicu@softvision.ro\u003e", "branch": "default", "desc": "Bug 1483993 - Check if profileDir is null before accessing it. r=jchen a=pascalc\n\nIn some scenarios profileDir is null which can cause a crash. Added a Nullable\nannotation to warn of this possibility and a null check to prevent the exception\nfrom happening.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5878", "files": ["mobile/android/base/java/org/mozilla/gecko/CrashReporterActivity.java"], "git_node": null, "git_parents": [null], "node": "004c2d9111693f0471d258cfb1675a100af8b4ca", "parents": ["6dea608bdf6b262cad68f588037d99c4d3f25972"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1491032 - Make TISInputSourceWrapper::WillDispatchKeyboardEvent() decide charCode value with keypress event index. r=m_kato a=pascalc\n\nIf a key inputs multiple characters, we dispatch same number eKeyPress\nevents to input each character.  However,\nTISInputSourceWrapper::WillDispatchKeyboardEvent() always sets\ncharCode of all eKeyPress events to first character of inserting.\nInstead, it should set charCode value to nth character of the\ninserting string.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5884", "files": ["widget/cocoa/TextInputHandler.h", "widget/cocoa/TextInputHandler.mm"], "git_node": null, "git_parents": [null], "node": "2b253a5c982161848b159c3f048d0225229ab46d", "parents": ["004c2d9111693f0471d258cfb1675a100af8b4ca"], "tags": []}], "date": 1537373400, "git_changesets": [null, null, null, null, null], "user": "nbeleuzu@mozilla.com"}, "9839": {"changesets": [{"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1475325 - 2. Add tests for hiding selection action in different cases; r=jchen a=ritu\n\nAdd some tests for hiding selection action during navigation, blurring,\nor clearing delegate.", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/SelectionActionDelegateTest.kt"], "git_node": null, "git_parents": [null], "node": "f6a4fa55f7245e3860503595c74d5b24e7ff0642", "parents": ["2b253a5c982161848b159c3f048d0225229ab46d"], "tags": []}], "date": 1537415763, "git_changesets": [null], "user": "btara@mozilla.com"}, "9840": {"changesets": [{"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset f6a4fa55f724 (bug 1475325) for failures in org.mozilla.geckoview.test.SelectionActionDelegateTest.clear. a=backout", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/SelectionActionDelegateTest.kt"], "git_node": null, "git_parents": [null], "node": "82ac63880ff38d905df3693ae0c3f604ed5d3307", "parents": ["f6a4fa55f7245e3860503595c74d5b24e7ff0642"], "tags": []}], "date": 1537427365, "git_changesets": [null], "user": "dluca@mozilla.com"}, "9841": {"changesets": [{"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442176 - 1. Remove current pin-on-caret-drag code; r=snorp a=pascalc\n\nRemove the current code that pins the toolbar on caret drag, which only\nworks for Fennec.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5189", "files": ["layout/base/AccessibleCaretManager.cpp", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/gfx/LayerSession.java", "widget/android/nsWindow.cpp", "widget/android/nsWindow.h"], "git_node": null, "git_parents": [null], "node": "9cfdcb17b563175083a852d7b91dbf3b02b473ed", "parents": ["82ac63880ff38d905df3693ae0c3f604ed5d3307"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1449567 - Don't reattach compositor for the same compositor object; r=snorp a=pascalc\n\nIf we're trying to detach and reattach the same compositor object for\nwhatever reason, we should skip it so we don't inadvertently end up not\nattaching the object at all.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5608", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/gfx/LayerSession.java", "widget/android/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "7ffbd3e49f6291c566021cecd2a6495b81204099", "parents": ["9cfdcb17b563175083a852d7b91dbf3b02b473ed"], "tags": []}, {"author": "Andrei Lazar \u003candrei.a.lazar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1480852 Crash in android.os.TransactionTooLargeException: data parcel size 1053364 bytes at android.os.BinderProxy.transactNative(Native Method) r=jchen a=pascalc\n\nAdded an extra check of bundle size due to some unexpected transactions sizes that exceed the limit.\nThe bundle gets lighter if the size exceeds the limit by removing the views' state as a last resort.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5682", "files": ["mobile/android/base/java/org/mozilla/gecko/BrowserApp.java", "mobile/android/base/java/org/mozilla/gecko/util/JavaUtil.java"], "git_node": null, "git_parents": [null], "node": "693ca8179b33dadb580cb466c7b10be43c632fe6", "parents": ["7ffbd3e49f6291c566021cecd2a6495b81204099"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1484783 - Ensure to read the default stride when hardware acceleration isn't usable. r=mattwoodrow a=pascalc\n\nOn some platforms where a hardware decoder is present, but non functioning, we would fail to initialize the video stride, leading to the frames being incorrectly displayed later.\n\nAlso delete the DXVA2 manager early under those circumstances\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5402", "files": ["dom/media/platforms/wmf/WMFVideoMFTManager.cpp"], "git_node": null, "git_parents": [null], "node": "a7212d69843185584cdb723048268d7afe2cdfb9", "parents": ["693ca8179b33dadb580cb466c7b10be43c632fe6"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1485307 - Focus urlbar when extension opens new tab r=rpl a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6029", "files": ["browser/components/extensions/parent/ext-tabs.js", "browser/components/extensions/test/browser/browser_ext_tabs_create_url.js"], "git_node": null, "git_parents": [null], "node": "17ab3c3b12562b85a7d9de98b7bcdd788e6b8236", "parents": ["a7212d69843185584cdb723048268d7afe2cdfb9"], "tags": []}, {"author": "Michael Cooper \u003cmcooper@mozilla.com\u003e", "branch": "default", "desc": "Bug 1488923 - When notifying listeners that a study is ending, include the reason why the study is ending r=aswan a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6196", "files": ["toolkit/components/normandy/lib/AddonStudies.jsm", "toolkit/components/normandy/test/unit/test_addon_unenroll.js"], "git_node": null, "git_parents": [null], "node": "93d45f9ae4c694e7950a02406d6ea9c511700109", "parents": ["17ab3c3b12562b85a7d9de98b7bcdd788e6b8236"], "tags": []}, {"author": "Lee Salzman \u003clsalzman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1489632 - mark Skia bitmap layer as immutable before popping it. r=rhunt a=pascalc", "files": ["gfx/skia/skia/src/core/SkBitmapDevice.h", "gfx/skia/skia/src/core/SkCanvas.cpp", "gfx/skia/skia/src/core/SkDevice.h"], "git_node": null, "git_parents": [null], "node": "f197ee75ff38460143b3d649154b830674b44886", "parents": ["93d45f9ae4c694e7950a02406d6ea9c511700109"], "tags": []}, {"author": "L. David Baron \u003cdbaron@dbaron.org\u003e", "branch": "default", "desc": "Bug 1491159 - More complete handling of TZ environment variable when initializing ICU timezone.  r=anba a=pascalc\n\nThis improves on the changes in bug 1484829 by handling the absolute\nfilename form of TZ environment variables both with and without an\ninitial ':' character, and by improving comments about relative and\nabsolute paths.  (Note that relative paths without the ':' are just\nOlson time zone names.)\n\nNote that the only test that failed without the patch was:\n  setTimeZone(\"/usr/share/zoneinfo/America/Chicago\");\n  assertEq(timeZoneName(), \"Central Daylight Time\");\nand it reported\n  Error: Assertion failed: got \"GMT-06:00\", expected \"Central Daylight Time\"\nwhich seems to be a sign that ICU gets some information out of that time\nzone identifier (i.e., it reported the correct standard-time GMT\noffset), but not everything.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5827", "files": ["js/src/tests/non262/Date/time-zone-path.js", "js/src/vm/DateTime.cpp"], "git_node": null, "git_parents": [null], "node": "918738f6956f03c706b2da4b4ab92a86eb468214", "parents": ["f197ee75ff38460143b3d649154b830674b44886"], "tags": []}, {"author": "Adam Gashlin \u003cagashlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1491999: Quote command line for multiple components. r=mhowell a=pascalc\n\nThe macro expansion of ExecAndWaitForInputIdle consumes the quotes\naround the macro argument. The argument has an extra layer of quotes\naround the executable name, which keeps it together even if it has\nspaces, but we need yet another layer around the whole command line or\nelse each component of the command line appears as another argument to\nStrCpy.\n\nStandard practice is to quote args in the macro definition, I overlooked\nthis in the initial implementation.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6111", "files": ["toolkit/mozapps/installer/windows/nsis/common.nsh"], "git_node": null, "git_parents": [null], "node": "57df5aaadcbcfe231cbf873261cb115689134256", "parents": ["918738f6956f03c706b2da4b4ab92a86eb468214"], "tags": []}, {"author": "Jean-Yves Avenard \u003cjyavenard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1492365 - Prevent arithmetic overflow. r=gerald a=pascalc\n\nShould mStreamLength be \u003e 2^32, we could have overflowed leading to false positive test.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6235", "files": ["dom/media/MediaCache.cpp"], "git_node": null, "git_parents": [null], "node": "d7d69ea0353c09bd3b3997f680e3226da02df0d3", "parents": ["57df5aaadcbcfe231cbf873261cb115689134256"], "tags": []}, {"author": "Julian Descottes \u003cjdescottes@mozilla.com\u003e", "branch": "default", "desc": "Bug 1492516 - Delete badge properties when removing badge element from the DOM;r=gl a=pascalc", "files": ["devtools/client/inspector/markup/test/browser_markup_display_node_02.js", "devtools/client/inspector/markup/views/element-editor.js"], "git_node": null, "git_parents": [null], "node": "40f14023347f155e84608b7759f38fe5f815704a", "parents": ["d7d69ea0353c09bd3b3997f680e3226da02df0d3"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1491975 - [wdspec] Fix pytest marker for skipif. r=ato a=test-only", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/webdriver/tests/new_session/platform_name.py"], "git_node": null, "git_parents": [null], "node": "0aac7a06ae89b9dd678eb4f1eb8a01339cd348c3", "parents": ["40f14023347f155e84608b7759f38fe5f815704a"], "tags": []}], "date": 1537431960, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null], "user": "ccoroiu@mozilla.com"}, "9842": {"changesets": [{"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1478212 - Propagate MediaFeatureChangeReason::SystemMetricsChange into sub frames. r=emilio a=pascalc\n\nA test case covers this will be introduced in bug 1486971.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4998", "files": ["layout/base/nsPresContext.cpp"], "git_node": null, "git_parents": [null], "node": "20990ad02e181fe3b9cf8475aea19f817e153528", "parents": ["0aac7a06ae89b9dd678eb4f1eb8a01339cd348c3"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486971 - Receive accessibilityDisplayShouldReduceMotion change and notify it. r=mstange a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5002", "files": ["widget/cocoa/nsChildView.mm"], "git_node": null, "git_parents": [null], "node": "8d26699d84cfd47c0e4d80c84bbbedcbef2be87c", "parents": ["20990ad02e181fe3b9cf8475aea19f817e153528"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486971 - Query NSWorkspace.accessibilityDisplayShouldReduceMotion only if it's on parent processes or it's the initial query on child processes. r=mstange a=pascalc\n\nIn child processes on MacOSX we don't spin native event loop at all.\nWithout native event loops NSWorkspace.accessibilityDisplayShouldReduceMotion\ndoesn't return up-to-date value when the system setting changed for some reasons.\nTo workaround this we use NSWorkspace.accessibilityDisplayShouldReduceMotion\nonly on the parent process which spins native event loop or when it's the\ninitial query on the child process.  And we give the up-to-date value to the\nchild process via an IPC call just like other cached values do.\n\nDepends on D5002\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5003", "files": ["widget/cocoa/nsLookAndFeel.h", "widget/cocoa/nsLookAndFeel.mm"], "git_node": null, "git_parents": [null], "node": "78dc157290d3408f7b7edc2a26918be00cc7712e", "parents": ["8d26699d84cfd47c0e4d80c84bbbedcbef2be87c"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486971 - Test for dynamically change of the prefers-reduced-motion setting on MacOSX. r=froydnj,mstange a=pascalc\n\nThe framework to simulate the setting change works as following;\n\n - nsIDOMWindowUtils.setPrefersReducedMotion() calls an IPC function which ends\n   up calling nsChildView::SetPrefersReducedMotion() in the parent process\n\n - nsChildView::SetPrefersReducedMotion() sets the given value into\n   nsLookAndFeel::mPrefersReducedMotionCached just like we set the value queried\n   via NSWorkspace.accessibilityDisplayShouldReduceMotion in the parent process\n   and send a notification which is the same notification MacOSX sends when the\n   system setting changed\n\n - Normally the cached value is cleared before quering new values since the\n   cache value is stale, but in this case the value is up-to-date one, so\n   nsChildView::SetPrefersReducedMotion() tells that we don't need to clear the\n   cache, and nsIDOMWindowUtils.resetPrefersReducedMotion() resets that state\n   of 'we don't need to clear the cache'\n\nThere are two test cases with the framework in this commit, one is just setting\nthe value and checking the value queried by window.matchMedia.  The other one is\nreceiving 'change' event and checking the value of the event target.\n\nNote that to make this test works the patch for bug 1478212 is necessary since\nthe test runs in an iframe.\n\nDepends on D5003\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5004", "files": ["dom/base/nsDOMWindowUtils.cpp", "dom/interfaces/base/nsIDOMWindowUtils.idl", "dom/ipc/PBrowser.ipdl", "dom/ipc/TabParent.cpp", "dom/ipc/TabParent.h", "ipc/ipdl/sync-messages.ini", "layout/style/test/mochitest.ini", "layout/style/test/test_mq_prefers_reduced_motion_dynamic.html", "widget/LookAndFeel.h", "widget/PuppetWidget.cpp", "widget/PuppetWidget.h", "widget/cocoa/nsChildView.h", "widget/cocoa/nsChildView.mm", "widget/cocoa/nsLookAndFeel.mm", "widget/nsIWidget.h", "widget/nsXPLookAndFeel.cpp", "widget/nsXPLookAndFeel.h"], "git_node": null, "git_parents": [null], "node": "b84a0e018ea893cef8c43fdcf8577870bc1e5bcd", "parents": ["78dc157290d3408f7b7edc2a26918be00cc7712e"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1489581 - Improve vertical centering inside the content blocking \"disabled\" label. r=paolo a=pascalc\n\nLabels in the identity popup that are potentially multiline get dynamic heights set\nas part of the descriptionHeightWorkaround. This causes some cross-platform glitches\nin vertically centering the icon and the label of the disabled indicator.\n\nThe disabled label doesn't really need to be multiline, so we avoid doing that. This\nalso means that we need to make some changes to handle long \"Disabled\" labels a little\nmore gracefully, but looking at existing translations of the word \"Disabled\" we won't\nrun into trouble: https://transvision.mozfr.org/string/?entity=browser/chrome/browser/browser.dtd:contentBlocking.disabled.label&repo=gecko_strings\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6041", "files": ["browser/components/controlcenter/content/panel.inc.xul", "browser/themes/shared/controlcenter/panel.inc.css"], "git_node": null, "git_parents": [null], "node": "84cbec4095126015b1a6fc9b8ab3a7c695953451", "parents": ["b84a0e018ea893cef8c43fdcf8577870bc1e5bcd"], "tags": []}, {"author": "Hiroyuki Ikezoe \u003chikezoe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1491580 - Use NSWorkspaceAccessibilityDisplayOptionsDidChangeNotification only for MacOSX 10.10 or later versions. r=mstange a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5968", "files": ["widget/cocoa/nsChildView.mm"], "git_node": null, "git_parents": [null], "node": "9449c1f37ca7855e487e3d3178fb3a534aca7835", "parents": ["84cbec4095126015b1a6fc9b8ab3a7c695953451"], "tags": []}, {"author": "Lina Cambridge \u003clina@yakshaving.ninja\u003e", "branch": "default", "desc": "Bug 1492010 - Ensure Sync engines with overridden telemetry names correctly report their validation results. r=tcsc a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6097", "files": ["services/sync/modules/telemetry.js", "services/sync/tests/unit/head_helpers.js", "services/sync/tests/unit/test_telemetry.js"], "git_node": null, "git_parents": [null], "node": "f139ab75d0c9a1d5033232f52dab2c73b5f24cd4", "parents": ["9449c1f37ca7855e487e3d3178fb3a534aca7835"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1492459: Always check langpacks for modification at startup. r=aswan a=jcristau\n\nFor most extension types, a missing or changed XPI file is not a serious\nissue, since a failure to start it does not cause any real problems, and can\nbe rectified after startup. For language packs, though, we need to eagerly\nregister the resources that they provide, and if those resources are missing,\nthe browser becomes unusable.\n\nThis patch changes the startup modification checks to always include language\npacks, even in profile directories. This will be a slight performance hit, but\nlanguage pack usage is low enough that it shouldn't affect most users.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6289", "files": ["toolkit/mozapps/extensions/AddonManagerStartup.cpp", "toolkit/mozapps/extensions/internal/XPIDatabase.jsm", "toolkit/mozapps/extensions/internal/XPIProvider.jsm", "toolkit/mozapps/extensions/test/xpcshell/test_webextension_langpack.js", "toolkit/mozapps/extensions/test/xpcshell/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "a53244dbea631c9d08c97aeb687460210baff126", "parents": ["f139ab75d0c9a1d5033232f52dab2c73b5f24cd4"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1492567 - Back out bug 1481866. r=dbaron a=pascalc\n\nSummary:\nThe behavior the WG proposed is way more subtle than what that bug implements,\nincluding:\n\n * Implementing two logical overflow longhands.\n * Expanding the overflow shorthand to different longhands depending on the\n   syntax of that.\n\nMeanwhile, Blink hasn't done the swap and will ship the same behavior that we\nshipped in Firefox 61 (bug 1453148), that is, overflow-x, then overflow-y.\n\nSo I think lacking a clear way forward we should revert this change and preserve\nour shipped behavior.\n\nReviewers: dbaron!\n\nTags: #secure-revision\n\nBug #: 1492567\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6317", "files": ["devtools/shared/css/generated/properties-db.js", "gfx/tests/crashtests/1325159-1.html", "layout/base/tests/preserve3d_sorting_hit_testing2_iframe.html", "layout/forms/crashtests/367587-1.html", "layout/mathml/crashtests/355986-1.xhtml", "layout/style/nsComputedDOMStyle.cpp", "layout/style/test/test_bug319381.html", "servo/components/style/properties/shorthands/box.mako.rs", "testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/css/css-overflow/overflow-shorthand-001.html", "testing/web-platform/tests/css/cssom/overflow-serialization.html", "testing/web-platform/tests/css/cssom/shorthand-values.html"], "git_node": null, "git_parents": [null], "node": "862f7fc8be9db739acc0c48b8b49f63ff4213079", "parents": ["a53244dbea631c9d08c97aeb687460210baff126"], "tags": []}, {"author": "Dorel Luca \u003cdluca@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP blocklist remote-settings - r=RyanVM  a=repo-update", "files": ["browser/app/blocklist.xml", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/blocklists/addons.json"], "git_node": null, "git_parents": [null], "node": "6f98c616ab30175f3129a6132d41e51cdc4bc796", "parents": ["862f7fc8be9db739acc0c48b8b49f63ff4213079"], "tags": []}], "date": 1537449136, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "dluca@mozilla.com"}, "9843": {"changesets": [{"author": "Mike Conley \u003cmconley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1482402 - Dispatch DevTools toolbox visibilitychange event on the iframe document instead of the iframe window. r=gl a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5456", "files": ["devtools/client/framework/toolbox.js", "devtools/client/shared/components/VisibilityHandler.js"], "git_node": null, "git_parents": [null], "node": "3ac8f0aae9c211cd678c3cd4897b619f0bd65b41", "parents": ["6f98c616ab30175f3129a6132d41e51cdc4bc796"], "tags": []}, {"author": "Dragos Crisan  \u003cdcrisan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1474570 - migrate talos linux tasks from worker type gecko-t-linux-talos to gecko-t-linux-talos-tw,r=pmoore a=test-only", "files": ["taskcluster/ci/source-test/jsshell.yml", "taskcluster/taskgraph/transforms/tests.py", "taskcluster/taskgraph/util/workertypes.py"], "git_node": null, "git_parents": [null], "node": "a1aa1b904b4ef870390ee08264953f58279f0e2d", "parents": ["3ac8f0aae9c211cd678c3cd4897b619f0bd65b41"], "tags": ["DEVEDITION_63_0b8_BUILD1", "DEVEDITION_63_0b8_RELEASE", "FIREFOX_63_0b8_BUILD1", "FIREFOX_63_0b8_RELEASE"]}], "date": 1537451684, "git_changesets": [null, null], "user": "archaeopteryx@coole-files.de"}, "9844": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging a1aa1b904b4ef870390ee08264953f58279f0e2d with DEVEDITION_63_0b8_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "9fd48e9bc7e8cb446d3f1d5857c3bd3ebdea867f", "parents": ["a1aa1b904b4ef870390ee08264953f58279f0e2d"], "tags": []}], "date": 1537462979, "git_changesets": [null], "user": "ffxbld"}, "9845": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging a1aa1b904b4ef870390ee08264953f58279f0e2d with FIREFOX_63_0b8_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "5f6eda63b4a1769165e61b8f989a7cfd20f99f9c", "parents": ["9fd48e9bc7e8cb446d3f1d5857c3bd3ebdea867f"], "tags": []}], "date": 1537463240, "git_changesets": [null], "user": "ffxbld"}, "9846": {"changesets": [{"author": "Justin Wood \u003cCallek@gmail.com\u003e", "branch": "default", "desc": "Bug 1486970 - Create revision and pushlog-id index routes for cron decision tasks. r=dustin,aki a=ritu\n\nThis hardcodes the push info in .taskgraph.yml for cron so that we don't break Chain Of Trust (signing)\non other branches (uplifts) when we adjust scriptworker to start passing in this data to json-e.\n\nThis allows us to incrementally roll this out without needing a flag day, and will be needed on all production branches.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4501", "files": [".taskcluster.yml"], "git_node": null, "git_parents": [null], "node": "5bd0f4d6fed870fbe5697035707770522be60327", "parents": ["5f6eda63b4a1769165e61b8f989a7cfd20f99f9c"], "tags": []}], "date": 1537472062, "git_changesets": [null], "user": "apavel@mozilla.com"}, "9847": {"changesets": [{"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442176 - 2. Add pinned-to-screen flag in GeckoSession; r=snorp r=droeh a=pascalc\n\nAdd a flag for whether the session should be pinned to the screen. The\napp would check the flag and prevent scrolling of the session when it's\npinned.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5190", "files": ["mobile/android/chrome/geckoview/GeckoViewContent.js", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/gfx/GeckoDisplay.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/gfx/LayerSession.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSession.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoView.java"], "git_node": null, "git_parents": [null], "node": "80aaf77b813f333734fc05e60472a2b86f422d97", "parents": ["5bd0f4d6fed870fbe5697035707770522be60327"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442176 - 3. Use new toolbar pinning code in Fennec; r=petru a=pascalc\n\nSend the new \"GeckoView:PinToScreen\" event in Fennec code so the Fennec\ntoolbar is pinned when dragging selection carets.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5191", "files": ["mobile/android/modules/ActionBarHandler.jsm"], "git_node": null, "git_parents": [null], "node": "a733114f72eb86e7c9f6a2406f2c832a325a3bf2", "parents": ["80aaf77b813f333734fc05e60472a2b86f422d97"], "tags": []}], "date": 1537480342, "git_changesets": [null, null], "user": "nchen@mozilla.com"}, "9848": {"changesets": [{"author": "Andreea Pavel \u003capavel@mozilla.com\u003e", "branch": "default", "desc": "Backed out 2 changesets (bug 1442176) for android build bustages a=backout\n\nBacked out changeset a733114f72eb (bug 1442176)\nBacked out changeset 80aaf77b813f (bug 1442176)", "files": ["mobile/android/chrome/geckoview/GeckoViewContent.js", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/gfx/GeckoDisplay.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/gfx/LayerSession.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSession.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoView.java", "mobile/android/modules/ActionBarHandler.jsm"], "git_node": null, "git_parents": [null], "node": "be49f2604cfe40b4b1b463fcf34717f10f94bc89", "parents": ["a733114f72eb86e7c9f6a2406f2c832a325a3bf2"], "tags": []}], "date": 1537481190, "git_changesets": [null], "user": "apavel@mozilla.com"}, "9849": {"changesets": [{"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442176 - 2. Add pinned-to-screen flag in GeckoSession; r=snorp r=droeh a=pascalc\n\nAdd a flag for whether the session should be pinned to the screen. The\napp would check the flag and prevent scrolling of the session when it's\npinned.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5190", "files": ["mobile/android/chrome/geckoview/GeckoViewContent.js", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/gfx/GeckoDisplay.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/gfx/LayerSession.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSession.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoView.java"], "git_node": null, "git_parents": [null], "node": "e7b0363606ced0b8225346ebdf9cea3382dd5ac5", "parents": ["be49f2604cfe40b4b1b463fcf34717f10f94bc89"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442176 - 3. Use new toolbar pinning code in Fennec; r=petru a=pascalc\n\nSend the new \"GeckoView:PinToScreen\" event in Fennec code so the Fennec\ntoolbar is pinned when dragging selection carets.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5191", "files": ["mobile/android/modules/ActionBarHandler.jsm"], "git_node": null, "git_parents": [null], "node": "620018ee95d1c553698b335aa7e31bad14da046d", "parents": ["e7b0363606ced0b8225346ebdf9cea3382dd5ac5"], "tags": []}], "date": 1537482118, "git_changesets": [null, null], "user": "nchen@mozilla.com"}, "9850": {"changesets": [{"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1475325 - Hide selection action in some scenarios; r=droeh a=ritu\n\nHide the selection action toolbar when the session is unfocused, or when\nchanging the selection action delegate.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5807", "files": ["mobile/android/chrome/geckoview/GeckoViewSelectionActionContent.js", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSession.java"], "git_node": null, "git_parents": [null], "node": "297509ef3d02a63316ca5f3b6e20029b542ba996", "parents": ["620018ee95d1c553698b335aa7e31bad14da046d"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1475325 - 2. Add tests for hiding selection action in different cases; r=jchen a=ritu\n\nAdd some tests for hiding selection action during navigation, blurring,\nor clearing delegate.", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/SelectionActionDelegateTest.kt"], "git_node": null, "git_parents": [null], "node": "d21a43596d555ea618da75910aa3c1cb06158725", "parents": ["297509ef3d02a63316ca5f3b6e20029b542ba996"], "tags": []}], "date": 1537484634, "git_changesets": [null, null], "user": "nchen@mozilla.com"}, "9851": {"changesets": [{"author": "Nick Thomas \u003cnthomas@mozilla.com\u003e", "branch": "default", "desc": "Bug 1493056 - fetch-content tries to use https for private urls with the proxy, should use http, r=tomprince a=release\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6454", "files": ["taskcluster/scripts/misc/fetch-content"], "git_node": null, "git_parents": [null], "node": "b414ce0c7b967dc0adcc357f5385979f4964a327", "parents": ["d21a43596d555ea618da75910aa3c1cb06158725"], "tags": []}], "date": 1537500225, "git_changesets": [null], "user": "nthomas@mozilla.com"}, "9852": {"changesets": [{"author": "Nick Thomas \u003cnthomas@mozilla.com\u003e", "branch": "default", "desc": "Bug 1493056 - check for mar existence before chmoding it, and remove deprecated action, r=aki a=rel