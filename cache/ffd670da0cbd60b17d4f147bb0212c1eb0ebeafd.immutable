 "git_node": null, "git_parents": [null], "node": "9f0c56001fbffc0afe2eabffeb7b65b7139d56cd", "parents": ["92426f37b247c4876a4d9df0394dc36bd96e804c"], "tags": []}, {"author": "Andreea Pavel \u003capavel@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 17ffad06d94f (bug 1484030) for failing bc at browser/base/content/test/performance/browser_tabopen.js on a CLOSED TREE", "files": ["browser/base/content/browser.css", "browser/base/content/browser.xul", "browser/themes/shared/urlbar-searchbar.inc.css"], "git_node": null, "git_parents": [null], "node": "0ccf5da4244e30b1b7fc285162a992190a31410d", "parents": ["9f0c56001fbffc0afe2eabffeb7b65b7139d56cd"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1485577 - Pass triggeringPrincipal into openDialog for window opening code. r=jkt,Standard8 on a CLOSED TREE\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4095", "files": ["browser/base/content/browser.js", "browser/components/nsBrowserContentHandler.js"], "git_node": null, "git_parents": [null], "node": "f84d024c27b5e8b12aecb986218eac2b5aa2f703", "parents": ["0ccf5da4244e30b1b7fc285162a992190a31410d"], "tags": []}, {"author": "Francois Marier \u003cfrancois@mozilla.com\u003e", "branch": "default", "desc": "Bug 1485180 - Instrument invalid download protection hashes. r=dimi\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3941", "files": ["toolkit/components/reputationservice/ApplicationReputation.cpp", "toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "b58d46fa298f44a1b4f3d503973b6483ea4e55e2", "parents": ["f84d024c27b5e8b12aecb986218eac2b5aa2f703"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1419939 - Add an env var to precache shaders. r=kvark\n\nI made the variable name up, since I didn't see another similar thing.\nLet me know if I should change it.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4239", "files": ["gfx/webrender_bindings/src/bindings.rs"], "git_node": null, "git_parents": [null], "node": "48905d7f2d9d1e208bdd145dc85d68b41d7e34bf", "parents": ["b58d46fa298f44a1b4f3d503973b6483ea4e55e2"], "tags": []}, {"author": "Timothy Guan-tin Chien \u003ctimdream@gmail.com\u003e", "branch": "default", "desc": "Bug 1484544 - Allow focusable element to function on top level video element r=Gijs\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4169", "files": ["toolkit/content/TopLevelVideoDocument.js"], "git_node": null, "git_parents": [null], "node": "a28cf3253e232c78a69cd4da63b40fba3b0ac7e9", "parents": ["48905d7f2d9d1e208bdd145dc85d68b41d7e34bf"], "tags": []}, {"author": "Henri Sivonen \u003chsivonen@hsivonen.fi\u003e", "branch": "default", "desc": "Bug 1485945 - Set the length instead of capacity of an address string to avoid writing past its logical length. r=valentin\n\nMozReview-Commit-ID: 5anNIW843JJ\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4201", "files": ["netwerk/protocol/http/nsHttpConnectionMgr.cpp"], "git_node": null, "git_parents": [null], "node": "c9059b70bf4a46c414bc4514a6db20538be0c9c0", "parents": ["a28cf3253e232c78a69cd4da63b40fba3b0ac7e9"], "tags": []}, {"author": "David Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "bug 1485087 - remove the option to use the TLS session cache from nsITLSServerSocket r=jryans,mayhemer\n\nAs initially implemented, nsITLSServerSocket by default enabled the use of the\nTLS session cache provided by NSS. However, no consumers of nsITLSServerSocket\nactually used it. Because it was an option, though, PSM had to jump through some\nhoops to a) make it work in the first place and b) not have NSS panic on\nshutdown. Furthermore, it meant increased memory usage for every user of Firefox\n(and again, nothing actually used the feature, so this was for naught).\n\nIn bug 1479918, we discovered that if PSM shut down before Necko, NSS could\nattempt to acquire a lock on the session cache that had been deleted, causing a\nshutdown hang. We probably should make it less easy to make this mistake in NSS,\nbut in the meantime bug 1479918 needs uplifting and this workaround is the\nsafest, most straight-forward way to achieve this.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3919", "files": ["browser/base/content/test/urlbar/browser_urlbar_search_no_speculative_connect_with_client_cert.js", "devtools/shared/security/socket.js", "dom/presentation/provider/PresentationControlService.js", "netwerk/base/TLSServerSocket.cpp", "netwerk/base/nsITLSServerSocket.idl", "netwerk/test/unit/test_be_conservative.js", "netwerk/test/unit/test_be_conservative_error_handling.js", "netwerk/test/unit/test_tls_flags.js", "netwerk/test/unit/test_tls_server.js", "netwerk/test/unit/test_tls_server_multiple_clients.js", "security/manager/ssl/nsNSSComponent.cpp", "security/manager/ssl/nsNSSComponent.h", "security/manager/ssl/tests/unit/test_logoutAndTeardown.js", "xpcom/build/XPCOMInit.cpp"], "git_node": null, "git_parents": [null], "node": "214a7d48d11a7f73502d2ba323058bdd13daebcd", "parents": ["c9059b70bf4a46c414bc4514a6db20538be0c9c0"], "tags": []}, {"author": "Michael Kelly \u003cmkelly@mozilla.com\u003e", "branch": "default", "desc": "Bug 1484776: Extend Browser Error Collection telemetry to 67. r=francois\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3808", "files": ["toolkit/components/telemetry/Scalars.yaml"], "git_node": null, "git_parents": [null], "node": "8cb3938281bca5c56fffad7cd13794e2c4f826ec", "parents": ["214a7d48d11a7f73502d2ba323058bdd13daebcd"], "tags": []}, {"author": "Sam Foster \u003csfoster@mozilla.com\u003e", "branch": "default", "desc": "Bug 1482271 - Add preferences UI for the DNS over HTTPS mode and uri prefs r=johannh,flod\n\nMozReview-Commit-ID: G10vRxluGCa\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4049", "files": ["browser/components/preferences/connection.js", "browser/components/preferences/connection.xul", "browser/components/preferences/in-content/main.xul", "browser/components/preferences/in-content/tests/browser.ini", "browser/components/preferences/in-content/tests/browser_connection_dnsoverhttps.js", "browser/locales/en-US/browser/preferences/connection.ftl", "browser/locales/en-US/browser/preferences/preferences.ftl"], "git_node": null, "git_parents": [null], "node": "8657207d083cf21ab62c4a9a8bc23564d5d65829", "parents": ["8cb3938281bca5c56fffad7cd13794e2c4f826ec"], "tags": []}, {"author": "Chris Manchester \u003ccmanchester@mozilla.com\u003e", "branch": "default", "desc": "Bug 1485174 - Prevent using an objdir to build with tup that was previously used to build with make. r=firefox-build-system-reviewers,froydnj\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4154", "files": ["python/mozbuild/mozbuild/controller/building.py"], "git_node": null, "git_parents": [null], "node": "3b000def0382fee7a4cd9bd7def3a13d8a3cc67b", "parents": ["8657207d083cf21ab62c4a9a8bc23564d5d65829"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1485743 - Don't show the Content Blocking tour in private windows. r=francois\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4197", "files": ["browser/base/content/browser-contentblocking.js"], "git_node": null, "git_parents": [null], "node": "258c008b1915370a62269b2d2b29d36ba888c09f", "parents": ["3b000def0382fee7a4cd9bd7def3a13d8a3cc67b"], "tags": []}, {"author": "Brian Grinstead \u003cbgrinstead@mozilla.com\u003e", "branch": "default", "desc": "Bug 1482448 - Part 1 - Move window listeners for browser.xul into one place;r=Gijs\n\nThis is an extension of the work in Bug 1473160 to make clear in what environments\nvarious gBrowserInit functions are run. Since we currently use these in an `if` block\nin browser.js for \"navigator:browser\" window types, and browser.xul is the only\nnavigator:browser window that loads browser.js, this moves the event listeners directly\ninto browser.xul so it's extra clear that they don't run in non-browser top level windows on OSX.\n\nAlso move a few on-event handlers from the \u003cwindow\u003e tag into this block so they\nall happen in one place.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4137", "files": ["browser/base/content/browser.js", "browser/base/content/browser.xul"], "git_node": null, "git_parents": [null], "node": "71d8a7a05ee06192ee309a092d9e5c6015eed311", "parents": ["258c008b1915370a62269b2d2b29d36ba888c09f"], "tags": []}, {"author": "Brian Grinstead \u003cbgrinstead@mozilla.com\u003e", "branch": "default", "desc": "Bug 1482448 - Part 2 - Run gBrowserInit.onBeforeInitialXULLayout in browser.xhtml;r=Gijs\n\nMozBeforeInitialXULLayout doesn't fire in HTML docs. Even if we change it to\nstart firing for all top-level docs, it ends up firing _before_ the inline script\nruns inside of browser.xul. For now, run that logic in DOMContentLoaded to\nat least get a more functional browser window.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4138", "files": ["browser/base/content/browser.xul"], "git_node": null, "git_parents": [null], "node": "036bcf5f704b5873b4efa8e778cb4bf85506fe9e", "parents": ["71d8a7a05ee06192ee309a092d9e5c6015eed311"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1485980 - Downgrade test runner packages to match support library r=jchen\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4221", "files": ["mobile/android/geckoview/build.gradle"], "git_node": null, "git_parents": [null], "node": "bf32d74e95721d7025b2fbc3bd9719c2dd8c0db2", "parents": ["036bcf5f704b5873b4efa8e778cb4bf85506fe9e"], "tags": []}, {"author": "Ting-Yu Lin \u003ctlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486074 - Move logic for copying aliased properties' fields to the bottom of property_database.js. r=emilio\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4247", "files": ["layout/style/test/property_database.js"], "git_node": null, "git_parents": [null], "node": "d8b05de1fa307cfbc941b5634fce1937531e2cc8", "parents": ["bf32d74e95721d7025b2fbc3bd9719c2dd8c0db2"], "tags": []}, {"author": "Boris Chiou \u003cboris.chiou@gmail.com\u003e", "branch": "default", "desc": "Bug 1246764 - Part 1: Move SVGPathData and its parser into svg_path.rs. r=emilio\n\nSVGPathData will be used by clip-path and offset-path (and/or more on the\nproperties which support \u003cbasic-shape\u003e). Therefore, let's move\nSVGPathData out of motion.rs.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3631\n", "files": ["servo/components/style/gecko/conversions.rs", "servo/components/style/values/specified/mod.rs", "servo/components/style/values/specified/motion.rs", "servo/components/style/values/specified/svg_path.rs"], "git_node": null, "git_parents": [null], "node": "53cc417083ff8c9aa708a7195595011434fc0060", "parents": ["b1f162ab77b4d38155ad384c04190c959919c63e"], "tags": []}, {"author": "Boris Chiou \u003cboris.chiou@gmail.com\u003e", "branch": "default", "desc": "Bug 1246764 - Part 2: Define path() for clip-path. r=emilio\n\nFor now, |clip-path: path()| is chrome-only, and not for shape-outside,\nso we only implement the parser for clip-path. Besides, I didn't put\npath() in BasicShape because path() doesn't use the reference box to\nresolve the percentage or keywords (i.e. SVG path only accept floating\npoint or integer number as the css pixel value). Therefore, I add it into\nShapeSource, instead of BasicShape.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3633\n", "files": ["devtools/shared/css/generated/properties-db.js", "layout/inspector/tests/test_bug877690.html", "layout/style/nsStyleStruct.h", "layout/style/test/property_database.js", "servo/components/style/gecko/conversions.rs", "servo/components/style/properties/gecko.mako.rs", "servo/components/style/values/generics/basic_shape.rs", "servo/components/style/values/specified/basic_shape.rs"], "git_node": null, "git_parents": [null], "node": "cdd09f26a2b05ae8a025e24a40f3ef5330b697d8", "parents": ["53cc417083ff8c9aa708a7195595011434fc0060"], "tags": []}, {"author": "Boris Chiou \u003cboris.chiou@gmail.com\u003e", "branch": "default", "desc": "Bug 1246764 - Part 3: Layout part for |clip-path: path()|. r=jwatt\n\nCreate clip-path for the path function and reuse some APIs in\nnsCSSClipPathInstance, so we don't have to update the code flow.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3635\n", "files": ["dom/svg/SVGPathData.cpp", "dom/svg/SVGPathData.h", "layout/svg/nsCSSClipPathInstance.cpp", "layout/svg/nsCSSClipPathInstance.h", "layout/svg/nsSVGUtils.cpp"], "git_node": null, "git_parents": [null], "node": "bcdbd9f8b52d4d76b554581132c94cc2b46b0a69", "parents": ["cdd09f26a2b05ae8a025e24a40f3ef5330b697d8"], "tags": []}, {"author": "Boris Chiou \u003cboris.chiou@gmail.com\u003e", "branch": "default", "desc": "Bug 1246764 - Part 4: Rename mask flag and function name of xxxBasicShape to xxxBasicShapeOrPath. r=jwatt\n\nThis flag and function name are used for both basic shapes and path function,\nso rename it. For now, we treat path() and other basic-shapes as the\ndifferent object (i.e. StyleSVGPath and StyleBasicShape), so I rename\nthese functions and mask flag.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3636\n", "files": ["layout/generic/nsFrame.cpp", "layout/svg/nsCSSClipPathInstance.cpp", "layout/svg/nsCSSClipPathInstance.h", "layout/svg/nsSVGIntegrationUtils.cpp", "layout/svg/nsSVGUtils.cpp", "layout/svg/nsSVGUtils.h"], "git_node": null, "git_parents": [null], "node": "fff761953caf5e8bf979636ad58b5b6cdad83f98", "parents": ["bcdbd9f8b52d4d76b554581132c94cc2b46b0a69"], "tags": []}, {"author": "Boris Chiou \u003cboris.chiou@gmail.com\u003e", "branch": "default", "desc": "Bug 1246764 - Part 5: Tests. r=jwatt\n\nAdd some chrome-only reftests.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3637\n", "files": ["layout/reftests/svg/svg-integration/clip-path/clip-path-path-001-ref.html", "layout/reftests/svg/svg-integration/clip-path/clip-path-path-001.html", "layout/reftests/svg/svg-integration/clip-path/clip-path-path-002-ref.html", "layout/reftests/svg/svg-integration/clip-path/clip-path-path-002.html", "layout/reftests/svg/svg-integration/clip-path/path.css", "layout/reftests/svg/svg-integration/clip-path/reftest.list", "layout/tools/reftest/jar.mn"], "git_node": null, "git_parents": [null], "node": "21b885b5fc62ce75eb92b9412ea2e0eba1287e7d", "parents": ["fff761953caf5e8bf979636ad58b5b6cdad83f98"], "tags": []}, {"author": "arthur.iakab \u003caiakab@mozilla.com\u003e", "branch": "default", "desc": "Merge autoland to mozilla-central a=merge", "files": ["build/build-clang/clang-tidy-cxx14.patch", "build/build-clang/llvm-debug-frame-for-5.patch", "mobile/android/base/java/org/mozilla/gecko/media/VideoPlayer.java", "mobile/android/components/Snippets.js", "tools/clang-tidy/test/misc-argument-comment.cpp", "tools/clang-tidy/test/misc-argument-comment.json", "tools/clang-tidy/test/misc-assert-side-effect.cpp", "tools/clang-tidy/test/misc-assert-side-effect.json", "tools/clang-tidy/test/misc-bool-pointer-implicit-conversion.cpp", "tools/clang-tidy/test/misc-bool-pointer-implicit-conversion.json", "tools/clang-tidy/test/misc-forward-declaration-namespace.cpp", "tools/clang-tidy/test/misc-forward-declaration-namespace.json", "tools/clang-tidy/test/misc-macro-repeated-side-effects.cpp", "tools/clang-tidy/test/misc-macro-repeated-side-effects.json", "tools/clang-tidy/test/misc-string-constructor.cpp", "tools/clang-tidy/test/misc-string-constructor.json", "tools/clang-tidy/test/misc-string-integer-assignment.cpp", "tools/c