.ini", "testing/web-platform/meta/webxr/xrSession_prevent_multiple_exclusive.https.html.ini", "testing/web-platform/meta/webxr/xrSession_requestAnimationFrame_callback_calls.https.html.ini", "testing/web-platform/meta/webxr/xrSession_requestAnimationFrame_data_valid.https.html.ini", "testing/web-platform/meta/webxr/xrSession_requestAnimationFrame_getDevicePose.https.html.ini", "testing/web-platform/meta/webxr/xrSession_requestFrameOfReference.https.html.ini"], "git_node": null, "git_parents": [null], "node": "68480db895db2446ce2b6e60b79d21ae9cd87597", "parents": ["81368bd086e67a5903960f94c75a754c44a28b41"], "tags": []}, {"author": "Timothy Gu \u003ctimothygu@chromium.org\u003e", "branch": "default", "desc": "Bug 1485456 [wpt PR 12627] - Align Document::open() and close() further with the spec, a=testonly\n\nAutomatic update from web-platform-testsAlign Document::open() and close() further with the spec\n\nA few checks were moved from open() to open(Document*, ScriptState&) to conform\nto the order of execution laid out by the HTML Standard. Web Platform Tests\nwere added to ensure the fixes stick. In particular, this ensures there is no\nside effects in a document.open() call that bailed early.\n\nDocument::SetContent() is amended so that write() and close() are not called if\nopen() bails out early.\n\nComments were added for better correspondence with the specification.\n\nBug: 866274, 875735\nChange-Id: I14badd991bb723254f8889ba4073aff19126c7ba\nReviewed-on: https://chromium-review.googlesource.com/1182370\nReviewed-by: Hayato Ito \u003chayato@chromium.org\u003e\nReviewed-by: Yuki Shiino \u003cyukishiino@chromium.org\u003e\nCommit-Queue: Timothy Gu \u003ctimothygu@chromium.org\u003e\nCr-Commit-Position: refs/heads/master@{#585394}\n\n--\n\nwpt-commits: f837e221ee1050947223bb08b3643ae4da902375\nwpt-pr: 12627\n", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/html/webappapis/dynamic-markup-insertion/opening-the-input-stream/bailout-side-effects-ignore-opens-during-unload.window.js", "testing/web-platform/tests/html/webappapis/dynamic-markup-insertion/opening-the-input-stream/bailout-side-effects-synchronous-script.window.js"], "git_node": null, "git_parents": [null], "node": "409b29746565bf3f8d1fa7b5f7f47382cd211c41", "parents": ["68480db895db2446ce2b6e60b79d21ae9cd87597"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1485456 [wpt PR 12627] - Update wpt metadata, a=testonly\n\nwpt-pr: 12627\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/html/webappapis/dynamic-markup-insertion/opening-the-input-stream/bailout-side-effects-ignore-opens-during-unload.window.js.ini"], "git_node": null, "git_parents": [null], "node": "1661c92f64ef7dd30b7a600fc101c3509d671c69", "parents": ["409b29746565bf3f8d1fa7b5f7f47382cd211c41"], "tags": []}, {"author": "Robert Ma \u003crobertma@chromium.org\u003e", "branch": "default", "desc": "Bug 1485498 [wpt PR 12630] - Skip some textual lints for *.bmp, a=testonly\n\nAutomatic update from web-platform-testsSkip some textual lints for *.bmp\n\n--\n\nwpt-commits: 2845cc57d5d031b87ead22733983b4a49b2855e0\nwpt-pr: 12630\n", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/lint.whitelist"], "git_node": null, "git_parents": [null], "node": "fae0ff1e7ec16e4f6a8cd22d62b1f4cf6e194c08", "parents": ["1661c92f64ef7dd30b7a600fc101c3509d671c69"], "tags": []}, {"author": "Simon Pieters \u003czcorpan@gmail.com\u003e", "branch": "default", "desc": "Bug 1470678 [wpt PR 11640] - Add a test for text-decoration in tables quirk, a=testonly\n\nAutomatic update from web-platform-testsAdd a test for text-decoration in tables quirk\n\n--\n\nwpt-commits: f4b8c1ed158c79fdb30ed70b2824da295f524755\nwpt-pr: 11640\n", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/quirks/text-decoration-doesnt-propagate-into-tables/quirks-ref.html", "testing/web-platform/tests/q