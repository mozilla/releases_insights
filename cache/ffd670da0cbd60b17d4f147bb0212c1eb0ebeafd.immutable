ml", "dom/security/test/mixedcontentblocker/file_server.sjs", "dom/security/test/mixedcontentblocker/test_main.html"], "git_node": null, "git_parents": [null], "node": "e6548800ca6d3c39abad8a14f273dceef4906405", "parents": ["00d4b1f1033612ee8e31803950d12de8a521d260"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1487525 - Don't reset pending uninstall attribute when disabling theme. r=aswan, a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5218", "files": ["toolkit/mozapps/extensions/LightweightThemeManager.jsm", "toolkit/mozapps/extensions/content/extensions.xml"], "git_node": null, "git_parents": [null], "node": "0a42a880c1302b0de216d341bd496d3dc477aac1", "parents": ["e6548800ca6d3c39abad8a14f273dceef4906405"], "tags": []}, {"author": "Razvan Caliman \u003crcaliman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1488031 - Trim axis labels, show variation axis tag when available. r=gl, a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5087", "files": ["devtools/client/inspector/fonts/components/FontAxis.js", "devtools/client/inspector/fonts/components/FontEditor.js", "devtools/client/inspector/fonts/components/FontPropertyValue.js", "devtools/client/inspector/fonts/components/moz.build", "devtools/client/themes/fonts.css"], "git_node": null, "git_parents": [null], "node": "4b4c5b5fe54d13e91cb3a9e2bc9ab905672412d3", "parents": ["0a42a880c1302b0de216d341bd496d3dc477aac1"], "tags": []}, {"author": "Razvan Caliman \u003crcaliman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1488031 - Font editor: show labels for min and max values for axes on hover and focus. r=gl, a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5143", "files": ["devtools/client/inspector/fonts/components/FontAxis.js", "devtools/client/inspector/fonts/components/FontEditor.js", "devtools/client/inspector/fonts/components/FontPropertyValue.js", "devtools/client/inspector/fonts/test/head.js", "devtools/client/inspector/fonts/utils/font-utils.js", "devtools/client/themes/fonts.css"], "git_node": null, "git_parents": [null], "node": "8834420ffad4df2f1e7055fbf25412f720ef59ee", "parents": ["4b4c5b5fe54d13e91cb3a9e2bc9ab905672412d3"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1489967 - Keep active state when Firefox is moved to background and focusmanager test mode is enabled. r=enndeakin, a=pascalc\n\nThe test mode can be used to virtually give a Chrome window the\nfocus even with Firefox being in the background.\n\nCurrently when such a window has the focus and another application\nis moved to the foreground, the active state is lost. This means that\nfor example Selenium tests which are run in parallel and using\ndifferent instances of Firefox will not receive the expected\n\"focus\" and \"blur\" events.\n\nThis patch checks for the test mode and if enabled doesn't\nlower the window, which will keep the focused state.", "files": ["dom/base/nsFocusManager.cpp", "dom/base/nsFocusManager.h", "xpfe/appshell/nsWebShellWindow.cpp"], "git_node": null, "git_parents": [null], "node": "c51520b3d2f3935ea9fa80fabf3aca21322d7da2", "parents": ["8834420ffad4df2f1e7055fbf25412f720ef59ee"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1484597 - Expose visual viewport information more conveniently in Layout. r=mstange, a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6074", "files": ["layout/base/PresShell.cpp", "layout/base/nsIPresShell.h", "layout/generic/nsGfxScrollFrame.cpp", "layout/generic/nsGfxScrollFrame.h", "layout/generic/nsIScrollableFrame.h"], "git_node": null, "git_parents": [null], "node": "3b9941572ef19ede316ba7adff3dee086541c9d9", "parents": ["c51520b3d2f3935ea9fa80fabf3aca21322d7da2"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1484597 - Keep the bounding client rect field of the 'mozcaretstatechanged' event relative to the visual viewport. r=mstange,nika, a=pascalc\n\nDepends on D6074\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6075", "files": ["dom/webidl/CaretStateChangedEvent.webidl", "layout/base/AccessibleCaretManager.cpp"], "git_node": null, "git_parents": [null], "node": "f22d1ffd83bcd93640649a2397b488e9ae4919b2", "parents": ["3b9941572ef19ede316ba7adff3dee086541c9d9"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1484597 - Use the visual viewport offset in ScrollToShowRect(). r=mstange, a=pascalc\n\nDepends on D6075\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6076", "files": ["layout/base/PresShell.cpp"], "git_node": null, "git_parents": [null], "node": "fae09b7d51adde312d1e75ca563b78b745df773c", "parents": ["f22d1ffd83bcd93640649a2397b488e9ae4919b2"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1484597 - Clear the APZ callback transform when originating a main thread scroll offset update for the RCD-RSF. r=kats, a=pascalc\n\nDepends on D6076\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6077", "files": ["layout/generic/nsGfxScrollFrame.cpp"], "git_node": null, "git_parents": [null], "node": "eaf11802a534eccc9e263024c95e8c7dede13997", "parents": ["fae09b7d51adde312d1e75ca563b78b745df773c"], "tags": []}], "date": 1538398082, "git_changesets": [null, null, null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9915": {"changesets": [{"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1494739 - Remove GV vibrate permission; r=me a=pascalc\n\nRmove the VIBRATE permission. GV actually doesn't support the vibration\nAPI at the moment, so the permission is unused anyways.", "files": ["mobile/android/geckoview/src/main/AndroidManifest.xml"], "git_node": null, "git_parents": [null], "node": "b89d43000773dd683b06437d00a196ac273e6af7", "parents": ["eaf11802a534eccc9e263024c95e8c7dede13997"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1492764 - Set .left class to headerbar box element as Gtk+ does, r=jhorak a=pascalc\n\nGtk+ sets .left/.right classes to GtkBox element at GtkHeaderBar according to button placement (left/right).\nWe don't support that now so set .left at least to be compatible with themes - BlueMenta for instance.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6657", "files": ["widget/gtk/WidgetStyleCache.cpp"], "git_node": null, "git_parents": [null], "node": "b6e5cc56a49f81aa5eb8b556a2b3ab77329985d0", "parents": ["b89d43000773dd683b06437d00a196ac273e6af7"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1492288 - Use IGNORE_ROOT_SCROLL_FRAME on Android when doing the hit test in AccessibleCaretManager::SelectWordOrShortcut(). r=kats a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6549", "files": ["layout/base/AccessibleCaretManager.cpp"], "git_node": null, "git_parents": [null], "node": "c1f74cb53e6d4f43f950a8102f6e8ef7c8fb2a41", "parents": ["b6e5cc56a49f81aa5eb8b556a2b3ab77329985d0"], "tags": []}, {"author": "James Willcox \u003csnorp@snorp.net\u003e", "branch": "default", "desc": "Bug 1491094 - Don't require ACCESS_WIFI_STATE for GeckoView r=droeh a=pascalc\n\nFennec will continue to require this. While we're here, also make 'touchscreen' feature optional.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7125", "files": ["mobile/android/geckoview/src/main/AndroidManifest.xml", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoNetworkManager.java"], "git_node": null, "git_parents": [null], "node": "20a95b6b2494f59b0aa86fe71e9a195305603a99", "parents": ["c1f74cb53e6d4f43f950a8102f6e8ef7c8fb2a41"], "tags": []}, {"author": "Francois Marier \u003cfrancois@mozilla.com\u003e", "branch": "default", "desc": "Bug 1488974 - Disable FastBlock after the load event has fired. r=mayhemer,Ehsan a=pascalc\n\nThe test used to assume that the load event didn't matter and so\nthe expected values had to be updated to match the new behavior.\n\nA new \"slowIFrame\" test was added to capture what was previously\ntested by the \"badIFrame\".\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7031", "files": ["ipc/glue/BackgroundUtils.cpp", "netwerk/base/LoadInfo.cpp", "netwerk/base/LoadInfo.h", "netwerk/base/nsILoadInfo.idl", "netwerk/ipc/NeckoChannelParams.ipdlh", "netwerk/protocol/http/nsHttpChannel.cpp", "toolkit/components/url-classifier/tests/mochitest/fastblock.html", "toolkit/components/url-classifier/tests/mochitest/fastblock_iframe.html", "toolkit/components/url-classifier/tests/mochitest/test_fastblock_bug1477046.html"], "git_node": null, "git_parents": [null], "node": "c6d12dab44f03bb846778586d1f90c19c77377b4", "parents": ["20a95b6b2494f59b0aa86fe71e9a195305603a99"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486695 - Only set nsDisplayListBuilder::mActiveScrolledRootForRootScrollframe for the RCD-RSF. r=mstange a=pascalc\n\nIt's queried during layer building, for the RCD-RSF only. If we set it for\na subframe RSF, that overwrites the value for the RCD-RSF, and we end up\nquerying the incorrect value.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6536", "files": ["layout/generic/nsGfxScrollFrame.cpp"], "git_node": null, "git_parents": [null], "node": "53e361cf9567c69172bfe1f1f67fec5944d6d8b3", "parents": ["c6d12dab44f03bb846778586d1f90c19c77377b4"], "tags": []}, {"author": "Jim Mathies \u003cjmathies@mozilla.com\u003e", "branch": "default", "desc": "Bug 1477064 -  Collect PLUGIN_DRAWING_MODEL histogram data on release. r=francois, data=francois a=pascalc", "files": ["toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "2c89af76feb4fb7b24cc7f32db3ac9ef35837e0d", "parents": ["53e361cf9567c69172bfe1f1f67fec5944d6d8b3"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1476221 - Expose the offset of the visual viewport relative to the layout viewport to chrome JS code via nsIDOMWindowUtils. r=mstange a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6090", "files": ["dom/base/nsDOMWindowUtils.cpp", "dom/interfaces/base/nsIDOMWindowUtils.idl"], "git_node": null, "git_parents": [null], "node": "2658fb7e9e994e9a581399e445a640ec7449d956", "parents": ["2c89af76feb4fb7b24cc7f32db3ac9ef35837e0d"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1476221 - Keep the bounding client rect of the 'FormAssist:AutoCompleteResults' message relative to the visual viewport. r=mstange a=pascalc\n\nDepends on D6090\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6091", "files": ["mobile/android/modules/FormAssistant.jsm"], "git_node": null, "git_parents": [null], "node": "52c77c08b8a50b158a75d4b4948babb42350c0ae", "parents": ["2658fb7e9e994e9a581399e445a640ec7449d956"], "tags": []}, {"author": "Stephen A Pohl \u003cspohl.mozilla.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1489785: Remove a workaround for gcc, introduced in bug 678607, that is no longer needed and that causes hangs in modal dialogs on macOS 10.14. r=mstange a=pascalc", "files": ["widget/cocoa/nsChildView.mm"], "git_node": null, "git_parents": [null], "node": "3fa0c4d514c91c625d0a6f8c2cae2b3c7157b712", "parents": ["52c77c08b8a50b158a75d4b4948babb42350c0ae"], "tags": []}, {"author": "ScottDowne \u003cscott.downe@gmail.com\u003e", "branch": "default", "desc": "Bug 1490734 - Fresh profile can sometimes display no card in the third card position r=k88hudson a=pascalc\n\nBug #: 1490734\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7195", "files": ["browser/components/newtab/content-src/components/Base/Base.jsx", "browser/components/newtab/content-src/components/Sections/Sections.jsx", "browser/components/newtab/data/content/activity-stream.bundle.js", "browser/components/newtab/data/content/activity-stream.bundle.js.map", "browser/components/newtab/test/unit/content-src/components/Base.test.jsx", "browser/components/newtab/test/unit/content-src/components/Sections.test.jsx"], "git_node": null, "git_parents": [null], "node": "f76a129ff2f2739e286626024004d7785bdb4dc1", "parents": ["3fa0c4d514c91c625d0a6f8c2cae2b3c7157b712"], "tags": ["DEVEDITION_63_0b11_BUILD1", "DEVEDITION_63_0b11_RELEASE", "FENNEC_63_0b11_BUILD1", "FENNEC_63_0b11_RELEASE", "FIREFOX_63_0b11_BUILD1", "FIREFOX_63_0b11_RELEASE"]}], "date": 1538399422, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null], "user": "ebalazs@mozilla.com"}, "9916": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging f76a129ff2f2739e286626024004d7785bdb4dc1 with FENNEC_63_0b11_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "86271f7343cac90e375a567aa2051040c3b6e619", "parents": ["f76a129ff2f2739e286626024004d7785bdb4dc1"], "tags": []}], "date": 1538407629, "git_changesets": [null], "user": "ffxbld"}, "9917": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging f76a129ff2f2739e286626024004d7785bdb4dc1 with DEVEDITION_63_0b11_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "caf49cf53a93a8207e4a7fcb6653de19d5a29091", "parents": ["86271f7343cac90e375a567aa2051040c3b6e619"], "tags": []}], "date": 1538407915, "git_changesets": [null], "user": "ffxbld"}, "9918": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging f76a129ff2f2739e286626024004d7785bdb4dc1 with FIREFOX_63_0b11_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "0e6e3b8a478e292dcb9734eba10dbd9fb887b2df", "parents": ["caf49cf53a93a8207e4a7fcb6653de19d5a29091"], "tags": []}], "date": 1538408146, "git_changesets": [null], "user": "ffxbld"}, "9919": {"changesets": [{"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1487255 - Update search blacklist. r=mikedeboer, a=jcristau", "files": ["toolkit/components/search/nsSearchService.js"], "git_node": null, "git_parents": [null], "node": "e31b0fa4bdb86164c0c017009052446a35eed1ad", "parents": ["0e6e3b8a478e292dcb9734eba10dbd9fb887b2df"], "tags": []}], "date": 1538408883, "git_changesets": [null], "user": "jcristau@mozilla.com"}, "9920": {"changesets": [{"author": "ahillier \u003cahillier@mozilla.com\u003e", "branch": "default", "desc": "Bug 1490508 - Apply mask correctly to CFR recommendation on urlbar focus r=Mardak a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5618", "files": ["browser/base/content/browser.css", "browser/themes/shared/urlbar-searchbar.inc.css"], "git_node": null, "git_parents": [null], "node": "cd305e92721b942d140e1af274e4330fe6e8abe7", "parents": ["e31b0fa4bdb86164c0c017009052446a35eed1ad"], "tags": []}], "date": 1538470866, "git_changesets": [null], "user": "rgurzau@mozilla.com"}, "9921": {"changesets": [{"author": "Dana Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "bug 1483905 - ensure the WebAuthnManager stays alive while WebAuthnTransactionChild is using it r=qdot a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5305", "files": ["dom/webauthn/WebAuthnTransactionChild.cpp", "dom/webauthn/tests/get_assertion_dead_object.html", "dom/webauthn/tests/mochitest.ini", "dom/webauthn/tests/test_webauthn_get_assertion_dead_object.html"], "git_node": null, "git_parents": [null], "node": "108b9d174f0971fcdeabe862c37b143656dbda27", "parents": ["cd305e92721b942d140e1af274e4330fe6e8abe7"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1495452 - Don't crash when there is no vibrate permission; r=me a=pascalc\n\nCatch exceptions when we don't have the vibrate permission.", "files": ["mobile/android/geckoview/src/main/java/org/mozilla/gecko/GeckoAppShell.java"], "git_node": null, "git_parents": [null], "node": "7fdf6a2b180dca64d5581843b5f4d87f71fd0311", "parents": ["108b9d174f0971fcdeabe862c37b143656dbda27"], "tags": []}], "date": 1538473464, "git_changesets": [null, null], "user": "archaeopteryx@coole-files.de"}, "9922": {"changesets": [{"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1495404 - Postpone dbus_bus_get() call until we need it at WakeLockListener::Callback(), r=jhorak a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7281", "files": ["widget/gtk/WakeLockListener.cpp", "widget/gtk/WakeLockListener.h"], "git_node": null, "git_parents": [null], "node": "95fd0bcb0f233d24eca493bc02dd0f8ac3ccdc9f", "parents": ["7fdf6a2b180dca64d5581843b5f4d87f71fd0311"], "tags": []}], "date": 1538481601, "git_changesets": [null], "user": "ebalazs@mozilla.com"}, "9923": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging f76a129ff2f2739e286626024004d7785bdb4dc1 with FENNEC_63_0b11_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "80077ba7f73158c097d77d852837e692de99c82b", "parents": ["95fd0bcb0f233d24eca493bc02dd0f8ac3ccdc9f"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "22024d8d03a9c972844bfa3caabea5a6fbac9e5e", "parents": ["80077ba7f73158c097d77d852837e692de99c82b"], "tags": []}], "date": 1538495875, "git_changesets": [null, null], "user": "ffxbld"}, "9924": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging f76a129ff2f2739e286626024004d7785bdb4dc1 with DEVEDITION_63_0b11_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "90bef69e5d3e7dcc52d826bffe0179ae04a53334", "parents": ["22024d8d03a9c972844bfa3caabea5a6fbac9e5e"], "tags": []}], "date": 1538496041, "git_changesets": [null], "user": "ffxbld"}, "9925": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging f76a129ff2f2739e286626024004d7785bdb4dc1 with FIREFOX_63_0b11_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "ae9d4c8a90047d7059203da2900b000048b8ec4a", "parents": ["90bef69e5d3e7dcc52d826bffe0179ae04a53334"], "tags": []}], "date": 1538496220, "git_changesets": [null], "user": "ffxbld"}, "9926": {"changesets": [{"author": "Rob Lemley \u003crob@thunderbird.net\u003e", "branch": "default", "desc": "Bug 1491907 - Set correct branch URL for Thunderbird based on product-details. r=bhearsum a=tomprince\n\nThunderbird releases come from the comm-esr.* repositories rather than the\ncomm-release repository. This adds a special case for Thunderbird and sets\nthe branch URL correctly.\n\nThis initial patch is based on the branch_prefix (comm or mozilla).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6509", "files": ["testing/mozharness/scripts/release/update-verify-config-creator.py"], "git_node": null, "git_parents": [null], "node": "44e1682a49189e22120bc0451a37f3cb60100845", "parents": ["ae9d4c8a90047d7059203da2900b000048b8ec4a"], "tags": []}, {"author": "Rob Lemley \u003crob@thunderbird.net\u003e", "branch": "default", "desc": "Bug 1491907 - Get comm/ version from comm/mail/version*.txt. r=dustin a=tomprince\n\nThe release-update-verify-config task requires that the versions passed\nto it match up with what's been released. The version of Thunderbird\ndoes not necessarily match the Gecko version it's based on.\n\nDepends on D6509\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6510", "files": ["taskcluster/ci/config.yml", "taskcluster/taskgraph/__init__.py", "taskcluster/taskgraph/config.py", "taskcluster/taskgraph/decision.py", "taskcluster/taskgraph/parameters.py"], "git_node": null, "git_parents": [null], "node": "9dc81ba0d288d2a46f6e0ef4976563cfea9a1be6", "parents": ["44e1682a49189e22120bc0451a37f3cb60100845"], "tags": []}], "date": 1538522156, "git_changesets": [null, null], "user": "mozilla@jorgk.com"}, "9927": {"changesets": [{"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1438830 - [mozprocess] Track and kill detached processes on Windows. r=gbrown a=test-only\n\nAllow mozprocess to track and kill processes on Windows,\neven when they got restarted.\n\nSuch processes are still part of the job object, but unless\nthe \"JOB_OBJECT_LIMIT_KILL_ON_JOB_CLOSE\" flag is set, they\naren't getting closed.\n\nSince our sandbox also creates jobs, we preferably want to\nnest the sandbox's job inside the job as created by mozprocess.\nSpecifying \"JOB_OBJECT_LIMIT_BREAKAWAY_OK\" would allow\nsandboxed processes within the job to break off and form their\nown, separate job. This is actually necessary for sandboxing\nto work on older versions of Windows without nested job support,\nbut on newer versions, we don't want them breaking away.", "files": ["testing/mozbase/mozprocess/mozprocess/processhandler.py", "testing/mozbase/mozprocess/mozprocess/winprocess.py"], "git_node": null, "git_parents": [null], "node": "570f98364ad3221e2da465e866ec720c1f4b9d9d", "parents": ["9dc81ba0d288d2a46f6e0ef4976563cfea9a1be6"], "tags": []}, {"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1489060 - Urlbar autofill is broken when autofilling history is disabled and autofilling bookmarks is enabled r=mak a=pascalc\n\nIn the origin query, the SELECT is aggregate due to both the TOTAL(frecency) column and the GROUP BY, but bookmarkedFragment is not aggregate. So it ends up looking only at whatever moz_place ends up first in its result set. If that moz_place's foreign_count is zero, then the whole bookmarkedFragment is zero, even if there are moz_places in the result set that are bookmarked.\n\nChange bookmarkedFragment to use TOTAL.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6867", "files": ["toolkit/components/places/UnifiedComplete.js", "toolkit/components/places/tests/unifiedcomplete/test_autofill_origins.js"], "git_node": null, "git_parents": [null], "node": "79aae3b724a5126554e76dbc93acf3c9805682fe", "parents": ["570f98364ad3221e2da465e866ec720c1f4b9d9d"], "tags": []}, {"author": "Daniel Stenberg \u003cdaniel@haxx.se\u003e", "branch": "default", "desc": "bug 1495537 - lower the default trr request-timeout to 1500 ms r=dragana a=pascalc\n\n99.15% of all TRR requests are done within 1.56 seconds (in beta 63) and\n1500 milliseconds is already a very long time to wait for a resolve to\nfail... The median is 44 ms and 95th percentile is at 471 ms.\n\nMozReview-Commit-ID: CICBAA0cEBd\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7336", "files": ["modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "aa5533acaf04c5e66d920ffa144800d8c426d669", "parents": ["79aae3b724a5126554e76dbc93acf3c9805682fe"], "tags": []}, {"author": "Alexandre Poirot \u003cpoirot.alex@gmail.com\u003e", "branch": "default", "desc": "Bug 1490927 - Stop sharing maps in NetworkMonitor between all instances. r=Honza a=pascalc\n\nWhen opening a web console and a browser console, we instantiate two NetworkMonitor\ninstances in the same process and they need independant states.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6054", "files": ["devtools/server/actors/network-monitor.js"], "git_node": null, "git_parents": [null], "node": "d442c34c8ef762d9f32b175017c8e07bdb0bd1c1", "parents": ["aa5533acaf04c5e66d920ffa144800d8c426d669"], "tags": []}, {"author": "k88hudson \u003ck88hudson@gmail.com\u003e", "branch": "default", "desc": "Bug 1490826 - Add form info to FxA form submits r=vladikoff a=pascalc\n\nReviewers: vladikoff\n\nReviewed By: vladikoff\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7541", "files": ["browser/components/newtab/content-src/components/StartupOverlay/StartupOverlay.jsx", "browser/components/newtab/data/content/activity-stream.bundle.js", "browser/components/newtab/data/content/activity-stream.bundle.js.map", "browser/components/newtab/docs/v2-system-addon/data_dictionary.md", "browser/components/newtab/docs/v2-system-addon/data_events.md", "browser/components/newtab/test/schemas/pings.js", "browser/components/newtab/test/unit/content-src/components/StartupOverlay.test.jsx"], "git_node": null, "git_parents": [null], "node": "600bf0fc57d47abd1e98b79949f1acc3a4bf5328", "parents": ["d442c34c8ef762d9f32b175017c8e07bdb0bd1c1"], "tags": []}, {"author": "Bryce Van Dyk \u003cbvandyk@mozilla.com\u003e", "branch": "default", "desc": "Bug 1492915 - Stop WebMDemuxer from inspecting partially encrypted packets for keyframe information. r=jya a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6415", "files": ["dom/media/webm/WebMDemuxer.cpp"], "git_node": null, "git_parents": [null], "node": "948c74f2d3df239534abc9255927c6686617b388", "parents": ["600bf0fc57d47abd1e98b79949f1acc3a4bf5328"], "tags": []}, {"author": "Shane Caraveo \u003cscaraveo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1494328 fix launchWebAuthFlow to use default redirect_uri r=aswan a=pascalc\n\nSome oauth services require the redirect uri be configured on their service,\nand the reject the redirect_uri param if we send it.  Chrome works fine in this scenario,\nbut we have been requiring the redirect_uri be provided.  This addresses that requirement\nby using our own default redirect url, which would be the url used to configure the\noauth service.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6945", "files": ["toolkit/components/extensions/child/ext-identity.js", "toolkit/components/extensions/parent/ext-identity.js", "toolkit/components/extensions/test/mochitest/redirect_auto.sjs", "toolkit/components/extensions/test/mochitest/test_ext_identity.html"], "git_node": null, "git_parents": [null], "node": "3947b51293f6f3ddd8173b263cee69f7e4850a45", "parents": ["948c74f2d3df239534abc9255927c6686617b388"], "tags": []}], "date": 1538558550, "git_changesets": [null, null, null, null, null, null, null], "user": "apavel@mozilla.com"}, "9928": {"changesets": [{"author": "Gabriele Svelto \u003cgsvelto@mozilla.com\u003e", "branch": "default", "desc": "Bug 1463048 - Remove asynchronous minidump generation r=ted a=pascalc\n\nThis reverts the changes in bug 1360308, bug 1390143 and bug 1469603. Minidump\ngeneration will now only happen on the main process' main thread which might\nlead to hangs but is known to be fairly robust. Asynchronous generation proved\ntoo brittle and enormously increased the complexity of this already\nhard-to-read code.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5147", "files": ["dom/ipc/ContentParent.cpp", "dom/ipc/ContentParent.h", "dom/ipc/ProcessHangMonitor.cpp", "dom/plugins/ipc/PluginBridge.h", "dom/plugins/ipc/PluginHangUIParent.cpp", "dom/plugins/ipc/PluginModuleParent.cpp", "dom/plugins/ipc/PluginModuleParent.h", "ipc/glue/CrashReporterHost.cpp", "ipc/glue/CrashReporterHost.h", "toolkit/crashreporter/nsDummyExceptionHandler.cpp", "toolkit/crashreporter/nsExceptionHandler.cpp", "toolkit/crashreporter/nsExceptionHandler.h"], "git_node": null, "git_parents": [null], "node": "b3fad6a4c6cb3b26e1692ef9caa42e965564dc0e", "parents": ["3947b51293f6f3ddd8173b263cee69f7e4850a45"], "tags": []}], "date": 1538564631, "git_changesets": [null], "user": "gsvelto@mozilla.com"}, "9929": {"changesets": [{"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1490009 - Clear CallbackObject fields after use for promise job to avoid tenuring objects unnecessarily r=bz a=pascalc", "files": ["dom/bindings/CallbackObject.h", "xpcom/base/CycleCollectedJSContext.cpp"], "git_node": null, "git_parents": [null], "node": "01dd14f85e40ed9ffadb2296aa305c4c7022e99c", "parents": ["b3fad6a4c6cb3b26e1692ef9caa42e965564dc0e"], "tags": []}], "date": 1538571932, "git_changesets": [null], "user": "apavel@mozilla.com"}, "9930": {"changesets": [{"author": "Dylan Roeh \u003cdroeh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1481296 - Add a popup blocking API to PromptDelegate. r=jchen,snorp a=pascalc", "files": ["mobile/android/chrome/geckoview/GeckoViewPromptContent.js", "mobile/android/components/geckoview/GeckoViewPrompt.js", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/util/Callbacks.kt", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSession.java", "mobile/android/geckoview_example/src/main/java/org/mozilla/geckoview_example/BasicGeckoViewPrompt.java"], "git_node": null, "git_parents": [null], "node": "c2b5cb2f178c01676790a35a2392376e7a0191cb", "parents": ["01dd14f85e40ed9ffadb2296aa305c4c7022e99c"], "tags": []}, {"author": "Dylan Roeh \u003cdroeh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1494486 - Add testing for PromptDelegate.onPopupRequest. r=snorp a=pascalc", "files": ["mobile/android/geckoview/src/androidTest/assets/www/popup.html", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/BaseSessionTest.kt", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/PromptDelegateTest.kt", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/GeckoSession.java"], "git_node": null, "git_parents": [null], "node": "9fcba1ba282cec2e8ac2a99aedf767d1e2658636", "parents": ["c2b5cb2f178c01676790a35a2392376e7a0191cb"], "tags": []}, {"author": "Matthew Noorenberghe \u003cmozilla@noorenberghe.ca\u003e", "branch": "default", "desc": "Bug 1426767 - Disable login context menu items on documents with a null principal. r=Gijs a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7386", "files": ["toolkit/components/passwordmgr/LoginManagerContent.jsm", "toolkit/components/passwordmgr/test/browser/browser_context_menu_iframe.js", "toolkit/components/passwordmgr/test/browser/form_basic_iframe.html"], "git_node": null, "git_parents": [null], "node": "d75eaf2157038a0f9965a76d3e08adc101d5cabc", "parents": ["9fcba1ba282cec2e8ac2a99aedf767d1e2658636"], "tags": []}, {"author": "Matthew Noorenberghe \u003cmozilla@noorenberghe.ca\u003e", "branch": "default", "desc": "Bug 1426767 - Ignore events in password manager from documents with a null principal. r=Gijs a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7387", "files": ["browser/base/content/content.js", "mobile/android/components/BrowserCLH.js", "toolkit/components/passwordmgr/test/mochitest/mochitest.ini", "toolkit/components/passwordmgr/test/mochitest/test_autofill_sandboxed.html"], "git_node": null, "git_parents": [null], "node": "ba6c6b60e8dac50c551eb33c7b35aa148a77d794", "parents": ["d75eaf2157038a0f9965a76d3e08adc101d5cabc"], "tags": []}, {"author": "Matthew Noorenberghe \u003cmozilla@noorenberghe.ca\u003e", "branch": "default", "desc": "Bug 1426767 - Don't autocomplete logins in documents with a null principal. r=Gijs a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7388", "files": ["toolkit/components/passwordmgr/nsLoginManager.js", "toolkit/components/passwordmgr/test/mochitest/mochitest.ini", "toolkit/components/passwordmgr/test/mochitest/test_autocomplete_sandboxed.html"], "git_node": null, "git_parents": [null], "node": "9739ddca6f2a38b22240831ecdc1f3a7e64b065b", "parents": ["ba6c6b60e8dac50c551eb33c7b35aa148a77d794"], "tags": []}, {"author": "Arshad Kazmi \u003carshadkazmi42@gmail.com\u003e", "branch": "default", "desc": "Bug 1491268 - Bookmarks policy's last field is displayed in same color like all other rows r=Felipe a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7238", "files": ["browser/components/enterprisepolicies/content/aboutPolicies.js"], "git_node": null, "git_parents": [null], "node": "cfa284805fbff5c80876c469d39e8217d7781ae0", "parents": ["9739ddca6f2a38b22240831ecdc1f3a7e64b065b"], "tags": []}, {"author": "Lina Cambridge \u003clina@yakshaving.ninja\u003e", "branch": "default", "desc": "Bug 1495723 - Add support for importing extra symbols to `defineLazyGlobalGetters`. r=kmag a=pascalc\n\nSome global imports, like `fetch`, expose multiple symbols. This patch\nensures we can define lazy getters for those symbols, by mapping the\nextra symbol name to the main import name.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7522", "files": ["js/xpconnect/loader/XPCOMUtils.jsm", "services/sync/modules/resource.js"], "git_node": null, "git_parents": [null], "node": "6a4d84aadda3b35f8ea9f556e1aae644668ed18e", "parents": ["cfa284805fbff5c80876c469d39e8217d7781ae0"], "tags": []}], "date": 1538647072, "git_changesets": [null, null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "9931": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP remote-settings - a=repo-update r=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7714", "files": ["security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc"], "git_node": null, "git_parents": [null], "node": "0ad842642aa7bca6216b9606a103250f08af0188", "parents": ["6a4d84aadda3b35f8ea9f556e1aae644668ed18e"], "tags": ["DEVEDITION_63_0b12_BUILD1", "DEVEDITION_63_0b12_RELEASE", "FIREFOX_63_0b12_BUILD1"]}], "date": 1538659550, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "9932": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 0ad842642aa7bca6216b9606a103250f08af0188 with DEVEDITION_63_0b12_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "e10c499f19138283105cd7c5ba1b4c57fabe1e9d", "parents": ["0ad842642aa7bca6216b9606a103250f08af0188"], "tags": []}], "date": 1538666905, "git_changesets": [null], "user": "ffxbld"}, "9933": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 0ad842642aa7bca6216b9606a103250f08af0188 with FIREFOX_63_0b12_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "735e947b99d7a7cd9991aaf6515ab499b6e06a2c", "parents": ["e10c499f19138283105cd7c5ba1b4c57fabe1e9d"], "tags": []}], "date": 1538667128, "git_changesets": [null], "user": "ffxbld"}, "9934": {"changesets": [{"author": "Rok Garbas \u003crok@garbas.si\u003e", "branch": "default", "desc": "Bug 1496480 - release-update-verify-config-* tasks failing due to recent refactoring in Bug 1491907, r=tomprince a=release\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7748", "files": ["testing/mozharness/scripts/release/update-verify-config-creator.py"], "git_node": null, "git_parents": [null], "node": "0082062b759f342cb97dd2f46486ca29552b16e4", "parents": ["735e947b99d7a7cd9991aaf6515ab499b6e06a2c"], "tags": ["FIREFOX_63_0b12_BUILD2", "FIREFOX_63_0b12_RELEASE"]}], "date": 1538675214, "git_changesets": [null], "user": "mozilla@hocat.ca"}, "9935": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 0082062b759f342cb97dd2f46486ca29552b16e4 with FIREFOX_63_0b12_BUILD2 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "2caa61443127197598ca7545d418002cdcfa9497", "parents": ["0082062b759f342cb97dd2f46486ca29552b16e4"], "tags": []}], "date": 1538677168, "git_changesets": [null], "user": "ffxbld"}, "9936": {"changesets": [{"author": "Gabriele Svelto \u003cgsvelto@mozilla.com\u003e", "branch": "default", "desc": "Bug 1127855 - Handle title highlighting properly in all locales r=nalexander a=pascalc\n\nThis patch uses a case-insensitive matcher to highlight the title of a history\nentry that's been typed by the user. Previously the matching substring was\ncalculated manually as lowercase assuming that it's representation would have\nthe same number of characters as the original mixed case. In some locales\nhowerver this assumption is wrong leading to out-of-bound exceptions when\nhighlighting part of the title.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6661", "files": ["mobile/android/base/java/org/mozilla/gecko/home/BrowserSearch.java"], "git_node": null, "git_parents": [null], "node": "6be41a677718e648495777aaf49705538773d72c", "parents": ["2caa61443127197598ca7545d418002cdcfa9497"], "tags": []}, {"author": "Gabriele Svelto \u003cgsvelto@mozilla.com\u003e", "branch": "default", "desc": "Bug 1494203 - Ensure the pattern we're highlighting is not interpreted as a regular expression r=nalexander a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6891", "files": ["mobile/android/base/java/org/mozilla/gecko/home/BrowserSearch.java"], "git_node": null, "git_parents": [null], "node": "d35270b1cafc2426dc20e3f5df2d0097990e1c44", "parents": ["6be41a677718e648495777aaf49705538773d72c"], "tags": []}], "date": 1538745719, "git_changesets": [null, null], "user": "gsvelto@mozilla.com"}, "9937": {"changesets": [{"author": "Nicholas Hurley \u003churley@mozilla.com\u003e", "branch": "default", "desc": "Bug 1409570 - Ensure that transactions matched with http/2 pushed streams are properly finished. r=bagder, a=pascalc\n\nThere was an earlier fix to this, that fixed part of the issue, but that\nfix was racy. In the case where the transaction was matched with the\npushed stream before the pushed stream received its END_STREAM, and the\nresponse headers did not include a content-length, the transaction would\nnever notice that the data was done being sent. When that transaction\nwas necessary for the load event to fire, the page would get stuck in\nthe loading state until the user explicitly cancelled.\n\nThis new patch ensures that the transaction will notice the EOS by\nmaking sure the pushed stream gets inserted into the list of push\nstreams with data in the case described above. (The previous patch,\nwhich is still in the tree, is still necessary, but not sufficient, to\nfix the issue.)\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7298", "files": ["netwerk/protocol/http/Http2Session.cpp"], "git_node": null, "git_parents": [null], "node": "e181e77ac1586bfe3c56e8e971c05c767bf251aa", "parents": ["d35270b1cafc2426dc20e3f5df2d0097990e1c44"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1299001 - Ensure that the toolbox resets the preferences set when it is closed. r=ochameau, a=pascalc\n\nThis patch fixes a regression which has been likely introduced in the refactoring\nwe did in Bug 1222047 on Firefox 63.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7523", "files": ["devtools/client/aboutdebugging/test/browser_addons_debug_webextension_popup.js", "devtools/client/framework/toolbox.js"], "git_node": null, "git_parents": [null], "node": "24ee15badf0605bb429c87566eaf4f58c56e73b1", "parents": ["e181e77ac1586bfe3c56e8e971c05c767bf251aa"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1492308 - 1. Generate natives binding for all JNIObject classes; r=snorp, a=pascalc\n\nRight now we skip generating natives binding for a class if the class\ndoesn't have native methods. However, we should still generate the\nnatives binding for JNIObject classes because these classes can still be\nattached to C++ objects even without native methods.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7106\n\nBug 1492308 - 2. Create new native handle before clearing old one; r=snorp\n\nCreate a new native handle first before deleting any old ones, so we can\nbe sure the new handle would not have the same value as the old handle,\nwhich can confuse our code.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7107\n\nBug 1492308 - 3. Add test for tapping after content crash; r=snorp\n\nAdd a test for the crash scenario where PZC is used after content\ncrashes and restarts.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7108\n\nBug 1492308 - 4. Add new mechanism for safely disposing native objects; r=snorp\n\nAdd a new mechanism in NativePtr::Detach to safely dispose objects. A\nnew disposer Runnable is passed to OnDetach functions. The OnDetach\nfunctions invoke the disposer after changing the object state. The\ndisposer then makes sure the object hasn't been attached to another\nnative object in the meantime. Disposal is only performed when the\ncurrent native object matches the original one.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7109\n\nBug 1492308 - 5. Make various objects use the new disposal mechanism; r=snorp\n\nMake LayerViewSupport, NPZCSupport, and GeckoEditableSupport use the new\ndisposal mechanism to ensure the disposal is performed safely.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7110", "files": ["mobile/android/annotations/src/main/java/org/mozilla/gecko/annotationProcessors/CodeGenerator.java", "mobile/android/annotations/src/main/java/org/mozilla/gecko/annotationProcessors/utils/Utils.java", "mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/ContentDelegateTest.kt", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/gfx/LayerSession.java", "mobile/android/geckoview/src/main/java/org/mozilla/gecko/gfx/PanZoomController.java", "widget/android/GeckoEditableSupport.cpp", "widget/android/GeckoEditableSupport.h", "widget/android/jni/Natives.h", "widget/android/nsWindow.cpp", "widget/android/nsWindow.h"], "git_node": null, "git_parents": [null], "node": "00ea8935b012372f3623ef15b4506b7f69f983bd", "parents": ["24ee15badf0605bb429c87566eaf4f58c56e73b1"], "tags": []}, {"author": "Daniel Stenberg \u003cdaniel@haxx.se\u003e", "branch": "default", "desc": "Bug 1495523 - Disable TRR after max-fails number of failed requests. r=valentin, a=pascalc\n\nMozReview-Commit-ID: 2dSEY6DuP2A\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7587", "files": ["modules/libpref/init/all.js", "netwerk/dns/TRR.cpp", "netwerk/dns/TRRService.cpp", "netwerk/dns/TRRService.h"], "git_node": null, "git_parents": [null], "node": "b75cfee22e1e01acd8f2d87780d787d43eeb15e7", "parents": ["00ea8935b012372f3623ef15b4506b7f69f983bd"], "tags": []}, {"author": "Razvan Caliman \u003crcaliman@mozilla.com\u003e", "branch": "default", "desc": "Bug 1494582 - Adjust toggle input direction for right-to-left layout. r=pbro, a=pascalc\n\nMozReview-Commit-ID: 5ItuYNHsmQt\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7623", "files": ["devtools/client/themes/common.css"], "git_node": null, "git_parents": [null], "node": "c0c2333f0ffa31ba84e55585f9225f0fe62b0793", "parents": ["b75cfee22e1e01acd8f2d87780d787d43eeb15e7"], "tags": []}, {"author": "Tim D. Smith \u003ctdsmith@mozilla.com\u003e", "branch": "default", "desc": "Bug 1494496 - Renew GEOLOCATION_REQUEST_GRANTED probe. r=jdm, a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7027", "files": ["toolkit/components/telemetry/Histograms.json"], "git_node": null, "git_parents": [null], "node": "135174a61d2db7777a05677af493e2ed23b8fe31", "parents": ["c0c2333f0ffa31ba84e55585f9225f0fe62b0793"], "tags": []}, {"author": "Andrea Marchesini \u003camarchesini@mozilla.com\u003e", "branch": "default", "desc": "Bug 1493629 - Better management of CSP EventListener for workers. r=ckerschb, a=pascalc", "files": ["dom/workers/WorkerPrivate.cpp"], "git_node": null, "git_parents": [null], "node": "01237eeedfac765312a1322b28719782c3a71731", "parents": ["135174a61d2db7777a05677af493e2ed23b8fe31"], "tags": []}], "date": 1538752208, "git_changesets": [null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9938": {"changesets": [{"author": "Ryan VanderMeulen \u003cryanvm@gmail.com\u003e", "branch": "default", "desc": "Backed out changesets 3886ffc45b71 and f6d84997277d (bug 1418470) for longer bake time.", "files": ["layout/style/test/mochitest.ini", "layout/style/test/support/blue-100x100.png", "layout/style/test/test_mask_image_CORS.html", "servo/components/style/properties/longhands/svg.mako.rs", "servo/components/style/values/specified/image.rs"], "git_node": null, "git_parents": [null], "node": "b1b3f1e5ec42a960fddf10f10ae8a0ecba93f784", "parents": ["01237eeedfac765312a1322b28719782c3a71731"], "tags": []}, {"author": "Steve Fink \u003csfink@mozilla.com\u003e", "branch": "default", "desc": "Bug 1487167 - Various DOM rooting issues. r=bz, a=RyanVM", "files": ["dom/base/ContentFrameMessageManager.cpp", "dom/base/ContentProcessMessageManager.cpp", "dom/base/CustomElementRegistry.cpp", "dom/bindings/DOMJSProxyHandler.cpp", "dom/serviceworkers/ServiceWorkerContainer.cpp"], "git_node": null, "git_parents": [null], "node": "3e4a2d14ca356812851c177c5d7fed4b32566e6f", "parents": ["b1b3f1e5ec42a960fddf10f10ae8a0ecba93f784"], "tags": []}], "date": 1538754098, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "9939": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 0082062b759f342cb97dd2f46486ca29552b16e4 with FIREFOX_63_0b12_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "c3df2456a08175e477a13e322b577a045d132cb9", "parents": ["3e4a2d14ca356812851c177c5d7fed4b32566e6f"], "tags": []}, {"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "Automatic version bump CLOSED TREE NO BUG a=release", "files": ["browser/config/version_display.txt"], "git_node": null, "git_parents": [null], "node": "8ad6d89e237e5b08064f61fecc5b8432749fda73", "parents": ["c3df2456a08175e477a13e322b577a045d132cb9"], "tags": []}], "date": 1538756211, "git_changesets": [null, null], "user": "ffxbld"}, "9940": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 0ad842642aa7bca6216b9606a103250f08af0188 with DEVEDITION_63_0b12_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "0ab725eb0f3d5f99a6b1a3af163270c02dda5b35", "parents": ["8ad6d89e237e5b08064f61fecc5b8432749fda73"], "tags": []}], "date": 1538756370, "git_changesets": [null], "user": "ffxbld"}, "9941": {"changesets": [{"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 01237eeedfac (bug 1493629) for wpt failures on ContentSecurityPolicy. a=backout", "files": ["dom/workers/WorkerPrivate.cpp"], "git_node": null, "git_parents": [null], "node": "9671f6ac6cbeae04e605a35ebda003d1006e2af5", "parents": ["0ab725eb0f3d5f99a6b1a3af163270c02dda5b35"], "tags": []}], "date": 1538758023, "git_changesets": [null], "user": "csabou@mozilla.com"}, "9942": {"changesets": [{"author": "Timothy Guan-tin Chien \u003ctimdream@gmail.com\u003e", "branch": "default", "desc": "Bug 1493089 - Cancel the pending animation instead of reversing it. r=Gijs, a=pascalc\n\nMy understanding of Web Animation API was wrong in bug 1449532. If a running\nanimation is pending, playing a new (reversed) animation will cause it to\nplay from the beginning of the new animation, instead of having the new animation\nto play, in reverse, from the current position.\n\nThis has caused the user to see a fade out animation that shouldn't take\nplace when the video loops, i.e. going from \"seeking\" to \"seeked\".\n\nThe code now probe into the state of the animation instance and cancel\nthe pending animation, reverse the running animation, or start the new\n(reversed) animation accordingly.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D6704", "files": ["toolkit/content/widgets/videocontrols.js", "toolkit/content/widgets/videocontrols.xml"], "git_node": null, "git_parents": [null], "node": "f52b00b9fd5945caa9b5c177599dd5639d063eb7", "parents": ["9671f6ac6cbeae04e605a35ebda003d1006e2af5"], "tags": []}, {"author": "Timothy Guan-tin Chien \u003ctimdream@gmail.com\u003e", "branch": "default", "desc": "Bug 1486278 - Workaround Bug 1495350 in video controls. r=Gijs,birtles, a=pascalc\n\nFor compositor animations, we don't guarantee the finished promise callback\nto run in the first frame after the animation finishes. By setting\nfill: both, we set the animation to fill until the main thread has a chance\nto catch up.\n\nA filling animation has to be cancelled explicitly, otherwise the\nvalue of the animating style will be locked at the last frame of the animation.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7317", "files": ["toolkit/content/widgets/videocontrols.js", "toolkit/content/widgets/videocontrols.xml"], "git_node": null, "git_parents": [null], "node": "4c33398398a55023ccae92d19ee0f18baf7f4a39", "parents": ["f52b00b9fd5945caa9b5c177599dd5639d063eb7"], "tags": []}, {"author": "Polly Shaw \u003cpolly.shaw@gmail.com\u003e", "branch": "default", "desc": "Bug 1489229 - Crash on MOZ_RELEASE_ASSERT which checks that WPAD is not being called if not explicitly requested by the user prefs. r=valentin, a=pascalc\n\nThe author did not isolate and fix the cause of the assertion failure,\nbut put in further diagnostics.The author did not isolate and fix the cause of the assertion failure,\nbut put in further diagnostics.\n* an additional assertion was put in on the main thread (which if\ntriggered would reveal the stack trace)\n* in one place where a previously a failure to read the network.proxy.type pref\nwas ignored, execution of WPAD is now halted with a warning.\n\nBesides these improved diagnostics, in nsPACMan::LoadPACFromURI where an\nasynchronous call was made to nsPACMan::StartLoading *before* the preconditions\nfor this call are set up was changed to be the other way around. The author\nsuspects that the previous code may have led to race conditions when\nLoadPACFromURI was not called from the main thread, although it is not obvious\nthat this would have caused such a crash.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5388", "files": ["netwerk/base/nsPACMan.cpp"], "git_node": null, "git_parents": [null], "node": "6375a647b5b70f0dc565f57cdeea2dbd476d8102", "parents": ["4c33398398a55023ccae92d19ee0f18baf7f4a39"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1489229 - Return early from WPAD runnable when pref has been changed. r=bagder, a=pascalc\n\nBug 356831 added a release assert that when performing WPAD the network.proxy.type pref is always 4 (PROXYCONFIG_WPAD).\nHowever, when changing the pref, the runnable is scheduled to run before the PAC thread is shutdown, so it will see the pref that is not PROXYCONFIG_WPAD, while attempting to do WPAD. To avoid this situation, we simply exit early when we detect the wrong pref value.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7617", "files": ["netwerk/base/nsPACMan.cpp"], "git_node": null, "git_parents": [null], "node": "dd37ab60c111c34e9160509c75297cc39d6c9e0d", "parents": ["6375a647b5b70f0dc565f57cdeea2dbd476d8102"], "tags": []}, {"author": "Matt Howell \u003cmhowell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1496094 - Fix determining the correct target path of a reparse point. r=rstrong, a=pascalc\n\nThe two standard reparse data buffer structs (SymbolicLinkReparseBuffer and\nMountPointReparseBuffer) both contain one UTF-16 array called PathBuffer which\ncontains two paths, the \"print name\" and the \"substitute name\", with no\nseparator between them. There are also fields in the struct that provide the\noffset and the length of both those paths (in bytes).\n\nI had originally missed that these were separate paths and that the print name\nwill typically not match the substitute name for file system links. This patch\ncorrects that oversight and uses the offsets to correctly check only the\nsubstitute name.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7645", "files": ["toolkit/mozapps/update/common/updatecommon.cpp"], "git_node": null, "git_parents": [null], "node": "32eb76185a118a033a7525161f31290fe062f1e2", "parents": ["dd37ab60c111c34e9160509c75297cc39d6c9e0d"], "tags": []}, {"author": "Matt Howell \u003cmhowell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1494900 - Part 1: Support optional command line arguments in the ExecInExplorer plugin. r=agashlin, a=RyanVM", "files": ["other-licenses/nsis/Contrib/ExecInExplorer/ExecInExplorer.cpp", "other-licenses/nsis/Plugins/ExecInExplorer.dll"], "git_node": null, "git_parents": [null], "node": "a48d5341b695f325fda0319f54613e24d9972c8e", "parents": ["32eb76185a118a033a7525161f31290fe062f1e2"], "tags": []}, {"author": "Matt Howell \u003cmhowell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1494900 - Part 2: Always use IE to show the uninstall survey on Win7/8. r=agashlin, a=RyanVM", "files": ["browser/installer/windows/nsis/uninstaller.nsi"], "git_node": null, "git_parents": [null], "node": "16e9bc01eb3dc02b8f608cba5825125bda12354d", "parents": ["a48d5341b695f325fda0319f54613e24d9972c8e"], "tags": []}, {"author": "Matt Howell \u003cmhowell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1495212 - Fix command line parameter checking in ExecInExplorer plugin. r=agashlin, a=pascalc\n\nBecause of a silly logic error I made in bug 1494900, the optional command line\nparameter support introduced there doesn't actually work at all; I reversed the\nsense of the check for the NSIS stack being empty. This fixes that by just using\nthe check that the popstring function was already doing.", "files": ["other-licenses/nsis/Contrib/ExecInExplorer/ExecInExplorer.cpp", "other-licenses/nsis/Plugins/ExecInExplorer.dll"], "git_node": null, "git_parents": [null], "node": "fc2af75c2aca83b9959f47b5696949beffe964ba", "parents": ["16e9bc01eb3dc02b8f608cba5825125bda12354d"], "tags": []}], "date": 1538771224, "git_changesets": [null, null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9943": {"changesets": [{"author": "ScottDowne \u003cscott.downe@gmail.com\u003e", "branch": "default", "desc": "Bug 1493041 - Topstories feed uninit can remove idle-daily observer before init has a chance to add it. r=k88hudson, a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7749", "files": ["browser/components/newtab/lib/TopStoriesFeed.jsm", "browser/components/newtab/test/unit/lib/TopStoriesFeed.test.js"], "git_node": null, "git_parents": [null], "node": "df28f33c9930120ca6aa568d8011ae94655aa7bc", "parents": ["fc2af75c2aca83b9959f47b5696949bef