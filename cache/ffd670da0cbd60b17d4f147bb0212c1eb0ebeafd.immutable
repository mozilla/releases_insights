ayout/reftests/floats/float-nowrap-2.html", "layout/reftests/floats/float-nowrap-3-ref.html", "layout/reftests/floats/float-nowrap-3.html", "layout/reftests/floats/float-nowrap-4-ref.html", "layout/reftests/floats/float-nowrap-4.html", "layout/reftests/floats/float-nowrap-5-ref.html", "layout/reftests/floats/float-nowrap-5.html", "layout/reftests/floats/float-nowrap-6.html", "layout/reftests/floats/float-nowrap-7.html", "layout/reftests/floats/float-nowrap-8.html", "layout/reftests/floats/float-nowrap-9.html", "layout/reftests/floats/reftest.list", "testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/css/CSS2/floats/float-nowrap-1-notref.html", "testing/web-platform/tests/css/CSS2/floats/float-nowrap-1.html", "testing/web-platform/tests/css/CSS2/floats/float-nowrap-2.html", "testing/web-platform/tests/css/CSS2/floats/float-nowrap-3-ref.html", "testing/web-platform/tests/css/CSS2/floats/float-nowrap-3.html", "testing/web-platform/tests/css/CSS2/floats/float-nowrap-4-ref.html", "testing/web-platform/tests/css/CSS2/floats/float-nowrap-4.html", "testing/web-platform/tests/css/CSS2/floats/float-nowrap-5-ref.html", "testing/web-platform/tests/css/CSS2/floats/float-nowrap-5.html", "testing/web-platform/tests/css/CSS2/floats/float-nowrap-6.html", "testing/web-platform/tests/css/CSS2/floats/float-nowrap-7.html", "testing/web-platform/tests/css/CSS2/floats/float-nowrap-8.html", "testing/web-platform/tests/css/CSS2/floats/float-nowrap-9.html"], "git_node": null, "git_parents": [null], "node": "6932f13cab4b201c3f1501adce7ef43b23ca80b0", "parents": ["d11f2e791af1f90eb47e972027000b5a17b35970"], "tags": []}, {"author": "Andreea Pavel \u003capavel@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 65b36a89443f (bug 1487649) for failing mochitest chrome at layout/base/tests/chrome/test_printpreview.xu", "files": ["dom/base/nsNodeUtils.cpp", "layout/base/tests/chrome/printpreview_helper.xul"], "git_node": null, "git_parents": [null], "node": "80a2b4e9547cb80289ae49e6a7dc98345addb4d0", "parents": ["6932f13cab4b201c3f1501adce7ef43b23ca80b0"], "tags": []}, {"author": "Mike Shal \u003cmshal@mozilla.com\u003e", "branch": "default", "desc": "Bug 1487840 - Trim tup's display of rust build scripts; r=chmanchester\n\nWe already trim the display of output lists for GENERATED_FILES scripts\nthat produce many outputs, so we should do the same for rust build\nscripts. This makes the terminal output of the build and the nodes from\n'tup graph' more readable.\n\nMozReview-Commit-ID: AftmrA4qJlr\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4797", "files": ["python/mozbuild/mozbuild/backend/tup.py"], "git_node": null, "git_parents": [null], "node": "64efa7d65fd1bdf6a7326ce758469453339d7d3d", "parents": ["80a2b4e9547cb80289ae49e6a7dc98345addb4d0"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1487591 - Make Selection treat AccessibleCaretEventHub as concrete class rather than nsISelectionListener r=smaug\n\nAccessibleCaretEventHub is an nsISelectionListener of Selection whose type is\n\"normal\".  This is added only when nsFrameSelection::Init() is called and\naccessible caret is enabled.  Additionally, nsFrameSelection::Init() is\nalways called immediately after creating nsFrameSelection.\n\nTherefore, when AccessibleCaretEventHub is installed to Selection, this is\nalways second selection listener and won't be installed multiple times.  So,\nSelection can store pointer of AccessibleCaretEventHub directly only when\nit's enabled and the Selection needs to notify it of selection change.\n\nThis patch makes Selection stores AccessibleCaretEventHub with RefPtr, then,\nmakes Selection::NotifySelectionListeners() call its OnSelectionChange()\nimmediately after AutoCopyListener.\n\nUnfortunately, this patch includes making of MOZ_CAN_RUN_SCRIPT_BOUNDARY and\nMOZ_CAN_RUN_SCRIPT a lot since some methods of AccessibleCaretEventHub are\nmarked as MOZ_CAN_RUN_SCRIPT and including AccessibleCaretEventHub.h into\nSelection.h causes compile the compile errors.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4733", "files": ["docshell/base/nsDocShell.h", "dom/base/Selection.cpp", "dom/base/Selection.h", "dom/base/nsCopySupport.h", "dom/base/nsDocumentEncoder.cpp", "dom/base/nsFocusManager.cpp", "dom/base/nsRange.h", "layout/base/AccessibleCaretEventHub.cpp", "layout/base/AccessibleCaretEventHub.h", "layout/base/PresShell.cpp", "layout/base/gtest/TestAccessibleCaretEventHub.cpp", "layout/base/moz.build", "layout/base/nsLayoutUtils.h", "layout/generic/nsCanvasFrame.cpp", "layout/generic/nsFrameSelection.cpp", "layout/generic/nsFrameSelection.h"], "git_node": null, "git_parents": [null], "node": "bdbd39b2251dd4effb6cf19fe07710118358bc4e", "parents": ["64efa7d65fd1bdf6a7326ce758469453339d7d3d"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1487659 - Make Selection treat SelectionChangeListener as a concrete class rather than nsISelectionListener r=smaug\n\nSelectionChangeListener is an nsISelectionListener class.  This is added only\nto Selection for \"normal\" and added by nsFrameSelection::Init() after\nAccessibleCaretEventHub.  So, we can make Selection directly treat\nSelectionChangeListener.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4757", "files": ["dom/base/Selection.cpp", "dom/base/Selection.h", "dom/base/SelectionChangeListener.cpp", "dom/base/SelectionChangeListener.h", "dom/base/moz.build", "layout/generic/nsFrameSelection.cpp"], "git_node": null, "git_parents": [null], "node": "18320a6e8444c623aadf8e1b42ef8a04ab31d203", "parents": ["bdbd39b2251dd4effb6cf19fe07710118358bc4e"], "tags": []}, {"author": "Sotaro Ikeda \u003csotaro.ikeda.g@gmail.com\u003e", "branch": "default", "desc": "Bug 1487001 - Use effective ScrollOffset to calculate visible rect of checkerboard. r=botond", "files": ["gfx/layers/apz/src/AsyncPanZoomController.cpp"], "git_node": null, "git_parents": [null], "node": "0509636cc5d54ee4abcc1864e69bc8d7aa29a3b0", "parents": ["c5716573049496e1514dbb8156eaf3ad7065854a"], "tags": []}, {"author": "Andreea Pavel \u003capavel@mozilla.com\u003e", "branch": "default", "desc": "Backed out 2 changesets (bug 1480900) for failing browser chrome at browser/extensions/formautofill/test/browser/browser_privacyPreferences.js on a CLOSED TREE\n\nBacked out changeset a55d81761fc4 (bug 1480900)\nBacked out changeset eaa2d0e9b62d (bug 1480900)", "files": ["browser/components/preferences/in-content/extensionControlled.js", "browser/components/preferences/in-content/privacy.js", "browser/components/preferences/in-content/privacy.xul", "browser/components/preferences/in-content/tests/browser_extension_controlled.js", "browser/locales/en-US/browser/preferences/preferences.ftl"], "git_node": null, "git_parents": [null], "node": "d974ef1647f3a78e04a7e9d9950b5794bf5e04d6", "parents": ["0509636cc5d54ee4abcc1864e69bc8d7aa29a3b0"], "tags": []}, {"author": "Jeff Muizelaar \u003cjmuizelaar@mozilla.com\u003e", "branch": "default", "desc": "Bug 1487647. Update webrender to commit 3fa5eb8aaa0172306bfdc5e87d1d0c9af39d103a", "files": ["gfx/webrender/src/display_list_flattener.rs", "gfx/webrender_bindings/revision.txt"], "git_node": null, "git_parents": [null], "node": "328589a86dd1140d64967737c53bb1144fb274a1", "parents": ["d974ef1647f3a78e04a7e9d9950b5794bf5e04d6"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1480900 - Part 1: Update the Content Blocking section copy based on the latest strings; r=johannh,flod\n", "files": ["browser/components/preferences/in-content/extensionControlled.js", "browser/components/preferences/in-content/privacy.xul", "browser/components/preferences/in-content/tests/browser_extension_controlled.js", "browser/locales/en-US/browser/preferences/preferences.ftl"], "git_node": null, "git_parents": [null], "node": "8e60483ec8240efee22522316f5210289e12cbd2", "parents": ["328589a86dd1140d64967737c53bb1144fb274a1"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1480900 - Part 2: Reorder the Privacy pane of the Preferences UI to move Content Blocking to the top, followed by Cookies & Site Data; r=johannh\n\nThe reason why I chose to do this dynamically instead of modifying the XUL markup\nwas to ensure that no changes are yet made in case the content blocking UI pref is\ndisabled.\n", "files": ["browser/components/preferences/in-content/privacy.js", "browser/extensions/formautofill/test/browser/browser_privacyPreferences.js"], "git_node": null, "git_parents": [null], "node": "d1c29bfb5ea928b822fe3ab08b678d03f480c0e6", "parents": ["8e60483ec8240efee22522316f5210289e12cbd2"], "tags": []}, {"author": "Denis Palmeiro \u003cdpalmeiro@mozilla.com\u003e", "branch": "default", "desc": "Bug 1485738: Add column number information to the JitSpew r=mgaudet\n\nSummary: It is currently quite difficult to debug minified scripts.  The JitSpew and profiler used to display only line numbers, so all of the output would be emitted as \"script:1\".  Column number information is now collected by the gecko profiler as of bug 785922.  The JitSpew should also emit column numbers so that it's easy to line up with the profiler output.\n\nReviewers: mgaudet\n\nReviewed By: mgaudet\n\nSubscribers: jandem\n\nBug #: 1485738\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4677", "files": ["js/src/jit/BaselineBailouts.cpp", "js/src/jit/BaselineCompiler.cpp", "js/src/jit/BaselineDebugModeOSR.cpp", "js/src/jit/BaselineIC.cpp", "js/src/jit/CodeGenerator.cpp", "js/src/jit/Ion.cpp", "js/src/jit/IonBuilder.cpp", "js/src/jit/IonIC.cpp", "js/src/jit/JitcodeMap.cpp", "js/src/jit/shared/CodeGenerator-shared.cpp"], "git_node": null, "git_parents": [null], "node": "3f831b709e370b14ccf9f06508760633cd6b312a", "parents": ["d1c29bfb