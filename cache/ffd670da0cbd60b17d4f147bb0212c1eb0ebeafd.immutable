metry/tests/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "a56c7bafe2d1174d1f5ad21d68372a7609867317", "parents": ["b326ad3d8f8f5a5cf5cbc9fc6cc0a12870de79f5"], "tags": []}, {"author": "Makoto Kato \u003cm_kato@ga2.so-net.ne.jp\u003e", "branch": "default", "desc": "Bug 1486314 - Use GetAsText. r=masayuki a=pascalc", "files": ["layout/forms/nsTextControlFrame.cpp"], "git_node": null, "git_parents": [null], "node": "d51352e7c73c3ac57b0f8f249972dc432c7c5a4c", "parents": ["a56c7bafe2d1174d1f5ad21d68372a7609867317"], "tags": []}, {"author": "Matt Howell \u003cmhowell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1490264 Part 1 - Correct Windows installer SFX stub vendor and description. r=agashlin a=pascalc", "files": ["other-licenses/7zstub/firefox/7zSD.sfx"], "git_node": null, "git_parents": [null], "node": "655bb2a8e2b5a3b187ba4982bc7ebdaa96389aa2", "parents": ["d51352e7c73c3ac57b0f8f249972dc432c7c5a4c"], "tags": []}, {"author": "Matt Howell \u003cmhowell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1490264 Part 2 - Document our SFX stub version resource edits. r=agashlin a=NPOTB\n\nAlso take the opportunity to add specific instructions about how to rebuild 7zSD.sfx.", "files": ["other-licenses/7zstub/README.mozilla"], "git_node": null, "git_parents": [null], "node": "2ebd5b9976ddca10fd121e97cccd3b3fc09769d1", "parents": ["655bb2a8e2b5a3b187ba4982bc7ebdaa96389aa2"], "tags": []}, {"author": "alwu \u003calwu@mozilla.com\u003e", "branch": "default", "desc": "Bug 1489375 - part1 : do not recreate AudioChannelAgent. r=padenot a=pascalc\n\nWhen calling resume() on a running AudioContext, there is no need to discard current AudioChannelAgent and then create a new one.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5799", "files": ["dom/media/webaudio/AudioDestinationNode.cpp"], "git_node": null, "git_parents": [null], "node": "9bad6b73be9d38192d0ac295518db33efae24e54", "parents": ["2ebd5b9976ddca10fd121e97cccd3b3fc0