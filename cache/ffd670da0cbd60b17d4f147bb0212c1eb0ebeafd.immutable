ith FIREFOX_RELEASE_63_BASE a=release DONTBUILD CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "db706cb47c7bb92103f0b6985a3d4e1ad7a93ee9", "parents": ["f96837a1bcfca4852479b6c4a6af78a64ac33a2f"], "tags": []}], "date": 1539598745, "git_changesets": [null], "user": "ffxbld-merge"}, "9980": {"changesets": [{"author": "Jamie Nicol \u003cjnicol@mozilla.com\u003e", "branch": "FIREFOX_63b_RELBRANCH", "desc": "Bug 1485441 - Don't enable robust buffer access on Adreno 630 devices r=jgilbert a=pascalc\n\nIt was causing the linking of some shaders to fail.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8207", "files": ["gfx/gl/GLContextProviderEGL.cpp"], "git_node": null, "git_parents": [null], "node": "40c8305fa9511f204c1378765d73c68ab9a06ea3", "parents": ["db706cb47c7bb92103f0b6985a3d4e1ad7a93ee9"], "tags": []}, {"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "FIREFOX_63b_RELBRANCH", "desc": "Bug 1494471 - Ignore the autofill threshold when autofilling URLs r=mak a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7361", "files": ["toolkit/components/places/UnifiedComplete.js", "toolkit/components/places/tests/unifiedcomplete/autofill_tasks.js"], "git_node": null, "git_parents": [null], "node": "33d3fba56989f5782602063b40c35dd3742c0e59", "parents": ["40c8305fa9511f204c1378765d73c68ab9a06ea3"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "FIREFOX_63b_RELBRANCH", "desc": "Bug 1495055 - Accept layout viewport updates from the main thread right away on Android. r=kats a=pascalc\n\nUsually APZ waits at least one transaction from the time the composition\nbounds (visual viewport) is updated, before updating the (layout) viewport,\nbut this causes problems due to the visual and layout viewport being out of\nsync during orientation changes and dynamic toolbar transitions on Android.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7368", "files": ["gfx/layers/apz/src/AsyncPanZoomController.cpp"], "git_node": null, "git_parents": [null], "node": "54af31d71170e1e3ebdfac20156dc65b3a045590", "parents": ["33d3fba56989f5782602063b40c35dd3742c0e59"], "tags": []}, {"author": "Botond Ballo \u003cbotond@mozilla.com\u003e", "branch": "FIREFOX_63b_RELBRANCH", "desc": "Bug 1495055 - Adjust the composited layout viewport in AdjustScrollForSurfaceShift(). r=kats a=pascalc\n\nDepends on D7368\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7369", "files": ["gfx/layers/FrameMetrics.cpp", "gfx/layers/FrameMetrics.h", "gfx/layers/apz/src/AsyncPanZoomController.cpp"], "git_node": null, "git_parents": [null], "node": "d4355974bccf97c944bda432accdea2ecf722c7a", "parents": ["54af31d71170e1e3ebdfac20156dc65b3a045590"], "tags": []}, {"author": "Stephen A Pohl \u003cspohl.mozilla.bugs@gmail.com\u003e", "branch": "FIREFOX_63b_RELBRANCH", "desc": "Bug 1498433: Ensure that crash reporter is in the foreground and focused on macOS. r=mstange a=pascalc", "files": ["toolkit/crashreporter/client/crashreporter_osx.mm"], "git_node": null, "git_parents": [null], "node": "2920a2227ae0ca772ed45d2ac3b037180d3c0159", "parents": ["d4355974bccf97c944bda432accdea2ecf722c7a"], "tags": []}], "date": 1539613616, "git_changesets": [null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "9981": {"changesets": [{"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "FIREFOX_63b_RELBRANCH", "desc": "Bug 1493659 - Part 2. Use buttonRef not the created reference function. r=birtles a=pascalc\n\nThis patch uses the buttonRef since the beta repository doesn't contain the\nchanges of bug 1494162. So we remove this created reference function.", "files": ["devtools/client/shared/components/menu/MenuButton.js"], "git_node": null, "git_parents": [null], "node": "e19d6a029c18b1b36bc66522cfac6590ff844d62", "parents": ["2920a2227ae0ca772ed45d2ac3b037180d3c0159"], "tags": []}], "date": 1539615161, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "9982": {"changesets": [{"author": "Ryan Hunt \u003crhunt@eqrion.net\u003e", "branch": "FIREFOX_63b_RELBRANCH", "desc": "Bug 1469486 - Protect main thread in-process access to WinCompositorWidget transparent surface. r=lsalzman, a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7178", "files": ["widget/windows/InProcessWinCompositorWidget.cpp", "widget/windows/InProcessWinCompositorWidget.h"], "git_node": null, "git_parents": [null], "node": "6641ad209d525686077ef92932d171021e8d99a4", "parents": ["e19d6a029c18b1b36bc66522cfac6590ff844d62"], "tags": ["FENNEC_63_0b15_BUILD1", "FENNEC_63_0b15_RELEASE"]}], "date": 1539617361, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "9983": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 6641ad209d525686077ef92932d171021e8d99a4 with FENNEC_63_0b15_BUILD1 a=release CLOSED TREE DONTBUILD", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "9534b781cd735e0f851b73f8e01f5e29cd8ce658", "parents": ["db706cb47c7bb92103f0b6985a3d4e1ad7a93ee9"], "tags": ["FIREFOX_BETA_63_END"]}], "date": 1539625613, "git_changesets": [null], "user": "ffxbld"}}
