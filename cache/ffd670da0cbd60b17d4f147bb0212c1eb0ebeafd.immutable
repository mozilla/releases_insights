675570aaaf2751bfd00", "parents": ["11dc9d2d679d7a4f56cafba28c62bd963dc208b3"], "tags": []}], "date": 1536243705, "git_changesets": [null], "user": "ccoroiu@mozilla.com"}, "9755": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP blocklist remote-settings - a=repo-update r=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5140", "files": ["browser/app/blocklist.xml", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/blocklists/addons.json", "services/settings/dumps/blocklists/certificates.json"], "git_node": null, "git_parents": [null], "node": "025879b600a55a8c1fe56c824873020935e6bf44", "parents": ["11ee04db91059fadedb83675570aaaf2751bfd00"], "tags": []}, {"author": "Tarek Ziad\u00e9 \u003ctarek@mozilla.com\u003e", "branch": "default", "desc": "Bug 1483164 - Move the timer test from onload. r=jmaher, a=test-only\n\nMoves the test to try to fix an intermittent failure on linux64-asan\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4908", "files": ["dom/tests/browser/perfmetrics/setinterval.html", "dom/tests/browser/perfmetrics/settimeout.html"], "git_node": null, "git_parents": [null], "node": "1def879b54308d9a46a06575c18066c541f0fd3d", "parents": ["025879b600a55a8c1fe56c824873020935e6bf44"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1488681 - [wdspec] Fix detection of modifier key on MacOS. r=jgraham, a=test-only", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/webdriver/tests/actions/support/keys.py"], "git_node": null, "git_parents": [null], "node": "87dea34b75a2d44f4797606525dc6fae11729027", "parents": ["1def879b54308d9a46a06575c18066c541f0fd3d"], "tags": []}, {"author": "Kershaw Chang \u003ckershaw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1488441 - Extend cookie's expiring time from 1s to 3s. r=jdm, a=test-only\n\nThe fail log shows that the cookie's expiring time is too short(only 1s). The cookie could be already expired.\nA simple solution in this patch is just extending the expiring time to 3s.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5034", "files": ["netwerk/cookie/test/unit/test_eviction.js"], "git_node": null, "git_parents": [null], "node": "ad14a62f4df6d7a0d4e83490506d495a6369a5f4", "parents": ["87dea34b75a2d44f4797606525dc6fae11729027"], "tags": []}], "date": 1536243766, "git_changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "9756": {"changesets": [{"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1479532 - Part 2 - Use more sensible importance level for default notification channel. r=jchen a=pascalc\n\nPreviously, most of our notifications were silent, so we adopt a default\npriority of IMPORTANCE_LOW instead of IMPORTANCE_DEFAULT.\n\nSince we cannot change the priority setting for existing users on Nightly any\nmore, we technically have to retire the old default channel and replace it by\na new channel with a different ID. While in a way this is circumventing Google's\nAPI design and destroys any existing customisation users have set for that\nchannel, we are only using this exceptionally to *lower* the initial priority of\nour default notification channel, which we accidentally set too high. Besides,\nit is unlikely that there are many users who really want to receive all kinds of\nrandom Firefox notifications with a high priority.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4364", "files": ["mobile/android/base/java/org/mozilla/gecko/notifications/NotificationHelper.java"], "git_node": null, "git_parents": [null], "node": "2845948ee280f93f4027f3a3a7a54ecb297a3291", "parents": ["ad14a62f4df6d7a0d4e83490506d495a6369a5f4"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1480415 - Set aria-label on Reader View button and set menuitem-specific attributes directly there instead of on the command element. r=jaws a=pascalc", "files": ["browser/modules/ReaderParent.jsm", "toolkit/components/reader/test/browser_readerMode.js"], "git_node": null, "git_parents": [null], "node": "a78183c5d8baf0475705d79c3f15d8f7c862caa9", "parents": ["2845948ee280f93f4027f3a3a7a54ecb297a3291"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1488155 - Only no-op visited \u003c-\u003e unvisited changes. r=heycam a=pascalc\n\nOther changes should really be (and are) indistinguishable.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4847", "files": ["layout/base/RestyleManager.cpp", "layout/reftests/bugs/1488155-ref.html", "layout/reftests/bugs/1488155.html", "layout/reftests/bugs/reftest.list", "servo/components/style/invalidation/element/state_and_attributes.rs"], "git_node": null, "git_parents": [null], "node": "bd956f348b953c90975ae6a0dbfcae210c40bc0b", "parents": ["a78183c5d8baf0475705d79c3f15d8f7c862caa9"], "tags": []}, {"author": "Ting-Yu Lin \u003caethanyc@gmail.com\u003e", "branch": "default", "desc": "Bug 1488219 - Mark nsDateTimeControlFrame as a leaf frame. r=dholbert a=pascalc\n\nnsDateTimeControlFrame should be a leaf like all the other \u003cinput\u003e frames\nlike nsTextControlFrame, nsCheckboxRadioFrame, etc.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4985", "files": ["layout/forms/crashtests/1488219.html", "layout/forms/crashtests/crashtests.list", "layout/generic/nsFrameIdList.h"], "git_node": null, "git_parents": [null], "node": "05de4a3234ad8c4ecadd0bb611a250783b73f81a", "parents": ["bd956f348b953c90975ae6a0dbfcae210c40bc0b"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1488436 - Remove the duplicated 'Change block list' link in the Content Blocking section of Preferences; r=johannh a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4940", "files": ["browser/components/preferences/in-content/privacy.xul"], "git_node": null, "git_parents": [null], "node": "23a3c1ffff7551d9f184e39ea6e64d3889e86247", "parents": ["05de4a3234ad8c4ecadd0bb611a250783b73f81a"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1488785 - Part 1: Don't save persistent storage access permissions for private browsing contexts; r=baku a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5046", "files": ["toolkit/components/antitracking/AntiTrackingCommon.cpp"], "git_node": null, "git_parents": [null], "node": "36e1ad4e005779b4de225bf359170731b8e836f6", "parents": ["23a3c1ffff7551d9f184e39ea6e64d3889e86247"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1488785 - Part 2: Add support for running tests in private windows to the antitracking mini-testsuite; r=baku a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5047", "files": ["toolkit/components/antitracking/test/browser/head.js"], "git_node": null, "git_parents": [null], "node": "053fbe0ad409f4b65310b3f9ea8cb5a2999ef0a9", "parents": ["36e1ad4e005779b4de225bf359170731b8e836f6"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1488785 - Part 3: Add a test to ensure that setting a storage access permission in a private window won't leave a persistent trace in the permission manager; r=baku a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5048", "files": ["toolkit/components/antitracking/test/browser/browser.ini", "toolkit/components/antitracking/test/browser/browser_permissionInNormalWindows.js", "toolkit/components/antitracking/test/browser/browser_permissionInPrivateWindows.js"], "git_node": null, "