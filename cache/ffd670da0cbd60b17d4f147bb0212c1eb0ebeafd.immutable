rust/nom-1.2.4/tests/issues.rs", "third_party/rust/nom-1.2.4/tests/mp4.rs", "third_party/rust/nom-1.2.4/tests/omnom.rs", "third_party/rust/nom-1.2.4/tests/test1.rs"], "git_node": null, "git_parents": [null, null], "node": "0a92f8ace9e2d5f72f080236f158a839673f14f6", "parents": ["6ba3579108f3dc4bcf014bbb1e5be1110795986c", "af9308e581b85f79ad8b82bdd943df3d3cbc3c07"], "tags": []}, {"author": "Mantaroh Yoshinaga \u003cmantaroh@gmail.com\u003e", "branch": "default", "desc": "Bug 1473210 - Add meatball menu sanity tests. r=birtles\n\nThis test will check the following:\n * Open / Close the meatball menu with click the button.\n * Handling the keys. (Up / Down / Home / End)\n * Close the meatball menu with F1 key.\n * Close the meatball menu with Escape key.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3592", "files": ["devtools/client/framework/test/browser.ini", "devtools/client/framework/test/browser_toolbox_meatball.js"], "git_node": null, "git_parents": [null], "node": "d8fc943845d6919d1a2ae73fc9875f6e13e565a0", "parents": ["0a92f8ace9e2d5f72f080236f158a839673f14f6"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1486370 - Change nsAutoCopyListener to a static class r=smaug\n\nnsAutoCopyListener is a singleton class but refcountable and a selection\nlistener.  nsFrameSelection adds it to only normal Selection when it's on\nmacOS or it's enabled by the pref.  Additionally, it's always first selection\nlistener since it's added immediately after Selection instance is created.\n\nSo, we can make it a static class, and normal Selection instance should have\na bool to decide whether it should notify nsAutoCopyListener of its changes.\nThen, we can save the cost of grabbing it with local RefPtr and the virtual\ncall.\n\nAdditionally, this patch renames nsAutoCopyListener to mozilla::AutoCopyListener\nand optimizes constructor of nsFrameSelection (using bool var cache to retrieve\nthe pref, avoid retrieving the pref on macOS).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4504", "files": ["dom/base/Selection.cpp", "dom/base/Selection.h", "layout/build/nsLayoutStatics.cpp", "layout/generic/AutoCopyListener.h", "layout/generic/moz.build", "layout/generic/nsAutoCopyListener.h", "layout/generic/nsFrameSelection.cpp", "modules/libpref/init/StaticPrefList.h"], "git_node": null, "git_parents": [null], "node": "c36af4e5a515788961c6e6a2675e98a9bcff4308", "parents": ["d8fc943845d6919d1a2ae73fc9875f6e13e565a0"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1485253 - fix crashes due to dead windows' taskbar preview objects sticking around, r=m_kato,florian\n\nThe fix in bug 1418793 accidentally removed the onCloseWindow call, which\nmeant we were setting `.enabled` on taskbar window objects whose windows\nwere already dead, which was causing crashes.\n\nI've reverted the removal, and also added some nullchecking, because the\nC++ component shouldn't make it this easy for consumers to cause crashes.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4559", "files": ["browser/base/content/browser.js", "widget/windows/TaskbarPreview.cpp"], "git_node": null, "git_parents": [null], "node": "12a3fa1ec069f4b7fe1b04b757b31edaf064bcef", "parents": ["c36af4e5a515788961c6e6a2675e98a9bcff4308"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486226 - Correctly handle empty (invalid) href attributes in \u003clink\u003e elements (e.g. favicons). r=mak\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4487", "files": ["browser/actors/LinkHandlerChild.jsm", "browser/base/content/test/favicons/browser.ini", "browser/base/content/test/favicons/browser_invalid_href_fallback.js", "browser/base/content/test/favicons/file_invalid_href.html"], "git_node": null, "git_parents": [null], "node": "527b48f62d15a7bbb1f7e721199a222f7327de70", "parents": ["12a3fa1ec069f4b7fe1b04b757b31edaf064bcef"], "tags": []}, {"author": "Arshad Kazmi \u003carshadkazmi42@gmail.com\u003e", "branch": "default", "desc": "Bug 1333787 - BrowserAction TextColor on Inactive Window r=dao\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4635", "files": ["toolkit/themes/osx/global/toolbarbutton.css"], "git_node": null, "git_parents": [null], "node": "bc21091cba697353151e3290522b0bc22fe52daf", "parents": ["527b48f62d15a7bbb1f7e721199a222f7327de70"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486808 - Remove nsINavBookmarksService::unfiledBookmarksFolder and PlacesUtils.unfiledBookmarksFolderId. r=mak\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4456", "files": ["browser/components/places/tests/browser/browser_controller_onDrop_tagFolder.js", "toolkit/components/places/PlacesDBUtils.jsm", "toolkit/components/places/PlacesUtils.jsm", "toolkit/components/places/nsINavBookmarksService.idl", "toolkit/components/places/nsNavBookmarks.cpp", "toolkit/components/places/tests/bookmarks/test_bookmarks_notifications.js", "toolkit/components/places/tests/bookmarks/test_bookmarkstree_cache.js", "toolkit/components/places/tests/bookmarks/test_nsINavBookmarkObserver.js", "toolkit/components/places/tests/head_common.js", "toolkit/components/places/tests/legacy/test_bookmarks.js", "toolkit/components/places/tests/maintenance/test_preventive_maintenance.js", "toolkit/components/places/tests/sync/test_bookmark_kinds.js", "toolkit/components/places/tests/sync/test_bookmark_structure_changes.js", "toolkit/components/places/tests/sync/test_bookmark_value_changes.js", "toolkit/components/places/tests/unit/test_mozIAsyncLivemarks.js"], "git_node": null, "git_parents": [null], "node": "9de4c7559795d4d6d89c3d223dfa73297af3934a", "parents": ["bc21091cba697353151e3290522b0bc22fe52daf"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1484914 - Never append duplicate access key hints r=bzbarsky\n\nOn macOS, access keys are not visually observable.\n\nOn Linux and Windows, access keys are underlined.\nMoreover, if intl.menuitems.alwaysappendaccesskeys is set, the access\nkey is always appended as \"(X)\", optionally preceded by a space, where X\nis the uppercased version of the access key.\n\nThis commit updates the logic to not append a new \"(X)\" if this expected\nsuffix is already present at the end of the label.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3996", "files": ["layout/xul/nsTextBoxFrame.cpp", "toolkit/components/passwordmgr/nsLoginManagerPrompter.js", "toolkit/content/widgets/text.xml"], "git_node": null, "git_parents": [null], "node": "964610ef7e3f6f715a0422879a5da67765233407", "parents": ["9de4c7559795d4d6d89c3d223dfa73297af3934a"], "tags": []}, {"author": "fvsch \u003cflorens@fvsch.com\u003e", "branch": "default", "desc": "Bug 1464348 - Tweak base devtools colors to fix theme inconsistencies; r=jdescottes\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4300", "files": ["devtools/client/themes/common.css", "devtools/client/themes/dark-theme.css", "devtools/client/themes/fonts.css", "devtools/client/themes/markup.css", "devtools/client/themes/variables.css"], "git_node": null, "git_parents": [null], "node": "7d47dca5962e1dc0b3426814885f9a5bd27afb07", "parents": ["964610ef7e3f6f715a0422879a5da67765233407"], "tags": []}, {"author": "Marco Bonardo \u003cmbonardo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1485746 - Cursor gets reset to start of address bar on window switch. r=adw\n\nThis restores the previous behavior where we set the selection only when setting a new different value\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4528", "files": ["browser/base/content/browser.js", "browser/base/content/test/urlbar/browser.ini", "browser/base/content/test/urlbar/browser_autocomplete_cursor.js", "browser/base/content/test/urlbar/browser_urlOverflow.js", "browser/base/content/urlbarBindings.xml"], "git_node": null, "git_parents": [null], "node": "621979b26f697513f06f4c5f2db1d5ee580c4363", "parents": ["7d47dca5962e1dc0b3426814885f9a5bd27afb07"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486768 - Fix mocha tests;r=Honza.\n\nSome tests were failing because of change in the code:\n- arrow icon don't have an expanded class anymore but use aria-expanded\n- executionPoint property wasn't set on the ConsoleMessageType\n- networkUpdateRequest action expects a second argument\n- requestHeadersFromUploadStream is retrieved from requestPostData.uploadHeaders\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4444", "files": ["devtools/client/webconsole/test/components/console-api-call.test.js", "devtools/client/webconsole/test/components/page-error.test.js", "devtools/client/webconsole/test/store/network-messages.test.js", "devtools/client/webconsole/test/store/private-messages.test.js", "devtools/client/webconsole/types.js"], "git_node": null, "git_parents": [null], "node": "9550be79a88ef8807582722835275c4d20c83a4a", "parents": ["621979b26f697513f06f4c5f2db1d5ee580c4363"], "tags": []}, {"author": "Henri Sivonen \u003chsivonen@hsivonen.fi\u003e", "branch": "default", "desc": "Bug 1484987 - Avoid writing past the logical length of a string in XPCOM. r=froydnj\n\nMozReview-Commit-ID: 3qkhOiQduLQ\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3883", "files": ["xpcom/io/Base64.cpp", "xpcom/io/nsStorageStream.cpp"], "git_node": null, "git_parents": [null], "node": "e5989730338493a5e91a41325080b99af9236bb6", "parents": ["9550be79a88ef8807582722835275c4d20c83a4a"], "tags": []}, {"author": "Andrew Swan \u003caswan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1481918 Allow webextension test wrappers for externally installed extensions r=kmag\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3716", "files": ["toolkit/components/extensions/ExtensionXPCShellUtils.jsm"], "git_node": null, "git_parents": [null], "node": "169b47aeda91a0122dcb491a501db4d4543b5e48", "parents": ["10c2d7ed3aaff4334d186739c2978dcb8f46226d"], "tags": []}, {"author": "Andrew Swan \u003caswan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1481918 Add an unenrollment hook for shield addon studies r=mythmon\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3717", "files": ["toolkit/components/normandy/lib/AddonStudies.jsm", "toolkit/components/normandy/test/unit/test_addon_unenroll.js", "toolkit/components/normandy/test/unit/xpcshell.ini"], "git_node": null, "git_parents": [null], "node": "a8c76f3a18f9f6b57331aea619df59bc16552d24", "parents": ["169b47aeda91a0122dcb491a501db4d4543b5e48"], "tags": []}, {"author": "Daniel Zielas \u003czielas.daniel@gmail.com\u003e", "branch": "default", "desc": "Bug 1420996 - EnumSet enhancement. r=botond,Waldo", "files": ["mfbt/EnumSet.h"], "git_node": null, "git_parents": [null], "node": "01ed229650de691ba2a555401d504fcb471e62fa", "parents": ["a8c76f3a18f9f6b57331aea619df59bc16552d24"], "tags": []}, {"author": "Daniel Zielas \u003czielas.daniel@gmail.com\u003e", "branch": "default", "desc": "Bug 1420996 - Replace CompositorHitTestInfo with an EnumSet. r=botond", "files": ["gfx/ipc/GfxMessageUtils.h", "gfx/layers/apz/src/APZCTreeManager.cpp", "gfx/layers/apz/src/APZUtils.h", "gfx/layers/apz/src/HitTestingTreeNode.cpp", "gfx/layers/apz/test/gtest/TestEventRegions.cpp", "gfx/layers/apz/testutil/APZTestData.cpp", "gfx/layers/wr/WebRenderCommandBuilder.cpp", "gfx/src/CompositorHitTestInfo.h", "gfx/webrender_bindings/WebRenderAPI.cpp", "gfx/webrender_bindings/src/bindings.rs", "layout/generic/nsFrame.cpp", "layout/generic/nsGfxScrollFrame.cpp", "layout/painting/FrameLayerBuilder.cpp", "layout/painting/nsDisplayList.cpp"], "git_node": null, "git_parents": [null], "node": "413bd039c1263f3b9cef04e19b538e8d4097b721", "parents": ["01ed229650de691ba2a555401d504fcb471e62fa"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486358 - Fix nsISHTransaction.idl's formatting.\n\nBy replacing tabs with spaces, and cleaning up the comments slightly.", "files": ["docshell/shistory/nsISHTransaction.idl"], "git_node": null, "git_parents": [null], "node": "caf7b122907df2ac56a6d92d28f8b2c8dc9de118", "parents": ["413bd039c1263f3b9cef04e19b538e8d4097b721"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486358 - Change nsISHistory's transactions list to an nsTArray. r=nika\n\n- nsISHistoryInternal loses `rootTransaction`, and gains\n  GetTransactionAtIndex(). (The implementing class `nsSHistory` already\n  implemented a method by that method.)\n\n- nsSHistory loses `mListRoot` in favour of `mTransactions`. It also loses\n  `mLength`, because `mTransactions` tracks the length itself.\n\n- nsISHTransaction.{prev,next} are no longer needed.\n\n- nsISHTransaction.create() is no longer needed, because all it does now is set\n  the SHEntry, and we can use SetSHEntry() for that.\n\nOverall this deletes about 200 lines of code.", "files": ["docshell/shistory/nsISHTransaction.idl", "docshell/shistory/nsISHistoryInternal.idl", "docshell/shistory/nsSHTransaction.cpp", "docshell/shistory/nsSHTransaction.h", "docshell/shistory/nsSHistory.cpp", "docshell/shistory/nsSHistory.h", "toolkit/modules/sessionstore/SessionHistory.jsm"], "git_node": null, "git_parents": [null], "node": "e39b65db5b40779e5369616220222528a34e6d0b", "parents": ["caf7b122907df2ac56a6d92d28f8b2c8dc9de118"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486358 - Factor out shistory entry window code. r=nika\n\n(It's worth noting that I had to fix one of these instances in the previous\npatch, by adding a -1.)", "files": ["docshell/shistory/nsSHistory.cpp", "docshell/shistory/nsSHistory.h"], "git_node": null, "git_parents": [null], "node": "4ec8618d4fbab7ef985323056f18f160d082874e", "parents": ["e39b65db5b40779e5369616220222528a34e6d0b"], "tags": []}, {"author": "arthur.iakab \u003caiakab@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to inbound", "files": [], "git_node": null, "git_parents": [null, null], "node": "a278fa75aa70031a56ded21803f59868861cff23", "parents": ["4ec8618d4fbab7ef985323056f18f160d082874e", "af9308e581b85f79ad8b82bdd943df3d3cbc3c07"], "tags": []}, {"author": "Narcis Beleuzu \u003cnbeleuzu@mozilla.com\u003e", "branch": "default", "desc": "Backed out 2 changesets (bug 1420996) for marionette failures.\n\nBacked out changeset 413bd039c126 (bug 1420996)\nBacked out changeset 01ed229650de (bug 1420996)", "files": ["gfx/ipc/GfxMessageUtils.h", "gfx/layers/apz/src/APZCTreeManager.cpp", "gfx/layers/apz/src/APZUtils.h", "gfx/layers/apz/src/HitTestingTreeNode.cpp", "gfx/layers/apz/test/gtest/TestEventRegions.cpp", "gfx/layers/apz/testutil/APZTestData.cpp", "gfx/layers/wr/WebRenderCommandBuilder.cpp", "gfx/src/CompositorHitTestInfo.h", "gfx/webrender_bindings/WebRenderAPI.cpp", "gfx/webrender_bindings/src/bindings.rs", "layout/generic/nsFrame.cpp", "layout/generic/nsGfxScrollFrame.cpp", "layout/painting/FrameLayerBuilder.cpp", "layout/painting/nsDisplayList.cpp", "mfbt/EnumSet.h"], "git_node": null, "git_parents": [null], "node": "fe26ccb3ec3b981c2321951df210402a6f58bff8", "parents": ["a278fa75aa70031a56ded21803f59868861cff23"], "tags": []}, {"author": "shindli \u003cshindli@mozilla.com\u003e", "branch": "default", "desc": "Merge inbound to mozilla-central.  a=merge", "files": ["layout/painting/FrameLayerBuilder.cpp", "layout/painting/nsDisplayList.cpp"], "git_node": null, "git_parents": [null, null], "node": "09de350001f07965f787c19f298fd0cd6cd839fa", "parents": ["d8fc943845d6919d1a2ae73fc9875f6e13e565a0", "fe26ccb3ec3b981c2321951df210402a6f58bff8"], "tags": []}, {"author": "Margareta Eliza Balazs \u003cebalazs@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 76ccb62dd14d (bug 1480349) for bc failures on browser_urlbar_search.js a=backout", "files": ["browser/base/content/test/urlbar/browser_urlbarAddonIframe.js", "browser/base/content/urlbarBindings.xml"], "git_node": null, "git_parents": [null], "node": "815b46ed118286d682ce258e6147df5dc691eabf", "parents": ["09de350001f07965f787c19f298fd0cd6cd839fa"], "tags": []}, {"author": "shindli \u003cshindli@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland. a=merge CLOSED TREE", "files": ["browser/base/content/urlbarBindings.xml"], "git_node": null, "git_parents": [null, null], "node": "9a9cc00a4a7d5e964f70b10a2cd32e531da809a4", "parents": ["e5989730338493a5e91a41325080b99af9236bb6", "815b46ed118286d682ce258e6147df5dc691eabf"], "tags": []}, {"author": "Jonathan Kingston \u003cjkt@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486159 - fix devtools to use openWebLinkIn. r=Honza\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4393", "files": ["devtools/client/netmonitor/src/app.js"], "git_node": null, "git_parents": [null], "node": "80282ed4858572c6cbe9e2de75d933c8ab2056e8", "parents": ["9a9cc00a4a7d5e964f70b10a2cd32e531da809a4"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1487135 - Make the allocation of AuthorStyles for ShadowRoot lazy. r=xidorn,firefox-style-system-reviewers\n\nSo that we don't waste a bunch of memory with stuff like \u003csvg:use\u003e. I\nplan to shrink AuthorStyles further, but this should help regardless, and isn't\nvery complex.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4618", "files": ["dom/base/ShadowRoot.cpp", "dom/base/ShadowRoot.h", "layout/style/ServoStyleSet.cpp", "servo/components/style/dom.rs", "servo/components/style/gecko/wrapper.rs", "servo/components/style/stylist.rs"], "git_node": null, "git_parents": [null], "node": "94b793d954094f288baa3b4d5dffa377a245e9cf", "parents": ["80282ed4858572c6cbe9e2de75d933c8ab2056e8"], "tags": []}, {"author": "Jamie Nicol \u003cjnicol@mozilla.com\u003e", "branch": "default", "desc": "Bug 1471221 - Calculate intermediate surface bounds in advanced layers in pre-pass. r=mattwoodrow\n\nAdvanced layers was calculating incorrect visible regions for\ncontainer layers with intermediate surfaces, as it was not taking\nasync transform animations in to account. Rather than recursing the\ndepth of the tree for each layer to calculate this in\nOnPrepareToRender, do a single pre-pass at the start of the frame.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4522", "files": ["gfx/layers/mlgpu/ContainerLayerMLGPU.cpp", "gfx/layers/mlgpu/ContainerLayerMLGPU.h", "gfx/layers/mlgpu/FrameBuilder.cpp"], "git_node": null, "git_parents": [null], "node": "fc155fd5c1f0daefd419c784e1752c2ec0dc70f0", "parents": ["94b793d954094f288baa3b4d5dffa377a245e9cf"], "tags": []}, {"author": "Dan Minor \u003cdminor@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486817 - Use separate log modules for mediapipeline and rtplogger; r=bwc\n\nThis restores the separate mediapipeline and RtpLogger lazy log modules that\nwere unified with the Signaling log module in Bug 1402334.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4478", "files": ["media/webrtc/signaling/src/mediapipeline/MediaPipeline.cpp", "media/webrtc/signaling/src/mediapipeline/MediaPipelineFilter.cpp", "media/webrtc/signaling/src/mediapipeline/RtpLogger.cpp", "media/webrtc/signaling/src/mediapipeline/moz.build"], "git_node": null, "git_parents": [null], "node": "f8c805ba907179606280538953be78abdfb8f6b7", "parents": ["fc155fd5c1f0daefd419c784e1752c2ec0dc70f0"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1487135 - followup: Add a missing check. r=me\n", "files": ["layout/style/ServoStyleSet.cpp"], "git_node": null, "git_parents": [null], "node": "752786e0dd0120b9d768fce98f02eef6cde1f3f8", "parents": ["f8c805ba907179606280538953be78abdfb8f6b7"], "tags": []}, {"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-central repo-update HSTS HPKP blocklist remote-settings - a=repo-update r=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4660", "files": ["browser/app/blocklist.xml", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/blocklists/addons.json", "services/settings/dumps/blocklists/certificates.json"], "git_node": null, "git_parents": [null], "node": "7adbbec1286f91dc5e88f14b6327182254a3a0ca", "parents": ["752786e0dd0120b9d768fce98f02eef6cde1f3f8"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Bug 1487095 - Disable layout/style/test/test_use_counters.html for release and beta. r=emilio a=aryx", "files": ["layout/style/test/mochitest.ini"], "git_node": null, "git_parents": [null], "node": "71a191217b2854442c9372c17228ebffebf9fc70", "parents": ["815b46ed118286d682ce258e6147df5dc691eabf"], "tags": []}, {"author": "Narcis Beleuzu \u003cnbeleuzu@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 4e195f7b2d6b (bug 1486824) for clipboard failures on OSX browser_editcontrols_update. a=backout", "files": ["accessible/tests/browser/events/browser_test_textcaret.js", "browser/base/content/browser-captivePortal.js", "browser/base/content/browser.js", "browser/base/content/test/captivePortal/head.js", "browser/base/content/test/forms/browser_selectpopup.js", "browser/base/content/test/plugins/browser_private_clicktoplay.js", "browser/base/content/test/sidebar/browser_sidebar_adopt.js", "browser/components/customizableui/test/browser_sidebar_toggle.js", "browser/components/extensions/test/browser/browser_ext_sidebarAction_windows.js", "browser/components/sessionstore/test/browser_394759_perwindowpb.js", "dom/tests/browser/browser_bug1236512.js", "testing/mochitest/BrowserTestUtils/BrowserTestUtils.jsm"], "git_node": null, "git_parents": [null], "node": "1bd0f0baab41d587e900da8797467801d71568a5", "parents": ["71a191217b2854442c9372c17228ebffebf9fc70"], "tags": []}, {"author": "Narcis Beleuzu \u003cnbeleuzu@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland. a=merge", "files": ["browser/base/content/browser.js"], "git_node": null, "git_parents": [null, null], "node": "8638b90e8d25e1c3b4c54492007aff5aa2051523", "parents": ["7adbbec1286f91dc5e88f14b6327182254a3a0ca", "1bd0f0baab41d587e900da8797467801d71568a5"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1462227 - Enable hiding system titlebar on Deepin desktop, r=jhorak\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4212", "files": ["widget/gtk/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "c3a7f10f4e357b9f88b54c1409f4aa6b8c602df3", "parents": ["8638b90e8d25e1c3b4c54492007aff5aa2051523"], "tags": []}, {"author": "Michael Ratcliffe \u003cmratcliffe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1487385 - Add key prop to MenuItem call r=nchevobbe\n\nFixes this warning every time the toolbox is opened:\n\n\"Warning: Each child in an array or iterator should have a unique \"key\" prop.\n\nCheck the render method of `ToolboxTabs`. See https://fb.me/react-warning-keys for more information.\n    in MenuItem (created by ToolboxTabs)\n    in ToolboxTabs (created by ToolboxToolbar)\n    in div (created by ToolboxToolbar)\n    in ToolboxToolbar (created by ToolboxController)\n    in ToolboxController\"\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4671", "files": ["devtools/client/framework/components/ToolboxTabs.js"], "git_node": null, "git_parents": [null], "node": "d85d49538117bc902dae505c9ff6de555b9b89f9", "parents": ["c3a7f10f4e357b9f88b54c1409f4aa6b8c602df3"], "tags": []}, {"author": "Martin Stransky \u003cstransky@redhat.com\u003e", "branch": "default", "desc": "Bug 1464826 - [Wayland] Don't calculate popup offset relatively to mShell on Wayland as it's relative to mContainer, r=jhorak\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4073", "files": ["widget/gtk/nsWindow.cpp"], "git_node": null, "git_parents": [null], "node": "e0c2014dde1bdcab48c0e3308be93eb0640e9c93", "parents": ["d85d49538117bc902dae505c9ff6de555b9b89f9"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1465508 - Fix intermittent browser_ext_url_overrides_newtab.js r=mixedpuppy\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4656", "files": ["browser/components/extensions/test/browser/browser-common.ini", "browser/components/extensions/test/browser/browser_ext_url_overrides_newtab.js"], "git_node": null, "git_parents": [null], "node": "4a462d6e9c46f9ace4debb9ca80aa503e983baca", "parents": ["e0c2014dde1bdcab48c0e3308be93eb0640e9c93"], "tags": []}, {"author": "Mark Banner \u003cstandard8@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486783 - Fix some undefined property references to description and previewImageURL in PlacesUtils.jsm and History.jsm. r=mak\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4451", "files": ["toolkit/components/places/History.jsm", "toolkit/components/places/PlacesUtils.jsm", "toolkit/components/places/tests/history/test_update.js"], "git_node": null, "git_parents": [null], "node": "24ecf28225607eabadeb38c2a76244c980755495", "parents": ["4a462d6e9c46f9ace4debb9ca80aa503e983baca"], "tags": []}, {"author": "Henri Sivonen \u003chsivonen@hsivonen.fi\u003e", "branch": "default", "desc": "Bug 1484990 - Use BulkWrite instead of write past length via BeginWriting() in XHR. r=baku\n\nThe old code assumes that it's OK to use nsAString::BeginWriting() to write\npast the string's logical length if the string has enough capacity. This is\nbogus, because the string doesn't know of data written past its logical\nlength.\n\nThe BulkWrite API has been created precisely for this purpose and allows\norderly capacity-aware low-level writes to the string.\n\nMozReview-Commit-ID: BYQHl8Z9Fbd\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3886", "files": ["dom/xhr/XMLHttpRequestMainThread.cpp", "dom/xhr/XMLHttpRequestMainThread.h", "dom/xhr/XMLHttpRequestString.cpp", "dom/xhr/XMLHttpRequestString.h"], "git_node": null, "git_parents": [null], "node": "47f6709be61f3b1f1c29334d4bc9ab5076327f5c", "parents": ["24ecf28225607eabadeb38c2a76244c980755495"], "tags": []}, {"author": "Henri Sivonen \u003chsivonen@hsivonen.fi\u003e", "branch": "default", "desc": "Bug 1487309 - Improve AssignLiteral() and AppendLiteral() documentation to talk about u\"\" literals. r=froydnj\n\nMozReview-Commit-ID: 60NCtRgKRcn\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4641", "files": ["xpcom/string/nsTSubstring.h"], "git_node": null, "git_parents": [null], "node": "91dc93fd924586ad3db866bb5ea0db0260c8209d", "parents": ["47f6709be61f3b1f1c29334d4bc9ab5076327f5c"], "tags": []}, {"author": "Valentin Gosu \u003cvalentin.gosu@gmail.com\u003e", "branch": "default", "desc": "Bug 1483043 - Only call SerializeURI if running in e10s r=mak\n\nSome nsIURI types do not implement nsIIPCSerializableURI, and this is causing a crash in SerializeURI when running in thunderbird.\nThis shouldn't happen, since thunderbird is not running under e10s, so even attempting to serialize the URIs is pointless.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3402", "files": ["toolkit/components/places/History.cpp"], "git_node": null, "git_parents": [null], "node": "92c10215a3f6ab857556d37ebcab53a09d65a91c", "parents": ["91dc93fd924586ad3db866bb5ea0db0260c8209d"], "tags": []}, {"author": "yulia \u003cystartsev@mozilla.com\u003e", "branch": "default", "desc": "Bug 1485022 - use target.reconfigure to set paint flashing; r=ochameau\n\nSet the targets paintflashing via the reconfigure on the target.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3897", "files": ["devtools/client/framework/toolbox.js", "devtools/server/actors/targets/browsing-context.js"], "git_node": null, "git_parents": [null], "node": "ea662eb5edee485f324f85aa43699fcbb1b7b445", "parents": ["92c10215a3f6ab857556d37ebcab53a09d65a91c"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1381799 - Fix intermittent test_alarm_clear_non_matching_name r=aswan\n\nThe failure from the bug could happen if the test runs so slow that the\ntimer expires before the existence of the alarm is checked.\nTo avoid that failure, extend the lifetime of the alarm from 2 to 2000\nseconds.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4678", "files": ["toolkit/components/extensions/test/xpcshell/test_ext_alarms.js"], "git_node": null, "git_parents": [null], "node": "037dab36696a698bb5859ea14318a8ca99379b57", "parents": ["ea662eb5edee485f324f85aa43699fcbb1b7b445"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1487263 - set requesting principal for macOS drags, r=mstange\n\nThe requesting principal is now required for saving content through\nnsIWebBrowserPersist, and so drag sessions on macOS need to provide one, just\nlike drag sessions on Windows already do (see bug 664717).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4673", "files": ["widget/cocoa/nsDragService.mm"], "git_node": null, "git_parents": [null], "node": "57204974417c9b9feaba3c2306624f3dd5d57d12", "parents": ["037dab36696a698bb5859ea14318a8ca99379b57"], "tags": []}, {"author": "Dennis Schubert \u003cdschubert@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486885 - Remove error logging inside getBaseDomainFromURI(). r=Gijs\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4684", "files": ["browser/extensions/webcompat/content/lib/ua_overrider.jsm", "mobile/android/extensions/webcompat/content/lib/ua_overrider.jsm"], "git_node": null, "git_parents": [null], "node": "396e4cc1baef39466a97905f9b17356f8c9b5a20", "parents": ["57204974417c9b9feaba3c2306624f3dd5d57d12"], "tags": []}, {"author": "Nicolas Chevobbe \u003cnchevobbe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1487452 - Set devtools.debugger.features.map-await-expression to true only on Nightly; r=bgrins.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4691", "files": ["devtools/client/preferences/devtools-client.js"], "git_node": null, "git_parents": [null], "node": "a35cbdf27bd1f79b1d756866d5a28b8e29f4c4f8", "parents": ["396e4cc1baef39466a97905f9b17356f8c9b5a20"], "tags": []}, {"author": "Preeti Mukherjee \u003cpreetimukherjee98@gmail.com\u003e", "branch": "default", "desc": "Bug 1471920 - [mozbuild] Use shutil.which in Python 3 instead of vendored third-party package r=davehunt\n\nUse shutil.which in mozbuild for Python 3 instead of vendored third-party package, and enable mozversion tests that are fixed under Python 3 by this change.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4184", "files": ["python/mozbuild/mozbuild/base.py", "testing/mozbase/mozversion/tests/manifest.ini"], "git_node": null, "git_parents": [null], "node": "4efdc36c40f71a960493ba2229fb90c529b58e56", "parents": ["a35cbdf27bd1f79b1d756866d5a28b8e29f4c4f8"], "tags": []}, {"author": "Jacek Caban \u003cjacek@codeweavers.com\u003e", "branch": "default", "desc": "Bug 1390583 - Stylo: Build Broken with MinGW r=xidorn\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4554", "files": ["layout/style/ServoBindings.toml"], "git_node": null, "git_parents": [null], "node": "978b64d7fe7bc486716ac62ebd67cf43734f7b0e", "parents": ["4efdc36c40f71a960493ba2229fb90c529b58e56"], "tags": []}, {"author": "Dave Townsend \u003cdtownsend@oxymoronical.com\u003e", "branch": "default", "desc": "Bug 1487437: Only show a space for a pending icon if it started loading while the throbber was showing. r=dao.\n\nThis stops us from showing a pending space when an icon is added after loading is\ncomplete causing us to shift the title when both pending and previous icon are\nshown.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4694", "files": ["browser/base/content/browser.js", "browser/base/content/test/favicons/browser.ini", "browser/base/content/test/favicons/browser_title_flicker.js"], "git_node": null, "git_parents": [null], "node": "8ce5007ce60f6b4733daec81a47590d6c2568178", "parents": ["978b64d7fe7bc486716ac62ebd67cf43734f7b0e"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1486421 - Check all values for machine_only. r=Felipe\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4686", "files": ["browser/components/enterprisepolicies/WindowsGPOParser.jsm"], "git_node": null, "git_parents": [null], "node": "aec6c504c6c47890c2bf08b4147e5fe262759742", "parents": ["8ce5007ce60f6b4733daec81a47590d6c2568178"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1483153 - Let menulist popups inherit the font from their menulist parent. r=felipe", "files": ["toolkit/themes/linux/global/menu.css", "toolkit/themes/windows/global/menu.css"], "git_node": null, "git_parents": [null], "node": "fb2c0eb9ad707ed11f05e7159ba3a132ead10879", "parents": ["fe26ccb3ec3b981c2321951df210402a6f58bff8"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1483325 - re-enable sidebar test after checking for correct messages to get them out of the queue, rs=mixe