git_node": null, "git_parents": [null], "node": "f0427508d13a0b949999656ab75875d7d608db51", "parents": ["e66fd6806bbfdce5a2b56aa4f939573591982f84"], "tags": []}, {"author": "Matt Howell \u003cmhowell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486376 Part 3 - Apply our existing patches to the LZMA SDK code. r=agashlin\n\nThis simply applies the file other-licenses/7zstub/mozila_customizations.diff,\nwhich did not need to be changed in this patch series because it applies cleanly\nto the LZMA SDK code, which is organized in the same way as the 7-zip code.", "files": ["other-licenses/7zstub/src/CPP/7zip/Bundles/SFXSetup/SFXSetup.dsp", "other-licenses/7zstub/src/CPP/7zip/Bundles/SFXSetup/SfxSetup.cpp", "other-licenses/7zstub/src/CPP/7zip/Bundles/SFXSetup/resource.h", "other-licenses/7zstub/src/CPP/7zip/Bundles/SFXSetup/resource.rc", "other-licenses/7zstub/src/CPP/7zip/UI/FileManager/ProgressDialog.cpp"], "git_node": null, "git_parents": [null], "node": "7cf0234dc9e8b86ca0ac90231395c3e6cb936e83", "parents": ["f0427508d13a0b949999656ab75875d7d608db51"], "tags": []}, {"author": "Matt Howell \u003cmhowell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486376 Part 4 - Update the version number in the 7-zip SFX manifest. r=agashlin", "files": ["other-licenses/7zstub/firefox/7zSD.manifest"], "git_node": null, "git_parents": [null], "node": "e442565e6d4b2fe82159fffcc79513bcd0ba6ee1", "parents": ["7cf0234dc9e8b86ca0ac90231395c3e6cb936e83"], "tags": []}, {"author": "Matt Howell \u003cmhowell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486376 Part 5 - Rebuild the binary SFX stub. r=agashlin", "files": ["other-licenses/7zstub/firefox/7zSD.sfx"], "git_node": null, "git_parents": [null], "node": "12156c3935c34359a7f75627632abe6c855ec17b", "parents": ["e442565e6d4b2fe82159fffcc79513bcd0ba6ee1"], "tags": []}, {"author": "Matt Howell \u003cmhowell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486376 Part 6 - Update the 7zstub readme to reflect the new contents. r=agashlin\n\nAlso added line breaks to make the file more readable (while making the diff\nharder to review).", "files": ["other-licenses/7zstub/README.mozilla"], "git_node": null, "git_parents": [null], "node": "da29148fc085264b11d70d1781a79ecc17dea651", "parents": ["12156c3935c34359a7f75627632abe6c855ec17b"], "tags": []}, {"author": "Gurzau Raul \u003crgurzau@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to inbound.  a=merge CLOSED TREE", "files": [], "git_node": null, "git_parents": [null, null], "node": "f2b2045a17cee9ed5d7a1dee39afb5062f359a4e", "parents": ["da29148fc085264b11d70d1781a79ecc17dea651", "ff62eab1d2ed5abce22e2922bc0103b0a3df9000"], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486962 - Ensure frame is associated with background images with WebRender. r=mstange\n\nThe frame for a background image should be associated with the image\nrequest. This was done on the non-WebRender path in\nnsCSSRendering::PaintStyleImageLayerWithSC but otherwise missing for the\nWebRender path. This is important because the association is what allows\nthe FRAME_UPDATE from imagelib to cause a repaint. Without it, it will\nmanifest as incomplete or missing background images, in particular after\nthe background image SourceSurface has been released to save memory.", "files": ["layout/painting/nsCSSRendering.cpp"], "git_node": null, "git_parents": [null], "node": "c5c7d67c2b5b43e08c08e4d592112b4be81af76e", "parents": ["f2b2045a17cee9ed5d7a1dee39afb5062f359a4e"], "tags": []}, {"author": "Jeff Muizelaar \u003cjmuizelaar@mozilla.com\u003e", "branch": "default", "desc": "Bug 1452426. Hook up invalidation testing in WebRender. r=mstange\n", "files": ["gfx/layers/wr/WebRenderCommandBuilder.cpp"], "git_node": null, "git_parents": [null], "node": "3cf0bec611e10d70c41dcd8548559e7f77e2d65c", "parents": ["c5c7d67c2b5b43e08c08e4d592112b4be81af76e"], "tags": []}, {"author": "Jeff Muizelaar \u003cjmuizelaar@mozilla.com\u003e", "branch": "default", "desc": "Bug 1452426. Hook up invalidation testing in WebRender. r=mstange\n", "files": [], "git_node": null, "git_parents": [null], "node": "77fa433348797871bf307483a5624b07a7b4c9da", "parents": ["3cf0bec611e10d70c41dcd8548559e7f77e2d65c"], "tags": []}, {"author": "Alexis Beingessner \u003ca.beingessner@gmail.com\u003e", "branch": "default", "desc": "Bug 1453953 - natively implement xul textboxes. r=mstange\n", "files": ["layout/base/nsLayoutUtils.cpp", "layout/reftests/bugs/reftest.list", "layout/reftests/text-shadow/reftest.list", "layout/xul/nsTextBoxFrame.cpp"], "git_node": null, "git_parents": [null], "node": "dd278a6e5c73796f269ff13ec5036da5a0c7813b", "parents": ["77fa433348797871bf307483a5624b07a7b4c9da"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1487330 - Make mozconfig.{asan,lto,tsan} use mozconfig.linux. r=froydnj\n\nThose mozconfigs do things in common that are already in\nmozconfig.linux. Let's just use that.\n\nThis will make the build have the binutils toolchain in PATH rather than\npassing it to CC/CXX, which is better because it also makes the build\nuse tools such as ar, ranlib, objcopy from the binutils toolchain,\nrather than the old system ones.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4649\n", "files": ["build/unix/mozconfig.asan", "build/unix/mozconfig.lto", "build/unix/mozconfig.tsan"], "git_node": null, "git_parents": [null], "node": "e1eac066705ff183de649f094718a4c114af3826", "parents": ["dd278a6e5c73796f269ff13ec5036da5a0c7813b"], "tags": []}, {"author": "Soeren Hentzschel \u003ccadeyrn@ymail.com\u003e", "branch": "default", "desc": "Bug 1483431 - improve design of about:policies. r=felipe", "files": ["browser/components/enterprisepolicies/content/aboutPolicies.css", "browser/components/enterprisepolicies/content/aboutPolicies.js", "browser/components/enterprisepolicies/helpers/WebsiteFilter.jsm", "browser/components/enterprisepolicies/schemas/policies-schema.json"], "git_node": null, "git_parents": [null], "node": "cd82664c5a141ff4b30f0bd0300f754adee3e262", "parents": ["e1eac066705ff183de649f094718a4c114af3826"], "tags": []}, {"author": "Soeren Hentzschel \u003ccadeyrn@ymail.com\u003e", "branch": "default", "desc": "Bug 1487557 - Make all rows of active policies to have the same number of columns. r=felipe", "files": ["browser/components/enterprisepolicies/content/aboutPolicies.js"], "git_node": null, "git_parents": [null], "node": "bfe71056fd0f2f81a824a1b05132c80083eaa754", "parents": ["cd82664c5a141ff4b30f0bd0300f754adee3e262"], "tags": []}, {"author": "Nicholas Nethercote \u003cnnethercote@mozilla.com\u003e", "branch": "default", "desc": "Bug 1487333 - Remove nsIExternalSharingAppService. r=jchen\n\nIt's unused.\n\nThe patch also renames nsIExternalSharingAppService.idl as\nnsISharingHandlerApp.idl, because the only thing left in the file is the\ndeclaration of nsISharingHandlerApp.", "files": ["docshell/build/nsDocShellModule.cpp", "uriloader/exthandler/android/nsAndroidHandlerApp.h", "uriloader/exthandler/android/nsExternalSharingAppService.cpp", "uriloader/exthandler/android/nsExternalSharingAppService.h", "uriloader/exthandler/moz.build", "uriloader/exthandler/nsIExternalSharingAppService.idl", "uriloader/exthandler/nsISharingHandlerApp.idl", "uriloader/exthandler/unix/nsExternalSharingAppService.h"], "git_node": null, "git_parents": [null], "node": "6b5dfb276159213aed3f93f6dac6d8ad85fec86e", "parents": ["bfe71056fd0f2f81a824a1b05132c80083eaa754"], "tags": []}, {"author": "Gurzau Raul \u003crgurzau@mozilla.com\u003e", "branch": "default", "desc": "Merge inbound to mozilla-central.  a=merge", "files": ["other-licenses/7zstub/src/Asm/x86/7zAsm.asm", "other-licenses/7zstub/src/C/7zVersion.h", "other-licenses/7zstub/src/C/Alloc.c", "other-licenses/7zstub/src/C/Alloc.h", "other-licenses/7zstub/src/C/Bcj2.c", "other-licenses/7zstub/src/C/Bcj2