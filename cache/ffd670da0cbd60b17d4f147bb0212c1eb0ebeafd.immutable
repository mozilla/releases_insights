hor": "Brian Hackett \u003cbhackett1024@gmail.com\u003e", "branch": "default", "desc": "Bug 1486556 - Avoid unlocking the helper thread state lock after looking for tasks to perform, r=jandem.", "files": ["js/src/vm/HelperThreads.cpp", "mfbt/RecordReplay.h", "toolkit/recordreplay/Thread.cpp"], "git_node": null, "git_parents": [null], "node": "fc437d64c83157d3539c8b337d4048e00cd373ea", "parents": ["85e1ddee9e8f5421f9834f406027857413cfdf4f"], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486318 - Actually apply transform from canvas pattern when drawing text to a canvas. r=lsalzman", "files": ["dom/canvas/CanvasRenderingContext2D.cpp"], "git_node": null, "git_parents": [null], "node": "ac1682b691d8a2d93531d613d203a9604c2f79af", "parents": ["fc437d64c83157d3539c8b337d4048e00cd373ea"], "tags": []}, {"author": "Narcis Beleuzu \u003cnbeleuzu@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to inbound.", "files": [], "git_node": null, "git_parents": [null, null], "node": "4ca69733bd89adf297f823f272739b4c742dd7e0", "parents": ["ac1682b691d8a2d93531d613d203a9604c2f79af", "1bd0f0baab41d587e900da8797467801d71568a5"], "tags": []}, {"author": "Brian Hackett \u003cbhackett1024@gmail.com\u003e", "branch": "default", "desc": "Backed out changeset fc437d64c831 (bug 1486556) for breaking coordination between record/replay system and helper threads.", "files": ["js/src/vm/HelperThreads.cpp", "mfbt/RecordReplay.h", "toolkit/recordreplay/Thread.cpp"], "git_node": null, "git_parents": [null], "node": "54c5a8af9831a0a36ed39c6f4581101acdcae79b", "parents": ["4ca69733bd89adf297f823f272739b4c742dd7e0"], "tags": []}, {"author": "Narcis Beleuzu \u003cnbeleuzu@mozilla.com\u003e", "branch": "default", "desc": "Merge inbound to mozilla-central. a=merge", "files": ["browser/components/extensions/test/browser/browser-common.ini"], "git_node": null, "git_parents": [null, null], "node": "c317d6b31d9c951c9357fb9a49d2686a3efcfe2f", "parents": ["91dc93fd924586ad3db866bb5ea0db0260c8209d", "54c5a8af9831a0a36ed39c6f4581101acdcae79b"], "tags": []}, {"author": "Narcis Beleuzu \u003cnbeleuzu@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland. a=merge CLOSED TREE", "files": [], "git_node": null, "git_parents": [null, null], "node": "7e58b028df95389c1994c268161a0c7ba6e7f957", "parents": ["aec6c504c6c47890c2bf08b4147e5fe262759742", "c317d6b31d9c951c9357fb9a49d2686a3efcfe2f"], "tags": []}, {"author": "Myk Melez \u003cmyk@mykzilla.org\u003e", "branch": "default", "desc": "Bug 1482810 - set COMPILE_FLAGS var to hide warnings for Rust crates r=chmanchester\n\nIn conjunction with the cc crate changes in https://github.com/alexcrichton/cc-rs/pull/342 (which I'll land in https://phabricator.services.mozilla.com/D4699), this hides warnings generated by C code in Rust crates (by removing warnings flags from CFLAGS when compiling Rust libraries).\n\nMozReview-Commit-ID: 9CZgLGbWjbA\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3939", "files": ["build/clang-plugin/tests/moz.build", "build/templates.mozbuild", "config/rules.mk", "js/src/old-configure.in", "old-configure.in", "python/mozbuild/mozbuild/frontend/context.py", "python/mozbuild/mozbuild/test/frontend/data/disable-compiler-warnings/moz.build", "python/mozbuild/mozbuild/test/frontend/data/disable-compiler-warnings/test1.c", "python/mozbuild/mozbuild/test/frontend/test_emitter.py"], "git_node": null, "git_parents": [null], "node": "b9197ece79556d5e565bb5350383b75f1448f06c", "parents": ["7e58b028df95389c1994c268161a0c7ba6e7f957"], "tags": []}, {"author": "Myk Melez \u003cmyk@mykzilla.org\u003e", "branch": "default", "desc": "Bug 1482810 - update cc crate from 1.0.18 to 1.0.23 r=froydnj\n\nThe fix for bug 1482810 requires an upstream change to the cc crate: if CFLAGS is defined, then don't enable warnings by default.  That change was included in cc crate version 1.0.23, and this change vendors that version of the cc crate into mozilla-central.\n\nMozReview-Commit-ID: Krfrs1dSN9d\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4699", "files": ["Cargo.lock", "third_party/rust/cc/.cargo-checksum.json", "third_party/rust/cc/.travis.yml", "third_party/rust/cc/Cargo.toml", "third_party/rust/cc/README.md", "third_party/rust/cc/src/lib.rs", "third_party/rust/cc/tests/test.rs"], "git_node": null, "git_parents": [null], "node": "7eae34bda99ca4c30b6f995fc85a69a58e56664c", "parents": ["b9197ece79556d5e565bb5350383b75f1448f06c"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1453723 - actually wait for the homepage to load, r=bgrins\n\nExplicitly specify which load we're waiting for to avoid intermittent oranges\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4692", "files": ["browser/base/content/test/urlbar/browser_urlbarAboutHomeLoading.js"], "git_node": null, "git_parents": [null], "node": "6b9c111f3da9939b88bab94a5e7220c72797962c", "parents": ["7eae34bda99ca4c30b6f995fc85a69a58e56664c"], "tags": []}, {"author": "Henri Sivonen \u003chsivonen@hsivonen.fi\u003e", "branch": "default", "desc": "Bug 1487310 - Let XPCOM strings manage their own buffer in LossyUTF8ToUTF16(). r=keeler\n\nThis does not change the outward behavior of LossyUTF8ToUTF16(). Both\nToNewUnicode() and CopyASCIItoUTF16() convert from Latin1 to UTF-16.\n\nMozReview-Commit-ID: 8SDgvoGaN4A\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4639", "files": ["security/manager/ssl/nsNSSCertHelper.cpp", "security/manager/ssl/nsNSSCertHelper.h"], "git_node": null, "git_parents": [null], "node": "c45b51ec248e6588993262fa1a558a24e3886cd4", "parents": ["6b9c111f3da9939b88bab94a5e7220c72797962c"], "tags": []}, {"author": "Jan Henning \u003cjh+bugzilla@buttercookie.de\u003e", "branch": "default", "desc": "Bug 1482105 - Use dedicated notification channel for the built-in updater. r=jchen\n\nTo avoid cluttering our notification settings on builds not using the built-in\nupdater, we only add that channel when required.\nPassing a null channelId to the system NotificationManager, which can then\nhappen if someone attempts to use the UPDATER channel anyway, even though\nMOZ_UPDATER is false, is safe. It just means that the NotificationManager will\nreturn the system's default channel, which will silently swallow any\nnotifications posted to it from apps targeting Android O or above.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4584", "files": ["mobile/android/base/java/org/mozilla/gecko/notifications/NotificationHelper.java", "mobile/android/base/java/org/mozilla/gecko/updater/Updater.java", "mobile/android/base/locales/en-US/android_strings.dtd", "mobile/android/base/strings.xml.in"], "git_node": null, "git_parents": [null], "node": "8d407fff0058f1a1b283a003a48525b36ff646ba", "parents": ["c45b51ec248e6588993262fa1a558a24e3886cd4"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1481439 - Print debugging info when browser_ext_omnibox.js fails r=aswan\n\nPrint useful information about the visible autocompletion results before\nfailing the test, for debugging.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4700", "files": ["browser/components/extensions/test/browser/browser_ext_omnibox.js"], "git_node": null, "git_parents": [null], "node": "e642f1e694bbe5a0ed5b798f53a70bb7d909375f", "parents": ["8d407fff0058f1a1b283a003a48525b36ff646ba"], "tags": []}, {"author": "Michael Kelly \u003cmkelly@mozilla.com\u003e", "branch": "default", "desc": "about:crashes: updated user interface (bug 1476062); r=mconley,flod\n\nThe about:crashes page's user interface is being updated (bug 1463515).\n\n- changed crash submission to be done through button press instead of link clicking\n    - this allows users to know that they are submitting the crash\n- updated visuals to match new mock-up\n    - mock-up image: https://bug1463515.bmoattachments.org/attachment.cgi?id=8990380\n- added new Fluent strings that are needed for the new user interface\n- modernized the surrounding code\n\nDifferential Revision: https://phabricator.services.mozilla.com/D2792", "files": ["toolkit/crashreporter/content/crashes.css", "toolkit/crashreporter/content/crashes.js", "toolkit/crashreporter/content/crashes.xhtml", "toolkit/crashreporter/test/browser/browser_aboutCrashes.js", "toolkit/crashreporter/test/browser/browser_aboutCrashesResubmit.js", "toolkit/crashreporter/test/browser/browser_bug471404.js", "toolkit/crashreporter/test/browser/browser_clearReports.js", "toolkit/locales/en-US/crashreporter/aboutcrashes.ftl"], "git_node": null, "git_parents": [null], "node": "e4b8f03094c3ea69d6b596c686b1c56d03fe979d", "parents": ["e642f1e694bbe5a0ed5b798f53a70bb7d909375f"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1487443 Bump MinGW Version to correct PEB Struct and ICU-conflicting daylight macro r=froydnj\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4685", "files": ["taskcluster/scripts/misc/build-clang-7-pre-mingw.sh"], "git_node": null, "git_parents": [null], "node": "1325b7962b0f4c03c13572afb58bf8e4446654cb", "parents": ["e4b8f03094c3ea69d6b596c686b1c56d03fe979d"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1480457 Address template parameter shadowing r=aklotz\n\nThis code throws an error in clang on the inner MMPolicy:\nerror: declaration of 'MMPolicy' shadows template parameter\n\nNotethat the template parameter is declared earlier at the\nclass definition of ReadOnlyTargetFunction\n\nMozReview-Commit-ID: buLE9d22YS\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4571", "files": ["mozglue/misc/interceptor/TargetFunction.h"], "git_node": null, "git_parents": [null], "node": "0e0d83a0de607d6c30168482f24b02af51bb0e48", "parents": ["1325b7962b0f4c03c13572afb58bf8e4446654cb"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1480457 Don't pass 'false' into a pointer field; pass nullptr r=aklotz\n\nMozReview-Commit-ID: FUA6jMwCV1d\n\nDepends on D4571\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4572", "files": ["gfx/thebes/gfxGDIFontList.cpp"], "git_node": null, "git_parents": [null], "node": "ddcf3daa268ca6ee795480813e91dd8ac3d688d8", "parents": ["0e0d83a0de607d6c30168482f24b02af51bb0e48"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1480457 Change a ui64 suffix to ULL r=aklotz\n\nMozReview-Commit-ID: KhWX2WiejtR\n\nDepends on D4572\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4573", "files": ["browser/app/winlauncher/LauncherProcessWin.cpp"], "git_node": null, "git_parents": [null], "node": "87c2ed42acf0614941589b6bc2e33a3690e9c063", "parents": ["ddcf3daa268ca6ee795480813e91dd8ac3d688d8"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1480457 - Cast a PEB entry into void* to point at the Process Heap r=aklotz", "files": ["browser/app/winlauncher/NativeNt.h"], "git_node": null, "git_parents": [null], "node": "ed585dab6e3cdef7ea5893c8ba4ed3050c53d896", "parents": ["87c2ed42acf0614941589b6bc2e33a3690e9c063"], "tags": []}, {"author": "J.C. Jones \u003cjjones@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486838 - Enable EV treatment for Symantec/DigiCert cross signatures r=keeler\n\nThere is a late-breaking EV compatibility concern with cross signatures for EV\ncertificates:\n\nFirefox's EV handling code always validates EV using the first EV policy OID\nexpressed in a certificate. For compatibility certificates issued under a cross-\nsigned root, if the first EV policy OID matches the original Symantec EV policy\nOID, then Firefox will attempt to verify that the root CA matches the original\nSymantec EV CA -- which it won't, as the root will be one of DigiCert's. Without\na patch, EV treatment will break.\n\nThis patch removes all EV policy OIDs for roots mentioned in TrustOverride-\nSymantecData.inc, letting the moz::pkix algorithm pick other EV policy OIDs to\nvalidate. I verified that I removed all affected OIDs using the BASH shell\ncommands:\n\n$ cd security/certverifier\n$ grep \"CN=\" TrustOverride-SymantecData.inc | sed -e 's/.*\\(CN=.*\\).*/\\1/' |\n  sort | uniq | while read r; do\n    echo $r; grep \"$r\" ExtendedValidation.cpp;\n  done\n\nReviewers should help me ensure that I did not remove any unexpected EV policy\nOIDs.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4709", "files": ["security/certverifier/ExtendedValidation.cpp"], "git_node": null, "git_parents": [null], "node": "ba4dd979f8e196606c5a0cebdbd98fe1aa73f019", "parents": ["ed585dab6e3cdef7ea5893c8ba4ed3050c53d896"], "tags": []}, {"author": "Csoregi Natalia \u003cncsoregi@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset ed585dab6e3c (bug 1480457) for being obsolete. CLOSED TREE", "files": ["browser/app/winlauncher/NativeNt.h"], "git_node": null, "git_parents": [null], "node": "79901f0800df50388ca995b04f03dc099f0633d0", "parents": ["ba4dd979f8e196606c5a0cebdbd98fe1aa73f019"], "tags": []}, {"author": "Csoregi Natalia \u003cncsoregi@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset e4b8f03094c3 (bug 1476062) for failures on browser_aboutCrashesResubmit.js. CLOSED TREE", "files": ["toolkit/crashreporter/content/crashes.css", "toolkit/crashreporter/content/crashes.js", "toolkit/crashreporter/content/crashes.xhtml", "toolkit/crashreporter/test/browser/browser_aboutCrashes.js", "toolkit/crashreporter/test/browser/browser_aboutCrashesResubmit.js", "toolkit/crashreporter/test/browser/browser_bug471404.js", "toolkit/crashreporter/test/browser/browser_clearReports.js", "toolkit/locales/en-US/crashreporter/aboutcrashes.ftl"], "git_node": null, "git_parents": [null], "node": "a4c481a0b09bb027d3662b5d536b223fdbf47979", "parents": ["79901f0800df50388ca995b04f03dc099f0633d0"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1480457-Correct typedef so it matches an earlier typedef r=aklotz", "files": ["memory/replace/logalloc/replay/Replay.cpp"], "git_node": null, "git_parents": [null], "node": "6ca61cc8a1829344967767f902d17f01530e6a61", "parents": ["a4c481a0b09bb027d3662b5d536b223fdbf47979"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1480457 - Address moz.build failures for mingw-clang r=aklotz", "files": ["mozglue/tests/interceptor/moz.build", "toolkit/library/moz.build"], "git_node": null, "git_parents": [null], "node": "a2c02757dfa7b8c4719ee98cae0751f1349863b5", "parents": ["6ca61cc8a1829344967767f902d17f01530e6a61"], "tags": []}, {"author": "ahillier \u003cahillier@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486779: Update CFR doorhanger to reflect new designs r=Mardak\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4532", "files": ["browser/base/content/popup-notifications.inc", "browser/themes/shared/browser.inc.css", "toolkit/content/widgets/notification.xml", "toolkit/themes/shared/popupnotification.inc.css"], "git_node": null, "git_parents": [null], "node": "575e3ec6db41089f80734bf872b63c9bfe354c08", "parents": ["a2c02757dfa7b8c4719ee98cae0751f1349863b5"], "tags": []}, {"author": "Kershaw Chang \u003ckershaw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1357676 - Modify failed tests r=jdm\n\nWe've introduced a new pref network.cookie.quotaPerHost and also a rule that the value of network.cookie.maxPerHost should always be bigger than network.cookie.quotaPerHost. So, before changing the value of network.cookie.maxPerHost, we have to set network.cookie.quotaPerHost first.\nThis patch only sets network.cookie.quotaPerHost equal to network.cookie.maxPerHost - 1 in all failed tests.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4346", "files": ["extensions/cookie/test/unit/test_domain_eviction.js", "netwerk/test/TestCookie.cpp", "toolkit/components/extensions/test/mochitest/test_ext_cookies_permissions_bad.html", "toolkit/components/extensions/test/mochitest/test_ext_cookies_permissions_good.html"], "git_node": null, "git_parents": [null], "node": "513621c77f125e2c2198e7e71d064ebb3f13bb74", "parents": ["575e3ec6db41089f80734bf872b63c9bfe354c08"], "tags": []}, {"author": "Andrei Oprea \u003candrei.br92@gmail.com\u003e", "branch": "default", "desc": "Bug 1485418 - Land CFR UI Strings r=flod,k88hudson\n\nLand UI strings that are not part of the messages\n\nUI Spec https://mozilla.invisionapp.com/share/YWLSGDZGUSF#/screens\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4003", "files": ["browser/components/newtab/lib/CFRPageActions.jsm", "browser/locales/en-US/browser/newtab/asrouter.ftl"], "git_node": null, "git_parents": [null], "node": "c14b6edd88634fe65402dbf3d5b404ed1c83fc4c", "parents": ["513621c77f125e2c2198e7e71d064ebb3f13bb74"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1487121 - Allow proxy.settings.set calls without an explicit proxyType property. r=mixedpuppy\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4562", "files": ["toolkit/components/extensions/parent/ext-proxy.js", "toolkit/components/extensions/test/xpcshell/test_ext_proxy_config.js"], "git_node": null, "git_parents": [null], "node": "f4ca43d3fc1b14fc56a13a3be6ce877873196ed4", "parents": ["c14b6edd88634fe65402dbf3d5b404ed1c83fc4c"], "tags": []}, {"author": "Ed Lee \u003cedilee@mozilla.com\u003e", "branch": "default", "desc": "Bug 1485422 - Add rating stars to CFR r=ahillier\n\nDepends on D4532\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4714", "files": ["browser/base/content/popup-notifications.inc", "browser/themes/shared/browser.inc.css"], "git_node": null, "git_parents": [null], "node": "0cdebe3c53f883266962a601a78baaa08cd62d0f", "parents": ["f4ca43d3fc1b14fc56a13a3be6ce877873196ed4"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486905 - add a HOST_LINKER variable for cross windows builds; r=dmajor\n\nThis setup seems to work well enough to enable me to link\nHOST_SIMPLE_PROGRAMS with an AArch64-cross setup.  Necessary library\npaths are passed to the linker via -LIBPATH and HOST_LDFLAGS rather than\nletting MSVC fish them out of the environment.  The change to\nHOST_SIMPLE_PROGRAMS to pass HOST_LDFLAGS was necessary for this to\nwork, in addition to the HOST_LINKER changes.", "files": ["build/moz.configure/windows.configure", "config/rules.mk"], "git_node": null, "git_parents": [null], "node": "345269b39c6c2d08edebb8225e55c690dc019537", "parents": ["54c5a8af9831a0a36ed39c6f4581101acdcae79b"], "tags": []}, {"author": "Dylan Roeh \u003cdroeh@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486525 - Add NavigationDelegateTest.redirectLoad() to test redirect onLoadRequest handling. r=jchen", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/NavigationDelegateTest.kt"], "git_node": null, "git_parents": [null], "node": "f22d0641fd3dfa79a87dce3e5068f6eef2f31c6e", "parents": ["345269b39c6c2d08edebb8225e55c690dc019537"], "tags": []}, {"author": "Jason Orendorff \u003cjorendorff@mozilla.com\u003e", "branch": "default", "desc": "Bug 1442750 - Slience a few Clang-only warnings in SpiderMonkey. r=jorendorff\n\nThe changes in shell/js.cpp silence warnings about unreachable return\nstatements.\n\nThe constant being removed in testErrorInterceptor.cpp is unused.", "files": ["js/src/jsapi-tests/testErrorInterceptor.cpp", "js/src/shell/js.cpp"], "git_node": null, "git_parents": [null], "node": "1289f17ab75d08071891f71d34480000e2bb52e1", "p