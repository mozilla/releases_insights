484586 - Update about:privatebrowsing for content blocking. r=Gijs\n\nThis makes the about:privatebrowsing display \"Content Blocking\" instead\nof \"Tracking Protection\" and makes the toggle flip the TP setting for PB\nmode as well as the CB pref if it's turned off.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4395", "files": ["browser/components/privatebrowsing/content/aboutPrivateBrowsing.js", "browser/components/privatebrowsing/content/aboutPrivateBrowsing.xhtml", "browser/components/privatebrowsing/test/browser/browser_privatebrowsing_about.js", "browser/locales/en-US/chrome/browser/aboutPrivateBrowsing.dtd", "browser/themes/shared/privatebrowsing/aboutPrivateBrowsing.css", "toolkit/components/remotepagemanager/MessagePort.jsm", "toolkit/modules/AsyncPrefs.jsm"], "git_node": null, "git_parents": [null], "node": "16c3fd5997ed66218e342017a73c512462401869", "parents": ["a89328c878886157edaf683b930d8ef607f69eb5"], "tags": []}, {"author": "Daniel Holbert \u003cdholbert@cs.stanford.edu\u003e", "branch": "default", "desc": "Bug 1486633: Simplify the logic for updating mWatchID in IDTracker.cpp. r=smaug\n\nNotes:\n* NS_Atomize never returns null, so this patch removes a null check on its\n  return value.\n* There's no need for the |atom| local variable and for our swap() call on it.\n  It's equivalent and simpler for us to just directly assign mWatchID, rather\n  than to use this disposable local variable.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4394", "files": ["dom/base/IDTracker.cpp"], "git_node": null, "git_parents": [null], "node": "54beb60ca7d5221a1b4bb61019fe0def40949899", "parents": ["16c3fd5997ed66218e342017a73c512462401869"], "tags": []}, {"author": "Byron Campen [:bwc] \u003cdocfaraday@gmail.com\u003e", "branch": "default", "desc": "Bug 1483338: Stop using level as the identifier for media transports. r=mjf\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3448", "files": ["dom/media/tests/mochitest/pc.js", "dom/media/tests/mochitest/test_peerConnection_threeUnbundledConnections.html", "media/mtransport/nricectx.cpp", "media/mtransport/nricectx.h", "media/mtransport/nricemediastream.cpp", "media/mtransport/nricemediastream.h", "media/mtransport/test/ice_unittest.cpp", "media/mtransport/test/transport_unittests.cpp", "media/mtransport/third_party/nICEr/src/ice/ice_peer_ctx.c", "media/mtransport/transportlayerdtls.cpp", "media/webrtc/signaling/gtest/jsep_session_unittest.cpp", "media/webrtc/signaling/src/jsep/JsepSession.h", "media/webrtc/signaling/src/jsep/JsepSessionImpl.cpp", "media/webrtc/signaling/src/jsep/JsepSessionImpl.h", "media/webrtc/signaling/src/jsep/JsepTransceiver.h", "media/webrtc/signaling/src/jsep/JsepTransport.h", "media/webrtc/signaling/src/media-conduit/AudioConduit.cpp", "media/webrtc/signaling/src/media-conduit/VideoConduit.cpp", "media/webrtc/signaling/src/peerconnection/PeerConnectionImpl.cpp", "media/webrtc/signaling/src/peerconnection/PeerConnectionImpl.h", "media/webrtc/signaling/src/peerconnection/PeerConnectionMedia.cpp", "media/webrtc/signaling/src/peerconnection/PeerConnectionMedia.h", "media/webrtc/signaling/src/peerconnection/TransceiverImpl.cpp", "media/webrtc/signaling/src/peerconnection/TransceiverImpl.h", "media/webrtc/signaling/src/sdp/SdpHelper.cpp", "media/webrtc/signaling/src/sdp/SdpHelper.h"], "git_node": null, "git_parents": [null], "node": "836086dfcd2fb2017381a4ec5d32f757f8b1458f", "parents": ["54beb60ca7d5221a1b4bb61019fe0def40949899"], "tags": []}, {"author": "Michael Ratcliffe \u003cmratcliffe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1435429 - Android 'mach mochitest' fails: 'A cross-directory support file path noted in a test manifest does not appear in any other manifest.' r=bc,chmanchester\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4214", "files": ["devtools/server/moz.build", "devtools/shared/moz.build", "devtools/shared/worker/moz.build", "devtools/startup/moz.build"], "git_node": null, "git_parents": [null], "node": "ae13aec18c6c2252c01f44565909014a36a5a544", "parents": ["836086dfcd2fb2017381a4ec5d32f757f8b1458f"], "tags": []}, {"author": "k88hudson \u003ck88hudson@gmail.com\u003e", "branch": "default", "desc": "Bug 1486931 - Fix CFR admin page CFR and add preview method r=ursula\n\nMozReview-Commit-ID: 1RApm3ApcOe\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4492", "files": ["browser/components/newtab/lib/ASRouter.jsm", "browser/components/newtab/lib/CFRPageActions.jsm", "browser/components/newtab/test/unit/asrouter/ASRouter.test.js"], "git_node": null, "git_parents": [null], "node": "8a25fc40764a60d9dd5a72b710955bf45220f94d", "parents": ["ae13aec18c6c2252c01f44565909014a36a5a544"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Backout changeset 681777ca2f49 (bug 1480006) and 0fc57261a269 (bug 1483190) to see if that fixes bug 1485759 on a CLOSED TREE. a=ebalazs\n\nAnother reason to backout is that there may be other subtle breakage\nlike bug 1478623 and bug 1478269 and we don't have a lot of test\ncoverage on Android.\n", "files": ["mobile/android/config/mozconfigs/android-aarch64/nightly", "mobile/android/config/mozconfigs/android-api-16/nightly", "mobile/android/config/mozconfigs/android-x86/nightly"], "git_node": null, "git_parents": [null], "node": "1507e086acbcf9e0c60cfa7e89dd31995950e520", "parents": ["5092029dac4e2fd24b985c0a438437879e333b07"], "tags": []}, {"author": "Dale Harvey \u003cdale@arandomurl.com\u003e", "branch": "default", "desc": "Bug 1482646 - Update icons for autoplay media. r=dao\n\nMozReview-Commit-ID: 2CY2yeXF16N\n", "files": ["browser/themes/shared/jar.inc.mn", "browser/themes/shared/notification-icons.inc.css", "browser/themes/shared/notification-icons/autoplay-media-blocked.svg", "browser/themes/shared/notification-icons/autoplay-media-detailed.svg", "browser/themes/shared/notification-icons/autoplay-media.svg"], "git_node": null, "git_parents": [null], "node": "ea6c1463602cb9f7bad261326b7a0041b12a5dda", "parents": ["1507e086acbcf9e0c60cfa7e89dd31995950e520"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486185 - Part 1: Make the Disable Protection button in the control centre UI work for the reject tracker cookie behavior; r=baku\n", "files": ["extensions/cookie/nsPermissionManager.cpp", "toolkit/components/antitracking/AntiTrackingCommon.cpp"], "git_node": null, "git_parents": [null], "node": "27b7d1d053fb992fdc742aaa15b2395cf12ed211", "parents": ["ea6c1463602cb9f7bad261326b7a0041b12a5dda"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486185 - Part 2: Ensure that anti-tracking tests are run in a mode where blocking is active but the top-level site is white-listed for content blocking; r=baku\n", "files": ["toolkit/components/antitracking/test/browser/browser.ini", "toolkit/components/antitracking/test/browser/browser_imageCache1.js", "toolkit/components/antitracking/test/browser/browser_imageCache2.js", "toolkit/components/antitracking/test/browser/browser_imageCache3.js", "toolkit/components/antitracking/test/browser/browser_imageCache4.js", "toolkit/components/antitracking/test/browser/head.js", "toolkit/components/antitracking/test/browser/imageCacheWorker.js"], "git_node": null, "git_parents": [null], "node": "8e9cb8f36114e0d2c2b7594d4d124784b6d41483", "parents": ["27b7d1d053fb992fdc742aaa15b2395cf12ed211"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1485839 - Remove the obsolete privacy.restrict3rdpartystorage.ui.enabled pref; r=nika\n", "files": ["dom/base/nsContentUtils.cpp", "dom/base/nsContentUtils.h", "modules/libpref/init/StaticPrefList.h"], "git_node": null, "git_parents": [null], "node": "7d267beb1d1fe34dc9fc43c5913230d4b473a9de", "parents": ["8e9cb8f36114e0d2c2b7594d4d124784b6d41483"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1485870 - Remove the XPCOM registration for nsSHTransaction; r=nika\n", "files": ["docshell/build/nsDocShellModule.cpp", "docshell/shistory/nsISHTransaction.idl", "docshell/shistory/nsSHistory.cpp"], "git_node": null, "git_parents": [null], "node": "b8fdb9372c775f81cbe2f5da4e4c2257433980a2", "parents": ["7d267beb1d1fe34dc9fc43c5913230d4b473a9de"], "tags": []}, {"author": "Jan de Mooij \u003cjdemooij@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486444 - Remove bogus/over-allocating no-arg versions of js_pod_malloc/js_pod_calloc. r=tcampbell\n\nThese functions incorrectly passed sizeof(T) instead of 1, so we would allocate sizeof(T) * sizeof(T) bytes instead of sizeof(T) bytes. This was used for PcScriptCache where we would allocate a few extra megabytes due to this bug. The patch changes PcScriptCache to use UniquePtr + MakeUnique.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4343", "files": ["js/public/Utility.h", "js/src/jit/JitFrames.cpp", "js/src/jit/PcScriptCache.h", "js/src/jit/arm/Simulator-arm.cpp", "js/src/jit/arm64/vixl/MozSimulator-vixl.cpp", "js/src/jit/mips32/Simulator-mips32.cpp", "js/src/jit/mips64/Simulator-mips64.cpp", "js/src/jit/shared/Disassembler-shared.cpp", "js/src/threading/ProtectedData.h", "js/src/vm/JSContext.cpp", "js/src/vm/JSContext.h"], "git_node": null, "git_parents": [null], "node": "c44d81b8909ab05e294a897ec76f02c04b729331", "parents": ["b8fdb9372c775f81cbe2f5da4e4c2257433980a2"], "tags": []}, {"author": "Alexandre Poirot \u003cpoirot.alex@gmail.com\u003e", "branch": "default", "desc": "Bug 1026583 - Avoid sending events for already destroyed actors. r=yulia\n\nReviewers: yulia!\n\nTags: #secure-revision\n\nBug #: 1026583\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4329\n\nMozReview-Commit-ID: 3485VTbMRqO\n", "files": ["devtools/shared/protocol.js"], "git_node": null, "git_parents": [null], "node": "dd0901f47236402523ab635cce63b3da891882a0", "parents": ["c44d81b8909ab05e294a897ec76f02c04b729331"], "tags": []}, {"author": "Alexandre Poirot \u003cpoirot.alex@gmail.com\u003e", "branch": "default", "desc": "Bug 1026583 - Avoid sending network monitor events when the related actors are already destroyed. r=Honza\n\nSummary: Depends On D4329\n\nReviewers: Honza!\n\nTags: #secure-revision\n\nBug #: 1026583\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4330\n\nMozReview-Commit-ID: H8j43mSIUnc\n", "files": ["devtools/server/actors/network-event.js", "devtools/server/actors/network-monitor/network-observer.js"], "git_node": null, "git_parents": [null], "node": "7dee3ca1609f27bc1945c5ecef2b9333f776460e", "parents": ["dd0901f47236402523ab635cce63b3da891882a0"], "tags": []}, {"author": "Alexandre Poirot \u003cpoirot.alex@gmail.com\u003e", "branch": "default", "desc": "Bug 1026583 - Prevent emitting webconsole event when its actor is already destroyed. r=Honza\n\nSummary: Depends On D4330\n\nReviewers: Honza!\n\nTags: #secure-revision\n\nBug #: 1026583\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4331\n\nMozReview-Commit-ID: 5yGFUQq4J9W\n", "files": ["devtools/server/actors/webconsole/listeners/document-events.js"], "git_node": null, "git_parents": [null], "node": "3cd4ee02dfc35984f84fddc0d04c724e2c53a4a3", "parents": ["7dee3ca1609f27bc1945c5ecef2b9333f776460e"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1479368 - [marionette] Wait for tab modal dialog to disappear.\n\nBoth \"WebDriver:AcceptAlert\" and \"WebDriver:DismissAlert\" have to\nwait until the tab modal dialog has been closed.", "files": ["testing/marionette/driver.js", "testing/web-platform/meta/webdriver/tests/element_send_keys/user_prompts.py.ini"], "git_node": null, "git_parents": [null], "node": "0509419ea0856d78031fcaccce1b2693a86064b1", "parents": ["3cd4ee02dfc35984f84fddc0d04c724e2c53a4a3"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1486495 - [wdspec] Create basic tests for \"Get Element CSS Value\" command.", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/webdriver/tests/get_element_attribute/__init__.py", "testing/web-platform/tests/webdriver/tests/get_element_css_value/__init__.py", "testing/web-platform/tests/webdriver/tests/get_element_css_value/get.py", "testing/web-platform/tests/webdriver/tests/get_element_css_value/user_prompts.py"], "git_node": null, "git_parents": [null], "node": "1132c5e406a2a6220f71f54668401a22e6eff3a5", "parents": ["0509419ea0856d78031fcaccce1b2693a86064b1"], "tags": []}, {"author": "Marco Castelluccio \u003cmcastelluccio@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486528 - Remove some unnecessary nsIMemory imports. r=njn", "files": ["dom/plugins/base/nsPluginsDirUnix.cpp", "dom/xbl/nsXBLService.cpp", "xpcom/build/XPCOM.h", "xpcom/io/nsSegmentedBuffer.h"], "git_node": null, "git_parents": [null], "node": "481d502afc69d7d120b2d80a2b881bcea25c2661", "parents": ["1132c5e406a2a6220f71f54668401a22e6eff3a5"], "tags": []}, {"author": "Ted Campbell \u003ctcampbell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1485347 - Part 1: Remove nTypeSets argument from JSScript::partiallyInit. r=jandem\n\nMozReview-Commit-ID: I6xBHG8FLlq\n", "files": ["js/src/vm/JSScript.cpp", "js/src/vm/JSScript.h"], "git_node": null, "git_parents": [null], "node": "a6aa090e485ef4e81fc6e090e12ab6d2019f21aa", "parents": ["481d502afc69d7d120b2d80a2b881bcea25c2661"], "tags": []}, {"author": "Ted Campbell \u003ctcampbell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1485347 - Part 2: Remove CheckScriptDataIntegrity. r=jandem\n\nThis diagnostic did not provide value and should be removed to allow\nfurther cleanup.\n\nMozReview-Commit-ID: 49XJM0G7NAP\n", "files": ["js/src/vm/JSScript.cpp"], "git_node": null, "git_parents": [null], "node": "b09a2762f0e5533dab80401953121580134a2c6e", "parents": ["a6aa090e485ef4e81fc6e090e12ab6d2019f21aa"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486020 - eliminate warning spam about ICU RTTI with MSVC; r=chmanchester", "files": ["config/external/icu/defs.mozbuild"], "git_node": null, "git_parents": [null], "node": "793be675465bde66c019439cb1ec4dc4c4653607", "parents": ["b09a2762f0e5533dab80401953121580134a2c6e"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486039 - use a more-portable idiom for pausing in SpinEvent::Wait; r=aklotz\n\nYieldProcessor is apparently defined to do the same thing on x86 as our\ncustom macros, but includes implementations for non-x86 processors.", "files": ["ipc/mscom/SpinEvent.cpp"], "git_node": null, "git_parents": [null], "node": "3568c72a41cc0ffd616ad107dace0c9253d293d7", "parents": ["793be675465bde66c019439cb1ec4dc4c4653607"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486040 - make WindowsDllBlocklist.h functional for aarch64 windows; r=aklotz", "files": ["mozglue/build/WindowsDllBlocklist.h"], "git_node": null, "git_parents": [null], "node": "dd857ab01989843d0feae7eb4525b374e6a34439", "parents": ["3568c72a41cc0ffd616ad107dace0c9253d293d7"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1485701 - make the interceptor code compilable, if not functional, on aarch64 windows; r=aklotz", "files": ["mozglue/misc/interceptor/PatcherDetour.h", "mozglue/misc/interceptor/TargetFunction.h", "mozglue/misc/nsWindowsDllInterceptor.h"], "git_node": null, "git_parents": [null], "node": "1642245157667814068b0d39d3b03d74801cca8a", "parents": ["dd857ab01989843d0feae7eb4525b374e6a34439"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1485485 - make bootstrap accept rustc/cargo in known-good locations; r=chmanchester\n\nmoz.configure looks for rustc/cargo on PATH and in ~/.cargo/bin.\nBootstrap only looks on PATH and not in ~/.cargo/bin, though it is smart\nenough to complain if rustc/cargo can't be found on PATH and you have\nthem in ~/.cargo/bin.  Bootstrap should look in both places by default,\nand be content if it finds them wherever they are, so long as\nmoz.configure can find them.", "files": ["python/mozboot/mozboot/base.py"], "git_node": null, "git_parents": [null], "node": "514f97264e6c75713ff3828931c5415a69697ca7", "parents": ["1642245157667814068b0d39d3b03d74801cca8a"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1486456 - [wdspec] Add basic tests for \"Get Element rect\". r=ato", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/webdriver/tests/get_element_rect/__init__.py", "testing/web-platform/tests/webdriver/tests/get_element_rect/get.py", "testing/web-platform/tests/webdriver/tests/get_element_rect/user_prompts.py"], "git_node": null, "git_parents": [null], "node": "4c623a756c06017d341d956ce5a8633baf3f7fc8", "parents": ["514f97264e6c75713ff3828931c5415a69697ca7"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1425700 - Add a very simple use counter implementation. r=heycam\n\nAs simple as I could make it, for now. We can improve on this.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3827\n", "files": ["servo/components/style/lib.rs", "servo/components/style/parser.rs", "servo/components/style/properties/properties.mako.rs", "servo/components/style/use_counters/mod.rs"], "git_node": null, "git_parents": [null], "node": "8efef28be72c1ab7e433248924b9459beb2e1b33", "parents": ["4c623a756c06017d341d956ce5a8633baf3f7fc8"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1425700 - Hook the use counters into StyleSheet parsing. r=heycam\n\nStill not hooked into telemetry, I talked with :janerik and :gfritzsche about\nthat, but test incoming!\n\nThis intentionally doesn't handle CSSOM and such for now, will file followups\nfor those, though should be trivial.\n\nI want to unify / clean up how we do the use counters and the error reporting\nstuff for CSSOM, since the current function call still shows up in profiles,\nbut that should be a follow-up.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3828\n", "files": ["dom/base/nsDocument.cpp", "dom/base/nsIDocument.h", "layout/style/ServoArcTypeList.h", "layout/style/ServoBindingList.h", "layout/style/ServoBindings.h", "layout/style/StyleSheet.cpp", "layout/style/test/gtest/StyloParsingBench.cpp", "modules/libpref/init/StaticPrefList.h", "servo/components/style/gecko/arc_types.rs", "servo/components/style/parser.rs", "servo/components/style/properties/declaration_block.rs", "servo/components/style/properties/properties.mako.rs", "servo/components/style/stylesheets/keyframes_rule.rs", "servo/components/style/stylesheets/mod.rs", "servo/components/style/stylesheets/stylesheet.rs", "servo/components/style/use_counters/mod.rs", "servo/ports/geckolib/glue.rs", "servo/ports/geckolib/stylesheet_loader.rs"], "git_node": null, "git_parents": [null], "node": "5449572186472bfc8ed0a48e6b08e6bc4e2424a6", "parents": ["8efef28be72c1ab7e433248924b9459beb2e1b33"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1425700 - Add a test for the use counters. r=heycam\n\nMostly testing that they work, and that they record what we expect them to\nrecord, that is, the actual property that was parsed, and not the properties\nthat it'd resolve or expand to.\n\nThat may be another tricky part for CSSOM, I think style setters would fail an\nalias test if implemented with the current setup (we do the property lookup in\nC++).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3829\n", "files": ["dom/base/nsDOMWindowUtils.cpp", "dom/interfaces/base/nsIDOMWindowUtils.idl", "layout/style/ServoBindingList.h", "layout/style/test/mochitest.ini", "layout/style/test/test_use_counters.html", "servo/components/style/properties/properties.mako.rs", "servo/components/style/use_counters/mod.rs", "servo/ports/geckolib/glue.rs"], "git_node": null, "git_parents": [null], "node": "bc3f9356906bd462f3941e2ec6510a145aa65b2d", "parents": ["5449572186472bfc8ed0a48e6b08e6bc4e2424a6"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1425700 - Add a parsing benchmarks with use counters. r=bholley\n\nThat way we have a simple baseline to measure overhead.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3839\n", "files": ["layout/style/test/gtest/StyloParsingBench.cpp"], "git_node": null, "git_parents": [null], "node": "42822c922dcfd2664b3a5d357a6b8d1f792c5d85", "parents": ["bc3f9356906bd462f3941e2ec6510a145aa65b2d"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1425700 - Make the counters non-atomic counters and merge afterwards. r=bholley\n\nThis was consistently faster in the benchmark (even when counters were disabled,\nwhich was slightly suspicious, but...).\n\nAnyway, it's not really much code, most of it is FFI copy-pasta.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3874\n", "files": ["dom/base/nsDocument.cpp", "dom/base/nsIDocument.h", "layout/style/ServoArcTypeList.h", "layout/style/ServoBindingList.h", "layout/style/ServoBindingTypes.h", "layout/style/ServoBindings.cpp", "layout/style/ServoBindings.h", "layout/style/ServoBindings.toml", "layout/style/StyleSheet.cpp", "layout/style/test/gtest/StyloParsingBench.cpp", "servo/components/style/gecko/arc_types.rs", "servo/components/style/gecko_bindings/sugar/ownership.rs", "servo/components/style/use_counters/mod.rs", "servo/ports/geckolib/glue.rs", "servo/ports/geckolib/stylesheet_loader.rs"], "git_node": null, "git_parents": [null], "node": "d5203d9dc33b2f829f621c30e99dbfa5a4bed32c", "parents": ["42822c922dcfd2664b3a5d357a6b8d1f792c5d85"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1486166 - Set the tooltip text on the parent of the urlbar input. r=dao\n\nThe reason bug 1440682 broke this was because I moved all the code to\nnsXULElement. However, there was a way for non-XUL elements to get XUL tooltips\nbefore that, which was via the RestyleManager mechanism to handle attribute\nmutations.\n\nSo the behavior before that patch was that non-XUL elements that got the\nattribute dynamically added or removed before that patch got their tooltips,\nlike the HTML input in the toolbar, but if you specified the attributes\nstatically in the markup, or while the element was somehow outside of the\ndocument or what not, it would never work.\n\nGiven that, this looks completely unintentional, and the fact that this ever\nworked was a bit lucky.\n\nChances are we eventually want tooltip support for HTML elements in chrome\ndocuments, but it is pretty likely that we want to use the HTML tooltip\ninfrastructure instead of nsXULTooltipListener, which is kind of an odd thing.\n\nThus, for now patch the code so that it sets it on the container of the \u003cinput\u003e,\nwhich is a XUL box that takes the same space as the \u003cinput\u003e, instead of moving\nall the XUL tooltip support to work on non-XUL elements.\n\nAlso, while at it, remove references to inputtooltiptext, since I didn't find a\nsingle reference in the code that would set this attribute ever.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4294\n", "files": ["browser/base/content/urlbarBindings.xml"], "git_node": null, "git_parents": [null], "node": "20a43066e367897769f5c155b1daba955cfaeea7", "parents": ["d5203d9dc33b2f829f621c30e99dbfa5a4bed32c"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1486536 - Make nsPresContext::CompatibilityModeChanged() properly call PresShell::ApplicableStylesChanged. r=heycam\n\nWe usually rely on this call happening soon enough that it doesn't\nmatter, but from document.write it can matter actually. This is the call that\nmakes this work the same way as other sheet addition / removals. This would fix\ncases where counter styles / @font-face rules in quirk.css wouldn't get\nproperly updated in some cases. Hopefully we don't have any of those.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4360\n", "files": ["layout/base/nsPresContext.cpp"], "git_node": null, "git_parents": [null], "node": "15e5faa7e1d9a290118f9c05c1480d1f6f3b9a6b", "parents": ["20a43066e367897769f5c155b1daba955cfaeea7"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1486536 - Explicitly flush the StyleSet from FlushPendingNotifications. r=heycam\n\nWhen CSS rules change, we usually do this implicitly from FlushUserFontSet & co.\n\nHowever there's a code path that dirties the stylist but not the CSS rules, and\nthat's when the compat mode changes and we're an SVG document.\n\nI don't think that can get hit (easily, at least?), but it's pretty easy to do\nso and I think this is cleaner too.\n\nThis fixes that case so the stylist can't assert in that case either, and so\nthat we still rebuild the cascade data so that the hash maps use the right keys\nfor a given quirks-mode.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4361\n", "files": ["layout/base/PresShell.cpp", "layout/style/ServoStyleSet.cpp"], "git_node": null, "git_parents": [null], "node": "15d80c644e1e8e07c5196d58f6707611c8fac4b0", "parents": ["15e5faa7e1d9a290118f9c05c1480d1f6f3b9a6b"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1486536 - Crashtest. r=heycam\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4362\n", "files": ["layout/style/crashtests/1486536.html", "layout/style/crashtests/crashtests.list"], "git_node": null, "git_parents": [null], "node": "a47f6d2d38a4d7e46770f43a137d456fa02525ba", "parents": ["15d80c644e1e8e07c5196d58f6707611c8fac4b0"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1486732 - Remove useless nsXBLBinding::mIsShadowRootBinding. r=smaug\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4434\n", "files": ["dom/xbl/nsXBLBinding.cpp", "dom/xbl/nsXBLBinding.h"], "git_node": null, "git_parents": [null], "node": "b5ebdb085efaf31a4f00159334c2d23679e5fa27", "parents": ["a47f6d2d38a4d7e46770f43a137d456fa02525ba"], "tags": []}, {"author": "Kai Engert \u003ckaie@kuix.de\u003e", "branch": "default", "desc": "Bug 1470914, NSS_3_39_BETA2, r=me\nUPGRADE_NSS_RELEASE", "files": ["security/nss/TAG-INFO", "security/nss/coreconf/coreconf.dep", "security/nss/gtests/nss_bogo_shim/config.json", "security/nss/gtests/nss_bogo_shim/nss_bogo_shim.cc", "security/nss/gtests/ssl_gtest/ssl_agent_unittest.cc", "security/nss/gtests/ssl_gtest/ssl_extension_unittest.cc", "security/nss/gtests/ssl_gtest/ssl_gather_unittest.cc", "security/nss/gtests/ssl_gtest/ssl_hrr_unittest.cc", "security/nss/gtests/ssl_gtest/ssl_v2_client_hello_unittest.cc", "security/nss/gtests/ssl_gtest/ssl_version_unittest.cc", "security/nss/gtests/ssl_gtest/tls_agent.cc", "security/nss/gtests/ssl_gtest/tls_agent.h", "security/nss/lib/ssl/ssl.h", "security/nss/lib/ssl/ssl3con.c", "security/nss/lib/ssl/ssl3gthr.c", "security/nss/lib/ssl/ssl3prot.h", "security/nss/lib/ssl/sslimpl.h", "security/nss/lib/ssl/sslsock.c", "security/nss/lib/ssl/tls13con.c", "security/nss/lib/ssl/tls13con.h", "security/nss/lib/ssl/tls13exthandle.c", "security/nss/tests/all.sh", "security/nss/tests/bogo/bogo.sh", "security/nss/tests/interop/interop.sh"], "git_node": null, "git_parents": [null], "node": "4a4b97e9087ca8ebed570bbc8591e4515eebee93", "parents": ["b5ebdb085efaf31a4f00159334c2d23679e5fa27"], "tags": []}, {"author": "Kai Engert \u003ckaie@kuix.de\u003e", "branch": "default", "desc": "Bug 1477680, NSPR 4.20 RTM, no code change, only version number, r=me\nUPGRADE_NSPR_RELEASE\nDONTBUILD", "files": ["nsprpub/TAG-INFO", "nsprpub/config/prdepend.h", "nsprpub/pr/include/prinit.h"], "git_node": null, "git_parents": [null], "node": "649fac61e18dd0cfa634527f04c9d4bb59f0f9d0", "parents": ["4a4b97e9087ca8ebed570bbc8591e4515eebee93"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1486467 - [webdriver] Rename pageLoad to page_load for TimeoutsResponse. r=ato", "files": ["testing/geckodriver/src/marionette.rs", "testing/webdriver/src/response.rs"], "git_node": null, "git_parents": [null], "node": "b4cb950d23e59879f9081cdf0a0ebd3405d39c4c", "parents": ["649fac61e18dd0cfa634527f04c9d4bb59f0f9d0"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1486467 - [webdriver] Rename sessionId to session_id for NewSessionResponse. r=ato", "files": ["testing/webdriver/src/response.rs", "testing/webdriver/src/server.rs"], "git_node": null, "git_parents": [null], "node": "9d702b7e5d80bc365790fe49001882b8dca80c9c", "parents": ["b4cb950d23e59879f9081cdf0a0ebd3405d39c4c"], "tags": []}, {"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 1478397 - Part 0: Reorganize the flex container checkbox and flex container properties to match new designs. r=rcaliman", "files": ["devtools/client/inspector/flexbox/components/FlexContainer.js", "devtools/client/inspector/flexbox/components/FlexContainerItem.js", "devtools/client/inspector/flexbox/comp