lt", "desc": "Bug 1496557 - Expose Report Breakage for Cookie Restrictions on Release. r=Gijs a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7856", "files": ["browser/app/profile/firefox.js", "browser/base/content/browser-contentblocking.js", "browser/base/content/test/trackingUI/browser_trackingUI_report_breakage.js"], "git_node": null, "git_parents": [null], "node": "87ddd19e49875560aef9863891d2b9e5494c87c1", "parents": ["55aa0ae41d9964324d3f7d8f4d942e2b33f5eafe"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1483699 - part 1 - add overflow checks for extending arrays; r=mccr8 a=pascalc", "files": ["xpcom/ds/nsTArray-inl.h", "xpcom/ds/nsTArray.h"], "git_node": null, "git_parents": [null], "node": "b4e29532f5282a02b819ad2fe1bc89fd6d5b1002", "parents": ["87ddd19e49875560aef9863891d2b9e5494c87c1"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1483699 - part 2 - make InsertSlotsAt error checking more thorough; r=mccr8 a=pascalc\n\nI don't know what the existing code was trying to do, but it certainly\nwasn't clear, and possibly not correct.", "files": ["xpcom/ds/nsTArray-inl.h", "xpcom/ds/nsTArray.h"], "git_node": null, "git_parents": [null], "node": "de127662180d7e2798660e75cee75523fdd056dd", "parents": ["b4e29532f5282a02b819ad2fe1bc89fd6d5b1002"], "tags": []}, {"author": "Oriol Brufau \u003coriol-bugzilla@hotmail.com\u003e", "branch": "default", "desc": "Bug 1489814 - Add 'populate' parameter in 'tabs.highlight'. r=mixedpuppy a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7240", "files": ["browser/components/extensions/parent/ext-tabs.js", "browser/components/extensions/schemas/tabs.json", "browser/components/extensions/test/browser/browser_ext_tabs_highlight.js"], "git_node": null, "git_parents": [null], "node": "253f11fbc824e50ded7fa9d1e6fb5046e0e86188", "parents": ["de127662180d7e2798660e75cee75523fdd056dd"], "tags": []}, {"author": "Mantaroh Yoshinaga \u003cmantaroh@gmail.com\u003e", "branch": "default", "desc": "Bug 1493659 - Skip the click event handler if touch event has occurred. r=birtles a=pascalc\n\nTapping the menu button during the panel has shown make the menu button to be unopenable. This cause reason is removing the pointer-events property before the mouse event happens.\nThe tapping event will happen many the event like the following:\n1) touchstart\n2) touchmove (Long tap only)\n3) touchend\n4) mousedown\n5) mouseup\n6) click\n\nThis patch will detect the touchend event to eat the click event.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7827", "files": ["devtools/client/shared/components/menu/MenuButton.js"], "git_node": null, "git_parents": [null], "node": "f997cf948ca01fc193119c3219fc35926fb8eb8e", "parents": ["253f11fbc824e50ded7fa9d1e6fb5046e0e86188"], "tags": []}], "date": 1539110264, "git_changesets": [null, null, null, null, null, null], "user": "archaeopteryx@coole-files.de"}, "9960": {"changesets": [{"author": "Jan Beich \u003cjbeich@FreeBSD.org\u003e", "branch": "default", "desc": "Bug 1496733 - Explicitly install libXt on FreeBSD. r=froydnj, a=NPOTB", "files": ["python/mozboot/mozboot/freebsd.py"], "git_node": null, "git_parents": [null], "node": "a3246a951d2edb5a0bca13be3fd407980361a551", "parents": ["f997cf948ca01fc193119c3219fc35926fb8eb8e"], "tags": []}, {"author": "Jan Beich \u003cjbeich@FreeBSD.org\u003e", "branch": "default", "desc": "Bug 1496708 - Install cbindgen as system package. f=gaston, r=froydnj, a=NPOTB\n\ncargo build is no longer called, so bootstrap will be faster.\nAll dependencies (including cbindgen) are usually up-to-date on BSDs\nbecause there's no fallback to Mozilla binaries.", "files": ["python/mozboot/mozboot/freebsd.py", "python/mozboot/mozboot/openbsd.py"], "git_node": null, "git_parents": [null], "node": "8a68e674c26549c04b3bfefc2939c77a73b88308", "parents": ["a3246a951d2edb5a0bca13be3fd407980361a551"], "tags": []}, {"author": "Jan Beich \u003cjbeich@FreeBSD.org\u003e", "branch": "default", "desc": "Bug 1496708 - Install node as system package. f=gaston, r=froydnj, a=NPOTB\n\nMozilla binaries (including toolchain artifacts) aren't available on BSDs.", "files": ["python/mozboot/mozboot/freebsd.py", "python/mozboot/mozboot/openbsd.py"], "git_node": null, "git_parents": [null], "node": "27fc86657940c0806d665ca7f6c82fbb9df910cc", "parents": ["8a68e674c26549c04b3bfefc2939c77a73b88308"], "tags": []}, {"author": "Olli Pettay \u003cOlli.Pettay@helsinki.fi\u003e", "branch": "default", "desc": "Bug 1492823 - Ensure user input suppression works correctly even after document.open. r=peterv, a=RyanVM", "files": ["dom/base/nsGlobalWindowInner.cpp", "dom/base/nsGlobalWindowInner.h", "dom/base/nsGlobalWindowOuter.cpp"], "git_node": null, "git_parents": [null], "node": "c05cd826f781b811eb54db0512e4cda3f962bef0", "parents": ["27fc86657940c0806d665ca7f6c82fbb9df910cc"], "tags": []}], "date": 1539111521, "git_changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "9961": {"changesets": [{"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Bug 1493659 - Skip the click event handler if touch event has occurred: fix eslint failure r=eslint a=eslint-fix", "files": ["devtools/client/shared/components/menu/MenuButton.js"], "git_node": null, "git_parents": [null], "node": "4b92224d68b8903df553ad03b6fb740fd6a20a11", "parents": ["c05cd826f781b811eb54db0512e4cda3f962bef0"], "tags": []}], "date": 1539112031, "git_changesets": [null], "user": "archaeopteryx@coole-files.de"}, "9962": {"changesets": [{"author": "Erica Wright \u003cewright@mozilla.com\u003e", "branch": "default", "desc": "Bug 1495612 - Add custom search keywords for DoH. r=jaws a=pascalc\n\nOn about:preferences, if a user enters \"doh\" or \"trr\" in the search, it brings them to the Connection Settings panel.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7363", "files": ["browser/components/preferences/in-content/main.xul"], "git_node": null, "git_parents": [null], "node": "6fc845dd67de815c6e5c16009d0fef122da84162", "parents": ["4b92224d68b8903df553ad03b6fb740fd6a20a11"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1496671 - Final pref changes for Content Blocking in Firefox 63. r=Gijs,baku a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8068", "files": ["browser/app/profile/firefox.js", "modules/libpref/init/StaticPrefList.h"], "git_node": null, "git_parents": [null], "node": "e6572dd7af95148602791d7e886d023383e5e428", "parents": ["6fc845dd67de815c6e5c16009d0fef122da84162"], "tags": []}, {"author": "Zibi Braniecki \u003czbraniecki@mozilla.com\u003e", "branch": "default", "desc": "Bug 1305705 - Don`t unregister langpacks on shutdown. r=aswan a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D5909", "files": ["toolkit/components/extensions/Extension.jsm"], "git_node": null, "git_parents": [null], "node": "bad62a87d92cede80c71a157c8dc038da0fd5379", "parents": ["e6572dd7af95148602791d7e886d023383e5e428"], "tags": []}], "date": 1539174192, "git_changesets": [null, null, null], "user": "dvarga@mozilla.com"}, "9963": {"changesets": [{"author": "Andreea Pavel \u003capavel@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 39f0d4e66898 (bug 675428) for causing bug 1496380 a=backout", "files": ["browser/installer/windows/nsis/shared.nsh", "browser/installer/windows/nsis/uninstaller.nsi"], "git_node": null, "git_parents": [null], "node": "6eb227fec6d5a3ca1a21f8fd57292b7855a975f4", "parents": ["bad62a87d92cede80c71a157c8dc038da0fd5379"], "tags": []}], "date": 1539193756, "git_changesets": [null], "user": "apavel@mozilla.com"}, "9964": {"changesets": [{"author": "Jamie Nicol \u003cjnicol@mozilla.com\u003e", "branch": "default", "desc": "Bug 1490789 - Apply shift when calculating old area of invalidated frame. r=miko, a=pascalc\n\nWhen calculating which regions of a layer to invalidate we usually\napply a shift to the area to account for changes in scroll offset. For\nitems within flattened transforms we do not do this, because the\ntransform itself includes the scroll offset. However, when calculating\nthe old area of an invalidated frame, we use the old transform. This\nincludes the previous scroll offset rather than the current, so we\nmust therefore still apply the shift.\n\nNot doing so was causing the incorrect region to be invalidated, and\ncontent to be rendered at the wrong location.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8080", "files": ["layout/painting/FrameLayerBuilder.cpp"], "git_node": null, "git_parents": [null], "node": "c4fd0c5a2d5af7898412724e0bfca04e493b78f5", "parents": ["6eb227fec6d5a3ca1a21f8fd57292b7855a975f4"], "tags": []}, {"author": "Rob Wu \u003crob@robwu.nl\u003e", "branch": "default", "desc": "Bug 1487478 - Move MatchPattern normalization into classifyPermission. r=aswan, a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4707", "files": ["toolkit/components/extensions/Extension.jsm", "toolkit/components/extensions/schemas/manifest.json", "toolkit/components/extensions/schemas/permissions.json"], "git_node": null, "git_parents": [null], "node": "3479e999805be6d1c93e3f5de3a910143a11aaa8", "parents": ["c4fd0c5a2d5af7898412724e0bfca04e493b78f5"], "tags": []}], "date": 1539197357, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "9965": {"changesets": [{"author": "David Parks \u003cdparks@mozilla.com\u003e", "branch": "default", "desc": "Bug 1495245 - Refactor AudioDeviceMessageRunnable's use of the PluginModuleSet. r=jmathies, a=RyanVM\n\nChanges AudioDeviceMessageRunnable to hold the AudioNotification instead of its PluginModuleSet to simplify object lifetime issues. AudioNotification is ref-counted so we can increment its ref-count during the asynchronous Runnable.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7555", "files": ["dom/plugins/ipc/PluginUtilsWin.cpp"], "git_node": null, "git_parents": [null], "node": "2704bbd93c5655757d331b7463bcbf49ab497956", "parents": ["3479e999805be6d1c93e3f5de3a910143a11aaa8"], "tags": []}], "date": 1539197518, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "9966": {"changesets": [{"author": "Paolo Amadini \u003cpaolo.mozmail@amadzone.org\u003e", "branch": "default", "desc": "Bug 1497926 - Back out changeset 981a904be103 from Beta for causing Bug 1497926. r=Gijs a=backout\n\nReviewers: Gijs\n\nBug #: 1497926\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8243", "files": ["browser/base/content/browser-context.inc", "browser/base/content/browser-menubar.inc", "browser/base/content/browser-sets.inc", "browser/base/content/browser.js", "browser/base/content/nsContextMenu.js", "browser/base/content/test/general/browser_viewSourceInTabOnViewSource.js", "browser/base/content/webext-panels.xul"], "git_node": null, "git_parents": [null], "node": "725973b45a9390e24257b66e718c0358a9fe888c", "parents": ["2704bbd93c5655757d331b7463bcbf49ab497956"], "tags": []}], "date": 1539198576, "git_changesets": [null], "user": "apavel@mozilla.com"}, "9967": {"changesets": [{"author": "Simon Fraser \u003csfraser@mozilla.com\u003e", "branch": "default", "desc": "Bug 1492639 Add destination checks to bouncer validation r=mtabara a=release\n\nReviewers: mtabara\n\nReviewed By: mtabara\n\nSubscribers: bhearsum, sfraser, catlee, mtabara\n\nTags: #secure-revision, #bmo-releng-security\n\nBug #: 1492639\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8189", "files": [".cron.yml", "taskcluster/ci/cron-bouncer-check/kind.yml", "testing/mozharness/scripts/release/bouncer_check.py"], "git_node": null, "git_parents": [null], "node": "06296e32a38a047fe7503b1ea6707f80fdb39206", "parents": ["725973b45a9390e24257b66e718c0358a9fe888c"], "tags": []}], "date": 1539260335, "git_changesets": [null], "user": "sfraser@mozilla.com"}, "9968": {"changesets": [{"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-beta repo-update HSTS HPKP blocklist remote-settings - a=repo-update r=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8373", "files": ["browser/app/blocklist.xml", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/blocklists/addons.json"], "git_node": null, "git_parents": [null], "node": "bcd58b71091df777dd0a1257cf8ab02054f1c68b", "parents": ["06296e32a38a047fe7503b1ea6707f80fdb39206"], "tags": []}, {"author": "Andrei Lazar \u003candrei.a.lazar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1496079 - Cannot view files due to missing READ_STORAGE_PERMISSION. r=JanH, a=pascalc\n\nFixed the issue where the read storage permission was not requested due to a typo.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7608", "files": ["mobile/android/chrome/content/browser.js"], "git_node": null, "git_parents": [null], "node": "a3d9a2b6a7bed56636a16d7e6106e42db032cbcc", "parents": ["bcd58b71091df777dd0a1257cf8ab02054f1c68b"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1497259 - 1. Fix log module names; r=droeh, a=ritu\n\nFix the GV log module names so they are all under the GeckoView group.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8050", "files": ["mobile/android/chrome/geckoview/ErrorPageEventHandler.js", "mobile/android/chrome/geckoview/geckoview.js", "mobile/android/components/geckoview/GeckoViewExternalAppService.js", "mobile/android/components/geckoview/GeckoViewStartup.js", "mobile/android/modules/geckoview/GeckoViewConsole.jsm", "mobile/android/modules/geckoview/GeckoViewContentModule.jsm", "mobile/android/modules/geckoview/GeckoViewModule.jsm", "mobile/android/modules/geckoview/GeckoViewRemoteDebugger.jsm", "mobile/android/modules/geckoview/GeckoViewUtils.jsm"], "git_node": null, "git_parents": [null], "node": "c78886e8b28ee7ca945373cfc015ee011ce323f8", "parents": ["a3d9a2b6a7bed56636a16d7e6106e42db032cbcc"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1497259 - 2. Don't log auto-fill values; r=droeh, a=ritu\n\nAuto-fill values can contain personal information and must not appear in\nthe log.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8051", "files": ["mobile/android/chrome/geckoview/GeckoViewContent.js", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/SessionAccessibility.java", "mobile/android/geckoview/src/main/java/org/mozilla/geckoview/SessionTextInput.java"], "git_node": null, "git_parents": [null], "node": "6cd7919cc0b8b4e05c495bed36ba70c60fb14bdf", "parents": ["c78886e8b28ee7ca945373cfc015ee011ce323f8"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1497259 - 3. Control GV logging through pref; r=droeh, a=ritu\n\nUse the \"geckoview.logging\" pref to control GV logging.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8052", "files": ["mobile/android/app/geckoview-prefs.js", "mobile/android/modules/geckoview/GeckoViewUtils.jsm"], "git_node": null, "git_parents": [null], "node": "095138ddfce66ad816470b4f0132e700d859f00a", "parents": ["6cd7919cc0b8b4e05c495bed36ba70c60fb14bdf"], "tags": []}], "date": 1539263431, "git_changesets": [null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9969": {"changesets": [{"author": "Jan Beich \u003cjbeich@FreeBSD.org\u003e", "branch": "default", "desc": "Bug 1497169 - Unbreak bundled libevent on FreeBSD 12. r=froydnj, a=NPOTB", "files": ["ipc/chromium/src/third_party/libevent/README.mozilla", "ipc/chromium/src/third_party/libevent/evutil_rand.c", "ipc/chromium/src/third_party/libevent/include/event2/util.h", "ipc/chromium/src/third_party/libevent/patches/openbsd-no-arc4random_addrandom.patch"], "git_node": null, "git_parents": [null], "node": "a571fb22559aacfc24a3c4ee36eccf87ca673863", "parents": ["095138ddfce66ad816470b4f0132e700d859f00a"], "tags": []}, {"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1492737 - Part 1: Support passing name length to JS_GetOwnUCPropertyDescriptor and add JS_GetUCPropertyDescriptor. r=Waldo, a=pascalc", "files": ["dom/xbl/nsXBLBinding.cpp", "dom/xbl/nsXBLProtoImpl.cpp", "js/src/jsapi.cpp", "js/src/jsapi.h"], "git_node": null, "git_parents": [null], "node": "d43c7f7c0d153856dc221f2f594f4eaa39accd15", "parents": ["a571fb22559aacfc24a3c4ee36eccf87ca673863"], "tags": []}, {"author": "Jan Varga \u003cjan.varga@gmail.com\u003e", "branch": "default", "desc": "Bug 1492737 - Part 2: Avoid searching the prototype chain when extracting keys. r=asuth, a=pascalc", "files": ["dom/indexedDB/KeyPath.cpp", "testing/web-platform/meta/IndexedDB/keypath-exceptions.htm.ini"], "git_node": null, "git_parents": [null], "node": "1c577d6a48f02dba918037d7f39ec98f3869d643", "parents": ["d43c7f7c0d153856dc221f2f594f4eaa39accd15"], "tags": []}, {"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1496673 - Fix crash in custom element data memory reporting code. r=jdai, a=pascalc\n\nWhile iterating the list in CustomElementReactionsStack::InvokeReactions we can\nhave null pointers in mReactionQueue for reactions that have already been\ninvoked.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7923", "files": ["dom/base/CustomElementRegistry.cpp"], "git_node": null, "git_parents": [null], "node": "c79baa59f78f57c297521e84c58d1025e0e685f6", "parents": ["1c577d6a48f02dba918037d7f39ec98f3869d643"], "tags": []}, {"author": "Michael Ratcliffe \u003cmratcliffe@mozilla.com\u003e", "branch": "default", "desc": "Bug 1493937 - Highlighting the various margin/border/padding/content regions from the box-model does not work anymore. r=pbro, a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8020", "files": ["devtools/client/inspector/boxmodel/components/BoxModelMain.js"], "git_node": null, "git_parents": [null], "node": "db5fb5feecf942eb9b50aff738f96e36a514759d", "parents": ["c79baa59f78f57c297521e84c58d1025e0e685f6"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1484843 - Add policy for disabling DNS over HTTPS. r=flod,Felipe,jkt, a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7743", "files": ["browser/components/enterprisepolicies/Policies.jsm", "browser/components/enterprisepolicies/schemas/policies-schema.json", "browser/components/enterprisepolicies/tests/browser/browser_policies_simple_pref_policies.js", "browser/locales/en-US/browser/policies/policies-descriptions.ftl"], "git_node": null, "git_parents": [null], "node": "66ab8622488cd2df04e61f686698e21124b34a43", "parents": ["db5fb5feecf942eb9b50aff738f96e36a514759d"], "tags": []}, {"author": "Shane Caraveo \u003cscaraveo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1467523 - Followup fix for case insensitive header name check. r=aswan,robwu, a=RyanVM", "files": ["toolkit/modules/addons/WebRequest.jsm"], "git_node": null, "git_parents": [null], "node": "f439e5f9e3d3abef1df5f1845dda16fbbdcd07fd", "parents": ["66ab8622488cd2df04e61f686698e21124b34a43"], "tags": []}], "date": 1539279684, "git_changesets": [null, null, null, null, null, null, null], "user": "ryanvm@gmail.com"}, "9970": {"changesets": [{"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1463684 - Specify UTF-8 charset for policy search engines. r=Felipe, a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8144", "files": ["browser/components/enterprisepolicies/Policies.jsm"], "git_node": null, "git_parents": [null], "node": "dc0694bc87c1f0e8f5475804d6845d6c36fcbc01", "parents": ["f439e5f9e3d3abef1df5f1845dda16fbbdcd07fd"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1496855 - Switch PDF policy to use pdfjs.disabled. r=Felipe, a=pascalc\n\npdfjs.disabled now works from policy, so use it\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8237", "files": ["browser/components/enterprisepolicies/Policies.jsm", "browser/components/enterprisepolicies/tests/browser/browser.ini", "browser/components/enterprisepolicies/tests/browser/browser_policies_simple_pref_policies.js", "browser/components/enterprisepolicies/tests/browser/browser_policy_disable_pdfjs.js", "browser/components/preferences/in-content/main.js", "browser/extensions/pdfjs/content/PdfJs.jsm"], "git_node": null, "git_parents": [null], "node": "818b81b2177e0995524b3deeddfb1d40c84ed1ef", "parents": ["dc0694bc87c1f0e8f5475804d6845d6c36fcbc01"], "tags": []}, {"author": "Yaron Tausky \u003cytausky@mozilla.com\u003e", "branch": "default", "desc": "Bug 1484524 - Workaround for a nullptr-induced crash in cache IPC. r=edenchuang, a=pascalc\n\nDOM cache IPC code requires a StrongWorkerRef to its worker when invoked\nfrom a WorkerGlobalScope. Under certain condition, e.g. when worker\ntermination was initiated, it's no longer possible to obtain such a reference,\nand said code fails silently by storing a nullptr in the CacheOpArgs object.\nThis leads to a crash when that object gets serialized.\n\nThis is a temporary workaround for this problem, until a more reasonable\nsolution is implemented.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8200", "files": ["dom/cache/TypeUtils.cpp"], "git_node": null, "git_parents": [null], "node": "39d6cdbcbf64bd391e2b7262cae56d686bb970e0", "parents": ["818b81b2177e0995524b3deeddfb1d40c84ed1ef"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1496322 - Update window border colors for Windows 10 1809 update. r=Gijs, a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7718", "files": ["browser/base/content/browser.js", "browser/themes/windows/browser-aero.css"], "git_node": null, "git_parents": [null], "node": "491779804da9cc041b85f0d78fff3df322f994e9", "parents": ["39d6cdbcbf64bd391e2b7262cae56d686bb970e0"], "tags": []}], "date": 1539281323, "git_changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "9971": {"changesets": [{"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1495169 - Remove cached measuring reflows if we aren't measuring the right thing because we got interrupted. r=dholbert, a=pascalc\n\nIf we're waiting on an interrupt, then our child items haven't been totally\nreflowed and our measures would be bogus.\n\nThis will probably regress performance in the cases bug 1209697 fixed, so we\nshould probably add an interrupt check somewhere in nsFlexContainerFrame to\navoid keeping reflowing flex containers indefinitely.\n\nWe could probably just bail out from our reflow if any kid reflow was\ninterrupted.\n\nFiled bug 1495532 to consider that.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7288", "files": ["layout/generic/nsFlexContainerFrame.cpp", "layout/generic/nsFlexContainerFrame.h"], "git_node": null, "git_parents": [null], "node": "9f144c575382a05e93c5c39e5186711588d98a0e", "parents": ["491779804da9cc041b85f0d78fff3df322f994e9"], "tags": []}, {"author": "Stephen A Pohl \u003cspohl.mozilla.bugs@gmail.com\u003e", "branch": "default", "desc": "Bug 1471873 - Ensure that the updater and crashreporter app don't appear in the recent apps section of the Dock on macOS 10.14+. r=mstange, a=RyanVM", "files": ["toolkit/crashreporter/client/macbuild/Contents/Info.plist", "toolkit/mozapps/update/updater/macbuild/Contents/Info.plist.in"], "git_node": null, "git_parents": [null], "node": "119b1911d0da671e5e381c925ee44d5d325575c2", "parents": ["9f144c575382a05e93c5c39e5186711588d98a0e"], "tags": []}, {"author": "Michael Kaply \u003cmozilla@kaply.com\u003e", "branch": "default", "desc": "Bug 1479575 - Search region reset. r=mikedeboer, a=pascalc\n\nDoing a one time search region reset again.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D8269", "files": ["browser/components/nsBrowserGlue.js"], "git_node": null, "git_parents": [null], "node": "94ae3c41f785d883c4a557fb15ff42d54aa398e8", "parents": ["119b1911d0da671e5e381c925ee44d5d325575c2"], "tags": []}], "date": 1539287216, "git_changesets": [null, null, null], "user": "ryanvm@gmail.com"}, "9972": {"changesets": [{"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1481859 - Initialized PdfJs sharedData state earlier in startup. r=bdahl, a=pascalc\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4288", "files": ["browser/components/nsBrowserGlue.js", "browser/extensions/pdfjs/content/PdfJs.jsm"], "git_node": null, "git_parents": [null], "node": "b6b6ccb319bac98aa469b86a1e81f1af55d3e04b", "parents": ["94ae3c41f785d883c4a557fb15ff42d54aa398e8"], "tags": []}, {"author": "Kris Maglione \u003cmaglione.k@gmail.com\u003e", "branch": "default", "desc": "Bug 1489072 - Fix startup perf regression in pdf.js init. r=bdahl, a=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7649", "files": ["browser/components/nsBrowserGlue.js", "browser/extensions/pdfjs/content/PdfJs.jsm"], "git_node": null, "git_parents": [null], "node": "91955baf362bcd432efd89fd8a247bb93e197e91", "parents": ["b6b6ccb319bac98aa469b86a1e81f1af55d3e04b"], "tags": ["DEVEDITION_63_0b14_BUILD1", "DEVEDITION_63_0b14_RELEASE", "FIREFOX_63_0b14_BUILD1", "FIREFOX_63_0b14_RELEASE"]}], "date": 1539288078, "git_changesets": [null, null], "user": "ryanvm@gmail.com"}, "9973": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@m