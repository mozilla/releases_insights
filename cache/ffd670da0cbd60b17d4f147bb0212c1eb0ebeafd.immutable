atch new location.\n\n--\n\nwpt-commits: 781335c8c0bcdbab3d3d6abf5d01adae04e3329c, 5564ab740219cd90a37ebaffc515902bd5bc6f3f\nwpt-pr: 12654\n", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/lint.whitelist", "testing/web-platform/tests/webdriver/tests/actions/special_keys.py", "testing/web-platform/tests/webdriver/tests/add_cookie/add.py", "testing/web-platform/tests/webdriver/tests/conftest.py", "testing/web-platform/tests/webdriver/tests/element_send_keys/scroll_into_view.py", "testing/web-platform/tests/webdriver/tests/get_named_cookie/get.py", "testing/web-platform/tests/webdriver/tests/support/defaults.py", "testing/web-platform/tests/webdriver/tests/support/fixtures.py", "testing/web-platform/tests/webdriver/tests/support/helpers.py"], "git_node": null, "git_parents": [null], "node": "5d49aabdab5caae983f78a4bdab5fa117a2ce699", "parents": ["37133ece7ce2e9f8672fc8bea356ccaa17ce60cc"], "tags": []}, {"author": "moz-wptsync-bot \u003cwptsync@mozilla.com\u003e", "branch": "default", "desc": "Bug 1485763 [wpt PR 12654] - Update wpt metadata, a=testonly\n\nwpt-pr: 12654\nwpt-type: metadata\n", "files": ["testing/web-platform/meta/webdriver/tests/accept_alert/accept.py.ini", "testing/web-platform/meta/webdriver/tests/actions/mouse.py.ini", "testing/web-platform/meta/webdriver/tests/actions/pointer_origin.py.ini", "testing/web-platform/meta/webdriver/tests/back/back.py.ini", "testing/web-platform/meta/webdriver/tests/back/user_prompts.py.ini", "testing/web-platform/meta/webdriver/tests/close_window/close.py.ini", "testing/web-platform/meta/webdriver/tests/delete_session/delete.py.ini", "testing/web-platform/meta/webdriver/tests/dismiss_alert/dismiss.py.ini", "testing/web-platform/meta/webdriver/tests/element_clear/clear.py.ini", "testing/web-platform/meta/webdriver/tests/element_click/bubbling.py.ini", "testing/web-platform/meta/webdriver/tests/element_click/click.py.ini", "testing/web-platform/meta/webdriver/tests/element_click/file_upl