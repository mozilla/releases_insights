server/actors/replay/debugger.js", "devtools/server/actors/replay/replay.js"], "git_node": null, "git_parents": [null], "node": "d96d56907ce0a58521bb129e64fc8b4c01eb816a", "parents": ["ee0b4798b061602ef9e12eb539e4187f59ce4ca2"], "tags": []}, {"author": "Tooru Fujisawa \u003carai_a@mac.com\u003e", "branch": "default", "desc": "Bug 956376 - Part 3: Use Debugger.findSources in ThreadActor#_discoverSources. r=ochameau", "files": ["devtools/server/actors/thread.js"], "git_node": null, "git_parents": [null], "node": "37f94ae472d60f1004844c09146c9eb3b3522055", "parents": ["d96d56907ce0a58521bb129e64fc8b4c01eb816a"], "tags": []}, {"author": "Tooru Fujisawa \u003carai_a@mac.com\u003e", "branch": "default", "desc": "Bug 956376 - Part 4: Use Debugger.findSources in PromisesActor#attach. r=ochameau", "files": ["devtools/server/actors/promises.js"], "git_node": null, "git_parents": [null], "node": "9cb7826b8f28a91d0c3e0034c4a645f08d371885", "parents": ["37f94ae472d60f1004844c09146c9eb3b3522055"], "tags": []}, {"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 1471460 - Adjust the styles of the active markup display badges. r=miker", "files": ["devtools/client/inspector/markup/views/element-editor.js", "devtools/client/themes/markup.css"], "git_node": null, "git_parents": [null], "node": "c09a146819d3a65127cee966b326efa9ee8ea4aa", "parents": ["9cb7826b8f28a91d0c3e0034c4a645f08d371885"], "tags": []}, {"author": "Henri Sivonen \u003chsivonen@hsivonen.fi\u003e", "branch": "default", "desc": "Bug 1483603 - Avoid propagating OOM from StartBulkWrite() when shrinking the buffer. r=froydnj\n\nShrinking the buffer is purely a memory footprint optimization and can be\nomitted as far as the string semantics visible to the caller are concerned.\nSince shrinking is optional, it doesn't make sense to propagate error when\nit fails due to OOM.\n\nMozReview-Commit-ID: BuyBLCBmYzZ\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3866", "files": ["xpcom/string/nsTSubstring.cpp"], "git_node": null, "git_parents": [null], "node": "c6a80a1c10a1c72f525ecc1bd94b72b5a66d9887", "parents": ["ba46bf160bdf92993de91398bfd9012771395125"], "tags": []}, {"author": "Margareta Eliza Balazs \u003cebalazs@mozilla.com\u003e", "branch": "default", "desc": "Merge inbound to mozilla-central.  a=merge", "files": [], "git_node": null, "git_parents": [null, null], "node": "768eef11f5ff119fc3b63221e326db16986900cb", "parents": ["c6a80a1c10a1c72f525ecc1bd94b72b5a66d9887", "c09a146819d3a65127cee966b326efa9ee8ea4aa"], "tags": []}, {"author": "Cosmin Sabou \u003ccsabou@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to mozilla-beta. a=merge l10n=pre-version-bump-merge CLOSED TREE", "files": [], "git_node": null, "git_parents": [null, null], "node": "4084eef2130fb02b6aa4d197b6058b9f8c3acf7d", "parents": ["18ad4be2a951890bdc6492a547fd68c8b5a12223", "768eef11f5ff119fc3b63221e326db16986900cb"], "tags": []}], "date": 1535387913, "git_changesets": [null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null], "user": "csabou@mozilla.com"}, "9731": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 9f4fd933ca7e9e72a477a956c2c35b669a3d58b8 with FENNEC_62_0b21_RELEASE a=release CLOSED TREE", "files": [".hgtags"], "git_node": null, "git_parents": [null], "node": "05195d26a0068908eecd7a182d44630a555d93cd", "parents": ["4084eef2130fb02b6aa4d197b6058b9f8c3acf7d"], "tags": []}], "date": 1535468020, "git_changesets": [null], "user": "ffxbld"}, "9732": {"changesets": [{"author": "Mozilla Releng Treescript \u003crelease+treescript@mozilla.org\u003e", "branch": "default", "desc": "No bug - Tagging 70d9557128b2de2ff42fe946b14dd68a2a4494f1 with DEVEDITION_63_0b1_RELEASE a=release CLOSED TREE", "fi