html/rendering/non-replaced-elements/the-fieldset-element-0/legend-sans-fieldset-display.html", "testing/web-platform/tests/html/rendering/non-replaced-elements/the-fieldset-element-0/legend.html", "testing/web-platform/tests/html/rendering/non-replaced-elements/the-fieldset-element-0/min-inline-size.html", "testing/web-platform/tests/input-device-capabilities/interfaces.html", "testing/web-platform/tests/webdriver/tests/support/fixtures.py"], "git_node": null, "git_parents": [null, null], "node": "3686bea81d04bce59d3b601e744babe3d814e3d6", "parents": ["d90dcb1712d4957676643616337e420d197a83c9", "6920b1cc9a3310cad6132e7fb30b5f1d5fc1fc41"], "tags": []}, {"author": "Jan-Ivar Bruaroey \u003cjib@mozilla.com\u003e", "branch": "default", "desc": "Bug 1487431 - Fix typo in mediasource test_FrameSelection_mp4.html to make last two tests work. r=bryce\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4798", "files": ["dom/media/mediasource/test/test_FrameSelection_mp4.html"], "git_node": null, "git_parents": [null], "node": "bd82753f481a714f04d132bb4620ee5b90f73249", "parents": ["18320a6e8444c623aadf8e1b42ef8a04ab31d203"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1482268 - Upgrade binutils for clang builds to 2.31.1. r=froydnj\n\nAll the Linux builds using GCC uses the binutils bundled with GCC. This\ngives us some leeway to update the binutils used for clang builds (using\nthe binutils toolchain as of bug 1486998) separately.\n\nSince we only ship builds using GCC, we're more free to upgrade\nbinutils for clang builds, without worrying about the next merge.\n\nThis upgrades to the last released version of binutils, and applies the\npatch from https://sourceware.org/bugzilla/show_bug.cgi?id=23591 on top,\nso that asan fuzzing builds don't fail.\n\nThe GPG key used to sign the upstream tarball is unfortunately not\nconnected to the web of trust. I verified the contents matched what's in\nthe Debian archive (which has a different tarball, because some files\nare removed/modified in Debian for license reasons ; there were no\ndifferences besides those).\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4748", "files": ["build/unix/build-binutils/3A24BC1E8FB409FA9F14371813FCEF89DD9E3C4F.key", "build/unix/build-binutils/build-binutils.sh", "taskcluster/ci/fetch/toolchains.yml", "taskcluster/ci/toolchain/linux.yml"], "git_node": null, "git_parents": [null], "node": "f3caf291fde8f6d44ad921f97931c84578014b05", "parents": ["bd82753f481a714f04d132bb4620ee5b90f73249"], "tags": []}, {"author": "Ting-Yu Lin \u003ctlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1347048 - Remove AccessibleCaret's selection bar support. r=mats\n\nThis UI feature was used by B2G only.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4040", "files": ["layout/base/AccessibleCaret.cpp", "layout/base/AccessibleCaret.h", "layout/base/AccessibleCaretManager.cpp", "layout/base/AccessibleCaretManager.h", "layout/base/gtest/TestAccessibleCaretManager.cpp", "layout/style/res/ua.css", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "5db1a1e485eb5353c2556845f34f33d358593b90", "parents": ["f3caf291fde8f6d44ad921f97931c84578014b05"], "tags": []}, {"author": "Fabrice Desr\u00e9 \u003cfabrice@desre.org\u003e", "branch": "default", "desc": "Bug 1487850 - Link.cpp doesn't build if MOZ_PLACES is not defined on non-ANDROID platforms r=Ehsan\n\nThe current code only compiles with ANDROID defined when MOZ_PLACES is undefined. This patch sets\nthe history service to nullptr in the remaining case. The value was already null-checked.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4796", "files": ["dom/base/Link.cpp"], "git_node": null, "git_parents": [null], "node": "8e012f9ed34a9510e506d202a88190ca28f8d108", "parents": ["5db1a1e485eb5353c2556845f34f33d358593b90"], "tags": []}, {"author": "Tiberius Oros \u003ctoros@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset 8e012f9ed34a (bug 1487850) for build bustages on a CLOSED TREE", "files": ["dom/base/Link.cpp"], "git_node": null, "git_parents": [null], "node": "31de93bde10a5533cc7c340ec2aab4ac07720336", "parents": ["8e012f9ed34a9510e506d202a88190ca28f8d108"], "tags": []}, {"author": "Dave Townsend \u003cdtownsend@oxymoronical.com\u003e", "branch": "default", "desc": "Bug 1487650: Don't show a space for a pending favicon in pinned tabs. r=dao\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4771", "files": ["browser/base/content/tabbrowser.css", "browser/base/content/test/favicons/browser_title_flicker.js"], "git_node": null, "git_parents": [null], "node": "1afe5144c19e8aa2e40d6e207881dbb2f3fb73bf", "parents": ["31de93bde10a5533cc7c340ec2aab4ac07720336"], "tags": []}, {"author": "timeless \u003ctimeless@mozdev.org\u003e", "branch": "default", "desc": "Bug 1487889 - Add missing whitespace for certErrorMismatchSinglePrefix1. r=johannh", "files": ["browser/actors/NetErrorChild.jsm"], "git_node": null, "git_parents": [null], "node": "9cbc8592d649c3876156e78fb9539038913435e6", "parents": ["05a0118455e4771d95f0667a713e32c5d0b4ee44"], "tags": []}, {"author": "D\u00e3o Gottwald \u003cdao@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486845 - Remove unused eventNode handling in tabbox. r=enn", "files": ["browser/base/content/browser.xul", "toolkit/content/widgets/tabbox.js"], "git_node": null, "git_parents": [null], "node": "ef8c5c529210fb992f4bff90fb26a4989743aeb8", "parents": ["9cbc8592d649c3876156e78fb9539038913435e6"], "tags": []}, {"author": "Mike Hommey \u003cmh+mozilla@glandium.org\u003e", "branch": "default", "desc": "Bug 1487595 - Remove LIBS_DESC_SUFFIX and EXPAND_LIBS_ORDER_STYLE. r=froydnj\n\nThey're both unused since bug 1429875.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4737\n", "files": ["build/autoconf/expandlibs.m4"], "git_node": null, "git_p