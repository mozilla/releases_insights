], "tags": []}, {"author": "Andrew Osmond \u003caosmond@mozilla.com\u003e", "branch": "default", "desc": "Bug 1487120 - Invalidate nsImageBoxFrame properly for WebRender. r=jrmuizel\n\nWhen the frame updates for an animated image, it will trigger\nnsImageBoxFrame::OnFrameUpdate to be called. We did not change this for\nWebRender, and thus it was missing similar checks added to\nnsImageFrame::InvalidateSelf as originally added in bug 1382985. This\ncaused us to ignore the frame update, and thus the animation never\nappeared to progress.", "files": ["layout/generic/nsImageFrame.cpp", "layout/xul/nsImageBoxFrame.cpp"], "git_node": null, "git_parents": [null], "node": "21fc9db289024eaf15d00df5e4125fded2e15d04", "parents": ["baa98a473b15c03bb983f379b8d7eb003496b2fe"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486730 - Remove some unnecessary includes from js/src/frontend r=Waldo", "files": ["js/src/frontend/BinSource-macros.h", "js/src/frontend/BinSource.h", "js/src/frontend/BinSourceRuntimeSupport.h", "js/src/frontend/BinToken.cpp", "js/src/frontend/BinTokenReaderBase.cpp", "js/src/frontend/BinTokenReaderBase.h", "js/src/frontend/BinTokenReaderMultipart.h", "js/src/frontend/BytecodeCompiler.cpp", "js/src/frontend/BytecodeCompiler.h", "js/src/frontend/BytecodeControlStructures.h", "js/src/frontend/BytecodeEmitter.cpp", "js/src/frontend/BytecodeEmitter.h", "js/src/frontend/EmitterScope.cpp", "js/src/frontend/EmitterScope.h", "js/src/frontend/ErrorReporter.h", "js/src/frontend/FoldConstants.cpp", "js/src/frontend/ForOfLoopControl.h", "js/src/frontend/FullParseHandler.h", "js/src/frontend/NameCollections.h", "js/src/frontend/ParseContext-inl.h", "js/src/frontend/ParseContext.h", "js/src/frontend/ParseNode.cpp", "js/src/frontend/ParseNode.h", "js/src/frontend/Parser.cpp", "js/src/frontend/Parser.h", "js/src/frontend/SharedContext.h", "js/src/frontend/TDZCheckCache.h", "js/src/frontend/TokenStream.h", "js/src/gc/Rooting.h", "js/src/vm/Iteration.h", "js/src/vm/Stack.h"], "git_node": null, "git_parents": [null], "node": "7d07908ee08acfa5333806b907bce7fb20c59dc1", "parents": ["21fc9db289024eaf15d00df5e4125fded2e15d04"], "tags": []}, {"author": "Jon Coppeard \u003cjcoppeard@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486782 - Remove unnecessary includes of gc/Zone.h r=sfink", "files": ["js/src/ctypes/CTypes.cpp", "js/src/frontend/BinToken.cpp", "js/src/frontend/BinTokenReaderBase.cpp", "js/src/frontend/BinTokenReaderMultipart.cpp", "js/src/frontend/BinTokenReaderTester.cpp", "js/src/frontend/TokenStream.h", "js/src/gc/GCInternals.h", "js/src/gc/WeakMap-inl.h", "js/src/jsapi-tests/testBinASTReader.cpp", "js/src/jsapi-tests/testBinTokenReaderTester.cpp", "js/src/jsapi-tests/testGCUniqueId.cpp", "js/src/jsapi-tests/testGCWeakRef.cpp", "js/src/jsapi-tests/testIsInsideNursery.cpp", "js/src/jsfriendapi.cpp", "js/src/shell/js.cpp", "js/src/vm/Compartment.cpp", "js/src/vm/Compartment.h", "js/src/vm/GlobalObject.h", "js/src/vm/ObjectGroup.cpp", "js/src/vm/Realm.h", "js/src/vm/RegExpConstants.h", "js/src/vm/RegExpShared.h", "js/src/vm/UnboxedObject.h"], "git_node": null, "git_parents": [null], "node": "fcae304349d841a9bb2850c59dcc70680b857aa7", "parents": ["7d07908ee08acfa5333806b907bce7fb20c59dc1"], "tags": []}, {"author": "Yash Johar \u003cyash.johar1992@gmail.com\u003e", "branch": "default", "desc": "Bug 1485185: Replace current RDM icon with phone/tablet icon; r=gl", "files": ["devtools/client/themes/images/command-responsivemode.svg", "devtools/client/themes/toolbox.css"], "git_node": null, "git_parents": [null], "node": "498b35c45ec1e50d5f98bcc2ac49c90357c920a2", "parents": ["fcae304349d841a9bb2850c59dcc70680b857aa7"], "tags": []}, {"author": "Gurzau Raul \u003crgurzau@mozilla.com\u003e", "branch": "default", "desc": "Merge inbound to mozilla-central.  a=merge", "files": ["browser/base/content/browser.js", "config/rules.mk", "devtools/client/framework/toolbox.js"], "git_node": null, "git_parents": [null, null], "node": "ff62eab1d2ed5abce22e2922bc0103b0a3df9000", "parents": ["c45b51ec248e6588993262fa1a558a24e3886cd4", "498b35c45ec1e50d5f98bcc2ac49c90357c920a2"], "tags": []}, {"author": "Gurzau Raul \u003crgurzau@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland. a=merge CLOSED TREE", "files": ["browser/themes/shared/browser.inc.css"], "git_node": null, "git_parents": [null, null], "node": "962a34323e709b36f5e46cc89c5a603ab859b5ff", "parents": ["0cdebe3c53f883266962a601a78baaa08cd62d0f", "ff62eab1d2ed5abce22e2922bc0103b0a3df9000"], "tags": []}, {"author": "Jared Wein \u003cjwein@mozilla.com\u003e", "branch": "default", "desc": "Bug 1480907 - Implement ability to bookmark a selection of tabs through drag and drop. r=Felipe\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4589", "files": ["browser/base/content/tabbrowser.xml", "browser/base/content/test/tabs/browser.ini", "browser/base/content/test/tabs/browser_multiselect_tabs_drag_to_bookmarks_toolbar.js"], "git_node": null, "git_parents": [null], "node": "c8d6a8dca44d819667a0cacfed8f0b3f411e4bc5", "parents": ["962a34323e709b36f5e46cc89c5a603ab859b5ff"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1486824 - change BrowserTestUtils to just call OpenBrowserWindow so it does the same thing as opening a window normally, r=mconley,nhnt11\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4466", "files": ["accessible/tests/browser/events/browser_test_textcaret.js", "browser/base/content/browser-captivePortal.js", "browser/base/content/browser.js", "browser/base/content/test/captivePortal/head.js", "browser/base/content/test/forms/browser_selectpopup.js", "browser/base/content/test/plugins/browser_private_clicktoplay.js", "browser/base/content/test/sidebar/browser_sidebar_adopt.js", "browser/components/customizableui/test/browser_editcontrols_update.js", "browser/components/customizableui/test/browser_sidebar_toggle.js", "browser/components/extensions/test/browser/browser_ext_sidebarAction_windows.js", "browser/components/privatebrowsing/test/browser/browser_privatebrowsing_about.js", "browser/components/sessionstore/test/browser_394759_perwindowpb.js", "dom/tests/browser/browser_bug1236512.js", "testing/mochitest/BrowserTestUtils/BrowserTestUtils.jsm"], "git_node": null, "git_parents": [null], "node": "96b5a88ac0041a1bd382a731749e1fca9aa911ed", "parents": ["c8d6a8dca44d819667a0cacfed8f0b3f411e4bc5"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1486297 - Add a pref for Pointer Lock API so that user can disable it. r=smaug!\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4637", "files": ["dom/webidl/Element.webidl", "modules/libpref/init/all.js"], "git_node": null, "git_parents": [null], "node": "86ec37344b447f7feaea09ed2e2eb25146ddff7c", "parents": ["96b5a88ac0041a1bd382a731749e1fca9aa911ed"], "tags": []}, {"author": "Csoregi Natalia \u003cncsoregi@mozilla.com\u003e", "branch": "default", "desc": "Backed out changeset c8d6a8dca44d (bug 1480907) for failures on browser_multiselect_tabs_reorder.js. CLOSED TREE", "files": ["browser/base/content/tabbrowser.xml", "browser/base/content/test/tabs/browser.ini", "browser/base/content/test/tabs/browser_multiselect_tabs_drag_to_bookmarks_toolbar.js"], "git_node": null, "git_parents": [null], "node": "ec1279ae74f332a9b7fa33cbb365a92c7d12b940", "parents": ["86ec37344b447f7feaea09ed2e2eb25146ddff7c"], "tags": []}, {"author": "Dana Keeler \u003cdkeeler@mozilla.com\u003e", "branch": "default", "desc": "bug 1487517 - un-do ciphersuite hiding from bug 1279479 and bug 1316300 r=mt\n\nIn bug 1279479 and bug 1316300 we hid some ciphersuites from TLS 1.3\nhandshakes, assuming we would fall back to TLS 1.2 if the peer needed them.\nHowever, as of bug 1479501, we don't fall back by default, so this just means\nwe can't negotiate these ciphersuites. This patch un-hides these ciphersuites\nfrom the TLS 1.3 handshake.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4725", "files": ["security/manager/ssl/nsNSSComponent.h", "security/manager/ssl/nsNSSIOLayer.cpp"], "git_node": null, "git_parents": [null], "node": "07600cea66576d9be76041dc5e6fb6b4b5dfbefa", "parents": ["ec1279ae74f332a9b7fa33cbb365a92c7d12b940"], "tags": []}, {"author": "Brian Grinstead \u003cbgrinstead@mozilla.com\u003e", "branch": "default", "desc": "Bug 1487476 - Expose lightweight themes as chrome-only features on nsIDocument instead of XULDocument;r=smaug\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4719", "files": ["dom/base/nsDocument.cpp", "dom/base/nsIDocument.h", "dom/xul/XULDocument.cpp", "dom/xul/XULDocument.h", "dom/xul/nsXULElement.cpp"], "git_node": null, "git_parents": [null], "node": "414403195a4ea35d4136828e9883ee1126b5284e", "parents": ["07600cea66576d9be76041dc5e6fb6b4b5dfbefa"], "tags": []}, {"author": "Adam Gashlin \u003cagashlin@mozilla.com\u003e", "branch": "default", "desc": "Bug 1480144: Let Windows Restart Manager ride the trains r=jmathies\n\nThe plan is to study the \"restart manager\" in 62 with a pref flip,\nand if that goes well enable it on release in 63. If it is to be\nenabled for the whole population in 63 it needs to ride the trains,\nso we'll let it be enabled by default as 63 goes to beta. There will\nbe time to uplift a backout so it won't reach the release population,\nif the 62 study indicates problems.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D2620", "files": ["browser/app/profile/firefox.js"], "git_node": null, "git_parents": [null], "node": "fafc1900d5dfeb7e94d7a39982d0603fd3c8f4fb", "parents": ["414403195a4ea35d4136828e9883ee1126b5284e"], "tags": []}, {"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1480349 - RTL hosts don't stay visible when the browser window is resized. r=mak\n\nThis does a few things that should help:\n\n(1) Run the timeout only after resize events have stopped.\n\n(2) Increase the timeout from 30ms to 100ms.  It doesn't need to be so fast.\n\n(3) Add a parameter to formatValue that bypasses actually formatting the value and instead only ensures the host is visible.  There's no need in this case to keep removing the formatting and then adding it back.  Having a \"formatValue\" method take a parameter to skip formatting is kind of weird, though.  At first I tried factoring out the make-host-visible part, but that requires also factoring out all the logic that determines whether the value is a formattable URL, and that ended up being ugly.  I'm open to better ideas.\n\nBased on an earlier patch by Marco Bonardo \u003cmbonardo@mozilla.com\u003e\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4502", "files": ["browser/base/content/test/urlbar/browser_urlbarAddonIframe.js", "browser/base/content/urlbarBindings.xml"], "git_node": null, "git_parents": [null], "node": "e2dcf1b6dd099b30117cd7457895089a01caf0da", "parents": ["fafc1900d5dfeb7e94d7a39982d0603fd3c8f4fb"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1487402 - Selection should stop notifying AutoCopyListener of selection changes after unlinked r=smaug\n\nThis is a regression of bug 1486370.\n\nUnlink of Selection removes all nsISelectionListener first, then, it removes\nall its ranges since it does not want to notify the changes anymore.\n\nAfter bug 1486370, Selection starts to store only bool flag whether it should\nnotify AutoCopyListener of selection changes. So, unless it sets the bool flag\nto false in Unlink, it'll notify selection change caused by Unlink.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4690", "files": ["dom/base/Selection.cpp"], "git_node": null, "git_parents": [null], "node": "2fe5a97dd750816987d3534bdba0d5ddccc73537", "parents": ["e2dcf1b6dd099b30117cd7457895089a01caf0da"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1487449 - stop macro redefinition warning spam for Windows macros; r=ted.mielczarek\n\nThis warning spam happens particularly with WebRTC, but I can see it\nhappening for any third-party software whose use of WINVER and friends\nconflicts with our own.  Let's just change mozilla-config.h to avoid\ndefining these macros if they're already defined via the command line.", "files": ["python/mozbuild/mozbuild/action/process_define_files.py"], "git_node": null, "git_parents": [null], "node": "89e2f1795be7cdb353df6f52ba0b2daa3b28dbb3", "parents": ["498b35c45ec1e50d5f98bcc2ac49c90357c920a2"], "tags": []}, {"author": "Gabriel Luong \u003cgabriel.luong@gmail.com\u003e", "branch": "default", "desc": "Bug 1486801 - Clicking on the [...] should expand the markup container. r=jdescottes", "files": ["devtools/client/inspector/markup/test/browser.ini", "devtools/client/inspector/markup/test/browser_markup_textcontent_display.js", "devtools/client/inspector/markup/test/browser_markup_toggle_04.js", "devtools/client/inspector/markup/views/element-editor.js", "devtools/client/inspector/markup/views/markup-container.js", "devtools/client/themes/markup.css"], "git_node": null, "git_parents": [null], "node": "64418bdd4bd24be885e2078c5c76d354c98165b9", "parents": ["89e2f1795be7cdb353df6f52ba0b2daa3b28dbb3"], "tags": []}, {"author": "Matt Howell \u003cmhowell@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486376 Part 1 - Remove existing copy of the 7-zip code. r=agashlin", "files": ["other-licenses/7zstub/src/Asm/arm/7zCrcOpt.asm", "other-licenses/7zstub/src/Asm/x86/7zAsm.asm", "other-licenses/7zstub/src/Asm/x86/7zCrcOpt.asm", "other-licenses/7zstub/src/Asm/x86/AesOpt.asm", "other-licenses/7zstub/src/Asm/x86/XzCrc64Opt.asm", "other-licenses/7zstub/src/C/7z.h", "other-licenses/7zstub/src/C/7zAlloc.c", "other-licenses