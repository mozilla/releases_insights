ranch": "default", "desc": "Bug 1486793 - [wdspec] Add basic tests for \"Take Element Screenshot\" command. r=ato", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/webdriver/tests/take_element_screenshot/__init__.py", "testing/web-platform/tests/webdriver/tests/take_element_screenshot/screenshot.py", "testing/web-platform/tests/webdriver/tests/take_element_screenshot/user_prompts.py"], "git_node": null, "git_parents": [null], "node": "46011d6f389df1f1f41a862c73e59b1716e92e55", "parents": ["e2251ddcafd236d667b5ebb4908429bc88c99de8"], "tags": []}, {"author": "Nathan Froyd \u003cfroydnj@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486882 - make TestPoisonArea work with aarch64 windows; r=Waldo\n\nWe already have the AArch64 return instruction; we just need to check\nfor the Windows-specific preprocessor conditional.", "files": ["mfbt/tests/TestPoisonArea.cpp"], "git_node": null, "git_parents": [null], "node": "4ad9205ce6c1d673c65f97a6d02b21d86a28c29b", "parents": ["46011d6f389df1f1f41a862c73e59b1716e92e55"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1487124 - [marionette] Skip test_capture_vertical_bounds on Android. r=whimboo", "files": ["testing/marionette/harness/marionette_harness/tests/unit/test_screenshot.py"], "git_node": null, "git_parents": [null], "node": "034adef609b91e0c2dc2c353dcb5d5dc9ff18a40", "parents": ["4ad9205ce6c1d673c65f97a6d02b21d86a28c29b"], "tags": []}, {"author": "arthur.iakab \u003caiakab@mozilla.com\u003e", "branch": "default", "desc": "Merge inbound to mozilla-central a=merge", "files": ["browser/components/preferences/in-content/privacy.js", "browser/components/preferences/in-content/privacy.xul", "browser/locales/en-US/browser/preferences/preferences.ftl", "python/mozbuild/mozbuild/mach_commands.py", "taskcluster/taskgraph/transforms/task.py", "third_party/rust/parking_lot_core/src/stable.rs"], "git_node": null, "git_parents": [null, null], "node": "2b50a2ad969a326c3d066426d6e823c44de5b7d4", "parents": ["b946a1ac70e563013202fb7eb6c096de53249eca", "034adef609b91e0c2dc2c353dcb5d5dc9ff18a40"], "tags": []}, {"author": "Sebastian Hengst \u003carchaeopteryx@coole-files.de\u003e", "branch": "default", "desc": "Bug 1487031 - Disable Talos h1 and h2 jobs until geckodriver in generation task for heavy profile gets updated to 0.21.0. r=jmaher a=permafail-disabling\n\nReviewers: jmaher\n\nTags: #secure-revision\n\nBug #: 1487031\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4592", "files": ["taskcluster/ci/test/test-sets.yml"], "git_node": null, "git_parents": [null], "node": "c6555188a710a4843da3862995860fe847d76287", "parents": ["2b50a2ad969a326c3d066426d6e823c44de5b7d4"], "tags": []}, {"author": "arthur.iakab \u003caiakab@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland", "files": ["third_party/rust/parking_lot_core/src/stable.rs"], "git_node": null, "git_parents": [null, null], "node": "00ae06989ae033bf9a79936d9929852cff09e8c4", "parents": ["f34cdd02f6b13ec00430211c08b0a296bc5f26ee", "c6555188a710a4843da3862995860fe847d76287"], "tags": []}, {"author": "Gijs Kruitbosch \u003cgijskruitbosch@gmail.com\u003e", "branch": "default", "desc": "Bug 1486824 - change BrowserTestUtils to just call OpenBrowserWindow so it does the same thing as opening a window normally, r=mconley,nhnt11\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4466", "files": ["accessible/tests/browser/events/browser_test_textcaret.js", "browser/base/content/browser-captivePortal.js", "browser/base/content/browser.js", "browser/base/content/test/captivePortal/head.js", "browser/base/content/test/forms/browser_selectpopup.js", "browser/base/content/test/plugins/browser_private_clicktoplay.js", "browser/base/content/test/sidebar/browser_sidebar_adopt.js", "browser/components/customizableui/test/browser_sidebar_toggle.js", "browser/components/extensions/test/browser/browser_ext_sidebarAction_windows.js", "browser/components/sessionstore/test/browser_394759_perwindowpb.js", "dom/tests/browser/browser_bug1236512.js", "testing/mochitest/BrowserTestUtils/BrowserTestUtils.jsm"], "git_node": null, "git_parents": [null], "node": "4e195f7b2d6b8c12aba04ef69401e9af65daa05a", "parents": ["00ae06989ae033bf9a79936d9929852cff09e8c4"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1486623 - Skip less nodes when reporting memory, and report ShadowRoot's StyleSheets. r=bzbarsky\n\nThis moves all the node-specific reporting to nsIDocument.\n\nOrphanReporter delegates all the reporting to that and then returns the sum of\nall sizes, which is not ideal but was pre-existing.\n\nAlso, I moved the main mStyleSheets size reporting to DocumentOrShadowRoot for\nit to be shared between document and ShadowRoot.\n\nI'll add memory reporting for the computed stylesheet maps and such in the\nShadowRoot in a followup.\n\nI went through all the XBL bindings, though it seems I could just use\nGetBindingWithContent(), since according to:\n\n  https://searchfox.org/mozilla-central/rev/55da592d85c2baf8d8818010c41d9738c97013d2/dom/xbl/nsXBLBinding.cpp#615\n\nWe don't allow multiple bindings to contribute anon content. Anyway it was the\nsame amount of code...\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4433", "files": ["dom/base/DocumentOrShadowRoot.cpp", "dom/base/DocumentOrShadowRoot.h", "dom/base/ShadowRoot.cpp", "dom/base/ShadowRoot.h", "dom/base/nsDocument.cpp", "dom/base/nsIDocument.h", "js/xpconnect/src/XPCJSRuntime.cpp"], "git_node": null, "git_parents": [null], "node": "2f49db02e5f6b4528bb5fe04c9fb9e80581b9adb", "parents": ["4e195f7b2d6b8c12aba04ef69401e9af65daa05a"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1486728 - Report memory usage of Shadow DOM style data. r=njn\n\nThis is on top of bug 1486623.\n\nWhile at it removed the 'stale computed styles' report, since it was unused\nsince I removed the undisplayed maps.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4453", "files": ["dom/base/DocumentOrShadowRoot.cpp", "dom/base/DocumentOrShadowRoot.h", "dom/base/ShadowRoot.cpp", "dom/base/nsWindowMemoryReporter.cpp", "dom/base/nsWindowSizes.h"], "git_node": null, "git_parents": [null], "node": "ac2c1fea89ea57dee4a5b85dd046ca7ef71a9baf", "parents": ["2f49db02e5f6b4528bb5fe04c9fb9e80581b9adb"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1487198 - Measure memory usage of the identifier map in ShadowRoot as well. r=smaug\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4615", "files": ["dom/base/DocumentOrShadowRoot.cpp", "dom/base/nsDocument.cpp"], "git_node": null, "git_parents": [null], "node": "48f88e237b4e94be9f85a52abb5cc13071dd8cc0", "parents": ["ac2c1fea89ea57dee4a5b85dd046ca7ef71a9baf"], "tags": []}, {"author": "Drew Willcoxon \u003cadw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1480349 - RTL hosts don't stay visible when the browser window is resized. r=mak\n\nThis does a few things that should help:\n\n(1) Run the timeout only after resize events have stopped.\n\n(2) Increase the timeout from 30ms to 100ms.  It doesn't need to be so fast.\n\n(3) Add a parameter to formatValue that bypasses actually formatting the value and instead only ensures the host is visible.  There's no need in this case to keep removing the formatting and then adding it back.  Having a \"formatValue\" method take a parameter to skip formatting is kind of weird, though.  At first I tried factoring out the make-host-visible part, but that requires also factoring out all the logic that determines whether the value is a formattable URL, and that ended up being ugly.  I'm open to better ideas.\n\nBased on an earlier patch by Marco Bonardo \u003cmbonardo@mozilla.com\u003e\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4502", "files": ["browser/base/content/test/urlbar/browser_urlbarAddonIframe.js", "browser/base/content/urlbarBindings.xml"], "git_node": null, "git_parents": [null], "node": "76ccb62dd14d57f1fdb8e9448b97eb06500ba9d7", "parents": ["48f88e237b4e94be9f85a52abb5cc13071dd8cc0"], "tags": []}, {"author": "Miko Mynttinen \u003cmikokm@gmail.com\u003e", "branch": "default", "desc": "Bug 1486477 - Initialize nsDisplayCanvasThemedBackground properly r=mattwoodrow\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4438", "files": ["layout/generic/nsCanvasFrame.h"], "git_node": null, "git_parents": [null], "node": "24e01317f8c2ab542de4f63304b1a0d23c3dfbd5", "parents": ["76ccb62dd14d57f1fdb8e9448b97eb06500ba9d7"], "tags": []}, {"author": "Joel Maher \u003cjmaher@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486789 - support subtest units independent of benchmark units, set values for speedometer. r=ahal\n\nallow support in .ini files for subtest units and lower_is_better values; implement this for speedometer.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4465", "files": ["testing/raptor/raptor/manifest.py", "testing/raptor/raptor/output.py", "testing/raptor/raptor/tests/raptor-speedometer.ini", "testing/raptor/webext/raptor/runner.js"], "git_node": null, "git_parents": [null], "node": "872ea5bd5a172c4c0d8bb65f9b064c8e9568f144", "parents": ["24e01317f8c2ab542de4f63304b1a0d23c3dfbd5"], "tags": []}, {"author": "Tom Ritter \u003ctom@mozilla.com\u003e", "branch": "default", "desc": "Bug 1480178 Bump mingw version to pick up new API functions and provide libmincorer?froydnj r=froydnj\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4565", "files": ["taskcluster/scripts/misc/build-clang-7-pre-mingw.sh"], "git_node": null, "git_parents": [null], "node": "8897c80e6240025264a58cf1b3ff7cbdf97c6e76", "parents": ["872ea5bd5a172c4c0d8bb65f9b064c8e9568f144"], "tags": []}, {"author": "Imanol Fernandez \u003cmortimergoro@gmail.com\u003e", "branch": "default", "desc": "Bug 1487079 - Fix hasOrientation and hasPosition are switched on WebVR GamepadPose r=qdot,kip\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4534", "files": ["dom/gamepad/GamepadPose.cpp"], "git_node": null, "git_parents": [null], "node": "5acb0074a4b37de8fcc0d727bfc68cc9a0c6bda3", "parents": ["8897c80e6240025264a58cf1b3ff7cbdf97c6e76"], "tags": []}, {"author": "Brian Birtles \u003cbirtles@gmail.com\u003e", "branch": "default", "desc": "Bug 1485901 - Add localization plumbing for new about:debugging panels; r=jdescottes\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4503", "files": ["devtools/client/aboutdebugging-new/aboutdebugging.js", "devtools/client/aboutdebugging-new/src/components/App.js", "devtools/client/aboutdebugging-new/src/components/sidebar/Sidebar.js", "devtools/client/aboutdebugging-new/tmp-locale/en-US/aboutdebugging.notftl", "devtools/client/jar.mn"], "git_node": null, "git_parents": [null], "node": "8031da3e4c91cca4e32e9b5ef6e9ffba03e30eca", "parents": ["5acb0074a4b37de8fcc0d727bfc68cc9a0c6bda3"], "tags": []}, {"author": "Miko Mynttinen \u003cmikokm@gmail.com\u003e", "branch": "default", "desc": "Bug 1472733 - Improve IntRect overflow handling when calculating layer invalidation area and visible region r=mattwoodrow\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4627", "files": ["gfx/layers/LayerTreeInvalidation.cpp", "gfx/layers/composite/LayerManagerComposite.cpp", "layout/painting/FrameLayerBuilder.cpp", "layout/painting/nsDisplayList.cpp"], "git_node": null, "git_parents": [null], "node": "6ba3579108f3dc4bcf014bbb1e5be1110795986c", "parents": ["8031da3e4c91cca4e32e9b5ef6e9ffba03e30eca"], "tags": []}, {"author": "Brian Hackett \u003cbhackett1024@gmail.com\u003e", "branch": "default", "desc": "Bug 1483319 Part 1 - Transmit console message arguments as debuggee values, r=jimb.", "files": ["devtools/server/actors/replay/debugger.js", "devtools/server/actors/replay/replay.js", "devtools/server/actors/webconsole.js"], "git_node": null, "git_parents": [null], "node": "fd6f1b574cbbdc5042b1802cce4aa8e3716b5ad4", "parents": ["034adef609b91e0c2dc2c353dcb5d5dc9ff18a40"], "tags": []}, {"author": "Brian Hackett \u003cbhackett1024@gmail.com\u003e", "branch": "default", "desc": "Bug 1483319 Part 2 - Treat replayForcedPause as unsolicited, r=jimb.", "files": ["devtools/shared/client/constants.js"], "git_node": null, "git_parents": [null], "node": "ed84aae6166c98f9870f769193fc55a93ee27977", "parents": ["fd6f1b574cbbdc5042b1802cce4aa8e3716b5ad4"], "tags": []}, {"author": "Brian Hackett \u003cbhackett1024@gmail.com\u003e", "branch": "default", "desc": "Bug 1483319 Part 3 - Combine BreakpointPaused and CheckpointPaused phases, r=mccr8.", "files": ["toolkit/recordreplay/ipc/ChildNavigation.cpp"], "git_node": null, "git_parents": [null], "node": "2ddf1cb297c5abc89e56df7105a3a595fea9f41d", "parents": ["ed84aae6166c98f9870f769193fc55a93ee27977"], "tags": []}, {"author": "Brian Hackett \u003cbhackett1024@gmail.com\u003e", "branch": "default", "desc": "Bug 1483319 Part 4 - Give ReplayDebugger control over when the active child should be replaying, r=mccr8.", "files": ["toolkit/recordreplay/ipc/JSControl.cpp", "toolkit/recordreplay/ipc/ParentIPC.cpp", "toolkit/recordreplay/ipc/ParentInternal.h"], "git_node": null, "git_parents": [null], "node": "4eb666e572f9998ba6ec4e261b2af80bd514029e", "parents": ["2ddf1cb297c5abc89e56df7105a3a595fea9f41d"], "tags": []}, {"author": "Brian Hackett \u003cbhackett1024@gmail.com\u003e", "branch": "default", "desc": "Bug 1483319 Part 5 - Ensure that the child process is replaying when sending requests that might trigger recording divergence, r=jimb.", "files": ["devtools/server/actors/replay/debugger.js"], "git_node": null, "git_parents": [null], "node": "8b832de5ad1d4ec6a0ad4951414c26a34800143a", "parents": ["4eb666e57