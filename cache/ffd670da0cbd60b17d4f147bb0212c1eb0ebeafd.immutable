changesets": [null, null, null, null], "user": "ryanvm@gmail.com"}, "9944": {"changesets": [{"author": "ahillier \u003cahillier@mozilla.com\u003e", "branch": "default", "desc": "Bug 1490508 - Apply mask correctly to CFR recommendation on urlbar focus r=Mardak,ursula a=pascalc\n\nOther part of this patch landed as https://hg.mozilla.org/releases/mozilla-beta/rev/cd305e92721b\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7320\n", "files": ["browser/components/newtab/lib/CFRPageActions.jsm"], "git_node": null, "git_parents": [null], "node": "b80fb23f66ea441b92d925bc878e07b56fba33cf", "parents": ["241c336e1fd0a5932b5f23efaf0d99c10802ffb0"], "tags": []}], "date": 1538777184, "git_changesets": [null], "user": "edilee@gmail.com"}, "9945": {"changesets": [{"author": "Boris Zbarsky \u003cbzbarsky@mit.edu\u003e", "branch": "default", "desc": "Bug 1496159 - Don't try to load modules from the bytecode cache. r=nbp, a=abillings", "files": ["dom/script/ScriptLoader.cpp"], "git_node": null, "git_parents": [null], "node": "503d94e63a248b88c412bc596247c8999a8aaaba", "parents": ["b80fb23f66ea441b92d925bc878e07b56fba33cf"], "tags": []}], "date": 1538829323, "git_changesets": [null], "user": "ryanvm@gmail.com"}, "9946": {"changesets": [{"author": "Johan Lorenzo \u003cjlorenzo@mozilla.com\u003e", "branch": "default", "desc": "Bug 1496090 - mozapkpublisher: Do not call version specific URLs anymore r=mtabara a=release\n\nBacked out changeset bc805cf0e6c5\n\nDifferential Revision: https://phabricator.services.mozilla.com/D7695", "files": ["taskcluster/ci/google-play-strings/kind.yml", "taskcluster/taskgraph/transforms/google_play_strings.py"], "git_node": null, "git_parents": [null], "node": "8027fae752ae41cf20c33607c0af3e02de03ae75", "parents": ["503d94e63a248b88c412bc596247c8999a8aaaba"], "tags": []}], "date": 1538991282, "git_changesets": [null], "user": "jlorenzo@mozilla.com"}, "9947": {"changesets": [{"author": "Tooru Fujisawa \u003carai_a@mac.com\u003e", "branc