evtools/client/aboutdebugging-new/src/middleware/worker-component-data.js", "devtools/client/aboutdebugging-new/src/reducers/runtime-state.js"], "git_node": null, "git_parents": [null], "node": "74cc390c60c4eca61fff9c95482c3afd9b652665", "parents": ["b01461eb41f7e87ecb8751d83989a055de5d907c"], "tags": []}, {"author": "Benjamin Bouvier \u003cbenj@benj.me\u003e", "branch": "default", "desc": "Bug 1485396: Handle non-unified builds for CompileDB too; r=froydnj", "files": ["python/mozbuild/mozbuild/compilation/database.py"], "git_node": null, "git_parents": [null], "node": "7e63c084f3090ff68f8c6c60bd78be2b70e791c3", "parents": ["74cc390c60c4eca61fff9c95482c3afd9b652665"], "tags": []}, {"author": "Ehsan Akhgari \u003cehsan@mozilla.com\u003e", "branch": "default", "desc": "Bug 1485871 - Remove some unused XPCOM registrations for editor; r=masayuki\n", "files": ["dom/html/nsTextEditorState.cpp", "editor/moz.build", "editor/nsEditorCID.h", "layout/build/nsLayoutModule.cpp"], "git_node": null, "git_parents": [null], "node": "289a5cd12a3839fa13ed1b3517b7a1fd2d3d4fea", "parents": ["7e63c084f3090ff68f8c6c60bd78be2b70e791c3"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1485580 - [wdspec] Improve timeouts tests for \"Set Timeout\" and \"New Session\". r=jgraham", "files": ["testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/webdriver/tests/new_session/invalid_capabilities.py", "testing/web-platform/tests/webdriver/tests/new_session/support/create.py", "testing/web-platform/tests/webdriver/tests/set_timeouts/set.py", "testing/web-platform/tests/webdriver/tests/set_timeouts/user_prompts.py"], "git_node": null, "git_parents": [null], "node": "1fd335726c0088e8ffe303beff533442c973b083", "parents": ["289a5cd12a3839fa13ed1b3517b7a1fd2d3d4fea"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1485580 - [marionette] Update unit tests for invalid timeout values. r=jgraham", "files": ["testing/marionette/harness/marionette_harness/tests/unit/test_capabilities.py", "testing/marionette/test/unit/test_capabilities.js"], "git_node": null, "git_parents": [null], "node": "4bc3167b02408d6af7f7bff52a0e77864254321d", "parents": ["1fd335726c0088e8ffe303beff533442c973b083"], "tags": []}, {"author": "Henrik Skupin \u003cmail@hskupin.info\u003e", "branch": "default", "desc": "Bug 1485580 - [geckodriver] Make parsing of float timeout values spec conforming. r=jgraham", "files": ["testing/web-platform/meta/webdriver/tests/new_session/create_alwaysMatch.py.ini", "testing/web-platform/meta/webdriver/tests/new_session/create_firstMatch.py.ini", "testing/webdriver/src/capabilities.rs", "testing/webdriver/src/command.rs", "testing/webdriver/src/common.rs"], "git_node": null, "git_parents": [null], "node": "26632fd3312a52222f96889a162f0374341329c9", "parents": ["4bc3167b02408d6af7f7bff52a0e77864254321d"], "tags": []}, {"author": "Jim Chen \u003cnchen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1485384 - Fix typo in open_allowCallsWhileClosed; r=me", "files": ["mobile/android/geckoview/src/androidTest/java/org/mozilla/geckoview/test/SessionLifecycleTest.kt"], "git_node": null, "git_parents": [null], "node": "2e9784340c6ca19cdeceab3c7526a4ecb2414d65", "parents": ["26632fd3312a52222f96889a162f0374341329c9"], "tags": []}, {"author": "Andrew Sutherland \u003casutherland@asutherland.org\u003e", "branch": "default", "desc": "Bug 1472303 - Backed out changeset 8a40d04dfcbb. r=asuth\n\nThe logic here to move our check was right, but our check was wrong.\nAlso, we landed a test that checked for our wrong implementation.\n\nWe need to correct our implementation and re-think the test.  The\nright test might just be a mochitest, possibly with some Firefox-only\nhooks involved.", "files": ["dom/serviceworkers/ServiceWorkerRegistration.cpp", "dom/serviceworkers/ServiceWorkerRegistrationImpl.cpp", "dom/workers/WorkerScope.cpp", "dom/workers/WorkerScope.h", "testing/web-platform/meta/MANIFEST.json", "testing/web-platform/tests/service-workers/service-worker/resources/update-top-level-worker.py", "testing/web-platform/tests/service-workers/service-worker/update-top-level.https.html"], "git_node": null, "git_parents": [null], "node": "ad4c1dca81f7c484d7ced574b50e2a44fb5738d6", "parents": ["2e9784340c6ca19cdeceab3c7526a4ecb2414d65"], "tags": []}, {"author": "Lifan Zeng \u003clifanfzeng@gmail.com\u003e", "branch": "default", "desc": "Bug 1446923 - Remove Some Old References to Chrome-Metro r=jlund\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3223", "files": ["python/mozbuild/mozbuild/test/frontend/test_emitter.py", "python/mozbuild/mozbuild/testing.py", "testing/mozharness/configs/unittests/win_taskcluster_unittest.py", "testing/mozharness/configs/unittests/win_unittest.py"], "git_node": null, "git_parents": [null], "node": "3d81b4beb659399940b24d237ea38ba6f83393db", "parents": ["043aff7fda61899c7af4e49eb0f971ab29722bc4"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1485293 - Make test_resizers_resizing_elements.html allow 2px difference of the result r=m_kato\n\nOddly, on Android, size of resized objects may be 2px different from ideal\nvalue.  I don't know the reason, could be zoom level or something is affected.\nHowever, fortunately, this difference is not important for this test because\nthis test checks whether resizers actually works with specific elements.\nSo, even if the result is 2px smaller or bigger than ideal value, we succeeded\nto check the resizer makes the element bigger or smaller as expected.\n\nTherefore, this patch makes the test allow 2px differences of the result.\n\nAdditionally, on Android, this test is always timed out if TV (even opt build).\nSo, this patch disables TV on Android.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4058", "files": ["editor/libeditor/tests/mochitest.ini", "editor/libeditor/tests/test_resizers_resizing_elements.html"], "git_node": null, "git_parents": [null], "node": "33d24ba5659c3a34faced448a925f903c4fc1e42", "parents": ["3d81b4beb659399940b24d237ea38ba6f83393db"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1484128 - part 0: Add automated tests for nsITableEditor::GetFirstSelectedCell() r=m_kato\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4059", "files": ["editor/libeditor/tests/mochitest.ini", "editor/libeditor/tests/test_nsITableEditor_getFirstSelectedCell.html"], "git_node": null, "git_parents": [null], "node": "7f45ff1131eb91c279120db47194cb4866e9a6f9", "parents": ["33d24ba5659c3a34faced448a925f903c4fc1e42"], "tags": []}, {"author": "Masayuki Nakano \u003cmasayuki@d-toybox.com\u003e", "branch": "default", "desc": "Bug 1484128 - part 1: Create HTMLEditor::GetFirstSelectedTableCellElement() for internal use of HTMLEditor::GetFirstSelectedCell() r=m_kato\n\nHTMLEditor::GetFirstSelectedCell() is an XPCOM method, but used internally a\nlot.  Therefore, we should create a non-virtual method for internal use.\n\nThis patch creates HTMLEditor::GetFirstSelectedTableCellElement(), and it\nwon't return NS_SUCCESS_EDITOR_ELEMENT_NOT_FOUND since nobody needs the\nvalue.  It's enough to check whether the result is nullptr without error for\nany callers.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4060", "files": ["editor/libeditor/HTMLEditRules.cpp", "editor/libeditor/HTMLEditor.cpp", "editor/libeditor/HTMLEditor.h", "editor/libeditor/HTMLEditorDataTransfer.cpp", "editor/libeditor/HTMLTableEditor.cpp", "editor/nsITableEditor.idl"], "git_node": null, "git_parents": [null], "node": "90f962c6f3dfefc79d0d6baf6e43e52455ee7b06", "parents": ["7f45ff1131eb91c279120db47194cb4866e9a6f9"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1485930 - Make tree pseudo-element prefix not case-sensitive. r=emilio\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4185", "files": ["layout/style/test/test_selectors.html", "servo/components/style/gecko/pseudo_element.rs", "servo/components/style/gecko/pseudo_element_definition.mako.rs", "servo/components/style/gecko/selector_parser.rs"], "git_node": null, "git_parents": [null], "node": "123eca2de8b83e4519a911d486dcfb3100a9b440", "parents": ["90f962c6f3dfefc79d0d6baf6e43e52455ee7b06"], "tags": []}, {"author": "Johann Hofmann \u003cjhofmann@mozilla.com\u003e", "branch": "default", "desc": "Bug 1484574 - Update copy for the content blocking section in the identity popup. r=paolo\n\nThis updates some copy based on UX and legal requirements as well as add a correct\nSUMO URL for the \"Learn More\" link for breakage reporting.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4172", "files": ["browser/base/content/browser-contentblocking.js", "browser/base/content/test/trackingUI/browser_trackingUI_report_breakage.js", "browser/components/controlcenter/content/panel.inc.xul", "browser/locales/en-US/chrome/browser/browser.dtd", "browser/themes/shared/controlcenter/panel.inc.css"], "git_node": null, "git_parents": [null], "node": "1a83a81da7387171b49c73ed634f026e070ba83d", "parents": ["123eca2de8b83e4519a911d486dcfb3100a9b440"], "tags": []}, {"author": "Tiberius Oros \u003ctoros@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland. a=merge CLOSED TREE", "files": ["gfx/2d/RwAssert.h", "testing/web-platform/meta/html/rendering/non-replaced-elements/the-fieldset-element-0/legend-position-relative.html.ini"], "git_node": null, "git_parents": [null, null], "node": "067c58fa95f155a7cc2780c11ca76dc3dca5896d", "parents": ["1a83a81da7387171b49c73ed634f026e070ba83d", "190b827aaa2b5e6fb9af7a0defb238ccc35f8b9e"], "tags": []}, {"author": "Xidorn Quan \u003cme@upsuper.org\u003e", "branch": "default", "desc": "Bug 1484521 - Prepend bullet frame in line layout. r=jfkthame\n\nBug 1478178 regressed this case because bullet frame is the last frame\nadded to line layout, rather than the first, so when we try to apply\njustification, we end up giving it the accumulated offset of the whole\nline.\n\nBullet frame has to be added after other frames in the line have been\nplaced, because its presence may depend on whether the line is empty.\nHowever, bullet frame is logically the first frame in a line and\nappending it to the end is somewhat counter-intuitive.\n\nThus, this patch tries to fix the issue via prepending bullet frame in\nline layout, so that the order of frames there can be more reliable.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3760", "files": ["layout/generic/nsBlockFrame.cpp", "layout/generic/nsLineLayout.cpp", "layout/generic/nsLineLayout.h", "layout/reftests/list-item/bullet-justify-1-ref.html", "layout/reftests/list-item/bullet-justify-1.html", "layout/reftests/list-item/reftest.list"], "git_node": null, "git_parents": [null], "node": "5c420838bf5229f08145ac9a8c0f4b06cfbc2925", "parents": ["067c58fa95f155a7cc2780c11ca76dc3dca5896d"], "tags": []}, {"author": "Andrei Lazar \u003candrei.a.lazar@softvision.ro\u003e", "branch": "default", "desc": "Bug 1482836 Remove deprecated Snippets code r=jchen\n\nRemoved unused Snippets code since now we're using Leanplum.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3521", "files": [".eslintignore", "mobile/android/components/MobileComponents.manifest", "mobile/android/components/Snippets.js", "mobile/android/components/moz.build", "mobile/android/installer/package-manifest.in"], "git_node": null, "git_parents": [null], "node": "917e36757da91e807aa0034fa2fe280eec5e32fd", "parents": ["5c420838bf5229f08145ac9a8c0f4b06cfbc2925"], "tags": []}, {"author": "ozoder \u003cozoder@redhat.com\u003e", "branch": "default", "desc": "Bug 1481392 - Close DBus connection after print, r=stransky\n\nDifferential Revision: http