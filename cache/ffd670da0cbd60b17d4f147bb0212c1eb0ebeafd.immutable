c/ir/ty.rs", "third_party/rust/bindgen/src/lib.rs", "third_party/rust/bindgen/src/options.rs", "third_party/rust/bindgen/src/regex_set.rs", "third_party/rust/bitflags/.cargo-checksum.json", "third_party/rust/bitflags/.travis.yml", "third_party/rust/bitflags/CHANGELOG.md", "third_party/rust/bitflags/CODE_OF_CONDUCT.md", "third_party/rust/bitflags/Cargo.toml", "third_party/rust/bitflags/README.md", "third_party/rust/bitflags/src/example_generated.rs", "third_party/rust/bitflags/src/lib.rs"], "git_node": null, "git_parents": [null], "node": "14ff938f2a6b4e7664e126569f1f6cfd2dc06ad6", "parents": ["0cc36a5788515e2590165b1680bbb286fe51481d"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1488172 - Fix Servo and unit tests build. r=me\n", "files": ["servo/components/style/properties/longhands/box.mako.rs", "servo/components/style/selector_parser.rs", "servo/components/style/servo/selector_parser.rs", "servo/components/style/stylist.rs", "servo/tests/unit/style/parsing/mod.rs", "servo/tests/unit/style/properties/mod.rs", "servo/tests/unit/style/viewport.rs"], "git_node": null, "git_parents": [null], "node": "d26ec598073acc11f0f6d3bcdbc429ba0066978e", "parents": ["14ff938f2a6b4e7664e126569f1f6cfd2dc06ad6"], "tags": []}, {"author": "Luca Greco \u003clgreco@mozilla.com\u003e", "branch": "default", "desc": "Bug 1487836 - Fix innerWindowID used for the WebExtensions devtools API eval denied errors. r=jdescottes\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4782", "files": ["devtools/server/actors/addon/webextension-inspected-window.js"], "git_node": null, "git_parents": [null], "node": "55570b34ff7c29a1159145007380745ea50cec4e", "parents": ["d26ec598073acc11f0f6d3bcdbc429ba0066978e"], "tags": []}, {"author": "ffxbld \u003cffxbld@mozilla.com\u003e", "branch": "default", "desc": "No Bug, mozilla-central repo-update HSTS HPKP blocklist remote-settings - a=repo-update r=RyanVM\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4852", "files": ["browser/app/blocklist.xml", "security/manager/ssl/StaticHPKPins.h", "security/manager/ssl/nsSTSPreloadList.inc", "services/settings/dumps/blocklists/addons.json"], "git_node": null, "git_parents": [null], "node": "fd75f8567ce97653176559bfedd37afd46b36d78", "parents": ["55570b34ff7c29a1159145007380745ea50cec4e"], "tags": []}, {"author": "Kershaw Chang \u003ckershaw@mozilla.com\u003e", "branch": "default", "desc": "Bug 1357676 - Implement batch eviction r=jdm\n\n1. Add network.cookie.QuotaPerHost, which has the default value 150.\n2. When the cookies exceed more than 180, evict cookies to 150.\n3. The concept of eviction is to sort all cookies by whether the cookie is expired and the cookie's last access time. Then, evict cookies by the given count.\n4. Details of evict algorithm:\n   4.1 Create a priority queue and push all cookies in it.\n   4.2 Use custom comparator to compare the cookie by expiry and last access.\n   4.3 Pop 30(180 - 150) cookies from the queue and append them to an output array.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D3342", "files": ["modules/libpref/init/all.js", "netwerk/cookie/nsCookieService.cpp", "netwerk/cookie/nsCookieService.h", "netwerk/cookie/test/unit/test_eviction.js"], "git_node": null, "git_parents": [null], "node": "a596012f29db4681255057a35690f251a73b7282", "parents": ["fd75f8567ce97653176559bfedd37afd46b36d78"], "tags": []}, {"author": "Emilio Cobos \u00c1lvarez \u003cemilio@crisal.io\u003e", "branch": "default", "desc": "Bug 1487649 - Don't do a name check when cloning a shadow root for print preview. r=smaug\n\nOtherwise the ShadowRoot for \u003cuse\u003e or other internal ones may not get cloned\nproperly.\n\nDifferential Revision: https://phabricator.services.mozilla.com/D4756", "files": ["dom/base/nsNodeUtils.cpp", "layout/base/tests/chrome/printpreview_helper.xul"], "git_node": null, "git_parents": [null], "node": "5254a8f44df4ac705bf05fe55476f476a37bf8b9", "parents": ["a596012f29db4681255057a35690f251a73b7282"], "tags": []}, {"author": "Peter Moore \u003cpmoore@mozilla.com\u003e", "branch": "default", "desc": "Bug 1486532 - Don't generate optional payload properties in generic-worker payloads r=dustin", "files": ["taskcluster/taskgraph/transforms/task.py"], "git_node": null, "git_parents": [null], "node": "b5cd01655d9b04a8bf98ffec045b7ab1af23a7ff", "parents": ["beb55c2404a975df85b39d1fdf0c66a5fb01cf86"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1487985: webdriver: stop throwing away error causes; r=whimboo\n\nInstead of using a catch-all that ignores the error cause, we can\nprint the cause as part of the panic.\n\nEventually the error handling in this function should be fixed to\nnot panic at all, obviously.\n", "files": ["testing/webdriver/src/server.rs"], "git_node": null, "git_parents": [null], "node": "6d2ab43607b357e66123a21bcb7b27167389b869", "parents": ["b5cd01655d9b04a8bf98ffec045b7ab1af23a7ff"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1487988: webdriver: make single character patterns use chars; r=whimboo\n\nSingle-character constant patterns should be made into chars as\nthese are faster to use and does not require heap memory allocation.\n", "files": ["testing/webdriver/src/capabilities.rs", "testing/webdriver/src/httpapi.rs"], "git_node": null, "git_parents": [null], "node": "eba010e030a975936c3086286c145ffc25786a1a", "parents": ["6d2ab43607b357e66123a21bcb7b27167389b869"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1487992: webdriver: drop redundant return statements; r=whimboo\n", "files": ["testing/webdriver/src/capabilities.rs"], "git_node": null, "git_parents": [null], "node": "db4c6ff847e1c8f9cdb4c3ecca87f7092d5536c2", "parents": ["eba010e030a975936c3086286c145ffc25786a1a"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1487994: webdriver: avoid unnecessary passing by value; r=whimboo\n\nIn some places we pass variables by value unnecessarily.  In these\ncases it would be more memory efficient to pass a reference so that\nwe avoid copying.\n", "files": ["testing/webdriver/src/command.rs", "testing/webdriver/src/httpapi.rs", "testing/webdriver/src/server.rs"], "git_node": null, "git_parents": [null], "node": "d2f8b8c24ed15e77bfe37c02b9f54305c99decfd", "parents": ["db4c6ff847e1c8f9cdb4c3ecca87f7092d5536c2"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1487994: webdriver: fixup; r=me\n\nDONTBUILD\n", "files": ["testing/webdriver/src/server.rs"], "git_node": null, "git_parents": [null], "node": "47f0ff650a27298179d4f4c7f5fbe646ee97bf3b", "parents": ["d2f8b8c24ed15e77bfe37c02b9f54305c99decfd"], "tags": []}, {"author": "Lars T Hansen \u003clhansen@mozilla.com\u003e", "branch": "default", "desc": "Bug 1487327 - Custom section for opting in to GC feature work.  r=luke\n\nWe introduce a new numbered section which must be the first section in\nthe .wasm file if it is present at all.  This section, GcFeatureOptIn,\ncarries the version number of the GC feature the module wants to opt\nin to.\n\nDuring validation we signal an error if we can't satisfy the\nrequirement; and we signal errors for all the GC feature aspects\n(anyref, ref, struct, and all the ref-type instructions) if no opt-in\nsection was present.\n\nThis patch does not affect how we generate code for stubs; that code\nis controlled by the --wasm-gc flag, as it is module-independent.\n\nThis patch also does not change how we choose the compiler; that is\nstill based on --wasm-gc.  But once --wasm-gc disappears we will be\nusing the opt-in section to control compiler selection until Ion can\nsupport the GC feature.\n\nCurrently the only supported GC feature version is 1.  As the engine\nevolves to accomodate new versions we will accept old version numbers\nprovided the engine remains completely backward compatible.  (We can\nalso provide version-triggered backward compatibility but I question\nthe utility.)", "files": ["js/src/jit-test/lib/wasm-binary.js", "js/src/jit-test/tests/wasm/binary.js", "js/src/jit-test/tests/wasm/gc/anyref-global-postbarrier.js", "js/src/jit-test/tests/wasm/gc/anyref-global-prebarrier.js", "js/src/jit-test/tests/wasm/gc/anyref-val-tracing.js", "js/src/jit-test/tests/wasm/gc/anyref.js", "js/src/jit-test/tests/wasm/gc/binary.js", "js/src/jit-test/tests/wasm/gc/debugger.js", "js/src/jit-test/tests/wasm/gc/disabled.js", "js/src/jit-test/tests/wasm/gc/gc-feature-opt-in.js", "js/src/jit-test/tests/wasm/gc/ref-global.js", "js/src/jit-test/tests/wasm/gc/ref-restrict.js", "js/src/jit-test/tests/wasm/gc/ref.js", "js/src/jit-test/tests/wasm/gc/structs.js", "js/src/wasm/WasmAST.h", "js/src/wasm/WasmBaselineCompile.cpp", "js/src/wasm/WasmBinaryConstants.h", "js/src/wasm/WasmCode.cpp", "js/src/wasm/WasmCode.h", "js/src/wasm/WasmCompile.cpp", "js/src/wasm/WasmCompile.h", "js/src/wasm/WasmGenerator.cpp", "js/src/wasm/WasmIonCompile.cpp", "js/src/wasm/WasmModule.cpp", "js/src/wasm/WasmOpIter.h", "js/src/wasm/WasmStubs.cpp", "js/src/wasm/WasmStubs.h", "js/src/wasm/WasmTextToBinary.cpp", "js/src/wasm/WasmValidate.cpp", "js/src/wasm/WasmValidate.h"], "git_node": null, "git_parents": [null], "node": "c91d997687bf454984288ff865e05aa6a4e680ea", "parents": ["47f0ff650a27298179d4f4c7f5fbe646ee97bf3b"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1487995: webdriver: avoid redundant mapping closure; r=whimboo\n\nThe deserialised value is already Some({u,i}64).\n", "files": ["testing/webdriver/src/actions.rs"], "git_node": null, "git_parents": [null], "node": "70b142cc123a637c01f92a9a13683d43f017373a", "parents": ["c91d997687bf454984288ff865e05aa6a4e680ea"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1487997: webdriver: fix needless string formatting; r=whimboo\n\nAlso fixes some x.or() to x.or_else() so that the closures are not\nevaluated unless they have to be.\n", "files": ["testing/webdriver/src/capabilities.rs", "testing/webdriver/src/command.rs"], "git_node": null, "git_parents": [null], "node": "a7f1cad8ce399ed3a0018e454cb938b91a39388f", "parents": ["70b142cc123a637c01f92a9a13683d43f017373a"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1487999: webdriver: simplify cloning of merged_capabilities; r=whimboo\n\nWe clone merged_capabilities in the CapabilitiesMatching implementation\nfor SpecNewSessionParameters::match_browser using x.map(|x| x.clone()),\nbut this can be simplified to x.cloned().\n", "files": ["testing/webdriver/src/capabilities.rs"], "git_node": null, "git_parents": [null], "node": "7b3bb57b8ae346e08751a5adf44c650eb2e0f007", "parents": ["a7f1cad8ce399ed3a0018e454cb938b91a39388f"], "tags": []}, {"author": "Andreas Tolfsen \u003cato@sny.no\u003e", "branch": "default", "desc": "Bug 1488004: webdriver: use separators in MAX_SAFE_INTEGER definitiion; r=whimboo\n\nThis silences a clippy warning.\n", "files": ["testing/webdriver/src/common.rs"], "git_node": null, "git_parents": [null], "node": "5e069742950476fd81c546df7b26384a51d6cd7b", "parents": ["7b3bb57b8ae346e08751a5adf44c650eb2e0f007"], "tags": []}, {"author": "Ciure Andrei \u003caciure@mozilla.com\u003e", "branch": "default", "desc": "Merge inbound to mozilla-central. a=merge", "files": [], "git_node": null, "git_parents": [null, null], "node": "df61bdb0bc83acc349a7a283f7add907e6207bb7", "parents": ["d26ec598073acc11f0f6d3bcdbc429ba0066978e", "5e069742950476fd81c546df7b26384a51d6cd7b"], "tags": []}, {"author": "Ciure Andrei \u003caciure@mozilla.com\u003e", "branch": "default", "desc": "Merge mozilla-central to autoland.  a=merge CLOSED TREE", "files": [], "git_node": null, "git_par